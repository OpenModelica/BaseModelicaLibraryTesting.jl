    Real 'quadraticLoadTorqueM.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'quadraticLoadTorqueM.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'quadraticLoadTorqueM.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'quadraticLoadTorqueM.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of flange with respect to support (= flange.phi - support.phi)";
    parameter Real 'quadraticLoadTorqueM.tau_nominal'(unit = "N.m", quantity = "Torque") = -161.4 "Nominal torque (if negative, torque is acting as load in positive direction of rotation)";
    parameter Boolean 'quadraticLoadTorqueM.TorqueDirection' = false "Same direction of torque in both directions of rotation";
    parameter Real 'quadraticLoadTorqueM.w_nominal'(min = 2.220446049250313e-16, unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal speed";
    Real 'quadraticLoadTorqueM.w'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange with respect to support (= der(phi))";
    Real 'quadraticLoadTorqueM.tau'(unit = "N.m", quantity = "Torque") "Accelerating torque acting at flange (= -flange.tau)";
    parameter Boolean 'quadraticLoadTorqueE.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'quadraticLoadTorqueE.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'quadraticLoadTorqueE.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'quadraticLoadTorqueE.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'quadraticLoadTorqueE.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of flange with respect to support (= flange.phi - support.phi)";
    parameter Real 'quadraticLoadTorqueE.tau_nominal'(unit = "N.m", quantity = "Torque") = -161.4 "Nominal torque (if negative, torque is acting as load in positive direction of rotation)";
    parameter Boolean 'quadraticLoadTorqueE.TorqueDirection' = false "Same direction of torque in both directions of rotation";
    parameter Real 'quadraticLoadTorqueE.w_nominal'(min = 2.220446049250313e-16, unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal speed";
    Real 'quadraticLoadTorqueE.w'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange with respect to support (= der(phi))";
    Real 'quadraticLoadTorqueE.tau'(unit = "N.m", quantity = "Torque") "Accelerating torque acting at flange (= -flange.tau)";
    parameter Integer 'aimcData.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'aimcData.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Real 'aimcData.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Integer 'aimcData.p'(min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'aimcData.fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'aimcData.Rs'(unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'aimcData.TsRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'aimcData.alpha20s'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'aimcData.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'aimcData.Lszero'(unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator zero sequence inductance";
    parameter Real 'aimcData.Lssigma'(unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator stray inductance per phase";
    parameter Real 'aimcData.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'aimcData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'aimcData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'aimcData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'aimcData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'aimcData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'aimcData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'aimcData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'aimcData.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'aimcData.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'aimcData.statorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'aimcData.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'aimcData.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'aimcData.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'aimcData.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'aimcData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'aimcData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'aimcData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'aimcData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'aimcData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'aimcData.Lm'(unit = "H", quantity = "Inductance") = 0.009225332222963813 "Stator main field inductance per phase";
    parameter Real 'aimcData.Lrsigma'(unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Rotor stray inductance per phase (equivalent three-phase winding)";
    parameter Real 'aimcData.Rr'(unit = "Ohm", quantity = "Resistance") = 0.04 "Rotor resistance per phase (equivalent three-phase winding) at TRef";
    parameter Real 'aimcData.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of rotor resistance";
    parameter Real 'aimcData.alpha20r'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of rotor resistance at 20 degC";
    parameter Integer 'currentQuasiRMSSensor.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
