  initial equation
    'aimcE.is[1]' = 0.0;
    'aimcE.is[2]' = 0.0;
    'aimcE.is[3]' = 0.0;
    'aimcE.ir[1]' = 0.0;
    'aimcE.ir[2]' = 0.0;
    'aimcM.is[1]' = 0.0;
    'aimcM.is[2]' = 0.0;
    'aimcM.is[3]' = 0.0;
    'aimcM.rotorCage.electroMagneticConverter.Phi.re' = 0.0;
    'aimcM.rotorCage.electroMagneticConverter.Phi.im' = 0.0;
  equation
    'aimcM.phiMechanical' = 'aimcM.flange.phi' - 'aimcM.internalSupport.phi';
    'aimcM.wMechanical' = der('aimcM.phiMechanical');
    'aimcM.tauElectrical' = 'aimcM.inertiaRotor.flange_a.tau';
    'aimcM.tauShaft' = -'aimcM.flange.tau';
    'aimcM.powerBalance.powerStator' = 'Modelica.Electrical.Polyphase.Functions.activePower'('aimcM.vs', 'aimcM.is');
    'aimcM.powerBalance.powerMechanical' = 'aimcM.wMechanical' * 'aimcM.tauShaft';
    'aimcM.powerBalance.powerInertiaStator' = 0.29 * 'aimcM.inertiaStator.a' * 'aimcM.inertiaStator.w';
    'aimcM.powerBalance.powerInertiaRotor' = 0.29 * 'aimcM.inertiaRotor.a' * 'aimcM.inertiaRotor.w';
    'aimcM.powerBalance.lossPowerTotal' = 'aimcM.powerBalance.lossPowerStatorWinding' + 'aimcM.powerBalance.lossPowerStatorCore' + 'aimcM.powerBalance.lossPowerRotorCore' + 'aimcM.powerBalance.lossPowerStrayLoad' + 'aimcM.powerBalance.lossPowerFriction' + 'aimcM.powerBalance.lossPowerRotorWinding';
    'aimcM.powerBalance.lossPowerStatorWinding' = 'aimcM.stator.resistor.resistor[1].LossPower' + 'aimcM.stator.resistor.resistor[2].LossPower' + 'aimcM.stator.resistor.resistor[3].LossPower';
    'aimcM.powerBalance.lossPowerStatorCore' = 'aimcM.stator.core.lossPower';
    'aimcM.powerBalance.lossPowerRotorCore' = 0.0;
    'aimcM.powerBalance.lossPowerStrayLoad' = 'aimcM.strayLoad.lossPower';
    'aimcM.powerBalance.lossPowerFriction' = 'aimcM.friction.lossPower';
    'aimcM.powerBalance.lossPowerRotorWinding' = 'aimcM.rotorCage.resistor.resistor[1].LossPower' + 'aimcM.rotorCage.resistor.resistor[2].LossPower' + 'aimcM.rotorCage.resistor.resistor[3].LossPower';
    'aimcM.stator.abs_V_m' = 'Modelica.ComplexMath.abs'('aimcM.stator.V_m');
    'aimcM.stator.arg_V_m' = 'Modelica.ComplexMath.arg'('aimcM.stator.V_m', 0.0);
    'aimcM.stator.Phi.re' = 'aimcM.stator.port_p.Phi.re';
    'aimcM.stator.Phi.im' = 'aimcM.stator.port_p.Phi.im';
    'aimcM.stator.abs_Phi' = 'Modelica.ComplexMath.abs'('aimcM.stator.Phi');
    'aimcM.stator.arg_Phi' = 'Modelica.ComplexMath.arg'('aimcM.stator.Phi', 0.0);
    'aimcM.stator.electroMagneticConverter.abs_V_m' = 'Modelica.ComplexMath.abs'('aimcM.stator.electroMagneticConverter.V_m');
    'aimcM.stator.electroMagneticConverter.arg_V_m' = 'Modelica.ComplexMath.arg'('aimcM.stator.electroMagneticConverter.V_m', 0.0);
    'aimcM.stator.electroMagneticConverter.Phi.re' = 'aimcM.stator.electroMagneticConverter.port_p.Phi.re';
    'aimcM.stator.electroMagneticConverter.Phi.im' = 'aimcM.stator.electroMagneticConverter.port_p.Phi.im';
    'aimcM.stator.electroMagneticConverter.abs_Phi' = 'Modelica.ComplexMath.abs'('aimcM.stator.electroMagneticConverter.Phi');
    'aimcM.stator.electroMagneticConverter.arg_Phi' = 'Modelica.ComplexMath.arg'('aimcM.stator.electroMagneticConverter.Phi', 0.0);
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_V_m' = 'Modelica.ComplexMath.abs'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m');
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].arg_V_m' = 'Modelica.ComplexMath.arg'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m', 0.0);
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_Phi' = 'Modelica.ComplexMath.abs'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi');
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].arg_Phi' = 'Modelica.ComplexMath.arg'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi', 0.0);
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_V_m' = 'Modelica.ComplexMath.abs'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m');
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_V_m' = 'Modelica.ComplexMath.arg'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m', 0.0);
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_Phi' = 'Modelica.ComplexMath.abs'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi');
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_Phi' = 'Modelica.ComplexMath.arg'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi', 0.0);
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].abs_V_m' = 'Modelica.ComplexMath.abs'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m');
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].arg_V_m' = 'Modelica.ComplexMath.arg'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m', 0.0);
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].abs_Phi' = 'Modelica.ComplexMath.abs'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi');
    'aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].arg_Phi' = 'Modelica.ComplexMath.arg'('aimcM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi', 0.0);
    'aimcM.stator.resistor.resistor[1].heatPort.T' = 'aimcM.stator.resistor.resistor[1].T_heatPort';
    'aimcM.stator.resistor.resistor[1].heatPort.Q_flow' = -'aimcM.stator.resistor.resistor[1].LossPower';
    'aimcM.stator.resistor.resistor[2].heatPort.T' = 'aimcM.stator.resistor.resistor[2].T_heatPort';
    'aimcM.stator.resistor.resistor[2].heatPort.Q_flow' = -'aimcM.stator.resistor.resistor[2].LossPower';
    'aimcM.stator.resistor.resistor[3].heatPort.T' = 'aimcM.stator.resistor.resistor[3].T_heatPort';
    'aimcM.stator.resistor.resistor[3].heatPort.Q_flow' = -'aimcM.stator.resistor.resistor[3].LossPower';
    'aimcM.stator.core.abs_V_m' = 'Modelica.ComplexMath.abs'('aimcM.stator.core.V_m');
    'aimcM.stator.core.arg_V_m' = 'Modelica.ComplexMath.arg'('aimcM.stator.core.V_m', 0.0);
    'aimcM.stator.core.Phi.re' = 'aimcM.stator.core.port_p.Phi.re';
    'aimcM.stator.core.Phi.im' = 'aimcM.stator.core.port_p.Phi.im';
    'aimcM.stator.core.abs_Phi' = 'Modelica.ComplexMath.abs'('aimcM.stator.core.Phi');
    'aimcM.stator.core.arg_Phi' = 'Modelica.ComplexMath.arg'('aimcM.stator.core.Phi', 0.0);
    'aimcM.stator.core.heatPort.T' = 'aimcM.stator.core.TheatPort';
    'aimcM.stator.core.heatPort.Q_flow' = -'aimcM.stator.core.lossPower';
    'aimcM.stator.stray.abs_V_m' = 'Modelica.ComplexMath.abs'('aimcM.stator.stray.V_m');
    'aimcM.stator.stray.arg_V_m' = 'Modelica.ComplexMath.arg'('aimcM.stator.stray.V_m', 0.0);
