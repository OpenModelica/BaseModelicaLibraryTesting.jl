//! base 0.1.0
package 'IdealGasH2O'
  function 'Modelica.Math.log' "Natural (base e) logarithm (u shall be > 0)"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := log('u');
    annotation(Inline = true);
  end 'Modelica.Math.log';

  function 'Modelica.Media.Common.smoothStep' "Approximation of a general step, such that the characteristic is continuous and differentiable"
    input Real 'x';
    input Real 'y1';
    input Real 'y2';
    input Real 'x_small'(min = 0.0) = 1e-5;
    output Real 'y';
  algorithm
    'y' := smooth(1, if 'x' > 'x_small' then 'y1' else if 'x' < (-'x_small') then 'y2' else if abs('x_small') > 0.0 then 'x' / 'x_small' * (('x' / 'x_small') ^ 2.0 - 3.0) * ('y2' - 'y1') / 4.0 + ('y1' + 'y2') / 2.0 else ('y1' + 'y2') / 2.0);
    annotation(Inline = true, smoothOrder = 1);
  end 'Modelica.Media.Common.smoothStep';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.density' "Return density of ideal gas"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 10.0, start = 10.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'state'.'p' / (461.5254384056201 * 'state'.'T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.density';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.isentropicEnthalpyApproximation' "Approximate method of calculating h_is from upstream properties and downstream pressure"
    input Real 'p2'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input 'Medium.ThermodynamicState' 'state';
    input Boolean 'exclEnthForm' = true;
    input 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' 'refChoice' = 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K';
    input Real 'h_off'(nominal = 1e5, start = 549760.6476280135, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 0.0;
    output Real 'h_is'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'gamma'(nominal = 1.2, start = 1.2, max = 5e5, min = 1.0, unit = "1", quantity = "RatioOfSpecificHeatCapacities") = 'Modelica.Media.Examples.IdealGasH2O.Medium.isentropicExponent'('state');
  algorithm
    'h_is' := 'Modelica.Media.IdealGases.Common.Functions.h_T'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'state'.'T', 'exclEnthForm', 'refChoice', 'h_off') + 'gamma' / ('gamma' - 1.0) * 'state'.'p' / 'Modelica.Media.Examples.IdealGasH2O.Medium.density'('state') * (('p2' / 'state'.'p') ^ (('gamma' - 1.0) / 'gamma') - 1.0);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.isentropicEnthalpyApproximation';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.isentropicExponent' "Return isentropic exponent"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'gamma'(nominal = 1.2, start = 1.2, max = 5e5, min = 1.0, unit = "1", quantity = "RatioOfSpecificHeatCapacities");
  algorithm
    'gamma' := 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCp'('state') / 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCv'('state');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.isentropicExponent';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.isobaricExpansionCoefficient' "Returns overall the isobaric expansion coefficient beta"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'beta'(max = 1e8, min = 0.0, unit = "1/K");
  algorithm
    'beta' := 1.0 / 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.isobaricExpansionCoefficient';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.isothermalCompressibility' "Returns overall the isothermal compressibility factor"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'kappa'(unit = "1/Pa", quantity = "Compressibility");
  algorithm
    'kappa' := 1.0 / 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.isothermalCompressibility';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.setSmoothState' "Return thermodynamic state so that it smoothly approximates: if x > 0 then state_a else state_b"
    input Real 'x';
    input 'Medium.ThermodynamicState' 'state_a';
    input 'Medium.ThermodynamicState' 'state_b';
    input Real 'x_small'(min = 0.0);
    output 'Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'Medium.ThermodynamicState'('Modelica.Media.Common.smoothStep'('x', 'state_a'.'p', 'state_b'.'p', 'x_small'), 'Modelica.Media.Common.smoothStep'('x', 'state_a'.'T', 'state_b'.'T', 'x_small'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.setSmoothState';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.specificEntropy' "Return specific entropy"
    input 'Medium.ThermodynamicState' 'state';
    output Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
  algorithm
    's' := 'Modelica.Media.IdealGases.Common.Functions.s0_T'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'state'.'T') - 461.5254384056201 * 'Modelica.Math.log'('state'.'p' / 101325.0);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.specificEntropy';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCp' "Return specific heat capacity at constant pressure"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'cp'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'cp' := 'Modelica.Media.IdealGases.Common.Functions.cp_T'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'state'.'T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCp';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCv' "Compute specific heat capacity at constant volume from temperature and gas data"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'cv'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'cv' := 'Modelica.Media.IdealGases.Common.Functions.cp_T'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'state'.'T') - 461.5254384056201;
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCv';

  function 'Modelica.Media.Examples.IdealGasH2O.Medium.velocityOfSound' "Return velocity of sound"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'a'(nominal = 1000.0, start = 1000.0, max = 1e5, min = 0.0, unit = "m/s", quantity = "Velocity");
  algorithm
    'a' := sqrt(max(0.0, 461.5254384056201 * 'state'.'T' * 'Modelica.Media.IdealGases.Common.Functions.cp_T'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'state'.'T') / 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCv'('state')));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.IdealGasH2O.Medium.velocityOfSound';

  function 'Modelica.Media.IdealGases.Common.Functions.cp_T' "Compute specific heat capacity at constant pressure from temperature and gas data"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'cp' := smooth(0, if 'T' < 'data'.'Tlimit' then 'data'.'R_s' * (1.0 / ('T' * 'T') * ('data'.'alow'[1] + 'T' * ('data'.'alow'[2] + 'T' * ('data'.'alow'[3] + 'T' * ('data'.'alow'[4] + 'T' * ('data'.'alow'[5] + 'T' * ('data'.'alow'[6] + 'data'.'alow'[7] * 'T'))))))) else 'data'.'R_s' * (1.0 / ('T' * 'T') * ('data'.'ahigh'[1] + 'T' * ('data'.'ahigh'[2] + 'T' * ('data'.'ahigh'[3] + 'T' * ('data'.'ahigh'[4] + 'T' * ('data'.'ahigh'[5] + 'T' * ('data'.'ahigh'[6] + 'data'.'ahigh'[7] * 'T'))))))));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.cp_T';

  function 'Modelica.Media.IdealGases.Common.Functions.h_T' "Compute specific enthalpy from temperature and gas data; reference is decided by the
    refChoice input, or by the referenceChoice package constant by default"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'exclEnthForm' = true;
    input 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' 'refChoice' = 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K';
    input Real 'h_off'(unit = "J/kg", quantity = "SpecificEnergy") = 0.0;
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := smooth(0, (if 'T' < 'data'.'Tlimit' then 'data'.'R_s' * (('T' * ('data'.'blow'[1] + 'data'.'alow'[2] * 'Modelica.Math.log'('T') + 'T' * ('data'.'alow'[3] + 'T' * (0.5 * 'data'.'alow'[4] + 'T' * (0.3333333333333333 * 'data'.'alow'[5] + 'T' * (0.25 * 'data'.'alow'[6] + 0.2 * 'data'.'alow'[7] * 'T'))))) - 'data'.'alow'[1]) / 'T') else 'data'.'R_s' * (('T' * ('data'.'bhigh'[1] + 'data'.'ahigh'[2] * 'Modelica.Math.log'('T') + 'T' * ('data'.'ahigh'[3] + 'T' * (0.5 * 'data'.'ahigh'[4] + 'T' * (0.3333333333333333 * 'data'.'ahigh'[5] + 'T' * (0.25 * 'data'.'ahigh'[6] + 0.2 * 'data'.'ahigh'[7] * 'T'))))) - 'data'.'ahigh'[1]) / 'T')) + (if 'exclEnthForm' then -'data'.'Hf' else 0.0) + (if 'refChoice' == 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K' then 'data'.'H0' else 0.0) + (if 'refChoice' == 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined' then 'h_off' else 0.0));
    annotation(Inline = false, smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.h_T';

  function 'Modelica.Media.IdealGases.Common.Functions.s0_T' "Compute specific entropy from temperature and gas data"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 's'(unit = "J/(kg.K)", quantity = "SpecificEntropy");
  algorithm
    's' := if 'T' < 'data'.'Tlimit' then 'data'.'R_s' * ('data'.'blow'[2] - 0.5 * 'data'.'alow'[1] / ('T' * 'T') - 'data'.'alow'[2] / 'T' + 'data'.'alow'[3] * 'Modelica.Math.log'('T') + 'T' * ('data'.'alow'[4] + 'T' * (0.5 * 'data'.'alow'[5] + 'T' * (0.3333333333333333 * 'data'.'alow'[6] + 0.25 * 'data'.'alow'[7] * 'T')))) else 'data'.'R_s' * ('data'.'bhigh'[2] - 0.5 * 'data'.'ahigh'[1] / ('T' * 'T') - 'data'.'ahigh'[2] / 'T' + 'data'.'ahigh'[3] * 'Modelica.Math.log'('T') + 'T' * ('data'.'ahigh'[4] + 'T' * (0.5 * 'data'.'ahigh'[5] + 'T' * (0.3333333333333333 * 'data'.'ahigh'[6] + 0.25 * 'data'.'ahigh'[7] * 'T'))));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.s0_T';

  record 'Medium.ThermodynamicState'
    Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  end 'Medium.ThermodynamicState';

  type 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' = enumeration('ZeroAt0K', 'ZeroAt25C', 'UserDefined');

  record 'Modelica.Media.IdealGases.Common.DataRecord'
    String 'name';
    Real 'MM'(min = 0.0, unit = "kg/mol", quantity = "MolarMass");
    Real 'Hf'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'H0'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'Tlimit'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[7] 'alow';
    Real[2] 'blow';
    Real[7] 'ahigh';
    Real[2] 'bhigh';
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  end 'Modelica.Media.IdealGases.Common.DataRecord';

  model 'IdealGasH2O' "IdealGas H20 medium model"
    Real 'state.p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'state.T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'state2.p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'state2.T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'cp'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cv'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'k'(nominal = 1.2, start = 1.2, max = 5e5, min = 1.0, unit = "1", quantity = "RatioOfSpecificHeatCapacities");
    Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real 'a'(nominal = 1000.0, start = 1000.0, max = 1e5, min = 0.0, unit = "m/s", quantity = "Velocity");
    Real 'beta';
    Real 'gamma';
    Real 'h_is'(nominal = 1e5, start = 549760.6476280135, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    Real 'smoothState.p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'smoothState.T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'm_flow_ext';
    Real 'der_p';
    Real 'der_T';
    parameter Real 'p01'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "state.p at time 0";
    parameter Real 'pRate1'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope") = 0.0 "state.p rate of change";
    parameter Real 'T01'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 200.0 "state.T at time 0";
    parameter Real 'Trate1'(unit = "K/s", quantity = "TemperatureSlope") = 1000.0 "state.T rate of change";
    parameter Real 'p02'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2e5 "state2.p at time 0";
    parameter Real 'pRate2'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope") = 0.0 "state2.p rate of change";
    parameter Real 'T02'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 500.0 "state2.T at time 0";
    parameter Real 'Trate2'(unit = "K/s", quantity = "TemperatureSlope") = 0.0 "state2.T rate of change";
  equation
    'cp' = 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCp'('state');
    'cv' = 'Modelica.Media.Examples.IdealGasH2O.Medium.specificHeatCapacityCv'('state');
    'k' = 'Modelica.Media.Examples.IdealGasH2O.Medium.isentropicExponent'('state');
    's' = 'Modelica.Media.Examples.IdealGasH2O.Medium.specificEntropy'('state');
    'a' = 'Modelica.Media.Examples.IdealGasH2O.Medium.velocityOfSound'('state');
    'beta' = 'Modelica.Media.Examples.IdealGasH2O.Medium.isobaricExpansionCoefficient'('state');
    'gamma' = 'Modelica.Media.Examples.IdealGasH2O.Medium.isothermalCompressibility'('state');
    'h_is' = 'Modelica.Media.Examples.IdealGasH2O.Medium.isentropicEnthalpyApproximation'(2.0, 'state', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0);
    'state.p' = 1e5;
    'state.T' = 200.0 + 1000.0 * time;
    'state2.p' = 2e5;
    'state2.T' = 500.0;
    'm_flow_ext' = time - 0.5;
    'smoothState.p' = ('Modelica.Media.Examples.IdealGasH2O.Medium.setSmoothState'('m_flow_ext', 'state', 'state2', 0.1)).p;
    'smoothState.T' = ('Modelica.Media.Examples.IdealGasH2O.Medium.setSmoothState'('m_flow_ext', 'state', 'state2', 0.1)).T;
    'der_p' = der('smoothState.p');
    'der_T' = der('smoothState.T');
    annotation(experiment(StopTime = 1));
  end 'IdealGasH2O';
end 'IdealGasH2O';
