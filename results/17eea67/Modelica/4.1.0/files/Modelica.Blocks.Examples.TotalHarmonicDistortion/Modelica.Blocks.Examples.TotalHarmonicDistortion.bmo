    Real 'thdRMS.division.u1' "Connector of Real input signal 1";
    Real 'thdRMS.division.u2' "Connector of Real input signal 2";
    Real 'thdRMS.division.y' "Connector of Real output signal";
    parameter Real 'thdRMS.limiter.uMax'(start = 1.0) = 1e60 "Upper limits of input signals";
    parameter Real 'thdRMS.limiter.uMin' = 2.220446049250313e-16 "Lower limits of input signals";
    parameter Boolean 'thdRMS.limiter.strict' = false "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.LimiterHomotopy' 'thdRMS.limiter.homotopyType' = 'Modelica.Blocks.Types.LimiterHomotopy'.'Linear' "Simplified model for homotopy-based initialization" annotation(Evaluate = true);
    Real 'thdRMS.limiter.u' "Connector of Real input signal";
    Real 'thdRMS.limiter.y' "Connector of Real output signal";
    Real 'thdRMS.limiter.simplifiedExpr' "Simplified expression for homotopy-based initialization";
    Real 'thdRMS.pythagoras.u1' "Connector of Real input signal 1";
    Real 'thdRMS.pythagoras.u2' "Connector of Real input signal 2";
    Real 'thdRMS.pythagoras.y' "Connector of Real output signal";
    parameter Boolean 'thdRMS.pythagoras.u1IsHypotenuse' = true "= true, if u1 is the hypotenuse and y is one leg";
    Boolean 'thdRMS.pythagoras.valid' "= true, if y is a valid result";
    Real 'thdRMS.pythagoras.y2' "Square of y";
    Boolean 'thdRMS.andValid.u1' "Connector of first Boolean input signal";
    Boolean 'thdRMS.andValid.u2' "Connector of second Boolean input signal";
    Boolean 'thdRMS.andValid.y' "Connector of Boolean output signal";
    Boolean 'thdRMS.booleanExpression.y' "Value of Boolean output";
    Real 'thdRMS.switch1.u1' "Connector of first Real input signal";
    Boolean 'thdRMS.switch1.u2' "Connector of Boolean input signal";
    Real 'thdRMS.switch1.u3' "Connector of second Real input signal";
    Real 'thdRMS.switch1.y' "Connector of Real output signal";
  initial equation
    'thd1.harmonic.mean1.t0' = time;
    'thd1.harmonic.mean1.x' = 0.0;
    'thd1.harmonic.mean1.y_last' = 0.0;
    'thd1.harmonic.mean2.t0' = time;
    'thd1.harmonic.mean2.x' = 0.0;
    'thd1.harmonic.mean2.y_last' = 0.0;
    'thd1.rootMeanSquare.mean.t0' = time;
    'thd1.rootMeanSquare.mean.x' = 0.0;
    'thd1.rootMeanSquare.mean.y_last' = 0.0;
    'thdRMS.harmonic.mean1.t0' = time;
    'thdRMS.harmonic.mean1.x' = 0.0;
    'thdRMS.harmonic.mean1.y_last' = 0.0;
    'thdRMS.harmonic.mean2.t0' = time;
    'thdRMS.harmonic.mean2.x' = 0.0;
    'thdRMS.harmonic.mean2.y_last' = 0.0;
    'thdRMS.rootMeanSquare.mean.t0' = time;
    'thdRMS.rootMeanSquare.mean.x' = 0.0;
    'thdRMS.rootMeanSquare.mean.y_last' = 0.0;
  equation
    'thd1.booleanExpression.y' = false;
    'thdRMS.booleanExpression.y' = true;
    'thd1.harmonic.product2.y' = 'thd1.harmonic.mean2.u';
    'thd1.harmonic.product1.y' = 'thd1.harmonic.mean1.u';
    'thd1.harmonic.mean1.y' = 'thd1.harmonic.rectangularToPolar.u_re';
    'thd1.harmonic.mean2.y' = 'thd1.harmonic.rectangularToPolar.u_im';
    'thd1.harmonic.rectangularToPolar.y_abs' = 'thd1.harmonic.y_rms';
    'thd1.harmonic.sin1.y' = 'thd1.harmonic.product1.u[1]';
    'thd1.harmonic.u' = 'thd1.harmonic.product2.u[1]';
    'thd1.harmonic.u' = 'thd1.harmonic.product1.u[2]';
    'thd1.harmonic.sin2.y' = 'thd1.harmonic.product2.u[2]';
    'thd1.harmonic.rectangularToPolar.y_arg' = 'thd1.harmonic.gain.u';
    'thd1.harmonic.gain.y' = 'thd1.harmonic.y_arg';
    'thd1.rootMeanSquare.product.y' = 'thd1.rootMeanSquare.mean.u';
    'thd1.rootMeanSquare.mean.y' = 'thd1.rootMeanSquare.sqrt1.u';
    'thd1.rootMeanSquare.sqrt1.y' = 'thd1.rootMeanSquare.y';
    'thd1.rootMeanSquare.u' = 'thd1.rootMeanSquare.product.u[2]';
    'thd1.rootMeanSquare.u' = 'thd1.rootMeanSquare.product.u[1]';
    'thd1.u' = 'thd1.harmonic.u';
    'thd1.u' = 'thd1.rootMeanSquare.u';
    'thd1.division.y' = 'thd1.y';
    'thd1.switch1.u1' = 'thd1.rootMeanSquare.y';
    'thd1.switch1.u1' = 'thd1.pythagoras.u1';
    'thd1.pythagoras.y' = 'thd1.division.u1';
    'thd1.pythagoras.valid' = 'thd1.andValid.u1';
    'thd1.greaterThreshold.y' = 'thd1.andValid.u2';
    'thd1.andValid.y' = 'thd1.valid';
    'thd1.limiter.y' = 'thd1.division.u2';
    'thd1.harmonic.y_rms' = 'thd1.switch1.u3';
    'thd1.harmonic.y_rms' = 'thd1.pythagoras.u2';
    'thd1.harmonic.y_rms' = 'thd1.greaterThreshold.u';
    'thd1.booleanExpression.y' = 'thd1.switch1.u2';
    'thd1.switch1.y' = 'thd1.limiter.u';
    'thdRMS.harmonic.product2.y' = 'thdRMS.harmonic.mean2.u';
    'thdRMS.harmonic.product1.y' = 'thdRMS.harmonic.mean1.u';
    'thdRMS.harmonic.mean1.y' = 'thdRMS.harmonic.rectangularToPolar.u_re';
    'thdRMS.harmonic.mean2.y' = 'thdRMS.harmonic.rectangularToPolar.u_im';
    'thdRMS.harmonic.rectangularToPolar.y_abs' = 'thdRMS.harmonic.y_rms';
    'thdRMS.harmonic.sin1.y' = 'thdRMS.harmonic.product1.u[1]';
    'thdRMS.harmonic.u' = 'thdRMS.harmonic.product2.u[1]';
    'thdRMS.harmonic.u' = 'thdRMS.harmonic.product1.u[2]';
    'thdRMS.harmonic.sin2.y' = 'thdRMS.harmonic.product2.u[2]';
    'thdRMS.harmonic.rectangularToPolar.y_arg' = 'thdRMS.harmonic.gain.u';
    'thdRMS.harmonic.gain.y' = 'thdRMS.harmonic.y_arg';
    'thdRMS.rootMeanSquare.product.y' = 'thdRMS.rootMeanSquare.mean.u';
    'thdRMS.rootMeanSquare.mean.y' = 'thdRMS.rootMeanSquare.sqrt1.u';
    'thdRMS.rootMeanSquare.sqrt1.y' = 'thdRMS.rootMeanSquare.y';
    'thdRMS.rootMeanSquare.u' = 'thdRMS.rootMeanSquare.product.u[2]';
    'thdRMS.rootMeanSquare.u' = 'thdRMS.rootMeanSquare.product.u[1]';
    'thdRMS.u' = 'thdRMS.harmonic.u';
    'thdRMS.u' = 'thdRMS.rootMeanSquare.u';
    'thdRMS.division.y' = 'thdRMS.y';
    'thdRMS.switch1.u1' = 'thdRMS.rootMeanSquare.y';
    'thdRMS.switch1.u1' = 'thdRMS.pythagoras.u1';
    'thdRMS.pythagoras.y' = 'thdRMS.division.u1';
    'thdRMS.pythagoras.valid' = 'thdRMS.andValid.u1';
    'thdRMS.greaterThreshold.y' = 'thdRMS.andValid.u2';
    'thdRMS.andValid.y' = 'thdRMS.valid';
    'thdRMS.limiter.y' = 'thdRMS.division.u2';
    'thdRMS.harmonic.y_rms' = 'thdRMS.switch1.u3';
    'thdRMS.harmonic.y_rms' = 'thdRMS.pythagoras.u2';
    'thdRMS.harmonic.y_rms' = 'thdRMS.greaterThreshold.u';
    'thdRMS.booleanExpression.y' = 'thdRMS.switch1.u2';
    'thdRMS.switch1.y' = 'thdRMS.limiter.u';
    'voltageSensor.p.v' = 'sineVoltage3.p.v';
    'sineVoltage3.n.v' = 'sineVoltage1.p.v';
    'ground.p.v' = 'voltageSensor.n.v';
    'ground.p.v' = 'sineVoltage1.n.v';
    'voltageSensor.v' = 'thdRMS.u';
    'voltageSensor.v' = 'thd1.u';
    'sineVoltage1.p.i' + 'sineVoltage3.n.i' = 0.0;
    'voltageSensor.n.i' + 'sineVoltage1.n.i' + 'ground.p.i' = 0.0;
    'voltageSensor.p.i' + 'sineVoltage3.p.i' = 0.0;
    'ground.p.v' = 0.0;
    'sineVoltage3.signalSource.y' = if time < 0.02 then 0.0 else 28.284271247461902 * 'Modelica.Math.sin'(942.4777960769379 * (time - 0.02));
    'sineVoltage3.v' = 'sineVoltage3.signalSource.y';
    0.0 = 'sineVoltage3.p.i' + 'sineVoltage3.n.i';
    'sineVoltage3.i' = 'sineVoltage3.p.i';
    'sineVoltage3.v' = 'sineVoltage3.p.v' - 'sineVoltage3.n.v';
    'sineVoltage1.signalSource.y' = if time < 0.02 then 0.0 else 141.4213562373095 * 'Modelica.Math.sin'(314.1592653589793 * (time - 0.02));
    'sineVoltage1.v' = 'sineVoltage1.signalSource.y';
    0.0 = 'sineVoltage1.p.i' + 'sineVoltage1.n.i';
    'sineVoltage1.i' = 'sineVoltage1.p.i';
    'sineVoltage1.v' = 'sineVoltage1.p.v' - 'sineVoltage1.n.v';
    'voltageSensor.p.i' = 0.0;
    'voltageSensor.n.i' = 0.0;
    'voltageSensor.v' = 'voltageSensor.p.v' - 'voltageSensor.n.v';
    'thd1.harmonic.sin1.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.cos'(314.1592653589793 * time);
    'thd1.harmonic.sin2.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.sin'(314.1592653589793 * time);
    'thd1.harmonic.product1.y' = 'thd1.harmonic.product1.u[1]' * 'thd1.harmonic.product1.u[2]';
    'thd1.harmonic.product2.y' = 'thd1.harmonic.product2.u[1]' * 'thd1.harmonic.product2.u[2]';
    der('thd1.harmonic.mean1.x') = 'thd1.harmonic.mean1.u';

    when sample('thd1.harmonic.mean1.t0' + 0.02, 0.02) then
      'thd1.harmonic.mean1.y_last' = 50.0 * pre('thd1.harmonic.mean1.x');
      reinit('thd1.harmonic.mean1.x', 0.0);
    end when;

    'thd1.harmonic.mean1.y' = 'thd1.harmonic.mean1.y_last';
    der('thd1.harmonic.mean2.x') = 'thd1.harmonic.mean2.u';

    when sample('thd1.harmonic.mean2.t0' + 0.02, 0.02) then
      'thd1.harmonic.mean2.y_last' = 50.0 * pre('thd1.harmonic.mean2.x');
      reinit('thd1.harmonic.mean2.x', 0.0);
    end when;

    'thd1.harmonic.mean2.y' = 'thd1.harmonic.mean2.y_last';
    'thd1.harmonic.rectangularToPolar.y_abs' = sqrt('thd1.harmonic.rectangularToPolar.u_re' * 'thd1.harmonic.rectangularToPolar.u_re' + 'thd1.harmonic.rectangularToPolar.u_im' * 'thd1.harmonic.rectangularToPolar.u_im');
    'thd1.harmonic.rectangularToPolar.y_arg' = 'Modelica.Math.atan2'('thd1.harmonic.rectangularToPolar.u_im', 'thd1.harmonic.rectangularToPolar.u_re');
    'thd1.harmonic.gain.y' = 'thd1.harmonic.gain.u';
    'thd1.rootMeanSquare.product.y' = 'thd1.rootMeanSquare.product.u[1]' * 'thd1.rootMeanSquare.product.u[2]';
    der('thd1.rootMeanSquare.mean.x') = 'thd1.rootMeanSquare.mean.u';

    when sample('thd1.rootMeanSquare.mean.t0' + 0.02, 0.02) then
      'thd1.rootMeanSquare.mean.y_last' = max(0.0, 50.0 * pre('thd1.rootMeanSquare.mean.x'));
      reinit('thd1.rootMeanSquare.mean.x', 0.0);
    end when;

    'thd1.rootMeanSquare.mean.y' = 'thd1.rootMeanSquare.mean.y_last';
    'thd1.rootMeanSquare.sqrt1.y' = sqrt('thd1.rootMeanSquare.sqrt1.u');
    'thd1.greaterThreshold.y' = 'thd1.greaterThreshold.u' > 0.0;
    'thd1.division.y' = 'thd1.division.u1' / 'thd1.division.u2';
    'thd1.limiter.simplifiedExpr' = 'thd1.limiter.u';
    'thd1.limiter.y' = homotopy(smooth(0, if 'thd1.limiter.u' > 1e60 then 1e60 else if 'thd1.limiter.u' < 2.220446049250313e-16 then 2.220446049250313e-16 else 'thd1.limiter.u'), 'thd1.limiter.simplifiedExpr');
    'thd1.pythagoras.y2' = 'thd1.pythagoras.u1' ^ 2.0 - 'thd1.pythagoras.u2' ^ 2.0;
    'thd1.pythagoras.valid' = 'thd1.pythagoras.y2' >= 0.0;
    'thd1.pythagoras.y' = if noEvent('thd1.pythagoras.y2' >= 0.0) then sqrt('thd1.pythagoras.y2') else 0.0;
    'thd1.andValid.y' = 'thd1.andValid.u1' and 'thd1.andValid.u2';
    'thd1.switch1.y' = if 'thd1.switch1.u2' then 'thd1.switch1.u1' else 'thd1.switch1.u3';
    'thdRMS.harmonic.sin1.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.cos'(314.1592653589793 * time);
    'thdRMS.harmonic.sin2.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.sin'(314.1592653589793 * time);
    'thdRMS.harmonic.product1.y' = 'thdRMS.harmonic.product1.u[1]' * 'thdRMS.harmonic.product1.u[2]';
    'thdRMS.harmonic.product2.y' = 'thdRMS.harmonic.product2.u[1]' * 'thdRMS.harmonic.product2.u[2]';
    der('thdRMS.harmonic.mean1.x') = 'thdRMS.harmonic.mean1.u';

    when sample('thdRMS.harmonic.mean1.t0' + 0.02, 0.02) then
      'thdRMS.harmonic.mean1.y_last' = 50.0 * pre('thdRMS.harmonic.mean1.x');
      reinit('thdRMS.harmonic.mean1.x', 0.0);
    end when;

    'thdRMS.harmonic.mean1.y' = 'thdRMS.harmonic.mean1.y_last';
    der('thdRMS.harmonic.mean2.x') = 'thdRMS.harmonic.mean2.u';

    when sample('thdRMS.harmonic.mean2.t0' + 0.02, 0.02) then
      'thdRMS.harmonic.mean2.y_last' = 50.0 * pre('thdRMS.harmonic.mean2.x');
      reinit('thdRMS.harmonic.mean2.x', 0.0);
    end when;

    'thdRMS.harmonic.mean2.y' = 'thdRMS.harmonic.mean2.y_last';
    'thdRMS.harmonic.rectangularToPolar.y_abs' = sqrt('thdRMS.harmonic.rectangularToPolar.u_re' * 'thdRMS.harmonic.rectangularToPolar.u_re' + 'thdRMS.harmonic.rectangularToPolar.u_im' * 'thdRMS.harmonic.rectangularToPolar.u_im');
    'thdRMS.harmonic.rectangularToPolar.y_arg' = 'Modelica.Math.atan2'('thdRMS.harmonic.rectangularToPolar.u_im', 'thdRMS.harmonic.rectangularToPolar.u_re');
    'thdRMS.harmonic.gain.y' = 'thdRMS.harmonic.gain.u';
    'thdRMS.rootMeanSquare.product.y' = 'thdRMS.rootMeanSquare.product.u[1]' * 'thdRMS.rootMeanSquare.product.u[2]';
    der('thdRMS.rootMeanSquare.mean.x') = 'thdRMS.rootMeanSquare.mean.u';

    when sample('thdRMS.rootMeanSquare.mean.t0' + 0.02, 0.02) then
      'thdRMS.rootMeanSquare.mean.y_last' = max(0.0, 50.0 * pre('thdRMS.rootMeanSquare.mean.x'));
      reinit('thdRMS.rootMeanSquare.mean.x', 0.0);
    end when;

    'thdRMS.rootMeanSquare.mean.y' = 'thdRMS.rootMeanSquare.mean.y_last';
    'thdRMS.rootMeanSquare.sqrt1.y' = sqrt('thdRMS.rootMeanSquare.sqrt1.u');
    'thdRMS.greaterThreshold.y' = 'thdRMS.greaterThreshold.u' > 0.0;
    'thdRMS.division.y' = 'thdRMS.division.u1' / 'thdRMS.division.u2';
    'thdRMS.limiter.simplifiedExpr' = 'thdRMS.limiter.u';
    'thdRMS.limiter.y' = homotopy(smooth(0, if 'thdRMS.limiter.u' > 1e60 then 1e60 else if 'thdRMS.limiter.u' < 2.220446049250313e-16 then 2.220446049250313e-16 else 'thdRMS.limiter.u'), 'thdRMS.limiter.simplifiedExpr');
    'thdRMS.pythagoras.y2' = 'thdRMS.pythagoras.u1' ^ 2.0 - 'thdRMS.pythagoras.u2' ^ 2.0;
    'thdRMS.pythagoras.valid' = 'thdRMS.pythagoras.y2' >= 0.0;
    'thdRMS.pythagoras.y' = if noEvent('thdRMS.pythagoras.y2' >= 0.0) then sqrt('thdRMS.pythagoras.y2') else 0.0;
    'thdRMS.andValid.y' = 'thdRMS.andValid.u1' and 'thdRMS.andValid.u2';
    'thdRMS.switch1.y' = if 'thdRMS.switch1.u2' then 'thdRMS.switch1.u1' else 'thdRMS.switch1.u3';
    annotation(experiment(StopTime = 0.1, Interval = 0.0001, Tolerance = 1e-06));
  end 'TotalHarmonicDistortion';
end 'TotalHarmonicDistortion';
