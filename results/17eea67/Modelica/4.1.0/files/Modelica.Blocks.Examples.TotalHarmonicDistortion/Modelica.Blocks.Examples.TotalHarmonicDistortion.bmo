    parameter Integer 'thd1.harmonic.product1.nu'(min = 0) = 2 "Number of input connections";
    Real 'thd1.harmonic.product1.u[1]';
    Real 'thd1.harmonic.product1.u[2]';
    Real 'thd1.harmonic.product1.y';
    parameter Integer 'thd1.harmonic.product2.significantDigits'(min = 1) = 3 "Number of significant digits to be shown in dynamic diagram layer for y";
