//! base 0.1.0
package 'TotalHarmonicDistortion'
  function 'Modelica.Math.atan2' "Four quadrant inverse tangent"
    input Real 'u1';
    input Real 'u2';
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := atan2('u1', 'u2');
    annotation(Inline = true);
  end 'Modelica.Math.atan2';

  function 'Modelica.Math.cos' "Cosine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := cos('u');
    annotation(Inline = true);
  end 'Modelica.Math.cos';

  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'TotalHarmonicDistortion' "Calculation of total harmonic distortion of voltage"
    parameter Real 'f1'(unit = "Hz", quantity = "Frequency") = 50.0 "Fundamental wave frequency";
    parameter Real 'V1'(unit = "V", quantity = "ElectricPotential") = 100.0 "Fundamental wave RMS voltage";
    parameter Real 'V3'(unit = "V", quantity = "ElectricPotential") = 20.0 "Third harmonic wave RMS voltage";
    parameter Real 'THD1' = 0.2 "Theoretically obtained THD with respect to fundamental wave";
    parameter Real 'THDrms' = 0.19611613513818404 "Theoretically obtained THD with respect to RMS";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'sineVoltage3.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 28.284271247461902 "Amplitude of sine wave";
    parameter Real 'sineVoltage3.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Real 'sineVoltage3.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 150.0 "Frequency of sine wave";
    Real 'sineVoltage3.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sineVoltage3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage3.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage3.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sineVoltage3.signalSource.amplitude' = 28.284271247461902 "Amplitude of sine wave";
    parameter Real 'sineVoltage3.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 150.0 "Frequency of sine wave";
    parameter Real 'sineVoltage3.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sineVoltage3.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltage3.signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltage3.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineVoltage3.signalSource.startTime'(unit = "s", quantity = "Time") = 0.02 "Output y = offset for time < startTime";
    parameter Real 'sineVoltage3.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
