    'Nand.Vdd.i' + 'VDD.p.i' = 0.0;
    'Nand.y.i' = 0.0;

    when time >= (pre('VIN1.signalSource.count') + 1) * 4e-8 + 2e-8 then
      'VIN1.signalSource.count' = pre('VIN1.signalSource.count') + 1;
      'VIN1.signalSource.T_start' = time;
    end when;

    'VIN1.signalSource.y' = if time < 2e-8 then 0.0 else if time < 'VIN1.signalSource.T_start' + 1e-9 then 3.5 * (time - 'VIN1.signalSource.T_start') / 1e-9 else if time < 'VIN1.signalSource.T_start' + 2e-8 then 3.5 else if time < 'VIN1.signalSource.T_start' + 2.1e-8 then 3.5 * ('VIN1.signalSource.T_start' + 2.1e-8 - time) / 1e-9 else 0.0;
    'VIN1.v' = 'VIN1.signalSource.y';
