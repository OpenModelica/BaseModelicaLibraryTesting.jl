    'VIN2.signalSource.y' = if time < 1e-8 then 0.0 else if time < 'VIN2.signalSource.T_start' + 1e-9 then 3.5 * (time - 'VIN2.signalSource.T_start') / 1e-9 else if time < 'VIN2.signalSource.T_start' + 2e-8 then 3.5 else if time < 'VIN2.signalSource.T_start' + 2.1e-8 then 3.5 * ('VIN2.signalSource.T_start' + 2.1e-8 - time) / 1e-9 else 0.0;
    'VIN2.v' = 'VIN2.signalSource.y';
    0.0 = 'VIN2.p.i' + 'VIN2.n.i';
    'VIN2.i' = 'VIN2.p.i';
    'VIN2.v' = 'VIN2.p.v' - 'VIN2.n.v';
    'VDD.signalSource.y' = if time < 0.0 then 0.0 else if time < 1e-9 then time * 5.0 / 1e-9 else 5.0;
    'VDD.v' = 'VDD.signalSource.y';
    0.0 = 'VDD.p.i' + 'VDD.n.i';
    'VDD.i' = 'VDD.p.i';
    'VDD.v' = 'VDD.p.v' - 'VDD.n.v';
    'Gnd1.p.v' = 0.0;
    'Gnd4.p.v' = 0.0;
    'Gnd5.p.v' = 0.0;
    assert('Nand.TP1.T_heatPort' > 0.0, "PMOS: Temperature must be positive", AssertionLevel.error);
    'Nand.TP1.gds' = 1e-7;
    'Nand.TP1.v' = 'Nand.TP1.beta_t' * 3.999999999999999e-6 / 1.0000000000000002e-6;
    'Nand.TP1.ud' = smooth(0, if 'Nand.TP1.D.v' > 'Nand.TP1.S.v' then 'Nand.TP1.S.v' else 'Nand.TP1.D.v');
    'Nand.TP1.us' = smooth(0, if 'Nand.TP1.D.v' > 'Nand.TP1.S.v' then 'Nand.TP1.D.v' else 'Nand.TP1.S.v');
    'Nand.TP1.uds' = 'Nand.TP1.ud' - 'Nand.TP1.us';
    'Nand.TP1.ubs' = smooth(0, if 'Nand.TP1.B.v' < 'Nand.TP1.us' then 0.0 else 'Nand.TP1.B.v' - 'Nand.TP1.us');
    'Nand.TP1.ugst' = ('Nand.TP1.G.v' - 'Nand.TP1.us' - 'Nand.TP1.vt_t' + 'Nand.TP1.k2_t' * 'Nand.TP1.ubs') * 0.8385;
    'Nand.TP1.id' = smooth(0, if 'Nand.TP1.ugst' >= 0.0 then 'Nand.TP1.uds' * 'Nand.TP1.gds' else if 'Nand.TP1.ugst' < 'Nand.TP1.uds' then 'Nand.TP1.uds' * 'Nand.TP1.gds' - 'Nand.TP1.v' * 'Nand.TP1.uds' * ('Nand.TP1.ugst' - 'Nand.TP1.uds' / 2.0) else 'Nand.TP1.uds' * 'Nand.TP1.gds' - 'Nand.TP1.v' * 'Nand.TP1.ugst' * 'Nand.TP1.ugst' / 2.0);
    'Nand.TP1.beta_t' = 1.05e-5;
    'Nand.TP1.vt_t' = -1.0;
    'Nand.TP1.k2_t' = 0.41;
    'Nand.TP1.G.i' = 0.0;
    'Nand.TP1.D.i' = smooth(0, if 'Nand.TP1.D.v' > 'Nand.TP1.S.v' then -'Nand.TP1.id' else 'Nand.TP1.id');
    'Nand.TP1.S.i' = smooth(0, if 'Nand.TP1.D.v' > 'Nand.TP1.S.v' then 'Nand.TP1.id' else -'Nand.TP1.id');
    'Nand.TP1.B.i' = 0.0;
    'Nand.TP1.LossPower' = 'Nand.TP1.D.i' * ('Nand.TP1.D.v' - 'Nand.TP1.S.v');
    'Nand.TP1.T_heatPort' = 293.15;
    assert('Nand.TP2.T_heatPort' > 0.0, "PMOS: Temperature must be positive", AssertionLevel.error);
    'Nand.TP2.gds' = 1e-7;
    'Nand.TP2.v' = 'Nand.TP2.beta_t' * 3.999999999999999e-6 / 1.0000000000000002e-6;
    'Nand.TP2.ud' = smooth(0, if 'Nand.TP2.D.v' > 'Nand.TP2.S.v' then 'Nand.TP2.S.v' else 'Nand.TP2.D.v');
    'Nand.TP2.us' = smooth(0, if 'Nand.TP2.D.v' > 'Nand.TP2.S.v' then 'Nand.TP2.D.v' else 'Nand.TP2.S.v');
    'Nand.TP2.uds' = 'Nand.TP2.ud' - 'Nand.TP2.us';
    'Nand.TP2.ubs' = smooth(0, if 'Nand.TP2.B.v' < 'Nand.TP2.us' then 0.0 else 'Nand.TP2.B.v' - 'Nand.TP2.us');
    'Nand.TP2.ugst' = ('Nand.TP2.G.v' - 'Nand.TP2.us' - 'Nand.TP2.vt_t' + 'Nand.TP2.k2_t' * 'Nand.TP2.ubs') * 0.8385;
    'Nand.TP2.id' = smooth(0, if 'Nand.TP2.ugst' >= 0.0 then 'Nand.TP2.uds' * 'Nand.TP2.gds' else if 'Nand.TP2.ugst' < 'Nand.TP2.uds' then 'Nand.TP2.uds' * 'Nand.TP2.gds' - 'Nand.TP2.v' * 'Nand.TP2.uds' * ('Nand.TP2.ugst' - 'Nand.TP2.uds' / 2.0) else 'Nand.TP2.uds' * 'Nand.TP2.gds' - 'Nand.TP2.v' * 'Nand.TP2.ugst' * 'Nand.TP2.ugst' / 2.0);
    'Nand.TP2.beta_t' = 1.05e-5;
    'Nand.TP2.vt_t' = -1.0;
    'Nand.TP2.k2_t' = 0.41;
    'Nand.TP2.G.i' = 0.0;
    'Nand.TP2.D.i' = smooth(0, if 'Nand.TP2.D.v' > 'Nand.TP2.S.v' then -'Nand.TP2.id' else 'Nand.TP2.id');
    'Nand.TP2.S.i' = smooth(0, if 'Nand.TP2.D.v' > 'Nand.TP2.S.v' then 'Nand.TP2.id' else -'Nand.TP2.id');
    'Nand.TP2.B.i' = 0.0;
    'Nand.TP2.LossPower' = 'Nand.TP2.D.i' * ('Nand.TP2.D.v' - 'Nand.TP2.S.v');
    'Nand.TP2.T_heatPort' = 293.15;
    assert('Nand.TN1.T_heatPort' > 0.0, "NMOS: Temperature must be positive", AssertionLevel.error);
    'Nand.TN1.gds' = 1e-7;
    'Nand.TN1.v' = 'Nand.TN1.beta_t' * 3.999999999999999e-6 / 1.6e-6;
    'Nand.TN1.ud' = smooth(0, if 'Nand.TN1.D.v' < 'Nand.TN1.S.v' then 'Nand.TN1.S.v' else 'Nand.TN1.D.v');
    'Nand.TN1.us' = smooth(0, if 'Nand.TN1.D.v' < 'Nand.TN1.S.v' then 'Nand.TN1.D.v' else 'Nand.TN1.S.v');
    'Nand.TN1.uds' = 'Nand.TN1.ud' - 'Nand.TN1.us';
    'Nand.TN1.ubs' = smooth(0, if 'Nand.TN1.B.v' > 'Nand.TN1.us' then 0.0 else 'Nand.TN1.B.v' - 'Nand.TN1.us');
    'Nand.TN1.ugst' = ('Nand.TN1.G.v' - 'Nand.TN1.us' - 'Nand.TN1.vt_t' + 'Nand.TN1.k2_t' * 'Nand.TN1.ubs') * 0.7311;
    'Nand.TN1.id' = smooth(0, if 'Nand.TN1.ugst' <= 0.0 then 'Nand.TN1.uds' * 'Nand.TN1.gds' else if 'Nand.TN1.ugst' > 'Nand.TN1.uds' then 'Nand.TN1.v' * 'Nand.TN1.uds' * ('Nand.TN1.ugst' - 'Nand.TN1.uds' / 2.0) + 'Nand.TN1.uds' * 'Nand.TN1.gds' else 'Nand.TN1.v' * 'Nand.TN1.ugst' * 'Nand.TN1.ugst' / 2.0 + 'Nand.TN1.uds' * 'Nand.TN1.gds');
    'Nand.TN1.beta_t' = 4.1e-5;
    'Nand.TN1.vt_t' = 0.8;
    'Nand.TN1.k2_t' = 1.144;
    'Nand.TN1.G.i' = 0.0;
    'Nand.TN1.D.i' = smooth(0, if 'Nand.TN1.D.v' < 'Nand.TN1.S.v' then -'Nand.TN1.id' else 'Nand.TN1.id');
    'Nand.TN1.S.i' = smooth(0, if 'Nand.TN1.D.v' < 'Nand.TN1.S.v' then 'Nand.TN1.id' else -'Nand.TN1.id');
    'Nand.TN1.B.i' = 0.0;
    'Nand.TN1.LossPower' = 'Nand.TN1.D.i' * ('Nand.TN1.D.v' - 'Nand.TN1.S.v');
    'Nand.TN1.T_heatPort' = 293.15;
    assert('Nand.TN2.T_heatPort' > 0.0, "NMOS: Temperature must be positive", AssertionLevel.error);
    'Nand.TN2.gds' = 1e-7;
    'Nand.TN2.v' = 'Nand.TN2.beta_t' * 3.999999999999999e-6 / 1.6e-6;
    'Nand.TN2.ud' = smooth(0, if 'Nand.TN2.D.v' < 'Nand.TN2.S.v' then 'Nand.TN2.S.v' else 'Nand.TN2.D.v');
    'Nand.TN2.us' = smooth(0, if 'Nand.TN2.D.v' < 'Nand.TN2.S.v' then 'Nand.TN2.D.v' else 'Nand.TN2.S.v');
    'Nand.TN2.uds' = 'Nand.TN2.ud' - 'Nand.TN2.us';
    'Nand.TN2.ubs' = smooth(0, if 'Nand.TN2.B.v' > 'Nand.TN2.us' then 0.0 else 'Nand.TN2.B.v' - 'Nand.TN2.us');
    'Nand.TN2.ugst' = ('Nand.TN2.G.v' - 'Nand.TN2.us' - 'Nand.TN2.vt_t' + 'Nand.TN2.k2_t' * 'Nand.TN2.ubs') * 0.7311;
    'Nand.TN2.id' = smooth(0, if 'Nand.TN2.ugst' <= 0.0 then 'Nand.TN2.uds' * 'Nand.TN2.gds' else if 'Nand.TN2.ugst' > 'Nand.TN2.uds' then 'Nand.TN2.v' * 'Nand.TN2.uds' * ('Nand.TN2.ugst' - 'Nand.TN2.uds' / 2.0) + 'Nand.TN2.uds' * 'Nand.TN2.gds' else 'Nand.TN2.v' * 'Nand.TN2.ugst' * 'Nand.TN2.ugst' / 2.0 + 'Nand.TN2.uds' * 'Nand.TN2.gds');
    'Nand.TN2.beta_t' = 4.1e-5;
    'Nand.TN2.vt_t' = 0.8;
    'Nand.TN2.k2_t' = 1.144;
    'Nand.TN2.G.i' = 0.0;
    'Nand.TN2.D.i' = smooth(0, if 'Nand.TN2.D.v' < 'Nand.TN2.S.v' then -'Nand.TN2.id' else 'Nand.TN2.id');
    'Nand.TN2.S.i' = smooth(0, if 'Nand.TN2.D.v' < 'Nand.TN2.S.v' then 'Nand.TN2.id' else -'Nand.TN2.id');
    'Nand.TN2.B.i' = 0.0;
    'Nand.TN2.LossPower' = 'Nand.TN2.D.i' * ('Nand.TN2.D.v' - 'Nand.TN2.S.v');
    'Nand.TN2.T_heatPort' = 293.15;
    'Nand.C4.i' = 4e-14 * der('Nand.C4.v');
    0.0 = 'Nand.C4.p.i' + 'Nand.C4.n.i';
    'Nand.C4.i' = 'Nand.C4.p.i';
    'Nand.C4.v' = 'Nand.C4.p.v' - 'Nand.C4.n.v';
    'Nand.C7.i' = 4e-14 * der('Nand.C7.v');
    0.0 = 'Nand.C7.p.i' + 'Nand.C7.n.i';
    'Nand.C7.i' = 'Nand.C7.p.i';
    'Nand.C7.v' = 'Nand.C7.p.v' - 'Nand.C7.n.v';
    'Nand.Gnd.p.v' = 0.0;
    'Nand.Gnd2.p.v' = 0.0;
    'Nand.Gnd3.p.v' = 0.0;
    'Nand.Gnd6.p.v' = 0.0;
    'Nand.Gnd7.p.v' = 0.0;
    'Nand.Gnd8.p.v' = 0.0;
  initial algorithm
    'VIN1.signalSource.count' := integer((time - 2e-8) / 4e-8);
    'VIN1.signalSource.T_start' := 2e-8 + 'VIN1.signalSource.count' * 4e-8;
  initial algorithm
    'VIN2.signalSource.count' := integer((time - 1e-8) / 4e-8);
    'VIN2.signalSource.T_start' := 1e-8 + 'VIN2.signalSource.count' * 4e-8;
    annotation(experiment(StopTime = 1e-007));
  end 'NandGate';
end 'NandGate';
