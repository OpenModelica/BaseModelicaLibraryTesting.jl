//! base 0.1.0
package 'SinglePhaseTwoLevel_RL'
  function 'Modelica.Math.atan2' "Four quadrant inverse tangent"
    input Real 'u1';
    input Real 'u2';
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := atan2('u1', 'u2');
    annotation(Inline = true);
  end 'Modelica.Math.atan2';

  function 'Modelica.Math.cos' "Cosine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := cos('u');
    annotation(Inline = true);
  end 'Modelica.Math.cos';

  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  type 'Modelica.Electrical.PowerConverters.Types.SingleReferenceType' = enumeration('Sawtooth', 'Triangle');

  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'SinglePhaseTwoLevel_RL' "Single-phase DC to AC converter with R-L load"
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 1000.0 "Switching frequency";
    parameter Real 'constantVoltage_n.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 50.0 "Value of constant voltage";
    Real 'constantVoltage_n.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'constantVoltage_n.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'constantVoltage_n.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'constantVoltage_n.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'constantVoltage_n.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'constantVoltage_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inverter.RonTransistor'(unit = "Ohm", quantity = "Resistance") = 1e-5 "Transistor closed resistance";
    parameter Real 'inverter.GoffTransistor'(unit = "S", quantity = "Conductance") = 1e-5 "Transistor opened conductance";
    parameter Real 'inverter.VkneeTransistor'(unit = "V", quantity = "ElectricPotential") = 0.0 "Transistor threshold voltage";
    parameter Real 'inverter.RonDiode'(unit = "Ohm", quantity = "Resistance") = 1e-5 "Diode closed resistance";
    parameter Real 'inverter.GoffDiode'(unit = "S", quantity = "Conductance") = 1e-5 "Diode opened conductance";
    parameter Real 'inverter.VkneeDiode'(unit = "V", quantity = "ElectricPotential") = 0.0 "Diode threshold voltage";
    Real 'inverter.dc_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.dc_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.dc_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.dc_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.vDC'(unit = "V", quantity = "ElectricPotential") "DC voltage";
    Real 'inverter.iDC'(unit = "A", quantity = "ElectricCurrent") "DC current";
    Real 'inverter.powerDC'(unit = "W", quantity = "Power") "DC power";
    Real 'inverter.ac.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.ac.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.vAC'(unit = "V", quantity = "ElectricPotential") "AC potential";
    Real 'inverter.iAC'(unit = "A", quantity = "ElectricCurrent") "AC current";
    Real 'inverter.powerAC'(unit = "W", quantity = "Power") "AC power";
    parameter Boolean 'inverter.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'inverter.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'inverter.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'inverter.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    parameter Boolean 'inverter.useConstantEnable' = true "Disable boolean input and use constantEnable, if true";
    parameter Boolean 'inverter.constantEnable' = true "Constant enabling of firing signals";
    parameter Integer 'inverter.m'(min = 1) = 1 "Number of phases" annotation(Evaluate = true);
    parameter Boolean 'inverter.enableLogic.useConstantEnable' = true "Disable boolean input and use constantEnable, if true";
    parameter Boolean 'inverter.enableLogic.constantEnable' = true "Constant enabling of firing signals";
    parameter Integer 'inverter.enableLogic.m'(min = 1) = 1 "Number of phases" annotation(Evaluate = true);
    parameter Boolean 'inverter.enableLogic.enableConstantSource.k' = true "Constant output value";
    Boolean 'inverter.enableLogic.enableConstantSource.y' "Connector of Boolean output signal";
    parameter Integer 'inverter.enableLogic.booleanReplicator.nout' = 1 "Number of outputs";
    Boolean 'inverter.enableLogic.booleanReplicator.u' "Connector of Boolean input signal";
    Boolean 'inverter.enableLogic.booleanReplicator.y[1]' "Connector of Boolean output signals";
    Boolean 'inverter.enableLogic.internalEnable[1]' "m replicated enable signals";
    Boolean 'inverter.andCondition_p.u1' "Connector of first Boolean input signal";
    Boolean 'inverter.andCondition_p.u2' "Connector of second Boolean input signal";
    Boolean 'inverter.andCondition_p.y' "Connector of Boolean output signal";
    Boolean 'inverter.fire_p' "Firing signal of positive potential transistor";
    Boolean 'inverter.andCondition_n.u1' "Connector of first Boolean input signal";
    Boolean 'inverter.andCondition_n.u2' "Connector of second Boolean input signal";
    Boolean 'inverter.andCondition_n.y' "Connector of Boolean output signal";
    Boolean 'inverter.fire_n' "Firing signal of negative potential transistor";
    Real 'inverter.transistor_p.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inverter.transistor_p.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.transistor_p.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.transistor_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inverter.transistor_p.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'inverter.transistor_p.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'inverter.transistor_p.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'inverter.transistor_p.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'inverter.transistor_p.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'inverter.transistor_p.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'inverter.transistor_p.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'inverter.transistor_p.off'(start = true) "Switching state";
    Real 'inverter.transistor_p.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'inverter.transistor_p.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'inverter.transistor_p.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Boolean 'inverter.transistor_p.fire';
    Real 'inverter.diode_p.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inverter.diode_p.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.diode_p.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.diode_p.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.diode_p.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.diode_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inverter.diode_p.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'inverter.diode_p.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'inverter.diode_p.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'inverter.diode_p.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'inverter.diode_p.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'inverter.diode_p.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'inverter.diode_p.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'inverter.diode_p.off'(start = true) "Switching state";
    Real 'inverter.diode_p.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'inverter.diode_p.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'inverter.diode_p.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Real 'inverter.transistor_n.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inverter.transistor_n.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_n.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
