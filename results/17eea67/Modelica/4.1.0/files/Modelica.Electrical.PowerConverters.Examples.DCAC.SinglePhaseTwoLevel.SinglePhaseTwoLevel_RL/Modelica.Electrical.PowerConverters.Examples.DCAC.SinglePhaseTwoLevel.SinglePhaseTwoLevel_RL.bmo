    parameter Real 'inverter.transistor_n.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'inverter.transistor_n.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'inverter.transistor_n.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'inverter.transistor_n.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'inverter.transistor_n.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'inverter.transistor_n.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'inverter.transistor_n.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'inverter.transistor_n.off'(start = true) "Switching state";
    Real 'inverter.transistor_n.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
