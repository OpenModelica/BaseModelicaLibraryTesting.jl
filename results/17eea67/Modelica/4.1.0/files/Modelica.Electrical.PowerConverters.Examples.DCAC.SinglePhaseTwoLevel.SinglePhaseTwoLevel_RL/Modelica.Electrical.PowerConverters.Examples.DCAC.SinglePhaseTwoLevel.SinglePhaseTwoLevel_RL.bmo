    'fundamentalWaveVoltage.product2.y' = 'fundamentalWaveVoltage.product2.u[1]' * 'fundamentalWaveVoltage.product2.u[2]';
    der('fundamentalWaveVoltage.mean1.x') = 'fundamentalWaveVoltage.mean1.u';

    when sample('fundamentalWaveVoltage.mean1.t0' + 0.001, 0.001) then
      'fundamentalWaveVoltage.mean1.y_last' = 1000.0 * pre('fundamentalWaveVoltage.mean1.x');
      reinit('fundamentalWaveVoltage.mean1.x', 0.0);
    end when;

    'fundamentalWaveVoltage.mean1.y' = 'fundamentalWaveVoltage.mean1.y_last';
    der('fundamentalWaveVoltage.mean2.x') = 'fundamentalWaveVoltage.mean2.u';

    when sample('fundamentalWaveVoltage.mean2.t0' + 0.001, 0.001) then
      'fundamentalWaveVoltage.mean2.y_last' = 1000.0 * pre('fundamentalWaveVoltage.mean2.x');
      reinit('fundamentalWaveVoltage.mean2.x', 0.0);
    end when;

    'fundamentalWaveVoltage.mean2.y' = 'fundamentalWaveVoltage.mean2.y_last';
    'fundamentalWaveVoltage.rectangularToPolar.y_abs' = sqrt('fundamentalWaveVoltage.rectangularToPolar.u_re' * 'fundamentalWaveVoltage.rectangularToPolar.u_re' + 'fundamentalWaveVoltage.rectangularToPolar.u_im' * 'fundamentalWaveVoltage.rectangularToPolar.u_im');
    'fundamentalWaveVoltage.rectangularToPolar.y_arg' = 'Modelica.Math.atan2'('fundamentalWaveVoltage.rectangularToPolar.u_im', 'fundamentalWaveVoltage.rectangularToPolar.u_re');
    'fundamentalWaveVoltage.gain.y' = 'fundamentalWaveVoltage.gain.u';
    'fundamentalWaveCurrent.sin1.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.cos'(6283.185307179586 * time);
    'fundamentalWaveCurrent.sin2.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.sin'(6283.185307179586 * time);
    'fundamentalWaveCurrent.product1.y' = 'fundamentalWaveCurrent.product1.u[1]' * 'fundamentalWaveCurrent.product1.u[2]';
    'fundamentalWaveCurrent.product2.y' = 'fundamentalWaveCurrent.product2.u[1]' * 'fundamentalWaveCurrent.product2.u[2]';
    der('fundamentalWaveCurrent.mean1.x') = 'fundamentalWaveCurrent.mean1.u';

    when sample('fundamentalWaveCurrent.mean1.t0' + 0.001, 0.001) then
      'fundamentalWaveCurrent.mean1.y_last' = 1000.0 * pre('fundamentalWaveCurrent.mean1.x');
      reinit('fundamentalWaveCurrent.mean1.x', 0.0);
    end when;

    'fundamentalWaveCurrent.mean1.y' = 'fundamentalWaveCurrent.mean1.y_last';
    der('fundamentalWaveCurrent.mean2.x') = 'fundamentalWaveCurrent.mean2.u';

    when sample('fundamentalWaveCurrent.mean2.t0' + 0.001, 0.001) then
      'fundamentalWaveCurrent.mean2.y_last' = 1000.0 * pre('fundamentalWaveCurrent.mean2.x');
      reinit('fundamentalWaveCurrent.mean2.x', 0.0);
    end when;

    'fundamentalWaveCurrent.mean2.y' = 'fundamentalWaveCurrent.mean2.y_last';
    'fundamentalWaveCurrent.rectangularToPolar.y_abs' = sqrt('fundamentalWaveCurrent.rectangularToPolar.u_re' * 'fundamentalWaveCurrent.rectangularToPolar.u_re' + 'fundamentalWaveCurrent.rectangularToPolar.u_im' * 'fundamentalWaveCurrent.rectangularToPolar.u_im');
    'fundamentalWaveCurrent.rectangularToPolar.y_arg' = 'Modelica.Math.atan2'('fundamentalWaveCurrent.rectangularToPolar.u_im', 'fundamentalWaveCurrent.rectangularToPolar.u_re');
    'fundamentalWaveCurrent.gain.y' = 'fundamentalWaveCurrent.gain.u';
    'resistor.R_actual' = 100.0;
    'resistor.v' = 'resistor.R_actual' * 'resistor.i';
    'resistor.LossPower' = 'resistor.v' * 'resistor.i';
    'resistor.T_heatPort' = 300.15;
    0.0 = 'resistor.p.i' + 'resistor.n.i';
    'resistor.i' = 'resistor.p.i';
    'resistor.v' = 'resistor.p.v' - 'resistor.n.v';
    der('inductor.i') = 'inductor.v';
    0.0 = 'inductor.p.i' + 'inductor.n.i';
    'inductor.i' = 'inductor.p.i';
    'inductor.v' = 'inductor.p.v' - 'inductor.n.v';
  initial algorithm
    'signalPWM.sawtooth.count' := integer(time / 0.001);
    'signalPWM.sawtooth.T_start' := 'signalPWM.sawtooth.count' * 0.001;
    annotation(experiment(StartTime = 0, StopTime = 0.1, Tolerance = 1e-06, Interval = 0.0002));
  end 'SinglePhaseTwoLevel_RL';
end 'SinglePhaseTwoLevel_RL';
