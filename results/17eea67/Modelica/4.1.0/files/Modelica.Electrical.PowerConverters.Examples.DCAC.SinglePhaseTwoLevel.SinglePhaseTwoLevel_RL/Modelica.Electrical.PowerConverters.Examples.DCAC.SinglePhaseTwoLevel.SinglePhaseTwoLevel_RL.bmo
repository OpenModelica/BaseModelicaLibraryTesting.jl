    'fundamentalWaveVoltage.sin1.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.cos'(6283.185307179586 * time);
    'fundamentalWaveVoltage.sin2.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.sin'(6283.185307179586 * time);
