    constant Real 'inverter.transistor_n.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Boolean 'inverter.transistor_n.fire';
    Real 'inverter.diode_n.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inverter.diode_n.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.diode_n.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
