//! base 0.1.0
package 'OneTank'
  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.ambient_fixed.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 4184.0 * ('T' - 273.15);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.ambient_fixed.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.flowSource.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 4184.0 * ('T' - 273.15);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.flowSource.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.density' "Return density"
    input 'pipe.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.density';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.setState_phX' "Return thermodynamic state from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe.Medium.ThermodynamicState'('p', 273.15 + 'h' / 4184.0);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.density' "Return density"
    input 'pipe.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.dynamicViscosity' "Return dynamic viscosity"
    input 'pipe.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'eta'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
  algorithm
    'eta' := 0.001;
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.dynamicViscosity';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.pressure' "Return pressure"
    input 'pipe.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / 'Modelica.Math.log10'('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'lambda2';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'dRe_ddp';
    Real 'aux1';
    Real 'aux2';
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'lambda2' := abs('dp_fric') * 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' * 'mu') "Known as lambda2=f(dp)";
    'aux1' := 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' ^ 2.0);
    'Re' := 'lambda2' / 64.0 "Hagen-Poiseuille";
    'dRe_ddp' := 'aux1' / 64.0 "Hagen-Poiseuille";

    if 'Re' > 'Re1' then
      'Re' := -2.0 * sqrt('lambda2') * 'Modelica.Math.log10'(2.51 / sqrt('lambda2') + 0.27 * 'Delta') "Colebrook-White";
      'aux2' := sqrt('aux1' * abs('dp_fric'));
      'dRe_ddp' := 0.43429448190325176 * (5.02 / (2.0 * abs('dp_fric') * (2.51 / 'aux2' + 0.27 * 'Delta')) - 2.0 * log(2.51 / 'aux2' + 0.27 * 'Delta') * 'aux1' / (2.0 * 'aux2'));

      if 'Re' < 'Re2' then
        ('Re', 'dRe_ddp') := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative'('lambda2', 'Re1', 'Re2', 'Delta', 'dp_fric');
      end if;
    end if;

    'm_flow' := 'crossArea' / 'diameter' * 'mu' * (if 'dp_fric' >= 0.0 then 'Re' else -'Re');
    'dm_flow_ddp_fric' := 'crossArea' / 'diameter' * 'mu' * 'dRe_ddp';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative' "Interpolation in log-log space using a cubic Hermite polynomial, where x=log10(lambda2), y=log10(Re)"
    input Real 'lambda2';
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    output Real 'dRe_ddp';
    Real 'x1' = 'Modelica.Math.log10'(64.0 * 'Re1');
    Real 'y1' = 'Modelica.Math.log10'('Re1');
    Real 'y1d' = 1.0;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x' = 'Modelica.Math.log10'('lambda2');
    Real 'y';
    Real 'dy_dx';
    Real 'aux3' = 'Modelica.Math.log10'('aux2');
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'x2' = 'Modelica.Math.log10'('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * 'Modelica.Math.log10'('aux4');
    Real 'y2' = 'Modelica.Math.log10'('aux5');
    Real 'y2d' = 0.5 + 1.0900791495771618 / ('aux5' * 'aux4');
  algorithm
    ('y', 'dy_dx') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('x', 'x1', 'x2', 'y1', 'y2', 'y1d', 'y2d');
    'Re' := 10.0 ^ 'y';
    'dRe_ddp' := 'Re' / abs('dp_fric') * 'dy_dx';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2' "Cubic Hermite spline interpolation in transition region"
    input Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta';
    output Real 'lambda2';
    Real 'x1' = 'Modelica.Math.log10'('Re1');
    Real 'y1' = 'Modelica.Math.log10'(64.0 * 'Re1');
    Real 'yd1' = 1.0;
    Real 'aux1' = 1.1217826467560994;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x2' = 'Modelica.Math.log10'('Re2');
    Real 'dx' = 'Modelica.Math.log10'('Re' / 'Re1');
    Real 'aux3' = 'Modelica.Math.log10'('aux2');
    Real 'diff_x' = 'x2' - 'x1';
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'yd2' = 2.0 + 4.0 * 'aux1' / ('aux2' * 'aux3' * 'Re2' ^ 0.9);
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'y2' = 'Modelica.Math.log10'('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * 'Modelica.Math.log10'('aux4');
    Real 'm' = ('y2' - 'y1') / 'diff_x';
    Real 'c2' = (3.0 * 'm' - 2.0 * 'yd1' - 'yd2') / 'diff_x';
    Real 'c3' = ('yd1' + 'yd2' - 2.0 * 'm') / ('diff_x' * 'diff_x');
  algorithm
    'lambda2' := 64.0 * 'Re1' * ('Re' / 'Re1') ^ ('yd1' + 'dx' * ('c2' + 'dx' * 'c3'));
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.tank.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 4184.0 * ('T' - 273.15);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.tank.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.tank.heatTransfer.Medium.temperature' "Return temperature"
    input 'tank.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.tank.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.timeTable.getInterpolationCoefficients' "Determine interpolation coefficients and next time event"
    input Real[:, 2] 'table';
    input Real 'offset';
    input Real 'startTimeScaled';
    input Real 'timeScaled';
    input Integer 'last';
    input Real 'TimeEps';
    input Real 'shiftTimeScaled';
    output Real 'a';
    output Real 'b';
    output Real 'nextEventScaled';
    output Integer 'next';
    Integer 'columns' = 2;
    Integer 'ncol' = 2;
    Integer 'nrow' = size('table', 1);
    Integer 'next0';
    Real 'tp';
    Real 'dt';
  algorithm
    'next' := 'last';
    'nextEventScaled' := 'timeScaled' - 'TimeEps' * abs('timeScaled');
    'tp' := 'timeScaled' + 'TimeEps' * abs('timeScaled');

    if 'tp' < 'startTimeScaled' then
      'nextEventScaled' := 'startTimeScaled';
      'a' := 0.0;
      'b' := 'offset';
    elseif 'nrow' < 2 then
      'a' := 0.0;
      'b' := 'offset' + 'table'[1,'columns'];
    elseif true then
      'tp' := 'tp' - 'shiftTimeScaled';

      while 'next' < 'nrow' and 'tp' >= 'table'['next',1] loop
        'next' := 'next' + 1;
      end while;

      if 'next' < 'nrow' then
        'nextEventScaled' := 'shiftTimeScaled' + 'table'['next',1];
      end if;

      if 'next' == 1 then
        'next' := 2;
      end if;

      'next0' := 'next' - 1;
      'dt' := 'table'['next',1] - 'table'['next0',1];

      if 'dt' <= 'TimeEps' * abs('table'['next',1]) then
        'a' := 0.0;
        'b' := 'offset' + 'table'['next','columns'];
      elseif true then
        'a' := ('table'['next','columns'] - 'table'['next0','columns']) / 'dt';
        'b' := 'offset' + 'table'['next0','columns'] - 'a' * 'table'['next0',1];
      end if;
    end if;

    'b' := 'b' - 'a' * 'shiftTimeScaled';
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.timeTable.getInterpolationCoefficients';

  function 'Modelica.Fluid.Utilities.checkBoundary' "Check whether boundary definition is correct"
    input String 'mediumName';
    input String[:] 'substanceNames';
    input Boolean 'singleState';
    input Boolean 'define_p';
    input Real[:] 'X_boundary';
    input String 'modelName' = "??? boundary ???";
    Integer 'nX' = size('X_boundary', 1);
    String 'X_str';
  algorithm
    assert(not 'singleState' or 'singleState' and 'define_p', "\nWrong value of parameter define_p (= false) in model \"" + 'modelName' + "\":\nThe selected medium \"" + 'mediumName' + "\" has Medium.singleState=true.\nTherefore, an boundary density cannot be defined and\ndefine_p = true is required.\n", AssertionLevel.error);

    for 'i' in 1:'nX' loop
      assert('X_boundary'['i'] >= 0.0, "\nWrong boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\":\nThe boundary value X_boundary(" + String('i') + ") = " + String('X_boundary'['i']) + "\nis negative. It must be positive.\n", AssertionLevel.error);
    end for;

    if 'nX' > 0 and abs(sum('X_boundary') - 1.0) > 1e-10 then
      'X_str' := "";

      for 'i' in 1:'nX' loop
        'X_str' := 'X_str' + "   X_boundary[" + String('i') + "] = " + String('X_boundary'['i']) + " \"" + 'substanceNames'['i'] + "\"\n";
      end for;

      'Modelica.Utilities.Streams.error'("The boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\"\n" + "do not sum up to 1. Instead, sum(X_boundary) = " + String(sum('X_boundary')) + ":\n" + 'X_str');
    end if;
  end 'Modelica.Fluid.Utilities.checkBoundary';

  function 'Modelica.Fluid.Utilities.cubicHermite_withDerivative' "Evaluate a cubic Hermite spline, return value and derivative"
    input Real 'x';
    input Real 'x1';
    input Real 'x2';
    input Real 'y1';
    input Real 'y2';
    input Real 'y1d';
    input Real 'y2d';
    output Real 'y';
    output Real 'dy_dx';
    Real 'h';
    Real 't';
    Real 'h00';
    Real 'h10';
    Real 'h01';
    Real 'h11';
    Real 'h00d';
    Real 'h10d';
    Real 'h01d';
    Real 'h11d';
    Real 'aux3';
    Real 'aux2';
  algorithm
    'h' := 'x2' - 'x1';

    if abs('h') > 0.0 then
      't' := ('x' - 'x1') / 'h';
      'aux3' := 't' ^ 3.0;
      'aux2' := 't' ^ 2.0;
      'h00' := 2.0 * 'aux3' - 3.0 * 'aux2' + 1.0;
      'h10' := 'aux3' - 2.0 * 'aux2' + 't';
      'h01' := 3.0 * 'aux2' - 2.0 * 'aux3';
      'h11' := 'aux3' - 'aux2';
      'h00d' := 6.0 * ('aux2' - 't');
      'h10d' := 3.0 * 'aux2' - 4.0 * 't' + 1.0;
      'h01d' := 6.0 * ('t' - 'aux2');
      'h11d' := 3.0 * 'aux2' - 2.0 * 't';
      'y' := 'y1' * 'h00' + 'h' * 'y1d' * 'h10' + 'y2' * 'h01' + 'h' * 'y2d' * 'h11';
      'dy_dx' := 'y1' * 'h00d' / 'h' + 'y1d' * 'h10d' + 'y2' * 'h01d' / 'h' + 'y2d' * 'h11d';
    elseif true then
      'y' := ('y1' + 'y2') / 2.0;
      'dy_dx' := sign('y2' - 'y1') * 1e60;
    end if;
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Utilities.cubicHermite_withDerivative';

  function 'Modelica.Fluid.Utilities.regFun3' "Co-monotonic and C1 smooth regularization function"
    input Real 'x';
    input Real 'x0';
    input Real 'x1';
    input Real 'y0';
    input Real 'y1';
    input Real 'y0d';
    input Real 'y1d';
    output Real 'y';
    output Real 'c';
    Real 'h0';
    Real 'Delta0';
    Real 'xstar';
    Real 'mu';
    Real 'eta';
    Real 'omega';
    Real 'rho';
    Real 'theta0';
    Real 'mu_tilde';
    Real 'eta_tilde';
    Real 'xi1';
    Real 'xi2';
    Real 'a1';
    Real 'a2';
    Real 'const12';
    Real 'const3';
    Real 'aux01';
    Real 'aux02';
    Boolean 'useSingleCubicPolynomial' = false;
  algorithm
    assert('x0' < 'x1', "regFun3(): Data points not sorted appropriately (x0 = " + String('x0') + " > x1 = " + String('x1') + "). Please flip arguments.", AssertionLevel.error);

    if 'y0d' * 'y1d' >= 0.0 then
    elseif true then
      assert(abs('y0d') < 2.220446049250313e-16 or abs('y1d') < 2.220446049250313e-16, "regFun3(): Derivatives at data points do not allow co-monotone interpolation, as both are non-zero, of opposite sign and have an absolute value larger than machine eps (y0d = " + String('y0d') + ", y1d = " + String('y1d') + "). Please correct arguments.", AssertionLevel.error);
    end if;

    'h0' := 'x1' - 'x0';
    'Delta0' := ('y1' - 'y0') / 'h0';

    if abs('Delta0') <= 0.0 then
      'y' := 'y0' + 'Delta0' * ('x' - 'x0');
      'c' := 0.0;
    elseif abs('y1d' + 'y0d' - 2.0 * 'Delta0') < 2.220446049250313e-14 then
      'y' := 'y0' + ('x' - 'x0') * ('y0d' + ('x' - 'x0') / 'h0' * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d') + ('x' - 'x0') * ('y0d' + 'y1d' - 2.0 * 'Delta0') / 'h0'));
      'aux01' := ('x0' + 'x1') / 2.0;
      'c' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('aux01' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('aux01' - 'x0') / 'h0' + 'y0d';
    elseif true then
      'xstar' := 0.3333333333333333 * (6.0 * 'x0' * 'Delta0' - (3.0 * 'x0' * 'y0d' + 3.0 * 'x0' * 'y1d') - 2.0 * 'h0' * 'y0d' - 'h0' * 'y1d' + 3.0 * 'h0' * 'Delta0') / (2.0 * 'Delta0' - ('y0d' + 'y1d'));
      'mu' := 'xstar' - 'x0';
      'eta' := 'x1' - 'xstar';
      'omega' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('xstar' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('xstar' - 'x0') / 'h0' + 'y0d';
      'aux01' := 0.25 * sign('Delta0') * min(abs('omega'), abs('Delta0')) "Slope c if not using plain cubic S0";

      if abs('y0d' - 'y1d') <= 2.220446049250313e-14 then
        'aux02' := 'y0d';

        if 'y1' > 'y0' + 'y0d' * ('x1' - 'x0') then
          'useSingleCubicPolynomial' := true;
        end if;
      elseif abs('y1d' + 'y0d' - 2.0 * 'Delta0') < 2.220446049250313e-14 then
        'aux02' := (6.0 * 'Delta0' * ('y1d' + 'y0d' - 1.5 * 'Delta0') - 'y1d' * 'y0d' - 'y1d' ^ 2.0 - 'y0d' ^ 2.0) * (if 'y1d' + 'y0d' - 2.0 * 'Delta0' >= 0.0 then 1.0 else -1.0) * 1e60;
      elseif true then
        'aux02' := (6.0 * 'Delta0' * ('y1d' + 'y0d' - 1.5 * 'Delta0') - 'y1d' * 'y0d' - 'y1d' ^ 2.0 - 'y0d' ^ 2.0) / (3.0 * ('y1d' + 'y0d' - 2.0 * 'Delta0'));
      end if;

      if ((('mu' > 0.0 and 'eta' < 'h0') and 'Delta0' * 'omega' <= 0.0 or abs('aux01') < abs('aux02') and 'aux02' * 'Delta0' >= 0.0) or abs('aux01') < abs(0.1 * 'Delta0')) and not 'useSingleCubicPolynomial' then
        'c' := 'aux01';

        if abs('c') < abs('aux02') and 'aux02' * 'Delta0' >= 0.0 then
          'c' := 'aux02';
        end if;

        if abs('c') < abs(0.1 * 'Delta0') then
          'c' := 0.1 * 'Delta0';
        end if;

        'theta0' := ('y0d' * 'mu' + 'y1d' * 'eta') / 'h0';

        if abs('theta0' - 'c') < 1e-6 * abs('c') then
          'c' := 0.999999 * 'theta0';
        end if;

        'rho' := 3.0 * ('Delta0' - 'c') / ('theta0' - 'c');
        'mu_tilde' := 'rho' * 'mu';
        'eta_tilde' := 'rho' * 'eta';
        'xi1' := 'x0' + 'mu_tilde';
        'xi2' := 'x1' - 'eta_tilde';
        'a1' := ('y0d' - 'c') / max('mu_tilde' ^ 2.0, 2.220446049250313e-14);
        'a2' := ('y1d' - 'c') / max('eta_tilde' ^ 2.0, 2.220446049250313e-14);
        'const12' := 'y0' - 'a1' / 3.0 * ('x0' - 'xi1') ^ 3.0 - 'c' * 'x0';
        'const3' := 'y1' - 'a2' / 3.0 * ('x1' - 'xi2') ^ 3.0 - 'c' * 'x1';

        if 'x' < 'xi1' then
          'y' := 'a1' / 3.0 * ('x' - 'xi1') ^ 3.0 + 'c' * 'x' + 'const12';
        elseif 'x' < 'xi2' then
          'y' := 'c' * 'x' + 'const12';
        elseif true then
          'y' := 'a2' / 3.0 * ('x' - 'xi2') ^ 3.0 + 'c' * 'x' + 'const3';
        end if;
      elseif true then
        'y' := 'y0' + ('x' - 'x0') * ('y0d' + ('x' - 'x0') / 'h0' * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d') + ('x' - 'x0') * ('y0d' + 'y1d' - 2.0 * 'Delta0') / 'h0'));
        'aux01' := ('x0' + 'x1') / 2.0;
        'c' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('aux01' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('aux01' - 'x0') / 'h0' + 'y0d';
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Utilities.regFun3';

  function 'Modelica.Math.exp' "Exponential, base e"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := exp('u');
    annotation(Inline = true);
  end 'Modelica.Math.exp';

  function 'Modelica.Math.log10' "Base 10 logarithm (u shall be > 0)"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := log10('u');
    annotation(Inline = true);
  end 'Modelica.Math.log10';

  function 'Modelica.Units.Conversions.to_bar' "Convert from Pascal to bar"
    input Real 'Pa'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'bar'(unit = "bar", quantity = "Pressure");
  algorithm
    'bar' := 'Pa' / 1e5;
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_bar';

  function 'Modelica.Units.Conversions.to_degC' "Convert from kelvin to degree Celsius"
    input Real 'Kelvin'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'Celsius'(unit = "degC", quantity = "ThermodynamicTemperature");
  algorithm
    'Celsius' := 'Kelvin' - 273.15;
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_degC';

  function 'Modelica.Utilities.Streams.error' "Print error message and cancel all actions - in case of an unrecoverable error"
    input String 'string';
  algorithm
    assert(false, 'string', AssertionLevel.error);
  end 'Modelica.Utilities.Streams.error';

  type 'Modelica.Fluid.Types.Dynamics' = enumeration('DynamicFreeInitial', 'FixedInitial', 'SteadyStateInitial', 'SteadyState');

  type 'Modelica.Fluid.Types.PortFlowDirection' = enumeration('Entering', 'Leaving', 'Bidirectional');

  record 'tank.heatTransfer.Medium.ThermodynamicState'
    Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  end 'tank.heatTransfer.Medium.ThermodynamicState';

  record 'pipe.Medium.ThermodynamicState'
    Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  end 'pipe.Medium.ThermodynamicState';

  record 'pipe.flowModel.Medium.ThermodynamicState'
    Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  end 'pipe.flowModel.Medium.ThermodynamicState';

  model 'OneTank' "Tank with one time-varying top inlet mass flow rate and a bottom outlet into the ambient"
    Real 'tank.level'(stateSelect = StateSelect.prefer, start = 0.8, unit = "m", quantity = "Length") "Fluid level in the tank";
    parameter Real 'tank.height'(min = 0.0, unit = "m", quantity = "Length") = 1.0 "Maximum level of tank before it overflows";
    parameter Real 'tank.crossArea'(unit = "m2", quantity = "Area") = 1.0 "Area of tank";
    parameter Real 'tank.V0'(unit = "m3", quantity = "Volume") = 0.1 "Volume of the liquid when level = 0";
    parameter Real 'tank.p_ambient'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Tank surface pressure";
    parameter Real 'tank.T_ambient'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Tank surface Temperature";
    parameter Real 'tank.level_start'(min = 0.0, unit = "m", quantity = "Length") = 0.8 "Start value of tank level";
    Real 'tank.fluidVolume'(unit = "m3", quantity = "Volume") "Volume";
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'DynamicFreeInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'DynamicFreeInitial' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'DynamicFreeInitial' "Formulation of substance balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'DynamicFreeInitial' "Formulation of trace substance balance" annotation(Evaluate = true);
    parameter Real 'tank.p_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Boolean 'tank.use_T_start' = true "= true, use T_start, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'tank.T_start'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Start value of temperature";
    parameter Real 'tank.h_start'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.tank.Medium.specificEnthalpy_pTX'(101325.0, 'tank.T_start', {1.0}) "Start value of specific enthalpy";
    parameter Real 'tank.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    Real 'tank.medium.p'(stateSelect = StateSelect.prefer, nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank.medium.h'(start = 'tank.h_start', unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'tank.medium.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'tank.medium.T'(stateSelect = StateSelect.prefer, nominal = 300.0, start = 'tank.T_start', max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'tank.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'tank.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'tank.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'tank.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'tank.medium.state.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank.medium.state.T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    parameter Boolean 'tank.medium.preferredMediumStates' = true "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'tank.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'tank.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'tank.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'tank.U'(unit = "J", quantity = "Energy") "Internal energy of fluid";
    Real 'tank.m'(min = 0.0, unit = "kg", quantity = "Mass") "Mass of fluid";
    Real 'tank.mb_flow'(unit = "kg/s", quantity = "MassFlowRate") "Mass flows across boundaries";
    Real 'tank.Hb_flow'(unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow across boundaries or energy source/sink";
    Real 'tank.Qb_flow'(unit = "W", quantity = "Power") "Heat flow across boundaries or energy source/sink";
    Real 'tank.Wb_flow'(unit = "W", quantity = "Power") "Work flow across boundaries or source term";
    parameter Boolean 'tank.initialize_p' = false "= true to set up initial equations for pressure";
    parameter Integer 'tank.nTopPorts' = 1 "Number of inlet ports above height (>= 1)";
    Real 'tank.topPorts[1].m_flow'(start = 0.0, max = 1e5, min = 0.0, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'tank.topPorts[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'tank.topPorts[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Integer 'tank.nPorts' = 1 "Number of inlet/outlet ports (on bottom and on the side)";
    parameter Real 'tank.portsData[1].diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Inner (hydraulic) diameter of inlet/outlet port";
    parameter Real 'tank.portsData[1].height'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Height over the bottom of the vessel";
    parameter Real 'tank.portsData[1].zeta_out'(min = 0.0) = 0.5 "Hydraulic resistance out of vessel, default 0.5 for small diameter mounted flush with the wall";
    parameter Real 'tank.portsData[1].zeta_in'(min = 0.0) = 1.04 "Hydraulic resistance into vessel, default 1.04 for small diameter mounted flush with the wall";
    Real 'tank.ports[1].m_flow'(start = 0.0, max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'tank.ports[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'tank.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'tank.use_HeatTransfer' = false "= true, if HeatTransfer model is used";
    parameter Integer 'tank.heatTransfer.n' = 1 "Number of heat transfer segments" annotation(Evaluate = true);
    Real 'tank.heatTransfer.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank.heatTransfer.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'tank.heatTransfer.surfaceAreas[1]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'tank.heatTransfer.Q_flows[1]'(unit = "W", quantity = "Power") "Heat flow rates";
    parameter Boolean 'tank.heatTransfer.use_k' = false "= true to use k value for thermal isolation";
    parameter Real 'tank.heatTransfer.k'(unit = "W/(m2.K)", quantity = "CoefficientOfHeatTransfer") = 0.0 "Heat transfer coefficient to ambient" annotation(Evaluate = true);
    parameter Real 'tank.heatTransfer.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'tank.heatTransfer.heatPorts[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'tank.heatTransfer.heatPorts[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'tank.heatTransfer.Ts[1]'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    parameter Real 'tank.hysteresisFactor'(min = 0.0) = 0.01 "Hysteresis for empty pipe = diameter*hysteresisFactor";
    parameter Boolean 'tank.stiffCharacteristicForEmptyPort' = false "= true, if steep pressure loss characteristic for empty pipe port" annotation(Evaluate = true);
