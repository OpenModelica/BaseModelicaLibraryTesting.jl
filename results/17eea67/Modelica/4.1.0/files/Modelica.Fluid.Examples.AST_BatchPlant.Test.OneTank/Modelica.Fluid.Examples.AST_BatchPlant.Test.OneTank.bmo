    parameter Real 'pipe.flowModel.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 0.0 "Start value of mass flow rates";
    parameter Real 'pipe.flowModel.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[1] at design inflow";
    parameter Real 'pipe.flowModel.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[n+1] at design outflow";
