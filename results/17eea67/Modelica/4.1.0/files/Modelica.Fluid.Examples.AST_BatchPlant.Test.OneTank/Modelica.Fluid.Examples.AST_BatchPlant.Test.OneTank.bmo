    parameter Boolean 'pipe.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'pipe.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'pipe.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure loss for nominal conditions";
    parameter Real 'timeTable.table[1,1]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[1,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[2,1]' = 10.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[2,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[3,1]' = 10.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[3,2]' = 40.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[4,1]' = 20.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[4,2]' = 40.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[5,1]' = 20.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[5,2]' = 10.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[6,1]' = 50.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[6,2]' = 10.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[7,1]' = 50.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[7,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[8,1]' = 60.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[8,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[9,1]' = 60.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[9,2]' = 20.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[10,1]' = 70.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[10,2]' = 20.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[11,1]' = 80.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[11,2]' = 55.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[12,1]' = 80.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[12,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[13,1]' = 100.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[13,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.timeScale'(min = 2.220446049250313e-16, unit = "s", quantity = "Time") = 1.0 "Time scale of first table column" annotation(Evaluate = true);
    Real 'timeTable.y' "Connector of Real output signal";
    parameter Real 'timeTable.offset' = 0.0 "Offset of output signal y";
    parameter Real 'timeTable.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'timeTable.shiftTime'(unit = "s", quantity = "Time") = 0.0 "Shift time of first table column";
    discrete Real 'timeTable.a' "Interpolation coefficient a of actual interval (y=a*x+b)";
    discrete Real 'timeTable.b' "Interpolation coefficient b of actual interval (y=a*x+b)";
    Integer 'timeTable.last'(start = 1) "Last used lower grid index";
    discrete Real 'timeTable.nextEvent'(fixed = true, start = 0.0, unit = "s", quantity = "Time") "Next event instant";
    discrete Real 'timeTable.nextEventScaled'(fixed = true, start = 0.0) "Next scaled event instant";
    Real 'timeTable.timeScaled' "Scaled time";
  initial equation
    pre('tank.aboveLevel[1]') = 0.8 >= 'tank.portsData_height2[1]';
    'pipe.flowModel.dp_nominal' = 1000.0 * 'pipe.flowModel.dp_small';
    'pipe.flowModel.dp_small' = 1.0;
  equation
    'tank.fluidVolume' = 'tank.V';
    'tank.medium.T_degC' = 'Modelica.Units.Conversions.to_degC'('tank.medium.T');
    'tank.medium.p_bar' = 'Modelica.Units.Conversions.to_bar'('tank.medium.p');
    'tank.heatTransfer.states[1].p' = 'tank.medium.state.p';
    'tank.heatTransfer.states[1].T' = 'tank.medium.state.T';
    'flowSource.medium.T_degC' = 'Modelica.Units.Conversions.to_degC'('flowSource.medium.T');
    'flowSource.medium.p_bar' = 'Modelica.Units.Conversions.to_bar'('flowSource.medium.p');
    'ambient_fixed.medium.T_degC' = 'Modelica.Units.Conversions.to_degC'('ambient_fixed.medium.T');
    'ambient_fixed.medium.p_bar' = 'Modelica.Units.Conversions.to_bar'('ambient_fixed.medium.p');
    'pipe.flowModel.dp_fric_nominal' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.pressureLoss_m_flow'('pipe.flowModel.m_flow_nominal', 995.586, 995.586, 0.001, 0.001, 'pipe.flowModel.pathLengths_internal[1]', 'pipe.flowModel.diameters[1]', ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') / 2.0, ('pipe.flowModel.roughnesses[1]' + 'pipe.flowModel.roughnesses[2]') / 2.0, 'pipe.flowModel.m_flow_small', 'pipe.flowModel.Res_turbulent_internal[1]');
    'tank.portsData_diameter[1]' = 'tank.portsData_diameter2[1]';
    'tank.portsData_height[1]' = 'tank.portsData_height2[1]';
    'flowSource.m_flow_in' = 'flowSource.m_flow_in_internal';
    'flowSource.ports[1].p' = 'tank.topPorts[1].p';
    'tank.ports[1].p' = 'pipe.port_a.p';
    'pipe.port_b.p' = 'ambient_fixed.ports[1].p';
    'timeTable.y' = 'flowSource.m_flow_in';
    'pipe.port_a.m_flow' + 'tank.ports[1].m_flow' = 0.0;
    'tank.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'flowSource.ports[1].m_flow' + 'tank.topPorts[1].m_flow' = 0.0;
    'pipe.port_b.m_flow' + 'ambient_fixed.ports[1].m_flow' = 0.0;
    assert('tank.medium.T' >= 272.15 and 'tank.medium.T' <= 403.15, "\nTemperature T (= " + String('tank.medium.T') + " K) is not\nin the allowed range (" + String(272.15) + " K <= T <= " + String(403.15) + " K)\nrequired from medium model \"" + "SimpleLiquidWater" + "\".\n", AssertionLevel.error);
    'tank.medium.h' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.tank.Medium.specificEnthalpy_pTX'('tank.medium.p', 'tank.medium.T', {'tank.medium.X[1]'});
    'tank.medium.u' = 4184.0 * ('tank.medium.T' - 273.15);
    'tank.medium.d' = 995.586;
    'tank.medium.R_s' = 0.0;
    'tank.medium.MM' = 0.018015268;
    'tank.medium.state.T' = 'tank.medium.T';
    'tank.medium.state.p' = 'tank.medium.p';
    'tank.medium.X[1]' = 1.0;
    assert('tank.medium.X[1]' >= (-1e-5) and 'tank.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('tank.medium.X[1]') + "of substance " + "SimpleLiquidWater" + "\nof medium " + "SimpleLiquidWater" + " is not in the range 0..1", AssertionLevel.error);
    assert('tank.medium.p' >= 0.0, "Pressure (= " + String('tank.medium.p') + " Pa) of medium \"" + "SimpleLiquidWater" + "\" is negative\n(Temperature = " + String('tank.medium.T') + " K)", AssertionLevel.error);
    'tank.heatTransfer.surfaceAreas[1]' = 1.0 + 3.5449077018110318 * 'tank.level';
    'tank.heatTransfer.Ts[1]' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.tank.heatTransfer.Medium.temperature'('tank.heatTransfer.states[1]');
    'tank.heatTransfer.Ts[1]' = 'tank.heatTransfer.heatPorts[1].T';
    'tank.heatTransfer.Q_flows[1]' = 'tank.heatTransfer.heatPorts[1].Q_flow';
    'tank.portsData_diameter[1]' = 'tank.portsData[1].diameter';
    'tank.portsData_height[1]' = 'tank.portsData[1].height';
    assert('tank.level' <= 1.0, "Tank starts to overflow (level = height = " + String('tank.level') + ")", AssertionLevel.error);
    assert('tank.m' >= 0.0, "Mass in tank is zero", AssertionLevel.error);
    'tank.bottomArea[1]' = 3.141592653589793 * ('tank.portsData_diameter2[1]' / 2.0) ^ 2.0;
    'tank.ports_emptyPipeHysteresis[1]' = 'tank.portsData_diameter2[1]' * 0.01;
    'tank.medium.p' = 101325.0;
    'tank.V' = 'tank.level' + 0.1 "Volume of fluid";
    'tank.mb_flow' = 'tank.topPorts[1].m_flow' + 'tank.ports[1].m_flow';
    'tank.Hb_flow' = 'tank.H_flow_top[1]' + 'tank.port_b_H_flow_bottom[1]';
    'tank.Qb_flow' = 'tank.heatTransfer.Q_flows[1]';
    'tank.Wb_flow' = 0.0 "Mechanical work is neglected, since also neglected in medium model (otherwise unphysical small temperature change, if tank level changes)";
    'tank.H_flow_top[1]' = 'tank.topPorts[1].m_flow' * 'flowSource.ports[1].h_outflow';
    'tank.topPorts[1].p' = 101325.0;
    'tank.topPorts[1].h_outflow' = 'tank.h_start';
    'tank.port_b_H_flow_bottom[1]' = smooth(0, 'tank.ports[1].m_flow' * (if 'tank.ports[1].m_flow' > 0.0 then 'pipe.port_a.h_outflow' else 'tank.ports[1].h_outflow'));
    'tank.aboveLevel[1]' = 'tank.level' >= 'tank.portsData_height2[1]' + 'tank.ports_emptyPipeHysteresis[1]' or pre('tank.aboveLevel[1]') and 'tank.level' >= 'tank.portsData_height2[1]' - 'tank.ports_emptyPipeHysteresis[1]';
    'tank.levelAbovePort[1]' = if 'tank.aboveLevel[1]' then 'tank.level' - 'tank.portsData_height2[1]' else 0.0;
    'tank.ports[1].h_outflow' = 'tank.medium.h';
    'tank.ports_m_flow_out[1]' = pre('tank.ports_m_flow_out[1]') and not 'tank.ports[1].p' > 101325.0 or 'tank.ports[1].m_flow' < (-1e-6);

    if 'tank.aboveLevel[1]' then
      'tank.ports[1].p' = 101325.0 + 'tank.levelAbovePort[1]' * 9.80665 * 'tank.medium.d' - smooth(2, noEvent(if 'tank.ports[1].m_flow' < 0.0 then 'tank.ports[1].m_flow' ^ 2.0 / (2.0 * 'tank.medium.d' * 'tank.bottomArea[1]' ^ 2.0) else 0.0));
    elseif true then
      if pre('tank.ports_m_flow_out[1]') then
        'tank.ports[1].m_flow' = 0.0;
      elseif true then
        'tank.ports[1].p' = 101325.0;
      end if;
    end if;

    'tank.zetas_out[1]' = 0.0;
    'tank.m' = 'tank.fluidVolume' * 'tank.medium.d';
    'tank.U' = 'tank.m' * 'tank.medium.u';
    der('tank.U') = 'tank.Hb_flow' + 'tank.Qb_flow' + 'tank.Wb_flow';
    der('tank.m') = 'tank.mb_flow';
    assert('flowSource.medium.T' >= 272.15 and 'flowSource.medium.T' <= 403.15, "\nTemperature T (= " + String('flowSource.medium.T') + " K) is not\nin the allowed range (" + String(272.15) + " K <= T <= " + String(403.15) + " K)\nrequired from medium model \"" + "SimpleLiquidWater" + "\".\n", AssertionLevel.error);
    'flowSource.medium.h' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.flowSource.Medium.specificEnthalpy_pTX'('flowSource.medium.p', 'flowSource.medium.T', {'flowSource.medium.X[1]'});
    'flowSource.medium.u' = 4184.0 * ('flowSource.medium.T' - 273.15);
    'flowSource.medium.d' = 995.586;
    'flowSource.medium.R_s' = 0.0;
    'flowSource.medium.MM' = 0.018015268;
    'flowSource.medium.state.T' = 'flowSource.medium.T';
    'flowSource.medium.state.p' = 'flowSource.medium.p';
    'flowSource.medium.X[1]' = 1.0;
    assert('flowSource.medium.X[1]' >= (-1e-5) and 'flowSource.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('flowSource.medium.X[1]') + "of substance " + "SimpleLiquidWater" + "\nof medium " + "SimpleLiquidWater" + " is not in the range 0..1", AssertionLevel.error);
    assert('flowSource.medium.p' >= 0.0, "Pressure (= " + String('flowSource.medium.p') + " Pa) of medium \"" + "SimpleLiquidWater" + "\" is negative\n(Temperature = " + String('flowSource.medium.T') + " K)", AssertionLevel.error);
    'Modelica.Fluid.Utilities.checkBoundary'("SimpleLiquidWater", {"SimpleLiquidWater"}, true, true, {'flowSource.X_in_internal[1]'}, "MassFlowSource_T");
    'flowSource.T_in_internal' = 293.15;
    'flowSource.X_in_internal[1]' = 1.0;
    'flowSource.medium.T' = 'flowSource.T_in_internal';
    'flowSource.ports[1].m_flow' = -'flowSource.m_flow_in_internal';
    'flowSource.ports[1].p' = 'flowSource.medium.p';
    'flowSource.ports[1].h_outflow' = 'flowSource.medium.h';
    assert('ambient_fixed.medium.T' >= 272.15 and 'ambient_fixed.medium.T' <= 403.15, "\nTemperature T (= " + String('ambient_fixed.medium.T') + " K) is not\nin the allowed range (" + String(272.15) + " K <= T <= " + String(403.15) + " K)\nrequired from medium model \"" + "SimpleLiquidWater" + "\".\n", AssertionLevel.error);
    'ambient_fixed.medium.h' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.ambient_fixed.Medium.specificEnthalpy_pTX'('ambient_fixed.medium.p', 'ambient_fixed.medium.T', {'ambient_fixed.medium.X[1]'});
    'ambient_fixed.medium.u' = 4184.0 * ('ambient_fixed.medium.T' - 273.15);
    'ambient_fixed.medium.d' = 995.586;
    'ambient_fixed.medium.R_s' = 0.0;
    'ambient_fixed.medium.MM' = 0.018015268;
    'ambient_fixed.medium.state.T' = 'ambient_fixed.medium.T';
    'ambient_fixed.medium.state.p' = 'ambient_fixed.medium.p';
    'ambient_fixed.medium.X[1]' = 1.0;
    assert('ambient_fixed.medium.X[1]' >= (-1e-5) and 'ambient_fixed.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('ambient_fixed.medium.X[1]') + "of substance " + "SimpleLiquidWater" + "\nof medium " + "SimpleLiquidWater" + " is not in the range 0..1", AssertionLevel.error);
    assert('ambient_fixed.medium.p' >= 0.0, "Pressure (= " + String('ambient_fixed.medium.p') + " Pa) of medium \"" + "SimpleLiquidWater" + "\" is negative\n(Temperature = " + String('ambient_fixed.medium.T') + " K)", AssertionLevel.error);
    'Modelica.Fluid.Utilities.checkBoundary'("SimpleLiquidWater", {"SimpleLiquidWater"}, true, true, {'ambient_fixed.X_in_internal[1]'}, "Boundary_pT");
    'ambient_fixed.p_in_internal' = 101325.0;
    'ambient_fixed.T_in_internal' = 293.15;
    'ambient_fixed.X_in_internal[1]' = 1.0;
    'ambient_fixed.medium.p' = 'ambient_fixed.p_in_internal';
    'ambient_fixed.medium.T' = 'ambient_fixed.T_in_internal';
    'ambient_fixed.ports[1].p' = 'ambient_fixed.medium.p';
    'ambient_fixed.ports[1].h_outflow' = 'ambient_fixed.medium.h';
    'pipe.flowModel.states[1].p' = ('Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.setState_phX'('pipe.port_a.p', 'tank.ports[1].h_outflow', fill(0.0, 0))).p;
    'pipe.flowModel.states[1].T' = ('Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.setState_phX'('pipe.port_a.p', 'tank.ports[1].h_outflow', fill(0.0, 0))).T;
    'pipe.flowModel.states[2].p' = ('Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.setState_phX'('pipe.port_b.p', 'ambient_fixed.ports[1].h_outflow', fill(0.0, 0))).p;
    'pipe.flowModel.states[2].T' = ('Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.setState_phX'('pipe.port_b.p', 'ambient_fixed.ports[1].h_outflow', fill(0.0, 0))).T;
    'pipe.flowModel.vs[1]' = 'pipe.port_a.m_flow' / 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.density'('pipe.flowModel.states[1]') / 'pipe.flowModel.crossAreas[1]';
    'pipe.flowModel.vs[2]' = -'pipe.port_b.m_flow' / 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.Medium.density'('pipe.flowModel.states[2]') / 'pipe.flowModel.crossAreas[2]';
    'pipe.flowModel.crossAreas[1]' = 0.007853981633974483;
    'pipe.flowModel.crossAreas[2]' = 0.007853981633974483;
    'pipe.flowModel.dimensions[1]' = 0.1;
    'pipe.flowModel.dimensions[2]' = 0.1;
    'pipe.flowModel.roughnesses[1]' = 2.5e-5;
    'pipe.flowModel.roughnesses[2]' = 2.5e-5;
    'pipe.flowModel.dheights[1]' = -1.0;
    'pipe.flowModel.pathLengths[1]' = 1.0;
    'pipe.flowModel.rhos[1]' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.density'('pipe.flowModel.states[1]');
    'pipe.flowModel.rhos[2]' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.density'('pipe.flowModel.states[2]');
    'pipe.flowModel.mus[1]' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.dynamicViscosity'('pipe.flowModel.states[1]');
    'pipe.flowModel.mus[2]' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.dynamicViscosity'('pipe.flowModel.states[2]');
    'pipe.flowModel.pathLengths_internal[1]' = 'pipe.flowModel.pathLengths[1]';
    'pipe.flowModel.Res_turbulent_internal[1]' = 4000.0;
    'pipe.flowModel.diameters[1]' = 0.5 * ('pipe.flowModel.dimensions[1]' + 'pipe.flowModel.dimensions[2]');
    'pipe.flowModel.m_flows[1]' = homotopy('Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead'('pipe.flowModel.dps_fg[1]', 'pipe.flowModel.rhos[1]', 'pipe.flowModel.rhos[2]', 'pipe.flowModel.mus[1]', 'pipe.flowModel.mus[2]', 'pipe.flowModel.pathLengths_internal[1]', 'pipe.flowModel.diameters[1]', 9.80665 * 'pipe.flowModel.dheights[1]', ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') / 2.0, ('pipe.flowModel.roughnesses[1]' + 'pipe.flowModel.roughnesses[2]') / 2.0, 'pipe.flowModel.dp_small', 'pipe.flowModel.Res_turbulent_internal[1]'), 'pipe.flowModel.m_flow_nominal' / 'pipe.flowModel.dp_nominal' * ('pipe.flowModel.dps_fg[1]' - 9.80665 * 'pipe.flowModel.dheights[1]' * 995.586));
    'pipe.flowModel.rhos_act[1]' = noEvent(if 'pipe.flowModel.m_flows[1]' > 0.0 then 'pipe.flowModel.rhos[1]' else 'pipe.flowModel.rhos[2]');
    'pipe.flowModel.mus_act[1]' = noEvent(if 'pipe.flowModel.m_flows[1]' > 0.0 then 'pipe.flowModel.mus[1]' else 'pipe.flowModel.mus[2]');
    'pipe.flowModel.Ib_flows[1]' = 0.0;
    'pipe.flowModel.Fs_p[1]' = 0.5 * ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') * ('Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.pressure'('pipe.flowModel.states[2]') - 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.pipe.flowModel.Medium.pressure'('pipe.flowModel.states[1]'));
    'pipe.flowModel.dps_fg[1]' = 'pipe.flowModel.Fs_fg[1]' * 2.0 / ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]');
    'pipe.flowModel.Is[1]' = 'pipe.flowModel.m_flows[1]' * 'pipe.flowModel.pathLengths[1]';
    0.0 = 'pipe.flowModel.Ib_flows[1]' - 'pipe.flowModel.Fs_p[1]' - 'pipe.flowModel.Fs_fg[1]';
    'pipe.port_a.m_flow' = 'pipe.flowModel.m_flows[1]';
    0.0 = 'pipe.port_a.m_flow' + 'pipe.port_b.m_flow';
    'pipe.port_b.h_outflow' = 'tank.ports[1].h_outflow' + 9.80665;
    'pipe.port_a.h_outflow' = 'ambient_fixed.ports[1].h_outflow' - 9.80665;
    'timeTable.timeScaled' = time;
    'timeTable.y' = 'timeTable.a' * 'timeTable.timeScaled' + 'timeTable.b';
  algorithm
    assert(true, "The first point in time has to be set to 0, but is table[1,1] = 0", AssertionLevel.error);

    when {time >= pre('timeTable.nextEvent'), initial()} then
      ('timeTable.a', 'timeTable.b', 'timeTable.nextEventScaled', 'timeTable.last') := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.OneTank.timeTable.getInterpolationCoefficients'({{0.0, 0.0}, {10.0, 0.0}, {10.0, 40.0}, {20.0, 40.0}, {20.0, 10.0}, {50.0, 10.0}, {50.0, 0.0}, {60.0, 0.0}, {60.0, 20.0}, {70.0, 20.0}, {80.0, 55.0}, {80.0, 0.0}, {100.0, 0.0}}, 0.0, 0.0, 'timeTable.timeScaled', 'timeTable.last', 2.220446049250313e-14, 0.0);
      'timeTable.nextEvent' := 'timeTable.nextEventScaled';
    end when;
    annotation(experiment(StopTime = 100));
  end 'OneTank';
end 'OneTank';
