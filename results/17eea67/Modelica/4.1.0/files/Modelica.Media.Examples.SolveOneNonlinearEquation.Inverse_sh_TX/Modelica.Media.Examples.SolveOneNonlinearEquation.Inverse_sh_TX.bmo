//! base 0.1.0
package 'Inverse_sh_TX'
  function 'Modelica.Math.log' "Natural (base e) logarithm (u shall be > 0)"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := log('u');
    annotation(Inline = true);
  end 'Modelica.Math.log';

  function 'Modelica.Math.Nonlinear.solveOneNonlinearEquation' "Solve f(u) = 0 in a very reliable and efficient way (f(u_min) and f(u_max) must have different signs)"
    input 'Modelica.Math.Nonlinear.Interfaces.partialScalarFunction' 'f';
    input Real 'u_min';
    input Real 'u_max';
    input Real 'tolerance' = 2.220446049250313e-14;
    output Real 'u';
    constant Real 'eps' = 2.220446049250313e-16;
    Real 'a' = 'u_min';
    Real 'b' = 'u_max';
    Real 'c';
    Real 'd';
    Real 'e';
    Real 'm';
    Real 's';
    Real 'p';
    Real 'q';
    Real 'r';
    Real 'tol';
    Real 'fa';
    Real 'fb';
    Real 'fc';
    Boolean 'found' = false;
  algorithm
    'fa' := 'f'('u_min');
    'fb' := 'f'('u_max');
    'fc' := 'fb';

    if 'fa' > 0.0 and 'fb' > 0.0 or 'fa' < 0.0 and 'fb' < 0.0 then
      'Modelica.Utilities.Streams.error'("The arguments u_min and u_max provided in the function call\n    solveOneNonlinearEquation(f,u_min,u_max)\ndo not bracket the root of the single non-linear equation 0=f(u):\n  u_min  = " + String('u_min') + "\n" + "  u_max  = " + String('u_max') + "\n" + "  fa = f(u_min) = " + String('fa') + "\n" + "  fb = f(u_max) = " + String('fb') + "\n" + "fa and fb must have opposite sign which is not the case");
    end if;

    'c' := 'a';
    'fc' := 'fa';
    'e' := 'b' - 'a';
    'd' := 'e';

    while not 'found' loop
      if abs('fc') < abs('fb') then
        'a' := 'b';
        'b' := 'c';
        'c' := 'a';
        'fa' := 'fb';
        'fb' := 'fc';
        'fc' := 'fa';
      end if;

      'tol' := 2.0 * 'eps' * abs('b') + 'tolerance';
      'm' := ('c' - 'b') / 2.0;

      if abs('m') <= 'tol' or 'fb' == 0.0 then
        'found' := true;
        'u' := 'b';
      elseif true then
        if abs('e') < 'tol' or abs('fa') <= abs('fb') then
          'e' := 'm';
          'd' := 'e';
        elseif true then
          's' := 'fb' / 'fa';

          if 'a' == 'c' then
            'p' := 2.0 * 'm' * 's';
            'q' := 1.0 - 's';
          elseif true then
            'q' := 'fa' / 'fc';
            'r' := 'fb' / 'fc';
            'p' := 's' * (2.0 * 'm' * 'q' * ('q' - 'r') - ('b' - 'a') * ('r' - 1.0));
            'q' := ('q' - 1.0) * ('r' - 1.0) * ('s' - 1.0);
          end if;

          if 'p' > 0.0 then
            'q' := -'q';
          elseif true then
            'p' := -'p';
          end if;

          's' := 'e';
          'e' := 'd';

          if 2.0 * 'p' < 3.0 * 'm' * 'q' - abs('tol' * 'q') and 'p' < abs(0.5 * 's' * 'q') then
            'd' := 'p' / 'q';
          elseif true then
            'e' := 'm';
            'd' := 'e';
          end if;
        end if;

        'a' := 'b';
        'fa' := 'fb';
        'b' := 'b' + (if abs('d') > 'tol' then 'd' else if 'm' > 0.0 then 'tol' else -'tol');
        'fb' := 'f'('b');

        if 'fb' > 0.0 and 'fc' > 0.0 or 'fb' < 0.0 and 'fc' < 0.0 then
          'c' := 'a';
          'fc' := 'fa';
          'e' := 'b' - 'a';
          'd' := 'e';
        end if;
      end if;
    end while;
  end 'Modelica.Math.Nonlinear.solveOneNonlinearEquation';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX' "Return temperature from specific enthalpy and mass fraction"
    input Real 'h'(nominal = 1e5, start = 3e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[4] 'X'(nominal = {0.1, 0.1, 0.1, 0.1}, max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"kg/kg", "kg/kg", "kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction", "MassFraction", "MassFraction"});
    input Boolean 'exclEnthForm' = true;
    input 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' 'refChoice' = 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K';
    input Real 'h_off'(unit = "J/kg", quantity = "SpecificEnergy") = 0.0;
    output Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX.f_nonlinear'(h = 'h', X = 'X', exclEnthForm = 'exclEnthForm', refChoice = 'refChoice', h_off = 'h_off'), 200.0, 6000.0, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.h_TX('T', 'X', 'exclEnthForm', 'refChoice', 'h_off')));
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX' "Return temperature from pressure, specific entropy and mass fraction"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
    input Real[4] 'X'(nominal = {0.1, 0.1, 0.1, 0.1}, max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"kg/kg", "kg/kg", "kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction", "MassFraction", "MassFraction"});
    output Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX.f_nonlinear'(p = 'p', s = 's', X = 'X'), 200.0, 6000.0, 2.220446049250313e-14);
    annotation(inverse(s = Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropyOfpTX('p', 'T', 'X')));
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.h_TX' "Return specific enthalpy"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'X'(nominal = {0.1, 0.1, 0.1, 0.1}, max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"kg/kg", "kg/kg", "kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction", "MassFraction", "MassFraction"}) = {0.768, 0.232, 0.0, 0.0};
    input Boolean 'exclEnthForm' = true;
    input 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' 'refChoice' = 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K';
    input Real 'h_off'(unit = "J/kg", quantity = "SpecificEnergy") = 0.0;
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'X' * {'Modelica.Media.IdealGases.Common.Functions.h_T'(({'Modelica.Media.IdealGases.Common.DataRecord'("N2", 0.0280134, 0.0, 309498.4543111511, 1000.0, {22103.71497, -381.846182, 6.08273836, -0.00853091441, 1.384646189e-5, -9.62579362e-9, 2.519705809e-12}, {710.846086, -10.76003744}, {587712.406, -2239.249073, 6.06694922, -6.1396855e-4, 1.491806679e-7, -1.923105485e-11, 1.061954386e-15}, {12832.10415, -15.86640027}, 296.80474344420884), 'Modelica.Media.IdealGases.Common.DataRecord'("O2", 0.0319988, 0.0, 271263.4223783392, 1000.0, {-34255.6342, 484.700097, 1.119010961, 0.00429388924, -6.83630052e-7, -2.0233727e-9, 1.039040018e-12}, {-3391.45487, 18.4969947}, {-1.037939022e6, 2344.830282, 1.819732036, 0.001267847582, -2.188067988e-7, 2.053719572e-11, -8.193467050000001e-16}, {-16890.10929, 17.38716506}, 259.8381814318037), 'Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'Modelica.Media.IdealGases.Common.DataRecord'("CO2", 0.0440095, -8.941478544405185e6, 212805.6215135368, 1000.0, {49436.5054, -626.411601, 5.30172524, 0.002503813816, -2.127308728e-7, -7.68998878e-10, 2.849677801e-13}, {-45281.9846, -7.04827944}, {117696.2419, -1788.791477, 8.29152319, -9.22315678e-5, 4.86367688e-9, -1.891053312e-12, 6.330036589999999e-16}, {-39083.5059, -26.52669281}, 188.92534566400437)})['i'], 'T', 'exclEnthForm', 'refChoice', 'h_off') for 'i' in 1:4};
    annotation(Inline = false, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.h_TX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.massToMoleFractions' "Return mole fractions from mass fractions X"
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real[:] 'MMX'(min = fill(0.0, size('MMX', 1)), unit = fill("kg/mol", size('MMX', 1)), quantity = fill("MolarMass", size('MMX', 1)));
    output Real[size('X', 1)] 'moleFractions'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MoleFraction", size('X', 1)));
    Real[size('X', 1)] 'invMMX';
    Real 'Mmix'(min = 0.0, unit = "kg/mol", quantity = "MolarMass");
  algorithm
    for 'i' in 1:size('X', 1) loop
      'invMMX'['i'] := 1.0 / 'MMX'['i'];
    end for;

    'Mmix' := 1.0 / ('X' * 'invMMX');

    for 'i' in 1:size('X', 1) loop
      'moleFractions'['i'] := 'Mmix' * 'X'['i'] / 'MMX'['i'];
    end for;
    annotation(smoothOrder = 5);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.massToMoleFractions';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.s_TX' "Return temperature dependent part of the entropy, expects full entropy vector"
    input Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'X'(nominal = {0.1, 0.1, 0.1, 0.1}, max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"kg/kg", "kg/kg", "kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction", "MassFraction", "MassFraction"});
    output Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
  algorithm
    's' := 'Modelica.Media.IdealGases.Common.Functions.s0_T'('Modelica.Media.IdealGases.Common.DataRecord'("N2", 0.0280134, 0.0, 309498.4543111511, 1000.0, {22103.71497, -381.846182, 6.08273836, -0.00853091441, 1.384646189e-5, -9.62579362e-9, 2.519705809e-12}, {710.846086, -10.76003744}, {587712.406, -2239.249073, 6.06694922, -6.1396855e-4, 1.491806679e-7, -1.923105485e-11, 1.061954386e-15}, {12832.10415, -15.86640027}, 296.80474344420884), 'T') * 'X'[1] + 'Modelica.Media.IdealGases.Common.Functions.s0_T'('Modelica.Media.IdealGases.Common.DataRecord'("O2", 0.0319988, 0.0, 271263.4223783392, 1000.0, {-34255.6342, 484.700097, 1.119010961, 0.00429388924, -6.83630052e-7, -2.0233727e-9, 1.039040018e-12}, {-3391.45487, 18.4969947}, {-1.037939022e6, 2344.830282, 1.819732036, 0.001267847582, -2.188067988e-7, 2.053719572e-11, -8.193467050000001e-16}, {-16890.10929, 17.38716506}, 259.8381814318037), 'T') * 'X'[2] + 'Modelica.Media.IdealGases.Common.Functions.s0_T'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T') * 'X'[3] + 'Modelica.Media.IdealGases.Common.Functions.s0_T'('Modelica.Media.IdealGases.Common.DataRecord'("CO2", 0.0440095, -8.941478544405185e6, 212805.6215135368, 1000.0, {49436.5054, -626.411601, 5.30172524, 0.002503813816, -2.127308728e-7, -7.68998878e-10, 2.849677801e-13}, {-45281.9846, -7.04827944}, {117696.2419, -1788.791477, 8.29152319, -9.22315678e-5, 4.86367688e-9, -1.891053312e-12, 6.330036589999999e-16}, {-39083.5059, -26.52669281}, 188.92534566400437), 'T') * 'X'[4];
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.s_TX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX' "Return thermodynamic state as function of p, T and composition X"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output 'Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 0 then 'Medium.ThermodynamicState'('p', 'T', {0.768, 0.232, 0.0, 0.0}) else if size('X', 1) == 4 then 'Medium.ThermodynamicState'('p', 'T', 'X') else 'Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_phX' "Return thermodynamic state as function of p, h and composition X"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e5, start = 3e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output 'Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 0 then 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX'('h', {0.768, 0.232, 0.0, 0.0}, true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0), {0.768, 0.232, 0.0, 0.0}) else if size('X', 1) == 4 then 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX'('h', 'X', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0), 'X') else 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX'('h', 'X', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0), cat(1, 'X', {1.0 - sum('X')}));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_phX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_psX' "Return thermodynamic state as function of p, s and composition X"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output 'Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 0 then 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX'('p', 's', {0.768, 0.232, 0.0, 0.0}), {0.768, 0.232, 0.0, 0.0}) else if size('X', 1) == 4 then 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX'('p', 's', 'X'), 'X') else 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX'('p', 's', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_psX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEnthalpy' "Return specific enthalpy"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e5, start = 3e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.h_TX'('state'.'T', 'state'.'X', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEnthalpy';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output Real 'h'(nominal = 1e5, start = 3e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEnthalpy'('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEnthalpy_pTX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropy' "Return specific entropy"
    input 'Medium.ThermodynamicState' 'state';
    output Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
  algorithm
    's' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropyOfpTX'('state'.'p', 'state'.'T', 'state'.'X');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropy';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropyOfpTX' "Return specific entropy from pressure, temperature and mass fractions"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'X'(nominal = {0.1, 0.1, 0.1, 0.1}, max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"kg/kg", "kg/kg", "kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction", "MassFraction", "MassFraction"});
    output Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real[4] 'Y'(each unit = "mol/mol") = 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.massToMoleFractions'('X', {0.0280134, 0.0319988, 0.01801528, 0.0440095});
  algorithm
    's' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.s_TX'('T', 'X') - ('X'[1] * 8.31446261815324 / 0.0280134 * (if 'X'[1] < 2.220446049250313e-16 then 'Y'[1] else 'Modelica.Math.log'('Y'[1] * 'p' / 101325.0)) + 'X'[2] * 8.31446261815324 / 0.0319988 * (if 'X'[2] < 2.220446049250313e-16 then 'Y'[2] else 'Modelica.Math.log'('Y'[2] * 'p' / 101325.0)) + 'X'[3] * 8.31446261815324 / 0.01801528 * (if 'X'[3] < 2.220446049250313e-16 then 'Y'[3] else 'Modelica.Math.log'('Y'[3] * 'p' / 101325.0)) + 'X'[4] * 8.31446261815324 / 0.0440095 * (if 'X'[4] < 2.220446049250313e-16 then 'Y'[4] else 'Modelica.Math.log'('Y'[4] * 'p' / 101325.0)));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropyOfpTX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropy_pTX' "Return specific entropy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
  algorithm
    's' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropy'('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature_psX('p', 's', 'X')));
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropy_pTX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature' "Return temperature of ideal gas"
    input 'Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e5, start = 3e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature'('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature_phX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature_psX' "Return temperature from p, s, and X or Xi"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature'('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_psX'('p', 's', 'X'));
    annotation(inverse(s = Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropy_pTX('p', 'T', 'X')));
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature_psX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX.f_nonlinear' "Solve h_TX(T,X) for T with given h"
    input Real 'u';
    input Real 'h'(nominal = 1e5, start = 3e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[4] 'X'(nominal = {0.1, 0.1, 0.1, 0.1}, max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"kg/kg", "kg/kg", "kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction", "MassFraction", "MassFraction"});
    input Boolean 'exclEnthForm';
    input 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' 'refChoice';
    input Real 'h_off'(nominal = 1e5, start = 3e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.h_TX'('u', 'X', 'exclEnthForm', 'refChoice', 'h_off') - 'h';
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX.f_nonlinear';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX.f_nonlinear' "Solve specificEntropyOfpTX(p,T,X) for T with given s"
    input Real 'u';
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
    input Real[4] 'X'(nominal = {0.1, 0.1, 0.1, 0.1}, max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"kg/kg", "kg/kg", "kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction", "MassFraction", "MassFraction"});
    output Real 'y';
  algorithm
    'y' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropyOfpTX'('p', 'u', 'X') - 's';
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX.f_nonlinear';

  function 'Modelica.Media.IdealGases.Common.Functions.h_T' "Compute specific enthalpy from temperature and gas data; reference is decided by the
    refChoice input, or by the referenceChoice package constant by default"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'exclEnthForm' = true;
    input 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' 'refChoice' = 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K';
    input Real 'h_off'(unit = "J/kg", quantity = "SpecificEnergy") = 0.0;
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := smooth(0, (if 'T' < 'data'.'Tlimit' then 'data'.'R_s' * (('T' * ('data'.'blow'[1] + 'data'.'alow'[2] * 'Modelica.Math.log'('T') + 'T' * ('data'.'alow'[3] + 'T' * (0.5 * 'data'.'alow'[4] + 'T' * (0.3333333333333333 * 'data'.'alow'[5] + 'T' * (0.25 * 'data'.'alow'[6] + 0.2 * 'data'.'alow'[7] * 'T'))))) - 'data'.'alow'[1]) / 'T') else 'data'.'R_s' * (('T' * ('data'.'bhigh'[1] + 'data'.'ahigh'[2] * 'Modelica.Math.log'('T') + 'T' * ('data'.'ahigh'[3] + 'T' * (0.5 * 'data'.'ahigh'[4] + 'T' * (0.3333333333333333 * 'data'.'ahigh'[5] + 'T' * (0.25 * 'data'.'ahigh'[6] + 0.2 * 'data'.'ahigh'[7] * 'T'))))) - 'data'.'ahigh'[1]) / 'T')) + (if 'exclEnthForm' then -'data'.'Hf' else 0.0) + (if 'refChoice' == 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K' then 'data'.'H0' else 0.0) + (if 'refChoice' == 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined' then 'h_off' else 0.0));
    annotation(Inline = false, smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.h_T';

  function 'Modelica.Media.IdealGases.Common.Functions.s0_T' "Compute specific entropy from temperature and gas data"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 's'(unit = "J/(kg.K)", quantity = "SpecificEntropy");
  algorithm
    's' := if 'T' < 'data'.'Tlimit' then 'data'.'R_s' * ('data'.'blow'[2] - 0.5 * 'data'.'alow'[1] / ('T' * 'T') - 'data'.'alow'[2] / 'T' + 'data'.'alow'[3] * 'Modelica.Math.log'('T') + 'T' * ('data'.'alow'[4] + 'T' * (0.5 * 'data'.'alow'[5] + 'T' * (0.3333333333333333 * 'data'.'alow'[6] + 0.25 * 'data'.'alow'[7] * 'T')))) else 'data'.'R_s' * ('data'.'bhigh'[2] - 0.5 * 'data'.'ahigh'[1] / ('T' * 'T') - 'data'.'ahigh'[2] / 'T' + 'data'.'ahigh'[3] * 'Modelica.Math.log'('T') + 'T' * ('data'.'ahigh'[4] + 'T' * (0.5 * 'data'.'ahigh'[5] + 'T' * (0.3333333333333333 * 'data'.'ahigh'[6] + 0.25 * 'data'.'ahigh'[7] * 'T'))));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.s0_T';

  function 'Modelica.Utilities.Streams.error' "Print error message and cancel all actions - in case of an unrecoverable error"
    input String 'string';
  algorithm
    assert(false, 'string', AssertionLevel.error);
  end 'Modelica.Utilities.Streams.error';

  record 'Medium.ThermodynamicState'
    Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[4] 'X'(nominal = fill(0.1, 4), start = {0.768, 0.232, 0.0, 0.0}, max = fill(1.0, 4), min = fill(0.0, 4), unit = fill("kg/kg", 4), quantity = fill("MassFraction", 4));
  end 'Medium.ThermodynamicState';

  partial function 'Modelica.Math.Nonlinear.Interfaces.partialScalarFunction' "Interface for a function with one input and one output Real signal"
    input Real 'u';
    output Real 'y';
  end 'Modelica.Math.Nonlinear.Interfaces.partialScalarFunction';

  type 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' = enumeration('ZeroAt0K', 'ZeroAt25C', 'UserDefined');

  record 'Modelica.Media.IdealGases.Common.DataRecord'
    String 'name';
    Real 'MM'(min = 0.0, unit = "kg/mol", quantity = "MolarMass");
    Real 'Hf'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'H0'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'Tlimit'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[7] 'alow';
    Real[2] 'blow';
    Real[7] 'ahigh';
    Real[2] 'bhigh';
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  end 'Modelica.Media.IdealGases.Common.DataRecord';

  model 'Inverse_sh_TX' "Solve h = h_TX(TX) for T, if h is given for ideal gas NASA"
    parameter Real 'T_min'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.0 "Vary temperature linearly from T_min (time=0) up to T_max (time=1)";
    parameter Real 'T_max'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 500.0 "Vary temperature linearly from T_min (time=0) up to T_max (time=1)";
    parameter Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Fixed pressure in model";
    parameter Real 'h_min'(unit = "J/kg", quantity = "SpecificEnergy") = 302499.2070626019 "Specific enthalpy at T_min";
    parameter Real 'h_max'(unit = "J/kg", quantity = "SpecificEnergy") = 506796.354985627 "Specific enthalpy at T_max";
    parameter Real 's_min'(unit = "J/(kg.K)", quantity = "SpecificEntropy") = 6898.317128785827 "Specific entropy at T_min";
    parameter Real 's_max'(unit = "J/(kg.K)", quantity = "SpecificEntropy") = 7419.588064899617 "Specific entropy at T_max";
    Real 'h1'(fixed = true, start = 302499.2070626019, unit = "J/kg", quantity = "SpecificEnergy") "Pre-defined specific enthalpy";
    Real 'h2'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy computed from Th (= h1 required)";
    Real 's1'(fixed = true, start = 6898.317128785827, unit = "J/(kg.K)", quantity = "SpecificEntropy") "Pre-defined specific entropy";
    Real 's2'(unit = "J/(kg.K)", quantity = "SpecificEntropy") "Specific entropy computed from Ts (= s1 required)";
    Real 'Th'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature computed from h1";
    Real 'Ts'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature computed from s1";
    parameter Real 'X[1]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.768 "Mass fraction vector";
    parameter Real 'X[2]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.232 "Mass fraction vector";
    parameter Real 'X[3]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.0 "Mass fraction vector";
    parameter Real 'X[4]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.0 "Mass fraction vector";
    constant Real 'timeUnit'(unit = "s", quantity = "Time") = 1.0;
  equation
    der('h1') = if time < 1.0 then 204297.14792302507 else 0.0;
    der('s1') = if time < 1.0 then 521.2709361137904 else 0.0;
    'Th' = 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature_phX'(1e5, 'h1', {0.768, 0.232, 0.0, 0.0});
    'Ts' = 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.temperature_psX'(1e5, 's1', {0.768, 0.232, 0.0, 0.0});
    'h2' = 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEnthalpy_pTX'(1e5, 'Th', {0.768, 0.232, 0.0, 0.0});
    's2' = 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropy'('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'(1e5, 'Ts', {0.768, 0.232, 0.0, 0.0}));
    annotation(experiment(StopTime = 1));
  end 'Inverse_sh_TX';
end 'Inverse_sh_TX';
