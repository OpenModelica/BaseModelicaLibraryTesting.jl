    'cuboidLeft.mu_r' = 100.0;
    'cuboidLeft.R_m' = 1.0 / 'cuboidLeft.G_m';
    'cuboidLeft.V_m.re' = ('Modelica.Units.SI.ComplexMagneticFlux.\'*\'.multiply'('cuboidLeft.Phi', 'Complex.\'constructor\'.fromReal'('cuboidLeft.R_m', 0.0))).re;
    'cuboidLeft.V_m.im' = ('Modelica.Units.SI.ComplexMagneticFlux.\'*\'.multiply'('cuboidLeft.Phi', 'Complex.\'constructor\'.fromReal'('cuboidLeft.R_m', 0.0))).im;
    'cuboidLeft.B.re' = ('Modelica.Units.SI.ComplexMagneticFlux.\'/\''('cuboidLeft.Phi', 'Complex.\'constructor\'.fromReal'('cuboidLeft.A', 0.0))).re;
    'cuboidLeft.B.im' = ('Modelica.Units.SI.ComplexMagneticFlux.\'/\''('cuboidLeft.Phi', 'Complex.\'constructor\'.fromReal'('cuboidLeft.A', 0.0))).im;
    'cuboidLeft.H.re' = ('Modelica.Units.SI.ComplexMagneticFluxDensity.\'/\''('cuboidLeft.B', 'Complex.\'constructor\'.fromReal'(1.25663706212e-6 * 'cuboidLeft.mu_r', 0.0))).re;
    'cuboidLeft.H.im' = ('Modelica.Units.SI.ComplexMagneticFluxDensity.\'/\''('cuboidLeft.B', 'Complex.\'constructor\'.fromReal'(1.25663706212e-6 * 'cuboidLeft.mu_r', 0.0))).im;
    0.0 = ('Modelica.Units.SI.ComplexMagneticFlux.\'+\''('cuboidLeft.port_p.Phi', 'cuboidLeft.port_n.Phi')).re;
    0.0 = ('Modelica.Units.SI.ComplexMagneticFlux.\'+\''('cuboidLeft.port_p.Phi', 'cuboidLeft.port_n.Phi')).im;
    'cuboidLeft.port_p.reference.gamma' = 'cuboidLeft.port_n.reference.gamma';
    'cuboidLeft.omega' = der('cuboidLeft.port_p.reference.gamma');
    'cuboidLeft.V_m.re' = ('Modelica.Units.SI.ComplexMagneticPotential.\'-\'.subtract'('cuboidLeft.port_p.V_m', 'cuboidLeft.port_n.V_m')).re;
    'cuboidLeft.V_m.im' = ('Modelica.Units.SI.ComplexMagneticPotential.\'-\'.subtract'('cuboidLeft.port_p.V_m', 'cuboidLeft.port_n.V_m')).im;
    'cuboidLeft.Phi.re' = 'cuboidLeft.port_p.Phi.re';
    'cuboidLeft.Phi.im' = 'cuboidLeft.port_p.Phi.im';
    'constFrequency.y' = 50.0;
    'short.V_m.re' = 0.0;
    'short.V_m.im' = 0.0;
    0.0 = ('Modelica.Units.SI.ComplexMagneticFlux.\'+\''('short.port_p.Phi', 'short.port_n.Phi')).re;
    0.0 = ('Modelica.Units.SI.ComplexMagneticFlux.\'+\''('short.port_p.Phi', 'short.port_n.Phi')).im;
    'short.port_p.reference.gamma' = 'short.port_n.reference.gamma';
    'short.omega' = der('short.port_p.reference.gamma');
    'short.V_m.re' = ('Modelica.Units.SI.ComplexMagneticPotential.\'-\'.subtract'('short.port_p.V_m', 'short.port_n.V_m')).re;
    'short.V_m.im' = ('Modelica.Units.SI.ComplexMagneticPotential.\'-\'.subtract'('short.port_p.V_m', 'short.port_n.V_m')).im;
    'short.Phi.re' = 'short.port_p.Phi.re';
    'short.Phi.im' = 'short.port_p.Phi.im';
    'idle.Phi.re' = 0.0;
    'idle.Phi.im' = 0.0;
    0.0 = ('Modelica.Units.SI.ComplexMagneticFlux.\'+\''('idle.port_p.Phi', 'idle.port_n.Phi')).re;
    0.0 = ('Modelica.Units.SI.ComplexMagneticFlux.\'+\''('idle.port_p.Phi', 'idle.port_n.Phi')).im;
    'idle.port_p.reference.gamma' = 'idle.port_n.reference.gamma';
    'idle.omega' = der('idle.port_p.reference.gamma');
    'idle.V_m.re' = ('Modelica.Units.SI.ComplexMagneticPotential.\'-\'.subtract'('idle.port_p.V_m', 'idle.port_n.V_m')).re;
    'idle.V_m.im' = ('Modelica.Units.SI.ComplexMagneticPotential.\'-\'.subtract'('idle.port_p.V_m', 'idle.port_n.V_m')).im;
    'idle.Phi.re' = 'idle.port_p.Phi.re';
    'idle.Phi.im' = 'idle.port_p.Phi.im';
    'complexRamp.magnitude' = if time < 0.0 then 0.0 else if time < 1.0 then time * 8e-4 else 8e-4;
    'complexRamp.y.re' = ('Complex.\'*\'.multiply'('Complex.\'constructor\'.fromReal'('complexRamp.magnitude', 0.0), 'Complex'(1.0, 0.0))).re;
    'complexRamp.y.im' = ('Complex.\'*\'.multiply'('Complex.\'constructor\'.fromReal'('complexRamp.magnitude', 0.0), 'Complex'(1.0, 0.0))).im;
    annotation(experiment(StopTime = 1, Interval = 0.001));
  end 'CuboidSections';
end 'CuboidSections';
