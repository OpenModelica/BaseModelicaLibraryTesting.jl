//! base 0.1.0
package 'DemoPowerSupplyWithBuffer'
  model 'DemoPowerSupplyWithBuffer' "Demonstrate how to avoid back current to the DC Power Supply"
    parameter Real 'amplitude'(unit = "A", quantity = "ElectricCurrent") = 50.0 "Pulse current amplitude peak-to-peak";
    parameter Real 'offset'(unit = "A", quantity = "ElectricCurrent") = -25.0 "Pulse current offset";
    parameter Real 'dutyCycle'(max = 1.0, min = 0.0) = 0.5 "Pulse current duty cycle";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 1000.0 "Pulse current frequency";
    parameter Real 'dcPowerSupply.V0'(min = 2.220446049250313e-16, unit = "V", quantity = "ElectricPotential") = 60.0 "No-load voltage";
    parameter Real 'dcPowerSupply.I0'(min = 2.220446049250313e-16, unit = "A", quantity = "ElectricCurrent") = 50.0 "Short-circuit current";
    parameter Real 'dcPowerSupply.P0'(min = 2.220446049250313e-16, unit = "W", quantity = "Power") = 1200.0 "Maximum power";
    parameter Real 'dcPowerSupply.Rcv'(min = 2.220446049250313e-16, unit = "Ohm", quantity = "Resistance") = 0.01 "Inner resistance in constant voltage region";
    parameter Real 'dcPowerSupply.Gcc'(min = 2.220446049250313e-16, unit = "S", quantity = "Conductance") = 0.01 "Inner conductance in constant current region";
    parameter Real 'dcPowerSupply.iBack'(unit = "A", quantity = "ElectricCurrent") = 0.1 "Allowed back current";
    Real 'dcPowerSupply.v'(start = 60.0, unit = "V", quantity = "ElectricPotential") "Terminal voltage";
    Real 'dcPowerSupply.i'(unit = "A", quantity = "ElectricCurrent") "Current (delivered < 0)";
    Real 'dcPowerSupply.P'(unit = "W", quantity = "Power") "Power (delivered < 0)";
    Real 'dcPowerSupply.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcPowerSupply.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcPowerSupply.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcPowerSupply.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'dcPowerSupply.vLim'(fixed = false, unit = "V", quantity = "ElectricPotential") "Voltage limit for cc";
    parameter Real 'dcPowerSupply.iLim'(fixed = false, unit = "A", quantity = "ElectricCurrent") "Current limit for cv";
    parameter Boolean 'dcPowerSupply.cp'(fixed = false) "Is cp present?";
    Boolean 'dcPowerSupply.cv'(start = true) "Operation in cv, otherwise cc (or cp)";
    Boolean 'dcPowerSupply.cc'(start = false) "Operation in cc, otherwise cv (or cp)";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'cable.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.001 "Resistance at temperature T_ref";
    parameter Real 'cable.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'cable.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'cable.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'cable.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'cable.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'cable.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'cable.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'cable.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'cable.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'cable.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'cable.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'cable.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'cable.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'diode.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'diode.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'diode.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'diode.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'diode.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'diode.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'diode.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'diode.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'diode.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'diode.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'diode.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'diode.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'diode.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'diode.off'(start = true) "Switching state";
    Real 'diode.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'diode.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'diode.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Real 'bufferCapacitor.v'(fixed = true, start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'bufferCapacitor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'bufferCapacitor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'bufferCapacitor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'bufferCapacitor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'bufferCapacitor.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'bufferCapacitor.C'(start = 1.0, min = 0.0, unit = "F", quantity = "Capacitance") = 0.1 "Capacitance";
    Real 'loadCurrent.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'loadCurrent.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'loadCurrent.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'loadCurrent.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'loadCurrent.i'(unit = "A") "Current flowing from pin p to pin n as input signal";
    Real 'loadCurrent.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop between the two pins (= p.v - n.v)";
    parameter Real 'pulse.amplitude' = 50.0 "Amplitude of pulse";
    parameter Real 'pulse.width'(max = 100.0, min = 2.2250738585072014e-308) = 50.0 "Width of pulse in % of period";
    parameter Real 'pulse.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.001 "Time for one period";
    parameter Integer 'pulse.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'pulse.y' "Connector of Real output signal";
    parameter Real 'pulse.offset' = 0.0 "Offset of output signal y";
    parameter Real 'pulse.startTime'(unit = "s", quantity = "Time") = 0.5 "Output y = offset for time < startTime";
    Real 'pulse.T_width'(unit = "s", quantity = "Time");
    Real 'pulse.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'pulse.count' "Period count";
    parameter Real 'step.height' = -25.0 "Height of step";
    Real 'step.y' "Connector of Real output signal";
    parameter Real 'step.offset' = 0.0 "Offset of output signal y";
    parameter Real 'step.startTime'(unit = "s", quantity = "Time") = 0.5 "Output y = offset for time < startTime";
    Real 'add.u1' "Connector of Real input signal 1";
    Real 'add.u2' "Connector of Real input signal 2";
    Real 'add.y' "Connector of Real output signal";
    parameter Real 'add.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'add.k2' = 1.0 "Gain of input signal 2";
  equation
    'dcPowerSupply.v' = 'dcPowerSupply.p.v' - 'dcPowerSupply.n.v';
    'dcPowerSupply.i' = 'dcPowerSupply.p.i';
    'dcPowerSupply.P' = 'dcPowerSupply.v' * 'dcPowerSupply.i';
    'pulse.T_width' = 5e-4;
    'ground.p.v' = 'bufferCapacitor.n.v';
    'ground.p.v' = 'loadCurrent.n.v';
    'ground.p.v' = 'dcPowerSupply.n.v';
    'dcPowerSupply.p.v' = 'cable.p.v';
    'cable.n.v' = 'diode.p.v';
    'pulse.y' = 'add.u1';
    'add.y' = 'loadCurrent.i';
    'step.y' = 'add.u2';
    'bufferCapacitor.p.v' = 'loadCurrent.p.v';
    'bufferCapacitor.p.v' = 'diode.n.v';
    'cable.p.i' + 'dcPowerSupply.p.i' = 0.0;
    'loadCurrent.n.i' + 'bufferCapacitor.n.i' + 'ground.p.i' + 'dcPowerSupply.n.i' = 0.0;
    'diode.p.i' + 'cable.n.i' = 0.0;
    'loadCurrent.p.i' + 'bufferCapacitor.p.i' + 'diode.n.i' = 0.0;
    'dcPowerSupply.p.i' + 'dcPowerSupply.n.i' = 0.0;
    assert('dcPowerSupply.v' >= 0.0, "Only voltage >= 0 allowed", AssertionLevel.error);
    assert('dcPowerSupply.i' <= 0.1, "Back current exceeded!", AssertionLevel.error);
    'dcPowerSupply.cv' = (-'dcPowerSupply.i') <= 'dcPowerSupply.iLim';
    'dcPowerSupply.cc' = 'dcPowerSupply.v' <= 'dcPowerSupply.vLim';

    if 'dcPowerSupply.cp' then
      if 'dcPowerSupply.cv' then
        'dcPowerSupply.v' = 60.0 - 0.01 * (-'dcPowerSupply.i');
      elseif 'dcPowerSupply.cc' then
        -'dcPowerSupply.i' = 50.0 - 0.01 * 'dcPowerSupply.v';
      elseif true then
        1200.0 = 'dcPowerSupply.v' * (-'dcPowerSupply.i');
      end if;
    elseif true then
      if 'dcPowerSupply.cv' then
        'dcPowerSupply.v' = 60.0 - 0.01 * (-'dcPowerSupply.i');
      elseif true then
        -'dcPowerSupply.i' = 50.0 - 0.01 * 'dcPowerSupply.v';
      end if;
    end if;

    'ground.p.v' = 0.0;
    'cable.R_actual' = 0.001;
    'cable.v' = 'cable.R_actual' * 'cable.i';
    'cable.LossPower' = 'cable.v' * 'cable.i';
    'cable.T_heatPort' = 300.15;
    0.0 = 'cable.p.i' + 'cable.n.i';
    'cable.i' = 'cable.p.i';
    'cable.v' = 'cable.p.v' - 'cable.n.v';
    'diode.off' = 'diode.s' < 0.0;
    'diode.v' = 'diode.s' * (if 'diode.off' then 1.0 else 1e-5);
    'diode.i' = 'diode.s' * (if 'diode.off' then 1e-5 else 1.0);
    'diode.LossPower' = 'diode.v' * 'diode.i';
    'diode.T_heatPort' = 293.15;
    0.0 = 'diode.p.i' + 'diode.n.i';
    'diode.i' = 'diode.p.i';
    'diode.v' = 'diode.p.v' - 'diode.n.v';
    'bufferCapacitor.i' = 0.1 * der('bufferCapacitor.v');
    0.0 = 'bufferCapacitor.p.i' + 'bufferCapacitor.n.i';
    'bufferCapacitor.i' = 'bufferCapacitor.p.i';
    'bufferCapacitor.v' = 'bufferCapacitor.p.v' - 'bufferCapacitor.n.v';
    'loadCurrent.v' = 'loadCurrent.p.v' - 'loadCurrent.n.v';
    0.0 = 'loadCurrent.p.i' + 'loadCurrent.n.i';
    'loadCurrent.i' = 'loadCurrent.p.i';

    when time >= (pre('pulse.count') + 1) * 0.001 + 0.5 then
      'pulse.count' = pre('pulse.count') + 1;
      'pulse.T_start' = time;
    end when;

    'pulse.y' = if time < 0.5 then 0.0 else if time < 'pulse.T_start' + 'pulse.T_width' then 50.0 else 0.0;
    'step.y' = if time < 0.5 then 0.0 else -25.0;
    'add.y' = 'add.u1' + 'add.u2';
  initial algorithm
    assert(true, "Rcv too high!", AssertionLevel.error);
    assert(true, "Gcc too high!", AssertionLevel.error);
    'dcPowerSupply.vLim' := 59.5059505950595;
    'dcPowerSupply.iLim' := 49.404940494049406;
    'dcPowerSupply.cp' := false;

    if 'dcPowerSupply.vLim' * 'dcPowerSupply.iLim' > 1200.0 then
      'dcPowerSupply.cp' := true;
      assert(true, "Rcv too high!", AssertionLevel.error);
      assert(true, "Gcc too high!", AssertionLevel.error);
      'dcPowerSupply.vLim' := 24.11631937201051;
      'dcPowerSupply.iLim' := 20.067114849732093;
    end if;
  initial algorithm
    'pulse.count' := integer((time - 0.5) / 0.001);
    'pulse.T_start' := 0.5 + 'pulse.count' * 0.001;
    annotation(experiment(Interval = 1e-05, Tolerance = 1e-6, StartTime = 0, StopTime = 1));
  end 'DemoPowerSupplyWithBuffer';
end 'DemoPowerSupplyWithBuffer';
