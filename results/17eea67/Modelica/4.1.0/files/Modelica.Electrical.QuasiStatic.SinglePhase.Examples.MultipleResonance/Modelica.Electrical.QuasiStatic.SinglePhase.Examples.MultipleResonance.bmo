    'transformer.v1.im' = ('Complex.\'+\''('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex'(0.0, 1.0), 'Complex.\'constructor\'.fromReal'('transformer.omega', 0.0)), 'Complex'(3e-5, 0.0)), 'transformer.i1'), 'Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex'(0.0, 1.0), 'Complex.\'constructor\'.fromReal'('transformer.omega', 0.0)), 'Complex'(5.203364296299078e-6, 0.0)), 'transformer.i2'))).im;
    'transformer.v2.re' = ('Complex.\'+\''('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex'(0.0, 1.0), 'Complex.\'constructor\'.fromReal'('transformer.omega', 0.0)), 'Complex'(1e-6, 0.0)), 'transformer.i2'), 'Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex'(0.0, 1.0), 'Complex.\'constructor\'.fromReal'('transformer.omega', 0.0)), 'Complex'(5.203364296299078e-6, 0.0)), 'transformer.i1'))).re;
    'transformer.v2.im' = ('Complex.\'+\''('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex'(0.0, 1.0), 'Complex.\'constructor\'.fromReal'('transformer.omega', 0.0)), 'Complex'(1e-6, 0.0)), 'transformer.i2'), 'Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex'(0.0, 1.0), 'Complex.\'constructor\'.fromReal'('transformer.omega', 0.0)), 'Complex'(5.203364296299078e-6, 0.0)), 'transformer.i1'))).im;
    ('Modelica.Units.SI.ComplexCurrent.\'+\''('transformer.pin_p1.i', 'transformer.pin_n1.i')).re = 0.0;
