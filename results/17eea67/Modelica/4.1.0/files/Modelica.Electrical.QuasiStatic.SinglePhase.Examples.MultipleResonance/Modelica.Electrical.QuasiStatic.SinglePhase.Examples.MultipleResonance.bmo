    'transformer.pin_p2.reference.gamma' = 'transformer.pin_n2.reference.gamma';
    'transformer.pin_p1.reference.gamma' = 'transformer.pin_p2.reference.gamma';
    'ground1.pin.v.re' = 0.0;
    'ground1.pin.v.im' = 0.0;
    'ground2.pin.v.re' = 0.0;
    'ground2.pin.v.im' = 0.0;
    'loadResistor.R_actual' = 5.0;
    'loadResistor.v.re' = ('Modelica.Units.SI.ComplexCurrent.\'*\'.multiply'('Complex.\'constructor\'.fromReal'('loadResistor.R_actual', 0.0), 'loadResistor.i')).re;
    'loadResistor.v.im' = ('Modelica.Units.SI.ComplexCurrent.\'*\'.multiply'('Complex.\'constructor\'.fromReal'('loadResistor.R_actual', 0.0), 'loadResistor.i')).im;
    'loadResistor.LossPower' = 'Modelica.ComplexMath.real'('Modelica.Units.SI.ComplexVoltage.\'*\'.multiply'('loadResistor.v', 'Modelica.ComplexMath.conj'('loadResistor.i')));
    'loadResistor.T_heatPort' = 293.15;
    ('Modelica.Units.SI.ComplexCurrent.\'+\''('loadResistor.pin_p.i', 'loadResistor.pin_n.i')).re = 0.0;
    ('Modelica.Units.SI.ComplexCurrent.\'+\''('loadResistor.pin_p.i', 'loadResistor.pin_n.i')).im = 0.0;
    'loadResistor.v.re' = ('Modelica.Units.SI.ComplexElectricPotential.\'-\'.subtract'('loadResistor.pin_p.v', 'loadResistor.pin_n.v')).re;
