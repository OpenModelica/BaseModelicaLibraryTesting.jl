    'loadInductor.v.im' = ('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex'(0.0, 1.0), 'Complex.\'constructor\'.fromReal'('loadInductor.omega', 0.0)), 'Complex'(5e-6, 0.0)), 'loadInductor.i')).im;
    ('Modelica.Units.SI.ComplexCurrent.\'+\''('loadInductor.pin_p.i', 'loadInductor.pin_n.i')).re = 0.0;
