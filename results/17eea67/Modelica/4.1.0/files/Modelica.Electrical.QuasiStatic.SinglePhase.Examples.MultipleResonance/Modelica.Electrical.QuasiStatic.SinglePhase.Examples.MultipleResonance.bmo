    'loadCapacitor.i.im' = ('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex.\'*\'.multiply'('Complex'(0.0, 1.0), 'Complex.\'constructor\'.fromReal'('loadCapacitor.omega', 0.0)), 'Complex'(5e-11, 0.0)), 'loadCapacitor.v')).im;
    ('Modelica.Units.SI.ComplexCurrent.\'+\''('loadCapacitor.pin_p.i', 'loadCapacitor.pin_n.i')).re = 0.0;
