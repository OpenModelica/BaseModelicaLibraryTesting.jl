    Real 'pmActuator.armature.stopper_xMin.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'pmActuator.armature.stopper_xMin.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring constant";
    parameter Real 'pmActuator.armature.stopper_xMin.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping constant";
    parameter Real 'pmActuator.armature.stopper_xMin.s_rel0'(unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
    parameter Real 'pmActuator.armature.stopper_xMin.f_ref'(min = 0.0, unit = "N", quantity = "Force") = 1e11 "Reference spring force at s_ref";
    parameter Real 'pmActuator.armature.stopper_xMin.s_ref'(min = 2.220446049250313e-16, unit = "m", quantity = "Length") = 1.0 "Reference relative compression at which f_c = f_ref";
    parameter Real 'pmActuator.armature.stopper_xMin.n'(min = 1.0) = 2.0 "Exponent of spring force ( f_c = -f_ref*|(s_rel-s_rel0)/s_ref|^n )";
    parameter Boolean 'pmActuator.armature.stopper_xMin.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
