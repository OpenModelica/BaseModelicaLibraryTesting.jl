    Boolean 'pmActuator.armature.stopper_xMin.contact' "= true, if contact, otherwise no contact";
    Real 'pmActuator.armature.stopper_xMin.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'pmActuator.armature.stopper_xMin.f_d2'(unit = "N", quantity = "Force") "Linear damping force";
    Real 'pmActuator.armature.stopper_xMin.f_d'(unit = "N", quantity = "Force") "Linear damping force which is limited by spring force (|f_d| <= |f_c|)";
    Real 'pmActuator.armature.stopper_xMin.ratio' "Scaling ratio of relative compression to s_ref";
    parameter Real 'pmActuator.r.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 2.86 "Resistance at temperature T_ref";
    parameter Real 'pmActuator.r.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'pmActuator.r.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
