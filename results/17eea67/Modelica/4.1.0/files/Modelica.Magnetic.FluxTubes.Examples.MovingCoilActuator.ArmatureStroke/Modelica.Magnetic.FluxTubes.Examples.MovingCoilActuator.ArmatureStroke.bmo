//! base 0.1.0
package 'ArmatureStroke'
  model 'ArmatureStroke' "Armature stroke of both moving coil actuator models after a voltage step at time t=0"
    constant Real 'steadyStateCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.5;
    Real 'pmGround.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'pmGround.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'pmSource.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 4.29 "Height of step";
    Real 'pmSource.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'pmSource.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'pmSource.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'pmSource.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'pmSource.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'pmSource.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'pmSource.signalSource.height' = 4.29 "Height of step";
    Real 'pmSource.signalSource.y' "Connector of Real output signal";
    parameter Real 'pmSource.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'pmSource.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'pmSource.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'pmSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'pmActuator.N' = 140.0 "Number of turns";
    parameter Real 'pmActuator.R'(unit = "Ohm", quantity = "Resistance") = 2.86 "Coil resistance";
    parameter Real 'pmActuator.r_core'(min = 0.0, unit = "m", quantity = "Length") = 0.0125 "Radius of ferromagnetic stator core";
    parameter Real 'pmActuator.l_PM'(unit = "m", quantity = "Length") = 0.0035 "Radial thickness of permanent magnet ring";
    parameter Real 'pmActuator.t'(unit = "m", quantity = "Length") = 0.02 "Axial length of permanent magnet ring and air gap respectively";
    parameter Real 'pmActuator.l_air'(unit = "m", quantity = "Length") = 0.003 "Total radial length of armature air gap";
    parameter Real 'pmActuator.l_FeOut'(unit = "m", quantity = "Length") = 0.004 "Radial thickness of outer back iron (for estimation of leakage permeance)";
    parameter Real 'pmActuator.material.H_cBRef'(unit = "A/m", quantity = "MagneticFieldStrength") = 4e5 "Coercivity at reference temperature";
    parameter Real 'pmActuator.material.B_rRef'(unit = "T", quantity = "MagneticFluxDensity") = 0.58 "Remanence at reference temperature";
    parameter Real 'pmActuator.material.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'pmActuator.material.alpha_Br'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = -0.001 "Temperature coefficient of remanence at reference temperature";
    parameter Real 'pmActuator.material.T_op'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operating temperature";
    parameter Real 'pmActuator.material.B_r'(unit = "T", quantity = "MagneticFluxDensity") = 0.58 "Remanence at operating temperature";
    parameter Real 'pmActuator.material.H_cB'(unit = "A/m", quantity = "MagneticFieldStrength") = 4e5 "Coercivity at operating temperature";
    parameter Real 'pmActuator.material.mu_r'(unit = "1", quantity = "RelativePermeability") = 1.1538733367881007 "Relative permeability";
    parameter Real 'pmActuator.m_a'(min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Mass of armature";
    parameter Real 'pmActuator.c'(unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring stiffness between impact partners";
    parameter Real 'pmActuator.d'(unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping coefficient between impact partners";
    parameter Real 'pmActuator.x_min'(unit = "m", quantity = "Length") = -0.004 "Position of stopper at minimum armature position";
    parameter Real 'pmActuator.x_max'(unit = "m", quantity = "Length") = 0.004 "Position of stopper at maximum armature position";
    Real 'pmActuator.x'(stateSelect = StateSelect.prefer, fixed = true, start = -0.004, unit = "m", quantity = "Length") "Armature position, alias for flange position";
    Real 'pmActuator.L'(unit = "H", quantity = "Inductance") "Coil inductance";
    Real 'pmActuator.mmf_PM.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'pmActuator.mmf_PM.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'pmActuator.mmf_PM.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'pmActuator.mmf_PM.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    parameter Real 'pmActuator.mmf_PM.V_m'(unit = "A", quantity = "MagneticPotential") = 1400.0 "Magnetic potential difference";
    Real 'pmActuator.mmf_PM.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'pmActuator.armature.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component from left flange to right flange (= flange_b.s - flange_a.s)";
    parameter Real 'pmActuator.armature.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Armature mass";
    parameter Real 'pmActuator.armature.c'(start = 1e11, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring stiffness between impact partners";
    parameter Real 'pmActuator.armature.d'(start = 2e7, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping coefficient between impact partners";
    parameter Real 'pmActuator.armature.n'(min = 1.0) = 2.0 "Exponent of spring forces (f_c = c*|s_rel|^n)" annotation(Evaluate = true);
    parameter Real 'pmActuator.armature.x_max'(start = 0.01, unit = "m", quantity = "Length") = 0.004 "Position of stopper at maximum armature position";
    parameter Real 'pmActuator.armature.x_min'(start = 0.0, unit = "m", quantity = "Length") = -0.004 "Position of stopper at minimum armature position";
    Real 'pmActuator.armature.s'(start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (= flange_a.s + L/2)";
    Real 'pmActuator.armature.v'(fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of components (= der(s))";
    Real 'pmActuator.armature.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of components (= der(v))";
    parameter Real 'pmActuator.armature.mass.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Mass of the sliding mass";
    parameter StateSelect 'pmActuator.armature.mass.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'pmActuator.armature.mass.s'(stateSelect = StateSelect.default, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'pmActuator.armature.mass.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'pmActuator.armature.mass.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.mass.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'pmActuator.armature.mass.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.mass.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'pmActuator.armature.mass.v'(stateSelect = StateSelect.default, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'pmActuator.armature.mass.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    Real 'pmActuator.armature.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'pmActuator.armature.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'pmActuator.armature.limit_xMin.s0'(unit = "m", quantity = "Length") = -0.004 "Fixed offset position of housing";
    Real 'pmActuator.armature.limit_xMin.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.limit_xMin.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'pmActuator.armature.limit_xMax.s0'(unit = "m", quantity = "Length") = 0.004 "Fixed offset position of housing";
    Real 'pmActuator.armature.limit_xMax.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.limit_xMax.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter StateSelect 'pmActuator.armature.stopper_xMax.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'pmActuator.armature.stopper_xMax.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'pmActuator.armature.stopper_xMax.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'pmActuator.armature.stopper_xMax.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'pmActuator.armature.stopper_xMax.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'pmActuator.armature.stopper_xMax.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.stopper_xMax.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'pmActuator.armature.stopper_xMax.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.stopper_xMax.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'pmActuator.armature.stopper_xMax.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring constant";
    parameter Real 'pmActuator.armature.stopper_xMax.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping constant";
    parameter Real 'pmActuator.armature.stopper_xMax.s_rel0'(unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
    parameter Real 'pmActuator.armature.stopper_xMax.f_ref'(min = 0.0, unit = "N", quantity = "Force") = 1e11 "Reference spring force at s_ref";
    parameter Real 'pmActuator.armature.stopper_xMax.s_ref'(min = 2.220446049250313e-16, unit = "m", quantity = "Length") = 1.0 "Reference relative compression at which f_c = f_ref";
    parameter Real 'pmActuator.armature.stopper_xMax.n'(min = 1.0) = 2.0 "Exponent of spring force ( f_c = -f_ref*|(s_rel-s_rel0)/s_ref|^n )";
    parameter Boolean 'pmActuator.armature.stopper_xMax.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'pmActuator.armature.stopper_xMax.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Boolean 'pmActuator.armature.stopper_xMax.contact' "= true, if contact, otherwise no contact";
    Real 'pmActuator.armature.stopper_xMax.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'pmActuator.armature.stopper_xMax.f_d2'(unit = "N", quantity = "Force") "Linear damping force";
    Real 'pmActuator.armature.stopper_xMax.f_d'(unit = "N", quantity = "Force") "Linear damping force which is limited by spring force (|f_d| <= |f_c|)";
    Real 'pmActuator.armature.stopper_xMax.ratio' "Scaling ratio of relative compression to s_ref";
    parameter StateSelect 'pmActuator.armature.stopper_xMin.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'pmActuator.armature.stopper_xMin.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'pmActuator.armature.stopper_xMin.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'pmActuator.armature.stopper_xMin.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'pmActuator.armature.stopper_xMin.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'pmActuator.armature.stopper_xMin.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
