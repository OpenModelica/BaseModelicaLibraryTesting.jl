//! base 0.1.0
package 'Resistor'
  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  model 'Resistor' "Resistor with simple thermal network"
    parameter Real 'resistor.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 100.0 "Resistance at temperature T_ref";
    parameter Real 'resistor.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'resistor.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.001 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor.i'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'resistor.heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'resistor.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'G.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'G.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'SineVoltage1.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 220.0 "Amplitude of sine wave";
    parameter Real 'SineVoltage1.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Real 'SineVoltage1.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1.0 "Frequency of sine wave";
    Real 'SineVoltage1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'SineVoltage1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'SineVoltage1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'SineVoltage1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'SineVoltage1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'SineVoltage1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'SineVoltage1.signalSource.amplitude' = 220.0 "Amplitude of sine wave";
    parameter Real 'SineVoltage1.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1.0 "Frequency of sine wave";
    parameter Real 'SineVoltage1.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'SineVoltage1.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'SineVoltage1.signalSource.y' "Connector of Real output signal";
    parameter Real 'SineVoltage1.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'SineVoltage1.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'SineVoltage1.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'SineVoltage1.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    Real 'thermalConductor.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate from port_a -> port_b";
    Real 'thermalConductor.dT'(unit = "K", quantity = "ThermodynamicTemperature");
    Real 'thermalConductor.port_a.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'thermalConductor.port_a.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'thermalConductor.port_b.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'thermalConductor.port_b.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'thermalConductor.G'(unit = "W/K", quantity = "ThermalConductance") = 50.0 "Constant thermal conductance of material";
    parameter Real 'fixedTemperature.T'(unit = "degC", quantity = "ThermodynamicTemperature") = 20.0 "Fixed temperature at the port";
    Real 'fixedTemperature.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'fixedTemperature.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
  equation
    'resistor.heatPort.T' = 'resistor.T_heatPort';
    'resistor.heatPort.Q_flow' = -'resistor.LossPower';
    'G.p.v' = 'resistor.n.v';
    'G.p.v' = 'SineVoltage1.n.v';
    'resistor.heatPort.T' = 'thermalConductor.port_a.T';
    'SineVoltage1.p.v' = 'resistor.p.v';
    'thermalConductor.port_b.T' = 'fixedTemperature.port.T';
    'thermalConductor.port_a.Q_flow' + 'resistor.heatPort.Q_flow' = 0.0;
    'SineVoltage1.p.i' + 'resistor.p.i' = 0.0;
    'SineVoltage1.n.i' + 'G.p.i' + 'resistor.n.i' = 0.0;
    'fixedTemperature.port.Q_flow' + 'thermalConductor.port_b.Q_flow' = 0.0;
    assert(1.0 + 0.001 * ('resistor.T_heatPort' - 293.15) >= 2.220446049250313e-16, "Temperature outside scope of model!", AssertionLevel.error);
    'resistor.R_actual' = 100.0 * (1.0 + 0.001 * ('resistor.T_heatPort' - 293.15));
    'resistor.v' = 'resistor.R_actual' * 'resistor.i';
    'resistor.LossPower' = 'resistor.v' * 'resistor.i';
    0.0 = 'resistor.p.i' + 'resistor.n.i';
    'resistor.i' = 'resistor.p.i';
    'resistor.v' = 'resistor.p.v' - 'resistor.n.v';
    'G.p.v' = 0.0;
    'SineVoltage1.signalSource.y' = if time < 0.0 then 0.0 else 220.0 * 'Modelica.Math.sin'(6.283185307179586 * time);
    'SineVoltage1.v' = 'SineVoltage1.signalSource.y';
    0.0 = 'SineVoltage1.p.i' + 'SineVoltage1.n.i';
    'SineVoltage1.i' = 'SineVoltage1.p.i';
    'SineVoltage1.v' = 'SineVoltage1.p.v' - 'SineVoltage1.n.v';
    'thermalConductor.Q_flow' = 50.0 * 'thermalConductor.dT';
    'thermalConductor.dT' = 'thermalConductor.port_a.T' - 'thermalConductor.port_b.T';
    'thermalConductor.port_a.Q_flow' = 'thermalConductor.Q_flow';
    'thermalConductor.port_b.Q_flow' = -'thermalConductor.Q_flow';
    'fixedTemperature.port.T' = 293.15;
    annotation(experiment(StopTime = 5));
  end 'Resistor';
end 'Resistor';
