//! base 0.1.0
package 'TransformerTestbench'
  function 'Complex.\'+\'' "Add two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' + 'c2'.'re', 'c1'.'im' + 'c2'.'im');
    annotation(Inline = true, smoothOrder = 100);
  end 'Complex.\'+\'';

  function 'Complex.\'*\'.multiply' "Multiply two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' * 'c2'.'re' - 'c1'.'im' * 'c2'.'im', 'c1'.'re' * 'c2'.'im' + 'c1'.'im' * 'c2'.'re');
    annotation(Inline = true, smoothOrder = 100);
  end 'Complex.\'*\'.multiply';

  function 'Complex.\'*\'.scalarProduct' "Scalar product of two complex vectors c1 and c2"
    input 'Complex'[:] 'c1';
    input 'Complex'[size('c1', 1)] 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex'(0.0, 0.0);

    for 'i' in 1:size('c1', 1) loop
      'c3' := 'Complex.\'constructor\'.fromReal'('c3'.'re' + 'c1['i']'.'re' * 'c2['i']'.'re' + 'c1['i']'.'im' * 'c2['i']'.'im', 'c3'.'im' + 'c1['i']'.'re' * 'c2['i']'.'im' - 'c1['i']'.'im' * 'c2['i']'.'re');
    end for;
    annotation(Inline = true, smoothOrder = 100);
  end 'Complex.\'*\'.scalarProduct';

  function 'Complex.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Complex.\'constructor\'.fromReal';

  function 'Modelica.ComplexMath.abs' "Absolute value of complex number"
    input 'Complex' 'c';
    output Real 'result';
  algorithm
    'result' := sqrt('c'.'re' ^ 2.0 + 'c'.'im' ^ 2.0);
    annotation(Inline = true);
  end 'Modelica.ComplexMath.abs';

  function 'Modelica.ComplexMath.arg' "Phase angle of complex number"
    input 'Complex' 'c';
    input Real 'phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'phi'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'phi' := 'Modelica.Math.atan3'('c'.'im', 'c'.'re', 'phi0');
    annotation(Inline = true);
  end 'Modelica.ComplexMath.arg';

  function 'Modelica.ComplexMath.conj' "Conjugate of complex number"
    input 'Complex' 'c1';
    output 'Complex' 'c2';
  algorithm
    'c2' := 'Complex.\'constructor\'.fromReal'('c1'.'re', -'c1'.'im');
    annotation(Inline = true);
  end 'Modelica.ComplexMath.conj';

  function 'Modelica.ComplexMath.exp' "Exponential of complex number"
    input 'Complex' 'c1';
    output 'Complex' 'c2';
  algorithm
    'c2' := 'Complex.\'constructor\'.fromReal'('Modelica.Math.exp'('c1'.'re') * 'Modelica.Math.cos'('c1'.'im'), 'Modelica.Math.exp'('c1'.'re') * 'Modelica.Math.sin'('c1'.'im'));
    annotation(Inline = true);
  end 'Modelica.ComplexMath.exp';

  function 'Modelica.ComplexMath.imag' "Imaginary part of complex number"
    input 'Complex' 'c';
    output Real 'r';
  algorithm
    'r' := 'c'.'im';
    annotation(Inline = true);
  end 'Modelica.ComplexMath.imag';

  function 'Modelica.ComplexMath.real' "Real part of complex number"
    input 'Complex' 'c';
    output Real 'r';
  algorithm
    'r' := 'c'.'re';
    annotation(Inline = true);
  end 'Modelica.ComplexMath.real';

  function 'Modelica.Math.atan2' "Four quadrant inverse tangent"
    input Real 'u1';
    input Real 'u2';
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := atan2('u1', 'u2');
    annotation(Inline = true);
  end 'Modelica.Math.atan2';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    elseif true then
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  function 'Modelica.Math.cos' "Cosine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := cos('u');
    annotation(Inline = true);
  end 'Modelica.Math.cos';

  function 'Modelica.Math.exp' "Exponential, base e"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := exp('u');
    annotation(Inline = true);
  end 'Modelica.Math.exp';

  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  function 'Modelica.Units.SI.ComplexCurrent.\'+\'' "Add two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' + 'c2'.'re', 'c1'.'im' + 'c2'.'im');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexCurrent.\'+\'';

  function 'Modelica.Units.SI.ComplexCurrent.\'/\'' "Divide two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'(('c1'.'re' * 'c2'.'re' + 'c1'.'im' * 'c2'.'im') / ('c2'.'re' * 'c2'.'re' + 'c2'.'im' * 'c2'.'im'), ('c1'.'im' * 'c2'.'re' - 'c1'.'re' * 'c2'.'im') / ('c2'.'re' * 'c2'.'re' + 'c2'.'im' * 'c2'.'im'));
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexCurrent.\'/\'';

  function 'Modelica.Units.SI.ComplexCurrent.\'*\'.multiply' "Multiply two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' * 'c2'.'re' - 'c1'.'im' * 'c2'.'im', 'c1'.'re' * 'c2'.'im' + 'c1'.'im' * 'c2'.'re');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexCurrent.\'*\'.multiply';

  function 'Modelica.Units.SI.ComplexCurrent.\'-\'.negate' "Unary minus (multiply complex number by -1)"
    input 'Complex' 'c1';
    output 'Complex' 'c2';
  algorithm
    'c2' := 'Complex.\'constructor\'.fromReal'(-'c1'.'re', -'c1'.'im');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexCurrent.\'-\'.negate';

  function 'Modelica.Units.SI.ComplexCurrent.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexCurrent.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexElectricPotential.\'-\'.subtract' "Subtract two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' - 'c2'.'re', 'c1'.'im' - 'c2'.'im');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexElectricPotential.\'-\'.subtract';

  function 'Modelica.Units.SI.ComplexElectricPotential.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexElectricPotential.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexVoltage.\'*\'.multiply' "Multiply two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' * 'c2'.'re' - 'c1'.'im' * 'c2'.'im', 'c1'.'re' * 'c2'.'im' + 'c1'.'im' * 'c2'.'re');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexVoltage.\'*\'.multiply';

  function 'Modelica.Units.SI.ComplexVoltage.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexVoltage.\'constructor\'.fromReal';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexOutput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexOutput';

  record 'Modelica.Units.SI.ComplexVoltage'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexVoltage';

  record 'Modelica.Units.SI.ComplexCurrent'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexCurrent';

  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  record 'Modelica.Units.SI.ComplexElectricPotential'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexElectricPotential';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexInput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexInput';

  model 'TransformerTestbench' "Transformer test bench"
    parameter Integer 'm' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'RL[1]'(unit = "Ohm", quantity = "Resistance") = 0.3333333333333333 "Load resistance";
    parameter Real 'RL[2]'(unit = "Ohm", quantity = "Resistance") = 0.3333333333333333 "Load resistance";
    parameter Real 'RL[3]'(unit = "Ohm", quantity = "Resistance") = 0.3333333333333333 "Load resistance";
    output Real 'VS'(unit = "V", quantity = "ElectricPotential") "Grid voltage";
    output Real 'phiS'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Grid phase";
    output Real 'VL'(unit = "V", quantity = "ElectricPotential") "Load voltage";
    output Real 'phiL'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Load phase";
    parameter Integer 'source.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'source.v[1].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.v[1].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.v[2].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.v[2].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.v[3].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.v[3].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.abs_v[1]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'source.abs_v[2]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'source.abs_v[3]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'source.arg_v[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'source.arg_v[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'source.arg_v[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'source.i[1].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.i[1].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.i[2].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.i[2].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.i[3].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.i[3].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.abs_i[1]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'source.abs_i[2]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'source.abs_i[3]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'source.arg_i[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'source.arg_i[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'source.arg_i[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'source.P[1]'(unit = "W", quantity = "Power") "Active power";
    Real 'source.P[2]'(unit = "W", quantity = "Power") "Active power";
    Real 'source.P[3]'(unit = "W", quantity = "Power") "Active power";
    Real 'source.P_total'(unit = "W", quantity = "Power") "Total active power";
    Real 'source.Q[1]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'source.Q[2]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'source.Q[3]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'source.Q_total'(unit = "var", quantity = "Power") "Total reactive power";
    Real 'source.S[1]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'source.S[2]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'source.S[3]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'source.S_total'(unit = "V.A", quantity = "Power") "Magnitude of total complex apparent power";
    Real 'source.pf[1]' "Power factor";
    Real 'source.pf[2]' "Power factor";
    Real 'source.pf[3]' "Power factor";
    Real 'source.omega'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of reference frame";
    parameter Integer 'source.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'source.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.plug_p.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.plug_p.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.plug_p.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'source.plug_n.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'source.plug_n.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.plug_n.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.plug_n.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.plug_n.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.plug_n.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.plug_n.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.plug_n.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.plug_n.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.plug_n.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'source.plug_n.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'source.plug_n.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'source.plug_n.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'source.plug_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'source.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    Real 'source.gamma'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Real 'source.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of the source";
    parameter Real 'source.V[1]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 57.73502691896258 "RMS voltage of the source";
    parameter Real 'source.V[2]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 57.73502691896258 "RMS voltage of the source";
    parameter Real 'source.V[3]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 57.73502691896258 "RMS voltage of the source";
    parameter Real 'source.phi[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase shift of the source";
    parameter Real 'source.phi[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.0943951023931953 "Phase shift of the source";
    parameter Real 'source.phi[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -4.1887902047863905 "Phase shift of the source";
    parameter Integer 'starS.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'starS.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'starS.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starS.plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starS.plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starS.plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starS.plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starS.plug_p.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starS.plug_p.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starS.plug_p.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starS.plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starS.plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starS.plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starS.plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starS.plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'starS.pin_n.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starS.pin_n.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starS.pin_n.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starS.pin_n.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starS.pin_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'starS.plugToPins_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'starS.plugToPins_p.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'starS.plugToPins_p.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starS.plugToPins_p.plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starS.plugToPins_p.plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'starS.plugToPins_p.pin_p[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starS.plugToPins_p.pin_p[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starS.plugToPins_p.pin_p[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starS.plugToPins_p.pin_p[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
