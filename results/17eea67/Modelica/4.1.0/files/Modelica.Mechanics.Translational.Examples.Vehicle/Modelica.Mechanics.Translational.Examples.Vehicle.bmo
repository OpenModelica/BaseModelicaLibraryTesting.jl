//! base 0.1.0
package 'Vehicle'
  function 'Modelica.Blocks.Tables.Internal.getDerTimeTableValueNoDer' "Derivative of interpolated 1-dim. table where first column is time (but do not provide a derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Integer 'icol';
    input Real 'timeIn';
    input Real 'nextTimeEvent';
    input Real 'pre_nextTimeEvent';
    input Real 'der_timeIn';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTimeTable_getDerValue('tableID', 'icol', 'timeIn', 'nextTimeEvent', 'pre_nextTimeEvent', 'der_timeIn') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getDerTimeTableValueNoDer';

  function 'Modelica.Blocks.Tables.Internal.getNextTimeEvent' "Return next time event value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Real 'timeIn';
    output Real 'nextTimeEvent';
  external "C" 'nextTimeEvent' = ModelicaStandardTables_CombiTimeTable_nextTimeEvent('tableID', 'timeIn') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getNextTimeEvent';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmax' "Return maximum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMax';
  external "C" 'timeMax' = ModelicaStandardTables_CombiTimeTable_maximumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmax';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmin' "Return minimum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMin';
  external "C" 'timeMin' = ModelicaStandardTables_CombiTimeTable_minimumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmin';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer2' "Interpolate 1-dim. table where first column is time (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Integer 'icol';
    input Real 'timeIn';
    input Real 'nextTimeEvent';
    input Real 'pre_nextTimeEvent';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTimeTable_getValue('tableID', 'icol', 'timeIn', 'nextTimeEvent', 'pre_nextTimeEvent') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1, noDerivative = 'nextTimeEvent', noDerivative = 'pre_nextTimeEvent') = 'Modelica.Blocks.Tables.Internal.getDerTimeTableValueNoDer');
  end 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer2';

  function 'Modelica.Math.atan' "Inverse tangent"
    input Real 'u';
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := atan('u');
    annotation(Inline = true);
  end 'Modelica.Math.atan';

  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  type 'Modelica.Blocks.Types.Regularization' = enumeration('Exp', 'Sine', 'Linear', 'Cosine');

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  type 'Modelica.Blocks.Types.TimeEvents' = enumeration('Always', 'AtDiscontinuities', 'NoTimeEvents');

  class 'Modelica.Blocks.Types.ExternalCombiTimeTable'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table where first column is time"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Real 'startTime';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation';
      input Real 'shiftTime' = 0.0;
      input 'Modelica.Blocks.Types.TimeEvents' 'timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" 'externalCombiTimeTable' = ModelicaStandardTables_CombiTimeTable_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'startTime', 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'shiftTime', 'timeEvents', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table where first column is time"
      input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" ModelicaStandardTables_CombiTimeTable_close('externalCombiTimeTable') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTimeTable';

  model 'Vehicle' "One-dimensional vehicle with driving resistances"
    parameter Real 'm'(min = 0.0, unit = "kg", quantity = "Mass") = 100.0 "Mass of vehicle";
    parameter Real 'R'(unit = "m", quantity = "Length") = 0.25 "Radius of wheel";
    parameter Real 'A'(unit = "m2", quantity = "Area") = 1.0 "Cross section of vehicle";
    parameter Real 'Cd' = 0.5 "Drag resistance coefficient";
    parameter Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.18 "Density of air";
    parameter Real 'vWind'(unit = "m/s", quantity = "Velocity") = 0.0 "Constant wind velocity";
    parameter Real 'Cr' = 0.01 "Rolling resistance coefficient";
    parameter Real 'inclination' = 0.0 "Constant inclination = tan(angle)";
    parameter Real 'vNom'(unit = "m/s", quantity = "Velocity") = 7.142857142857143 "Nominal velocity";
    parameter Real 'fDrag'(unit = "N", quantity = "Force") = 15.051020408163264 "Drag resistance";
    parameter Real 'alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Inclination angle";
    parameter Real 'fRoll'(unit = "N", quantity = "Force") = 9.80665 "Roll resistance";
    parameter Real 'fGrav'(unit = "N", quantity = "Force") = 0.0 "Grav resistance";
    parameter Real 'vehicle.m'(min = 0.0, unit = "kg", quantity = "Mass") = 100.0 "Total mass of vehicle";
    parameter Real 'vehicle.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Real 'vehicle.J'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Total rotational inertia of drive train";
    parameter Real 'vehicle.R'(unit = "m", quantity = "Length") = 0.25 "Wheel radius";
    parameter Real 'vehicle.A'(start = 1.0, unit = "m2", quantity = "Area") = 1.0 "Cross section of vehicle";
    parameter Real 'vehicle.Cd'(start = 0.5) = 0.5 "Drag resistance coefficient";
    parameter Real 'vehicle.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.2 "Density of air";
    parameter Boolean 'vehicle.useWindInput' = false "Enable signal input for wind velocity";
    parameter Real 'vehicle.vWindConstant'(unit = "m/s", quantity = "Velocity") = 0.0 "Constant wind velocity";
    parameter Boolean 'vehicle.useCrInput' = false "Enable signal input for Cr";
    parameter Real 'vehicle.CrConstant' = 0.01 "Constant rolling resistance coefficient";
    parameter Real 'vehicle.vReg'(unit = "m/s", quantity = "Velocity") = 0.001 "Velocity for regularization around 0";
    parameter Boolean 'vehicle.useInclinationInput' = true "Enable signal input for inclination";
    parameter Real 'vehicle.inclinationConstant' = 0.0 "Constant inclination = tan(angle)";
    Real 'vehicle.s'(fixed = true, start = 0.0, displayUnit = "km", unit = "m", quantity = "Length") "Position of vehicle";
    Real 'vehicle.v'(fixed = true, start = 0.0, displayUnit = "km/h", unit = "m/s", quantity = "Velocity") "Velocity of vehicle";
    Real 'vehicle.a'(unit = "m/s2", quantity = "Acceleration") "Acceleration of vehicle";
    constant Real 'vehicle.vRef'(unit = "m/s", quantity = "Velocity") = 1.0 "Reference velocity for air drag";
    parameter Boolean 'vehicle.fDrag.useSupport' = true "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'vehicle.fDrag.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'vehicle.fDrag.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.fDrag.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.fDrag.support.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.fDrag.support.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.fDrag.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'vehicle.fDrag.f'(unit = "N", quantity = "Force") "Accelerating force acting at flange (= flange.f)";
    parameter Real 'vehicle.fDrag.f_nominal'(unit = "N", quantity = "Force") = -0.3 "Nominal force (if negative, force is acting as load in positive direction of motion)";
    parameter Boolean 'vehicle.fDrag.ForceDirection' = false "Same direction of force in both directions of motion";
    parameter Real 'vehicle.fDrag.v_nominal'(min = 2.220446049250313e-16, unit = "m/s", quantity = "Velocity") = 1.0 "Nominal speed";
    Real 'vehicle.fDrag.v'(unit = "m/s", quantity = "Velocity") "Velocity of flange with respect to support (= der(s))";
    parameter Boolean 'vehicle.fRoll.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'vehicle.fRoll.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'vehicle.fRoll.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.fRoll.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.fRoll.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'vehicle.fRoll.f'(unit = "N", quantity = "Force") "Accelerating force acting at flange (= flange.f)";
    parameter Real 'vehicle.fRoll.fWeight'(start = 0.0, unit = "N", quantity = "Force") = 980.665 "Wheel load due to gravity";
    parameter Boolean 'vehicle.fRoll.useCrInput' = false "Enable signal input for Cr";
    parameter Real 'vehicle.fRoll.CrConstant' = 0.01 "Constant rolling resistance coefficient";
    parameter Boolean 'vehicle.fRoll.useInclinationInput' = true "Enable signal input for inclination";
    parameter Real 'vehicle.fRoll.inclinationConstant' = 0.0 "Constant inclination = tan(angle)";
    parameter 'Modelica.Blocks.Types.Regularization' 'vehicle.fRoll.reg' = 'Modelica.Blocks.Types.Regularization'.'Linear' "Type of regularization" annotation(Evaluate = true);
    parameter Real 'vehicle.fRoll.v0'(min = 2.220446049250313e-16, unit = "m/s", quantity = "Velocity") = 0.001 "Regularization below v0";
    Real 'vehicle.fRoll.v'(unit = "m/s", quantity = "Velocity") "Velocity of flange with respect to support (= der(s))";
    Real 'vehicle.fRoll.f_nominal'(unit = "N", quantity = "Force") "Nominal rolling resistance without regularization";
    Real 'vehicle.fRoll.inclination' "Inclination=tan(angle)";
    Real 'vehicle.fRoll.Cr_internal' "Rolling resistance coefficient";
    Real 'vehicle.fRoll.inclination_internal' "Inclination";
    parameter Boolean 'vehicle.fGrav.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'vehicle.fGrav.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'vehicle.fGrav.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.fGrav.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.fGrav.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'vehicle.fGrav.f'(unit = "N") "Driving force as input signal";
    Real 'vehicle.flangeT.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.flangeT.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.flangeR.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'vehicle.flangeR.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'vehicle.inertia.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'vehicle.inertia.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'vehicle.inertia.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'vehicle.inertia.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'vehicle.inertia.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Moment of inertia";
    parameter StateSelect 'vehicle.inertia.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'vehicle.inertia.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'vehicle.inertia.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'vehicle.inertia.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Boolean 'vehicle.idealRollingWheel.useSupportR' = false "= true, if rotational support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    parameter Boolean 'vehicle.idealRollingWheel.useSupportT' = false "= true, if translational support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'vehicle.idealRollingWheel.flangeR.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'vehicle.idealRollingWheel.flangeR.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'vehicle.idealRollingWheel.flangeT.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.idealRollingWheel.flangeT.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.idealRollingWheel.internalSupportR.tau'(unit = "N.m", quantity = "Torque") "External support torque (must be computed via torque balance in model where InternalSupport is used; = flange.tau)";
    Real 'vehicle.idealRollingWheel.internalSupportR.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "External support angle (= flange.phi)";
    Real 'vehicle.idealRollingWheel.internalSupportR.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'vehicle.idealRollingWheel.internalSupportR.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'vehicle.idealRollingWheel.internalSupportT.f'(unit = "N", quantity = "Force") "External support force (must be computed via force balance in model where InternalSupport is used; = flange.f)";
    Real 'vehicle.idealRollingWheel.internalSupportT.s'(unit = "m", quantity = "Length") "External support position (= flange.s)";
    Real 'vehicle.idealRollingWheel.internalSupportT.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.idealRollingWheel.internalSupportT.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'vehicle.idealRollingWheel.fixedR.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'vehicle.idealRollingWheel.fixedR.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'vehicle.idealRollingWheel.fixedR.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'vehicle.idealRollingWheel.fixedT.s0'(unit = "m", quantity = "Length") = 0.0 "Fixed offset position of housing";
    Real 'vehicle.idealRollingWheel.fixedT.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.idealRollingWheel.fixedT.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'vehicle.idealRollingWheel.radius'(start = 0.3, min = 0.0, unit = "m", quantity = "Length") = 0.25 "Wheel radius";
    parameter Real 'vehicle.mass.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 100.0 "Mass of the sliding mass";
    parameter StateSelect 'vehicle.mass.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'vehicle.mass.s'(stateSelect = StateSelect.default, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'vehicle.mass.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'vehicle.mass.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.mass.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.mass.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.mass.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.mass.v'(stateSelect = StateSelect.default, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'vehicle.mass.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    Real 'vehicle.inclination' "Inclination=tan(angle)";
    parameter Boolean 'vehicle.windSpeed.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'vehicle.windSpeed.s'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'vehicle.windSpeed.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle.windSpeed.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle.windSpeed.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    parameter Boolean 'vehicle.windSpeed.exact' = false "Is true/false for exact treatment/filtering of the input signal, respectively" annotation(Evaluate = true);
    parameter Real 'vehicle.windSpeed.f_crit'(unit = "Hz", quantity = "Frequency") = 50.0 "If exact=false, critical frequency of filter to filter input signal";
    Real 'vehicle.windSpeed.v'(stateSelect = StateSelect.prefer, unit = "m/s", quantity = "Velocity") "Absolute velocity of flange";
    Real 'vehicle.windSpeed.a'(unit = "m/s2", quantity = "Acceleration") "If exact=false, absolute acceleration of flange else dummy";
    Real 'vehicle.windSpeed.v_ref'(unit = "m/s") "Reference speed of flange as input signal";
    parameter Real 'vehicle.windSpeed.w_crit'(unit = "rad/s", quantity = "AngularFrequency") = 314.1592653589793 "Critical frequency";
    parameter Real 'vehicle.gravForceGain.k'(start = 1.0) = -980.665 "Gain value multiplied with input signal";
    Real 'vehicle.gravForceGain.u' "Input signal connector";
    Real 'vehicle.gravForceGain.y' "Output signal connector";
    parameter Real 'vehicle.constWindSpeed.k'(start = 1.0) = 0.0 "Constant output value";
    Real 'vehicle.constWindSpeed.y' "Connector of Real output signal";
    Real 'vehicle.atan.u' "Connector of Real input signal";
    Real 'vehicle.atan.y'(unit = "rad") "Connector of Real output signal";
    Real 'vehicle.sin.u'(unit = "rad") "Connector of Real input signal";
    Real 'vehicle.sin.y' "Connector of Real output signal";
    parameter Real 'vehicle1.m'(min = 0.0, unit = "kg", quantity = "Mass") = 100.0 "Total mass of vehicle";
    parameter Real 'vehicle1.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Real 'vehicle1.J'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Total rotational inertia of drive train";
    parameter Real 'vehicle1.R'(unit = "m", quantity = "Length") = 0.25 "Wheel radius";
    parameter Real 'vehicle1.A'(start = 1.0, unit = "m2", quantity = "Area") = 1.0 "Cross section of vehicle";
    parameter Real 'vehicle1.Cd'(start = 0.5) = 0.5 "Drag resistance coefficient";
    parameter Real 'vehicle1.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.2 "Density of air";
    parameter Boolean 'vehicle1.useWindInput' = false "Enable signal input for wind velocity";
    parameter Real 'vehicle1.vWindConstant'(unit = "m/s", quantity = "Velocity") = 0.0 "Constant wind velocity";
    parameter Boolean 'vehicle1.useCrInput' = false "Enable signal input for Cr";
    parameter Real 'vehicle1.CrConstant' = 0.01 "Constant rolling resistance coefficient";
    parameter Real 'vehicle1.vReg'(unit = "m/s", quantity = "Velocity") = 0.001 "Velocity for regularization around 0";
    parameter Boolean 'vehicle1.useInclinationInput' = true "Enable signal input for inclination";
    parameter Real 'vehicle1.inclinationConstant' = 0.0 "Constant inclination = tan(angle)";
    Real 'vehicle1.s'(fixed = true, start = 0.0, displayUnit = "km", unit = "m", quantity = "Length") "Position of vehicle";
    Real 'vehicle1.v'(fixed = true, start = 0.0, displayUnit = "km/h", unit = "m/s", quantity = "Velocity") "Velocity of vehicle";
    Real 'vehicle1.a'(unit = "m/s2", quantity = "Acceleration") "Acceleration of vehicle";
    constant Real 'vehicle1.vRef'(unit = "m/s", quantity = "Velocity") = 1.0 "Reference velocity for air drag";
    parameter Boolean 'vehicle1.fDrag.useSupport' = true "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'vehicle1.fDrag.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'vehicle1.fDrag.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle1.fDrag.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle1.fDrag.support.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle1.fDrag.support.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle1.fDrag.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'vehicle1.fDrag.f'(unit = "N", quantity = "Force") "Accelerating force acting at flange (= flange.f)";
    parameter Real 'vehicle1.fDrag.f_nominal'(unit = "N", quantity = "Force") = -0.3 "Nominal force (if negative, force is acting as load in positive direction of motion)";
    parameter Boolean 'vehicle1.fDrag.ForceDirection' = false "Same direction of force in both directions of motion";
    parameter Real 'vehicle1.fDrag.v_nominal'(min = 2.220446049250313e-16, unit = "m/s", quantity = "Velocity") = 1.0 "Nominal speed";
    Real 'vehicle1.fDrag.v'(unit = "m/s", quantity = "Velocity") "Velocity of flange with respect to support (= der(s))";
    parameter Boolean 'vehicle1.fRoll.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'vehicle1.fRoll.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'vehicle1.fRoll.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'vehicle1.fRoll.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'vehicle1.fRoll.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'vehicle1.fRoll.f'(unit = "N", quantity = "Force") "Accelerating force acting at flange (= flange.f)";
    parameter Real 'vehicle1.fRoll.fWeight'(start = 0.0, unit = "N", quantity = "Force") = 980.665 "Wheel load due to gravity";
    parameter Boolean 'vehicle1.fRoll.useCrInput' = false "Enable signal input for Cr";
    parameter Real 'vehicle1.fRoll.CrConstant' = 0.01 "Constant rolling resistance coefficient";
    parameter Boolean 'vehicle1.fRoll.useInclinationInput' = true "Enable signal input for inclination";
    parameter Real 'vehicle1.fRoll.inclinationConstant' = 0.0 "Constant inclination = tan(angle)";
    parameter 'Modelica.Blocks.Types.Regularization' 'vehicle1.fRoll.reg' = 'Modelica.Blocks.Types.Regularization'.'Linear' "Type of regularization" annotation(Evaluate = true);
    parameter Real 'vehicle1.fRoll.v0'(min = 2.220446049250313e-16, unit = "m/s", quantity = "Velocity") = 0.001 "Regularization below v0";
    Real 'vehicle1.fRoll.v'(unit = "m/s", quantity = "Velocity") "Velocity of flange with respect to support (= der(s))";
    Real 'vehicle1.fRoll.f_nominal'(unit = "N", quantity = "Force") "Nominal rolling resistance without regularization";
    Real 'vehicle1.fRoll.inclination' "Inclination=tan(angle)";
