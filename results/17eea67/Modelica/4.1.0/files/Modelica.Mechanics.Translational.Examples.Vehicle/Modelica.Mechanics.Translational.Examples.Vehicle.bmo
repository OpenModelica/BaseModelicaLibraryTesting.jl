    'trailer.fDrag.v' = der('trailer.fDrag.s');
    'trailer.fDrag.f' = -(-0.3) * smooth(1, if 'trailer.fDrag.v' >= 0.0 then 'trailer.fDrag.v' ^ 2.0 else -'trailer.fDrag.v' ^ 2.0);
