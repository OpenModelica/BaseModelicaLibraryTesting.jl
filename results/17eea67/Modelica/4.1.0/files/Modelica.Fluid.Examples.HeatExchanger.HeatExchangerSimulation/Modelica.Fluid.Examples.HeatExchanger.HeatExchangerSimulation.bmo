  function 'Modelica.Fluid.Examples.HeatExchanger.HeatExchangerSimulation.HEX.pipe_2.Medium.density_pT' "Computes density as a function of pressure and temperature"
    input Real 'p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Integer 'phase'(max = 2, min = 0) = 0;
    input Integer 'region' = 0;
    output Real 'd'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
