    'o'[10] := 'o'[9] * 'o'[9];
    'o'[11] := 'o'[3] * 'o'[5] * 'tau2';
    'o'[12] := 'o'[5] * 'o'[5];
    'gpi' := (1.0 + 'pi' * ('tau2' * ('tau2' * ((-(0.057581259083432 + 0.05032527872793 * 'o'[2])) * 'tau2' - 0.045996013696365) - 0.017834862292358) - 0.0017731742473213 + 'pi' * ('tau2' * (('o'[1] * ('o'[2] * (-(0.087594591301146 + 5.3349095828174e-5 * 'o'[6])) - 0.007878555448671) - 3.789797503263e-4) * 'tau2' - 6.6065283340406e-5) + 'pi' * (6.1445213076927e-8 + (1.31612001853305e-6 + 'o'[1] * ('o'[2] * (-(0.0045101773626444 + 0.122004760687947 * 'o'[6])) - 9.683303171571e-5)) * 'tau2' + 'pi' * ('tau2' * ((5.116287140914e-8 + 1.92901490874028e-6 * 'tau2') * 'tau2' - 3.15389238237468e-9) + 'pi' * (1.14610381688305e-5 * 'o'[1] * 'o'[3] * 'tau2' + 'pi' * ('o'[2] * ('o'[7] * (-(0.012702883392813 + 143.374451604624 * 'o'[1] * 'o'[5] * 'tau2')) - 1.00288598706366e-10) + 'pi' * ('o'[1] * 'o'[4] * (-(8.8352662293707e-6 + 0.272627897050173 * 'o'[8])) * 'tau2' - 4.1341695026989e-17 + 'pi' * ('o'[4] * (9.0049690883672e-11 - 65.8490727183984 * 'o'[3] * 'o'[4] * 'o'[5]) + 'pi' * (1.78287415218792e-7 * 'o'[7] + 'pi' * ('o'[3] * (1.0406965210174e-18 + 'o'[1] * (-(1.0234747095929e-12 + 1.0018179379511e-8 * 'o'[3])) * 'o'[3]) + 'o'[10] * 'o'[9] * ((1.71088510070544 * 'o'[11] - 1.29412653835176e-9) * 'o'[6] + 'o'[9] * ('o'[9] * ('o'[3] * 'o'[5] * (1.78371690710842e-23 + 'o'[1] * 'o'[3] * 'o'[4] * (6.1258633752464e-12 - 8.4004935396416e-5 * 'o'[7]) * 'tau2') + 'pi' * ('pi' * (8.32192847496054e-5 * 'o'[12] * 'o'[3] * 'o'[5] * 'tau2' + 'pi' * ('o'[1] * 'o'[4] * 'o'[5] * (1.75410265428146e-27 + (1.32995316841867e-15 - 2.26487297378904e-5 * 'o'[1] * 'o'[5]) * 'o'[8]) * 'pi' - 2.93678005497663e-14 * 'o'[1] * 'o'[12] * 'o'[3] * 'tau2')) - 1.24017662339842e-24 * 'o'[11])) - 6.05920510335078 * 'o'[12] * 'o'[4] * 'o'[5] * 'tau2'))))))))))))) / 'pi';
    'd' := 'p' / (461.526 * 'T' * 'pi' * 'gpi');
