      'T' := 'eta2c' * ((859777.2253558 + 'o'[1] * (482.19755109255 + 1.126159740723e-12 * 'o'[5])) / 'o'[1] + 'eta2c' * (((2.0825544563171e10 + 31081.088422714 * 'o'[2]) * 'pi2c' - 5.834013185159e11) / 'o'[5] + 'o'[6] * ('o'[8] * ('o'[6] * (1.2324579690832e-7 * 'o'[5] + 'o'[6] * ('o'[8] * (2.7846367088554e-5 * 'o'[5] + (0.0012918582991878 * 'o'[5] * 'o'[6] - 5.9270038474176e-4 * 'o'[5]) * 'o'[8]) - 1.1606921130984e-6 * 'o'[5])) - 10.842984880077 * 'pi2c') + 'o'[4] * (7.3263350902181e12 + 'o'[7] * (3.7966001272486 + (-(0.04536417267666 + 1.7804982240686e-11 * 'o'[2])) * 'pi2c'))))) + 'o'[4] * ('pi2c' * (3.5825089945447e11 + 'pi2c' * ('o'[1] * 'pi2c' * (610747.83564516 + 'pi2c' * ((1208.2315865936 + 1.4559115658698e-13 * 'o'[5]) * 'pi2c' - 25745.72360417)) - 1.078306821747e10)) - 3.2368398555242e12);
