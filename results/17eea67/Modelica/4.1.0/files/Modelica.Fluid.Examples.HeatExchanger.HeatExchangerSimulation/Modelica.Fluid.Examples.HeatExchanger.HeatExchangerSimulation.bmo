  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat' "Region 4 saturation temperature as a function of pressure"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 't_sat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'pi';
    Real[20] 'o';
  algorithm
    assert('p' > 611.657, "IF97 medium function tsat called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'pi' := min('p', 2.2064e7) * 1e-6;
    'o'[1] := 'pi' ^ 0.25;
    'o'[2] := -3.2325550322333e6 * 'o'[1];
    'o'[3] := 'pi' ^ 0.5;
    'o'[4] := -724213.16703206 * 'o'[3];
    'o'[5] := 405113.40542057 + 'o'[2] + 'o'[4];
    'o'[6] := -17.073846940092 * 'o'[1];
    'o'[7] := 14.91510861353 + 'o'[3] + 'o'[6];
    'o'[8] := -4.0 * 'o'[5] * 'o'[7];
    'o'[9] := 12020.82470247 * 'o'[1];
    'o'[10] := 1167.0521452767 * 'o'[3];
    'o'[11] := 'o'[10] - 4823.2657361591 + 'o'[9];
    'o'[12] := 'o'[11] * 'o'[11];
    'o'[13] := 'o'[12] + 'o'[8];
    'o'[14] := 'o'[13] ^ 0.5;
    'o'[15] := -'o'[14];
    'o'[16] := -12020.82470247 * 'o'[1];
    'o'[17] := -1167.0521452767 * 'o'[3];
    'o'[18] := 4823.2657361591 + 'o'[15] + 'o'[16] + 'o'[17];
    'o'[19] := 1.0 / 'o'[18];
    'o'[20] := 2.0 * 'o'[19] * 'o'[5];
    't_sat' := 0.5 * (650.17534844798 + 'o'[20] - ((650.17534844798 + 'o'[20]) ^ 2.0 - 4.0 * (1300.35069689596 * 'o'[19] * 'o'[5] - 0.23855557567849)) ^ 0.5);
    annotation(derivative(order = 1) = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der' "Derivative function for tsat"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'der_p'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    output Real 'der_tsat'(unit = "K/s", quantity = "TemperatureSlope");
    Real 'dtp';
  algorithm
    'dtp' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dtsatofp'('p');
    'der_tsat' := 'dtp' * 'der_p';
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.v3a_ph' "Region 3 a: inverse function v(p,h)"
