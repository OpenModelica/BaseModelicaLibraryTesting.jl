    'o'[5] := 'o'[4] * 'o'[4];
    'o'[6] := 'o'[3] * 'o'[4] * 'o'[5] * 'tau2';
    'o'[7] := 'o'[3] * 'o'[4] * 'tau2';
    'o'[8] := 'o'[1] * 'o'[3] * 'o'[4];
