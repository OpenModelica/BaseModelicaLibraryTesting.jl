    parameter 'Modelica.Fluid.Types.Dynamics' 'HEX.wall.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter Real 'HEX.wall.T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.0 "Wall temperature start value";
    parameter Real 'HEX.wall.dT'(unit = "K", quantity = "ThermodynamicTemperature") = 1.0;
    Real 'HEX.wall.Tb[1]'(nominal = 300.0, start = 300.5, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'HEX.wall.Tb[2]'(nominal = 300.0, start = 300.5, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
