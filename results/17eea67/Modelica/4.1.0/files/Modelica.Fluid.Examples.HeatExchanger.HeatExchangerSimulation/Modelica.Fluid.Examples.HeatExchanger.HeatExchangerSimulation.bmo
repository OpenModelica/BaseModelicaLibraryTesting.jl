  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.h3ab_p' "Region 3 a b boundary for pressure/enthalpy"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    constant Real[:] 'n' = {2014.64004206875, 3.74696550136983, -0.0219921901054187, 8.7513168600995e-5};
    constant Real 'hstar'(unit = "J/kg", quantity = "SpecificEnergy") = 1000.0;
    constant Real 'pstar'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e6;
    Real 'pi' = 'p' / 'pstar';
  algorithm
    'h' := ('n'[1] + 'n'[2] * 'pi' + 'n'[3] * 'pi' ^ 2.0 + 'n'[4] * 'pi' ^ 3.0) * 'hstar';
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.h3ab_p';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat' "Region 4 saturation pressure as a function of temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'p_sat'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real[8] 'o';
    Real 'Tlim' = min('T', 647.096);
  algorithm
    assert('T' >= 273.16, "IF97 medium function psat: input temperature (= 273.16 K).\nlower than the triple point temperature 273.16 K", AssertionLevel.error);
    'o'[1] := 'Tlim' - 650.17534844798;
    'o'[2] := 1.0 / 'o'[1];
    'o'[3] := -0.23855557567849 * 'o'[2];
    'o'[4] := 'o'[3] + 'Tlim';
    'o'[5] := -4823.2657361591 * 'o'[4];
    'o'[6] := 'o'[4] * 'o'[4];
    'o'[7] := 14.91510861353 * 'o'[6];
    'o'[8] := 405113.40542057 + 'o'[5] + 'o'[7];
    'p_sat' := 1.6e7 * 'o'[8] * 'o'[8] * 'o'[8] * 'o'[8] / (3.2325550322333e6 - 12020.82470247 * 'o'[4] + 17.073846940092 * 'o'[6] + sqrt((12020.82470247 * 'o'[4] - 3.2325550322333e6 - 17.073846940092 * 'o'[6]) ^ 2.0 - 4.0 * (1167.0521452767 * 'o'[4] - 724213.16703206 + 'o'[6]) * 'o'[8])) ^ 4.0;
    annotation(derivative(order = 1) = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat_der');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat_der' "Derivative function for psat"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'der_T'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'der_psat'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dpt';
  algorithm
    'dpt' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dptofT'('T');
    'der_psat' := 'dpt' * 'der_T';
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat_der';

