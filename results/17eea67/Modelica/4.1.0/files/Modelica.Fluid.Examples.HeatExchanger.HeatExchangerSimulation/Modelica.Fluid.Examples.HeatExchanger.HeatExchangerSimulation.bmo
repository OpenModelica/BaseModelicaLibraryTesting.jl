  model 'HeatExchangerSimulation' "Simulation for the heat exchanger model"
    parameter Real 'HEX.length'(min = 0.0, unit = "m", quantity = "Length") = 20.0 "Length of flow path for both fluids";
    parameter Integer 'HEX.nNodes'(min = 1) = 20 "Spatial segmentation";
    parameter 'Modelica.Fluid.Types.ModelStructure' 'HEX.modelStructure_1' = 'Modelica.Fluid.Types.ModelStructure'.'av_b' "Determines whether flow or volume models are present at the ports" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.ModelStructure' 'HEX.modelStructure_2' = 'Modelica.Fluid.Types.ModelStructure'.'a_vb' "Determines whether flow or volume models are present at the ports" annotation(Evaluate = true);
    parameter Real 'HEX.crossArea_1'(unit = "m2", quantity = "Area") = 4.5e-4 "Cross sectional area";
    parameter Real 'HEX.crossArea_2'(unit = "m2", quantity = "Area") = 4.5e-4 "Cross sectional area";
    parameter Real 'HEX.perimeter_1'(unit = "m", quantity = "Length") = 0.075 "Flow channel perimeter";
    parameter Real 'HEX.perimeter_2'(unit = "m", quantity = "Length") = 0.075 "Flow channel perimeter";
    parameter Boolean 'HEX.use_HeatTransfer' = true "= true to use the HeatTransfer_1/_2 model";
    parameter Real 'HEX.area_h_1'(unit = "m2", quantity = "Area") = 1.5 "Heat transfer area";
    parameter Real 'HEX.area_h_2'(unit = "m2", quantity = "Area") = 1.5 "Heat transfer area";
    parameter Real 'HEX.s_wall'(min = 0.0, unit = "m", quantity = "Length") = 0.005 "Wall thickness";
    parameter Real 'HEX.k_wall'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 100.0 "Thermal conductivity of wall material";
    parameter Real 'HEX.c_wall'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 500.0 "Specific heat capacity of wall material";
    parameter Real 'HEX.rho_wall'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 900.0 "Density of wall material";
    parameter Real 'HEX.area_h'(unit = "m2", quantity = "Area") = 1.5 "Heat transfer area";
    parameter Real 'HEX.m_wall'(min = 0.0, unit = "kg", quantity = "Mass") = 6.75 "Wall mass";
    parameter Boolean 'HEX.allowFlowReversal' = true "Allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'HEX.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'HEX.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'HEX.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance, if pressureLoss options available" annotation(Evaluate = true);
    parameter Real 'HEX.Twall_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.0 "Start value of wall temperature";
    parameter Real 'HEX.dT'(unit = "K", quantity = "ThermodynamicTemperature") = 1.0;
    parameter Boolean 'HEX.use_T_start' = true "Use T_start if true, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'HEX.p_a_start1'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Real 'HEX.p_b_start1'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Real 'HEX.T_start_1'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 304.0 "Start value of temperature" annotation(Evaluate = true);
    parameter Real 'HEX.h_start_1'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 129386.63063497175 "Start value of specific enthalpy" annotation(Evaluate = true);
    parameter Real 'HEX.X_start_1[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    parameter Real 'HEX.m_flow_start_1'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 0.2 "Start value of mass flow rate" annotation(Evaluate = true);
    parameter Real 'HEX.p_a_start2'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Real 'HEX.p_b_start2'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Real 'HEX.T_start_2'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.0 "Start value of temperature" annotation(Evaluate = true);
    parameter Real 'HEX.h_start_2'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 112665.04341854039 "Start value of specific enthalpy" annotation(Evaluate = true);
    parameter Real 'HEX.X_start_2[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    parameter Real 'HEX.m_flow_start_2'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 0.2 "Start value of mass flow rate" annotation(Evaluate = true);
    parameter Real 'HEX.roughness_1'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Absolute roughness of pipe (default = smooth steel pipe)";
    parameter Real 'HEX.roughness_2'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Absolute roughness of pipe (default = smooth steel pipe)";
    Real 'HEX.Q_flow_1'(unit = "W", quantity = "Power") "Total heat flow rate of pipe 1";
    Real 'HEX.Q_flow_2'(unit = "W", quantity = "Power") "Total heat flow rate of pipe 2";
    parameter Integer 'HEX.wall.n'(min = 1) = 20 "Segmentation perpendicular to heat conduction";
    parameter Real 'HEX.wall.s'(unit = "m", quantity = "Length") = 0.005 "Wall thickness";
    parameter Real 'HEX.wall.area_h'(unit = "m2", quantity = "Area") = 1.5 "Heat transfer area";
    parameter Real 'HEX.wall.rho_wall'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 900.0 "Density of wall material";
    parameter Real 'HEX.wall.c_wall'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 500.0 "Specific heat capacity of wall material";
    parameter Real 'HEX.wall.k_wall'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 100.0 "Thermal conductivity of wall material";
    parameter Real 'HEX.wall.m[1]'(min = 0.0, unit = "kg", quantity = "Mass") = 0.3375 "Distribution of wall mass";
    parameter Real 'HEX.wall.m[2]'(min = 0.0, unit = "kg", quantity = "Mass") = 0.3375 "Distribution of wall mass";
