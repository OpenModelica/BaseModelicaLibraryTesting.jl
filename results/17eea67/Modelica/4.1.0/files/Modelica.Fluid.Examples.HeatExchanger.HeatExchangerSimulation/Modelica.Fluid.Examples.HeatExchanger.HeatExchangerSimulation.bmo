    der('HEX.wall.T[19]') = 0.0;
    der('HEX.wall.T[20]') = 0.0;
    'HEX.pipe_1.flowModel.dp_nominal' = 'HEX.pipe_1.flowModel.dp_fric_nominal' + 9.80665 * ('HEX.pipe_1.flowModel.dheights[1]' + 'HEX.pipe_1.flowModel.dheights[2]' + 'HEX.pipe_1.flowModel.dheights[3]' + 'HEX.pipe_1.flowModel.dheights[4]' + 'HEX.pipe_1.flowModel.dheights[5]' + 'HEX.pipe_1.flowModel.dheights[6]' + 'HEX.pipe_1.flowModel.dheights[7]' + 'HEX.pipe_1.flowModel.dheights[8]' + 'HEX.pipe_1.flowModel.dheights[9]' + 'HEX.pipe_1.flowModel.dheights[10]' + 'HEX.pipe_1.flowModel.dheights[11]' + 'HEX.pipe_1.flowModel.dheights[12]' + 'HEX.pipe_1.flowModel.dheights[13]' + 'HEX.pipe_1.flowModel.dheights[14]' + 'HEX.pipe_1.flowModel.dheights[15]' + 'HEX.pipe_1.flowModel.dheights[16]' + 'HEX.pipe_1.flowModel.dheights[17]' + 'HEX.pipe_1.flowModel.dheights[18]' + 'HEX.pipe_1.flowModel.dheights[19]' + 'HEX.pipe_1.flowModel.dheights[20]') * 998.2060924679472;
