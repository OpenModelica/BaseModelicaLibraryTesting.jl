  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13' "Density at the boundary between regions 1 and 3"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'p2';
    Real[3] 'o';
  algorithm
    'p2' := 7.1 - 6.04960677555959e-8 * 'p';
    'o'[1] := 'p2' * 'p2';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
    'd' := 57.4756752485113 / (0.0737412153522555 + 'p2' * (0.00145092247736023 + 'p2' * (1.02697173772229e-4 + 'p2' * (1.14683182476084e-5 + 'p2' * (1.99080616601101e-6 + 'o'[1] * 'p2' * (1.13217858826367e-8 + 'o'[2] * 'o'[3] * 'p2' * (1.35549330686006e-17 + 'o'[1] * ('o'[1] * 'o'[2] * ('p2' * (3.29199117056433e-22 + (2.73712834080283e-24 * 'p2' - 5.17859076694812e-23) * 'p2') - 7.02987180039442e-22) - 3.11228834832975e-19))))))));
