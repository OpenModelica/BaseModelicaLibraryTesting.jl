    'massFlowRate1.ports[1].p' = 'massFlowRate1.medium.p';
    'massFlowRate1.ports[1].h_outflow' = 'massFlowRate1.medium.h';
    'Ramp1.y' = (if time < 50.0 then 0.0 else if time < 55.0 then (time - 50.0) * 0.4 / 5.0 else 0.4) - 0.2;
    annotation(experiment(StopTime = 200, Tolerance = 1e-005));
  end 'HeatExchangerSimulation';
end 'HeatExchangerSimulation';
