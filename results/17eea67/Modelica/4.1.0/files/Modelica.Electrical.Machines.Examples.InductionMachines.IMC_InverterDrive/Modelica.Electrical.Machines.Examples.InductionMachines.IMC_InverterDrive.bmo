    parameter Real 'gridCurrent.ToSpacePhasor1.phi[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    parameter Real 'gridCurrent.ToSpacePhasor1.phi[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 2.0943951023931953;
    parameter Real 'gridCurrent.ToSpacePhasor1.phi[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 4.1887902047863905;
    parameter Real 'gridCurrent.ToSpacePhasor1.TransformationMatrix[1,1]' = 0.6666666666666666;
    parameter Real 'gridCurrent.ToSpacePhasor1.TransformationMatrix[1,2]' = -0.33333333333333315;
