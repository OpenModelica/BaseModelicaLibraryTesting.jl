//! base 0.1.0
package 'IMC_InverterDrive'
  function 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower' "Calculate active power of voltage and current input"
    input Real[3] 'v'(unit = {"V", "V", "V"}, quantity = {"ElectricPotential", "ElectricPotential", "ElectricPotential"});
    input Real[3] 'i'(unit = {"A", "A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent", "ElectricCurrent"});
    output Real 'p'(unit = "W", quantity = "Power");
    constant Integer 'm' = 3;
    Real[2] 'v_'(unit = {"V", "V"}, quantity = {"ElectricPotential", "ElectricPotential"});
    Real[2] 'i_'(unit = {"A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent"});
  algorithm
    'v_' := {0.0, 0.0};
    'i_' := {0.0, 0.0};

    for 'k' in 1:'m' loop
      'v_' := {'v_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k'], 'v_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k']};
      'i_' := {'i_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k'], 'i_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k']};
    end for;

    'p' := 'm' / 2.0 * ('v_'[1] * 'i_'[1] + 'v_'[2] * 'i_'[2]);
    annotation(Inline = true);
  end 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower';

  function 'Modelica.Electrical.Polyphase.Functions.quasiRMS' "Calculate continuous quasi RMS value of input"
    input Real[:] 'x';
    output Real 'y';
  algorithm
    'y' := sqrt(sum('x' .^ 2.0 / size('x', 1)));
    annotation(Inline = true);
  end 'Modelica.Electrical.Polyphase.Functions.quasiRMS';

  function 'Modelica.Math.atan2' "Four quadrant inverse tangent"
    input Real 'u1';
    input Real 'u2';
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := atan2('u1', 'u2');
    annotation(Inline = true);
  end 'Modelica.Math.atan2';

  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  type 'Modelica.Electrical.PowerConverters.Types.PWMType' = enumeration('SVPWM', 'Intersective');

  type 'Modelica.Electrical.PowerConverters.Types.ReferenceType' = enumeration('Sawtooth1', 'Sawtooth3', 'Triangle1', 'Triangle3');

  model 'IMC_InverterDrive' "Test example: InductionMachineSquirrelCage inverter drive"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'VNominal'(unit = "V", quantity = "ElectricPotential") = 400.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'RGrid'(unit = "Ohm", quantity = "Resistance") = 0.01 "Grid choke resistance";
    parameter Real 'LGrid'(unit = "H", quantity = "Inductance") = 5e-4 "Grid choke inductance";
    parameter Real 'VDC'(unit = "V", quantity = "ElectricPotential") = 540.1897896942636 "Theoretical DC voltage";
    parameter Real 'CDC'(min = 0.0, unit = "F", quantity = "Capacitance") = 0.005 "DC capacitor";
    parameter Real 'TLoad'(unit = "N.m", quantity = "Torque") = 161.4 "Nominal load torque";
    parameter Real 'wLoad'(unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal load speed";
    parameter Real 'JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load's moment of inertia";
    parameter Integer 'sineVoltage.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltage.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'sineVoltage.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'sineVoltage.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    parameter Integer 'sineVoltage.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltage.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
