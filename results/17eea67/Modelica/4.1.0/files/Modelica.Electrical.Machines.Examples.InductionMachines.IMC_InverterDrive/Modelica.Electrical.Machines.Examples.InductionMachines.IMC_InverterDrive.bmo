    elseif time < 'pwm.svPWM.T0' + 5e-4 * ('pwm.svPWM.t0' / 4.0 + 'pwm.svPWM.ta' / 2.0 + 'pwm.svPWM.tb' / 2.0) then
      'pwm.svPWM.fire_p[1]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.kb' + 1,1];
      'pwm.svPWM.fire_p[2]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.kb' + 1,2];
      'pwm.svPWM.fire_p[3]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.kb' + 1,3];
    elseif time < 'pwm.svPWM.T0' + 5e-4 * ('pwm.svPWM.t0' / 4.0 + 'pwm.svPWM.ta' / 2.0 + 'pwm.svPWM.tb' / 2.0 + 'pwm.svPWM.t0' / 2.0) then
      'pwm.svPWM.fire_p[1]' = true;
      'pwm.svPWM.fire_p[2]' = true;
      'pwm.svPWM.fire_p[3]' = true;
    elseif time < 'pwm.svPWM.T0' + 5e-4 * ('pwm.svPWM.t0' / 4.0 + 'pwm.svPWM.ta' / 2.0 + 'pwm.svPWM.tb' / 2.0 + 'pwm.svPWM.t0' / 2.0 + 'pwm.svPWM.tb' / 2.0) then
      'pwm.svPWM.fire_p[1]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.kb' + 1,1];
      'pwm.svPWM.fire_p[2]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.kb' + 1,2];
      'pwm.svPWM.fire_p[3]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.kb' + 1,3];
    elseif time < 'pwm.svPWM.T0' + 5e-4 * ('pwm.svPWM.t0' / 4.0 + 'pwm.svPWM.ta' / 2.0 + 'pwm.svPWM.tb' / 2.0 + 'pwm.svPWM.t0' / 2.0 + 'pwm.svPWM.tb' / 2.0 + 'pwm.svPWM.ta' / 2.0) then
      'pwm.svPWM.fire_p[1]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.ka' + 1,1];
      'pwm.svPWM.fire_p[2]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.ka' + 1,2];
      'pwm.svPWM.fire_p[3]' = ({{true, false, false}, {true, true, false}, {false, true, false}, {false, true, true}, {false, false, true}, {true, false, true}})['pwm.svPWM.ka' + 1,3];
    elseif true then
      'pwm.svPWM.fire_p[1]' = false;
      'pwm.svPWM.fire_p[2]' = false;
      'pwm.svPWM.fire_p[3]' = false;
    end if;

    'pwm.svPWM.fire_n[1]' = not 'pwm.svPWM.fire_p[1]';
    'pwm.svPWM.fire_n[2]' = not 'pwm.svPWM.fire_p[2]';
    'pwm.svPWM.fire_n[3]' = not 'pwm.svPWM.fire_p[3]';
    'pwm.svPWM.sampleTrigger' = sample(0.0, 5e-4);

    when 'pwm.svPWM.sampleTrigger' then
      'pwm.svPWM.firstTrigger' = time <= 2.5e-4;
    end when;
  algorithm
    when 'pwm.svPWM.sampleTrigger' then
      'pwm.svPWM.uRef' := min(sqrt('pwm.svPWM.u[1]' ^ 2.0 + 'pwm.svPWM.u[2]' ^ 2.0) / 360.1265264628424, 0.8660254037844387);
      'pwm.svPWM.phiRef' := if 'pwm.svPWM.uRef' < 2.2250738585072014e-308 then 0.0 else 'Modelica.Math.atan2'('pwm.svPWM.u[2]', 'pwm.svPWM.u[1]');
      'pwm.svPWM.phiPos' := max(0.0, 'pwm.svPWM.phiRef' + (if 'pwm.svPWM.phiRef' < (-1.3951473992034527e-15) then 6.283185307179586 else 0.0));
      'pwm.svPWM.ka' := min(integer('pwm.svPWM.phiPos' / 1.0471975511965976), 5);
      'pwm.svPWM.kb' := mod('pwm.svPWM.ka' + 1, 6);
      'pwm.svPWM.phiSec' := 'pwm.svPWM.phiPos' - 'pwm.svPWM.ka' * 3.141592653589793 / 3.0;
      'pwm.svPWM.tb' := min('pwm.svPWM.uRef' * sin('pwm.svPWM.phiSec') / 0.8660254037844386, 1.0);
      'pwm.svPWM.ta' := min('pwm.svPWM.uRef' * cos('pwm.svPWM.phiSec') - 'pwm.svPWM.tb' * 0.5000000000000001, 1.0);
      'pwm.svPWM.t0' := max(1.0 - 'pwm.svPWM.ta' - 'pwm.svPWM.tb', 0.0);
      'pwm.svPWM.T0' := time;
    end when;
    annotation(experiment(StopTime = 1.5, Interval = 5e-05, Tolerance = 1e-06));
  end 'IMC_InverterDrive';
end 'IMC_InverterDrive';
