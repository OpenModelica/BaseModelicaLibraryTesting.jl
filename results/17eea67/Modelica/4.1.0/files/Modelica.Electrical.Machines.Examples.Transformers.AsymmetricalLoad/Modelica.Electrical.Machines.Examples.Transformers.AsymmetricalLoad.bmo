    Real 'earth.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'earth.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'earth.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'earth.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'earth.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'earth.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'groundT.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'groundT.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
  initial equation
    'transformer.i2[1]' = 0.0;
  equation
    'transformer.powerBalance.power1' = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'('transformer.v1', 'transformer.i1');
    'transformer.powerBalance.power2' = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'('transformer.v2', 'transformer.i2');
    'transformer.powerBalance.lossPowerTotal' = 'transformer.powerBalance.lossPower1' + 'transformer.powerBalance.lossPower2' + 'transformer.powerBalance.lossPowerCore';
    'transformer.powerBalance.lossPower1' = 'transformer.r1.resistor[1].LossPower' + 'transformer.r1.resistor[2].LossPower' + 'transformer.r1.resistor[3].LossPower';
    'transformer.powerBalance.lossPower2' = 'transformer.r2.resistor[1].LossPower' + 'transformer.r2.resistor[2].LossPower' + 'transformer.r2.resistor[3].LossPower';
    'transformer.powerBalance.lossPowerCore' = 0.0;
    'transformer.r1.resistor[1].heatPort.T' = 'transformer.r1.resistor[1].T_heatPort';
    'transformer.r1.resistor[1].heatPort.Q_flow' = -'transformer.r1.resistor[1].LossPower';
    'transformer.r1.resistor[2].heatPort.T' = 'transformer.r1.resistor[2].T_heatPort';
    'transformer.r1.resistor[2].heatPort.Q_flow' = -'transformer.r1.resistor[2].LossPower';
    'transformer.r1.resistor[3].heatPort.T' = 'transformer.r1.resistor[3].T_heatPort';
    'transformer.r1.resistor[3].heatPort.Q_flow' = -'transformer.r1.resistor[3].LossPower';
    'transformer.r2.resistor[1].heatPort.T' = 'transformer.r2.resistor[1].T_heatPort';
    'transformer.r2.resistor[1].heatPort.Q_flow' = -'transformer.r2.resistor[1].LossPower';
    'transformer.r2.resistor[2].heatPort.T' = 'transformer.r2.resistor[2].T_heatPort';
    'transformer.r2.resistor[2].heatPort.Q_flow' = -'transformer.r2.resistor[2].LossPower';
    'transformer.r2.resistor[3].heatPort.T' = 'transformer.r2.resistor[3].T_heatPort';
    'transformer.r2.resistor[3].heatPort.Q_flow' = -'transformer.r2.resistor[3].LossPower';
    'transformer.thermalAmbient.Q_flow1' = 'transformer.thermalAmbient.temperature1.port.Q_flow';
    'transformer.thermalAmbient.Q_flow2' = 'transformer.thermalAmbient.temperature2.port.Q_flow';
    'transformer.thermalAmbient.Q_flowCore' = 'transformer.thermalAmbient.temperatureCore.port.Q_flow';
    'transformer.thermalAmbient.Q_flowTotal' = 'transformer.thermalAmbient.Q_flow1' + 'transformer.thermalAmbient.Q_flow2' + 'transformer.thermalAmbient.Q_flowCore';
    'source.sineVoltage[1].p.v' = 'source.plug_p.pin[1].v';
    'source.sineVoltage[2].p.v' = 'source.plug_p.pin[2].v';
    'source.sineVoltage[3].p.v' = 'source.plug_p.pin[3].v';
    'source.sineVoltage[1].n.v' = 'source.plug_n.pin[1].v';
    'source.sineVoltage[2].n.v' = 'source.plug_n.pin[2].v';
    'source.sineVoltage[3].n.v' = 'source.plug_n.pin[3].v';
    'starS.plug_p.pin[3].v' = 'starS.pin_n.v';
    'starS.plug_p.pin[3].v' = 'starS.plug_p.pin[2].v';
    'starS.plug_p.pin[3].v' = 'starS.plug_p.pin[1].v';
    -('starS.plug_p.pin[3].i' + 'starS.pin_n.i' + 'starS.plug_p.pin[2].i' + 'starS.plug_p.pin[1].i') = 0.0;
    'currentSensorS.plug_p.pin[1].v' = 'currentSensorS.currentSensor[1].p.v';
    'currentSensorS.currentSensor[1].p.i' - 'currentSensorS.plug_p.pin[1].i' = 0.0;
    'currentSensorS.plug_p.pin[2].v' = 'currentSensorS.currentSensor[2].p.v';
    'currentSensorS.currentSensor[2].p.i' - 'currentSensorS.plug_p.pin[2].i' = 0.0;
    'currentSensorS.plug_p.pin[3].v' = 'currentSensorS.currentSensor[3].p.v';
    'currentSensorS.currentSensor[3].p.i' - 'currentSensorS.plug_p.pin[3].i' = 0.0;
    'currentSensorS.currentSensor[1].n.v' = 'currentSensorS.plug_n.pin[1].v';
    'currentSensorS.currentSensor[2].n.v' = 'currentSensorS.plug_n.pin[2].v';
    'currentSensorS.currentSensor[3].n.v' = 'currentSensorS.plug_n.pin[3].v';
