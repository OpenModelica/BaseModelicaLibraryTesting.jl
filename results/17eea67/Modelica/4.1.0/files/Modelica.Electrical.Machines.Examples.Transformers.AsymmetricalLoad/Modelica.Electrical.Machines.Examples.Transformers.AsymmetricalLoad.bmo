    'transformer.thermalAmbient.thermalCollector1.port_a[1].T' = 'transformer.thermalAmbient.thermalCollector1.port_b.T';
    'transformer.thermalAmbient.thermalCollector1.port_a[2].T' = 'transformer.thermalAmbient.thermalCollector1.port_b.T';
    'transformer.thermalAmbient.thermalCollector1.port_a[3].T' = 'transformer.thermalAmbient.thermalCollector1.port_b.T';
    'transformer.thermalAmbient.thermalCollector2.port_b.Q_flow' + 'transformer.thermalAmbient.thermalCollector2.port_a[1].Q_flow' + 'transformer.thermalAmbient.thermalCollector2.port_a[2].Q_flow' + 'transformer.thermalAmbient.thermalCollector2.port_a[3].Q_flow' = 0.0;
    'transformer.thermalAmbient.thermalCollector2.port_a[1].T' = 'transformer.thermalAmbient.thermalCollector2.port_b.T';
    'transformer.thermalAmbient.thermalCollector2.port_a[2].T' = 'transformer.thermalAmbient.thermalCollector2.port_b.T';
    'transformer.thermalAmbient.thermalCollector2.port_a[3].T' = 'transformer.thermalAmbient.thermalCollector2.port_b.T';
    'plugToPin_n.pin_n.v' = 'plugToPin_n.plug_n.pin[1].v';
    'plugToPin_n.plug_n.pin[1].i' = -'plugToPin_n.pin_n.i';
    'plugToPin_n.plug_n.pin[2].i' = 0.0;
    'plugToPin_n.plug_n.pin[3].i' = 0.0;
    'load.R_actual' = 1.0;
    'load.v' = 'load.R_actual' * 'load.i';
    'load.LossPower' = 'load.v' * 'load.i';
    'load.T_heatPort' = 300.15;
    0.0 = 'load.p.i' + 'load.n.i';
    'load.i' = 'load.p.i';
    'load.v' = 'load.p.v' - 'load.n.v';
    'earth.R_actual' = 1e6;
    'earth.v' = 'earth.R_actual' * 'earth.i';
    'earth.LossPower' = 'earth.v' * 'earth.i';
    'earth.T_heatPort' = 300.15;
    0.0 = 'earth.p.i' + 'earth.n.i';
    'earth.i' = 'earth.p.i';
    'earth.v' = 'earth.p.v' - 'earth.n.v';
    'groundT.p.v' = 0.0;
    annotation(experiment(StopTime = 0.1, Interval = 1E-4, Tolerance = 1E-6));
  end 'AsymmetricalLoad';
end 'AsymmetricalLoad';
