    parameter Real 'load.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1.0 "Resistance at temperature T_ref";
    parameter Real 'load.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'load.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'load.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'load.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'load.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'load.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'load.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'load.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'load.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'earth.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1e6 "Resistance at temperature T_ref";
    parameter Real 'earth.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'earth.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'earth.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'earth.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'earth.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
