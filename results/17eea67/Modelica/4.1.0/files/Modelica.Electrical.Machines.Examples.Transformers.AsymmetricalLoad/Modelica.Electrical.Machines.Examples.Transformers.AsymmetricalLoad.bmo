    parameter Real 'transformerData.P_sc'(start = 300.0, unit = "W", quantity = "Power") = 300.0 "Short-circuit (copper) losses";
    parameter Real 'transformerData.n' = 1.0 "Ratio primary voltage (line-to-line) / secondary voltage (line-to-line)";
    parameter Real 'transformerData.V1ph'(unit = "V", quantity = "ElectricPotential") = 100.0 "Primary phase voltage (RMS)";
    parameter Real 'transformerData.I1ph'(unit = "A", quantity = "ElectricCurrent") = 100.0 "Primary phase current (RMS)";
    parameter Real 'transformerData.V2ph'(unit = "V", quantity = "ElectricPotential") = 57.73502691896258 "Secondary phase voltage (RMS)";
    parameter Real 'transformerData.I2ph'(unit = "A", quantity = "ElectricCurrent") = 173.2050807568877 "Secondary phase current (RMS)";
    parameter Real 'transformerData.Z1ph'(unit = "Ohm", quantity = "Resistance") = 0.025 "Primary impedance per phase";
    parameter Real 'transformerData.R1'(unit = "Ohm", quantity = "Resistance") = 0.005 "Warm primary resistance per phase";
    parameter Real 'transformerData.L1sigma'(unit = "H", quantity = "Inductance") = 7.796968012336763e-5 "Primary stray inductance per phase";
    parameter Real 'transformerData.Z2ph'(unit = "Ohm", quantity = "Resistance") = 0.008333333333333335 "Secondary impedance per phase";
    parameter Real 'transformerData.R2'(unit = "Ohm", quantity = "Resistance") = 0.0016666666666666672 "Warm secondary resistance per phase";
    parameter Real 'transformerData.L2sigma'(unit = "H", quantity = "Inductance") = 2.598989337445588e-5 "Secondary stray inductance per phase";
    parameter Integer 'transformer.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    constant String 'transformer.VectorGroup' = "Dy01";
    parameter Real 'transformer.n'(start = 1.0) = 1.0 "Ratio primary voltage (line-to-line) / secondary voltage (line-to-line)";
    parameter Real 'transformer.R1'(start = 0.005, unit = "Ohm", quantity = "Resistance") = 0.005 "Primary resistance per phase at TRef";
    parameter Real 'transformer.T1Ref'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of primary resistance";
    parameter Real 'transformer.alpha20_1'(start = 0.0, displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of primary resistance at 20 degC";
    parameter Real 'transformer.L1sigma'(start = 7.8e-5, unit = "H", quantity = "Inductance") = 7.796968012336763e-5 "Primary stray inductance per phase";
    parameter Real 'transformer.R2'(start = 0.0016666666666666668, unit = "Ohm", quantity = "Resistance") = 0.0016666666666666672 "Secondary resistance per phase at TRef";
    parameter Real 'transformer.T2Ref'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of secondary resistance";
    parameter Real 'transformer.alpha20_2'(start = 0.0, displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of secondary resistance at 20 degC";
    parameter Real 'transformer.L2sigma'(start = 2.6e-5, unit = "H", quantity = "Inductance") = 2.598989337445588e-5 "Secondary stray inductance per phase";
    parameter Boolean 'transformer.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Real 'transformer.T1Operational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of primary resistance";
    parameter Real 'transformer.T2Operational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of secondary resistance";
