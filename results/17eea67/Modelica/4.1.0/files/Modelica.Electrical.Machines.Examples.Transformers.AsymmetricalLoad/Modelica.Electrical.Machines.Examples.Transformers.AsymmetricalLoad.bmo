    Real 'transformer.i2[2]'(unit = "A", quantity = "ElectricCurrent") "Secondary current";
    Real 'transformer.i2[3]'(unit = "A", quantity = "ElectricCurrent") "Secondary current";
    constant String 'transformer.C1' = "D";
    constant String 'transformer.C2' = "y";
