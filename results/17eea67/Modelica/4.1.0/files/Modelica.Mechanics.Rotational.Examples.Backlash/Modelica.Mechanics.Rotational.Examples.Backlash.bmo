//! base 0.1.0
package 'Backlash'
  model 'Backlash' "Example to demonstrate backlash"
    parameter Real 'fixed1.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'fixed1.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'fixed1.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'springDamper.c'(start = 1e5, min = 0.0, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 2e4 "Spring constant";
    parameter Real 'springDamper.d'(start = 0.0, min = 0.0, unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 50.0 "Damping constant";
    parameter Real 'springDamper.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    Real 'springDamper.phi_rel'(stateSelect = StateSelect.prefer, nominal = 1.0, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'springDamper.w_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity (= der(phi_rel))";
    Real 'springDamper.a_rel'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration (= der(w_rel))";
    Real 'springDamper.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'springDamper.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'springDamper.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'springDamper.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'springDamper.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'springDamper.phi_nominal'(min = 0.0, displayUnit = "rad", unit = "rad", quantity = "Angle") = 1.0 "Nominal value of phi_rel (used for scaling)";
    parameter StateSelect 'springDamper.stateSelect' = StateSelect.prefer "Priority to use phi_rel and w_rel as states";
    parameter Boolean 'springDamper.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'springDamper.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'springDamper.tau_c'(unit = "N.m", quantity = "Torque") "Spring torque";
    Real 'springDamper.tau_d'(unit = "N.m", quantity = "Torque") "Damping torque";
    Real 'inertia1.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia1.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inertia1.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia1.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'inertia1.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 5.0 "Moment of inertia";
    parameter StateSelect 'inertia1.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'inertia1.phi'(stateSelect = StateSelect.default, fixed = true, start = 1.570796326794897, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'inertia1.w'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'inertia1.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'fixed2.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'fixed2.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'fixed2.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'elastoBacklash.c'(start = 1e5, min = 2.2250738585072014e-308, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 2e4 "Spring constant (c > 0 required)";
    parameter Real 'elastoBacklash.d'(start = 0.0, min = 0.0, unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 50.0 "Damping constant";
    parameter Real 'elastoBacklash.b'(min = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.7853981633974483 "Total backlash";
    parameter Real 'elastoBacklash.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    Real 'elastoBacklash.phi_rel'(stateSelect = StateSelect.prefer, nominal = 1.0, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'elastoBacklash.w_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity (= der(phi_rel))";
    Real 'elastoBacklash.a_rel'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration (= der(w_rel))";
    Real 'elastoBacklash.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'elastoBacklash.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'elastoBacklash.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'elastoBacklash.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'elastoBacklash.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'elastoBacklash.phi_nominal'(min = 0.0, displayUnit = "rad", unit = "rad", quantity = "Angle") = 1.0 "Nominal value of phi_rel (used for scaling)";
    parameter StateSelect 'elastoBacklash.stateSelect' = StateSelect.prefer "Priority to use phi_rel and w_rel as states";
    parameter Boolean 'elastoBacklash.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'elastoBacklash.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    parameter Real 'elastoBacklash.bMax'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.39269908169872414 "Backlash in range bMin <= phi_rel - phi_rel0 <= bMax";
    parameter Real 'elastoBacklash.bMin'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.39269908169872414 "Backlash in range bMin <= phi_rel - phi_rel0 <= bMax";
    Real 'elastoBacklash.tau_c'(unit = "N.m", quantity = "Torque");
    Real 'elastoBacklash.tau_d'(unit = "N.m", quantity = "Torque");
    Real 'elastoBacklash.phi_diff'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'elastoBacklash.bEps'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1e-10 "Minimum backlash";
    Real 'inertia2.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia2.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inertia2.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia2.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'inertia2.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 5.0 "Moment of inertia";
    parameter StateSelect 'inertia2.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'inertia2.phi'(stateSelect = StateSelect.default, fixed = true, start = 1.570796326794897, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'inertia2.w'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'inertia2.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'fixed3.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'fixed3.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'fixed3.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'elastoBacklash2.c'(start = 1e5, min = 2.2250738585072014e-308, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 2e4 "Spring constant (c > 0 required)";
    parameter Real 'elastoBacklash2.d'(start = 0.0, min = 0.0, unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 50.0 "Damping constant";
    parameter Real 'elastoBacklash2.b'(min = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.78539816339745 "Total backlash";
    parameter Real 'elastoBacklash2.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    Real 'elastoBacklash2.phi_rel'(stateSelect = StateSelect.prefer, nominal = 1.0, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'elastoBacklash2.w_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity (= der(phi_rel))";
    Real 'elastoBacklash2.a_rel'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration (= der(w_rel))";
    Real 'elastoBacklash2.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'elastoBacklash2.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'elastoBacklash2.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'elastoBacklash2.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'elastoBacklash2.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'elastoBacklash2.phi_nominal'(min = 0.0, displayUnit = "rad", unit = "rad", quantity = "Angle") = 1.0 "Nominal value of phi_rel (used for scaling)";
    parameter StateSelect 'elastoBacklash2.stateSelect' = StateSelect.prefer "Priority to use phi_rel and w_rel as states";
    parameter Boolean 'elastoBacklash2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'elastoBacklash2.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    parameter Real 'elastoBacklash2.bMax'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.392699081698725 "Backlash in range bMin <= phi_rel - phi_rel0 <= bMax";
    parameter Real 'elastoBacklash2.bMin'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.392699081698725 "Backlash in range bMin <= phi_rel - phi_rel0 <= bMax";
    Real 'elastoBacklash2.tau_c'(unit = "N.m", quantity = "Torque");
    Real 'elastoBacklash2.tau_d'(unit = "N.m", quantity = "Torque");
    Real 'elastoBacklash2.phi_diff'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'elastoBacklash2.bEps'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1e-10 "Minimum backlash";
    Real 'inertia3.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia3.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inertia3.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia3.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'inertia3.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 5.0 "Moment of inertia";
    parameter StateSelect 'inertia3.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'inertia3.phi'(stateSelect = StateSelect.default, fixed = true, start = 1.570796326794897, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'inertia3.w'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'inertia3.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
  equation
    'elastoBacklash.phi_diff' = 'elastoBacklash.phi_rel';
    'elastoBacklash2.phi_diff' = 'elastoBacklash2.phi_rel';
    'springDamper.flange_b.phi' = 'inertia1.flange_a.phi';
    'elastoBacklash.flange_b.phi' = 'inertia2.flange_a.phi';
    'fixed1.flange.phi' = 'springDamper.flange_a.phi';
    'fixed2.flange.phi' = 'elastoBacklash.flange_a.phi';
    'elastoBacklash2.flange_b.phi' = 'inertia3.flange_a.phi';
    'fixed3.flange.phi' = 'elastoBacklash2.flange_a.phi';
    'springDamper.flange_a.tau' + 'fixed1.flange.tau' = 0.0;
    'inertia1.flange_a.tau' + 'springDamper.flange_b.tau' = 0.0;
    'inertia1.flange_b.tau' = 0.0;
    'elastoBacklash.flange_a.tau' + 'fixed2.flange.tau' = 0.0;
    'inertia2.flange_a.tau' + 'elastoBacklash.flange_b.tau' = 0.0;
    'inertia2.flange_b.tau' = 0.0;
    'elastoBacklash2.flange_a.tau' + 'fixed3.flange.tau' = 0.0;
    'inertia3.flange_a.tau' + 'elastoBacklash2.flange_b.tau' = 0.0;
    'inertia3.flange_b.tau' = 0.0;
    'fixed1.flange.phi' = 0.0;
    'springDamper.tau_c' = 2e4 * 'springDamper.phi_rel';
    'springDamper.tau_d' = 50.0 * 'springDamper.w_rel';
    'springDamper.tau' = 'springDamper.tau_c' + 'springDamper.tau_d';
    'springDamper.lossPower' = 'springDamper.tau_d' * 'springDamper.w_rel';
    'springDamper.phi_rel' = 'springDamper.flange_b.phi' - 'springDamper.flange_a.phi';
    'springDamper.w_rel' = der('springDamper.phi_rel');
    'springDamper.a_rel' = der('springDamper.w_rel');
    'springDamper.flange_b.tau' = 'springDamper.tau';
    'springDamper.flange_a.tau' = -'springDamper.tau';
    'inertia1.phi' = 'inertia1.flange_a.phi';
    'inertia1.phi' = 'inertia1.flange_b.phi';
    'inertia1.w' = der('inertia1.phi');
    'inertia1.a' = der('inertia1.w');
    5.0 * 'inertia1.a' = 'inertia1.flange_a.tau' + 'inertia1.flange_b.tau';
    'fixed2.flange.phi' = 0.0;

    if initial() then
      'elastoBacklash.tau_c' = if 'elastoBacklash.phi_diff' > 0.5890486225480862 then 2e4 * ('elastoBacklash.phi_diff' - 0.39269908169872414) else if 'elastoBacklash.phi_diff' < (-0.5890486225480862) then 2e4 * ('elastoBacklash.phi_diff' + 0.39269908169872414) else 6666.666666666667 * 'elastoBacklash.phi_diff';
      'elastoBacklash.tau_d' = 50.0 * 'elastoBacklash.w_rel';
      'elastoBacklash.tau' = 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d';
      'elastoBacklash.lossPower' = 'elastoBacklash.tau_d' * 'elastoBacklash.w_rel';
    elseif true then
      'elastoBacklash.tau_c' = if 'elastoBacklash.phi_diff' > 0.39269908169872414 then 2e4 * ('elastoBacklash.phi_diff' - 0.39269908169872414) else if 'elastoBacklash.phi_diff' < (-0.39269908169872414) then 2e4 * ('elastoBacklash.phi_diff' + 0.39269908169872414) else 0.0;
      'elastoBacklash.tau_d' = 50.0 * 'elastoBacklash.w_rel';
      'elastoBacklash.tau' = if 'elastoBacklash.phi_diff' > 0.39269908169872414 then smooth(0, noEvent(if 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d' <= 0.0 then 0.0 else 'elastoBacklash.tau_c' + min('elastoBacklash.tau_c', 'elastoBacklash.tau_d'))) else if 'elastoBacklash.phi_diff' < (-0.39269908169872414) then smooth(0, noEvent(if 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d' >= 0.0 then 0.0 else 'elastoBacklash.tau_c' + max('elastoBacklash.tau_c', 'elastoBacklash.tau_d'))) else 0.0;
      'elastoBacklash.lossPower' = if 'elastoBacklash.phi_diff' > 0.39269908169872414 then smooth(0, noEvent(if 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d' <= 0.0 then 0.0 else min('elastoBacklash.tau_c', 'elastoBacklash.tau_d') * 'elastoBacklash.w_rel')) else if 'elastoBacklash.phi_diff' < (-0.39269908169872414) then smooth(0, noEvent(if 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d' >= 0.0 then 0.0 else max('elastoBacklash.tau_c', 'elastoBacklash.tau_d') * 'elastoBacklash.w_rel')) else 0.0;
    end if;

    'elastoBacklash.phi_rel' = 'elastoBacklash.flange_b.phi' - 'elastoBacklash.flange_a.phi';
    'elastoBacklash.w_rel' = der('elastoBacklash.phi_rel');
    'elastoBacklash.a_rel' = der('elastoBacklash.w_rel');
    'elastoBacklash.flange_b.tau' = 'elastoBacklash.tau';
    'elastoBacklash.flange_a.tau' = -'elastoBacklash.tau';
    'inertia2.phi' = 'inertia2.flange_a.phi';
    'inertia2.phi' = 'inertia2.flange_b.phi';
    'inertia2.w' = der('inertia2.phi');
    'inertia2.a' = der('inertia2.w');
    5.0 * 'inertia2.a' = 'inertia2.flange_a.tau' + 'inertia2.flange_b.tau';
    'fixed3.flange.phi' = 0.0;

    if initial() then
      'elastoBacklash2.tau_c' = if 'elastoBacklash2.phi_diff' > 0.5890486225480875 then 2e4 * ('elastoBacklash2.phi_diff' - 0.392699081698725) else if 'elastoBacklash2.phi_diff' < (-0.5890486225480875) then 2e4 * ('elastoBacklash2.phi_diff' + 0.392699081698725) else 6666.666666666667 * 'elastoBacklash2.phi_diff';
      'elastoBacklash2.tau_d' = 50.0 * 'elastoBacklash2.w_rel';
      'elastoBacklash2.tau' = 'elastoBacklash2.tau_c' + 'elastoBacklash2.tau_d';
      'elastoBacklash2.lossPower' = 'elastoBacklash2.tau_d' * 'elastoBacklash2.w_rel';
    elseif true then
      'elastoBacklash2.tau_c' = if 'elastoBacklash2.phi_diff' > 0.392699081698725 then 2e4 * ('elastoBacklash2.phi_diff' - 0.392699081698725) else if 'elastoBacklash2.phi_diff' < (-0.392699081698725) then 2e4 * ('elastoBacklash2.phi_diff' + 0.392699081698725) else 0.0;
      'elastoBacklash2.tau_d' = 50.0 * 'elastoBacklash2.w_rel';
      'elastoBacklash2.tau' = if 'elastoBacklash2.phi_diff' > 0.392699081698725 then if 'elastoBacklash2.tau_c' + 'elastoBacklash2.tau_d' <= 0.0 then 0.0 else 'elastoBacklash2.tau_c' + 'elastoBacklash2.tau_d' else if 'elastoBacklash2.phi_diff' < (-0.392699081698725) then if 'elastoBacklash2.tau_c' + 'elastoBacklash2.tau_d' >= 0.0 then 0.0 else 'elastoBacklash2.tau_c' + 'elastoBacklash2.tau_d' else 0.0;
      'elastoBacklash2.lossPower' = if 'elastoBacklash2.phi_diff' > 0.392699081698725 then if 'elastoBacklash2.tau_c' + 'elastoBacklash2.tau_d' <= 0.0 then 0.0 else 'elastoBacklash2.tau_d' * 'elastoBacklash2.w_rel' else if 'elastoBacklash2.phi_diff' < (-0.392699081698725) then if 'elastoBacklash2.tau_c' + 'elastoBacklash2.tau_d' >= 0.0 then 0.0 else 'elastoBacklash2.tau_d' * 'elastoBacklash2.w_rel' else 0.0;
    end if;

    'elastoBacklash2.phi_rel' = 'elastoBacklash2.flange_b.phi' - 'elastoBacklash2.flange_a.phi';
    'elastoBacklash2.w_rel' = der('elastoBacklash2.phi_rel');
    'elastoBacklash2.a_rel' = der('elastoBacklash2.w_rel');
    'elastoBacklash2.flange_b.tau' = 'elastoBacklash2.tau';
    'elastoBacklash2.flange_a.tau' = -'elastoBacklash2.tau';
    'inertia3.phi' = 'inertia3.flange_a.phi';
    'inertia3.phi' = 'inertia3.flange_b.phi';
    'inertia3.w' = der('inertia3.phi');
    'inertia3.a' = der('inertia3.w');
    5.0 * 'inertia3.a' = 'inertia3.flange_a.tau' + 'inertia3.flange_b.tau';
    annotation(experiment(StopTime = 1.0, Interval = 0.001));
  end 'Backlash';
end 'Backlash';
