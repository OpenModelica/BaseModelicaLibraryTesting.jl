//! base 0.1.0
package 'HoldWithDAeffects2'
  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  type 'Modelica.Clocked.Types.Resolution' = enumeration('y', 'd', 'h', 'm', 's', 'ms', 'us', 'ns');

  model 'HoldWithDAeffects2' "Example of a HoldWithDAeffects block for Real signals (with a computational delay of one sample period)"
    parameter Real 'sine.amplitude' = 2.0 "Amplitude of sine wave";
    parameter Real 'sine.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of sine wave";
    parameter Real 'sine.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine.y' "Connector of Real output signal";
    parameter Real 'sine.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    Real 'sample1.u' "Connector of continuous-time, Real input signal";
    Real 'sample1.y' "Connector of clocked, Real output signal";
    Clock 'sample1.clock' "Output signal y is associated with this clock input";
    parameter Integer 'periodicClock.factor'(min = 0) = 20 "Sample factor with respect to resolution" annotation(Evaluate = true);
    parameter 'Modelica.Clocked.Types.Resolution' 'periodicClock.resolution' = 'Modelica.Clocked.Types.Resolution'.'ms' "Clock resolution" annotation(Evaluate = true);
    parameter Boolean 'periodicClock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'periodicClock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'periodicClock.y';
    constant Integer 'periodicClock.conversionTable[1]' = 31536000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[2]' = 86400 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[3]' = 3600 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[4]' = 60 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[5]' = 1 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[6]' = 1000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[7]' = 1000000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[8]' = 1000000000 "Table to convert from Resolution to Integer clock resolution";
    parameter Integer 'periodicClock.resolutionFactor' = 1000 annotation(Evaluate = true);
    Clock 'periodicClock.c';
    parameter Real 'hold1.y_start' = 0.5 "Value of output y before the first tick of the clock associated to input u";
    Real 'hold1.u'(start = 0.5) "Connector of clocked, Real input signal";
    Real 'hold1.y' "Connector of continuous-time, Real output signal";
    parameter Boolean 'hold1.computationalDelay' = true "=true, if a computational delay should be imposed" annotation(Evaluate = true);
    parameter Integer 'hold1.shiftCounter'(max = 1, min = 0) = 1 "(min=0, max=resolution), computational delay = interval()*shiftCounter/resolution";
    parameter Integer 'hold1.resolution'(min = 1) = 1 "Time quantization resolution of sample interval";
    parameter Boolean 'hold1.limited' = true "= true, if output is limited" annotation(Evaluate = true);
    parameter Boolean 'hold1.quantized' = false "= true, if output quantization effects included" annotation(Evaluate = true);
    parameter Real 'hold1.yMax' = 1.9 "Upper limit of output (if limited = true)";
    parameter Real 'hold1.yMin' = -1.9 "Lower limit of output (if limited = true)";
    parameter Integer 'hold1.bits'(min = 1) = 8 "Number of bits of quantization (if quantized = true)";
    Real 'hold1.limiter.u' "Connector of clocked, Real input signal";
    Real 'hold1.limiter.y' "Connector of clocked, Real output signal";
    parameter Real 'hold1.limiter.uMax'(start = 1.0) = 1.9 "Upper limits of input signals";
    parameter Real 'hold1.limiter.uMin' = -1.9 "Lower limits of input signals";
    Real 'hold1.compDelay.u' "Connector of clocked, Real input signal";
    Real 'hold1.compDelay.y' "Connector of clocked, Real output signal";
    parameter Integer 'hold1.compDelay.shiftCounter'(max = 1, min = 0) = 1 "(min=0, max=resolution), computational delay = interval()*shiftCounter/resolution" annotation(Evaluate = true);
    parameter Integer 'hold1.compDelay.resolution'(min = 1) = 1 "Time quantization resolution of sample interval" annotation(Evaluate = true);
    Real 'hold1.compDelay.ubuf'(start = 0.0);
    parameter Real 'hold1.hold1.y_start' = 0.5 "Value of output y before the first tick of the clock associated to input u";
    Real 'hold1.hold1.u'(start = 0.5) "Connector of clocked, Real input signal";
    Real 'hold1.hold1.y' "Connector of continuous-time, Real output signal";
    Real 'hold1.uFeedthrough3';
    Real 'hold1.y2';
    Real 'hold1.y3';
    Real 'hold1.y4';
    Real 'hold1.y5';
    parameter Integer 'shiftSample1.shiftCounter'(min = 0) = 2 "Numerator of shifting formula" annotation(Evaluate = true);
    parameter Integer 'shiftSample1.resolution'(min = 1) = 1 "Denominator of shifting formula" annotation(Evaluate = true);
    Real 'shiftSample1.u' "Connector of clocked, Real input signal";
    Real 'shiftSample1.y' "Connector of clocked, Real output signal";
  equation
    'hold1.u' = 'hold1.y2';
    'hold1.u' = 'hold1.limiter.u';
    'hold1.uFeedthrough3' = 'hold1.y4';
    'hold1.uFeedthrough3' = 'hold1.compDelay.u';
    'hold1.uFeedthrough3' = 'hold1.y3';
    'hold1.uFeedthrough3' = 'hold1.limiter.y';
    'hold1.y5' = 'hold1.hold1.u';
    'hold1.y5' = 'hold1.compDelay.y';
    'hold1.hold1.y' = 'hold1.y';
    'sine.y' = 'sample1.u';
    'periodicClock.y' = 'sample1.clock';
    'sample1.y' = 'shiftSample1.u';
    'shiftSample1.y' = 'hold1.u';
    'sine.y' = if time < 0.0 then 0.0 else 2.0 * 'Modelica.Math.sin'(12.566370614359172 * time);
    'sample1.y' = sample('sample1.u', 'sample1.clock');
    'periodicClock.c' = Clock('periodicClock.factor', 1000);
    'periodicClock.y' = 'periodicClock.c';
    'hold1.limiter.y' = if 'hold1.limiter.u' > 1.9 then 1.9 else if 'hold1.limiter.u' < (-1.9) then -1.9 else 'hold1.limiter.u';
    'hold1.compDelay.ubuf' = 'hold1.compDelay.u';
    'hold1.compDelay.y' = shiftSample(previous('hold1.compDelay.ubuf'), 1, 1);
    'hold1.hold1.y' = hold('hold1.hold1.u');
    'shiftSample1.y' = shiftSample('shiftSample1.u', 2, 1);
    annotation(experiment(StopTime = 0.2));
  end 'HoldWithDAeffects2';
end 'HoldWithDAeffects2';
