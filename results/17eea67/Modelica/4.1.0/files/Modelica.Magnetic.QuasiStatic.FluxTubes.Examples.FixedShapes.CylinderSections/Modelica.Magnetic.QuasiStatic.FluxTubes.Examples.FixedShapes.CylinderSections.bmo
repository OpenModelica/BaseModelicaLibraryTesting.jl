    Real 'hollowCylinderRadiaLRight.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'hollowCylinderRadiaLRight.abs_V_m'(unit = "A", quantity = "MagneticPotential") "Magnitude of complex magnetic potential difference";
    Real 'hollowCylinderRadiaLRight.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic potential difference";
    Real 'hollowCylinderRadiaLRight.Phi.re'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'hollowCylinderRadiaLRight.Phi.im'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'hollowCylinderRadiaLRight.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnitude of complex magnetic flux";
    Real 'hollowCylinderRadiaLRight.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux";
    Real 'hollowCylinderRadiaLRight.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'hollowCylinderRadiaLRight.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 100.0 "Constant relative permeability";
    Real 'hollowCylinderRadiaLRight.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'hollowCylinderRadiaLRight.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'hollowCylinderRadiaLRight.B.re'(unit = "T", quantity = "MagneticFluxDensity") "Real part of complex number";
    Real 'hollowCylinderRadiaLRight.B.im'(unit = "T", quantity = "MagneticFluxDensity") "Imaginary part of complex number";
    Real 'hollowCylinderRadiaLRight.abs_B'(unit = "T", quantity = "MagneticFluxDensity") "Magnitude of complex magnetic flux density";
    Real 'hollowCylinderRadiaLRight.arg_B'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux density";
    Real 'hollowCylinderRadiaLRight.A'(unit = "m2", quantity = "Area") "Area of cross section penetrated by magnetic flux";
    Real 'hollowCylinderRadiaLRight.H.re'(unit = "A/m", quantity = "MagneticFieldStrength") "Real part of complex number";
    Real 'hollowCylinderRadiaLRight.H.im'(unit = "A/m", quantity = "MagneticFieldStrength") "Imaginary part of complex number";
    Real 'hollowCylinderRadiaLRight.abs_H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnitude of complex magnetic field strength";
    Real 'hollowCylinderRadiaLRight.arg_H'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic field strength";
    Real 'hollowCylinderRadiaLRight.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    parameter Real 'hollowCylinderRadiaLRight.l'(unit = "m", quantity = "Length") = 0.02 "Width (orthogonal to flux direction)";
    parameter Real 'hollowCylinderRadiaLRight.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.015 "Inner radius of hollow cylinder";
    parameter Real 'hollowCylinderRadiaLRight.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.055 "Outer radius of hollow cylinder";
    parameter Real 'hollowCylinderRadiaLRight.alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 6.283185307179586 "Central angle";
