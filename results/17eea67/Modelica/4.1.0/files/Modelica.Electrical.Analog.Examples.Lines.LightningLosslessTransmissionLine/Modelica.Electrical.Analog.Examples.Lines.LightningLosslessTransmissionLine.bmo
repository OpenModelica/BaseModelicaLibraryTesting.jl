//! base 0.1.0
package 'LightningLosslessTransmissionLine'
  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  type 'Modelica.Electrical.Analog.Types.ImpulseApproximation' = enumeration('DoubleExp', 'Heidler');

  model 'LightningLosslessTransmissionLine' "Lightning on a lossless transmission line"
    parameter Real 'Rload'(unit = "Ohm", quantity = "Resistance") = 200.0 "Load resistance";
    parameter Real 'r'(min = 2.2250738585072014e-308, unit = "Ohm/m") = 2.5e-5 "Resistance per meter";
    parameter Real 'g'(min = 2.2250738585072014e-308, unit = "S/m") = 1.5e-11 "Conductance per meter";
    parameter Real 'l'(min = 2.2250738585072014e-308, unit = "H/m") = 1e-6 "Inductance per meter";
    parameter Real 'c'(min = 2.2250738585072014e-308, unit = "F/m") = 1.5e-11 "Capacitance per meter";
    parameter Real 'len'(unit = "m", quantity = "Length") = 1e5 "Length of line";
    parameter Real 'c0'(unit = "m/s", quantity = "Velocity") = 2.581988897471611e8 "Speed of EM wave";
    parameter Real 'td'(unit = "s", quantity = "Time") = 3.8729833462074176e-4 "Transmission delay";
    parameter Real 'z0'(unit = "Ohm", quantity = "Resistance") = 258.1988897471611 "Characteristic impedance for very high frequency";
    Real 'line1.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'line1.v2'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'line1.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'line1.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'line1.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'line1.Z0'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 258.1988897471611 "Characteristic impedance";
    parameter Real 'line1.TD'(unit = "s", quantity = "Time") = 1.9364916731037088e-4 "Transmission delay: specify > 0 if F and NL are not given";
    parameter Real 'line1.F'(unit = "Hz", quantity = "Frequency") = 0.0 "Frequency: specify > 0 if TD is not given";
    parameter Real 'line1.NL' = 0.25 "Normalized length: specify if TD is not given";
    Real 'line1.es'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of forward travelling wave";
    Real 'line1.er'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of reflected wave";
    parameter Real 'line1.TDi'(unit = "s", quantity = "Time") = 1.9364916731037088e-4 "Internally used transmission delay";
    Real 'line2.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'line2.v2'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'line2.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'line2.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'line2.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line2.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line2.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line2.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line2.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line2.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line2.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line2.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'line2.Z0'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 258.1988897471611 "Characteristic impedance";
    parameter Real 'line2.TD'(unit = "s", quantity = "Time") = 1.9364916731037088e-4 "Transmission delay: specify > 0 if F and NL are not given";
    parameter Real 'line2.F'(unit = "Hz", quantity = "Frequency") = 0.0 "Frequency: specify > 0 if TD is not given";
    parameter Real 'line2.NL' = 0.25 "Normalized length: specify if TD is not given";
    Real 'line2.es'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of forward travelling wave";
    Real 'line2.er'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of reflected wave";
    parameter Real 'line2.TDi'(unit = "s", quantity = "Time") = 1.9364916731037088e-4 "Internally used transmission delay";
    parameter Real 'source.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 310268.7007525359 "Amplitude of sine wave";
    parameter Real 'source.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Real 'source.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    Real 'source.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'source.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'source.signalSource.amplitude' = 310268.7007525359 "Amplitude of sine wave";
    parameter Real 'source.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'source.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'source.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'source.signalSource.y' "Connector of Real output signal";
    parameter Real 'source.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'source.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'source.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'source.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'load.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 200.0 "Resistance at temperature T_ref";
    parameter Real 'load.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'load.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'load.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'load.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'load.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'load.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'load.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'load.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'load.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter 'Modelica.Electrical.Analog.Types.ImpulseApproximation' 'lightningImpulseCurrent.approximation' = 'Modelica.Electrical.Analog.Types.ImpulseApproximation'.'Heidler' "Approximation of impulse";
    parameter Real 'lightningImpulseCurrent.I'(unit = "A", quantity = "ElectricCurrent") = 1e4 "Amplitude";
    parameter Real 'lightningImpulseCurrent.T1'(unit = "s", quantity = "Time") = 1e-5 "Rise time";
    parameter Real 'lightningImpulseCurrent.T2'(unit = "s", quantity = "Time") = 3.5e-4 "Decay time to half value";
    parameter Integer 'lightningImpulseCurrent.m'(min = 2) = 5 "Integer exponent of Heidler-function 5..10";
    Real 'lightningImpulseCurrent.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'lightningImpulseCurrent.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'lightningImpulseCurrent.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'lightningImpulseCurrent.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'lightningImpulseCurrent.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'lightningImpulseCurrent.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter 'Modelica.Electrical.Analog.Types.ImpulseApproximation' 'lightningImpulseCurrent.signalSource.approximation' = 'Modelica.Electrical.Analog.Types.ImpulseApproximation'.'Heidler' "Approximation of impulse";
    parameter Real 'lightningImpulseCurrent.signalSource.amplitude' = 1e4 "Amplitude";
    parameter Real 'lightningImpulseCurrent.signalSource.T1'(unit = "s", quantity = "Time") = 1e-5 "Rise time";
    parameter Real 'lightningImpulseCurrent.signalSource.T2'(unit = "s", quantity = "Time") = 3.5e-4 "Decay time to half value";
    Real 'lightningImpulseCurrent.signalSource.y' "Connector of Real output signal";
    parameter Real 'lightningImpulseCurrent.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'lightningImpulseCurrent.signalSource.startTime'(unit = "s", quantity = "Time") = 0.02 "Output y = offset for time < startTime";
    parameter Integer 'lightningImpulseCurrent.signalSource.m'(min = 2) = 5 "Integer exponent of Heidler-function 5..10";
    parameter Real 'lightningImpulseCurrent.signalSource.eta'(fixed = false, start = 1.0, min = 2.2250738585072014e-308) "Amplitude parameter";
    parameter Real 'lightningImpulseCurrent.signalSource.T0'(unit = "s", quantity = "Time") = 2.3650464499470163e-5 "Initial value of time parameter";
    parameter Real 'lightningImpulseCurrent.signalSource.T'(fixed = false, start = 2.3650464499470163e-5, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time when maximum occurs";
    parameter Real 'lightningImpulseCurrent.signalSource.T10'(fixed = false, start = 2.3650464499470163e-6, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time to 10%";
    parameter Real 'lightningImpulseCurrent.signalSource.tau1'(fixed = false, start = 1e-5, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time constant 1";
    parameter Real 'lightningImpulseCurrent.signalSource.tau2'(fixed = false, start = 3.5e-4, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time constant 2";
    parameter Real 'lightningImpulseCurrent.offset'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Current offset";
    parameter Real 'lightningImpulseCurrent.startTime'(unit = "s", quantity = "Time") = 0.02 "Time offset";
  initial equation
    'lightningImpulseCurrent.signalSource.tau2' / 'lightningImpulseCurrent.signalSource.T' * 5.0 = 1.0 + ('lightningImpulseCurrent.signalSource.T' / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0;
    'lightningImpulseCurrent.signalSource.eta' = ('lightningImpulseCurrent.signalSource.T' / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0 / (1.0 + ('lightningImpulseCurrent.signalSource.T' / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0) * exp(-'lightningImpulseCurrent.signalSource.T' / 'lightningImpulseCurrent.signalSource.tau2');
    0.1 * 'lightningImpulseCurrent.signalSource.eta' = ('lightningImpulseCurrent.signalSource.T10' / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0 / (1.0 + ('lightningImpulseCurrent.signalSource.T10' / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0) * exp(-'lightningImpulseCurrent.signalSource.T10' / 'lightningImpulseCurrent.signalSource.tau2');
    0.9 * 'lightningImpulseCurrent.signalSource.eta' = (('lightningImpulseCurrent.signalSource.T10' + 8.000000000000001e-6) / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0 / (1.0 + (('lightningImpulseCurrent.signalSource.T10' + 8.000000000000001e-6) / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0) * exp(-('lightningImpulseCurrent.signalSource.T10' + 8.000000000000001e-6) / 'lightningImpulseCurrent.signalSource.tau2');
    0.5 * 'lightningImpulseCurrent.signalSource.eta' = (('lightningImpulseCurrent.signalSource.T10' - 1.0000000000000002e-6 + 3.5e-4) / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0 / (1.0 + (('lightningImpulseCurrent.signalSource.T10' - 1.0000000000000002e-6 + 3.5e-4) / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0) * exp(-('lightningImpulseCurrent.signalSource.T10' - 1.0000000000000002e-6 + 3.5e-4) / 'lightningImpulseCurrent.signalSource.tau2');
  equation
    'line1.p1.v' = 'source.p.v';
    'line2.p2.v' = 'load.p.v';
    'ground.p.v' = 'lightningImpulseCurrent.p.v';
    'ground.p.v' = 'line2.n1.v';
    'ground.p.v' = 'line1.n2.v';
    'ground.p.v' = 'line2.n2.v';
    'ground.p.v' = 'load.n.v';
    'ground.p.v' = 'source.n.v';
    'ground.p.v' = 'line1.n1.v';
    'lightningImpulseCurrent.n.v' = 'line2.p1.v';
    'lightningImpulseCurrent.n.v' = 'line1.p2.v';
    'source.p.i' + 'line1.p1.i' = 0.0;
    'lightningImpulseCurrent.n.i' + 'line2.p1.i' + 'line1.p2.i' = 0.0;
    'load.p.i' + 'line2.p2.i' = 0.0;
    'lightningImpulseCurrent.p.i' + 'ground.p.i' + 'load.n.i' + 'source.n.i' + 'line2.n2.i' + 'line2.n1.i' + 'line1.n2.i' + 'line1.n1.i' = 0.0;
    'line1.i1' = ('line1.v1' - 'line1.es') / 258.1988897471611;
    'line1.i2' = ('line1.v2' - 'line1.er') / 258.1988897471611;
    'line1.es' = 2.0 * delay('line1.v2', 1.9364916731037088e-4, 1.9364916731037088e-4) - delay('line1.er', 1.9364916731037088e-4, 1.9364916731037088e-4);
    'line1.er' = 2.0 * delay('line1.v1', 1.9364916731037088e-4, 1.9364916731037088e-4) - delay('line1.es', 1.9364916731037088e-4, 1.9364916731037088e-4);
    0.0 = 'line1.p1.i' + 'line1.n1.i';
    0.0 = 'line1.p2.i' + 'line1.n2.i';
    'line1.v1' = 'line1.p1.v' - 'line1.n1.v';
    'line1.v2' = 'line1.p2.v' - 'line1.n2.v';
    'line1.i1' = 'line1.p1.i';
    'line1.i2' = 'line1.p2.i';
    'line2.i1' = ('line2.v1' - 'line2.es') / 258.1988897471611;
    'line2.i2' = ('line2.v2' - 'line2.er') / 258.1988897471611;
    'line2.es' = 2.0 * delay('line2.v2', 1.9364916731037088e-4, 1.9364916731037088e-4) - delay('line2.er', 1.9364916731037088e-4, 1.9364916731037088e-4);
    'line2.er' = 2.0 * delay('line2.v1', 1.9364916731037088e-4, 1.9364916731037088e-4) - delay('line2.es', 1.9364916731037088e-4, 1.9364916731037088e-4);
    0.0 = 'line2.p1.i' + 'line2.n1.i';
    0.0 = 'line2.p2.i' + 'line2.n2.i';
    'line2.v1' = 'line2.p1.v' - 'line2.n1.v';
    'line2.v2' = 'line2.p2.v' - 'line2.n2.v';
    'line2.i1' = 'line2.p1.i';
    'line2.i2' = 'line2.p2.i';
    'source.signalSource.y' = if time < 0.0 then 0.0 else 310268.7007525359 * 'Modelica.Math.sin'(314.1592653589793 * time);
    'source.v' = 'source.signalSource.y';
    0.0 = 'source.p.i' + 'source.n.i';
    'source.i' = 'source.p.i';
    'source.v' = 'source.p.v' - 'source.n.v';
    'load.R_actual' = 200.0;
    'load.v' = 'load.R_actual' * 'load.i';
    'load.LossPower' = 'load.v' * 'load.i';
    'load.T_heatPort' = 300.15;
    0.0 = 'load.p.i' + 'load.n.i';
    'load.i' = 'load.p.i';
    'load.v' = 'load.p.v' - 'load.n.v';
    'ground.p.v' = 0.0;

    if time < 0.02 then
      'lightningImpulseCurrent.signalSource.y' = 0.0;
    elseif true then
      'lightningImpulseCurrent.signalSource.y' = 1e4 / 'lightningImpulseCurrent.signalSource.eta' * ((time - 0.02) / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0 / (1.0 + ((time - 0.02) / 'lightningImpulseCurrent.signalSource.tau1') ^ 5.0) * exp(-(time - 0.02) / 'lightningImpulseCurrent.signalSource.tau2');
    end if;

    'lightningImpulseCurrent.i' = 'lightningImpulseCurrent.signalSource.y';
    0.0 = 'lightningImpulseCurrent.p.i' + 'lightningImpulseCurrent.n.i';
    'lightningImpulseCurrent.i' = 'lightningImpulseCurrent.p.i';
    'lightningImpulseCurrent.v' = 'lightningImpulseCurrent.p.v' - 'lightningImpulseCurrent.n.v';
    annotation(experiment(StopTime = 0.025, Interval = 1e-06, Tolerance = 1e-06));
  end 'LightningLosslessTransmissionLine';
end 'LightningLosslessTransmissionLine';
