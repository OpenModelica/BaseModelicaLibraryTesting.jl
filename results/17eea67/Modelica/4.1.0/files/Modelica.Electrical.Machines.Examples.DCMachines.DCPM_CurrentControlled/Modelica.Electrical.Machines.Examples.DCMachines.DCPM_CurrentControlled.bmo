    'dcpm.airGapDC.w' = der('dcpm.airGapDC.flange.phi') - der('dcpm.airGapDC.support.phi');
    'dcpm.airGapDC.vai' = 0.6366197723675815 * 'dcpm.airGapDC.psi_e' * 'dcpm.airGapDC.w';
    'dcpm.airGapDC.tauElectrical' = 0.6366197723675815 * 'dcpm.airGapDC.psi_e' * 'dcpm.airGapDC.ia';
    'dcpm.airGapDC.flange.tau' = -'dcpm.airGapDC.tauElectrical';
    'dcpm.airGapDC.support.tau' = 'dcpm.airGapDC.tauElectrical';
    'dcpm.eGround.p.v' = 0.0;
    'dcpm.ie.i' = 1.0;
    0.0 = 'dcpm.ie.p.i' + 'dcpm.ie.n.i';
    'dcpm.ie.i' = 'dcpm.ie.p.i';
    'dcpm.ie.v' = 'dcpm.ie.p.v' - 'dcpm.ie.n.v';
    'step.y' = if time < 0.1 then 0.0 else 100.0;
    'signalVoltage.v' = 'signalVoltage.p.v' - 'signalVoltage.n.v';
    0.0 = 'signalVoltage.p.i' + 'signalVoltage.n.i';
    'signalVoltage.i' = 'signalVoltage.p.i';
    'ground.p.v' = 0.0;
    'loadInertia.phi' = 'loadInertia.flange_a.phi';
    'loadInertia.phi' = 'loadInertia.flange_b.phi';
    'loadInertia.w' = der('loadInertia.phi');
    'loadInertia.a' = der('loadInertia.w');
    0.15 * 'loadInertia.a' = 'loadInertia.flange_a.tau' + 'loadInertia.flange_b.tau';
    'loadTorque.w' = der('loadTorque.phi');
    'loadTorque.tau' = -'loadTorque.flange.tau';
    'loadTorque.tau' = (-63.66197723675815) * smooth(1, if 'loadTorque.w' >= 0.0 then ('loadTorque.w' / 149.22565104551515) ^ 2.0 else -('loadTorque.w' / 149.22565104551515) ^ 2.0);
    'loadTorque.phi' = 'loadTorque.flange.phi' - 'loadTorque.phi_support';
    'loadTorque.phi_support' = 0.0;
    'currentSensor.p.v' = 'currentSensor.n.v';
    'currentSensor.p.i' = 'currentSensor.i';
    'currentSensor.n.i' = -'currentSensor.i';
    'speedSensor.w' = der('speedSensor.flange.phi');
    0.0 = 'speedSensor.flange.tau';
    der('firstOrder.y') = ('firstOrder.u' - 'firstOrder.y') / 0.001;
    'PID.addP.y' = 'PID.addP.u1' + (-1.0) * 'PID.addP.u2';
    'PID.P.y' = 'PID.P.u';
    'PID.I.local_reset' = false;
    'PID.I.local_set' = 0.0;
    der('PID.I.y') = 33.333333333333336 * 'PID.I.u';
    'PID.gainPID.y' = 0.75 * 'PID.gainPID.u';
    'PID.addPID.y' = 'PID.addPID.u1' + 'PID.addPID.u2' + 'PID.addPID.u3';
    'PID.addI.y' = 'PID.addI.u1' + (-1.0) * 'PID.addI.u2' + 'PID.addI.u3';
    'PID.addSat.y' = 'PID.addSat.u1' + (-1.0) * 'PID.addSat.u2';
    'PID.gainTrack.y' = 1.4814814814814814 * 'PID.gainTrack.u';
    'PID.limiter.simplifiedExpr' = 'PID.limiter.u';
    'PID.limiter.y' = homotopy(smooth(0, if 'PID.limiter.u' > 100.0 then 100.0 else if 'PID.limiter.u' < (-100.0) then -100.0 else 'PID.limiter.u'), 'PID.limiter.simplifiedExpr');
    'PID.Dzero.y' = 0.0;
    'PID.addFF.y' = 'PID.addFF.u1' + 0.6366197723675815 * 'PID.addFF.u2';
    annotation(experiment(StopTime = 2.0, Interval = 1E-4, Tolerance = 1E-6));
  end 'DCPM_CurrentControlled';
end 'DCPM_CurrentControlled';
