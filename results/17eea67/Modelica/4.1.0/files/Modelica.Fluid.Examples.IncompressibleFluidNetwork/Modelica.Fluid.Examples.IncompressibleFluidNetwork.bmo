//! base 0.1.0
package 'IncompressibleFluidNetwork'
  function '$OMC$PositiveMax'
    input Real 'flowValue';
    input Real 'eps';
    output Real 'positiveMax';
  algorithm
    'positiveMax' := max('flowValue', 'eps');
  end '$OMC$PositiveMax';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe1.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe1.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe1.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe1.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe1.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe1.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe1.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe1.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe1.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe10.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe10.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe10.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe10.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe10.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe10.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe10.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe10.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe10.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe10.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe11.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe11.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe11.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe11.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe11.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe11.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe11.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe11.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe11.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe2.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe2.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe2.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe2.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe2.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe2.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe2.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe2.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe2.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe2.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe3.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe3.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe3.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe3.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe3.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe3.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe3.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe3.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe3.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe4.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe4.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe4.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe4.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe4.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe4.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe4.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe4.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe4.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe4.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe5.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe5.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe5.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe5.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe5.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe5.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe5.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe5.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe5.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe6.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe6.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe6.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe6.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe6.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe6.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe6.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe6.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe6.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe6.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe7.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe7.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe7.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe7.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe7.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe7.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe7.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe7.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe7.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe7.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe8.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe8.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe8.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe8.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe8.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe8.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe8.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe8.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe8.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.T_ph';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.setState_pTX' "Returns state record, given pressure and temperature"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe9.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe9.Medium.ThermodynamicState'('T', 'p');
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.setState_phX' "Returns state record, given pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe9.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe9.Medium.ThermodynamicState'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.T_ph'('p', 'h'), 'p');
    annotation(Inline = true, smoothOrder = 3);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpy' "Return specific enthalpy as a function of the thermodynamic state record"
    input 'pipe9.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpyOfT'('state'.'p', 'state'.'T', false);
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpy'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe9.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.temperature'('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.T_ph.f_nonlinear' "Solve specificEnthalpyOfT(p,T) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.specificEnthalpyOfT'('p', 'u', false) - 'h';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.Medium.T_ph.f_nonlinear';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.Medium.density' "Return density as a function of the thermodynamic state record"
    input 'pipe9.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Math.Polynomials.evaluate'({-0.002086443325811417, -0.49655615344558274, 1053.3329167389916}, 'Modelica.Units.Conversions.to_degC'('state'.'T'));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.Medium.pressure' "Return pressure as a function of the thermodynamic state record"
    input 'pipe9.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'zeta';
    Real 'k0';
    Real 'k_inv';
    Real 'dm_flow_ddp_laminar';
    Real 'dp_fric_turbulent'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_fric_laminar'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / 'Delta')) ^ 2.0;
    'k_inv' := (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0 / (8.0 * 'zeta');
    'dp_fric_turbulent' := sign('dp_fric') * ('mu' * 'diameter' * 3.141592653589793 / 4.0) ^ 2.0 * 'Re2' ^ 2.0 / ('k_inv' * 'rho');
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'dm_flow_ddp_laminar' := 'rho' / ('k0' * 'mu');
    'dp_fric_laminar' := sign('dp_fric') * 3.141592653589793 * 'k0' * 'mu' ^ 2.0 / 'rho' * 'diameter' / 4.0 * 'Re1';

    if abs('dp_fric') > abs('dp_fric_turbulent') then
      'm_flow' := sign('dp_fric') * sqrt('rho' * 'k_inv' * abs('dp_fric'));
      'dm_flow_ddp_fric' := 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric')) ^ (-0.5);
    elseif abs('dp_fric') < abs('dp_fric_laminar') then
      'm_flow' := 'dm_flow_ddp_laminar' * 'dp_fric';
      'dm_flow_ddp_fric' := 'dm_flow_ddp_laminar';
    elseif true then
      ('m_flow', 'dm_flow_ddp_fric') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('dp_fric', 'dp_fric_laminar', 'dp_fric_turbulent', 'dm_flow_ddp_laminar' * 'dp_fric_laminar', sign('dp_fric_turbulent') * sqrt('rho' * 'k_inv' * abs('dp_fric_turbulent')), 'dm_flow_ddp_laminar', if abs('dp_fric_turbulent') > 0.0 then 0.5 * 'rho' * 'k_inv' * ('rho' * 'k_inv' * abs('dp_fric_turbulent')) ^ (-0.5) else 1e60);
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.heatTransfer.Medium.temperature' "Return temperature as a function of the thermodynamic state record"
    input 'pipe9.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.sink.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.sink.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.sink.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.sink.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.sink.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.sink.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.sink.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.sink.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.source.Medium.h_T' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T'), 0.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.source.Medium.h_T_der');
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.source.Medium.h_T';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.source.Medium.h_T_der' "Compute specific enthalpy from temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT';
    output Real 'dh';
  algorithm
    'dh' := 'Modelica.Math.Polynomials.evaluate'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'Modelica.Units.Conversions.to_degC'('T')) * 'dT';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.source.Medium.h_T_der';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.source.Medium.specificEnthalpyOfT' "Return specific enthalpy from pressure and temperature, taking the flag enthalpyOfT into account"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'densityOfT' = false;
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.source.Medium.h_T'('T');
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.source.Medium.specificEnthalpyOfT';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.valve1.valveCharacteristic'
    input Real 'pos'(max = 1.0, min = 0.0);
    output Real 'rc';
  algorithm
    'rc' := 'pos';
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.valve1.valveCharacteristic';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.valve1.Medium.T_ph' "Compute temperature from pressure and specific enthalpy"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.valve1.Medium.T_ph.f_nonlinear'(p = 'p', h = 'h'), 243.14999999999998, 373.15, 2.220446049250313e-14);
    annotation(inverse(h = Modelica.Fluid.Examples.IncompressibleFluidNetwork.valve1.Medium.specificEnthalpyOfT('p', 'T', false)), Inline = false, LateInline = true);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.valve1.Medium.T_ph';

