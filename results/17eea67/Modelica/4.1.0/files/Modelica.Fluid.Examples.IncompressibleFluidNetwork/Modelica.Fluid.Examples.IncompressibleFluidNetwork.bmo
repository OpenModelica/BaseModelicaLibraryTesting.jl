    Real 'pipe11.flowModel.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    parameter Real 'pipe11.flowModel.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'pipe11.flowModel.crossAreas[1]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe11.flowModel.crossAreas[2]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe11.flowModel.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe11.flowModel.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe11.flowModel.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe11.flowModel.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe11.flowModel.dheights[1]'(unit = "m", quantity = "Length") "Height(states[2:n]) - Height(states[1:n-1])";
    parameter Real 'pipe11.flowModel.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'pipe11.flowModel.allowFlowReversal' = true "= true, if flow reversal is enabled, otherwise restrict flow to design direction (states[1] -> states[n+1])" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe11.flowModel.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance" annotation(Evaluate = true);
    parameter Real 'pipe11.flowModel.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") = 0.0 "Start value of mass flow rates";
    parameter Real 'pipe11.flowModel.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[1] at design inflow";
    parameter Real 'pipe11.flowModel.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[n+1] at design outflow";
    parameter Integer 'pipe11.flowModel.m' = 1 "Number of flow segments";
    Real 'pipe11.flowModel.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe11.flowModel.m_flows[1]'(stateSelect = StateSelect.default, start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rates between states";
    Real 'pipe11.flowModel.Is[1]'(unit = "kg.m/s", quantity = "Momentum") "Momenta of flow segments";
    Real 'pipe11.flowModel.Ib_flows[1]'(unit = "N", quantity = "Force") "Flow of momentum across boundaries";
    Real 'pipe11.flowModel.Fs_p[1]'(unit = "N", quantity = "Force") "Pressure forces";
    Real 'pipe11.flowModel.Fs_fg[1]'(unit = "N", quantity = "Force") "Friction and gravity forces";
    parameter Boolean 'pipe11.flowModel.useUpstreamScheme' = true "= false to average upstream and downstream properties across flow segments" annotation(Evaluate = true);
    parameter Boolean 'pipe11.flowModel.use_Ib_flows' = false "= true to consider differences in flow of momentum through boundaries" annotation(Evaluate = true);
    Real 'pipe11.flowModel.rhos[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe11.flowModel.rhos[2]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe11.flowModel.rhos_act[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
    Real 'pipe11.flowModel.mus[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe11.flowModel.mus[2]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe11.flowModel.mus_act[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") "Actual viscosity per segment";
    Real 'pipe11.flowModel.dps_fg[1]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    parameter Real 'pipe11.flowModel.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0 "Start of turbulent regime, depending on type of flow device";
    parameter Boolean 'pipe11.flowModel.show_Res' = false "= true, if Reynolds numbers are included for plotting" annotation(Evaluate = true);
    parameter Boolean 'pipe11.flowModel.use_rho_nominal' = false "= true, if rho_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe11.flowModel.rho_nominal'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1042.5672163397553 "Nominal density (e.g., rho_liquidWater = 995, rho_air = 1.2)";
    parameter Boolean 'pipe11.flowModel.use_mu_nominal' = true "= true, if mu_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe11.flowModel.mu_nominal'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") = 0.006396761240194778 "Nominal dynamic viscosity (e.g., mu_liquidWater = 1e-3, mu_air = 1.8e-5)";
    Real 'pipe11.flowModel.pathLengths_internal[1]'(unit = "m", quantity = "Length") "pathLengths used internally; to be defined by extending class";
    Real 'pipe11.flowModel.Res_turbulent_internal[1]'(unit = "1", quantity = "ReynoldsNumber") "Re_turbulent used internally; to be defined by extending class";
    parameter Real 'pipe11.flowModel.dp_nominal'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Nominal pressure loss (only for nominal models)";
    parameter Real 'pipe11.flowModel.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 1.0 "Nominal mass flow rate";
    parameter Real 'pipe11.flowModel.m_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 1e-4 * 'pipe11.flowModel.m_flow_nominal' "Within regularization if |m_flows| < m_flow_small (may be wider for large discontinuities in static head)";
    parameter Real 'pipe11.flowModel.dp_small'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Within regularization if |dp| < dp_small (may be wider for large discontinuities in static head)";
    parameter Boolean 'pipe11.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'pipe11.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'pipe11.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'pipe11.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure loss for nominal conditions";
    parameter Boolean 'pipe11.flowModel.use_Re' = true "= true, if turbulent region is defined by Re, otherwise by m_flow_small" annotation(Evaluate = true);
    Real 'pipe11.m_flows[1]'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rates of fluid across segment boundaries";
    Real 'pipe11.m_flows[2]'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rates of fluid across segment boundaries";
    Real 'pipe11.m_flows[3]'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rates of fluid across segment boundaries";
    Real 'pipe11.H_flows[1]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates of fluid across segment boundaries";
    Real 'pipe11.H_flows[2]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates of fluid across segment boundaries";
    Real 'pipe11.H_flows[3]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates of fluid across segment boundaries";
    Real 'pipe11.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'pipe11.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'pipe11.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe11.dheightsFM[1]'(unit = "m", quantity = "Length") "Differences in heights between flow segments";
    Real 'pipe11.crossAreasFM[1]'(unit = "m2", quantity = "Area") "Cross flow areas of flow segments";
    Real 'pipe11.crossAreasFM[2]'(unit = "m2", quantity = "Area") "Cross flow areas of flow segments";
    Real 'pipe11.vsFM[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'pipe11.vsFM[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'pipe11.dimensionsFM[1]'(unit = "m", quantity = "Length") "Hydraulic diameters of flow segments";
    Real 'pipe11.dimensionsFM[2]'(unit = "m", quantity = "Length") "Hydraulic diameters of flow segments";
    Real 'pipe11.roughnessesFM[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
    Real 'pipe11.roughnessesFM[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
    parameter Boolean 'pipe11.use_HeatTransfer' = false "= true to use the HeatTransfer model";
    parameter Integer 'pipe11.heatTransfer.n' = 2 "Number of heat transfer segments" annotation(Evaluate = true);
    Real 'pipe11.heatTransfer.states[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'pipe11.heatTransfer.states[1].p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Real 'pipe11.heatTransfer.states[2].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'pipe11.heatTransfer.states[2].p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Real 'pipe11.heatTransfer.surfaceAreas[1]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'pipe11.heatTransfer.surfaceAreas[2]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'pipe11.heatTransfer.Q_flows[1]'(unit = "W", quantity = "Power") "Heat flow rates";
    Real 'pipe11.heatTransfer.Q_flows[2]'(unit = "W", quantity = "Power") "Heat flow rates";
    parameter Boolean 'pipe11.heatTransfer.use_k' = false "= true to use k value for thermal isolation";
    parameter Real 'pipe11.heatTransfer.k'(unit = "W/(m2.K)", quantity = "CoefficientOfHeatTransfer") = 0.0 "Heat transfer coefficient to ambient" annotation(Evaluate = true);
    parameter Real 'pipe11.heatTransfer.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'pipe11.heatTransfer.heatPorts[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'pipe11.heatTransfer.heatPorts[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'pipe11.heatTransfer.heatPorts[2].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'pipe11.heatTransfer.heatPorts[2].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'pipe11.heatTransfer.Ts[1]'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    Real 'pipe11.heatTransfer.Ts[2]'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    Real 'pipe11.heatTransfer.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow in segments";
    Real 'pipe11.heatTransfer.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow in segments";
    parameter Real 'pipe11.heatTransfer.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'pipe11.heatTransfer.lengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe11.heatTransfer.lengths[2]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe11.heatTransfer.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameter for pipe flow)";
    Real 'pipe11.heatTransfer.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameter for pipe flow)";
    Real 'pipe11.heatTransfer.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
    Real 'pipe11.heatTransfer.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
    parameter Real 'pipe11.dxs[1]' = 0.5 "Normalized lengths";
    parameter Real 'pipe11.dxs[2]' = 0.5 "Normalized lengths";
  initial equation
    assert(abs('pipe1.flowModel.crossAreas[1]' - 0.7853981633974483 * 'pipe1.flowModel.dimensions[1]' ^ 2.0) < 1e-10 * 'pipe1.flowModel.crossAreas[1]', "NominalTurbulentPipeFlow model requires circular tubes", AssertionLevel.error);
    assert(abs('pipe1.flowModel.crossAreas[2]' - 0.7853981633974483 * 'pipe1.flowModel.dimensions[2]' ^ 2.0) < 1e-10 * 'pipe1.flowModel.crossAreas[2]', "NominalTurbulentPipeFlow model requires circular tubes", AssertionLevel.error);
    'pipe1.flowModel.dp_nominal' = 'pipe1.flowModel.dp_fric_nominal' + 9.80665 * 'pipe1.flowModel.dheights[1]' * 1042.5672163397553;
