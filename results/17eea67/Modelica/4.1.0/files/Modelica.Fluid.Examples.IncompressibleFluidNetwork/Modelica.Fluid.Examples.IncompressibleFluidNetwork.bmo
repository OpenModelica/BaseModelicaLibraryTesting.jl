    'pipe11.vs[1]' = 0.5 * ('pipe11.m_flows[1]' + 'pipe11.m_flows[2]') / 'pipe11.mediums[1].d' / 4.908738521234052e-4;
    'pipe11.vs[2]' = 0.5 * ('pipe11.m_flows[2]' + 'pipe11.m_flows[3]') / 'pipe11.mediums[2].d' / 4.908738521234052e-4;
    'pipe11.heatTransfer.surfaceAreas[1]' = 0.019634954084936207;
    'pipe11.heatTransfer.surfaceAreas[2]' = 0.019634954084936207;
    'pipe11.heatTransfer.Ts[1]' = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.heatTransfer.Medium.temperature'('pipe11.heatTransfer.states[1]');
    'pipe11.heatTransfer.Ts[2]' = 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.heatTransfer.Medium.temperature'('pipe11.heatTransfer.states[2]');
    'pipe11.heatTransfer.vs[1]' = 'pipe11.vs[1]';
    'pipe11.heatTransfer.vs[2]' = 'pipe11.vs[2]';
    'pipe11.heatTransfer.lengths[1]' = 0.25;
    'pipe11.heatTransfer.lengths[2]' = 0.25;
    'pipe11.heatTransfer.dimensions[1]' = 0.025;
    'pipe11.heatTransfer.dimensions[2]' = 0.025;
    'pipe11.heatTransfer.roughnesses[1]' = 2.5e-5;
    'pipe11.heatTransfer.roughnesses[2]' = 2.5e-5;
    'pipe11.heatTransfer.Ts[1]' = 'pipe11.heatTransfer.heatPorts[1].T';
    'pipe11.heatTransfer.Ts[2]' = 'pipe11.heatTransfer.heatPorts[2].T';
