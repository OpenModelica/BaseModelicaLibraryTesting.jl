    'pipe11.heatTransfer.Q_flows[2]' = 'pipe11.heatTransfer.heatPorts[2].Q_flow';
    'pipe11.Qb_flows[1]' = 'pipe11.heatTransfer.Q_flows[1]';
    'pipe11.Qb_flows[2]' = 'pipe11.heatTransfer.Q_flows[2]';
    'pipe11.Wb_flows[1]' = 'pipe11.vs[1]' * 4.908738521234052e-4 * (('pipe11.mediums[2].p' - 'pipe11.mediums[1].p') / 2.0 + 'pipe11.flowModel.dps_fg[1]' / 2.0);
    'pipe11.Wb_flows[2]' = 'pipe11.vs[2]' * 4.908738521234052e-4 * (('pipe11.mediums[2].p' - 'pipe11.mediums[1].p') / 2.0 + 'pipe11.flowModel.dps_fg[1]' / 2.0);
    'pipe11.pathLengths[1]' = 0.5;
    'pipe11.dheightsFM[1]' = 0.0;
    'pipe11.crossAreasFM[1]' = 4.908738521234052e-4;
    'pipe11.crossAreasFM[2]' = 4.908738521234052e-4;
    'pipe11.dimensionsFM[1]' = 0.025;
    'pipe11.dimensionsFM[2]' = 0.025;
    'pipe11.roughnessesFM[1]' = 2.5e-5;
    'pipe11.roughnessesFM[2]' = 2.5e-5;
    'pipe11.mb_flows[1]' = 'pipe11.m_flows[1]' - 'pipe11.m_flows[2]';
    'pipe11.Hb_flows[1]' = 'pipe11.H_flows[1]' - 'pipe11.H_flows[2]';
    'pipe11.mb_flows[2]' = 'pipe11.m_flows[2]' - 'pipe11.m_flows[3]';
    'pipe11.Hb_flows[2]' = 'pipe11.H_flows[2]' - 'pipe11.H_flows[3]';
    'pipe11.H_flows[2]' = semiLinear('pipe11.m_flows[2]', 'pipe11.mediums[1].h', 'pipe11.mediums[2].h');
    'pipe11.H_flows[1]' = semiLinear('pipe11.port_a.m_flow', ('$OMC$PositiveMax'(-'pipe5.port_b.m_flow', 1e-7) * 'pipe5.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe6.port_b.m_flow', 1e-7) * 'pipe6.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe9.port_b.m_flow', 1e-7) * 'pipe9.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe10.port_b.m_flow', 1e-7) * 'pipe10.port_b.h_outflow') / ('$OMC$PositiveMax'(-'pipe5.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe6.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe9.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe10.port_b.m_flow', 1e-7)), 'pipe11.mediums[1].h');
    'pipe11.H_flows[3]' = -semiLinear('pipe11.port_b.m_flow', 'valve3.port_a.h_outflow', 'pipe11.mediums[2].h');
    'pipe11.port_a.m_flow' = 'pipe11.m_flows[1]';
    'pipe11.port_b.m_flow' = -'pipe11.m_flows[3]';
    'pipe11.port_a.h_outflow' = 'pipe11.mediums[1].h';
    'pipe11.port_b.h_outflow' = 'pipe11.mediums[2].h';
    'pipe11.state_a.T' = ('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_phX'('pipe11.port_a.p', ('$OMC$PositiveMax'(-'pipe5.port_b.m_flow', 1e-7) * 'pipe5.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe6.port_b.m_flow', 1e-7) * 'pipe6.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe9.port_b.m_flow', 1e-7) * 'pipe9.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe10.port_b.m_flow', 1e-7) * 'pipe10.port_b.h_outflow') / ('$OMC$PositiveMax'(-'pipe5.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe6.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe9.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe10.port_b.m_flow', 1e-7)), fill(0.0, 0))).T;
    'pipe11.state_a.p' = ('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_phX'('pipe11.port_a.p', ('$OMC$PositiveMax'(-'pipe5.port_b.m_flow', 1e-7) * 'pipe5.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe6.port_b.m_flow', 1e-7) * 'pipe6.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe9.port_b.m_flow', 1e-7) * 'pipe9.port_b.h_outflow' + '$OMC$PositiveMax'(-'pipe10.port_b.m_flow', 1e-7) * 'pipe10.port_b.h_outflow') / ('$OMC$PositiveMax'(-'pipe5.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe6.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe9.port_b.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe10.port_b.m_flow', 1e-7)), fill(0.0, 0))).p;
    'pipe11.state_b.T' = ('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_phX'('pipe11.port_b.p', 'valve3.port_a.h_outflow', fill(0.0, 0))).T;
    'pipe11.state_b.p' = ('Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe11.Medium.setState_phX'('pipe11.port_b.p', 'valve3.port_a.h_outflow', fill(0.0, 0))).p;
    'pipe11.statesFM[1].T' = 'pipe11.mediums[1].state.T';
    'pipe11.statesFM[1].p' = 'pipe11.mediums[1].state.p';
    'pipe11.statesFM[2].T' = 'pipe11.mediums[2].state.T';
    'pipe11.statesFM[2].p' = 'pipe11.mediums[2].state.p';
    'pipe11.m_flows[2]' = 'pipe11.flowModel.m_flows[1]';
    'pipe11.vsFM[1]' = 'pipe11.vs[1]';
    'pipe11.vsFM[2]' = 'pipe11.vs[2]';
    'pipe11.port_a.p' = 'pipe11.mediums[1].p';
    'pipe11.port_b.p' = 'pipe11.mediums[2].p';
    'pipe11.ms[1]' = 'pipe11.fluidVolumes[1]' * 'pipe11.mediums[1].d';
    'pipe11.Us[1]' = 'pipe11.ms[1]' * 'pipe11.mediums[1].u';
    'pipe11.ms[2]' = 'pipe11.fluidVolumes[2]' * 'pipe11.mediums[2].d';
    'pipe11.Us[2]' = 'pipe11.ms[2]' * 'pipe11.mediums[2].u';
    der('pipe11.Us[1]') = 'pipe11.Hb_flows[1]' + 'pipe11.Wb_flows[1]' + 'pipe11.Qb_flows[1]';
    der('pipe11.Us[2]') = 'pipe11.Hb_flows[2]' + 'pipe11.Wb_flows[2]' + 'pipe11.Qb_flows[2]';
    0.0 = 'pipe11.mb_flows[1]';
    0.0 = 'pipe11.mb_flows[2]';
    annotation(experiment(StopTime = 200));
  end 'IncompressibleFluidNetwork';
end 'IncompressibleFluidNetwork';
