  function 'Modelica.Fluid.Utilities.checkBoundary' "Check whether boundary definition is correct"
    input String 'mediumName';
    input String[:] 'substanceNames';
    input Boolean 'singleState';
    input Boolean 'define_p';
    input Real[:] 'X_boundary';
    input String 'modelName' = "??? boundary ???";
    Integer 'nX' = size('X_boundary', 1);
    String 'X_str';
  algorithm
    assert(not 'singleState' or 'singleState' and 'define_p', "\nWrong value of parameter define_p (= false) in model \"" + 'modelName' + "\":\nThe selected medium \"" + 'mediumName' + "\" has Medium.singleState=true.\nTherefore, an boundary density cannot be defined and\ndefine_p = true is required.\n", AssertionLevel.error);

    for 'i' in 1:'nX' loop
      assert('X_boundary'['i'] >= 0.0, "\nWrong boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\":\nThe boundary value X_boundary(" + String('i') + ") = " + String('X_boundary'['i']) + "\nis negative. It must be positive.\n", AssertionLevel.error);
    end for;

    if 'nX' > 0 and abs(sum('X_boundary') - 1.0) > 1e-10 then
      'X_str' := "";

      for 'i' in 1:'nX' loop
        'X_str' := 'X_str' + "   X_boundary[" + String('i') + "] = " + String('X_boundary'['i']) + " \"" + 'substanceNames'['i'] + "\"\n";
      end for;

      'Modelica.Utilities.Streams.error'("The boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\"\n" + "do not sum up to 1. Instead, sum(X_boundary) = " + String(sum('X_boundary')) + ":\n" + 'X_str');
    end if;
  end 'Modelica.Fluid.Utilities.checkBoundary';

  function 'Modelica.Fluid.Utilities.cubicHermite_withDerivative' "Evaluate a cubic Hermite spline, return value and derivative"
    input Real 'x';
    input Real 'x1';
    input Real 'x2';
    input Real 'y1';
    input Real 'y2';
    input Real 'y1d';
    input Real 'y2d';
    output Real 'y';
    output Real 'dy_dx';
    Real 'h';
    Real 't';
    Real 'h00';
    Real 'h10';
    Real 'h01';
    Real 'h11';
    Real 'h00d';
    Real 'h10d';
    Real 'h01d';
    Real 'h11d';
    Real 'aux3';
    Real 'aux2';
  algorithm
    'h' := 'x2' - 'x1';

    if abs('h') > 0.0 then
      't' := ('x' - 'x1') / 'h';
      'aux3' := 't' ^ 3.0;
      'aux2' := 't' ^ 2.0;
      'h00' := 2.0 * 'aux3' - 3.0 * 'aux2' + 1.0;
      'h10' := 'aux3' - 2.0 * 'aux2' + 't';
      'h01' := 3.0 * 'aux2' - 2.0 * 'aux3';
      'h11' := 'aux3' - 'aux2';
      'h00d' := 6.0 * ('aux2' - 't');
      'h10d' := 3.0 * 'aux2' - 4.0 * 't' + 1.0;
      'h01d' := 6.0 * ('t' - 'aux2');
      'h11d' := 3.0 * 'aux2' - 2.0 * 't';
      'y' := 'y1' * 'h00' + 'h' * 'y1d' * 'h10' + 'y2' * 'h01' + 'h' * 'y2d' * 'h11';
      'dy_dx' := 'y1' * 'h00d' / 'h' + 'y1d' * 'h10d' + 'y2' * 'h01d' / 'h' + 'y2d' * 'h11d';
    elseif true then
      'y' := ('y1' + 'y2') / 2.0;
      'dy_dx' := sign('y2' - 'y1') * 1e60;
    end if;
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Utilities.cubicHermite_withDerivative';

  function 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero' "Evaluate polynomial of order 3 that passes the origin with a predefined derivative"
    input Real 'x';
    input Real 'x1';
    input Real 'y1';
    input Real 'y1d';
    input Real 'y0d';
    output Real 'y';
    Real 'a1';
    Real 'a2';
    Real 'a3';
    Real 'xx';
  algorithm
    'a1' := 'x1' * 'y0d';
    'a2' := 3.0 * 'y1' - 'x1' * 'y1d' - 2.0 * 'a1';
    'a3' := 'y1' - 'a2' - 'a1';
    'xx' := 'x' / 'x1';
    'y' := 'xx' * ('a1' + 'xx' * ('a2' + 'xx' * 'a3'));
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero';

  function 'Modelica.Fluid.Utilities.regFun3' "Co-monotonic and C1 smooth regularization function"
    input Real 'x';
    input Real 'x0';
    input Real 'x1';
    input Real 'y0';
    input Real 'y1';
    input Real 'y0d';
    input Real 'y1d';
    output Real 'y';
    output Real 'c';
    Real 'h0';
    Real 'Delta0';
    Real 'xstar';
    Real 'mu';
    Real 'eta';
    Real 'omega';
    Real 'rho';
    Real 'theta0';
    Real 'mu_tilde';
    Real 'eta_tilde';
    Real 'xi1';
    Real 'xi2';
    Real 'a1';
    Real 'a2';
    Real 'const12';
    Real 'const3';
    Real 'aux01';
    Real 'aux02';
    Boolean 'useSingleCubicPolynomial' = false;
  algorithm
    assert('x0' < 'x1', "regFun3(): Data points not sorted appropriately (x0 = " + String('x0') + " > x1 = " + String('x1') + "). Please flip arguments.", AssertionLevel.error);

    if 'y0d' * 'y1d' >= 0.0 then
    elseif true then
      assert(abs('y0d') < 2.220446049250313e-16 or abs('y1d') < 2.220446049250313e-16, "regFun3(): Derivatives at data points do not allow co-monotone interpolation, as both are non-zero, of opposite sign and have an absolute value larger than machine eps (y0d = " + String('y0d') + ", y1d = " + String('y1d') + "). Please correct arguments.", AssertionLevel.error);
    end if;

    'h0' := 'x1' - 'x0';
    'Delta0' := ('y1' - 'y0') / 'h0';

    if abs('Delta0') <= 0.0 then
      'y' := 'y0' + 'Delta0' * ('x' - 'x0');
      'c' := 0.0;
    elseif abs('y1d' + 'y0d' - 2.0 * 'Delta0') < 2.220446049250313e-14 then
      'y' := 'y0' + ('x' - 'x0') * ('y0d' + ('x' - 'x0') / 'h0' * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d') + ('x' - 'x0') * ('y0d' + 'y1d' - 2.0 * 'Delta0') / 'h0'));
      'aux01' := ('x0' + 'x1') / 2.0;
      'c' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('aux01' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('aux01' - 'x0') / 'h0' + 'y0d';
    elseif true then
      'xstar' := 0.3333333333333333 * (6.0 * 'x0' * 'Delta0' - (3.0 * 'x0' * 'y0d' + 3.0 * 'x0' * 'y1d') - 2.0 * 'h0' * 'y0d' - 'h0' * 'y1d' + 3.0 * 'h0' * 'Delta0') / (2.0 * 'Delta0' - ('y0d' + 'y1d'));
      'mu' := 'xstar' - 'x0';
      'eta' := 'x1' - 'xstar';
      'omega' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('xstar' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('xstar' - 'x0') / 'h0' + 'y0d';
      'aux01' := 0.25 * sign('Delta0') * min(abs('omega'), abs('Delta0')) "Slope c if not using plain cubic S0";

      if abs('y0d' - 'y1d') <= 2.220446049250313e-14 then
        'aux02' := 'y0d';

        if 'y1' > 'y0' + 'y0d' * ('x1' - 'x0') then
          'useSingleCubicPolynomial' := true;
        end if;
      elseif abs('y1d' + 'y0d' - 2.0 * 'Delta0') < 2.220446049250313e-14 then
        'aux02' := (6.0 * 'Delta0' * ('y1d' + 'y0d' - 1.5 * 'Delta0') - 'y1d' * 'y0d' - 'y1d' ^ 2.0 - 'y0d' ^ 2.0) * (if 'y1d' + 'y0d' - 2.0 * 'Delta0' >= 0.0 then 1.0 else -1.0) * 1e60;
      elseif true then
        'aux02' := (6.0 * 'Delta0' * ('y1d' + 'y0d' - 1.5 * 'Delta0') - 'y1d' * 'y0d' - 'y1d' ^ 2.0 - 'y0d' ^ 2.0) / (3.0 * ('y1d' + 'y0d' - 2.0 * 'Delta0'));
      end if;

      if ((('mu' > 0.0 and 'eta' < 'h0') and 'Delta0' * 'omega' <= 0.0 or abs('aux01') < abs('aux02') and 'aux02' * 'Delta0' >= 0.0) or abs('aux01') < abs(0.1 * 'Delta0')) and not 'useSingleCubicPolynomial' then
        'c' := 'aux01';

        if abs('c') < abs('aux02') and 'aux02' * 'Delta0' >= 0.0 then
          'c' := 'aux02';
        end if;

        if abs('c') < abs(0.1 * 'Delta0') then
          'c' := 0.1 * 'Delta0';
        end if;

        'theta0' := ('y0d' * 'mu' + 'y1d' * 'eta') / 'h0';

        if abs('theta0' - 'c') < 1e-6 * abs('c') then
          'c' := 0.999999 * 'theta0';
        end if;

        'rho' := 3.0 * ('Delta0' - 'c') / ('theta0' - 'c');
        'mu_tilde' := 'rho' * 'mu';
        'eta_tilde' := 'rho' * 'eta';
        'xi1' := 'x0' + 'mu_tilde';
        'xi2' := 'x1' - 'eta_tilde';
        'a1' := ('y0d' - 'c') / max('mu_tilde' ^ 2.0, 2.220446049250313e-14);
        'a2' := ('y1d' - 'c') / max('eta_tilde' ^ 2.0, 2.220446049250313e-14);
        'const12' := 'y0' - 'a1' / 3.0 * ('x0' - 'xi1') ^ 3.0 - 'c' * 'x0';
        'const3' := 'y1' - 'a2' / 3.0 * ('x1' - 'xi2') ^ 3.0 - 'c' * 'x1';

        if 'x' < 'xi1' then
          'y' := 'a1' / 3.0 * ('x' - 'xi1') ^ 3.0 + 'c' * 'x' + 'const12';
        elseif 'x' < 'xi2' then
          'y' := 'c' * 'x' + 'const12';
        elseif true then
          'y' := 'a2' / 3.0 * ('x' - 'xi2') ^ 3.0 + 'c' * 'x' + 'const3';
        end if;
      elseif true then
        'y' := 'y0' + ('x' - 'x0') * ('y0d' + ('x' - 'x0') / 'h0' * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d') + ('x' - 'x0') * ('y0d' + 'y1d' - 2.0 * 'Delta0') / 'h0'));
        'aux01' := ('x0' + 'x1') / 2.0;
        'c' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('aux01' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('aux01' - 'x0') / 'h0' + 'y0d';
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Utilities.regFun3';

  function 'Modelica.Fluid.Utilities.regRoot2' "Anti-symmetric approximation of square root with discontinuous factor so that the first derivative is finite and continuous"
    input Real 'x';
    input Real 'x_small'(min = 0.0) = 0.01;
    input Real 'k1'(min = 0.0) = 1.0;
    input Real 'k2'(min = 0.0) = 1.0;
    input Boolean 'use_yd0' = false;
    input Real 'yd0'(min = 0.0) = 1.0;
    output Real 'y';
    Real 'sqrt_k1' = if 'k1' > 0.0 then sqrt('k1') else 0.0;
    Real 'sqrt_k2' = if 'k2' > 0.0 then sqrt('k2') else 0.0;
  algorithm
    'y' := smooth(2, if 'x' >= 'x_small' then 'sqrt_k1' * sqrt('x') else if 'x' <= (-'x_small') then -'sqrt_k2' * sqrt(abs('x')) else if 'k1' >= 'k2' then 'Modelica.Fluid.Utilities.regRoot2.regRoot2_utility'('x', 'x_small', 'k1', 'k2', 'use_yd0', 'yd0') else -'Modelica.Fluid.Utilities.regRoot2.regRoot2_utility'(-'x', 'x_small', 'k2', 'k1', 'use_yd0', 'yd0'));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Utilities.regRoot2';

  function 'Modelica.Fluid.Utilities.regSquare2' "Anti-symmetric approximation of square with discontinuous factor so that the first derivative is non-zero and is continuous"
    input Real 'x';
    input Real 'x_small'(min = 0.0) = 0.01;
    input Real 'k1'(min = 0.0) = 1.0;
    input Real 'k2'(min = 0.0) = 1.0;
    input Boolean 'use_yd0' = false;
    input Real 'yd0'(min = 0.0) = 1.0;
    output Real 'y';
  algorithm
    'y' := smooth(2, if 'x' >= 'x_small' then 'k1' * 'x' ^ 2.0 else if 'x' <= (-'x_small') then -'k2' * 'x' ^ 2.0 else if 'k1' >= 'k2' then 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility'('x', 'x_small', 'k1', 'k2', 'use_yd0', 'yd0') else -'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility'(-'x', 'x_small', 'k2', 'k1', 'use_yd0', 'yd0'));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Utilities.regSquare2';

  function 'Modelica.Fluid.Utilities.regStep' "Approximation of a general step, such that the characteristic is continuous and differentiable"
    input Real 'x';
    input Real 'y1';
    input Real 'y2';
    input Real 'x_small'(min = 0.0) = 1e-5;
    output Real 'y';
  algorithm
    'y' := smooth(1, if 'x' > 'x_small' then 'y1' else if 'x' < (-'x_small') then 'y2' else if 'x_small' > 0.0 then 'x' / 'x_small' * (('x' / 'x_small') ^ 2.0 - 3.0) * ('y2' - 'y1') / 4.0 + ('y1' + 'y2') / 2.0 else ('y1' + 'y2') / 2.0);
  end 'Modelica.Fluid.Utilities.regStep';

  function 'Modelica.Fluid.Utilities.regRoot2.regRoot2_utility' "Interpolating with two 3-order polynomials with a prescribed derivative at x=0"
    input Real 'x';
    input Real 'x1';
    input Real 'k1';
    input Real 'k2';
    input Boolean 'use_yd0';
    input Real 'yd0'(min = 0.0);
    output Real 'y';
    Real 'x2';
    Real 'xsqrt1';
    Real 'xsqrt2';
    Real 'y1';
    Real 'y2';
    Real 'y1d';
    Real 'y2d';
    Real 'w';
    Real 'y0d';
    Real 'w1';
    Real 'w2';
    Real 'sqrt_k1' = if 'k1' > 0.0 then sqrt('k1') else 0.0;
    Real 'sqrt_k2' = if 'k2' > 0.0 then sqrt('k2') else 0.0;
  algorithm
    if 'k2' > 0.0 then
      'x2' := -'x1' * ('k2' / 'k1');
    elseif 'k1' > 0.0 then
      'x2' := -'x1';
    elseif true then
      'y' := 0.0;
      return;
    end if;

    if 'x' <= 'x2' then
      'y' := -'sqrt_k2' * sqrt(abs('x'));
    elseif true then
      'y1' := 'sqrt_k1' * sqrt('x1');
      'y2' := -'sqrt_k2' * sqrt(abs('x2'));
      'y1d' := 'sqrt_k1' / sqrt('x1') / 2.0;
      'y2d' := 'sqrt_k2' / sqrt(abs('x2')) / 2.0;

      if 'use_yd0' then
        'y0d' := 'yd0';
      elseif true then
        'w' := 'x2' / 'x1';
        'y0d' := ((3.0 * 'y2' - 'x2' * 'y2d') / 'w' - (3.0 * 'y1' - 'x1' * 'y1d') * 'w') / (2.0 * 'x1' * (1.0 - 'w'));
      end if;

      'w1' := 'sqrt_k1' * sqrt(8.75 / 'x1');
      'w2' := 'sqrt_k2' * sqrt(8.75 / abs('x2'));
      'y0d' := smooth(2, min('y0d', 0.9 * min('w1', 'w2')));
      'y' := 'y1' * (if 'x' >= 0.0 then 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x' / 'x1', 1.0, 1.0, 'y1d' * 'x1' / 'y1', 'y0d' * 'x1' / 'y1') else 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x' / 'x1', 'x2' / 'x1', 'y2' / 'y1', 'y2d' * 'x1' / 'y1', 'y0d' * 'x1' / 'y1'));
    end if;
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Utilities.regRoot2.regRoot2_utility';

  function 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility' "Interpolating with two 3-order polynomials with a prescribed derivative at x=0"
    input Real 'x';
    input Real 'x1';
    input Real 'k1';
    input Real 'k2';
    input Boolean 'use_yd0' = false;
    input Real 'yd0'(min = 0.0) = 1.0;
    output Real 'y';
    Real 'x2';
    Real 'y1';
    Real 'y2';
    Real 'y1d';
    Real 'y2d';
    Real 'w';
    Real 'w1';
    Real 'w2';
    Real 'y0d';
    Real 'ww';
  algorithm
    'x2' := -'x1';

    if 'x' <= 'x2' then
      'y' := -'k2' * 'x' ^ 2.0;
    elseif true then
      'y1' := 'k1' * 'x1' ^ 2.0;
      'y2' := -'k2' * 'x2' ^ 2.0;
      'y1d' := 'k1' * 2.0 * 'x1';
      'y2d' := -'k2' * 2.0 * 'x2';

      if 'use_yd0' then
        'y0d' := 'yd0';
      elseif true then
        'w' := 'x2' / 'x1';
        'y0d' := ((3.0 * 'y2' - 'x2' * 'y2d') / 'w' - (3.0 * 'y1' - 'x1' * 'y1d') * 'w') / (2.0 * 'x1' * (1.0 - 'w'));
      end if;

      'w1' := 2.23606797749979 * 'k1' * 'x1';
      'w2' := 2.23606797749979 * 'k2' * abs('x2');
      'ww' := 0.9 * (if 'w1' < 'w2' then 'w1' else 'w2');

      if 'ww' < 'y0d' then
        'y0d' := 'ww';
      end if;

      'y' := if 'x' >= 0.0 then 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x', 'x1', 'y1', 'y1d', 'y0d') else 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x', 'x2', 'y2', 'y2d', 'y0d');
    end if;
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility';

  function 'Modelica.Math.exp' "Exponential, base e"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := exp('u');
    annotation(Inline = true);
  end 'Modelica.Math.exp';

  function 'Modelica.Math.log10' "Base 10 logarithm (u shall be > 0)"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := log10('u');
    annotation(Inline = true);
  end 'Modelica.Math.log10';

  function 'Modelica.Math.Nonlinear.solveOneNonlinearEquation' "Solve f(u) = 0 in a very reliable and efficient way (f(u_min) and f(u_max) must have different signs)"
    input 'Modelica.Math.Nonlinear.Interfaces.partialScalarFunction' 'f';
    input Real 'u_min';
    input Real 'u_max';
    input Real 'tolerance' = 2.220446049250313e-14;
    output Real 'u';
    constant Real 'eps' = 2.220446049250313e-16;
    Real 'a' = 'u_min';
    Real 'b' = 'u_max';
    Real 'c';
    Real 'd';
    Real 'e';
    Real 'm';
    Real 's';
    Real 'p';
    Real 'q';
    Real 'r';
    Real 'tol';
    Real 'fa';
    Real 'fb';
    Real 'fc';
    Boolean 'found' = false;
  algorithm
    'fa' := 'f'('u_min');
    'fb' := 'f'('u_max');
    'fc' := 'fb';

    if 'fa' > 0.0 and 'fb' > 0.0 or 'fa' < 0.0 and 'fb' < 0.0 then
      'Modelica.Utilities.Streams.error'("The arguments u_min and u_max provided in the function call\n    solveOneNonlinearEquation(f,u_min,u_max)\ndo not bracket the root of the single non-linear equation 0=f(u):\n  u_min  = " + String('u_min') + "\n" + "  u_max  = " + String('u_max') + "\n" + "  fa = f(u_min) = " + String('fa') + "\n" + "  fb = f(u_max) = " + String('fb') + "\n" + "fa and fb must have opposite sign which is not the case");
    end if;

    'c' := 'a';
    'fc' := 'fa';
    'e' := 'b' - 'a';
    'd' := 'e';

    while not 'found' loop
      if abs('fc') < abs('fb') then
        'a' := 'b';
        'b' := 'c';
        'c' := 'a';
        'fa' := 'fb';
        'fb' := 'fc';
        'fc' := 'fa';
      end if;

      'tol' := 2.0 * 'eps' * abs('b') + 'tolerance';
      'm' := ('c' - 'b') / 2.0;

      if abs('m') <= 'tol' or 'fb' == 0.0 then
        'found' := true;
        'u' := 'b';
      elseif true then
        if abs('e') < 'tol' or abs('fa') <= abs('fb') then
          'e' := 'm';
          'd' := 'e';
        elseif true then
          's' := 'fb' / 'fa';

          if 'a' == 'c' then
            'p' := 2.0 * 'm' * 's';
            'q' := 1.0 - 's';
          elseif true then
            'q' := 'fa' / 'fc';
            'r' := 'fb' / 'fc';
            'p' := 's' * (2.0 * 'm' * 'q' * ('q' - 'r') - ('b' - 'a') * ('r' - 1.0));
            'q' := ('q' - 1.0) * ('r' - 1.0) * ('s' - 1.0);
          end if;

          if 'p' > 0.0 then
            'q' := -'q';
          elseif true then
            'p' := -'p';
          end if;

          's' := 'e';
          'e' := 'd';

          if 2.0 * 'p' < 3.0 * 'm' * 'q' - abs('tol' * 'q') and 'p' < abs(0.5 * 's' * 'q') then
            'd' := 'p' / 'q';
          elseif true then
            'e' := 'm';
            'd' := 'e';
          end if;
        end if;

        'a' := 'b';
        'fa' := 'fb';
        'b' := 'b' + (if abs('d') > 'tol' then 'd' else if 'm' > 0.0 then 'tol' else -'tol');
        'fb' := 'f'('b');

        if 'fb' > 0.0 and 'fc' > 0.0 or 'fb' < 0.0 and 'fc' < 0.0 then
          'c' := 'a';
          'fc' := 'fa';
          'e' := 'b' - 'a';
          'd' := 'e';
        end if;
      end if;
    end while;
  end 'Modelica.Math.Nonlinear.solveOneNonlinearEquation';

  function 'Modelica.Math.Polynomials.evaluate' "Evaluate polynomial at a given abscissa value"
    input Real[:] 'p';
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := 'p'[1];

    for 'j' in 2:size('p', 1) loop
      'y' := 'p'['j'] + 'u' * 'y';
    end for;
    annotation(derivative(order = 1, zeroDerivative = 'p') = 'Modelica.Math.Polynomials.evaluate_der');
  end 'Modelica.Math.Polynomials.evaluate';

  function 'Modelica.Math.Polynomials.evaluate_der' "Evaluate derivative of polynomial at a given abscissa value"
    input Real[:] 'p';
    input Real 'u';
    input Real 'du';
    output Real 'dy';
    Integer 'n' = size('p', 1);
  algorithm
    'dy' := 'p'[1] * ('n' - 1);

    for 'j' in 2:size('p', 1) - 1 loop
      'dy' := 'p'['j'] * ('n' - 'j') + 'u' * 'dy';
    end for;

    'dy' := 'dy' * 'du';
  end 'Modelica.Math.Polynomials.evaluate_der';

  function 'Modelica.Math.Polynomials.integralValue' "Integral of polynomial p(u) from u_low to u_high"
    input Real[:] 'p';
    input Real 'u_high';
    input Real 'u_low' = 0.0;
    output Real 'integral' = 0.0;
    Integer 'n' = size('p', 1);
    Real 'y_low' = 0.0;
  algorithm
    for 'j' in 1:'n' loop
      'integral' := 'u_high' * ('p'['j'] / ('n' - 'j' + 1) + 'integral');
      'y_low' := 'u_low' * ('p'['j'] / ('n' - 'j' + 1) + 'y_low');
    end for;

    'integral' := 'integral' - 'y_low';
    annotation(derivative(order = 1, zeroDerivative = 'p') = 'Modelica.Math.Polynomials.integralValue_der');
  end 'Modelica.Math.Polynomials.integralValue';

  function 'Modelica.Math.Polynomials.integralValue_der' "Time derivative of integral of polynomial p(u) from u_low to u_high, assuming only u_high as time-dependent (Leibniz rule)"
    input Real[:] 'p';
    input Real 'u_high';
    input Real 'u_low' = 0.0;
    input Real 'du_high';
    input Real 'du_low' = 0.0;
    output Real 'dintegral' = 0.0;
  algorithm
    'dintegral' := 'Modelica.Math.Polynomials.evaluate'('p', 'u_high') * 'du_high';
  end 'Modelica.Math.Polynomials.integralValue_der';

  function 'Modelica.Units.Conversions.to_bar' "Convert from Pascal to bar"
    input Real 'Pa'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'bar'(unit = "bar", quantity = "Pressure");
  algorithm
    'bar' := 'Pa' / 1e5;
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_bar';

  function 'Modelica.Units.Conversions.to_degC' "Convert from kelvin to degree Celsius"
    input Real 'Kelvin'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'Celsius'(unit = "degC", quantity = "ThermodynamicTemperature");
  algorithm
    'Celsius' := 'Kelvin' - 273.15;
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_degC';

  function 'Modelica.Utilities.Streams.error' "Print error message and cancel all actions - in case of an unrecoverable error"
    input String 'string';
  algorithm
    assert(false, 'string', AssertionLevel.error);
  end 'Modelica.Utilities.Streams.error';

