    Real 'sineVoltage_p.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage_p.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage_p.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
