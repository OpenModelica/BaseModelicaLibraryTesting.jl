    Real 'resistor.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
  initial equation
    'meanVoltage.t0' = time;
    'meanVoltage.x' = 0.0;
    'meanVoltage.y_last' = 0.0;
    'rootMeanSquareVoltage.mean.t0' = time;
    'rootMeanSquareVoltage.mean.x' = 0.0;
    'rootMeanSquareVoltage.mean.y_last' = 0.0;
    'meanCurrent.t0' = time;
    'meanCurrent.x' = 0.0;
    'meanCurrent.y_last' = 0.0;
  equation
    'rectifier.powerTotalAC' = 'rectifier.powerAC[1]' + 'rectifier.powerAC[2]' + 'rectifier.powerAC[3]';
    'rectifier.vDC' = 'rectifier.dc_p.v';
    'rectifier.iDC' = 'rectifier.dc_p.i';
    'rectifier.powerDC' = 'rectifier.vDC' * 'rectifier.iDC';
    'star.plug_p.pin[3].v' = 'star.pin_n.v';
    'star.plug_p.pin[3].v' = 'star.plug_p.pin[2].v';
    'star.plug_p.pin[3].v' = 'star.plug_p.pin[1].v';
    -('star.plug_p.pin[3].i' + 'star.pin_n.i' + 'star.plug_p.pin[2].i' + 'star.plug_p.pin[1].i') = 0.0;
    'sineVoltage_p.sineVoltage[1].p.v' = 'sineVoltage_p.plug_p.pin[1].v';
    'sineVoltage_p.sineVoltage[2].p.v' = 'sineVoltage_p.plug_p.pin[2].v';
    'sineVoltage_p.sineVoltage[3].p.v' = 'sineVoltage_p.plug_p.pin[3].v';
    'sineVoltage_p.sineVoltage[1].n.v' = 'sineVoltage_p.plug_n.pin[1].v';
    'sineVoltage_p.sineVoltage[2].n.v' = 'sineVoltage_p.plug_n.pin[2].v';
    'sineVoltage_p.sineVoltage[3].n.v' = 'sineVoltage_p.plug_n.pin[3].v';
    'rectifier.diode.plug_p.pin[1].v' = 'rectifier.diode.idealDiode[1].p.v';
    'rectifier.diode.idealDiode[1].p.i' - 'rectifier.diode.plug_p.pin[1].i' = 0.0;
    'rectifier.diode.plug_p.pin[2].v' = 'rectifier.diode.idealDiode[2].p.v';
    'rectifier.diode.idealDiode[2].p.i' - 'rectifier.diode.plug_p.pin[2].i' = 0.0;
    'rectifier.diode.plug_p.pin[3].v' = 'rectifier.diode.idealDiode[3].p.v';
    'rectifier.diode.idealDiode[3].p.i' - 'rectifier.diode.plug_p.pin[3].i' = 0.0;
    'rectifier.diode.idealDiode[1].n.v' = 'rectifier.diode.plug_n.pin[1].v';
    'rectifier.diode.idealDiode[2].n.v' = 'rectifier.diode.plug_n.pin[2].v';
    'rectifier.diode.idealDiode[3].n.v' = 'rectifier.diode.plug_n.pin[3].v';
    'rectifier.star.plug_p.pin[3].v' = 'rectifier.star.pin_n.v';
    'rectifier.star.plug_p.pin[3].v' = 'rectifier.star.plug_p.pin[2].v';
    'rectifier.star.plug_p.pin[3].v' = 'rectifier.star.plug_p.pin[1].v';
    -('rectifier.star.plug_p.pin[3].i' + 'rectifier.star.pin_n.i' + 'rectifier.star.plug_p.pin[2].i' + 'rectifier.star.plug_p.pin[1].i') = 0.0;
    'rectifier.diode.plug_n.pin[1].v' = 'rectifier.star.plug_p.pin[1].v';
    'rectifier.diode.plug_n.pin[2].v' = 'rectifier.star.plug_p.pin[2].v';
    'rectifier.diode.plug_n.pin[3].v' = 'rectifier.star.plug_p.pin[3].v';
    'rectifier.star.pin_n.v' = 'rectifier.dc_p.v';
    'rectifier.ac.pin[1].v' = 'rectifier.diode.plug_p.pin[1].v';
    'rectifier.ac.pin[2].v' = 'rectifier.diode.plug_p.pin[2].v';
    'rectifier.ac.pin[3].v' = 'rectifier.diode.plug_p.pin[3].v';
    'rectifier.diode.plug_p.pin[1].i' - 'rectifier.ac.pin[1].i' = 0.0;
    'rectifier.diode.plug_p.pin[2].i' - 'rectifier.ac.pin[2].i' = 0.0;
    'rectifier.diode.plug_p.pin[3].i' - 'rectifier.ac.pin[3].i' = 0.0;
    'rootMeanSquareVoltage.product.y' = 'rootMeanSquareVoltage.mean.u';
    'rootMeanSquareVoltage.mean.y' = 'rootMeanSquareVoltage.sqrt1.u';
    'rootMeanSquareVoltage.sqrt1.y' = 'rootMeanSquareVoltage.y';
    'rootMeanSquareVoltage.u' = 'rootMeanSquareVoltage.product.u[2]';
    'rootMeanSquareVoltage.u' = 'rootMeanSquareVoltage.product.u[1]';
    'star.pin_n.v' = 'currentSensor.n.v';
    'star.pin_n.v' = 'ground.p.v';
    'meanCurrent.u' = 'currentSensor.i';
    'voltagesensor.v' = 'rootMeanSquareVoltage.u';
    'voltagesensor.v' = 'meanVoltage.u';
    'rectifier.dc_p.v' = 'resistor.p.v';
    'rectifier.dc_p.v' = 'voltagesensor.p.v';
    'resistor.n.v' = 'currentSensor.p.v';
    'resistor.n.v' = 'voltagesensor.n.v';
    'star.plug_p.pin[1].v' = 'sineVoltage_p.plug_n.pin[1].v';
    'star.plug_p.pin[2].v' = 'sineVoltage_p.plug_n.pin[2].v';
    'star.plug_p.pin[3].v' = 'sineVoltage_p.plug_n.pin[3].v';
    'rectifier.ac.pin[1].v' = 'sineVoltage_p.plug_p.pin[1].v';
    'rectifier.ac.pin[2].v' = 'sineVoltage_p.plug_p.pin[2].v';
    'rectifier.ac.pin[3].v' = 'sineVoltage_p.plug_p.pin[3].v';
    'currentSensor.n.i' + 'star.pin_n.i' + 'ground.p.i' = 0.0;
    'sineVoltage_p.plug_n.pin[1].i' + 'star.plug_p.pin[1].i' = 0.0;
    'sineVoltage_p.plug_n.pin[2].i' + 'star.plug_p.pin[2].i' = 0.0;
    'sineVoltage_p.plug_n.pin[3].i' + 'star.plug_p.pin[3].i' = 0.0;
    'sineVoltage_p.sineVoltage[1].p.i' - 'sineVoltage_p.plug_p.pin[1].i' = 0.0;
    'sineVoltage_p.sineVoltage[1].n.i' - 'sineVoltage_p.plug_n.pin[1].i' = 0.0;
    'sineVoltage_p.sineVoltage[2].p.i' - 'sineVoltage_p.plug_p.pin[2].i' = 0.0;
    'sineVoltage_p.sineVoltage[2].n.i' - 'sineVoltage_p.plug_n.pin[2].i' = 0.0;
    'sineVoltage_p.sineVoltage[3].p.i' - 'sineVoltage_p.plug_p.pin[3].i' = 0.0;
    'sineVoltage_p.sineVoltage[3].n.i' - 'sineVoltage_p.plug_n.pin[3].i' = 0.0;
    'rectifier.ac.pin[1].i' + 'sineVoltage_p.plug_p.pin[1].i' = 0.0;
    'rectifier.ac.pin[2].i' + 'sineVoltage_p.plug_p.pin[2].i' = 0.0;
    'rectifier.ac.pin[3].i' + 'sineVoltage_p.plug_p.pin[3].i' = 0.0;
    'rectifier.star.plug_p.pin[1].i' + 'rectifier.diode.plug_n.pin[1].i' = 0.0;
    'rectifier.star.plug_p.pin[2].i' + 'rectifier.diode.plug_n.pin[2].i' = 0.0;
    'rectifier.star.plug_p.pin[3].i' + 'rectifier.diode.plug_n.pin[3].i' = 0.0;
    'rectifier.diode.idealDiode[1].n.i' - 'rectifier.diode.plug_n.pin[1].i' = 0.0;
    'rectifier.diode.idealDiode[2].n.i' - 'rectifier.diode.plug_n.pin[2].i' = 0.0;
    'rectifier.diode.idealDiode[3].n.i' - 'rectifier.diode.plug_n.pin[3].i' = 0.0;
    'rectifier.star.pin_n.i' - 'rectifier.dc_p.i' = 0.0;
    'resistor.p.i' + 'voltagesensor.p.i' + 'rectifier.dc_p.i' = 0.0;
    'resistor.n.i' + 'currentSensor.p.i' + 'voltagesensor.n.i' = 0.0;
    'ground.p.v' = 0.0;
    'sineVoltage_p.sineVoltage[1].signalSource.y' = if time < 0.0 then 0.0 else 155.56349186104046 * 'Modelica.Math.sin'(314.1592653589793 * time);
    'sineVoltage_p.sineVoltage[1].v' = 'sineVoltage_p.sineVoltage[1].signalSource.y';
    0.0 = 'sineVoltage_p.sineVoltage[1].p.i' + 'sineVoltage_p.sineVoltage[1].n.i';
    'sineVoltage_p.sineVoltage[1].i' = 'sineVoltage_p.sineVoltage[1].p.i';
    'sineVoltage_p.sineVoltage[1].v' = 'sineVoltage_p.sineVoltage[1].p.v' - 'sineVoltage_p.sineVoltage[1].n.v';
    'sineVoltage_p.sineVoltage[2].signalSource.y' = if time < 0.0 then 0.0 else 155.56349186104046 * 'Modelica.Math.sin'(314.1592653589793 * time - 2.0943951023931953);
    'sineVoltage_p.sineVoltage[2].v' = 'sineVoltage_p.sineVoltage[2].signalSource.y';
    0.0 = 'sineVoltage_p.sineVoltage[2].p.i' + 'sineVoltage_p.sineVoltage[2].n.i';
    'sineVoltage_p.sineVoltage[2].i' = 'sineVoltage_p.sineVoltage[2].p.i';
    'sineVoltage_p.sineVoltage[2].v' = 'sineVoltage_p.sineVoltage[2].p.v' - 'sineVoltage_p.sineVoltage[2].n.v';
    'sineVoltage_p.sineVoltage[3].signalSource.y' = if time < 0.0 then 0.0 else 155.56349186104046 * 'Modelica.Math.sin'(314.1592653589793 * time - 4.1887902047863905);
    'sineVoltage_p.sineVoltage[3].v' = 'sineVoltage_p.sineVoltage[3].signalSource.y';
    0.0 = 'sineVoltage_p.sineVoltage[3].p.i' + 'sineVoltage_p.sineVoltage[3].n.i';
    'sineVoltage_p.sineVoltage[3].i' = 'sineVoltage_p.sineVoltage[3].p.i';
    'sineVoltage_p.sineVoltage[3].v' = 'sineVoltage_p.sineVoltage[3].p.v' - 'sineVoltage_p.sineVoltage[3].n.v';
    'sineVoltage_p.v[1]' = 'sineVoltage_p.plug_p.pin[1].v' - 'sineVoltage_p.plug_n.pin[1].v';
    'sineVoltage_p.v[2]' = 'sineVoltage_p.plug_p.pin[2].v' - 'sineVoltage_p.plug_n.pin[2].v';
    'sineVoltage_p.v[3]' = 'sineVoltage_p.plug_p.pin[3].v' - 'sineVoltage_p.plug_n.pin[3].v';
    'sineVoltage_p.i[1]' = 'sineVoltage_p.plug_p.pin[1].i';
    'sineVoltage_p.i[2]' = 'sineVoltage_p.plug_p.pin[2].i';
    'sineVoltage_p.i[3]' = 'sineVoltage_p.plug_p.pin[3].i';
    'rectifier.vAC[1]' = 'rectifier.ac.pin[1].v';
    'rectifier.vAC[2]' = 'rectifier.ac.pin[2].v';
    'rectifier.vAC[3]' = 'rectifier.ac.pin[3].v';
    'rectifier.iAC[1]' = 'rectifier.ac.pin[1].i';
    'rectifier.iAC[2]' = 'rectifier.ac.pin[2].i';
    'rectifier.iAC[3]' = 'rectifier.ac.pin[3].i';
    'rectifier.powerAC[1]' = 'rectifier.vAC[1]' * 'rectifier.iAC[1]';
    'rectifier.powerAC[2]' = 'rectifier.vAC[2]' * 'rectifier.iAC[2]';
    'rectifier.powerAC[3]' = 'rectifier.vAC[3]' * 'rectifier.iAC[3]';
    'rectifier.diode.idealDiode[1].off' = 'rectifier.diode.idealDiode[1].s' < 0.0;
    'rectifier.diode.idealDiode[1].v' = 'rectifier.diode.idealDiode[1].s' * (if 'rectifier.diode.idealDiode[1].off' then 1.0 else 1e-5);
    'rectifier.diode.idealDiode[1].i' = 'rectifier.diode.idealDiode[1].s' * (if 'rectifier.diode.idealDiode[1].off' then 1e-5 else 1.0);
    'rectifier.diode.idealDiode[1].LossPower' = 'rectifier.diode.idealDiode[1].v' * 'rectifier.diode.idealDiode[1].i';
    'rectifier.diode.idealDiode[1].T_heatPort' = 293.15;
    0.0 = 'rectifier.diode.idealDiode[1].p.i' + 'rectifier.diode.idealDiode[1].n.i';
    'rectifier.diode.idealDiode[1].i' = 'rectifier.diode.idealDiode[1].p.i';
    'rectifier.diode.idealDiode[1].v' = 'rectifier.diode.idealDiode[1].p.v' - 'rectifier.diode.idealDiode[1].n.v';
    'rectifier.diode.idealDiode[2].off' = 'rectifier.diode.idealDiode[2].s' < 0.0;
    'rectifier.diode.idealDiode[2].v' = 'rectifier.diode.idealDiode[2].s' * (if 'rectifier.diode.idealDiode[2].off' then 1.0 else 1e-5);
    'rectifier.diode.idealDiode[2].i' = 'rectifier.diode.idealDiode[2].s' * (if 'rectifier.diode.idealDiode[2].off' then 1e-5 else 1.0);
    'rectifier.diode.idealDiode[2].LossPower' = 'rectifier.diode.idealDiode[2].v' * 'rectifier.diode.idealDiode[2].i';
    'rectifier.diode.idealDiode[2].T_heatPort' = 293.15;
    0.0 = 'rectifier.diode.idealDiode[2].p.i' + 'rectifier.diode.idealDiode[2].n.i';
    'rectifier.diode.idealDiode[2].i' = 'rectifier.diode.idealDiode[2].p.i';
    'rectifier.diode.idealDiode[2].v' = 'rectifier.diode.idealDiode[2].p.v' - 'rectifier.diode.idealDiode[2].n.v';
    'rectifier.diode.idealDiode[3].off' = 'rectifier.diode.idealDiode[3].s' < 0.0;
    'rectifier.diode.idealDiode[3].v' = 'rectifier.diode.idealDiode[3].s' * (if 'rectifier.diode.idealDiode[3].off' then 1.0 else 1e-5);
    'rectifier.diode.idealDiode[3].i' = 'rectifier.diode.idealDiode[3].s' * (if 'rectifier.diode.idealDiode[3].off' then 1e-5 else 1.0);
    'rectifier.diode.idealDiode[3].LossPower' = 'rectifier.diode.idealDiode[3].v' * 'rectifier.diode.idealDiode[3].i';
    'rectifier.diode.idealDiode[3].T_heatPort' = 293.15;
    0.0 = 'rectifier.diode.idealDiode[3].p.i' + 'rectifier.diode.idealDiode[3].n.i';
    'rectifier.diode.idealDiode[3].i' = 'rectifier.diode.idealDiode[3].p.i';
    'rectifier.diode.idealDiode[3].v' = 'rectifier.diode.idealDiode[3].p.v' - 'rectifier.diode.idealDiode[3].n.v';
    'rectifier.diode.v[1]' = 'rectifier.diode.plug_p.pin[1].v' - 'rectifier.diode.plug_n.pin[1].v';
    'rectifier.diode.v[2]' = 'rectifier.diode.plug_p.pin[2].v' - 'rectifier.diode.plug_n.pin[2].v';
    'rectifier.diode.v[3]' = 'rectifier.diode.plug_p.pin[3].v' - 'rectifier.diode.plug_n.pin[3].v';
    'rectifier.diode.i[1]' = 'rectifier.diode.plug_p.pin[1].i';
    'rectifier.diode.i[2]' = 'rectifier.diode.plug_p.pin[2].i';
    'rectifier.diode.i[3]' = 'rectifier.diode.plug_p.pin[3].i';
    'rectifier.LossPower' = 'rectifier.diode.idealDiode[1].LossPower' + 'rectifier.diode.idealDiode[2].LossPower' + 'rectifier.diode.idealDiode[3].LossPower';
    'rectifier.T_heatPort' = 293.15;
    'voltagesensor.p.i' = 0.0;
    'voltagesensor.n.i' = 0.0;
    'voltagesensor.v' = 'voltagesensor.p.v' - 'voltagesensor.n.v';
    der('meanVoltage.x') = 'meanVoltage.u';

    when sample('meanVoltage.t0' + 0.006666666666666667, 0.006666666666666667) then
      'meanVoltage.y_last' = 150.0 * pre('meanVoltage.x');
      reinit('meanVoltage.x', 0.0);
    end when;

    'meanVoltage.y' = 'meanVoltage.y_last';
    'rootMeanSquareVoltage.product.y' = 'rootMeanSquareVoltage.product.u[1]' * 'rootMeanSquareVoltage.product.u[2]';
    der('rootMeanSquareVoltage.mean.x') = 'rootMeanSquareVoltage.mean.u';

    when sample('rootMeanSquareVoltage.mean.t0' + 0.006666666666666667, 0.006666666666666667) then
      'rootMeanSquareVoltage.mean.y_last' = max(0.0, 150.0 * pre('rootMeanSquareVoltage.mean.x'));
      reinit('rootMeanSquareVoltage.mean.x', 0.0);
    end when;

    'rootMeanSquareVoltage.mean.y' = 'rootMeanSquareVoltage.mean.y_last';
    'rootMeanSquareVoltage.sqrt1.y' = sqrt('rootMeanSquareVoltage.sqrt1.u');
    'currentSensor.p.v' = 'currentSensor.n.v';
    'currentSensor.p.i' = 'currentSensor.i';
    'currentSensor.n.i' = -'currentSensor.i';
    der('meanCurrent.x') = 'meanCurrent.u';

    when sample('meanCurrent.t0' + 0.006666666666666667, 0.006666666666666667) then
      'meanCurrent.y_last' = 150.0 * pre('meanCurrent.x');
      reinit('meanCurrent.x', 0.0);
    end when;

    'meanCurrent.y' = 'meanCurrent.y_last';
    'resistor.R_actual' = 20.0;
    'resistor.v' = 'resistor.R_actual' * 'resistor.i';
    'resistor.LossPower' = 'resistor.v' * 'resistor.i';
    'resistor.T_heatPort' = 300.15;
    0.0 = 'resistor.p.i' + 'resistor.n.i';
    'resistor.i' = 'resistor.p.i';
    'resistor.v' = 'resistor.p.v' - 'resistor.n.v';
    annotation(experiment(StopTime = 0.1, Tolerance = 1e-06, Interval = 0.0002));
  end 'DiodeCenterTapmPulse';
end 'DiodeCenterTapmPulse';
