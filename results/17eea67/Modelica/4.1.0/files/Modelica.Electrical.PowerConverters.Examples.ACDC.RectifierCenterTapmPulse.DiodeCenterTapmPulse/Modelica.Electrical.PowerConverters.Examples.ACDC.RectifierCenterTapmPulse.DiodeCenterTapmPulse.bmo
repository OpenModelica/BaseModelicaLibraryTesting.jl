//! base 0.1.0
package 'DiodeCenterTapmPulse'
  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  model 'DiodeCenterTapmPulse' "2*m pulse diode rectifier with center tap with resistive load"
    parameter Integer 'm'(min = 3) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'Vrms'(unit = "V", quantity = "ElectricPotential") = 110.0 "RMS supply voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Frequency";
    parameter Real 'R'(unit = "Ohm", quantity = "Resistance") = 20.0 "Load resistance";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'star.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
