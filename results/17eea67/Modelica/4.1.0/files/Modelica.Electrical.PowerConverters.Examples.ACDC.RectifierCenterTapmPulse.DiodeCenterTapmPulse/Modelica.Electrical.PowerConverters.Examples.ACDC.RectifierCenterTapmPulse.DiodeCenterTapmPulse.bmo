    Real 'rectifier.diode.idealDiode[3].s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'rectifier.diode.idealDiode[3].unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'rectifier.diode.idealDiode[3].unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
