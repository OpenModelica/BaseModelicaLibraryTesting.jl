    constant Real 'rectifier.diode.idealDiode[1].unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Real 'rectifier.diode.idealDiode[2].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
