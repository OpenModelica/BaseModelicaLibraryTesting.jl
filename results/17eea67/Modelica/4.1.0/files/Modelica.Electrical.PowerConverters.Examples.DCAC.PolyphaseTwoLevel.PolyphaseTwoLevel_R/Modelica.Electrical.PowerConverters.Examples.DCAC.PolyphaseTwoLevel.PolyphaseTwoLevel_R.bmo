    'fundamentalWaveCurrent[1].rectangularToPolar.y_arg' = 'Modelica.Math.atan2'('fundamentalWaveCurrent[1].rectangularToPolar.u_im', 'fundamentalWaveCurrent[1].rectangularToPolar.u_re');
