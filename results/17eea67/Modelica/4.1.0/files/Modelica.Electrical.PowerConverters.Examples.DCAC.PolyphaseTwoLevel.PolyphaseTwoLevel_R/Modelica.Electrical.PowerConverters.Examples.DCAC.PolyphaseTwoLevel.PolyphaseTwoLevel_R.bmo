    'fundamentalWaveCurrent[3].gain.y' = 'fundamentalWaveCurrent[3].gain.u';
    'fundamentalWaveVoltage[1].sin1.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * 'Modelica.Math.cos'(314.1592653589793 * time);
