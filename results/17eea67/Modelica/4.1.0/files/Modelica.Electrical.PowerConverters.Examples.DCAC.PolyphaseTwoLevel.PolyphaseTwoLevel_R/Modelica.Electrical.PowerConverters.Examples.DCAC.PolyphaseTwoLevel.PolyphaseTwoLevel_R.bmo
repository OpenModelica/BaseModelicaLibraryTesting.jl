//! base 0.1.0
package 'PolyphaseTwoLevel_R'
  function 'Modelica.Math.atan2' "Four quadrant inverse tangent"
    input Real 'u1';
    input Real 'u2';
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := atan2('u1', 'u2');
    annotation(Inline = true);
  end 'Modelica.Math.atan2';

  function 'Modelica.Math.cos' "Cosine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := cos('u');
    annotation(Inline = true);
  end 'Modelica.Math.cos';

  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  type 'Modelica.Electrical.PowerConverters.Types.SingleReferenceType' = enumeration('Sawtooth', 'Triangle');

  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'PolyphaseTwoLevel_R' "Polyphase DC to AC converter with R load"
    parameter Integer 'm' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 1000.0 "Switching frequency";
    parameter Real 'f1'(unit = "Hz", quantity = "Frequency") = 50.0 "Fundamental wave AC frequency";
    parameter Real 'R'(unit = "Ohm", quantity = "Resistance") = 100.0 "Resistance";
    parameter Real 'constantVoltage_n.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 50.0 "Value of constant voltage";
    Real 'constantVoltage_n.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'constantVoltage_n.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'constantVoltage_n.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'constantVoltage_n.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'constantVoltage_n.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'constantVoltage_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'inverter.useConstantEnable' = true "Disable boolean input and use constantEnable, if true";
    parameter Boolean 'inverter.constantEnable' = true "Constant enabling of firing signals";
    parameter Integer 'inverter.m'(min = 3) = 3 "Number of phases" annotation(Evaluate = true);
    Boolean 'inverter.andCondition_p[1].u1' "Connector of first Boolean input signal";
    Boolean 'inverter.andCondition_p[1].u2' "Connector of second Boolean input signal";
    Boolean 'inverter.andCondition_p[1].y' "Connector of Boolean output signal";
    Boolean 'inverter.andCondition_p[2].u1' "Connector of first Boolean input signal";
    Boolean 'inverter.andCondition_p[2].u2' "Connector of second Boolean input signal";
    Boolean 'inverter.andCondition_p[2].y' "Connector of Boolean output signal";
    Boolean 'inverter.andCondition_p[3].u1' "Connector of first Boolean input signal";
    Boolean 'inverter.andCondition_p[3].u2' "Connector of second Boolean input signal";
    Boolean 'inverter.andCondition_p[3].y' "Connector of Boolean output signal";
    Boolean 'inverter.fire_p[1]' "Firing signals of positive potential transistors";
    Boolean 'inverter.fire_p[2]' "Firing signals of positive potential transistors";
    Boolean 'inverter.fire_p[3]' "Firing signals of positive potential transistors";
    parameter Boolean 'inverter.enableLogic.useConstantEnable' = true "Disable boolean input and use constantEnable, if true";
    parameter Boolean 'inverter.enableLogic.constantEnable' = true "Constant enabling of firing signals";
    parameter Integer 'inverter.enableLogic.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Boolean 'inverter.enableLogic.enableConstantSource.k' = true "Constant output value";
    Boolean 'inverter.enableLogic.enableConstantSource.y' "Connector of Boolean output signal";
    parameter Integer 'inverter.enableLogic.booleanReplicator.nout' = 3 "Number of outputs";
    Boolean 'inverter.enableLogic.booleanReplicator.u' "Connector of Boolean input signal";
    Boolean 'inverter.enableLogic.booleanReplicator.y[1]' "Connector of Boolean output signals";
    Boolean 'inverter.enableLogic.booleanReplicator.y[2]' "Connector of Boolean output signals";
    Boolean 'inverter.enableLogic.booleanReplicator.y[3]' "Connector of Boolean output signals";
    Boolean 'inverter.enableLogic.internalEnable[1]' "m replicated enable signals";
    Boolean 'inverter.enableLogic.internalEnable[2]' "m replicated enable signals";
    Boolean 'inverter.enableLogic.internalEnable[3]' "m replicated enable signals";
    Boolean 'inverter.andCondition_n[1].u1' "Connector of first Boolean input signal";
    Boolean 'inverter.andCondition_n[1].u2' "Connector of second Boolean input signal";
    Boolean 'inverter.andCondition_n[1].y' "Connector of Boolean output signal";
    Boolean 'inverter.andCondition_n[2].u1' "Connector of first Boolean input signal";
    Boolean 'inverter.andCondition_n[2].u2' "Connector of second Boolean input signal";
    Boolean 'inverter.andCondition_n[2].y' "Connector of Boolean output signal";
    Boolean 'inverter.andCondition_n[3].u1' "Connector of first Boolean input signal";
    Boolean 'inverter.andCondition_n[3].u2' "Connector of second Boolean input signal";
    Boolean 'inverter.andCondition_n[3].y' "Connector of Boolean output signal";
    Boolean 'inverter.fire_n[1]' "Firing signals of negative potential transistors";
    Boolean 'inverter.fire_n[2]' "Firing signals of negative potential transistors";
    Boolean 'inverter.fire_n[3]' "Firing signals of negative potential transistors";
    parameter Real 'inverter.RonTransistor'(unit = "Ohm", quantity = "Resistance") = 1e-5 "Transistor closed resistance";
    parameter Real 'inverter.GoffTransistor'(unit = "S", quantity = "Conductance") = 1e-5 "Transistor opened conductance";
    parameter Real 'inverter.VkneeTransistor'(unit = "V", quantity = "ElectricPotential") = 0.0 "Transistor threshold voltage";
    parameter Real 'inverter.RonDiode'(unit = "Ohm", quantity = "Resistance") = 1e-5 "Diode closed resistance";
    parameter Real 'inverter.GoffDiode'(unit = "S", quantity = "Conductance") = 1e-5 "Diode opened conductance";
    parameter Real 'inverter.VkneeDiode'(unit = "V", quantity = "ElectricPotential") = 0.0 "Diode threshold voltage";
    Real 'inverter.dc_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.dc_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.dc_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.dc_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.vDC'(unit = "V", quantity = "ElectricPotential") "DC voltage";
    Real 'inverter.iDC'(unit = "A", quantity = "ElectricCurrent") "DC current";
    Real 'inverter.powerDC'(unit = "W", quantity = "Power") "DC power";
    parameter Integer 'inverter.ac.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'inverter.ac.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.ac.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.ac.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.ac.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.ac.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.ac.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.vAC[1]'(unit = "V", quantity = "ElectricPotential") "AC potential";
    Real 'inverter.vAC[2]'(unit = "V", quantity = "ElectricPotential") "AC potential";
    Real 'inverter.vAC[3]'(unit = "V", quantity = "ElectricPotential") "AC potential";
    Real 'inverter.iAC[1]'(unit = "A", quantity = "ElectricCurrent") "AC current";
    Real 'inverter.iAC[2]'(unit = "A", quantity = "ElectricCurrent") "AC current";
    Real 'inverter.iAC[3]'(unit = "A", quantity = "ElectricCurrent") "AC current";
    Real 'inverter.powerAC[1]'(unit = "W", quantity = "Power") "AC power";
    Real 'inverter.powerAC[2]'(unit = "W", quantity = "Power") "AC power";
    Real 'inverter.powerAC[3]'(unit = "W", quantity = "Power") "AC power";
    Real 'inverter.powerTotalAC'(unit = "W", quantity = "Power") "AC total power";
    parameter Boolean 'inverter.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'inverter.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'inverter.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'inverter.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    parameter Integer 'inverter.transistor_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'inverter.transistor_p.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'inverter.transistor_p.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'inverter.transistor_p.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'inverter.transistor_p.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'inverter.transistor_p.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'inverter.transistor_p.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    parameter Integer 'inverter.transistor_p.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'inverter.transistor_p.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.transistor_p.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.transistor_p.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'inverter.transistor_p.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'inverter.transistor_p.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.transistor_p.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.transistor_p.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'inverter.transistor_p.Ron[1]'(start = 1e-5, min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Closed thyristor resistance";
    parameter Real 'inverter.transistor_p.Ron[2]'(start = 1e-5, min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Closed thyristor resistance";
    parameter Real 'inverter.transistor_p.Ron[3]'(start = 1e-5, min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Closed thyristor resistance";
    parameter Real 'inverter.transistor_p.Goff[1]'(start = 1e-5, min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Opened thyristor conductance";
    parameter Real 'inverter.transistor_p.Goff[2]'(start = 1e-5, min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Opened thyristor conductance";
    parameter Real 'inverter.transistor_p.Goff[3]'(start = 1e-5, min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Opened thyristor conductance";
    parameter Real 'inverter.transistor_p.Vknee[1]'(start = 0.0, min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Threshold voltage";
    parameter Real 'inverter.transistor_p.Vknee[2]'(start = 0.0, min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Threshold voltage";
    parameter Real 'inverter.transistor_p.Vknee[3]'(start = 0.0, min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Threshold voltage";
    parameter Integer 'inverter.transistor_p.mh'(min = 1) = 3 "Number of heatPorts=number of phases";
    parameter Boolean 'inverter.transistor_p.useHeatPort' = false "= true, if all heat ports are enabled" annotation(Evaluate = true);
    parameter Real 'inverter.transistor_p.T[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'inverter.transistor_p.T[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'inverter.transistor_p.T[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    Boolean 'inverter.transistor_p.fire[1]';
    Boolean 'inverter.transistor_p.fire[2]';
    Boolean 'inverter.transistor_p.fire[3]';
    Real 'inverter.transistor_p.idealGTOThyristor[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inverter.transistor_p.idealGTOThyristor[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.idealGTOThyristor[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.transistor_p.idealGTOThyristor[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverter.transistor_p.idealGTOThyristor[1].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverter.transistor_p.idealGTOThyristor[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inverter.transistor_p.idealGTOThyristor[1].Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'inverter.transistor_p.idealGTOThyristor[1].Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'inverter.transistor_p.idealGTOThyristor[1].Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'inverter.transistor_p.idealGTOThyristor[1].useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'inverter.transistor_p.idealGTOThyristor[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'inverter.transistor_p.idealGTOThyristor[1].LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'inverter.transistor_p.idealGTOThyristor[1].T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'inverter.transistor_p.idealGTOThyristor[1].off'(start = true) "Switching state";
    Real 'inverter.transistor_p.idealGTOThyristor[1].s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'inverter.transistor_p.idealGTOThyristor[1].unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'inverter.transistor_p.idealGTOThyristor[1].unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Boolean 'inverter.transistor_p.idealGTOThyristor[1].fire';
