//! base 0.1.0
package 'SaturatedInductor'
  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  model 'SaturatedInductor' "Inductor with saturation in the ferromagnetic core"
    Real 'ground_m.port.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'ground_m.port.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    parameter Real 'source.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 325.2691193458119 "Amplitude of sine wave";
    parameter Real 'source.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267948966 "Phase of sine wave";
    parameter Real 'source.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    Real 'source.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'source.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'source.signalSource.amplitude' = 325.2691193458119 "Amplitude of sine wave";
    parameter Real 'source.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'source.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267948966 "Phase of sine wave";
    parameter Boolean 'source.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'source.signalSource.y' "Connector of Real output signal";
    parameter Real 'source.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'source.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'source.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'source.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'r.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 7.5 "Resistance at temperature T_ref";
    parameter Real 'r.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'r.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'r.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'r.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'r.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'r.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'r.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'r.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'r.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'r.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'r.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'r.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'r.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'coil.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'coil.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'coil.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'coil.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'coil.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'coil.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'coil.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'coil.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'coil.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'coil.i'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'coil.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'coil.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux coupled into magnetic circuit";
    parameter Real 'coil.N' = 600.0 "Number of turns";
    Real 'coil.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'coil.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    Real 'coil.eps';
    Real 'r_mLeak.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'r_mLeak.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'r_mLeak.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'r_mLeak.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'r_mLeak.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'r_mLeak.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'r_mLeak.R_m'(unit = "H-1", quantity = "Reluctance") = 1.2e6 "Magnetic reluctance";
    Real 'r_mAirPar.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'r_mAirPar.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'r_mAirPar.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'r_mAirPar.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'r_mAirPar.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'r_mAirPar.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'r_mAirPar.nonLinearPermeability' = false "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'r_mAirPar.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'r_mAirPar.material.label' = "SoftMagnetic" "Name of material";
    parameter Real 'r_mAirPar.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1.0 "Initial relative permeability at B=0";
    parameter Real 'r_mAirPar.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Flux density at maximum relative permeability";
    parameter Real 'r_mAirPar.material.c_a' = 1.0 "Coefficient of approximation function";
    parameter Real 'r_mAirPar.material.c_b' = 1.0 "Coefficient of approximation function";
    parameter Real 'r_mAirPar.material.n' = 1.0 "Exponent of approximation function";
    Real 'r_mAirPar.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'r_mAirPar.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'r_mAirPar.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'r_mAirPar.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'r_mAirPar.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'r_mAirPar.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'r_mAirPar.B_N' "Absolute value of normalized B";
    parameter Real 'r_mAirPar.l'(unit = "m", quantity = "Length") = 1e-4 "Length in direction of flux";
    parameter Real 'r_mAirPar.a'(unit = "m", quantity = "Length") = 0.025 "Width of rectangular cross-section";
    parameter Real 'r_mAirPar.b'(unit = "m", quantity = "Length") = 0.025 "Height of rectangular cross-section";
    Real 'r_mFe.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'r_mFe.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'r_mFe.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'r_mFe.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'r_mFe.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'r_mFe.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'r_mFe.nonLinearPermeability' = true "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'r_mFe.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'r_mFe.material.label' = "M350-50A" "Name of material";
    parameter Real 'r_mFe.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1210.0 "Initial relative permeability at B=0";
    parameter Real 'r_mFe.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.16 "Flux density at maximum relative permeability";
    parameter Real 'r_mFe.material.c_a' = 24630.0 "Coefficient of approximation function";
    parameter Real 'r_mFe.material.c_b' = 2.44 "Coefficient of approximation function";
    parameter Real 'r_mFe.material.n' = 14.0 "Exponent of approximation function";
    Real 'r_mFe.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'r_mFe.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'r_mFe.B'(start = 0.0, unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'r_mFe.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'r_mFe.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'r_mFe.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'r_mFe.B_N' "Absolute value of normalized B";
    parameter Real 'r_mFe.l'(unit = "m", quantity = "Length") = 0.26 "Length in direction of flux";
    parameter Real 'r_mFe.a'(unit = "m", quantity = "Length") = 0.025 "Width of rectangular cross-section";
    parameter Real 'r_mFe.b'(unit = "m", quantity = "Length") = 0.025 "Height of rectangular cross-section";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
  equation
    'coil.eps' = 2.220446049250313e-14;
    'source.p.v' = 'r.p.v';
    'r.n.v' = 'coil.p.v';
    'ground.p.v' = 'source.n.v';
    'ground.p.v' = 'coil.n.v';
    'r_mLeak.port_p.V_m' = 'r_mAirPar.port_p.V_m';
    'r_mLeak.port_p.V_m' = 'coil.port_p.V_m';
    'r_mAirPar.port_n.V_m' = 'r_mFe.port_p.V_m';
    'ground_m.port.V_m' = 'r_mFe.port_n.V_m';
    'ground_m.port.V_m' = 'coil.port_n.V_m';
    'ground_m.port.V_m' = 'r_mLeak.port_n.V_m';
    'r.p.i' + 'source.p.i' = 0.0;
    'coil.p.i' + 'r.n.i' = 0.0;
    'r_mAirPar.port_p.Phi' + 'r_mLeak.port_p.Phi' + 'coil.port_p.Phi' = 0.0;
    'r_mFe.port_n.Phi' + 'r_mLeak.port_n.Phi' + 'coil.port_n.Phi' + 'ground_m.port.Phi' = 0.0;
    'ground.p.i' + 'coil.n.i' + 'source.n.i' = 0.0;
    'r_mFe.port_p.Phi' + 'r_mAirPar.port_n.Phi' = 0.0;
    'ground_m.port.V_m' = 0.0;
    'source.signalSource.y' = if time < 0.0 then 0.0 else 325.2691193458119 * 'Modelica.Math.sin'(314.1592653589793 * time + 1.5707963267948966);
    'source.v' = 'source.signalSource.y';
    0.0 = 'source.p.i' + 'source.n.i';
    'source.i' = 'source.p.i';
    'source.v' = 'source.p.v' - 'source.n.v';
    'r.R_actual' = 7.5;
    'r.v' = 'r.R_actual' * 'r.i';
    'r.LossPower' = 'r.v' * 'r.i';
    'r.T_heatPort' = 300.15;
    0.0 = 'r.p.i' + 'r.n.i';
    'r.i' = 'r.p.i';
    'r.v' = 'r.p.v' - 'r.n.v';
    'coil.v' = 'coil.p.v' - 'coil.n.v';
    0.0 = 'coil.p.i' + 'coil.n.i';
    'coil.i' = 'coil.p.i';
    'coil.V_m' = 'coil.port_p.V_m' - 'coil.port_n.V_m';
    0.0 = 'coil.port_p.Phi' + 'coil.port_n.Phi';
    'coil.Phi' = 'coil.port_p.Phi';
    'coil.V_m' = 'coil.i' * 600.0 "Ampere's law";
    600.0 * der('coil.Phi') = -'coil.v' "Faraday's law";
    'coil.Psi' = 600.0 * 'coil.Phi';
    'coil.L_stat' = noEvent(if abs('coil.i') > 'coil.eps' then abs('coil.Psi' / 'coil.i') else abs('coil.Psi' / 'coil.eps'));
    'r_mLeak.V_m' = 'r_mLeak.Phi' * 1.2e6;
    0.0 = 'r_mLeak.port_p.Phi' + 'r_mLeak.port_n.Phi';
    'r_mLeak.V_m' = 'r_mLeak.port_p.V_m' - 'r_mLeak.port_n.V_m';
    'r_mLeak.Phi' = 'r_mLeak.port_p.Phi';
    'r_mAirPar.A' = 6.250000000000001e-4;
    'r_mAirPar.G_m' = 1.25663706212e-6 * 'r_mAirPar.mu_r' * 'r_mAirPar.A' / 1e-4;
    'r_mAirPar.B_N' = abs('r_mAirPar.B' / 'r_mAirPar.material.B_myMax');
    'r_mAirPar.mu_r' = 1.0;
    'r_mAirPar.R_m' = 1.0 / 'r_mAirPar.G_m';
    'r_mAirPar.V_m' = 'r_mAirPar.Phi' * 'r_mAirPar.R_m';
    'r_mAirPar.B' = 'r_mAirPar.Phi' / 'r_mAirPar.A';
    'r_mAirPar.H' = 'r_mAirPar.B' / (1.25663706212e-6 * 'r_mAirPar.mu_r');
    0.0 = 'r_mAirPar.port_p.Phi' + 'r_mAirPar.port_n.Phi';
    'r_mAirPar.V_m' = 'r_mAirPar.port_p.V_m' - 'r_mAirPar.port_n.V_m';
    'r_mAirPar.Phi' = 'r_mAirPar.port_p.Phi';
    'r_mFe.A' = 6.250000000000001e-4;
    'r_mFe.G_m' = 1.25663706212e-6 * 'r_mFe.mu_r' * 'r_mFe.A' / 0.26;
    'r_mFe.B_N' = abs('r_mFe.B' / 'r_mFe.material.B_myMax');
    'r_mFe.mu_r' = 1.0 + ('r_mFe.material.mu_i' - 1.0 + 'r_mFe.material.c_a' * 'r_mFe.B_N') / (1.0 + 'r_mFe.material.c_b' * 'r_mFe.B_N' + 'r_mFe.B_N' ^ 'r_mFe.material.n');
    'r_mFe.R_m' = 1.0 / 'r_mFe.G_m';
    'r_mFe.V_m' = 'r_mFe.Phi' * 'r_mFe.R_m';
    'r_mFe.B' = 'r_mFe.Phi' / 'r_mFe.A';
    'r_mFe.H' = 'r_mFe.B' / (1.25663706212e-6 * 'r_mFe.mu_r');
    0.0 = 'r_mFe.port_p.Phi' + 'r_mFe.port_n.Phi';
    'r_mFe.V_m' = 'r_mFe.port_p.V_m' - 'r_mFe.port_n.V_m';
    'r_mFe.Phi' = 'r_mFe.port_p.Phi';
    'ground.p.v' = 0.0;
    annotation(experiment(StopTime = 0.1, Tolerance = 1e-007));
  end 'SaturatedInductor';
end 'SaturatedInductor';
