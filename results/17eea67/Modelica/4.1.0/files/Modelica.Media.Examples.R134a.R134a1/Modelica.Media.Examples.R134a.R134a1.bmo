//! base 0.1.0
package 'R134a1'
  function 'Modelica.Math.exp' "Exponential, base e"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := exp('u');
    annotation(Inline = true);
  end 'Modelica.Math.exp';

  function 'Modelica.Math.log' "Natural (base e) logarithm (u shall be > 0)"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := log('u');
    annotation(Inline = true);
  end 'Modelica.Math.log';

  function 'Modelica.Media.Common.Helmholtz_ph' "Function to calculate analytic derivatives for computing d and t given p and h"
    input 'Modelica.Media.Common.HelmholtzDerivs' 'f';
    output 'Modelica.Media.Common.NewtonDerivatives_ph' 'nderivs';
    Real 'cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'cv' := -'f'.'R_s' * ('f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
    'nderivs'.'p' := 'f'.'d' * 'f'.'R_s' * 'f'.'T' * 'f'.'delta' * 'f'.'fdelta';
    'nderivs'.'h' := 'f'.'R_s' * 'f'.'T' * ('f'.'tau' * 'f'.'ftau' + 'f'.'delta' * 'f'.'fdelta');
    'nderivs'.'pd' := 'f'.'R_s' * 'f'.'T' * 'f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta');
    'nderivs'.'pt' := 'f'.'R_s' * 'f'.'d' * 'f'.'delta' * ('f'.'fdelta' - 'f'.'tau' * 'f'.'fdeltatau');
    'nderivs'.'ht' := 'cv' + 'nderivs'.'pt' / 'f'.'d';
    'nderivs'.'hd' := ('nderivs'.'pd' - 'f'.'T' * 'nderivs'.'pt' / 'f'.'d') / 'f'.'d';
  end 'Modelica.Media.Common.Helmholtz_ph';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.R134a_liqofdT' "Properties on liquid boundary phase"
    input Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'liq';
    Real 'T_liq'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'd_liq'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
  algorithm
    if 'T' < 374.18 then
      'd_liq' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.bubbleDensity'('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_T'('T'));
      'T_liq' := 'T';
    elseif true then
      'd_liq' := 508.0;
      'T_liq' := 374.18;
    end if;

    'f' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.f_R134a'('d_liq', 'T_liq');
    'liq' := 'Modelica.Media.R134a.Common.helmholtzToBoundaryProps'('f');
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.R134a_liqofdT';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.R134a_vapofdT' "Properties on vapor boundary phase"
    input Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'vap';
    Real 'T_vap'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'd_vap'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
  algorithm
    if 'T' < 374.18 then
      'd_vap' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.dewDensity'('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_T'('T'));
      'T_vap' := 'T';
    elseif true then
      'd_vap' := 508.0;
      'T_vap' := 374.18;
    end if;

    'f' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.f_R134a'('d_vap', 'T_vap');
    'vap' := 'Modelica.Media.R134a.Common.helmholtzToBoundaryProps'('f');
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.R134a_vapofdT';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.T_ph_der' "Time derivative function of T_ph"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    input Real 'p_der';
    input Real 'h_der';
    output Real 'T_der';
  algorithm
    if 'derivs'.'phase' == 2 then
      'T_der' := 1.0 / 'derivs'.'dpT' * 'p_der';
    elseif true then
      'T_der' := ('derivs'.'T' * 'derivs'.'pt' - 'derivs'.'rho' * 'derivs'.'pd') / ('derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pd' * 'derivs'.'cv' + 'derivs'.'T' * 'derivs'.'pt' * 'derivs'.'pt') * 'p_der' + 'derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pd' / ('derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pd' * 'derivs'.'cv' + 'derivs'.'T' * 'derivs'.'pt' * 'derivs'.'pt') * 'h_der';
    end if;
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.T_ph_der';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.T_props_ph' "Temperature as function of pressure and specific enthalpy"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    output Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'derivs'.'T';
    annotation(derivative(order = 1, noDerivative = 'derivs') = 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.T_ph_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.T_props_ph';

