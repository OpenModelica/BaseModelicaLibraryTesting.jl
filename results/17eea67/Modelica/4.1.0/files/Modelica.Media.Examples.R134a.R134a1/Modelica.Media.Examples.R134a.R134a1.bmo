    Integer 'int';
    Integer 'error';
    Real 'pred';
    Real 'localx';
  algorithm
    'pred' := min('sat'.'psat' / 4.05928e6, 1.0);
    ('int', 'error') := 'Modelica.Media.R134a.Common.FindInterval'('pred', 'p_breaks');
    'localx' := 'pred' - 'p_breaks'['int'];
    'hv' := 389653.0 * 'Modelica.Media.R134a.Common.CubicSplineEval'('localx', 'hv_coef'['int',1:4]);
    annotation(derivative(order = 1) = 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.dDewEnthalpy_dPressure_der_sat');
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.dewEnthalpy';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.dt_ph' "Density and temperature w.r.t. pressure and specific enthalpy"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'd'(nominal = 500.0, start = 4.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    output Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    'fixedMassFlowRate.Medium.SaturationProperties' 'sat';
    Real 'delp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 0.01;
    Real 'delh'(unit = "J/kg", quantity = "SpecificEnergy") = 0.01;
    Integer 'error';
    Real 'x';
    Real 'vvap';
    Real 'vliq';
    Real 'hvapor'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.dewEnthalpy'('sat');
    Real 'hliquid'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.bubbleEnthalpy'('sat');
  algorithm
    if ('h' < 'hliquid' or 'h' > 'hvapor') or 'p' > 4.05928e6 then
      ('d', 'T', 'error') := 'Modelica.Media.R134a.R134a_ph.dtofphOnePhase'('p', 'h', 'delp', 'delh');
    elseif true then
      'vvap' := 1.0 / 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.dewDensity'('sat');
      'vliq' := 1.0 / 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.bubbleDensity'('sat');
      'x' := ('h' - 'hliquid') / ('hvapor' - 'hliquid');
      'error' := 0;
      'T' := 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.saturationTemperature'('p');
      'd' := 1.0 / ('vliq' + 'x' * ('vvap' - 'vliq'));
    end if;
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.dt_ph';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.f_R134a' "Calculation of helmholtz derivatives by density and temperature"
    input Real 'd'(nominal = 500.0, start = 4.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Real 'delta';
    Real 'tau';
    'Modelica.Media.Common.HelmholtzDerivs' 'fid';
  algorithm
    'delta' := 'd' / 508.0;
    'tau' := 374.18 / 'T';
    'fid' := 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.fid_R134a'('delta', 'tau');
    'f' := 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.fres_R134a'('delta', 'tau');
    'f'.'f' := 'f'.'f' + 'fid'.'f';
    'f'.'fdelta' := 'f'.'fdelta' + 'fid'.'fdelta';
    'f'.'fdeltadelta' := 'f'.'fdeltadelta' + 'fid'.'fdeltadelta';
    'f'.'ftau' := 'f'.'ftau' + 'fid'.'ftau';
    'f'.'ftautau' := 'f'.'ftautau' + 'fid'.'ftautau';
    'f'.'d' := 'd';
    'f'.'T' := 'T';
    'f'.'R_s' := 81.4888564372;
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.f_R134a';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.fid_R134a' "Helmholtz coefficients of ideal part"
    input Real 'delta';
    input Real 'tau';
    output 'Modelica.Media.Common.HelmholtzDerivs' 'fid';
    'Modelica.Media.R134a.R134aData.Ideal' 'id';
    Real 'atau' = abs('tau');
    Real 'adelta' = abs('delta');
  algorithm
    'fid'.'delta' := 'delta';
    'fid'.'tau' := 'tau';
    'fid'.'f' := 'Modelica.Math.log'('adelta') + 'id'.'a'[1] + 'id'.'a'[2] * 'atau' + 'id'.'a'[3] * 'Modelica.Math.log'('atau') + 'id'.'a'[4] * 'atau' ^ (-0.5) + 'id'.'a'[5] * 'atau' ^ (-0.75);
    'fid'.'fdelta' := 1.0 / 'adelta';
    'fid'.'fdeltadelta' := -1.0 / ('adelta' * 'adelta');
    'fid'.'ftau' := 'id'.'a'[2] + 'id'.'a'[3] / 'atau' - 0.5 * 'id'.'a'[4] * 'atau' ^ (-1.5) - 0.75 * 'id'.'a'[5] * 'atau' ^ (-1.75);
    'fid'.'ftautau' := 0.75 * 'id'.'a'[4] * 'atau' ^ (-2.5) - 'id'.'a'[3] / ('atau' * 'atau') + 1.3125 * 'id'.'a'[5] * 'atau' ^ (-2.75);
    'fid'.'fdeltatau' := 0.0;
    'fid'.'d' := 'fid'.'delta' * 508.0;
    'fid'.'T' := 374.18 / 'fid'.'tau';
    'fid'.'R_s' := 81.4888564372;
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.fid_R134a';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.fres_R134a' "Calculation of helmholtz derivatives"
    input Real 'delta';
    input Real 'tau';
    output 'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'Modelica.Media.R134a.R134aData.Residual' 'res';
    Real 'k';
    Real 'dc';
    Real 'cdc';
  algorithm
    'f'.'tau' := abs('tau');
    'f'.'delta' := abs('delta');
    'f'.'f' := 0.0;
    'f'.'ftau' := 0.0;
    'f'.'fdelta' := 0.0;
    'f'.'ftautau' := 0.0;
    'f'.'fdeltadelta' := 0.0;
    'f'.'fdeltatau' := 0.0;

    for 'i' in 1:'res'.'ns1' loop
      'k' := 'res'.'n'['i'] * 'f'.'delta' ^ 'res'.'d'['i'] * 'f'.'tau' ^ 'res'.'t'['i'];
      'f'.'f' := 'f'.'f' + 'k';
      'f'.'fdelta' := 'f'.'fdelta' + 'k' * 'res'.'d'['i'];
      'f'.'fdeltadelta' := 'f'.'fdeltadelta' + 'k' * 'res'.'d'['i'] * ('res'.'d'['i'] - 1.0);
      'f'.'ftau' := 'f'.'ftau' + 'k' * 'res'.'t'['i'];
      'f'.'ftautau' := 'f'.'ftautau' + 'k' * 'res'.'t'['i'] * ('res'.'t'['i'] - 1.0);
      'f'.'fdeltatau' := 'f'.'fdeltatau' + 'k' * 'res'.'t'['i'] * 'res'.'d'['i'];
    end for;

    for 'i' in 'res'.'ns1' + 1:21 loop
      'dc' := 'f'.'delta' ^ 'res'.'c'['i'];
      'cdc' := 'res'.'c'['i'] * 'dc';
      'k' := 'Modelica.Math.exp'(-'dc') * 'res'.'n'['i'] * 'delta' ^ 'res'.'d'['i'] * 'f'.'tau' ^ 'res'.'t'['i'];
      'f'.'f' := 'f'.'f' + 'k';
      'f'.'fdelta' := 'f'.'fdelta' + 'k' * ('res'.'d'['i'] - 'cdc');
      'f'.'fdeltadelta' := 'f'.'fdeltadelta' + 'k' * (('res'.'d'['i'] - 'cdc') * ('res'.'d'['i'] - 1.0 - 'cdc') - 'res'.'c'['i'] * 'cdc');
      'f'.'ftau' := 'f'.'ftau' + 'k' * 'res'.'t'['i'];
      'f'.'ftautau' := 'f'.'ftautau' + 'k' * 'res'.'t'['i'] * ('res'.'t'['i'] - 1.0);
      'f'.'fdeltatau' := 'f'.'fdeltatau' + 'k' * 'res'.'t'['i'] * ('res'.'d'['i'] - 'cdc');
    end for;

    'f'.'fdelta' := 'f'.'fdelta' / 'delta';
    'f'.'fdeltadelta' := 'f'.'fdeltadelta' / ('delta' * 'delta');
    'f'.'ftau' := 'f'.'ftau' / 'tau';
    'f'.'ftautau' := 'f'.'ftautau' / ('tau' * 'tau');
    'f'.'fdeltatau' := 'f'.'fdeltatau' / ('delta' * 'tau');
    'f'.'d' := 'f'.'delta' * 508.0;
    'f'.'T' := 374.18 / 'f'.'tau';
    'f'.'R_s' := 81.4888564372;
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.fres_R134a';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.getPhase_ph' "Number of phases by pressure and specific enthalpy"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Integer 'phase';
    'fixedMassFlowRate.Medium.SaturationProperties' 'sat';
    Real 'hl'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.bubbleEnthalpy'('sat');
    Real 'hv'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.dewEnthalpy'('sat');
  algorithm
    'phase' := if ('h' < 'hl' or 'h' > 'hv') or 'p' > 4.05928e6 then 1 else 2;
    annotation(GenerateEvents = true, Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.getPhase_ph';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.pressure' "Pressure w.r.t. thermodynamic state"
    input 'fixedMassFlowRate.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.pressure';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.rho_ph_der' "Time derivative function of density_ph"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    input Real 'p_der';
    input Real 'h_der';
    output Real 'd_der';
  algorithm
    if 'derivs'.'phase' == 2 then
      'd_der' := 'derivs'.'rho' * ('derivs'.'rho' * 'derivs'.'cv' / 'derivs'.'dpT' + 1.0) / ('derivs'.'dpT' * 'derivs'.'T') * 'p_der' + (-'derivs'.'rho' * 'derivs'.'rho' / ('derivs'.'dpT' * 'derivs'.'T')) * 'h_der';
    elseif true then
      'd_der' := 'derivs'.'rho' * ('derivs'.'cv' * 'derivs'.'rho' + 'derivs'.'pt') / ('derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pd' * 'derivs'.'cv' + 'derivs'.'T' * 'derivs'.'pt' * 'derivs'.'pt') * 'p_der' + (-'derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pt' / ('derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pd' * 'derivs'.'cv' + 'derivs'.'T' * 'derivs'.'pt' * 'derivs'.'pt')) * 'h_der';
    end if;
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.rho_ph_der';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.rho_props_ph' "Density as function of pressure and specific enthalpy"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    input 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'derivs'.'rho';
    annotation(derivative(order = 1, noDerivative = 'derivs') = 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.rho_ph_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.rho_props_ph';

