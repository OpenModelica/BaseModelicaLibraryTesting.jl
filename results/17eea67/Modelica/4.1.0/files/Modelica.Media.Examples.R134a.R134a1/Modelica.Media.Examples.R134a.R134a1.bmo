  algorithm
    'pred' := min('sat'.'psat' / 4.05928e6, 1.0);
    ('int', 'error') := 'Modelica.Media.R134a.Common.FindInterval'('pred', 'p_breaks');
    'localx' := 'pred' - 'p_breaks'['int'];
    'der_dhvdp' := 389653.0 * 'Modelica.Media.R134a.Common.CubicSplineDerEval'('localx', 'hv_coef'['int',1:4]) / 4.05928e6 * 'der_sat'.'psat';
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.dDewEnthalpy_dPressure_der_sat';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.density_ph' "Density as function of pressure and specific enthalpy"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase' = 0;
    output Real 'd'(nominal = 500.0, start = 4.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.rho_props_ph'('p', 'h', 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.derivsOf_ph'('p', 'h', 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.getPhase_ph'('p', 'h')));
    annotation(Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.density_ph';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.derivsOf_ph' "Derivatives required for inversion of temperature and density functions"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase';
    output 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'ambient.Medium.SaturationProperties' 'sat';
    'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'liq';
    'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'vap';
    'Modelica.Media.Common.NewtonDerivatives_ph' 'newder';
    Real 'x';
    Real 'dxv';
  algorithm
    'derivs'.'p' := 'p';
    'derivs'.'h' := 'h';
    'derivs'.'phase' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.getPhase_ph'('p', 'h');
    'sat'.'psat' := 'p';
    'sat'.'Tsat' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.saturationTemperature'('p');
    ('derivs'.'rho', 'derivs'.'T') := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.dt_ph'('p', 'h');

    if 'derivs'.'phase' == 2 then
      'liq' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.R134a_liqofdT'('derivs'.'T');
      'vap' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.R134a_vapofdT'('derivs'.'T');
      'x' := if 'liq'.'h' <> 'vap'.'h' then ('h' - 'liq'.'h') / ('vap'.'h' - 'liq'.'h') else if 'h' >= 'vap'.'h' then 1.0 else 0.0;
      'derivs'.'cv' := 'Modelica.Media.R134a.Common.cv2Phase'('liq', 'vap', 'x', 'derivs'.'T', 'p');
      'dxv' := if 'liq'.'d' <> 'vap'.'d' then 'liq'.'d' * 'vap'.'d' / ('liq'.'d' - 'vap'.'d') else 0.0;
      'derivs'.'dpT' := ('vap'.'s' - 'liq'.'s') * 'dxv';
    elseif true then
      'f' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.f_R134a'('derivs'.'rho', 'derivs'.'T');
      'f'.'d' := 'derivs'.'rho';
      'f'.'T' := 'derivs'.'T';
      'f'.'R_s' := 81.4888564372;
      'newder' := 'Modelica.Media.Common.Helmholtz_ph'('f');
      'derivs'.'cv' := -'f'.'R_s' * ('f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
      'derivs'.'pd' := 'newder'.'pd';
      'derivs'.'pt' := 'newder'.'pt';
    end if;
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.derivsOf_ph';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.dewDensity' "Density of vapor phase w.r.t. saturation pressure | use setSat_p function for input"
