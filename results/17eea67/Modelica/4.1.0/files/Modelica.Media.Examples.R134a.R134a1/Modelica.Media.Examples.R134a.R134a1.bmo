    output Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'derivs'.'T';
    annotation(derivative(order = 1, noDerivative = 'derivs') = 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.T_ph_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.T_props_ph';

