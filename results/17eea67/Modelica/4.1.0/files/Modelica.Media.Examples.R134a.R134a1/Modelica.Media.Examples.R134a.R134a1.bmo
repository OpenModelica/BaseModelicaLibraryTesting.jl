    'pred' := 'p' / 4.05928e6;
    ('int', 'error') := 'Modelica.Media.R134a.Common.FindInterval'('pred', 'p_breaks');
    'localx' := 'pred' - 'p_breaks'['int'];
    'der_Tsat' := 'Modelica.Media.R134a.Common.CubicSplineDerEval'('localx', 'T_coef'['int',:]) / 4.05928e6 * 'der_p';
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.saturationTemperature_der_p';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_T' "Return saturation property record from temperature"
    input Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'ambient.Medium.SaturationProperties' 'sat';
  algorithm
    'sat'.'Tsat' := 'T';
    'sat'.'psat' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.saturationPressure'('T');
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_T';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_p' "Return saturation property record from pressure"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output 'ambient.Medium.SaturationProperties' 'sat';
  algorithm
    'sat'.'psat' := 'p';
    'sat'.'Tsat' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.saturationTemperature'('p');
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_p';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.specificEnthalpy' "Specific enthalpy w.r.t. thermodynamic state | use setState_phX function for input"
    input 'ambient.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'state'.'h';
    annotation(Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.specificEnthalpy';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.temperature_ph' "Temperature as function of pressure and specific enthalpy"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase' = 0;
    output Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.T_props_ph'('p', 'h', 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.derivsOf_ph'('p', 'h', 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.getPhase_ph'('p', 'h')));
    annotation(Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.temperature_ph';

  function 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.vapourQuality' "Return vapour quality"
    input 'ambient.Medium.ThermodynamicState' 'state';
    output Real 'x'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction");
    constant Real 'eps'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 1e-8;
  algorithm
    'x' := min(max(('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.specificEnthalpy'('state') - 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.bubbleEnthalpy'('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.pressure'('state')))) / ('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.dewEnthalpy'('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.pressure'('state'))) - 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.bubbleEnthalpy'('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a1.ambient.Medium.pressure'('state'))) + 'eps'), 0.0), 1.0);
  end 'Modelica.Media.Examples.R134a.R134a1.ambient.Medium.vapourQuality';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.R134a_liqofdT' "Properties on liquid boundary phase"
    input Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'liq';
    Real 'T_liq'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'd_liq'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
  algorithm
    if 'T' < 374.18 then
      'd_liq' := 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.bubbleDensity'('Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.setSat_T'('T'));
      'T_liq' := 'T';
    elseif true then
      'd_liq' := 508.0;
      'T_liq' := 374.18;
    end if;

    'f' := 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.f_R134a'('d_liq', 'T_liq');
    'liq' := 'Modelica.Media.R134a.Common.helmholtzToBoundaryProps'('f');
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.R134a_liqofdT';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.R134a_vapofdT' "Properties on vapor boundary phase"
    input Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'vap';
    Real 'T_vap'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'd_vap'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
  algorithm
    if 'T' < 374.18 then
      'd_vap' := 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.dewDensity'('Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.setSat_T'('T'));
      'T_vap' := 'T';
    elseif true then
      'd_vap' := 508.0;
      'T_vap' := 374.18;
    end if;

    'f' := 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.f_R134a'('d_vap', 'T_vap');
    'vap' := 'Modelica.Media.R134a.Common.helmholtzToBoundaryProps'('f');
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.R134a_vapofdT';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.T_ph_der' "Time derivative function of T_ph"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    input Real 'p_der';
    input Real 'h_der';
    output Real 'T_der';
  algorithm
    if 'derivs'.'phase' == 2 then
      'T_der' := 1.0 / 'derivs'.'dpT' * 'p_der';
    elseif true then
      'T_der' := ('derivs'.'T' * 'derivs'.'pt' - 'derivs'.'rho' * 'derivs'.'pd') / ('derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pd' * 'derivs'.'cv' + 'derivs'.'T' * 'derivs'.'pt' * 'derivs'.'pt') * 'p_der' + 'derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pd' / ('derivs'.'rho' * 'derivs'.'rho' * 'derivs'.'pd' * 'derivs'.'cv' + 'derivs'.'T' * 'derivs'.'pt' * 'derivs'.'pt') * 'h_der';
    end if;
  end 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.T_ph_der';

  function 'Modelica.Media.Examples.R134a.R134a1.fixedMassFlowRate.Medium.T_props_ph' "Temperature as function of pressure and specific enthalpy"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
