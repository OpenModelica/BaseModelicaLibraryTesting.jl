6557345158, 0.996069053766824, 0.4307167462684177}, {5.322780585611914, 1.720316041896115, 1.007293551783249, 0.4340258706136082}, {5.581856116174721, 1.770664322860376, 1.018880860299036, 0.4373842594703593}, {5.866088407465559, 1.823520560177389, 1.030853140388873, 0.4407934798537482}, {6.171923002120571, 1.879189565923113, 1.043230569280668, 0.4442551829095663}, {6.501535536191801, 1.937885751613769, 1.056035595849955, 0.447771109307688}, {6.857377194386117, 1.999844889612192, 1.06929243102071, 0.4513430963808631}, {7.242214043652889, 2.065326797427353, 1.083027227973919, 0.4549730857610047}, {7.659178646510535, 2.134618343011173, 1.097268285542566, 0.4586631318040277}, {8.111827066134506, 2.208036973520845, 1.112046277772487, 0.4624154109045757}, {8.604208529071581, 2.285934758959754, 1.127394514184514, 0.4662322318172514}, {9.140948252644797, 2.368703086413673, 1.143349235435159, 0.4701160471199221}, {9.727346257355943, 2.456778125271054, 1.159949950207535, 0.4740694659762598}, {10.36949636473117, 2.550647201445953, 1.177239820295516, 0.4780952683808142}, {11.07442943815378, 2.650856267473131, 1.195266102140809, 0.4821964211012327}, {11.85028605617332, 2.758018689992081, 1.214080654794935, 0.486376095569567}, {12.70652798974013, 2.872825592971998, 1.233740526395416, 0.4906376880197966}, {13.65419174621447, 2.996058162729545, 1.25430863346617, 0.4949848422233832}, {14.70620059822895, 3.128602227412618, 1.275854551067133, 0.4994214752410865}, {15.87774199700023, 3.27146570561858, 1.298455434935754, 0.5039518066908264}, {17.20674254013149, 3.425586345730544, 1.322197606263238, 0.5085803921309422}, {18.63402248089567, 3.593353579496717, 1.34717402597493, 0.5133121612816782}, {20.32390211918452, 3.774153760759719, 1.37349921982773, 0.5181524619605369}, {22.18601347832784, 3.971869398731903, 1.401284417001323, 0.5231071115480921}, {24.31252464422925, 4.187482117105547, 1.430671346578243, 0.5281824536278078}, {26.73985851010544, 4.423583955149483, 1.461812601611662, 0.5333854293394883}, {29.52491937183151, 4.682968036424375, 1.494883366150635, 0.5387236561640727}, {32.73828578159125, 4.968928762622564, 1.53008387159375, 0.5442055229446516}, {36.46825750913934, 5.285374439016692, 1.567644134852697, 0.5498403020789376}, {40.82633712570511, 5.63697065758656, 1.607829829067538, 0.5556382833229866}, {45.95475926455129, 6.02932417573452, 1.650949619985925, 0.561610934467759}, {52.03696918320384, 6.469220871161562, 1.697364417633431, 0.5677710957231201}, {59.31241581636025, 6.964936570782171, 1.747499159582017, 0.5741332167790794}, {68.09776191782187, 7.526647036007701, 1.801857981792066, 0.5807136484549547}, {78.81778054554678, 8.166974540194117, 1.861043982241702, 0.5875310049495474}, {92.07856359262058, 8.901415236315513, 1.925786076833259, 0.5946066185193436}, {108.5962925592044, 9.751235331139156, 1.996968777326911, 0.6019651167819492}, {129.6612727594772, 10.73953725331416, 2.075696926484503, 0.6096351651125727}, {156.8149508938095, 11.90149594899319, 2.163329563019325, 0.6176504358167556}, {192.5895489261716, 13.27895255374134, 2.261610095071371, 0.626050889913749}, {240.7894220277205, 14.92863095592906, 2.372777247256969, 0.6348845111387734}, {307.4933991972216, 16.92543720677949, 2.499777113694852, 0.6442096900359834}, {402.8115941258301, 19.36864049070909, 2.646574749423806, 0.6540985866240505}, {544.4627680553028, 22.38732251366779, 2.818658896530704, 0.6646420006807281}, {765.4263901392872, 26.13984326739216, 3.02389532713334, 0.6759566538738164}, {1132.473145221229, 30.77464245663644, 3.274097890822487, 0.6881964979202373}, {1728.456306009293, 37.03669144378617, 3.586095407785845, 0.7015710980094141}, {2746.345210190641, 46.36511685430635, 3.986312539776484, 0.7163772638856115}, {4641.775374977525, 61.99723710600262, 4.516428772903993, 0.733057552026205}, {8525.65796223134, 68.10054194649604, 5.081630948855855, 0.7472071449747022}, {17415.72862879567, 62.19045752188775, 5.890642485434674, 0.7632728136051337}, {38134.58054210775, 53.70618375512508, 7.12422816988373, 0.7828757764751582}, {85891.58440190039, 109.098168330335, 8.90287328562379, 0.8059157661363586}, {195130.3750681718, 237.5849575768755, 11.17514113283684, 0.8277377240352704}, {478254.8713012288, 198.6473214368117, 13.94735114459777, 0.8459822722289891}, {1.185655347397813e6, -217.4684780917248, 17.6297910235764, 0.862925429260232}, {2.750846962420604e6, -162.9109294341851, 22.59666061556802, 0.8814128590616266}, {6.12391363088082e6, 4322.208699496733, 29.98861227777463, 0.9042234397623542}, {1.223685185147719e7, 8090.21835774415, 36.38774289535504, 0.9167366942666613}, {2.818621443600825e7, 3085.71154819258, 41.35729893033309, 0.9225727665578074}, {8.316585285067827e7, -11363.24148807467, 51.96252092604191, 0.9326388658049112}, {2.79424420022855e8, -61136.67992222013, 70.38061963269288, 0.9435863614001085}, {9.252325428804928e8, -54874.63721818197, 91.10802490104044, 0.957945474156748}, {2.237265034221097e9, 68968.19415082679, 114.2108494843807, 0.9677749072712486}, {1.59773251287263e13, -7.58058156719993e8, 8988.788796440838, 0.974158469581287}};
    Real 'hl'(unit = "J/kg", quantity = "SpecificEnergy");
    Boolean 'liquid';
    Boolean 'supercritical';
    Integer 'int';
    Real 'pred';
    Real 'localx';
    Integer 'i';
    Real 'dh';
    Real 'dp';
    Real 'damping';
    Real 'det';
    Real 'deld';
    Real 'delt';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'Modelica.Media.Common.NewtonDerivatives_ph' 'nDerivs';
    Boolean 'found';
  algorithm
    'i' := 0;
    'error' := 0;
    'found' := false;
    'damping' := 1.0;
    'pred' := 'p' / 4.05928e6;
    ('int', 'error') := 'Modelica.Media.R134a.Common.FindInterval'('pred', 'p_breaks');
    'localx' := 'pred' - 'p_breaks'['int'];
    'supercritical' := 'p' > 4.05928e6;

    if 'supercritical' then
      'd' := 1535.6999999999998;
      'T' := 270.0 + 120.0 * ('h' / 389653.0);
    elseif true then
      'liquid' := 'h' < 393549.53 * 'Modelica.Media.R134a.Common.CubicSplineEval'('localx', 'hl_coef'['int',:]);

      if 'liquid' then
        'damping' := 0.3;
        'd' := 511.9 * 'Modelica.Media.R134a.Common.CubicSplineEval'('localx', 'dl_coef'['int',:]) * 1.5;
        'T' := 'Modelica.Media.R134a.Common.CubicSplineEval'('localx', 'T_coef'['int',:]);
      elseif true then
        'd' := 511.9 * 'Modelica.Media.R134a.Common.CubicSplineEval'('localx', 'dv_coef'['int',:]) * 0.95;
        'T' := 'Modelica.Media.R134a.Common.CubicSplineEval'('localx', 'T_coef'['int',:]);
      end if;
    end if;

    while 'i' < 50 and not 'found' loop
      'f' := 'Modelica.Media.R134a.R134a_ph.f_R134a'('d', 'T');
      'nDerivs' := 'Modelica.Media.Common.Helmholtz_ph'('f');
      'dh' := 'nDerivs'.'h' - 'h';
      'dp' := 'nDerivs'.'p' - 'p';

      if abs('dh') <= 'delh' and abs('dp') <= 'delp' then
        'found' := true;
        'error' := if not 'found' then 1 else 0;
      end if;

      'det' := 'nDerivs'.'ht' * 'nDerivs'.'pd' - 'nDerivs'.'pt' * 'nDerivs'.'hd';

      if abs('det') < 1e-10 then
        'det' := sign('det') * 1e-10;
      end if;

      'delt' := ('nDerivs'.'pd' * 'dh' - 'nDerivs'.'hd' * 'dp') / 'det';
      'deld' := ('nDerivs'.'ht' * 'dp' - 'nDerivs'.'pt' * 'dh') / 'det';
      'T' := 'T' - 'damping' * 'delt';
      'd' := 'd' - 'damping' * 'deld';

      if 'T' < 169.85 then
        'T' := 169.95;
      end if;

      if 'd' <= 0.0 then
        'd' := 0.028172;
      elseif 'd' > 2386.6611795 then
        'd' := 1591.107453;
      end if;

      'i' := 'i' + 1;
    end while;
  end 'Modelica.Media.R134a.R134a_ph.dtofphOnePhase';

  function 'Modelica.Media.R134a.R134a_ph.f_R134a' "Calculation of helmholtz derivatives by density and temperature"
    input Real 'd'(nominal = 500.0, start = 4.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Real 'delta';
    Real 'tau';
    'Modelica.Media.Common.HelmholtzDerivs' 'fid';
  algorithm
    'delta' := 'd' / 508.0;
    'tau' := 374.18 / 'T';
    'fid' := 'Modelica.Media.R134a.R134a_ph.fid_R134a'('delta', 'tau');
    'f' := 'Modelica.Media.R134a.R134a_ph.fres_R134a'('delta', 'tau');
    'f'.'f' := 'f'.'f' + 'fid'.'f';
    'f'.'fdelta' := 'f'.'fdelta' + 'fid'.'fdelta';
    'f'.'fdeltadelta' := 'f'.'fdeltadelta' + 'fid'.'fdeltadelta';
    'f'.'ftau' := 'f'.'ftau' + 'fid'.'ftau';
    'f'.'ftautau' := 'f'.'ftautau' + 'fid'.'ftautau';
    'f'.'d' := 'd';
    'f'.'T' := 'T';
    'f'.'R_s' := 81.4888564372;
  end 'Modelica.Media.R134a.R134a_ph.f_R134a';

  function 'Modelica.Media.R134a.R134a_ph.fid_R134a' "Helmholtz coefficients of ideal part"
    input Real 'delta';
    input Real 'tau';
    output 'Modelica.Media.Common.HelmholtzDerivs' 'fid';
    'Modelica.Media.R134a.R134aData.Ideal' 'id';
    Real 'atau' = abs('tau');
    Real 'adelta' = abs('delta');
  algorithm
    'fid'.'delta' := 'delta';
    'fid'.'tau' := 'tau';
    'fid'.'f' := 'Modelica.Math.log'('adelta') + 'id'.'a'[1] + 'id'.'a'[2] * 'atau' + 'id'.'a'[3] * 'Modelica.Math.log'('atau') + 'id'.'a'[4] * 'atau' ^ (-0.5) + 'id'.'a'[5] * 'atau' ^ (-0.75);
    'fid'.'fdelta' := 1.0 / 'adelta';
    'fid'.'fdeltadelta' := -1.0 / ('adelta' * 'adelta');
    'fid'.'ftau' := 'id'.'a'[2] + 'id'.'a'[3] / 'atau' - 0.5 * 'id'.'a'[4] * 'atau' ^ (-1.5) - 0.75 * 'id'.'a'[5] * 'atau' ^ (-1.75);
    'fid'.'ftautau' := 0.75 * 'id'.'a'[4] * 'atau' ^ (-2.5) - 'id'.'a'[3] / ('atau' * 'atau') + 1.3125 * 'id'.'a'[5] * 'atau' ^ (-2.75);
    'fid'.'fdeltatau' := 0.0;
    'fid'.'d' := 'fid'.'delta' * 508.0;
    'fid'.'T' := 374.18 / 'fid'.'tau';
    'fid'.'R_s' := 81.4888564372;
  end 'Modelica.Media.R134a.R134a_ph.fid_R134a';

  function 'Modelica.Media.R134a.R134a_ph.fres_R134a' "Calculation of helmholtz derivatives"
    input Real 'delta';
    input Real 'tau';
    output 'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'Modelica.Media.R134a.R134aData.Residual' 'res';
    Real 'k';
    Real 'dc';
    Real 'cdc';
  algorithm
    'f'.'tau' := abs('tau');
    'f'.'delta' := abs('delta');
    'f'.'f' := 0.0;
    'f'.'ftau' := 0.0;
    'f'.'fdelta' := 0.0;
    'f'.'ftautau' := 0.0;
    'f'.'fdeltadelta' := 0.0;
    'f'.'fdeltatau' := 0.0;

    for 'i' in 1:'res'.'ns1' loop
      'k' := 'res'.'n'['i'] * 'f'.'delta' ^ 'res'.'d'['i'] * 'f'.'tau' ^ 'res'.'t'['i'];
      'f'.'f' := 'f'.'f' + 'k';
      'f'.'fdelta' := 'f'.'fdelta' + 'k' * 'res'.'d'['i'];
      'f'.'fdeltadelta' := 'f'.'fdeltadelta' + 'k' * 'res'.'d'['i'] * ('res'.'d'['i'] - 1.0);
      'f'.'ftau' := 'f'.'ftau' + 'k' * 'res'.'t'['i'];
      'f'.'ftautau' := 'f'.'ftautau' + 'k' * 'res'.'t'['i'] * ('res'.'t'['i'] - 1.0);
      'f'.'fdeltatau' := 'f'.'fdeltatau' + 'k' * 'res'.'t'['i'] * 'res'.'d'['i'];
    end for;

    for 'i' in 'res'.'ns1' + 1:21 loop
      'dc' := 'f'.'delta' ^ 'res'.'c'['i'];
      'cdc' := 'res'.'c'['i'] * 'dc';
      'k' := 'Modelica.Math.exp'(-'dc') * 'res'.'n'['i'] * 'delta' ^ 'res'.'d'['i'] * 'f'.'tau' ^ 'res'.'t'['i'];
      'f'.'f' := 'f'.'f' + 'k';
      'f'.'fdelta' := 'f'.'fdelta' + 'k' * ('res'.'d'['i'] - 'cdc');
      'f'.'fdeltadelta' := 'f'.'fdeltadelta' + 'k' * (('res'.'d'['i'] - 'cdc') * ('res'.'d'['i'] - 1.0 - 'cdc') - 'res'.'c'['i'] * 'cdc');
      'f'.'ftau' := 'f'.'ftau' + 'k' * 'res'.'t'['i'];
      'f'.'ftautau' := 'f'.'ftautau' + 'k' * 'res'.'t'['i'] * ('res'.'t'['i'] - 1.0);
      'f'.'fdeltatau' := 'f'.'fdeltatau' + 'k' * 'res'.'t'['i'] * ('res'.'d'['i'] - 'cdc');
    end for;

    'f'.'fdelta' := 'f'.'fdelta' / 'delta';
    'f'.'fdeltadelta' := 'f'.'fdeltadelta' / ('delta' * 'delta');
    'f'.'ftau' := 'f'.'ftau' / 'tau';
    'f'.'ftautau' := 'f'.'ftautau' / ('tau' * 'tau');
    'f'.'fdeltatau' := 'f'.'fdeltatau' / ('delta' * 'tau');
    'f'.'d' := 'f'.'delta' * 508.0;
    'f'.'T' := 374.18 / 'f'.'tau';
    'f'.'R_s' := 81.4888564372;
  end 'Modelica.Media.R134a.R134a_ph.fres_R134a';

  function 'Modelica.Units.Conversions.to_bar' "Convert from Pascal to bar"
    input Real 'Pa'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'bar'(unit = "bar", quantity = "Pressure");
  algorithm
    'bar' := 'Pa' / 1e5;
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_bar';

  function 'Modelica.Units.Conversions.to_degC' "Convert from kelvin to degree Celsius"
    input Real 'Kelvin'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'Celsius'(unit = "degC", quantity = "ThermodynamicTemperature");
  algorithm
    'Celsius' := 'Kelvin' - 273.15;
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_degC';

