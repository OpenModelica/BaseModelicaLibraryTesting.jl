  algorithm
    'pred' := 'p' / 4.05928e6;
    ('int', 'error') := 'Modelica.Media.R134a.Common.FindInterval'('pred', 'p_breaks');
    'localx' := 'pred' - 'p_breaks'['int'];
    'der_Tsat' := 'Modelica.Media.R134a.Common.CubicSplineDerEval'('localx', 'T_coef'['int',:]) / 4.05928e6 * 'der_p';
  end 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.saturationTemperature_der_p';

  function 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.setSat_T' "Return saturation property record from temperature"
    input Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'volume.Medium.SaturationProperties' 'sat';
  algorithm
    'sat'.'Tsat' := 'T';
    'sat'.'psat' := 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.saturationPressure'('T');
  end 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.setSat_T';

  function 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.setSat_p' "Return saturation property record from pressure"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output 'volume.Medium.SaturationProperties' 'sat';
  algorithm
    'sat'.'psat' := 'p';
    'sat'.'Tsat' := 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.saturationTemperature'('p');
  end 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.setSat_p';

  function 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.specificEnthalpy' "Specific enthalpy w.r.t. thermodynamic state | use setState_phX function for input"
    input 'volume.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'state'.'h';
    annotation(Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.specificEnthalpy';

  function 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.temperature_ph' "Temperature as function of pressure and specific enthalpy"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase' = 0;
    output Real 'T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.T_props_ph'('p', 'h', 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.derivsOf_ph'('p', 'h', 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.getPhase_ph'('p', 'h')));
    annotation(Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.temperature_ph';

  function 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.vapourQuality' "Return vapour quality"
    input 'volume.Medium.ThermodynamicState' 'state';
    output Real 'x'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction");
    constant Real 'eps'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 1e-8;
  algorithm
    'x' := min(max(('Modelica.Media.Examples.R134a.R134a1.volume.Medium.specificEnthalpy'('state') - 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.bubbleEnthalpy'('Modelica.Media.Examples.R134a.R134a1.volume.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a1.volume.Medium.pressure'('state')))) / ('Modelica.Media.Examples.R134a.R134a1.volume.Medium.dewEnthalpy'('Modelica.Media.Examples.R134a.R134a1.volume.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a1.volume.Medium.pressure'('state'))) - 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.bubbleEnthalpy'('Modelica.Media.Examples.R134a.R134a1.volume.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a1.volume.Medium.pressure'('state'))) + 'eps'), 0.0), 1.0);
  end 'Modelica.Media.Examples.R134a.R134a1.volume.Medium.vapourQuality';

  function 'Modelica.Media.R134a.Common.CubicSplineDerEval' "Derivative of cubic spline"
    input Real 'x';
    input Real[4] 'coefs';
    output Real 'yder';
  algorithm
    'yder' := 'coefs'[3] + 'x' * (2.0 * 'coefs'[2] + 'x' * 3.0 * 'coefs'[1]);
  end 'Modelica.Media.R134a.Common.CubicSplineDerEval';

  function 'Modelica.Media.R134a.Common.CubicSplineEval' "Cubic spline"
    input Real 'x';
    input Real[4] 'coefs';
    output Real 'y';
  algorithm
    'y' := 'coefs'[4] + 'x' * ('coefs'[3] + 'x' * ('coefs'[2] + 'x' * 'coefs'[1]));
  end 'Modelica.Media.R134a.Common.CubicSplineEval';

  function 'Modelica.Media.R134a.Common.FindInterval' "Half-interval search algorithm"
    input Real 'x';
    input Real[:] 'breaks';
    output Integer 'i';
    output Integer 'error' = 0;
    Integer 'n' = size('breaks', 1) - 1;
    Integer 'ix' = 1;
    Integer 'm' = 'n';
  algorithm
    'i' := 1;

    if 'x' < 'breaks'[1] or 'x' >= 'breaks'['n'] then
      'error' := 1;
    end if;

    if 'x' < 'breaks'[1] or 'x' >= 'breaks'[2] then
      while 'm' <> 'ix' loop
        if 'x' < 'breaks'['m'] then
          'n' := 'm';
        elseif true then
          'ix' := 'm';
        end if;

        'm' := integer(div('ix' + 'n', 2));
      end while;

      'i' := 'ix';
    end if;
  end 'Modelica.Media.R134a.Common.FindInterval';

  function 'Modelica.Media.R134a.Common.cv2Phase' "Compute isochoric specific heat capacity inside the two-phase region"
    input 'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'liq';
    input 'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'vap';
    input Real 'x'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    output Real 'dpT';
    Real 'dxv';
    Real 'dvTl';
    Real 'dvTv';
    Real 'duTl';
    Real 'duTv';
    Real 'dxt';
  algorithm
    'dxv' := if 'liq'.'d' <> 'vap'.'d' then 'liq'.'d' * 'vap'.'d' / ('liq'.'d' - 'vap'.'d') else 0.0;
    'dpT' := ('vap'.'s' - 'liq'.'s') * 'dxv';
    'dvTl' := ('liq'.'pt' - 'dpT') / 'liq'.'pd' / 'liq'.'d' / 'liq'.'d';
    'dvTv' := ('vap'.'pt' - 'dpT') / 'vap'.'pd' / 'vap'.'d' / 'vap'.'d';
    'dxt' := -'dxv' * ('dvTl' + 'x' * ('dvTv' - 'dvTl'));
    'duTl' := 'liq'.'cv' + ('T' * 'liq'.'pt' - 'p') * 'dvTl';
    'duTv' := 'vap'.'cv' + ('T' * 'vap'.'pt' - 'p') * 'dvTv';
    'cv' := 'duTl' + 'x' * ('duTv' - 'duTl') + 'dxt' * ('vap'.'u' - 'liq'.'u');
  end 'Modelica.Media.R134a.Common.cv2Phase';

  function 'Modelica.Media.R134a.Common.helmholtzToBoundaryProps' "Calculate phase boundary property record from dimensionless Helmholtz function"
    input 'Modelica.Media.Common.HelmholtzDerivs' 'f';
    output 'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'sat';
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'f'.'R_s' * 'f'.'d' * 'f'.'T' * 'f'.'delta' * 'f'.'fdelta';
    'sat'.'d' := 'f'.'d';
    'sat'.'h' := 'f'.'R_s' * 'f'.'T' * ('f'.'tau' * 'f'.'ftau' + 'f'.'delta' * 'f'.'fdelta');
    'sat'.'s' := 'f'.'R_s' * ('f'.'tau' * 'f'.'ftau' - 'f'.'f');
    'sat'.'u' := 'f'.'R_s' * 'f'.'T' * 'f'.'tau' * 'f'.'ftau';
    'sat'.'cp' := 'f'.'R_s' * (('f'.'delta' * 'f'.'fdelta' - 'f'.'delta' * 'f'.'tau' * 'f'.'fdeltatau') ^ 2.0 / (2.0 * 'f'.'delta' * 'f'.'fdelta' + 'f'.'delta' * 'f'.'delta' * 'f'.'fdeltadelta') - 'f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
    'sat'.'cv' := 'f'.'R_s' * (-'f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
    'sat'.'pt' := 'f'.'R_s' * 'f'.'d' * ('f'.'delta' * ('f'.'fdelta' - 'f'.'tau' * 'f'.'fdeltatau'));
    'sat'.'pd' := 'f'.'R_s' * 'f'.'T' * ('f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta'));
    'sat'.'a' := abs('f'.'R_s' * 'f'.'T' * (2.0 * 'f'.'delta' * 'f'.'fdelta' + 'f'.'delta' * 'f'.'delta' * 'f'.'fdeltadelta' - ('f'.'delta' * 'f'.'fdelta' - 'f'.'delta' * 'f'.'tau' * 'f'.'fdeltatau') * ('f'.'delta' * 'f'.'fdelta' - 'f'.'delta' * 'f'.'tau' * 'f'.'fdeltatau') / ('f'.'tau' * 'f'.'tau' * 'f'.'ftautau'))) ^ 0.5;
    'sat'.'kappa' := 1.0 / ('f'.'d' * 'f'.'R_s' * 'f'.'T' * 'f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta'));
    'sat'.'beta' := 'f'.'R_s' * 'f'.'d' * 'f'.'delta' * ('f'.'fdelta' - 'f'.'tau' * 'f'.'fdeltatau') * 'sat'.'kappa';
    'sat'.'gamma' := 'sat'.'a' ^ 2.0 / 'f'.'R_s' / 'f'.'T';
  end 'Modelica.Media.R134a.Common.helmholtzToBoundaryProps';

