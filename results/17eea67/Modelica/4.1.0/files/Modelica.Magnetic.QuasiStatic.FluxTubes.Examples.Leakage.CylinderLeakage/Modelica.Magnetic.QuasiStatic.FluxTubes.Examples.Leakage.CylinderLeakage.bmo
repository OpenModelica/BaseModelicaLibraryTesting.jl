    Real 'hollowCylinderAxialFlux2.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux";
    Real 'hollowCylinderAxialFlux2.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'hollowCylinderAxialFlux2.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 100.0 "Constant relative permeability";
    Real 'hollowCylinderAxialFlux2.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'hollowCylinderAxialFlux2.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'hollowCylinderAxialFlux2.B.re'(unit = "T", quantity = "MagneticFluxDensity") "Real part of complex number";
    Real 'hollowCylinderAxialFlux2.B.im'(unit = "T", quantity = "MagneticFluxDensity") "Imaginary part of complex number";
    Real 'hollowCylinderAxialFlux2.abs_B'(unit = "T", quantity = "MagneticFluxDensity") "Magnitude of complex magnetic flux density";
    Real 'hollowCylinderAxialFlux2.arg_B'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux density";
    Real 'hollowCylinderAxialFlux2.A'(unit = "m2", quantity = "Area") "Area of cross section penetrated by magnetic flux";
    Real 'hollowCylinderAxialFlux2.H.re'(unit = "A/m", quantity = "MagneticFieldStrength") "Real part of complex number";
    Real 'hollowCylinderAxialFlux2.H.im'(unit = "A/m", quantity = "MagneticFieldStrength") "Imaginary part of complex number";
    Real 'hollowCylinderAxialFlux2.abs_H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnitude of complex magnetic field strength";
    Real 'hollowCylinderAxialFlux2.arg_H'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic field strength";
    Real 'hollowCylinderAxialFlux2.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    parameter Real 'hollowCylinderAxialFlux2.l'(unit = "m", quantity = "Length") = 0.1 "Axial length (in direction of flux)";
    parameter Real 'hollowCylinderAxialFlux2.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Inner radius of hollow cylinder (zero for cylinder)";
    parameter Real 'hollowCylinderAxialFlux2.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.05 "Outer radius of (hollow) cylinder";
    parameter Real 'hollowCylinderAxialFlux2.alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 6.283185307179586 "Central angle";
