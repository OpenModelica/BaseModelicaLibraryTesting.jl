    Real 'quarterCylinder2.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'quarterCylinder2.abs_V_m'(unit = "A", quantity = "MagneticPotential") "Magnitude of complex magnetic potential difference";
    Real 'quarterCylinder2.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic potential difference";
    Real 'quarterCylinder2.Phi.re'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'quarterCylinder2.Phi.im'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'quarterCylinder2.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnitude of complex magnetic flux";
    Real 'quarterCylinder2.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux";
    Real 'quarterCylinder2.omega'(unit = "rad/s", quantity = "AngularVelocity");
    Real 'quarterCylinder2.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'quarterCylinder2.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    parameter Real 'quarterCylinder2.l'(unit = "m", quantity = "Length") = 0.6283185307179586 "Axial length orthogonal to flux (=2*pi*r for cylindrical pole and r>>distance between edge and plane)";
    Real 'constantSource.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'constantSource.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'constantSource.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'constantSource.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'constantSource.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'constantSource.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'constantSource.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'constantSource.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'constantSource.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'constantSource.port_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'constantSource.omega'(unit = "rad/s", quantity = "AngularVelocity");
    Real 'constantSource.gamma'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Real 'constantSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of the source";
    Real 'constantSource.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'constantSource.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    parameter Real 'constantSource.Phi.re'(unit = "Wb", quantity = "MagneticFlux") = 0.005 "Real part of complex number";
