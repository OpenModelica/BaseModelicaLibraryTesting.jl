    Real 'quarterCylinder2.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'quarterCylinder2.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'quarterCylinder2.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
