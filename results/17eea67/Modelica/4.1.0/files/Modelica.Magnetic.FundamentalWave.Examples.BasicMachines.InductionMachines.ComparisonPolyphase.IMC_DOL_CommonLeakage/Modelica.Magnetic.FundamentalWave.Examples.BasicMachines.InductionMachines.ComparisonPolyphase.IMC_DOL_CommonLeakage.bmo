//! base 0.1.0
package 'IMC_DOL_CommonLeakage'
  function 'Complex.\'*\'.multiply' "Multiply two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' * 'c2'.'re' - 'c1'.'im' * 'c2'.'im', 'c1'.'re' * 'c2'.'im' + 'c1'.'im' * 'c2'.'re');
    annotation(Inline = true, smoothOrder = 100);
  end 'Complex.\'*\'.multiply';

  function 'Complex.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Complex.\'constructor\'.fromReal';

  function 'Modelica.ComplexMath.abs' "Absolute value of complex number"
    input 'Complex' 'c';
    output Real 'result';
  algorithm
    'result' := sqrt('c'.'re' ^ 2.0 + 'c'.'im' ^ 2.0);
    annotation(Inline = true);
  end 'Modelica.ComplexMath.abs';

  function 'Modelica.ComplexMath.arg' "Phase angle of complex number"
    input 'Complex' 'c';
    input Real 'phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'phi'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'phi' := 'Modelica.Math.atan3'('c'.'im', 'c'.'re', 'phi0');
    annotation(Inline = true);
  end 'Modelica.ComplexMath.arg';

  function 'Modelica.ComplexMath.conj' "Conjugate of complex number"
    input 'Complex' 'c1';
    output 'Complex' 'c2';
  algorithm
    'c2' := 'Complex.\'constructor\'.fromReal'('c1'.'re', -'c1'.'im');
    annotation(Inline = true);
  end 'Modelica.ComplexMath.conj';

  function 'Modelica.ComplexMath.exp' "Exponential of complex number"
    input 'Complex' 'c1';
    output 'Complex' 'c2';
  algorithm
    'c2' := 'Complex.\'constructor\'.fromReal'('Modelica.Math.exp'('c1'.'re') * 'Modelica.Math.cos'('c1'.'im'), 'Modelica.Math.exp'('c1'.'re') * 'Modelica.Math.sin'('c1'.'im'));
    annotation(Inline = true);
  end 'Modelica.ComplexMath.exp';

  function 'Modelica.ComplexMath.real' "Real part of complex number"
    input 'Complex' 'c';
    output Real 'r';
  algorithm
    'r' := 'c'.'re';
    annotation(Inline = true);
  end 'Modelica.ComplexMath.real';

  function 'Modelica.Electrical.Polyphase.Functions.activePower' "Calculate active power of voltage and current input"
    input Real[:] 'v'(unit = fill("V", size('v', 1)), quantity = fill("ElectricPotential", size('v', 1)));
    input Real[size('v', 1)] 'i'(unit = fill("A", size('v', 1)), quantity = fill("ElectricCurrent", size('v', 1)));
    output Real 'p'(unit = "W", quantity = "Power");
  algorithm
    'p' := sum('v' * 'i');
    annotation(Inline = true);
  end 'Modelica.Electrical.Polyphase.Functions.activePower';

  function 'Modelica.Electrical.Polyphase.Functions.quasiRMS' "Calculate continuous quasi RMS value of input"
    input Real[:] 'x';
    output Real 'y';
  algorithm
    'y' := sqrt(sum('x' .^ 2.0 / size('x', 1)));
    annotation(Inline = true);
  end 'Modelica.Electrical.Polyphase.Functions.quasiRMS';

  function 'Modelica.Math.atan2' "Four quadrant inverse tangent"
    input Real 'u1';
    input Real 'u2';
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := atan2('u1', 'u2');
    annotation(Inline = true);
  end 'Modelica.Math.atan2';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    elseif true then
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  function 'Modelica.Math.cos' "Cosine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := cos('u');
    annotation(Inline = true);
  end 'Modelica.Math.cos';

  function 'Modelica.Math.exp' "Exponential, base e"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := exp('u');
    annotation(Inline = true);
  end 'Modelica.Math.exp';

  function 'Modelica.Math.sin' "Sine"
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    output Real 'y';
  algorithm
    'y' := sin('u');
    annotation(Inline = true);
  end 'Modelica.Math.sin';

  function 'Modelica.Units.SI.ComplexMagneticFlux.\'+\'' "Add two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' + 'c2'.'re', 'c1'.'im' + 'c2'.'im');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexMagneticFlux.\'+\'';

  function 'Modelica.Units.SI.ComplexMagneticFlux.\'*\'.multiply' "Multiply two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' * 'c2'.'re' - 'c1'.'im' * 'c2'.'im', 'c1'.'re' * 'c2'.'im' + 'c1'.'im' * 'c2'.'re');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexMagneticFlux.\'*\'.multiply';

  function 'Modelica.Units.SI.ComplexMagneticFlux.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexMagneticFlux.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexMagneticPotential.\'-\'.subtract' "Subtract two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' - 'c2'.'re', 'c1'.'im' - 'c2'.'im');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexMagneticPotential.\'-\'.subtract';

  function 'Modelica.Units.SI.ComplexMagneticPotential.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexMagneticPotential.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexMagneticPotentialDifference.\'*\'.multiply' "Multiply two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex.\'constructor\'.fromReal'('c1'.'re' * 'c2'.'re' - 'c1'.'im' * 'c2'.'im', 'c1'.'re' * 'c2'.'im' + 'c1'.'im' * 'c2'.'re');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexMagneticPotentialDifference.\'*\'.multiply';

  function 'Modelica.Units.SI.ComplexMagneticPotentialDifference.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexMagneticPotentialDifference.\'constructor\'.fromReal';

  record 'Modelica.Units.SI.ComplexMagneticPotentialDifference'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexMagneticPotentialDifference';

  record 'Modelica.Units.SI.ComplexMagneticFlux'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexMagneticFlux';

  record 'Modelica.Units.SI.ComplexMagneticPotential'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexMagneticPotential';

  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  model 'IMC_DOL_CommonLeakage' "Direct on line start of polyphase induction machine with squirrel cage"
    parameter Integer 'm' = 5 "Number of stator phases" annotation(Evaluate = true);
    parameter Integer 'mBase' = 1 "Number of symmetric base systems";
    parameter Real 'VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'tOn'(unit = "s", quantity = "Time") = 0.1 "Start time of machine";
    parameter Real 'T_Load'(unit = "N.m", quantity = "Torque") = 161.4 "Nominal load torque";
    parameter Real 'w_Load'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal load speed";
    parameter Real 'J_Load'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load inertia";
    Real 'groundM.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'groundM.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'starM.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'starM.plug_p.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    Real 'starM.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'starM.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'starM.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'starM.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'starM.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'starM.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'starM.plug_p.pin[4].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'starM.plug_p.pin[4].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'starM.plug_p.pin[5].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'starM.plug_p.pin[5].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'starM.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'starM.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'sineVoltageM.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltageM.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltageM.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltageM.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltageM.v[4]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltageM.v[5]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltageM.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'sineVoltageM.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'sineVoltageM.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'sineVoltageM.i[4]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'sineVoltageM.i[5]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    parameter Integer 'sineVoltageM.plug_p.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltageM.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.plug_p.pin[4].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_p.pin[4].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.plug_p.pin[5].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_p.pin[5].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'sineVoltageM.plug_n.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltageM.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.plug_n.pin[4].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_n.pin[4].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.plug_n.pin[5].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.plug_n.pin[5].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'sineVoltageM.V[1]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitudes of sine waves";
    parameter Real 'sineVoltageM.V[2]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitudes of sine waves";
    parameter Real 'sineVoltageM.V[3]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitudes of sine waves";
    parameter Real 'sineVoltageM.V[4]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitudes of sine waves";
    parameter Real 'sineVoltageM.V[5]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitudes of sine waves";
    parameter Real 'sineVoltageM.phase[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phases of sine waves";
    parameter Real 'sineVoltageM.phase[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -1.2566370614359172 "Phases of sine waves";
    parameter Real 'sineVoltageM.phase[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.5132741228718345 "Phases of sine waves";
    parameter Real 'sineVoltageM.phase[4]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -3.7699111843077517 "Phases of sine waves";
    parameter Real 'sineVoltageM.phase[5]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -5.026548245743669 "Phases of sine waves";
    parameter Real 'sineVoltageM.f[1]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'sineVoltageM.f[2]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'sineVoltageM.f[3]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'sineVoltageM.f[4]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'sineVoltageM.f[5]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'sineVoltageM.offset[1]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'sineVoltageM.offset[2]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'sineVoltageM.offset[3]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'sineVoltageM.offset[4]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'sineVoltageM.offset[5]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'sineVoltageM.startTime[1]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'sineVoltageM.startTime[2]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'sineVoltageM.startTime[3]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'sineVoltageM.startTime[4]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'sineVoltageM.startTime[5]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'sineVoltageM.sineVoltage[1].V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[1].phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[1].f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    Real 'sineVoltageM.sineVoltage[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sineVoltageM.sineVoltage[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.sineVoltage[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.sineVoltage[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.sineVoltage[1].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.sineVoltage[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sineVoltageM.sineVoltage[1].signalSource.amplitude' = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[1].signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[1].signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase of sine wave";
    parameter Boolean 'sineVoltageM.sineVoltage[1].signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltageM.sineVoltage[1].signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltageM.sineVoltage[1].signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineVoltageM.sineVoltage[1].signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sineVoltageM.sineVoltage[1].offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'sineVoltageM.sineVoltage[1].startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'sineVoltageM.sineVoltage[2].V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[2].phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -1.2566370614359172 "Phase of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[2].f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    Real 'sineVoltageM.sineVoltage[2].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sineVoltageM.sineVoltage[2].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.sineVoltage[2].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.sineVoltage[2].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltageM.sineVoltage[2].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltageM.sineVoltage[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sineVoltageM.sineVoltage[2].signalSource.amplitude' = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[2].signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[2].signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -1.2566370614359172 "Phase of sine wave";
    parameter Boolean 'sineVoltageM.sineVoltage[2].signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltageM.sineVoltage[2].signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltageM.sineVoltage[2].signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineVoltageM.sineVoltage[2].signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sineVoltageM.sineVoltage[2].offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'sineVoltageM.sineVoltage[2].startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'sineVoltageM.sineVoltage[3].V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[3].phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.5132741228718345 "Phase of sine wave";
    parameter Real 'sineVoltageM.sineVoltage[3].f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
