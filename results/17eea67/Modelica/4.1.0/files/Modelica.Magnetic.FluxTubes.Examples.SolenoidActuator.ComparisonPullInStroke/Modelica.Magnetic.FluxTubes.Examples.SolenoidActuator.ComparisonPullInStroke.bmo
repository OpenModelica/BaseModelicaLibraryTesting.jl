//! base 0.1.0
package 'ComparisonPullInStroke'
  function 'Modelica.Blocks.Tables.Internal.getDerTimeTableValueNoDer' "Derivative of interpolated 1-dim. table where first column is time (but do not provide a derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Integer 'icol';
    input Real 'timeIn';
    input Real 'nextTimeEvent';
    input Real 'pre_nextTimeEvent';
    input Real 'der_timeIn';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTimeTable_getDerValue('tableID', 'icol', 'timeIn', 'nextTimeEvent', 'pre_nextTimeEvent', 'der_timeIn') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getDerTimeTableValueNoDer';

  function 'Modelica.Blocks.Tables.Internal.getNextTimeEvent' "Return next time event value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Real 'timeIn';
    output Real 'nextTimeEvent';
  external "C" 'nextTimeEvent' = ModelicaStandardTables_CombiTimeTable_nextTimeEvent('tableID', 'timeIn') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getNextTimeEvent';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmax' "Return maximum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMax';
  external "C" 'timeMax' = ModelicaStandardTables_CombiTimeTable_maximumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmax';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmin' "Return minimum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMin';
  external "C" 'timeMin' = ModelicaStandardTables_CombiTimeTable_minimumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmin';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer2' "Interpolate 1-dim. table where first column is time (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Integer 'icol';
    input Real 'timeIn';
    input Real 'nextTimeEvent';
    input Real 'pre_nextTimeEvent';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTimeTable_getValue('tableID', 'icol', 'timeIn', 'nextTimeEvent', 'pre_nextTimeEvent') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1, noDerivative = 'nextTimeEvent', noDerivative = 'pre_nextTimeEvent') = 'Modelica.Blocks.Tables.Internal.getDerTimeTableValueNoDer');
  end 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer2';

  function 'Modelica.Math.log' "Natural (base e) logarithm (u shall be > 0)"
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := log('u');
    annotation(Inline = true);
  end 'Modelica.Math.log';

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  type 'Modelica.Blocks.Types.TimeEvents' = enumeration('Always', 'AtDiscontinuities', 'NoTimeEvents');

  class 'Modelica.Blocks.Types.ExternalCombiTimeTable'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table where first column is time"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Real 'startTime';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation';
      input Real 'shiftTime' = 0.0;
      input 'Modelica.Blocks.Types.TimeEvents' 'timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" 'externalCombiTimeTable' = ModelicaStandardTables_CombiTimeTable_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'startTime', 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'shiftTime', 'timeEvents', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table where first column is time"
      input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" ModelicaStandardTables_CombiTimeTable_close('externalCombiTimeTable') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTimeTable';

  model 'ComparisonPullInStroke' "Pull-in stroke of both solenoid models after a voltage step at time t=0"
    parameter Real 'v_step'(unit = "V", quantity = "ElectricPotential") = 12.0 "Applied voltage";
    Real 'advancedGround.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'advancedGround.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'advancedSource.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 12.0 "Height of step";
    Real 'advancedSource.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'advancedSource.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'advancedSource.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'advancedSource.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'advancedSource.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'advancedSource.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'advancedSource.signalSource.height' = 12.0 "Height of step";
    Real 'advancedSource.signalSource.y' "Connector of Real output signal";
    parameter Real 'advancedSource.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'advancedSource.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'advancedSource.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'advancedSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'advancedSolenoid.N' = 957.0 "Number of turns";
    parameter Real 'advancedSolenoid.R'(unit = "Ohm", quantity = "Resistance") = 5.0 "Coil resistance";
    parameter Real 'advancedSolenoid.R_par'(unit = "Ohm", quantity = "Resistance") = 1e5 "Resistance parallel to the coil, in series to C_par";
    parameter Real 'advancedSolenoid.C_par'(min = 0.0, unit = "F", quantity = "Capacitance") = 1e-9 "Capacitance parallel to the coil, in series to R_par";
    parameter Real 'advancedSolenoid.r_yokeOut'(min = 0.0, unit = "m", quantity = "Length") = 0.015 "Outer yoke radius";
    parameter Real 'advancedSolenoid.r_yokeIn'(min = 0.0, unit = "m", quantity = "Length") = 0.0135 "Inner yoke radius";
    parameter Real 'advancedSolenoid.l_yoke'(unit = "m", quantity = "Length") = 0.035 "Axial yoke length";
    parameter Real 'advancedSolenoid.t_yokeBot'(unit = "m", quantity = "Length") = 0.0035 "Axial thickness of yoke bottom";
    parameter Real 'advancedSolenoid.l_pole'(unit = "m", quantity = "Length") = 0.0065 "Axial length of pole";
    parameter Real 'advancedSolenoid.t_poleBot'(unit = "m", quantity = "Length") = 0.0035 "Axial thickness of bottom at pole side";
    parameter Real 'advancedSolenoid.t_airPar'(unit = "m", quantity = "Length") = 6.5e-4 "Radial thickness of parasitic air gap due to slide guiding";
    parameter String 'advancedSolenoid.material.label' = "9SMnPb28" "Name of material";
    parameter Real 'advancedSolenoid.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 400.0 "Initial relative permeability at B=0";
    parameter Real 'advancedSolenoid.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.488 "Flux density at maximum relative permeability";
    parameter Real 'advancedSolenoid.material.c_a' = 1200.0 "Coefficient of approximation function";
    parameter Real 'advancedSolenoid.material.c_b' = 3.0 "Coefficient of approximation function";
    parameter Real 'advancedSolenoid.material.n' = 12.5 "Exponent of approximation function";
    parameter Real 'advancedSolenoid.r_arm'(min = 0.0, unit = "m", quantity = "Length") = 0.005 "Armature radius = pole radius";
    parameter Real 'advancedSolenoid.l_arm'(unit = "m", quantity = "Length") = 0.026 "Armature length";
    parameter Real 'advancedSolenoid.c'(unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring stiffness between impact partners";
    parameter Real 'advancedSolenoid.d'(unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping coefficient between impact partners";
    parameter Real 'advancedSolenoid.x_min'(unit = "m", quantity = "Length") = 2.5e-4 "Stopper at minimum armature position";
    parameter Real 'advancedSolenoid.x_max'(unit = "m", quantity = "Length") = 0.005 "Stopper at maximum armature position";
    Real 'advancedSolenoid.x'(stateSelect = StateSelect.prefer, fixed = true, start = 0.005, unit = "m", quantity = "Length") "Armature position";
    Real 'advancedSolenoid.Psi_tot'(unit = "Wb", quantity = "MagneticFlux") "Total flux linkage for information only";
    Real 'advancedSolenoid.L_statTot'(unit = "H", quantity = "Inductance") "Total static inductance for information only";
    parameter Real 'advancedSolenoid.rho_steel'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 7853.0 "Density for calculation of armature mass from geometry";
    Real 'advancedSolenoid.ground.port.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.ground.port.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.coil1.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.coil1.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.coil1.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.coil1.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.coil1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'advancedSolenoid.coil1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'advancedSolenoid.coil1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'advancedSolenoid.coil1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'advancedSolenoid.coil1.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'advancedSolenoid.coil1.i'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'advancedSolenoid.coil1.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'advancedSolenoid.coil1.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux coupled into magnetic circuit";
    parameter Real 'advancedSolenoid.coil1.N' = 478.5 "Number of turns";
    Real 'advancedSolenoid.coil1.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'advancedSolenoid.coil1.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    Real 'advancedSolenoid.coil1.eps';
    parameter Real 'advancedSolenoid.r_1.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 5.0 "Resistance at temperature T_ref";
    parameter Real 'advancedSolenoid.r_1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'advancedSolenoid.r_1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'advancedSolenoid.r_1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'advancedSolenoid.r_1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'advancedSolenoid.r_1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'advancedSolenoid.r_1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'advancedSolenoid.r_1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'advancedSolenoid.r_1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'advancedSolenoid.r_1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'advancedSolenoid.r_1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'advancedSolenoid.r_1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'advancedSolenoid.r_1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'advancedSolenoid.r_1.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'advancedSolenoid.g_mFeYokeSide1.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.g_mFeYokeSide1.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.g_mFeYokeSide1.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.g_mFeYokeSide1.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.g_mFeYokeSide1.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'advancedSolenoid.g_mFeYokeSide1.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'advancedSolenoid.g_mFeYokeSide1.nonLinearPermeability' = true "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'advancedSolenoid.g_mFeYokeSide1.material.label' = "9SMnPb28" "Name of material";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 400.0 "Initial relative permeability at B=0";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.488 "Flux density at maximum relative permeability";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.material.c_a' = 1200.0 "Coefficient of approximation function";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.material.c_b' = 3.0 "Coefficient of approximation function";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.material.n' = 12.5 "Exponent of approximation function";
    Real 'advancedSolenoid.g_mFeYokeSide1.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'advancedSolenoid.g_mFeYokeSide1.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'advancedSolenoid.g_mFeYokeSide1.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'advancedSolenoid.g_mFeYokeSide1.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'advancedSolenoid.g_mFeYokeSide1.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'advancedSolenoid.g_mFeYokeSide1.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'advancedSolenoid.g_mFeYokeSide1.B_N' "Absolute value of normalized B";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.l'(unit = "m", quantity = "Length") = 0.01575 "Axial length (in direction of flux)";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.0135 "Inner radius of hollow cylinder (zero for cylinder)";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.015 "Outer radius of (hollow) cylinder";
    parameter Real 'advancedSolenoid.g_mFeYokeSide1.alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 6.283185307179586 "Central angle";
    Real 'advancedSolenoid.g_mFeArm.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.g_mFeArm.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.g_mFeArm.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.g_mFeArm.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.g_mFeArm.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'advancedSolenoid.g_mFeArm.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'advancedSolenoid.g_mFeArm.nonLinearPermeability' = true "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'advancedSolenoid.g_mFeArm.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'advancedSolenoid.g_mFeArm.material.label' = "9SMnPb28" "Name of material";
    parameter Real 'advancedSolenoid.g_mFeArm.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 400.0 "Initial relative permeability at B=0";
    parameter Real 'advancedSolenoid.g_mFeArm.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.488 "Flux density at maximum relative permeability";
    parameter Real 'advancedSolenoid.g_mFeArm.material.c_a' = 1200.0 "Coefficient of approximation function";
    parameter Real 'advancedSolenoid.g_mFeArm.material.c_b' = 3.0 "Coefficient of approximation function";
    parameter Real 'advancedSolenoid.g_mFeArm.material.n' = 12.5 "Exponent of approximation function";
    Real 'advancedSolenoid.g_mFeArm.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'advancedSolenoid.g_mFeArm.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'advancedSolenoid.g_mFeArm.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'advancedSolenoid.g_mFeArm.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'advancedSolenoid.g_mFeArm.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'advancedSolenoid.g_mFeArm.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'advancedSolenoid.g_mFeArm.B_N' "Absolute value of normalized B";
    parameter Real 'advancedSolenoid.g_mFeArm.l'(unit = "m", quantity = "Length") = 0.022375000000000003 "Axial length (in direction of flux)";
    parameter Real 'advancedSolenoid.g_mFeArm.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Inner radius of hollow cylinder (zero for cylinder)";
    parameter Real 'advancedSolenoid.g_mFeArm.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.005 "Outer radius of (hollow) cylinder";
    parameter Real 'advancedSolenoid.g_mFeArm.alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 6.283185307179586 "Central angle";
    Real 'advancedSolenoid.g_mAirWork.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.g_mAirWork.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.g_mAirWork.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.g_mAirWork.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.g_mAirWork.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'advancedSolenoid.g_mAirWork.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'advancedSolenoid.g_mAirWork.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    parameter Real 'advancedSolenoid.g_mAirWork.mu_r'(start = 1.0, unit = "1", quantity = "RelativePermeability") = 1.0 "Relative magnetic permeability";
    Real 'advancedSolenoid.g_mAirWork.F_m'(unit = "N", quantity = "Force") "Reluctance force";
    Real 'advancedSolenoid.g_mAirWork.s'(unit = "m", quantity = "Length") "Distance between flange and support";
    Real 'advancedSolenoid.g_mAirWork.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'advancedSolenoid.g_mAirWork.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'advancedSolenoid.g_mAirWork.dGmBydx'(unit = "V.s/(A.m)", quantity = "Permeability") "Derivative of permeance with respect to armature position";
    parameter Integer 'advancedSolenoid.g_mAirWork.dlBydx' = 1 "Derivative of flux tube's varying dimension with respect to armature position; set to +1 or -1";
    Real 'advancedSolenoid.g_mAirWork.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'advancedSolenoid.g_mAirWork.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'advancedSolenoid.g_mAirWork.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'advancedSolenoid.g_mAirWork.l'(unit = "m", quantity = "Length") "Axial length (in direction of flux)";
    parameter Real 'advancedSolenoid.g_mAirWork.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Inner radius of (hollow) cylinder";
    parameter Real 'advancedSolenoid.g_mAirWork.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.005 "Outer radius of (hollow) cylinder";
    Real 'advancedSolenoid.g_mAirWork.B'(unit = "T", quantity = "MagneticFluxDensity") "Homogeneous flux density";
    parameter Real 'advancedSolenoid.g_mAirWork.A'(unit = "m2", quantity = "Area") = 7.853981633974483e-5 "Cross-sectional area orthogonal to direction of flux";
    Real 'advancedSolenoid.g_mFeYokeBot.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.g_mFeYokeBot.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'advancedSolenoid.g_mFeYokeBot.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'advancedSolenoid.g_mFeYokeBot.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
