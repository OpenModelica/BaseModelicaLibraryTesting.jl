    'simpleSolenoid.g_mLeak2.Phi' = 'simpleSolenoid.g_mLeak2.port_p.Phi';
    'simpleSolenoid.g_mLeakWork.G_m' = 1.6336281807560003e-8 * 'Modelica.Math.log'(1.0 + 0.00942477796076938 / 'simpleSolenoid.g_mLeakWork.l');
    'simpleSolenoid.g_mLeakWork.dGmBydx' = -1.5396582874080926e-10 / ('simpleSolenoid.g_mLeakWork.l' ^ 2.0 * (1.0 + 0.00942477796076938 / 'simpleSolenoid.g_mLeakWork.l'));
    'simpleSolenoid.g_mLeakWork.V_m' = 'simpleSolenoid.g_mLeakWork.Phi' * 'simpleSolenoid.g_mLeakWork.R_m';
    'simpleSolenoid.g_mLeakWork.R_m' = 1.0 / 'simpleSolenoid.g_mLeakWork.G_m';
    'simpleSolenoid.g_mLeakWork.F_m' = 0.5 * 'simpleSolenoid.g_mLeakWork.V_m' ^ 2.0 * 'simpleSolenoid.g_mLeakWork.dGmBydx';
    'simpleSolenoid.g_mLeakWork.s_support' = 0.0;
    'simpleSolenoid.g_mLeakWork.flange.f' = -'simpleSolenoid.g_mLeakWork.F_m';
    0.0 = 'simpleSolenoid.g_mLeakWork.port_p.Phi' + 'simpleSolenoid.g_mLeakWork.port_n.Phi';
    'simpleSolenoid.g_mLeakWork.V_m' = 'simpleSolenoid.g_mLeakWork.port_p.V_m' - 'simpleSolenoid.g_mLeakWork.port_n.V_m';
    'simpleSolenoid.g_mLeakWork.Phi' = 'simpleSolenoid.g_mLeakWork.port_p.Phi';
    'simpleSolenoid.x' = 'simpleSolenoid.flange.s';
    'simpleLoad.v' = der('simpleLoad.s');
    'simpleLoad.a' = der('simpleLoad.v');
    0.01 * 'simpleLoad.a' = 'simpleLoad.flange_a.f' + 'simpleLoad.flange_b.f';
    'simpleLoad.flange_a.s' = 'simpleLoad.s';
    'simpleLoad.flange_b.s' = 'simpleLoad.s';
    'comparisonWithFEA.timeScaled' = time;

    when {time >= pre('comparisonWithFEA.nextTimeEvent'), initial()} then
      'comparisonWithFEA.nextTimeEventScaled' = 'Modelica.Blocks.Tables.Internal.getNextTimeEvent'('comparisonWithFEA.tableID', 'comparisonWithFEA.timeScaled');
      'comparisonWithFEA.nextTimeEvent' = if 'comparisonWithFEA.nextTimeEventScaled' < 1e60 then 'comparisonWithFEA.nextTimeEventScaled' else 1e60;
    end when;

    'comparisonWithFEA.y[1]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer2'('comparisonWithFEA.tableID', 1, 'comparisonWithFEA.timeScaled', 'comparisonWithFEA.nextTimeEventScaled', pre('comparisonWithFEA.nextTimeEventScaled'));
    'comparisonWithFEA.y[2]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer2'('comparisonWithFEA.tableID', 2, 'comparisonWithFEA.timeScaled', 'comparisonWithFEA.nextTimeEventScaled', pre('comparisonWithFEA.nextTimeEventScaled'));
    'comparisonWithFEA.y[3]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer2'('comparisonWithFEA.tableID', 3, 'comparisonWithFEA.timeScaled', 'comparisonWithFEA.nextTimeEventScaled', pre('comparisonWithFEA.nextTimeEventScaled'));
    annotation(experiment(StopTime = 0.05, Tolerance = 1e-007));
  end 'ComparisonPullInStroke';
end 'ComparisonPullInStroke';
