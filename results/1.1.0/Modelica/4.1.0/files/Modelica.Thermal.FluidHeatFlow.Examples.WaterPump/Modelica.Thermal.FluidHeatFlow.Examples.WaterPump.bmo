    Real 'idealPump.flowPort_a.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'idealPump.flowPort_a.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'idealPump.flowPort_a.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'idealPump.flowPort_b.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'idealPump.flowPort_b.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'idealPump.flowPort_b.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'idealPump.flowPort_b.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'idealPump.flowPort_b.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    Real 'idealPump.flowPort_b.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'idealPump.flowPort_b.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'idealPump.flowPort_b.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'idealPump.flowPort_b.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'idealPump.wNominal'(start = 1.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 104.71975511966 "Nominal speed";
    parameter Real 'idealPump.dp0'(start = 2.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 5e5 "Max. pressure increase @ V_flow=0";
    parameter Real 'idealPump.V_flow0'(start = 2.0, unit = "m3/s", quantity = "VolumeFlowRate") = 0.18 "Max. volume flow rate @ dp=0";
    Real 'idealPump.w'(unit = "rad/s", quantity = "AngularVelocity") = der('idealPump.flange_a.phi') "Speed";
    Real 'idealPump.dp1'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'idealPump.V_flow1'(unit = "m3/s", quantity = "VolumeFlowRate");
    Real 'idealPump.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'idealPump.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'volumeFlowSensor.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'volumeFlowSensor.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'volumeFlowSensor.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'volumeFlowSensor.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
