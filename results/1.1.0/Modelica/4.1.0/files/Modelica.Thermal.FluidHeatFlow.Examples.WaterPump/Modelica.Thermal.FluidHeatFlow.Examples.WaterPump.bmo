//! base 0.1.0
package 'WaterPump'
  model 'WaterPump' "Water pumping station"
    output Real 'V_flow'(unit = "m3/s", quantity = "VolumeFlowRate") = 'volumeFlowSensor.y' "Volume flow rate";
    output Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'pressureSensor.y' "Pressure at pump outlet";
    output Real 'w'(displayUnit = "1/min", unit = "rad/s", quantity = "AngularVelocity") = 'multiSensor.w' "Pump speed";
    output Real 'tau'(unit = "N.m", quantity = "Torque") = 'multiSensor.tau' "Pump torque";
    output Real 'power'(unit = "W", quantity = "Power") = 'multiSensor.power' "Pump power";
    parameter Real 'trapezoid.amplitude' = 1.2 "Amplitude of trapezoid";
    parameter Real 'trapezoid.rising'(min = 0.0, unit = "s", quantity = "Time") = 0.6 "Rising duration of trapezoid";
    parameter Real 'trapezoid.width'(min = 0.0, unit = "s", quantity = "Time") = 0.6 "Width duration of trapezoid";
    parameter Real 'trapezoid.falling'(min = 0.0, unit = "s", quantity = "Time") = 0.6 "Falling duration of trapezoid";
    parameter Real 'trapezoid.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 2.0 "Time for one period";
    parameter Integer 'trapezoid.nperiod' = 1 "Number of periods (< 0 means infinite number of periods)";
    Real 'trapezoid.y' "Connector of Real output signal";
    parameter Real 'trapezoid.offset' = 0.0 "Offset of output signal y";
    parameter Real 'trapezoid.startTime'(unit = "s", quantity = "Time") = 0.1 "Output y = offset for time < startTime";
    parameter Real 'trapezoid.T_rising'(unit = "s", quantity = "Time") = 0.6 "End time of rising phase within one period";
    parameter Real 'trapezoid.T_width'(unit = "s", quantity = "Time") = 1.2 "End time of width phase within one period";
    parameter Real 'trapezoid.T_falling'(unit = "s", quantity = "Time") = 1.7999999999999998 "End time of falling phase within one period";
    Real 'trapezoid.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'trapezoid.count' "Period count";
    parameter Real 'gain.k'(start = 1.0) = 104.71975511966 "Gain value multiplied with input signal";
    Real 'gain.u' "Input signal connector";
    Real 'gain.y' "Output signal connector";
    parameter Boolean 'speed.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'speed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'speed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'speed.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    parameter Boolean 'speed.exact' = true "Is true/false for exact treatment/filtering of the input signal, respectively" annotation(Evaluate = true);
    parameter Real 'speed.f_crit'(unit = "Hz", quantity = "Frequency") = 50.0 "If exact=false, critical frequency of filter to filter input signal";
    Real 'speed.phi'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotation angle of flange with respect to support";
    Real 'speed.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange with respect to support";
    Real 'speed.a'(unit = "rad/s2", quantity = "AngularAcceleration") "If exact=false, angular acceleration of flange with respect to support else dummy";
    Real 'speed.w_ref'(unit = "rad/s") "Reference angular velocity of flange with respect to support as input signal";
    parameter Real 'speed.w_crit'(unit = "rad/s", quantity = "AngularFrequency") = 314.1592653589793 "Critical frequency";
    Real 'multiSensor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'multiSensor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'multiSensor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'multiSensor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'multiSensor.power'(unit = "W") "Power in flange flange_a as output signal";
    Real 'multiSensor.w'(displayUnit = "1/min", unit = "rad/s") "Absolute angular velocity of flange_a as output signal";
    Real 'multiSensor.tau'(unit = "N.m") "Torque in flange flange_a and flange_b (tau = flange_a.tau = -flange_b.tau) as output signal";
    parameter Real 'ambient1.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'ambient1.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'ambient1.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'ambient1.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'ambient1.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    parameter Real 'ambient1.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Initial temperature of medium";
    parameter Boolean 'ambient1.T0fixed' = false "Initial temperature guess value or fixed";
    Real 'ambient1.T_port'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'ambient1.T'(nominal = 300.0, fixed = false, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    parameter Real 'ambient1.flowPort.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'ambient1.flowPort.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'ambient1.flowPort.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'ambient1.flowPort.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'ambient1.flowPort.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    Real 'ambient1.flowPort.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'ambient1.flowPort.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'ambient1.flowPort.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'ambient1.flowPort.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    constant Boolean 'ambient1.Exchange' = true "Exchange of medium via flowport";
    Real 'ambient1.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy in the volume";
    parameter Boolean 'ambient1.usePressureInput' = false "Enable / disable pressure input" annotation(Evaluate = true);
    parameter Real 'ambient1.constantAmbientPressure'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Ambient pressure";
    parameter Boolean 'ambient1.useTemperatureInput' = false "Enable / disable temperature input" annotation(Evaluate = true);
    parameter Real 'ambient1.constantAmbientTemperature'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'ambient1.pAmbient'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'ambient1.TAmbient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    parameter Real 'idealPump.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'idealPump.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'idealPump.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'idealPump.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'idealPump.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    parameter Real 'idealPump.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.0 "Mass of medium";
    parameter Real 'idealPump.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Initial temperature of medium";
    parameter Boolean 'idealPump.T0fixed' = false "Initial temperature guess value or fixed";
    parameter Real 'idealPump.tapT'(max = 1.0, min = 0.0) = 1.0 "Defines temperature of heatPort between inlet and outlet temperature";
    Real 'idealPump.dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop a->b";
    Real 'idealPump.V_flow'(start = 0.0, unit = "m3/s", quantity = "VolumeFlowRate") "Volume flow a->b";
    Real 'idealPump.Q_flow'(unit = "W", quantity = "Power") "Heat exchange with ambient";
    Real 'idealPump.T'(nominal = 300.0, fixed = false, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    Real 'idealPump.T_a'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'idealPump.T_b'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_b";
    Real 'idealPump.dT'(unit = "K", quantity = "ThermodynamicTemperature");
    Real 'idealPump.T_q'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature relevant for heat exchange with ambient";
    Real 'idealPump.h'(start = 'idealPump.medium.cp' * 293.15, unit = "J/kg", quantity = "SpecificEnergy") "Medium's specific enthalpy";
    parameter Real 'idealPump.flowPort_a.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'idealPump.flowPort_a.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'idealPump.flowPort_a.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'idealPump.flowPort_a.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'idealPump.flowPort_a.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
