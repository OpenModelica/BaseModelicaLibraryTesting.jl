    parameter Real 'oneWayValve.flowPort_b.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'oneWayValve.flowPort_b.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'oneWayValve.flowPort_b.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    Real 'oneWayValve.flowPort_b.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'oneWayValve.flowPort_b.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'oneWayValve.flowPort_b.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'oneWayValve.flowPort_b.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'oneWayValve.V_flowNominal'(start = 1.0, unit = "m3/s", quantity = "VolumeFlowRate") = 0.18 "Nominal volume flow rate (forward)";
    parameter Real 'oneWayValve.dpForward'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e4 "Pressure drop at nominal flow (forward)";
    parameter Real 'oneWayValve.dpNominal'(start = 1e5, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 5e5 "Nominal pressure (backward)";
    parameter Real 'oneWayValve.V_flowBackward'(start = 1e-6, unit = "m3/s", quantity = "VolumeFlowRate") = 1e-6 "Leakage volume flow rate (backward)";
    parameter Real 'oneWayValve.frictionLoss'(start = 0.0, max = 1.0, min = 0.0) = 0.0 "Part of friction losses fed to medium";
    Boolean 'oneWayValve.backward'(start = true) "State forward=false / backward=true";
    Real 'oneWayValve.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the valve characteristic";
    constant Real 'oneWayValve.unitVolumeFlowRate'(unit = "m3/s", quantity = "VolumeFlowRate") = 1.0;
    constant Real 'oneWayValve.unitPressureDrop'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    parameter Real 'pipe.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'pipe.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'pipe.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'pipe.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'pipe.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    parameter Real 'pipe.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.0 "Mass of medium";
    parameter Real 'pipe.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Initial temperature of medium";
    parameter Boolean 'pipe.T0fixed' = false "Initial temperature guess value or fixed";
    parameter Real 'pipe.tapT'(max = 1.0, min = 0.0) = 1.0 "Defines temperature of heatPort between inlet and outlet temperature";
    Real 'pipe.dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop a->b";
    Real 'pipe.V_flow'(start = 0.0, unit = "m3/s", quantity = "VolumeFlowRate") "Volume flow a->b";
    Real 'pipe.Q_flow'(unit = "W", quantity = "Power") "Heat exchange with ambient";
    Real 'pipe.T'(nominal = 300.0, fixed = false, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    Real 'pipe.T_a'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'pipe.T_b'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_b";
    Real 'pipe.dT'(unit = "K", quantity = "ThermodynamicTemperature");
    Real 'pipe.T_q'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature relevant for heat exchange with ambient";
    Real 'pipe.h'(start = 'pipe.medium.cp' * 293.15, unit = "J/kg", quantity = "SpecificEnergy") "Medium's specific enthalpy";
    parameter Real 'pipe.flowPort_a.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'pipe.flowPort_a.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'pipe.flowPort_a.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'pipe.flowPort_a.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'pipe.flowPort_a.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    Real 'pipe.flowPort_a.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'pipe.flowPort_a.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'pipe.flowPort_a.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pipe.flowPort_a.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'pipe.flowPort_b.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'pipe.flowPort_b.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'pipe.flowPort_b.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'pipe.flowPort_b.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'pipe.flowPort_b.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    Real 'pipe.flowPort_b.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'pipe.flowPort_b.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'pipe.flowPort_b.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pipe.flowPort_b.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'pipe.V_flowLaminar'(start = 0.1, min = 2.2250738585072014e-308, unit = "m3/s", quantity = "VolumeFlowRate") = 0.09 "Laminar volume flow";
    parameter Real 'pipe.dpLaminar'(start = 0.1, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e4 "Laminar pressure drop";
    parameter Real 'pipe.V_flowNominal'(start = 1.0, unit = "m3/s", quantity = "VolumeFlowRate") = 0.18 "Nominal volume flow";
    parameter Real 'pipe.dpNominal'(start = 1.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 3e4 "Nominal pressure drop";
    parameter Real 'pipe.frictionLoss'(max = 1.0, min = 0.0) = 0.0 "Part of friction losses fed to medium";
    Real 'pipe.pressureDrop'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'pipe.volumeFlow'(unit = "m3/s", quantity = "VolumeFlowRate");
    Real 'pipe.Q_friction'(unit = "W", quantity = "Power");
    parameter Real 'pipe.dpNomMin'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2e4;
    parameter Real 'pipe.k'(fixed = false, unit = "Pa.s2/m6");
    parameter Boolean 'pipe.useHeatPort' = false "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'pipe.h_g'(start = 0.0, unit = "m", quantity = "Length") = 25.0 "Geodetic height (height difference from flowPort_a to flowPort_b)";
    parameter Real 'pipe.g'(min = 0.0, unit = "m/s2", quantity = "Acceleration") = 9.80665 "Gravitation";
    Real 'pipe.Q_flowHeatPort'(unit = "W", quantity = "Power") "Heat flow at conditional heatPort";
    parameter Real 'ambient2.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'ambient2.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'ambient2.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'ambient2.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'ambient2.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    parameter Real 'ambient2.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Initial temperature of medium";
    parameter Boolean 'ambient2.T0fixed' = false "Initial temperature guess value or fixed";
    Real 'ambient2.T_port'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'ambient2.T'(nominal = 300.0, fixed = false, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    parameter Real 'ambient2.flowPort.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.6 "Density";
    parameter Real 'ambient2.flowPort.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant pressure";
    parameter Real 'ambient2.flowPort.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 4177.0 "Specific heat capacity at constant volume";
    parameter Real 'ambient2.flowPort.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 0.615 "Thermal conductivity";
    parameter Real 'ambient2.flowPort.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 8e-7 "Kinematic viscosity";
    Real 'ambient2.flowPort.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'ambient2.flowPort.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'ambient2.flowPort.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'ambient2.flowPort.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    constant Boolean 'ambient2.Exchange' = true "Exchange of medium via flowport";
    Real 'ambient2.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy in the volume";
    parameter Boolean 'ambient2.usePressureInput' = false "Enable / disable pressure input" annotation(Evaluate = true);
    parameter Real 'ambient2.constantAmbientPressure'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Ambient pressure";
    parameter Boolean 'ambient2.useTemperatureInput' = false "Enable / disable temperature input" annotation(Evaluate = true);
    parameter Real 'ambient2.constantAmbientTemperature'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'ambient2.pAmbient'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'ambient2.TAmbient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  equation
    'idealPump.flowPort_a.h' = 'ambient1.flowPort.h';
    assert(abs('idealPump.flowPort_a.medium.rho' - 'ambient1.flowPort.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('idealPump.flowPort_a.medium.cp' - 'ambient1.flowPort.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('idealPump.flowPort_a.medium.cv' - 'ambient1.flowPort.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('idealPump.flowPort_a.medium.lambda' - 'ambient1.flowPort.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('idealPump.flowPort_a.medium.nu' - 'ambient1.flowPort.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'idealPump.flowPort_a.p' = 'ambient1.flowPort.p';
    'speed.flange.phi' = 'multiSensor.flange_a.phi';
    'oneWayValve.flowPort_a.h' = 'pressureSensor.flowPort.h';
    'oneWayValve.flowPort_a.h' = 'volumeFlowSensor.flowPort_b.h';
    assert(abs('oneWayValve.flowPort_a.medium.rho' - 'pressureSensor.flowPort.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.rho' - 'volumeFlowSensor.flowPort_b.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.cp' - 'pressureSensor.flowPort.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.cp' - 'volumeFlowSensor.flowPort_b.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.cv' - 'pressureSensor.flowPort.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.cv' - 'volumeFlowSensor.flowPort_b.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.lambda' - 'pressureSensor.flowPort.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.lambda' - 'volumeFlowSensor.flowPort_b.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.nu' - 'pressureSensor.flowPort.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('oneWayValve.flowPort_a.medium.nu' - 'volumeFlowSensor.flowPort_b.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'oneWayValve.flowPort_a.p' = 'pressureSensor.flowPort.p';
    'oneWayValve.flowPort_a.p' = 'volumeFlowSensor.flowPort_b.p';
    'volumeFlowSensor.flowPort_a.h' = 'idealPump.flowPort_b.h';
    assert(abs('volumeFlowSensor.flowPort_a.medium.rho' - 'idealPump.flowPort_b.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('volumeFlowSensor.flowPort_a.medium.cp' - 'idealPump.flowPort_b.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('volumeFlowSensor.flowPort_a.medium.cv' - 'idealPump.flowPort_b.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('volumeFlowSensor.flowPort_a.medium.lambda' - 'idealPump.flowPort_b.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('volumeFlowSensor.flowPort_a.medium.nu' - 'idealPump.flowPort_b.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'volumeFlowSensor.flowPort_a.p' = 'idealPump.flowPort_b.p';
    'ambient2.flowPort.h' = 'pipe.flowPort_b.h';
    assert(abs('ambient2.flowPort.medium.rho' - 'pipe.flowPort_b.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient2.flowPort.medium.cp' - 'pipe.flowPort_b.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient2.flowPort.medium.cv' - 'pipe.flowPort_b.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient2.flowPort.medium.lambda' - 'pipe.flowPort_b.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient2.flowPort.medium.nu' - 'pipe.flowPort_b.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'ambient2.flowPort.p' = 'pipe.flowPort_b.p';
    'pipe.flowPort_a.h' = 'oneWayValve.flowPort_b.h';
    assert(abs('pipe.flowPort_a.medium.rho' - 'oneWayValve.flowPort_b.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe.flowPort_a.medium.cp' - 'oneWayValve.flowPort_b.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe.flowPort_a.medium.cv' - 'oneWayValve.flowPort_b.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe.flowPort_a.medium.lambda' - 'oneWayValve.flowPort_b.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe.flowPort_a.medium.nu' - 'oneWayValve.flowPort_b.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'pipe.flowPort_a.p' = 'oneWayValve.flowPort_b.p';
    'multiSensor.flange_b.phi' = 'idealPump.flange_a.phi';
    'gain.y' = 'speed.w_ref';
    'trapezoid.y' = 'gain.u';
    'multiSensor.flange_a.tau' + 'speed.flange.tau' = 0.0;
    'idealPump.flange_a.tau' + 'multiSensor.flange_b.tau' = 0.0;
    'idealPump.flowPort_a.m_flow' + 'ambient1.flowPort.m_flow' = 0.0;
    'idealPump.flowPort_a.H_flow' + 'ambient1.flowPort.H_flow' = 0.0;
    'volumeFlowSensor.flowPort_a.m_flow' + 'idealPump.flowPort_b.m_flow' = 0.0;
    'volumeFlowSensor.flowPort_a.H_flow' + 'idealPump.flowPort_b.H_flow' = 0.0;
    'oneWayValve.flowPort_a.m_flow' + 'pressureSensor.flowPort.m_flow' + 'volumeFlowSensor.flowPort_b.m_flow' = 0.0;
    'oneWayValve.flowPort_a.H_flow' + 'pressureSensor.flowPort.H_flow' + 'volumeFlowSensor.flowPort_b.H_flow' = 0.0;
    'pipe.flowPort_a.m_flow' + 'oneWayValve.flowPort_b.m_flow' = 0.0;
    'pipe.flowPort_a.H_flow' + 'oneWayValve.flowPort_b.H_flow' = 0.0;
    'ambient2.flowPort.m_flow' + 'pipe.flowPort_b.m_flow' = 0.0;
    'ambient2.flowPort.H_flow' + 'pipe.flowPort_b.H_flow' = 0.0;

    when time >= (pre('trapezoid.count') + 1) * 2.0 + 0.1 then
      'trapezoid.count' = pre('trapezoid.count') + 1;
      'trapezoid.T_start' = time;
    end when;

    'trapezoid.y' = if time < 0.1 or 'trapezoid.count' >= 1 then 0.0 else if time < 'trapezoid.T_start' + 0.6 then 1.2 * (time - 'trapezoid.T_start') / 0.6 else if time < 'trapezoid.T_start' + 1.2 then 1.2 else if time < 'trapezoid.T_start' + 1.7999999999999998 then 1.2 * ('trapezoid.T_start' + 1.7999999999999998 - time) / 0.6 else 0.0;
    'gain.y' = 104.71975511966 * 'gain.u';
    'speed.phi' = 'speed.flange.phi' - 'speed.phi_support';
    'speed.w' = der('speed.phi');
    'speed.w' = 'speed.w_ref';
    'speed.a' = 0.0;
    'speed.phi_support' = 0.0;
    'multiSensor.flange_a.phi' = 'multiSensor.flange_b.phi';
    'multiSensor.w' = der('multiSensor.flange_a.phi');
    'multiSensor.tau' = 'multiSensor.flange_a.tau';
    'multiSensor.power' = 'multiSensor.tau' * 'multiSensor.w';
    0.0 = 'multiSensor.flange_a.tau' + 'multiSensor.flange_b.tau';
    'ambient1.pAmbient' = 1e5;
    'ambient1.TAmbient' = 293.15;
    'ambient1.flowPort.p' = 'ambient1.pAmbient';
    'ambient1.T' = 'ambient1.TAmbient';
    'ambient1.T_port' = 'ambient1.flowPort.h' / 'ambient1.medium.cp';
    'ambient1.T' = 'ambient1.h' / 'ambient1.medium.cp';
    'ambient1.flowPort.H_flow' = semiLinear('ambient1.flowPort.m_flow', 'ambient1.flowPort.h', 'ambient1.h');
    'idealPump.dp1' = 5e5 * sign('idealPump.w' / 104.71975511966) * ('idealPump.w' / 104.71975511966) ^ 2.0;
    'idealPump.V_flow1' = 0.18 * ('idealPump.w' / 104.71975511966);

    if noEvent(abs('idealPump.w') < 2.2250738585072014e-308) then
      'idealPump.dp' = 0.0;
      'idealPump.flange_a.tau' = 0.0;
    elseif true then
      'idealPump.dp' = -'idealPump.dp1' * (1.0 - 'idealPump.V_flow' / 'idealPump.V_flow1');
      'idealPump.flange_a.tau' * 'idealPump.w' = -'idealPump.dp' * 'idealPump.V_flow';
    end if;

    'idealPump.Q_flow' = 0.0;
    'idealPump.dp' = 'idealPump.flowPort_a.p' - 'idealPump.flowPort_b.p';
    'idealPump.V_flow' = 'idealPump.flowPort_a.m_flow' / 'idealPump.medium.rho';
    'idealPump.T_a' = 'idealPump.flowPort_a.h' / 'idealPump.medium.cp';
    'idealPump.T_b' = 'idealPump.flowPort_b.h' / 'idealPump.medium.cp';
    'idealPump.dT' = if noEvent('idealPump.V_flow' >= 0.0) then 'idealPump.T' - 'idealPump.T_a' else 'idealPump.T_b' - 'idealPump.T';
    'idealPump.h' = 'idealPump.medium.cp' * 'idealPump.T';
    'idealPump.T_q' = 'idealPump.T';
    'idealPump.flowPort_a.m_flow' + 'idealPump.flowPort_b.m_flow' = 0.0;
    'idealPump.flowPort_a.H_flow' + 'idealPump.flowPort_b.H_flow' + 'idealPump.Q_flow' = 0.0;
    'idealPump.flowPort_a.H_flow' = semiLinear('idealPump.flowPort_a.m_flow', 'idealPump.flowPort_a.h', 'idealPump.h');
    'idealPump.flowPort_b.H_flow' = semiLinear('idealPump.flowPort_b.m_flow', 'idealPump.flowPort_b.h', 'idealPump.h');
    'volumeFlowSensor.y' = 'volumeFlowSensor.V_flow';
    'volumeFlowSensor.dp' = 0.0;
    'volumeFlowSensor.Q_flow' = 0.0;
    'volumeFlowSensor.dp' = 'volumeFlowSensor.flowPort_a.p' - 'volumeFlowSensor.flowPort_b.p';
    'volumeFlowSensor.V_flow' = 'volumeFlowSensor.flowPort_a.m_flow' / 'volumeFlowSensor.medium.rho';
    'volumeFlowSensor.T_a' = 'volumeFlowSensor.flowPort_a.h' / 'volumeFlowSensor.medium.cp';
    'volumeFlowSensor.T_b' = 'volumeFlowSensor.flowPort_b.h' / 'volumeFlowSensor.medium.cp';
    'volumeFlowSensor.dT' = if noEvent('volumeFlowSensor.V_flow' >= 0.0) then 'volumeFlowSensor.T' - 'volumeFlowSensor.T_a' else 'volumeFlowSensor.T_b' - 'volumeFlowSensor.T';
    'volumeFlowSensor.h' = 'volumeFlowSensor.medium.cp' * 'volumeFlowSensor.T';
    'volumeFlowSensor.T_q' = 'volumeFlowSensor.T';
    'volumeFlowSensor.flowPort_a.m_flow' + 'volumeFlowSensor.flowPort_b.m_flow' = 0.0;
    'volumeFlowSensor.flowPort_a.H_flow' + 'volumeFlowSensor.flowPort_b.H_flow' + 'volumeFlowSensor.Q_flow' = 0.0;
    'volumeFlowSensor.flowPort_a.H_flow' = semiLinear('volumeFlowSensor.flowPort_a.m_flow', 'volumeFlowSensor.flowPort_a.h', 'volumeFlowSensor.h');
    'volumeFlowSensor.flowPort_b.H_flow' = semiLinear('volumeFlowSensor.flowPort_b.m_flow', 'volumeFlowSensor.flowPort_b.h', 'volumeFlowSensor.h');
    'pressureSensor.y' = 'pressureSensor.flowPort.p';
    'pressureSensor.flowPort.m_flow' = 0.0;
    'pressureSensor.flowPort.H_flow' = 0.0;
    'oneWayValve.backward' = 'oneWayValve.s' < 0.0;
    'oneWayValve.dp' = 'oneWayValve.s' * (if 'oneWayValve.backward' then 1.0 else 55555.555555555555);
    'oneWayValve.V_flow' = 'oneWayValve.s' * (if 'oneWayValve.backward' then 2e-12 else 1.0);
    'oneWayValve.Q_flow' = 0.0;
    'oneWayValve.dp' = 'oneWayValve.flowPort_a.p' - 'oneWayValve.flowPort_b.p';
    'oneWayValve.V_flow' = 'oneWayValve.flowPort_a.m_flow' / 'oneWayValve.medium.rho';
    'oneWayValve.T_a' = 'oneWayValve.flowPort_a.h' / 'oneWayValve.medium.cp';
    'oneWayValve.T_b' = 'oneWayValve.flowPort_b.h' / 'oneWayValve.medium.cp';
    'oneWayValve.dT' = if noEvent('oneWayValve.V_flow' >= 0.0) then 'oneWayValve.T' - 'oneWayValve.T_a' else 'oneWayValve.T_b' - 'oneWayValve.T';
    'oneWayValve.h' = 'oneWayValve.medium.cp' * 'oneWayValve.T';
    'oneWayValve.T_q' = 'oneWayValve.T';
    'oneWayValve.flowPort_a.m_flow' + 'oneWayValve.flowPort_b.m_flow' = 0.0;
    'oneWayValve.flowPort_a.H_flow' + 'oneWayValve.flowPort_b.H_flow' + 'oneWayValve.Q_flow' = 0.0;
    'oneWayValve.flowPort_a.H_flow' = semiLinear('oneWayValve.flowPort_a.m_flow', 'oneWayValve.flowPort_a.h', 'oneWayValve.h');
    'oneWayValve.flowPort_b.H_flow' = semiLinear('oneWayValve.flowPort_b.m_flow', 'oneWayValve.flowPort_b.h', 'oneWayValve.h');
    'pipe.Q_flowHeatPort' = 0.0;
    'pipe.volumeFlow' = 'pipe.V_flow';
    'pipe.dp' = 'pipe.pressureDrop' + 'pipe.medium.rho' * 9.80665 * 25.0;
    'pipe.Q_flow' = 'pipe.Q_flowHeatPort' + 'pipe.Q_friction';

    if 'pipe.volumeFlow' > 0.09 then
      'pipe.pressureDrop' = 111111.11111111111 * 'pipe.volumeFlow' + 'pipe.k' * ('pipe.volumeFlow' - 0.09) ^ 2.0;
    elseif 'pipe.volumeFlow' < (-0.09) then
      'pipe.pressureDrop' = 111111.11111111111 * 'pipe.volumeFlow' - 'pipe.k' * ('pipe.volumeFlow' + 0.09) ^ 2.0;
    elseif true then
      'pipe.pressureDrop' = 111111.11111111111 * 'pipe.volumeFlow';
    end if;

    'pipe.Q_friction' = 0.0;
    'pipe.dp' = 'pipe.flowPort_a.p' - 'pipe.flowPort_b.p';
    'pipe.V_flow' = 'pipe.flowPort_a.m_flow' / 'pipe.medium.rho';
    'pipe.T_a' = 'pipe.flowPort_a.h' / 'pipe.medium.cp';
    'pipe.T_b' = 'pipe.flowPort_b.h' / 'pipe.medium.cp';
    'pipe.dT' = if noEvent('pipe.V_flow' >= 0.0) then 'pipe.T' - 'pipe.T_a' else 'pipe.T_b' - 'pipe.T';
    'pipe.h' = 'pipe.medium.cp' * 'pipe.T';
    'pipe.T_q' = 'pipe.T';
    'pipe.flowPort_a.m_flow' + 'pipe.flowPort_b.m_flow' = 0.0;
    'pipe.flowPort_a.H_flow' + 'pipe.flowPort_b.H_flow' + 'pipe.Q_flow' = 0.0;
    'pipe.flowPort_a.H_flow' = semiLinear('pipe.flowPort_a.m_flow', 'pipe.flowPort_a.h', 'pipe.h');
    'pipe.flowPort_b.H_flow' = semiLinear('pipe.flowPort_b.m_flow', 'pipe.flowPort_b.h', 'pipe.h');
    'ambient2.pAmbient' = 1e5;
    'ambient2.TAmbient' = 293.15;
    'ambient2.flowPort.p' = 'ambient2.pAmbient';
    'ambient2.T' = 'ambient2.TAmbient';
    'ambient2.T_port' = 'ambient2.flowPort.h' / 'ambient2.medium.cp';
    'ambient2.T' = 'ambient2.h' / 'ambient2.medium.cp';
    'ambient2.flowPort.H_flow' = semiLinear('ambient2.flowPort.m_flow', 'ambient2.flowPort.h', 'ambient2.h');
  initial algorithm
    'trapezoid.count' := integer((time - 0.1) / 2.0);
    'trapezoid.T_start' := 0.1 + 'trapezoid.count' * 2.0;
  initial algorithm
    assert(true, "SimpleFriction: V_flowNominal has to be > V_flowLaminar!", AssertionLevel.error);
    assert(true, "SimpleFriction: dpNominal has to be > dpLaminar/V_flowLaminar*V_flowNominal!", AssertionLevel.error);
    'pipe.k' := 1.2345679012345679e6;
    annotation(experiment(StopTime = 2, Interval = 0.001, Tolerance = 1e-06));
  end 'WaterPump';
end 'WaterPump';
