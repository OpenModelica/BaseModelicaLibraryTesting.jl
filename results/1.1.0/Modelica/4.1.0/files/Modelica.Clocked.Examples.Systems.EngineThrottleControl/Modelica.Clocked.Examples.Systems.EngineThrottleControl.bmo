//! base 0.1.0
package 'EngineThrottleControl'
  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'EngineThrottleControl' "Closed-loop throttle control synchronized to the crankshaft angle of an
   internal combustion engine"
    parameter Real 'speedRef.height' = 103.67 "Height of step";
    Real 'speedRef.y' "Connector of Real output signal";
    parameter Real 'speedRef.offset' = 207.34 "Offset of output signal y";
    parameter Real 'speedRef.startTime'(unit = "s", quantity = "Time") = 5.0 "Output y = offset for time < startTime";
    parameter Real 'speedControl.k_p' = 0.0614 "Proportional gain";
    parameter Real 'speedControl.k_I' = 0.0723 "Integral gain";
    Real 'speedControl.N_des'(start = 0.0, unit = "rad/s") "Desired speed, (rad/s)";
    Real 'speedControl.N'(start = 0.0, unit = "rad/s") "Measured speed, (rad/s)";
    Real 'speedControl.Theta'(start = 8.9, unit = "deg") "Throttle angle (deg)";
    Real 'speedControl.x_d'(fixed = true, start = 8.973, unit = "deg", quantity = "Angle");
    Real 'sample1.u' "Connector of continuous-time, Real input signal";
    Real 'sample1.y' "Connector of clocked, Real output signal";
    parameter Real 'hold1.y_start' = 8.9 "Value of output y before the first tick of the clock associated to input u";
    Real 'hold1.u'(start = 8.9) "Connector of clocked, Real input signal";
    Real 'hold1.y' "Connector of continuous-time, Real output signal";
    Real 'engine.Theta'(unit = "deg") "Throttle angle (deg)";
    parameter Real 'engine.throttleBody.P_0'(unit = "bar", quantity = "Pressure") = 1.0 "Atmospheric pressure (bar)";
    Real 'engine.throttleBody.m_ai'(fixed = true, start = 0.0, unit = "g") "Mass";
    Real 'engine.throttleBody.f_Theta'(unit = "deg", quantity = "Angle") "Auxiliary variable";
    Real 'engine.throttleBody.g_Pm' "Auxiliary variable";
    Real 'engine.throttleBody.Theta'(unit = "deg") "Throttle angle (deg)";
    Real 'engine.throttleBody.Pm'(unit = "bar") "Intake manifold pressure (bar)";
    Real 'engine.throttleBody.m_ai_der'(unit = "g/s") "Mass flow rate of air into manifold (g/s)";
    Real 'engine.throttleBody.tmp1';
    Real 'engine.throttleBody.tmp2';
    Real 'engine.throttleBody.pratio';
    Real 'engine.throttleBody.gpratio';
    parameter Real 'engine.intakeManifold.RTVmRatio' = 0.41328 "RT/V_m";
    parameter Real 'engine.intakeManifold.P_0'(unit = "bar", quantity = "Pressure") = 0.543 "Initial value for P_m, (bar)";
    Real 'engine.intakeManifold.m_ai_der'(unit = "g/s") "Mass flow rate of air into manifold (g/s)";
    Real 'engine.intakeManifold.N'(unit = "rad/s") "Engine speed (rad/sec)";
    Real 'engine.intakeManifold.m_ao_der'(unit = "g/s") "Mass flow rate of air out of manifold (g/s)";
    Real 'engine.intakeManifold.P_m'(fixed = true, start = 0.543, unit = "bar") "Intake manifold pressure (bar)";
    parameter Real 'engine.torqueGeneration.AFR' = 14.6 "Air-fuel ratio";
    parameter Real 'engine.torqueGeneration.sigma' = 15.0 "Spark advance, BTDC";
    Real 'engine.torqueGeneration.m_a'(unit = "g") "Mass of air charge in cylinder (delayed of 180deg crankshaft rotation) (g)";
    Real 'engine.torqueGeneration.N'(unit = "rad/s") "Engine speed (rad/sec)";
    Real 'engine.torqueGeneration.T_torque_e'(unit = "N.m") "Torque generated by engine";
    parameter Boolean 'engine.crankshaftPositionEvent.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'engine.crankshaftPositionEvent.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'engine.crankshaftPositionEvent.y';
    Real 'engine.crankshaftPositionEvent.angle'(unit = "rad") "Input angle observed for generating clock ticks.";
    Integer 'engine.crankshaftPositionEvent.direction' "Rotation direction (sign: +1 or -1). Sampled with the provided clock signal
     'y'.";
    Boolean 'engine.crankshaftPositionEvent.direction_changed'(start = false) "= true, if the rotation direction of the observed angle changed since the last tick of y', otherwise false. Sampled with the provided clock signal y.";
    parameter Real 'engine.crankshaftPositionEvent.trigger_interval'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.1415926535898 "Rotational-interval the input angle must be changed to trigger the next clock tick";
    parameter Boolean 'engine.crankshaftPositionEvent.rotationalClock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'engine.crankshaftPositionEvent.rotationalClock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'engine.crankshaftPositionEvent.rotationalClock.y';
    Real 'engine.crankshaftPositionEvent.rotationalClock.angle'(unit = "rad") "Input angle observed for generating clock ticks.";
    Integer 'engine.crankshaftPositionEvent.rotationalClock.direction' "Rotation direction (sign: +1 or -1). Sampled with the provided clock signal
     'y'.";
    Boolean 'engine.crankshaftPositionEvent.rotationalClock.direction_changed'(start = false) "= true, if the rotation direction of the observed angle changed since the last tick of y', otherwise false. Sampled with the provided clock signal y.";
    Real 'engine.crankshaftPositionEvent.rotationalClock.trigger_interval'(unit = "rad") "Rotational-interval the input angle must be changed to trigger the next clock tick";
    parameter Boolean 'engine.crankshaftPositionEvent.rotationalClock.y_clock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'engine.crankshaftPositionEvent.rotationalClock.y_clock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'engine.crankshaftPositionEvent.rotationalClock.y_clock.y';
    Boolean 'engine.crankshaftPositionEvent.rotationalClock.y_clock.u';
    Real 'engine.crankshaftPositionEvent.rotationalClock.update_offset.u' "Connector of continuous-time, Real input signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.update_offset.y' "Connector of clocked, Real output signal";
    Clock 'engine.crankshaftPositionEvent.rotationalClock.update_offset.clock' "Output signal y is associated with this clock input";
    parameter Real 'engine.crankshaftPositionEvent.rotationalClock.angular_offset.y_start' = 0.0 "Value of output y before the first tick of the clock associated to input u";
    Real 'engine.crankshaftPositionEvent.rotationalClock.angular_offset.u'(start = 0.0) "Connector of clocked, Real input signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.angular_offset.y' "Connector of continuous-time, Real output signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.sub.u1' "Connector of Real input signal 1";
    Real 'engine.crankshaftPositionEvent.rotationalClock.sub.u2' "Connector of Real input signal 2";
    Real 'engine.crankshaftPositionEvent.rotationalClock.sub.y' "Connector of Real output signal";
    parameter Real 'engine.crankshaftPositionEvent.rotationalClock.sub.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'engine.crankshaftPositionEvent.rotationalClock.sub.k2' = -1.0 "Gain of input signal 2";
    Real 'engine.crankshaftPositionEvent.rotationalClock.less.u1' "Connector of first Real input signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.less.u2' "Connector of second Real input signal";
    Boolean 'engine.crankshaftPositionEvent.rotationalClock.less.y' "Connector of Boolean output signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.abs2.u' "Connector of Real input signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.abs2.y' "Connector of Real output signal";
    parameter Boolean 'engine.crankshaftPositionEvent.rotationalClock.abs2.generateEvent' = false "Choose whether events shall be generated" annotation(Evaluate = true);
    Real 'engine.crankshaftPositionEvent.rotationalClock.abs1.u' "Connector of Real input signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.abs1.y' "Connector of Real output signal";
    parameter Boolean 'engine.crankshaftPositionEvent.rotationalClock.abs1.generateEvent' = false "Choose whether events shall be generated" annotation(Evaluate = true);
    Real 'engine.crankshaftPositionEvent.rotationalClock.direction_sign.u' "Connector of Real input signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.direction_sign.y' "Connector of Real output signal";
    parameter Boolean 'engine.crankshaftPositionEvent.rotationalClock.direction_sign.generateEvent' = false "Choose whether events shall be generated" annotation(Evaluate = true);
    Real 'engine.crankshaftPositionEvent.rotationalClock.cast.u' "Connector of Real input signal";
    Integer 'engine.crankshaftPositionEvent.rotationalClock.cast.y' "Connector of Integer output signal";
    Integer 'engine.crankshaftPositionEvent.rotationalClock.changed.u'(start = 0) "Connector of Integer input signal.";
    Boolean 'engine.crankshaftPositionEvent.rotationalClock.changed.y' "Connector of Boolean output signal.";
    Real 'engine.crankshaftPositionEvent.rotationalClock.update_direction.u' "Connector of continuous-time, Real input signal";
    Real 'engine.crankshaftPositionEvent.rotationalClock.update_direction.y' "Connector of clocked, Real output signal";
    Clock 'engine.crankshaftPositionEvent.rotationalClock.update_direction.clock' "Output signal y is associated with this clock input";
    parameter Real 'engine.crankshaftPositionEvent.threshold.k'(start = 1.0) = 3.1415926535898 "Constant output value";
    Real 'engine.crankshaftPositionEvent.threshold.y' "Connector of Real output signal";
    Real 'engine.inductionToPowerDelay.m_a'(unit = "g") "Mass of cylinder air charge (g)";
    Real 'engine.inductionToPowerDelay.m_a_delayed'(unit = "g") "180deg delayed mass of cylinder air charge (g)";
    Clock 'engine.inductionToPowerDelay.clock';
    Real 'engine.inductionToPowerDelay.sample1.u' "Connector of continuous-time, Real input signal";
    Real 'engine.inductionToPowerDelay.sample1.y' "Connector of clocked, Real output signal";
    Clock 'engine.inductionToPowerDelay.sample1.clock' "Output signal y is associated with this clock input";
    parameter Real 'engine.inductionToPowerDelay.hold1.y_start' = 0.152 "Value of output y before the first tick of the clock associated to input u";
    Real 'engine.inductionToPowerDelay.hold1.u'(start = 0.152) "Connector of clocked, Real input signal";
    Real 'engine.inductionToPowerDelay.hold1.y' "Connector of continuous-time, Real output signal";
    Real 'engine.inductionToPowerDelay.delay.u' "Connector of clocked, Real input signal";
    Real 'engine.inductionToPowerDelay.delay.y' "Connector of clocked, Real output signal";
    parameter Integer 'engine.inductionToPowerDelay.delay.shift'(min = 0) = 1 "Delay = interval() * shift/resolution";
    parameter Integer 'engine.inductionToPowerDelay.delay.resolution'(min = 1) = 1 "Time quantization resolution of sample interval";
    parameter Integer 'engine.inductionToPowerDelay.delay.n' = 1;
    Real 'engine.inductionToPowerDelay.delay.u_buffer[1]'(start = 0.0) "The previous values of the inputs; u_last[1] = u, u_last[2] = previous(u_last[1]); u_last[3] = previous(u_last[2])";
    Real 'engine.inductionToPowerDelay.delay.u_buffer[2]'(start = 0.0) "The previous values of the inputs; u_last[1] = u, u_last[2] = previous(u_last[1]); u_last[3] = previous(u_last[2])";
    Boolean 'engine.inductionToPowerDelay.delay.first'(start = true) "Used to identify the first clock tick";
    Real 'engine.cylinderAirCharge.m_a'(unit = "g") "Mass of an cylinder air charge (g)";
    Real 'engine.cylinderAirCharge.m_ao_der'(unit = "g/s") "Mass flow rate of air out of manifold (g/s)";
    Clock 'engine.cylinderAirCharge.clock';
    Real 'engine.cylinderAirCharge.add.u1' "Connector of Real input signal 1";
    Real 'engine.cylinderAirCharge.add.u2' "Connector of Real input signal 2";
    Real 'engine.cylinderAirCharge.add.y' "Connector of Real output signal";
    parameter Real 'engine.cylinderAirCharge.add.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'engine.cylinderAirCharge.add.k2' = -1.0 "Gain of input signal 2";
    Real 'engine.cylinderAirCharge.sample1.u' "Connector of continuous-time, Real input signal";
    Real 'engine.cylinderAirCharge.sample1.y' "Connector of clocked, Real output signal";
    Clock 'engine.cylinderAirCharge.sample1.clock' "Output signal y is associated with this clock input";
    parameter Real 'engine.cylinderAirCharge.hold1.y_start' = 0.0 "Value of output y before the first tick of the clock associated to input u";
    Real 'engine.cylinderAirCharge.hold1.u'(start = 0.0) "Connector of clocked, Real input signal";
    Real 'engine.cylinderAirCharge.hold1.y' "Connector of continuous-time, Real output signal";
    parameter Real 'engine.cylinderAirCharge.integrator.k' = 1.0 "Integrator gain";
    parameter Boolean 'engine.cylinderAirCharge.integrator.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'engine.cylinderAirCharge.integrator.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'engine.cylinderAirCharge.integrator.initType' = 'Modelica.Blocks.Types.Init'.'InitialState' "Type of initialization (1: no init, 2: steady state, 3,4: initial output)" annotation(Evaluate = true);
    parameter Real 'engine.cylinderAirCharge.integrator.y_start' = 0.0 "Initial or guess value of output (= state)";
    Real 'engine.cylinderAirCharge.integrator.u' "Connector of Real input signal";
    Real 'engine.cylinderAirCharge.integrator.y' "Connector of Real output signal";
    Boolean 'engine.cylinderAirCharge.integrator.local_reset';
    Real 'engine.cylinderAirCharge.integrator.local_set';
    parameter Boolean 'engine.torque.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'engine.torque.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'engine.torque.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'engine.torque.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'engine.torque.tau'(unit = "N.m") "Accelerating torque acting at flange (= -flange.tau)";
    Real 'engine.inertia.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'engine.inertia.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'engine.inertia.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'engine.inertia.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'engine.inertia.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.14 "Moment of inertia";
    parameter StateSelect 'engine.inertia.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'engine.inertia.phi'(stateSelect = StateSelect.default, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'engine.inertia.w'(stateSelect = StateSelect.default, fixed = true, start = 209.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'engine.inertia.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'engine.speedSensor.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'engine.speedSensor.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'engine.speedSensor.w'(unit = "rad/s") "Absolute angular velocity of flange as output signal";
    Real 'engine.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'engine.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'engine.angleSensor.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'engine.angleSensor.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'engine.angleSensor.phi'(displayUnit = "deg", unit = "rad") "Absolute angle of flange as output signal";
    Clock 'engine.synchronize';
    parameter Real 'step1.height' = -5.0 "Height of step";
    Real 'step1.y' "Connector of Real output signal";
    parameter Real 'step1.offset' = 25.0 "Offset of output signal y";
    parameter Real 'step1.startTime'(unit = "s", quantity = "Time") = 2.0 "Output y = offset for time < startTime";
    parameter Real 'step2.height' = 5.0 "Height of step";
    Real 'step2.y' "Connector of Real output signal";
    parameter Real 'step2.offset' = 0.0 "Offset of output signal y";
    parameter Real 'step2.startTime'(unit = "s", quantity = "Time") = 8.0 "Output y = offset for time < startTime";
    Real 'add.u1' "Connector of Real input signal 1";
    Real 'add.u2' "Connector of Real input signal 2";
    Real 'add.y' "Connector of Real output signal";
    parameter Real 'add.k1' = -1.0 "Gain of input signal 1";
    parameter Real 'add.k2' = -1.0 "Gain of input signal 2";
    parameter Boolean 'torque.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'torque.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'torque.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'torque.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'torque.tau'(unit = "N.m") "Accelerating torque acting at flange (= -flange.tau)";
    Real 'angleSensor.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'angleSensor.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'angleSensor.phi'(displayUnit = "deg", unit = "rad") "Absolute angle of flange as output signal";
    Real 'derivative.u' "Connector of Real input signal";
    Real 'derivative.y' "Connector of Real output signal";
    Real 'sample2.u' "Connector of continuous-time, Real input signal";
    Real 'sample2.y' "Connector of clocked, Real output signal";
    Clock 'sample2.clock' "Output signal y is associated with this clock input";
  initial equation
    'engine.cylinderAirCharge.integrator.y' = 0.0;
  equation
    'engine.crankshaftPositionEvent.rotationalClock.angle' = 'engine.crankshaftPositionEvent.rotationalClock.sub.u1';
    'engine.crankshaftPositionEvent.rotationalClock.angle' = 'engine.crankshaftPositionEvent.rotationalClock.update_offset.u';
    'engine.crankshaftPositionEvent.rotationalClock.update_offset.y' = 'engine.crankshaftPositionEvent.rotationalClock.angular_offset.u';
    'engine.crankshaftPositionEvent.rotationalClock.angular_offset.y' = 'engine.crankshaftPositionEvent.rotationalClock.sub.u2';
    'engine.crankshaftPositionEvent.rotationalClock.less.y' = 'engine.crankshaftPositionEvent.rotationalClock.y_clock.u';
    'engine.crankshaftPositionEvent.rotationalClock.y_clock.y' = 'engine.crankshaftPositionEvent.rotationalClock.update_direction.clock';
    'engine.crankshaftPositionEvent.rotationalClock.y_clock.y' = 'engine.crankshaftPositionEvent.rotationalClock.y';
    'engine.crankshaftPositionEvent.rotationalClock.y_clock.y' = 'engine.crankshaftPositionEvent.rotationalClock.update_offset.clock';
    'engine.crankshaftPositionEvent.rotationalClock.sub.y' = 'engine.crankshaftPositionEvent.rotationalClock.update_direction.u';
    'engine.crankshaftPositionEvent.rotationalClock.sub.y' = 'engine.crankshaftPositionEvent.rotationalClock.abs1.u';
    'engine.crankshaftPositionEvent.rotationalClock.trigger_interval' = 'engine.crankshaftPositionEvent.rotationalClock.abs2.u';
    'engine.crankshaftPositionEvent.rotationalClock.abs1.y' = 'engine.crankshaftPositionEvent.rotationalClock.less.u2';
    'engine.crankshaftPositionEvent.rotationalClock.abs2.y' = 'engine.crankshaftPositionEvent.rotationalClock.less.u1';
    'engine.crankshaftPositionEvent.rotationalClock.direction_sign.y' = 'engine.crankshaftPositionEvent.rotationalClock.cast.u';
    'engine.crankshaftPositionEvent.rotationalClock.cast.y' = 'engine.crankshaftPositionEvent.rotationalClock.direction';
    'engine.crankshaftPositionEvent.rotationalClock.cast.y' = 'engine.crankshaftPositionEvent.rotationalClock.changed.u';
    'engine.crankshaftPositionEvent.rotationalClock.update_direction.y' = 'engine.crankshaftPositionEvent.rotationalClock.direction_sign.u';
    'engine.crankshaftPositionEvent.rotationalClock.changed.y' = 'engine.crankshaftPositionEvent.rotationalClock.direction_changed';
    'engine.crankshaftPositionEvent.angle' = 'engine.crankshaftPositionEvent.rotationalClock.angle';
    'engine.crankshaftPositionEvent.threshold.y' = 'engine.crankshaftPositionEvent.rotationalClock.trigger_interval';
    'engine.crankshaftPositionEvent.rotationalClock.y' = 'engine.crankshaftPositionEvent.y';
    'engine.crankshaftPositionEvent.rotationalClock.direction_changed' = 'engine.crankshaftPositionEvent.direction_changed';
    'engine.crankshaftPositionEvent.rotationalClock.direction' = 'engine.crankshaftPositionEvent.direction';
    'engine.inductionToPowerDelay.clock' = 'engine.inductionToPowerDelay.sample1.clock';
    'engine.inductionToPowerDelay.m_a' = 'engine.inductionToPowerDelay.sample1.u';
    'engine.inductionToPowerDelay.hold1.y' = 'engine.inductionToPowerDelay.m_a_delayed';
    'engine.inductionToPowerDelay.sample1.y' = 'engine.inductionToPowerDelay.delay.u';
    'engine.inductionToPowerDelay.delay.y' = 'engine.inductionToPowerDelay.hold1.u';
    'engine.cylinderAirCharge.add.y' = 'engine.cylinderAirCharge.m_a';
    'engine.cylinderAirCharge.clock' = 'engine.cylinderAirCharge.sample1.clock';
    'engine.cylinderAirCharge.sample1.y' = 'engine.cylinderAirCharge.hold1.u';
    'engine.cylinderAirCharge.hold1.y' = 'engine.cylinderAirCharge.add.u2';
    'engine.cylinderAirCharge.m_ao_der' = 'engine.cylinderAirCharge.integrator.u';
    'engine.cylinderAirCharge.integrator.y' = 'engine.cylinderAirCharge.sample1.u';
    'engine.cylinderAirCharge.integrator.y' = 'engine.cylinderAirCharge.add.u1';
    'engine.Theta' = 'engine.throttleBody.Theta';
    'engine.throttleBody.m_ai_der' = 'engine.intakeManifold.m_ai_der';
    'engine.intakeManifold.P_m' = 'engine.throttleBody.Pm';
    'engine.inductionToPowerDelay.m_a_delayed' = 'engine.torqueGeneration.m_a';
    'engine.cylinderAirCharge.m_a' = 'engine.inductionToPowerDelay.m_a';
    'engine.intakeManifold.m_ao_der' = 'engine.cylinderAirCharge.m_ao_der';
    'engine.torque.tau' = 'engine.torqueGeneration.T_torque_e';
    'engine.torque.flange.phi' = 'engine.inertia.flange_a.phi';
    'engine.angleSensor.flange.phi' = 'engine.inertia.flange_b.phi';
    'engine.angleSensor.flange.phi' = 'engine.flange_b.phi';
    'engine.angleSensor.flange.phi' = 'engine.speedSensor.flange.phi';
    'engine.angleSensor.flange.tau' + 'engine.speedSensor.flange.tau' + 'engine.inertia.flange_b.tau' - 'engine.flange_b.tau' = 0.0;
    'engine.intakeManifold.N' = 'engine.speedSensor.w';
    'engine.intakeManifold.N' = 'engine.torqueGeneration.N';
    'engine.angleSensor.phi' = 'engine.crankshaftPositionEvent.angle';
    'engine.crankshaftPositionEvent.y' = 'engine.synchronize';
    'engine.crankshaftPositionEvent.y' = 'engine.cylinderAirCharge.clock';
    'engine.crankshaftPositionEvent.y' = 'engine.inductionToPowerDelay.clock';
    'speedRef.y' = 'sample1.u';
    'sample1.y' = 'speedControl.N_des';
    'speedControl.Theta' = 'hold1.u';
    'hold1.y' = 'engine.Theta';
    'engine.flange_b.phi' = 'angleSensor.flange.phi';
    'engine.flange_b.phi' = 'torque.flange.phi';
    'add.y' = 'torque.tau';
    'step2.y' = 'add.u2';
    'step1.y' = 'add.u1';
    'angleSensor.phi' = 'derivative.u';
    'derivative.y' = 'sample2.u';
    'sample2.y' = 'speedControl.N';
    'sample2.clock' = 'engine.synchronize';
    'engine.inertia.flange_a.tau' + 'engine.torque.flange.tau' = 0.0;
    'angleSensor.flange.tau' + 'torque.flange.tau' + 'engine.flange_b.tau' = 0.0;
    'speedRef.y' = 207.34 + (if time < 5.0 then 0.0 else 103.67);

    when Clock() then
      'speedControl.x_d' = previous('speedControl.x_d') + 0.0723 * interval() * (previous('speedControl.N_des') - previous('speedControl.N'));
      'speedControl.Theta' = 0.0614 * ('speedControl.N_des' - 'speedControl.N') + 'speedControl.x_d';
    end when;

    'sample1.y' = sample('sample1.u', Clock());
    'hold1.y' = hold('hold1.u');
    der('engine.throttleBody.m_ai') = 'engine.throttleBody.f_Theta' * 'engine.throttleBody.g_Pm';
    'engine.throttleBody.f_Theta' = 2.821 - 0.05231 * 'engine.throttleBody.Theta' + 0.10299 * 'engine.throttleBody.Theta' ^ 2.0 - 6.3e-4 * 'engine.throttleBody.Theta' ^ 3.0;
    'engine.throttleBody.tmp1' = 'engine.throttleBody.Pm';
    'engine.throttleBody.tmp2' = 1.0 / 'engine.throttleBody.Pm';
    'engine.throttleBody.pratio' = min('engine.throttleBody.tmp1', 'engine.throttleBody.tmp2');
    'engine.throttleBody.gpratio' = if 'engine.throttleBody.pratio' >= 0.5 then 2.0 * sqrt('engine.throttleBody.pratio' - 'engine.throttleBody.pratio' ^ 2.0) else 1.0;
    'engine.throttleBody.g_Pm' = sign(1.0 - 'engine.throttleBody.Pm') * 'engine.throttleBody.gpratio';
    'engine.throttleBody.m_ai_der' = der('engine.throttleBody.m_ai');
    der('engine.intakeManifold.P_m') = 0.41328 * ('engine.intakeManifold.m_ai_der' - 'engine.intakeManifold.m_ao_der');
    'engine.intakeManifold.m_ao_der' = 0.08979 * 'engine.intakeManifold.N' * 'engine.intakeManifold.P_m' - 0.366 - 0.0337 * 'engine.intakeManifold.N' * 'engine.intakeManifold.P_m' ^ 2.0 + 1e-4 * 'engine.intakeManifold.N' ^ 2.0 * 'engine.intakeManifold.P_m';
    'engine.torqueGeneration.T_torque_e' = 379.36 * 'engine.torqueGeneration.m_a' - 181.3 + 319.88599999999997 - 181.18599999999998 + 3.9000000000000004 - 0.63 + 0.027 * 'engine.torqueGeneration.N' - 1.07e-4 * 'engine.torqueGeneration.N' ^ 2.0 + 4.8e-4 * 'engine.torqueGeneration.N' * 15.0 + 38.25 * 'engine.torqueGeneration.m_a' - 11.25 * 'engine.torqueGeneration.m_a';
    'engine.crankshaftPositionEvent.rotationalClock.y_clock.y' = Clock('engine.crankshaftPositionEvent.rotationalClock.y_clock.u', 0.0);
    'engine.crankshaftPositionEvent.rotationalClock.update_offset.y' = sample('engine.crankshaftPositionEvent.rotationalClock.update_offset.u', 'engine.crankshaftPositionEvent.rotationalClock.update_offset.clock');
    'engine.crankshaftPositionEvent.rotationalClock.angular_offset.y' = hold('engine.crankshaftPositionEvent.rotationalClock.angular_offset.u');
    'engine.crankshaftPositionEvent.rotationalClock.sub.y' = 'engine.crankshaftPositionEvent.rotationalClock.sub.u1' + (-1.0) * 'engine.crankshaftPositionEvent.rotationalClock.sub.u2';
    'engine.crankshaftPositionEvent.rotationalClock.less.y' = 'engine.crankshaftPositionEvent.rotationalClock.less.u1' < 'engine.crankshaftPositionEvent.rotationalClock.less.u2';
    'engine.crankshaftPositionEvent.rotationalClock.abs2.y' = if noEvent('engine.crankshaftPositionEvent.rotationalClock.abs2.u' >= 0.0) then 'engine.crankshaftPositionEvent.rotationalClock.abs2.u' else -'engine.crankshaftPositionEvent.rotationalClock.abs2.u';
    'engine.crankshaftPositionEvent.rotationalClock.abs1.y' = if noEvent('engine.crankshaftPositionEvent.rotationalClock.abs1.u' >= 0.0) then 'engine.crankshaftPositionEvent.rotationalClock.abs1.u' else -'engine.crankshaftPositionEvent.rotationalClock.abs1.u';
    'engine.crankshaftPositionEvent.rotationalClock.direction_sign.y' = if noEvent('engine.crankshaftPositionEvent.rotationalClock.direction_sign.u' > 0.0) then 1.0 else if noEvent('engine.crankshaftPositionEvent.rotationalClock.direction_sign.u' < 0.0) then -1.0 else 0.0;
    'engine.crankshaftPositionEvent.rotationalClock.cast.y' = if 'engine.crankshaftPositionEvent.rotationalClock.cast.u' > 0.0 then integer(floor('engine.crankshaftPositionEvent.rotationalClock.cast.u' + 0.5)) else integer(ceil('engine.crankshaftPositionEvent.rotationalClock.cast.u' - 0.5));

    if firstTick() then
      'engine.crankshaftPositionEvent.rotationalClock.changed.y' = false;
    elseif true then
      'engine.crankshaftPositionEvent.rotationalClock.changed.y' = not 'engine.crankshaftPositionEvent.rotationalClock.changed.u' == previous('engine.crankshaftPositionEvent.rotationalClock.changed.u');
    end if;

    'engine.crankshaftPositionEvent.rotationalClock.update_direction.y' = sample('engine.crankshaftPositionEvent.rotationalClock.update_direction.u', 'engine.crankshaftPositionEvent.rotationalClock.update_direction.clock');
    'engine.crankshaftPositionEvent.threshold.y' = 3.1415926535898;
    'engine.inductionToPowerDelay.sample1.y' = sample('engine.inductionToPowerDelay.sample1.u', 'engine.inductionToPowerDelay.sample1.clock');
    'engine.inductionToPowerDelay.hold1.y' = hold('engine.inductionToPowerDelay.hold1.u');
    'engine.inductionToPowerDelay.delay.first' = false;
    'engine.inductionToPowerDelay.delay.u_buffer[1]' = if previous('engine.inductionToPowerDelay.delay.first') then 'engine.inductionToPowerDelay.delay.u' else 'engine.inductionToPowerDelay.delay.u';
    'engine.inductionToPowerDelay.delay.u_buffer[2]' = if previous('engine.inductionToPowerDelay.delay.first') then 'engine.inductionToPowerDelay.delay.u' else previous('engine.inductionToPowerDelay.delay.u_buffer[1]');
    'engine.inductionToPowerDelay.delay.y' = shiftSample('engine.inductionToPowerDelay.delay.u_buffer[2]', 1, 1);
    'engine.cylinderAirCharge.add.y' = 'engine.cylinderAirCharge.add.u1' + (-1.0) * 'engine.cylinderAirCharge.add.u2';
    'engine.cylinderAirCharge.sample1.y' = sample('engine.cylinderAirCharge.sample1.u', 'engine.cylinderAirCharge.sample1.clock');
    'engine.cylinderAirCharge.hold1.y' = hold('engine.cylinderAirCharge.hold1.u');
    'engine.cylinderAirCharge.integrator.local_reset' = false;
    'engine.cylinderAirCharge.integrator.local_set' = 0.0;
    der('engine.cylinderAirCharge.integrator.y') = 'engine.cylinderAirCharge.integrator.u';
    'engine.torque.flange.tau' = -'engine.torque.tau';
    'engine.torque.phi_support' = 0.0;
    'engine.inertia.phi' = 'engine.inertia.flange_a.phi';
    'engine.inertia.phi' = 'engine.inertia.flange_b.phi';
    'engine.inertia.w' = der('engine.inertia.phi');
    'engine.inertia.a' = der('engine.inertia.w');
    0.14 * 'engine.inertia.a' = 'engine.inertia.flange_a.tau' + 'engine.inertia.flange_b.tau';
    'engine.speedSensor.w' = der('engine.speedSensor.flange.phi');
    0.0 = 'engine.speedSensor.flange.tau';
    'engine.angleSensor.phi' = 'engine.angleSensor.flange.phi';
    0.0 = 'engine.angleSensor.flange.tau';
    'step1.y' = 25.0 + (if time < 2.0 then 0.0 else -5.0);
    'step2.y' = if time < 8.0 then 0.0 else 5.0;
    'add.y' = (-1.0) * 'add.u1' + (-1.0) * 'add.u2';
    'torque.flange.tau' = -'torque.tau';
    'torque.phi_support' = 0.0;
    'angleSensor.phi' = 'angleSensor.flange.phi';
    0.0 = 'angleSensor.flange.tau';
    'derivative.y' = der('derivative.u');
    'sample2.y' = sample('sample2.u', 'sample2.clock');
  algorithm
    assert('engine.crankshaftPositionEvent.rotationalClock.trigger_interval' > 0.0 or 'engine.crankshaftPositionEvent.rotationalClock.trigger_interval' < 0.0, "The rotational-interval of rotational clocks must be non-zero.", AssertionLevel.error);
    annotation(experiment(StopTime = 1.1));
  end 'EngineThrottleControl';
end 'EngineThrottleControl';
