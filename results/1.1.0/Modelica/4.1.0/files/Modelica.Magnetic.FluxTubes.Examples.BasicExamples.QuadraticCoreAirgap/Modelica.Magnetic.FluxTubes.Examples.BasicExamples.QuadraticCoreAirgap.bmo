    'voltageSensor.p.i' = 0.0;
    'voltageSensor.n.i' = 0.0;
    'voltageSensor.v' = 'voltageSensor.p.v' - 'voltageSensor.n.v';
    0.09999999999999998 * 'leakage.R_m' = 0.9 * 'leakage.R_mUsefulTot';
    'leakage.V_m' = 'leakage.Phi' * 'leakage.R_m';
    'leakage.R_m' = 1.0 / 'leakage.G_m';
    0.0 = 'leakage.port_p.Phi' + 'leakage.port_n.Phi';
    'leakage.V_m' = 'leakage.port_p.V_m' - 'leakage.port_n.V_m';
    'leakage.Phi' = 'leakage.port_p.Phi';
    annotation(experiment(StopTime = 0.05, Interval = 0.0001));
  end 'QuadraticCoreAirgap';
end 'QuadraticCoreAirgap';
