//! base 0.1.0
package 'QuadraticCoreAirgap'
  model 'QuadraticCoreAirgap' "Educational example: iron core with airgap"
    parameter Real 'l'(unit = "m", quantity = "Length") = 0.1 "Outer length of iron core";
    parameter Real 'a'(unit = "m", quantity = "Length") = 0.01 "Side length of square cross section";
    parameter Real 'mu_r' = 1000.0 "Relative permeability of core";
    parameter Real 'delta'(unit = "m", quantity = "Length") = 0.001 "Length of airgap";
    parameter Real 'sigma' = 0.1 "Leakage coefficient";
    parameter Integer 'N' = 500 "Number of turns of exciting coil";
    parameter Real 'I'(unit = "A", quantity = "ElectricCurrent") = 1.5 "Maximum exciting current";
    Real 'excitingCoil.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'excitingCoil.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'excitingCoil.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'excitingCoil.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'excitingCoil.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'excitingCoil.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'excitingCoil.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'excitingCoil.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'excitingCoil.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'excitingCoil.i'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'excitingCoil.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'excitingCoil.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux coupled into magnetic circuit";
    parameter Real 'excitingCoil.N' = 500.0 "Number of turns";
    Real 'excitingCoil.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'excitingCoil.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    Real 'excitingCoil.eps' = 2.220446049250313e-14;
    Real 'leftLeg.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'leftLeg.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'leftLeg.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'leftLeg.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'leftLeg.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'leftLeg.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'leftLeg.nonLinearPermeability' = false "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'leftLeg.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'leftLeg.material.label' = "SoftMagnetic" "Name of material";
    parameter Real 'leftLeg.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1.0 "Initial relative permeability at B=0";
    parameter Real 'leftLeg.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Flux density at maximum relative permeability";
    parameter Real 'leftLeg.material.c_a' = 1.0 "Coefficient of approximation function";
    parameter Real 'leftLeg.material.c_b' = 1.0 "Coefficient of approximation function";
    parameter Real 'leftLeg.material.n' = 1.0 "Exponent of approximation function";
    Real 'leftLeg.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'leftLeg.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'leftLeg.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'leftLeg.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'leftLeg.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'leftLeg.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'leftLeg.B_N' "Absolute value of normalized B";
    parameter Real 'leftLeg.l'(unit = "m", quantity = "Length") = 0.09000000000000001 "Length in direction of flux";
    parameter Real 'leftLeg.a'(unit = "m", quantity = "Length") = 0.01 "Width of rectangular cross-section";
    parameter Real 'leftLeg.b'(unit = "m", quantity = "Length") = 0.01 "Height of rectangular cross-section";
    Real 'upperYoke.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'upperYoke.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'upperYoke.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'upperYoke.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'upperYoke.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'upperYoke.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'upperYoke.nonLinearPermeability' = false "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'upperYoke.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'upperYoke.material.label' = "SoftMagnetic" "Name of material";
    parameter Real 'upperYoke.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1.0 "Initial relative permeability at B=0";
    parameter Real 'upperYoke.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Flux density at maximum relative permeability";
    parameter Real 'upperYoke.material.c_a' = 1.0 "Coefficient of approximation function";
    parameter Real 'upperYoke.material.c_b' = 1.0 "Coefficient of approximation function";
    parameter Real 'upperYoke.material.n' = 1.0 "Exponent of approximation function";
    Real 'upperYoke.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'upperYoke.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'upperYoke.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'upperYoke.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'upperYoke.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'upperYoke.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'upperYoke.B_N' "Absolute value of normalized B";
    parameter Real 'upperYoke.l'(unit = "m", quantity = "Length") = 0.09000000000000001 "Length in direction of flux";
    parameter Real 'upperYoke.a'(unit = "m", quantity = "Length") = 0.01 "Width of rectangular cross-section";
    parameter Real 'upperYoke.b'(unit = "m", quantity = "Length") = 0.01 "Height of rectangular cross-section";
    Real 'rightLeg.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'rightLeg.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'rightLeg.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'rightLeg.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'rightLeg.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'rightLeg.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'rightLeg.nonLinearPermeability' = false "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'rightLeg.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'rightLeg.material.label' = "SoftMagnetic" "Name of material";
    parameter Real 'rightLeg.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1.0 "Initial relative permeability at B=0";
    parameter Real 'rightLeg.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Flux density at maximum relative permeability";
    parameter Real 'rightLeg.material.c_a' = 1.0 "Coefficient of approximation function";
    parameter Real 'rightLeg.material.c_b' = 1.0 "Coefficient of approximation function";
    parameter Real 'rightLeg.material.n' = 1.0 "Exponent of approximation function";
    Real 'rightLeg.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'rightLeg.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'rightLeg.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'rightLeg.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'rightLeg.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'rightLeg.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'rightLeg.B_N' "Absolute value of normalized B";
    parameter Real 'rightLeg.l'(unit = "m", quantity = "Length") = 0.08900000000000001 "Length in direction of flux";
    parameter Real 'rightLeg.a'(unit = "m", quantity = "Length") = 0.01 "Width of rectangular cross-section";
    parameter Real 'rightLeg.b'(unit = "m", quantity = "Length") = 0.01 "Height of rectangular cross-section";
    Real 'airGap.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'airGap.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'airGap.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'airGap.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'airGap.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'airGap.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'airGap.nonLinearPermeability' = false "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'airGap.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'airGap.material.label' = "SoftMagnetic" "Name of material";
    parameter Real 'airGap.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1.0 "Initial relative permeability at B=0";
    parameter Real 'airGap.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Flux density at maximum relative permeability";
    parameter Real 'airGap.material.c_a' = 1.0 "Coefficient of approximation function";
    parameter Real 'airGap.material.c_b' = 1.0 "Coefficient of approximation function";
    parameter Real 'airGap.material.n' = 1.0 "Exponent of approximation function";
    Real 'airGap.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'airGap.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'airGap.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'airGap.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'airGap.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'airGap.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'airGap.B_N' "Absolute value of normalized B";
    parameter Real 'airGap.l'(unit = "m", quantity = "Length") = 0.001 "Length in direction of flux";
    parameter Real 'airGap.a'(unit = "m", quantity = "Length") = 0.01 "Width of rectangular cross-section";
    parameter Real 'airGap.b'(unit = "m", quantity = "Length") = 0.01 "Height of rectangular cross-section";
    Real 'measuringCoil.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'measuringCoil.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'measuringCoil.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'measuringCoil.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'measuringCoil.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'measuringCoil.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'measuringCoil.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'measuringCoil.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'measuringCoil.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'measuringCoil.i'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'measuringCoil.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'measuringCoil.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux coupled into magnetic circuit";
    parameter Real 'measuringCoil.N' = 1.0 "Number of turns";
    Real 'measuringCoil.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'measuringCoil.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    Real 'measuringCoil.eps' = 2.220446049250313e-14;
    Real 'lowerYoke.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'lowerYoke.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'lowerYoke.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'lowerYoke.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'lowerYoke.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'lowerYoke.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'lowerYoke.nonLinearPermeability' = false "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'lowerYoke.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'lowerYoke.material.label' = "SoftMagnetic" "Name of material";
    parameter Real 'lowerYoke.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1.0 "Initial relative permeability at B=0";
    parameter Real 'lowerYoke.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Flux density at maximum relative permeability";
    parameter Real 'lowerYoke.material.c_a' = 1.0 "Coefficient of approximation function";
    parameter Real 'lowerYoke.material.c_b' = 1.0 "Coefficient of approximation function";
    parameter Real 'lowerYoke.material.n' = 1.0 "Exponent of approximation function";
    Real 'lowerYoke.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'lowerYoke.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'lowerYoke.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'lowerYoke.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'lowerYoke.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'lowerYoke.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'lowerYoke.B_N' "Absolute value of normalized B";
    parameter Real 'lowerYoke.l'(unit = "m", quantity = "Length") = 0.09000000000000001 "Length in direction of flux";
    parameter Real 'lowerYoke.a'(unit = "m", quantity = "Length") = 0.01 "Width of rectangular cross-section";
    parameter Real 'lowerYoke.b'(unit = "m", quantity = "Length") = 0.01 "Height of rectangular cross-section";
    Real 'magneticGround.port.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'magneticGround.port.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'electricGround1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricGround1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'rampCurrent.I'(start = 1.0, unit = "A", quantity = "ElectricCurrent") = 1.5 "Height of ramp";
    parameter Real 'rampCurrent.duration'(start = 2.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.015 "Duration of ramp";
    Real 'rampCurrent.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'rampCurrent.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rampCurrent.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rampCurrent.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rampCurrent.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rampCurrent.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'rampCurrent.signalSource.height' = 1.5 "Height of ramp";
    parameter Real 'rampCurrent.signalSource.duration'(start = 2.0, min = 0.0, unit = "s", quantity = "Time") = 0.015 "Duration of ramp (= 0.0 gives a Step)";
    Real 'rampCurrent.signalSource.y' "Connector of Real output signal";
    parameter Real 'rampCurrent.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'rampCurrent.signalSource.startTime'(unit = "s", quantity = "Time") = 0.01 "Output y = offset for time < startTime";
    parameter Real 'rampCurrent.offset'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Current offset";
    parameter Real 'rampCurrent.startTime'(unit = "s", quantity = "Time") = 0.01 "Time offset";
    Real 'magFluxSensor.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'magFluxSensor.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'magFluxSensor.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'magFluxSensor.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'magFluxSensor.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port p to port n as output signal";
    Real 'electricGround2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricGround2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'voltageSensor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'voltageSensor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'voltageSensor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'voltageSensor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'voltageSensor.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as output signal";
    Real 'leakage.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'leakage.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'leakage.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'leakage.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'leakage.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'leakage.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    Real 'leakage.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'leakage.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    parameter Real 'leakage.c_usefulFlux'(start = 0.7, max = 0.9999999999999998, min = 2.220446049250313e-16, unit = "1", quantity = "CouplingCoefficient") = 0.9 "Ratio useful flux/(leakage flux + useful flux) = useful flux/total flux";
    Real 'leakage.R_mUsefulTot'(unit = "H-1", quantity = "Reluctance");
    Real 'usefulReluctance.y' = 1.0 / 'airGap.G_m' "Value of Real output";
  equation
    'excitingCoil.port_p.V_m' = 'leftLeg.port_p.V_m';
    'leftLeg.port_n.V_m' = 'upperYoke.port_p.V_m';
    'upperYoke.port_n.V_m' = 'rightLeg.port_p.V_m';
    'measuringCoil.port_p.V_m' = 'leakage.port_p.V_m';
    'measuringCoil.port_p.V_m' = 'rightLeg.port_n.V_m';
    'measuringCoil.port_n.V_m' = 'airGap.port_p.V_m';
    'leakage.port_n.V_m' = 'airGap.port_n.V_m';
    'leakage.port_n.V_m' = 'lowerYoke.port_p.V_m';
    'magFluxSensor.port_p.V_m' = 'magneticGround.port.V_m';
    'magFluxSensor.port_p.V_m' = 'lowerYoke.port_n.V_m';
    'rampCurrent.p.v' = 'electricGround1.p.v';
    'rampCurrent.p.v' = 'excitingCoil.n.v';
    'rampCurrent.n.v' = 'excitingCoil.p.v';
    'electricGround2.p.v' = 'voltageSensor.n.v';
    'electricGround2.p.v' = 'measuringCoil.n.v';
    'measuringCoil.p.v' = 'voltageSensor.p.v';
    'excitingCoil.port_n.V_m' = 'magFluxSensor.port_n.V_m';
    'leakage.R_mUsefulTot' = 'usefulReluctance.y';
    'leftLeg.port_p.Phi' + 'excitingCoil.port_p.Phi' = 0.0;
    'magFluxSensor.port_n.Phi' + 'excitingCoil.port_n.Phi' = 0.0;
    'rampCurrent.p.i' + 'electricGround1.p.i' + 'excitingCoil.n.i' = 0.0;
    'upperYoke.port_p.Phi' + 'leftLeg.port_n.Phi' = 0.0;
    'rightLeg.port_p.Phi' + 'upperYoke.port_n.Phi' = 0.0;
    'leakage.port_p.Phi' + 'measuringCoil.port_p.Phi' + 'rightLeg.port_n.Phi' = 0.0;
    'measuringCoil.port_n.Phi' + 'airGap.port_p.Phi' = 0.0;
    'voltageSensor.p.i' + 'measuringCoil.p.i' = 0.0;
    'voltageSensor.n.i' + 'electricGround2.p.i' + 'measuringCoil.n.i' = 0.0;
    'leakage.port_n.Phi' + 'lowerYoke.port_p.Phi' + 'airGap.port_n.Phi' = 0.0;
    'magFluxSensor.port_p.Phi' + 'magneticGround.port.Phi' + 'lowerYoke.port_n.Phi' = 0.0;
    'rampCurrent.n.i' + 'excitingCoil.p.i' = 0.0;
    'excitingCoil.v' = 'excitingCoil.p.v' - 'excitingCoil.n.v';
    0.0 = 'excitingCoil.p.i' + 'excitingCoil.n.i';
    'excitingCoil.i' = 'excitingCoil.p.i';
    'excitingCoil.V_m' = 'excitingCoil.port_p.V_m' - 'excitingCoil.port_n.V_m';
    0.0 = 'excitingCoil.port_p.Phi' + 'excitingCoil.port_n.Phi';
    'excitingCoil.Phi' = 'excitingCoil.port_p.Phi';
    'excitingCoil.V_m' = 'excitingCoil.i' * 500.0 "Ampere's law";
    500.0 * der('excitingCoil.Phi') = -'excitingCoil.v' "Faraday's law";
    'excitingCoil.Psi' = 500.0 * 'excitingCoil.Phi';
    'excitingCoil.L_stat' = noEvent(if abs('excitingCoil.i') > 'excitingCoil.eps' then abs('excitingCoil.Psi' / 'excitingCoil.i') else abs('excitingCoil.Psi' / 'excitingCoil.eps'));
    'leftLeg.A' = 1e-4;
    'leftLeg.G_m' = 1.25663706212e-6 * 'leftLeg.mu_r' * 'leftLeg.A' / 0.09000000000000001;
    'leftLeg.B_N' = abs('leftLeg.B' / 'leftLeg.material.B_myMax');
    'leftLeg.mu_r' = 1000.0;
    'leftLeg.R_m' = 1.0 / 'leftLeg.G_m';
    'leftLeg.V_m' = 'leftLeg.Phi' * 'leftLeg.R_m';
    'leftLeg.B' = 'leftLeg.Phi' / 'leftLeg.A';
    'leftLeg.H' = 'leftLeg.B' / (1.25663706212e-6 * 'leftLeg.mu_r');
    0.0 = 'leftLeg.port_p.Phi' + 'leftLeg.port_n.Phi';
    'leftLeg.V_m' = 'leftLeg.port_p.V_m' - 'leftLeg.port_n.V_m';
    'leftLeg.Phi' = 'leftLeg.port_p.Phi';
    'upperYoke.A' = 1e-4;
    'upperYoke.G_m' = 1.25663706212e-6 * 'upperYoke.mu_r' * 'upperYoke.A' / 0.09000000000000001;
    'upperYoke.B_N' = abs('upperYoke.B' / 'upperYoke.material.B_myMax');
    'upperYoke.mu_r' = 1000.0;
    'upperYoke.R_m' = 1.0 / 'upperYoke.G_m';
    'upperYoke.V_m' = 'upperYoke.Phi' * 'upperYoke.R_m';
    'upperYoke.B' = 'upperYoke.Phi' / 'upperYoke.A';
    'upperYoke.H' = 'upperYoke.B' / (1.25663706212e-6 * 'upperYoke.mu_r');
    0.0 = 'upperYoke.port_p.Phi' + 'upperYoke.port_n.Phi';
    'upperYoke.V_m' = 'upperYoke.port_p.V_m' - 'upperYoke.port_n.V_m';
    'upperYoke.Phi' = 'upperYoke.port_p.Phi';
    'rightLeg.A' = 1e-4;
    'rightLeg.G_m' = 1.25663706212e-6 * 'rightLeg.mu_r' * 'rightLeg.A' / 0.08900000000000001;
    'rightLeg.B_N' = abs('rightLeg.B' / 'rightLeg.material.B_myMax');
    'rightLeg.mu_r' = 1000.0;
    'rightLeg.R_m' = 1.0 / 'rightLeg.G_m';
    'rightLeg.V_m' = 'rightLeg.Phi' * 'rightLeg.R_m';
    'rightLeg.B' = 'rightLeg.Phi' / 'rightLeg.A';
    'rightLeg.H' = 'rightLeg.B' / (1.25663706212e-6 * 'rightLeg.mu_r');
    0.0 = 'rightLeg.port_p.Phi' + 'rightLeg.port_n.Phi';
    'rightLeg.V_m' = 'rightLeg.port_p.V_m' - 'rightLeg.port_n.V_m';
    'rightLeg.Phi' = 'rightLeg.port_p.Phi';
    'airGap.A' = 1e-4;
    'airGap.G_m' = 1.25663706212e-6 * 'airGap.mu_r' * 'airGap.A' / 0.001;
    'airGap.B_N' = abs('airGap.B' / 'airGap.material.B_myMax');
    'airGap.mu_r' = 1.0;
    'airGap.R_m' = 1.0 / 'airGap.G_m';
    'airGap.V_m' = 'airGap.Phi' * 'airGap.R_m';
    'airGap.B' = 'airGap.Phi' / 'airGap.A';
    'airGap.H' = 'airGap.B' / (1.25663706212e-6 * 'airGap.mu_r');
    0.0 = 'airGap.port_p.Phi' + 'airGap.port_n.Phi';
    'airGap.V_m' = 'airGap.port_p.V_m' - 'airGap.port_n.V_m';
    'airGap.Phi' = 'airGap.port_p.Phi';
    'measuringCoil.v' = 'measuringCoil.p.v' - 'measuringCoil.n.v';
    0.0 = 'measuringCoil.p.i' + 'measuringCoil.n.i';
    'measuringCoil.i' = 'measuringCoil.p.i';
    'measuringCoil.V_m' = 'measuringCoil.port_p.V_m' - 'measuringCoil.port_n.V_m';
    0.0 = 'measuringCoil.port_p.Phi' + 'measuringCoil.port_n.Phi';
    'measuringCoil.Phi' = 'measuringCoil.port_p.Phi';
    'measuringCoil.V_m' = 'measuringCoil.i' "Ampere's law";
    der('measuringCoil.Phi') = -'measuringCoil.v' "Faraday's law";
    'measuringCoil.Psi' = 'measuringCoil.Phi';
    'measuringCoil.L_stat' = noEvent(if abs('measuringCoil.i') > 'measuringCoil.eps' then abs('measuringCoil.Psi' / 'measuringCoil.i') else abs('measuringCoil.Psi' / 'measuringCoil.eps'));
    'lowerYoke.A' = 1e-4;
    'lowerYoke.G_m' = 1.25663706212e-6 * 'lowerYoke.mu_r' * 'lowerYoke.A' / 0.09000000000000001;
    'lowerYoke.B_N' = abs('lowerYoke.B' / 'lowerYoke.material.B_myMax');
    'lowerYoke.mu_r' = 1000.0;
