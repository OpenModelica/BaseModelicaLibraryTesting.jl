    parameter Real 'hbridge.RonDiode'(unit = "Ohm", quantity = "Resistance") = 1e-5 "Diode closed resistance";
    parameter Real 'hbridge.GoffDiode'(unit = "S", quantity = "Conductance") = 1e-5 "Diode opened conductance";
    parameter Real 'hbridge.VkneeDiode'(unit = "V", quantity = "ElectricPotential") = 0.0 "Diode threshold voltage";
    parameter Boolean 'hbridge.useConstantEnable' = true "Disable boolean input and use constantEnable, if true";
    parameter Boolean 'hbridge.constantEnable' = true "Constant enabling of firing signals";
    parameter Integer 'hbridge.m'(min = 1) = 1 "Number of phases" annotation(Evaluate = true);
    parameter Boolean 'hbridge.enableLogic.useConstantEnable' = true "Disable boolean input and use constantEnable, if true";
    parameter Boolean 'hbridge.enableLogic.constantEnable' = true "Constant enabling of firing signals";
