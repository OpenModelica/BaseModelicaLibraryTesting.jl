//! base 0.1.0
package 'HBridge_DC_Drive'
  function 'Modelica.Electrical.PowerConverters.Examples.DCDC.HBridge.HBridge_DC_Drive.dutyCycleTable.getInterpolationCoefficients' "Determine interpolation coefficients and next time event"
    input Real[:, 2] 'table';
    input Real 'offset';
    input Real 'startTimeScaled';
    input Real 'timeScaled';
    input Integer 'last';
    input Real 'TimeEps';
    input Real 'shiftTimeScaled';
    output Real 'a';
    output Real 'b';
    output Real 'nextEventScaled';
    output Integer 'next';
    Integer 'columns' = 2;
    Integer 'ncol' = 2;
    Integer 'nrow' = size('table', 1);
    Integer 'next0';
    Real 'tp';
    Real 'dt';
  algorithm
    'next' := 'last';
    'nextEventScaled' := 'timeScaled' - 'TimeEps' * abs('timeScaled');
    'tp' := 'timeScaled' + 'TimeEps' * abs('timeScaled');

    if 'tp' < 'startTimeScaled' then
      'nextEventScaled' := 'startTimeScaled';
      'a' := 0.0;
      'b' := 'offset';
    elseif 'nrow' < 2 then
      'a' := 0.0;
      'b' := 'offset' + 'table'[1,'columns'];
    elseif true then
      'tp' := 'tp' - 'shiftTimeScaled';

      while 'next' < 'nrow' and 'tp' >= 'table'['next',1] loop
        'next' := 'next' + 1;
      end while;

      if 'next' < 'nrow' then
        'nextEventScaled' := 'shiftTimeScaled' + 'table'['next',1];
      end if;

      if 'next' == 1 then
        'next' := 2;
      end if;

      'next0' := 'next' - 1;
      'dt' := 'table'['next',1] - 'table'['next0',1];

      if 'dt' <= 'TimeEps' * abs('table'['next',1]) then
        'a' := 0.0;
        'b' := 'offset' + 'table'['next','columns'];
      elseif true then
        'a' := ('table'['next','columns'] - 'table'['next0','columns']) / 'dt';
        'b' := 'offset' + 'table'['next0','columns'] - 'a' * 'table'['next0',1];
      end if;
    end if;

    'b' := 'b' - 'a' * 'shiftTimeScaled';
  end 'Modelica.Electrical.PowerConverters.Examples.DCDC.HBridge.HBridge_DC_Drive.dutyCycleTable.getInterpolationCoefficients';

  function 'Modelica.Electrical.PowerConverters.Examples.DCDC.HBridge.HBridge_DC_Drive.torqueTable.getInterpolationCoefficients' "Determine interpolation coefficients and next time event"
    input Real[:, 2] 'table';
    input Real 'offset';
    input Real 'startTimeScaled';
    input Real 'timeScaled';
    input Integer 'last';
    input Real 'TimeEps';
    input Real 'shiftTimeScaled';
    output Real 'a';
    output Real 'b';
    output Real 'nextEventScaled';
    output Integer 'next';
    Integer 'columns' = 2;
    Integer 'ncol' = 2;
    Integer 'nrow' = size('table', 1);
    Integer 'next0';
    Real 'tp';
    Real 'dt';
  algorithm
    'next' := 'last';
    'nextEventScaled' := 'timeScaled' - 'TimeEps' * abs('timeScaled');
    'tp' := 'timeScaled' + 'TimeEps' * abs('timeScaled');

    if 'tp' < 'startTimeScaled' then
      'nextEventScaled' := 'startTimeScaled';
      'a' := 0.0;
      'b' := 'offset';
    elseif 'nrow' < 2 then
      'a' := 0.0;
      'b' := 'offset' + 'table'[1,'columns'];
    elseif true then
      'tp' := 'tp' - 'shiftTimeScaled';

      while 'next' < 'nrow' and 'tp' >= 'table'['next',1] loop
        'next' := 'next' + 1;
      end while;

      if 'next' < 'nrow' then
        'nextEventScaled' := 'shiftTimeScaled' + 'table'['next',1];
      end if;

      if 'next' == 1 then
        'next' := 2;
      end if;

      'next0' := 'next' - 1;
      'dt' := 'table'['next',1] - 'table'['next0',1];

      if 'dt' <= 'TimeEps' * abs('table'['next',1]) then
        'a' := 0.0;
        'b' := 'offset' + 'table'['next','columns'];
      elseif true then
        'a' := ('table'['next','columns'] - 'table'['next0','columns']) / 'dt';
        'b' := 'offset' + 'table'['next0','columns'] - 'a' * 'table'['next0',1];
      end if;
    end if;

    'b' := 'b' - 'a' * 'shiftTimeScaled';
  end 'Modelica.Electrical.PowerConverters.Examples.DCDC.HBridge.HBridge_DC_Drive.torqueTable.getInterpolationCoefficients';

  type 'Modelica.Electrical.PowerConverters.Types.SingleReferenceType' = enumeration('Sawtooth', 'Triangle');

  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'HBridge_DC_Drive' "H bridge DC/DC converter with DC drive"
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 1000.0 "Switching frequency";
    Real 'hbridge.dc_p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'hbridge.dc_p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'hbridge.dc_n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'hbridge.dc_n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'hbridge.vDC1'(unit = "V", quantity = "ElectricPotential") = 'hbridge.dc_p1.v' - 'hbridge.dc_n1.v' "DC voltage side 1";
    Real 'hbridge.iDC1'(unit = "A", quantity = "ElectricCurrent") = 'hbridge.dc_p1.i' "DC current side 1";
    Real 'hbridge.powerDC1'(unit = "W", quantity = "Power") = 'hbridge.vDC1' * 'hbridge.iDC1' "DC power side 1";
    Real 'hbridge.dc_p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'hbridge.dc_p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'hbridge.dc_n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'hbridge.dc_n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'hbridge.vDC2'(unit = "V", quantity = "ElectricPotential") = 'hbridge.dc_p2.v' - 'hbridge.dc_n2.v' "DC voltages side 2";
    Real 'hbridge.iDC2'(unit = "A", quantity = "ElectricCurrent") = 'hbridge.dc_p2.i' "DC current side 2";
    Real 'hbridge.powerDC2'(unit = "W", quantity = "Power") = 'hbridge.vDC2' * 'hbridge.iDC2' "DC power side 2";
    parameter Boolean 'hbridge.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'hbridge.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'hbridge.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'hbridge.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    parameter Real 'hbridge.RonTransistor'(unit = "Ohm", quantity = "Resistance") = 1e-5 "Transistor closed resistance";
    parameter Real 'hbridge.GoffTransistor'(unit = "S", quantity = "Conductance") = 1e-5 "Transistor opened conductance";
