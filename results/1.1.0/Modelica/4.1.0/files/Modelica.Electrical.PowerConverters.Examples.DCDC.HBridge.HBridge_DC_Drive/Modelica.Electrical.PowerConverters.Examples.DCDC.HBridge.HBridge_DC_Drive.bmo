    'hbridge.inverter_p.diode_n.v' = 'hbridge.inverter_p.diode_n.p.v' - 'hbridge.inverter_p.diode_n.n.v';
    'hbridge.inverter_p.LossPower' = 'hbridge.inverter_p.transistor_p.LossPower' + 'hbridge.inverter_p.diode_n.LossPower' + 'hbridge.inverter_p.transistor_n.LossPower' + 'hbridge.inverter_p.diode_n.LossPower';
    'hbridge.inverter_p.T_heatPort' = 293.15;
    'hbridge.inverter_n.enableLogic.enableConstantSource.y' = true;
    'hbridge.inverter_n.enableLogic.booleanReplicator.y[1]' = 'hbridge.inverter_n.enableLogic.booleanReplicator.u';
    'hbridge.inverter_n.andCondition_p.y' = 'hbridge.inverter_n.andCondition_p.u1' and 'hbridge.inverter_n.andCondition_p.u2';
    'hbridge.inverter_n.andCondition_n.y' = 'hbridge.inverter_n.andCondition_n.u1' and 'hbridge.inverter_n.andCondition_n.u2';
    'hbridge.inverter_n.transistor_p.off' = 'hbridge.inverter_n.transistor_p.s' < 0.0 or not 'hbridge.inverter_n.transistor_p.fire';
    'hbridge.inverter_n.transistor_p.v' = 'hbridge.inverter_n.transistor_p.s' * (if 'hbridge.inverter_n.transistor_p.off' then 1.0 else 1e-5);
    'hbridge.inverter_n.transistor_p.i' = 'hbridge.inverter_n.transistor_p.s' * (if 'hbridge.inverter_n.transistor_p.off' then 1e-5 else 1.0);
    'hbridge.inverter_n.transistor_p.LossPower' = 'hbridge.inverter_n.transistor_p.v' * 'hbridge.inverter_n.transistor_p.i';
    'hbridge.inverter_n.transistor_p.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_n.transistor_p.p.i' + 'hbridge.inverter_n.transistor_p.n.i';
    'hbridge.inverter_n.transistor_p.i' = 'hbridge.inverter_n.transistor_p.p.i';
    'hbridge.inverter_n.transistor_p.v' = 'hbridge.inverter_n.transistor_p.p.v' - 'hbridge.inverter_n.transistor_p.n.v';
    'hbridge.inverter_n.diode_p.off' = 'hbridge.inverter_n.diode_p.s' < 0.0;
    'hbridge.inverter_n.diode_p.v' = 'hbridge.inverter_n.diode_p.s' * (if 'hbridge.inverter_n.diode_p.off' then 1.0 else 1e-5);
    'hbridge.inverter_n.diode_p.i' = 'hbridge.inverter_n.diode_p.s' * (if 'hbridge.inverter_n.diode_p.off' then 1e-5 else 1.0);
    'hbridge.inverter_n.diode_p.LossPower' = 'hbridge.inverter_n.diode_p.v' * 'hbridge.inverter_n.diode_p.i';
    'hbridge.inverter_n.diode_p.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_n.diode_p.p.i' + 'hbridge.inverter_n.diode_p.n.i';
    'hbridge.inverter_n.diode_p.i' = 'hbridge.inverter_n.diode_p.p.i';
    'hbridge.inverter_n.diode_p.v' = 'hbridge.inverter_n.diode_p.p.v' - 'hbridge.inverter_n.diode_p.n.v';
    'hbridge.inverter_n.transistor_n.off' = 'hbridge.inverter_n.transistor_n.s' < 0.0 or not 'hbridge.inverter_n.transistor_n.fire';
    'hbridge.inverter_n.transistor_n.v' = 'hbridge.inverter_n.transistor_n.s' * (if 'hbridge.inverter_n.transistor_n.off' then 1.0 else 1e-5);
    'hbridge.inverter_n.transistor_n.i' = 'hbridge.inverter_n.transistor_n.s' * (if 'hbridge.inverter_n.transistor_n.off' then 1e-5 else 1.0);
    'hbridge.inverter_n.transistor_n.LossPower' = 'hbridge.inverter_n.transistor_n.v' * 'hbridge.inverter_n.transistor_n.i';
    'hbridge.inverter_n.transistor_n.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_n.transistor_n.p.i' + 'hbridge.inverter_n.transistor_n.n.i';
    'hbridge.inverter_n.transistor_n.i' = 'hbridge.inverter_n.transistor_n.p.i';
    'hbridge.inverter_n.transistor_n.v' = 'hbridge.inverter_n.transistor_n.p.v' - 'hbridge.inverter_n.transistor_n.n.v';
    'hbridge.inverter_n.diode_n.off' = 'hbridge.inverter_n.diode_n.s' < 0.0;
    'hbridge.inverter_n.diode_n.v' = 'hbridge.inverter_n.diode_n.s' * (if 'hbridge.inverter_n.diode_n.off' then 1.0 else 1e-5);
    'hbridge.inverter_n.diode_n.i' = 'hbridge.inverter_n.diode_n.s' * (if 'hbridge.inverter_n.diode_n.off' then 1e-5 else 1.0);
    'hbridge.inverter_n.diode_n.LossPower' = 'hbridge.inverter_n.diode_n.v' * 'hbridge.inverter_n.diode_n.i';
    'hbridge.inverter_n.diode_n.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_n.diode_n.p.i' + 'hbridge.inverter_n.diode_n.n.i';
    'hbridge.inverter_n.diode_n.i' = 'hbridge.inverter_n.diode_n.p.i';
    'hbridge.inverter_n.diode_n.v' = 'hbridge.inverter_n.diode_n.p.v' - 'hbridge.inverter_n.diode_n.n.v';
    'hbridge.inverter_n.LossPower' = 'hbridge.inverter_n.transistor_p.LossPower' + 'hbridge.inverter_n.diode_n.LossPower' + 'hbridge.inverter_n.transistor_n.LossPower' + 'hbridge.inverter_n.diode_n.LossPower';
    'hbridge.inverter_n.T_heatPort' = 293.15;
    'hbridge.not_p.y' = not 'hbridge.not_p.u';
    'hbridge.not_n.y' = not 'hbridge.not_n.u';
    'hbridge.LossPower' = 'hbridge.inverter_p.LossPower' + 'hbridge.inverter_n.LossPower';
    'hbridge.T_heatPort' = 293.15;
    'constantVoltage.v' = 120.0;
    0.0 = 'constantVoltage.p.i' + 'constantVoltage.n.i';
    'constantVoltage.i' = 'constantVoltage.p.i';
    'constantVoltage.v' = 'constantVoltage.p.v' - 'constantVoltage.n.v';
    'signalPWM.limiter.simplifiedExpr' = 'signalPWM.limiter.u';
    'signalPWM.limiter.y' = homotopy(smooth(0, if 'signalPWM.limiter.u' > 1.0 then 1.0 else if 'signalPWM.limiter.u' < 0.0 then 0.0 else 'signalPWM.limiter.u'), 'signalPWM.limiter.simplifiedExpr');

    when {'signalPWM.zeroOrderHold.sampleTrigger', initial()} then
      'signalPWM.zeroOrderHold.ySample' = if time >= 0.0 then 'signalPWM.zeroOrderHold.u' else pre('signalPWM.zeroOrderHold.ySample');
    end when;

    'signalPWM.zeroOrderHold.y' = pre('signalPWM.zeroOrderHold.ySample');
    'signalPWM.zeroOrderHold.sampleTrigger' = sample(0.0, 0.001);

    when 'signalPWM.zeroOrderHold.sampleTrigger' then
      'signalPWM.zeroOrderHold.firstTrigger' = time <= 5e-4;
    end when;

    when time >= (pre('signalPWM.triangle.count') + 1) * 0.001 then
      'signalPWM.triangle.count' = pre('signalPWM.triangle.count') + 1;
      'signalPWM.triangle.T_start' = time;
    end when;

    'signalPWM.triangle.y' = if time < 0.0 then 0.0 else if time < 'signalPWM.triangle.T_start' + 5e-4 then (time - 'signalPWM.triangle.T_start') / 5e-4 else if time < 'signalPWM.triangle.T_start' + 5e-4 then 1.0 else if time < 'signalPWM.triangle.T_start' + 0.001 then ('signalPWM.triangle.T_start' + 0.001 - time) / 5e-4 else 0.0;
    'signalPWM.greaterEqual_p.y' = 'signalPWM.greaterEqual_p.u1' > 'signalPWM.greaterEqual_p.u2';
    'signalPWM.add.y' = (-1.0) * 'signalPWM.add.u1' + 'signalPWM.add.u2';
    'signalPWM.constOne.y' = 1.0;
    'signalPWM.greaterEqual_n.y' = 'signalPWM.greaterEqual_n.u1' > 'signalPWM.greaterEqual_n.u2';
    'ground.p.v' = 0.0;
    'currentSensor.p.v' = 'currentSensor.n.v';
    'currentSensor.p.i' = 'currentSensor.i';
    'currentSensor.n.i' = -'currentSensor.i';
    'voltageSensor.p.i' = 0.0;
    'voltageSensor.n.i' = 0.0;
    'voltageSensor.v' = 'voltageSensor.p.v' - 'voltageSensor.n.v';
    der('meanCurrent.x') = 'meanCurrent.u';

    when sample('meanCurrent.t0' + 0.001, 0.001) then
      'meanCurrent.y_last' = 1000.0 * pre('meanCurrent.x');
      reinit('meanCurrent.x', 0.0);
    end when;

    'meanCurrent.y' = 'meanCurrent.y_last';
    der('meanVoltage.x') = 'meanVoltage.u';

    when sample('meanVoltage.t0' + 0.001, 0.001) then
      'meanVoltage.y_last' = 1000.0 * pre('meanVoltage.x');
      reinit('meanVoltage.x', 0.0);
    end when;

    'meanVoltage.y' = 'meanVoltage.y_last';
    'dcpm.inertiaRotor.phi' = 'dcpm.inertiaRotor.flange_a.phi';
    'dcpm.inertiaRotor.phi' = 'dcpm.inertiaRotor.flange_b.phi';
    'dcpm.inertiaRotor.w' = der('dcpm.inertiaRotor.phi');
    'dcpm.inertiaRotor.a' = der('dcpm.inertiaRotor.w');
    0.15 * 'dcpm.inertiaRotor.a' = 'dcpm.inertiaRotor.flange_a.tau' + 'dcpm.inertiaRotor.flange_b.tau';
    'dcpm.inertiaStator.phi' = 'dcpm.inertiaStator.flange_a.phi';
    'dcpm.inertiaStator.phi' = 'dcpm.inertiaStator.flange_b.phi';
    'dcpm.inertiaStator.w' = der('dcpm.inertiaStator.phi');
    'dcpm.inertiaStator.a' = der('dcpm.inertiaStator.w');
    0.15 * 'dcpm.inertiaStator.a' = 'dcpm.inertiaStator.flange_a.tau' + 'dcpm.inertiaStator.flange_b.tau';
    'dcpm.fixed.flange.phi' = 0.0;
    'dcpm.friction.tau' = 0.0;
    'dcpm.friction.lossPower' = -'dcpm.friction.tau' * 'dcpm.friction.w';
    'dcpm.friction.phi' = 'dcpm.friction.flange.phi' - 'dcpm.friction.support.phi';
    'dcpm.friction.w' = der('dcpm.friction.phi');
    'dcpm.friction.tau' = -'dcpm.friction.flange.tau';
    'dcpm.friction.tau' = 'dcpm.friction.support.tau';
    'dcpm.ra.R_actual' = 0.05;
    'dcpm.ra.v' = 'dcpm.ra.R_actual' * 'dcpm.ra.i';
    'dcpm.ra.LossPower' = 'dcpm.ra.v' * 'dcpm.ra.i';
    0.0 = 'dcpm.ra.p.i' + 'dcpm.ra.n.i';
    'dcpm.ra.i' = 'dcpm.ra.p.i';
    'dcpm.ra.v' = 'dcpm.ra.p.v' - 'dcpm.ra.n.v';
    'dcpm.la.v' = 0.0015 * der('dcpm.la.i');
    0.0 = 'dcpm.la.p.i' + 'dcpm.la.n.i';
    'dcpm.la.i' = 'dcpm.la.p.i';
    'dcpm.la.v' = 'dcpm.la.p.v' - 'dcpm.la.n.v';
    'dcpm.brush.v' = 0.0;
    'dcpm.brush.lossPower' = 'dcpm.brush.v' * 'dcpm.brush.i';
    0.0 = 'dcpm.brush.p.i' + 'dcpm.brush.n.i';
    'dcpm.brush.i' = 'dcpm.brush.p.i';
    'dcpm.brush.v' = 'dcpm.brush.p.v' - 'dcpm.brush.n.v';
    'dcpm.core.Gc' = 0.0;
    'dcpm.core.i' = 0.0;
    'dcpm.core.lossPower' = 'dcpm.core.v' * 'dcpm.core.i';
    0.0 = 'dcpm.core.p.i' + 'dcpm.core.n.i';
    'dcpm.core.i' = 'dcpm.core.p.i';
    'dcpm.core.v' = 'dcpm.core.p.v' - 'dcpm.core.n.v';
    'dcpm.strayLoad.v' = 0.0;
    'dcpm.strayLoad.tau' = 0.0;
    'dcpm.strayLoad.lossPower' = -'dcpm.strayLoad.tau' * 'dcpm.strayLoad.w';
    'dcpm.strayLoad.phi' = 'dcpm.strayLoad.flange.phi' - 'dcpm.strayLoad.support.phi';
    'dcpm.strayLoad.w' = der('dcpm.strayLoad.phi');
    'dcpm.strayLoad.tau' = -'dcpm.strayLoad.flange.tau';
    'dcpm.strayLoad.tau' = 'dcpm.strayLoad.support.tau';
    0.0 = 'dcpm.strayLoad.p.i' + 'dcpm.strayLoad.n.i';
    'dcpm.strayLoad.i' = 'dcpm.strayLoad.p.i';
    'dcpm.strayLoad.v' = 'dcpm.strayLoad.p.v' - 'dcpm.strayLoad.n.v';
    'dcpm.thermalAmbient.temperatureArmature.port.T' = 'dcpm.thermalAmbient.temperatureArmature.T';
    'dcpm.thermalAmbient.temperatureCore.port.T' = 293.15;
    'dcpm.thermalAmbient.temperatureStrayLoad.port.T' = 293.15;
    'dcpm.thermalAmbient.temperatureFriction.port.T' = 293.15;
    'dcpm.thermalAmbient.constTa.y' = 293.15;
    'dcpm.thermalAmbient.temperatureBrush.port.T' = 293.15;
    'dcpm.thermalAmbient.temperaturePermanentMagnet.port.T' = 'dcpm.thermalAmbient.temperaturePermanentMagnet.T';
    'dcpm.thermalAmbient.constTpm.y' = 293.15;
    'dcpm.airGapDC.psi_e' = 'dcpm.airGapDC.ie';
    'dcpm.airGapDC.vai' = 'dcpm.airGapDC.pin_ap.v' - 'dcpm.airGapDC.pin_an.v';
    'dcpm.airGapDC.ia' = 'dcpm.airGapDC.pin_ap.i';
    'dcpm.airGapDC.ia' = -'dcpm.airGapDC.pin_an.i';
    'dcpm.airGapDC.vei' = 'dcpm.airGapDC.pin_ep.v' - 'dcpm.airGapDC.pin_en.v';
    'dcpm.airGapDC.ie' = 'dcpm.airGapDC.pin_ep.i';
    'dcpm.airGapDC.ie' = -'dcpm.airGapDC.pin_en.i';
    'dcpm.airGapDC.vei' = der('dcpm.airGapDC.psi_e');
    'dcpm.airGapDC.w' = der('dcpm.airGapDC.flange.phi') - der('dcpm.airGapDC.support.phi');
    'dcpm.airGapDC.vai' = 0.6366197723675815 * 'dcpm.airGapDC.psi_e' * 'dcpm.airGapDC.w';
    'dcpm.airGapDC.tauElectrical' = 0.6366197723675815 * 'dcpm.airGapDC.psi_e' * 'dcpm.airGapDC.ia';
    'dcpm.airGapDC.flange.tau' = -'dcpm.airGapDC.tauElectrical';
    'dcpm.airGapDC.support.tau' = 'dcpm.airGapDC.tauElectrical';
    'dcpm.eGround.p.v' = 0.0;
    'dcpm.ie.i' = 1.0;
    0.0 = 'dcpm.ie.p.i' + 'dcpm.ie.n.i';
    'dcpm.ie.i' = 'dcpm.ie.p.i';
    'dcpm.ie.v' = 'dcpm.ie.p.v' - 'dcpm.ie.n.v';
    'torque.flange.tau' = -'torque.tau';
    'torque.phi_support' = 0.0;
    'torqueTable.timeScaled' = time;
    'torqueTable.y' = 'torqueTable.a' * 'torqueTable.timeScaled' + 'torqueTable.b';
    'dutyCycleTable.timeScaled' = time;
    'dutyCycleTable.y' = 'dutyCycleTable.a' * 'dutyCycleTable.timeScaled' + 'dutyCycleTable.b';
    0.0045000000000000005 * der('inductor.i') = 'inductor.v';
    0.0 = 'inductor.p.i' + 'inductor.n.i';
    'inductor.i' = 'inductor.p.i';
    'inductor.v' = 'inductor.p.v' - 'inductor.n.v';
  initial algorithm
    'signalPWM.triangle.count' := integer(time / 0.001);
    'signalPWM.triangle.T_start' := 'signalPWM.triangle.count' * 0.001;
  algorithm
    assert(true, "The first point in time has to be set to 0, but is table[1,1] = 0", AssertionLevel.error);

    when {time >= pre('torqueTable.nextEvent'), initial()} then
      ('torqueTable.a', 'torqueTable.b', 'torqueTable.nextEventScaled', 'torqueTable.last') := 'Modelica.Electrical.PowerConverters.Examples.DCDC.HBridge.HBridge_DC_Drive.torqueTable.getInterpolationCoefficients'({{0.0, 0.0}, {6.0, 0.0}, {7.0, -63.66197723675815}, {9.0, -63.66197723675815}, {10.0, 63.66197723675815}, {15.0, 63.66197723675815}, {16.0, -63.66197723675815}, {18.0, -63.66197723675815}, {19.0, 0.0}, {24.0, 0.0}}, 0.0, 0.0, 'torqueTable.timeScaled', 'torqueTable.last', 2.220446049250313e-14, 0.0);
      'torqueTable.nextEvent' := 'torqueTable.nextEventScaled';
    end when;
  algorithm
    assert(true, "The first point in time has to be set to 0, but is table[1,1] = 0", AssertionLevel.error);

    when {time >= pre('dutyCycleTable.nextEvent'), initial()} then
      ('dutyCycleTable.a', 'dutyCycleTable.b', 'dutyCycleTable.nextEventScaled', 'dutyCycleTable.last') := 'Modelica.Electrical.PowerConverters.Examples.DCDC.HBridge.HBridge_DC_Drive.dutyCycleTable.getInterpolationCoefficients'({{0.0, 0.5}, {3.0, 0.5}, {4.0, 0.8}, {12.0, 0.8}, {13.0, 0.2}, {21.0, 0.2}, {22.0, 0.5}, {24.0, 0.5}}, 0.0, 0.0, 'dutyCycleTable.timeScaled', 'dutyCycleTable.last', 2.220446049250313e-14, 0.0);
      'dutyCycleTable.nextEvent' := 'dutyCycleTable.nextEventScaled';
    end when;
    annotation(experiment(StopTime = 24, Interval = 0.0002, Tolerance = 1e-06));
  end 'HBridge_DC_Drive';
end 'HBridge_DC_Drive';
