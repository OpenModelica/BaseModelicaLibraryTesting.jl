    'dcee.re.p.v' = 'dcee.pin_ep.v';
    'dcee.re.n.v' = 'dcee.lesigma.p.v';
    'dcee.airGapDC.pin_en.v' = 'dcee.compoundDCExcitation.pin_n.v';
    'dcee.airGapDC.pin_en.v' = 'dcee.ground.p.v';
    'dcee.airGapDC.pin_ep.v' = 'dcee.compoundDCExcitation.pin_p.v';
    'dcee.groundSE.p.v' = 'dcee.compoundDCExcitation.pin_sen.v';
    'dcee.pin_en.v' = 'dcee.compoundDCExcitation.pin_en.v';
    'dcee.compoundDCExcitation.pin_en.i' - 'dcee.pin_en.i' = 0.0;
    'dcee.compoundDCExcitation.pin_ep.v' = 'dcee.lesigma.n.v';
    'dcee.core.n.v' = 'dcee.brush.p.v';
    'dcee.core.n.v' = 'dcee.airGapDC.pin_an.v';
    'dcee.thermalAmbient.thermalPort.heatPortExcitation.T' = 'dcee.internalThermalPort.heatPortExcitation.T';
    'dcee.thermalAmbient.thermalPort.heatPortExcitation.T' = 'dcee.re.heatPort.T';
    'dcee.la.p.v' = 'dcee.core.p.v';
    'dcee.la.p.v' = 'dcee.ra.n.v';
    'dcee.brush.n.v' = 'dcee.pin_an.v';
    'dcee.pin_ap.v' = 'dcee.strayLoad.p.v';
    'dcee.strayLoad.p.i' - 'dcee.pin_ap.i' = 0.0;
    'dcee.strayLoad.n.v' = 'dcee.ra.p.v';
    'dcee.thermalAmbient.thermalPort.heatPortCore.T' = 'dcee.internalThermalPort.heatPortCore.T';
    'dcee.thermalAmbient.thermalPort.heatPortCore.T' = 'dcee.core.heatPort.T';
    'dcee.thermalAmbient.thermalPort.heatPortBrush.T' = 'dcee.internalThermalPort.heatPortBrush.T';
    'dcee.thermalAmbient.thermalPort.heatPortBrush.T' = 'dcee.brush.heatPort.T';
    'dcee.thermalAmbient.thermalPort.heatPortStrayLoad.T' = 'dcee.internalThermalPort.heatPortStrayLoad.T';
    'dcee.thermalAmbient.thermalPort.heatPortStrayLoad.T' = 'dcee.strayLoad.heatPort.T';
    'dcee.thermalAmbient.thermalPort.heatPortFriction.T' = 'dcee.internalThermalPort.heatPortFriction.T';
    'dcee.thermalAmbient.thermalPort.heatPortFriction.T' = 'dcee.friction.heatPort.T';
    'dcee.thermalAmbient.thermalPort.heatPortArmature.T' = 'dcee.internalThermalPort.heatPortArmature.T';
    'dcee.thermalAmbient.thermalPort.heatPortArmature.T' = 'dcee.ra.heatPort.T';
    'dcee.inertiaRotor.flange_b.phi' = 'dcee.friction.flange.phi';
    'dcee.inertiaRotor.flange_b.phi' = 'dcee.flange.phi';
    'dcee.inertiaRotor.flange_b.phi' = 'dcee.strayLoad.flange.phi';
    'dcee.strayLoad.flange.tau' + 'dcee.friction.flange.tau' + 'dcee.inertiaRotor.flange_b.tau' - 'dcee.flange.tau' = 0.0;
    'ramp.y' = 'signalVoltage.v';
    'signalVoltage.p.v' = 'dcee.pin_ap.v';
    'dcee.pin_an.v' = 'ground.p.v';
    'dcee.pin_an.v' = 'signalVoltage.n.v';
    'dcee.pin_en.v' = 'constantVoltage.n.v';
    'dcee.pin_en.v' = 'groundExcitation.p.v';
    'dcee.pin_ep.v' = 'constantVoltage.p.v';
    'loadInertia.flange_b.phi' = 'loadTorqueStep.flange.phi';
    'dcee.flange.phi' = 'loadInertia.flange_a.phi';
    'loadInertia.flange_a.tau' + 'dcee.flange.tau' = 0.0;
    'dcee.inertiaStator.flange_b.tau' = 0.0;
    'dcee.thermalAmbient.thermalPort.heatPortFriction.Q_flow' + 'dcee.friction.heatPort.Q_flow' - 'dcee.internalThermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcee.internalSupport.tau' = 0.0;
    'dcee.core.p.i' + 'dcee.la.p.i' + 'dcee.ra.n.i' = 0.0;
    'dcee.thermalAmbient.thermalPort.heatPortArmature.Q_flow' + 'dcee.ra.heatPort.Q_flow' - 'dcee.internalThermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcee.brush.n.i' - 'dcee.pin_an.i' = 0.0;
    'dcee.thermalAmbient.thermalPort.heatPortBrush.Q_flow' + 'dcee.brush.heatPort.Q_flow' - 'dcee.internalThermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcee.thermalAmbient.thermalPort.heatPortCore.Q_flow' + 'dcee.core.heatPort.Q_flow' - 'dcee.internalThermalPort.heatPortCore.Q_flow' = 0.0;
    'dcee.strayLoad.n.i' + 'dcee.ra.p.i' = 0.0;
    'dcee.thermalAmbient.thermalPort.heatPortStrayLoad.Q_flow' + 'dcee.strayLoad.heatPort.Q_flow' - 'dcee.internalThermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcee.thermalAmbient.temperatureArmature.port.Q_flow' - 'dcee.thermalAmbient.thermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcee.thermalAmbient.temperatureCore.port.Q_flow' - 'dcee.thermalAmbient.thermalPort.heatPortCore.Q_flow' = 0.0;
    'dcee.thermalAmbient.temperatureStrayLoad.port.Q_flow' - 'dcee.thermalAmbient.thermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcee.thermalAmbient.temperatureFriction.port.Q_flow' - 'dcee.thermalAmbient.thermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcee.thermalAmbient.temperatureBrush.port.Q_flow' - 'dcee.thermalAmbient.thermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcee.thermalAmbient.temperatureExcitation.port.Q_flow' - 'dcee.thermalAmbient.thermalPort.heatPortExcitation.Q_flow' = 0.0;
    'dcee.internalThermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcee.internalThermalPort.heatPortCore.Q_flow' = 0.0;
    'dcee.internalThermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcee.internalThermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcee.internalThermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcee.internalThermalPort.heatPortExcitation.Q_flow' = 0.0;
    'dcee.airGapDC.flange.tau' + 'dcee.inertiaRotor.flange_a.tau' = 0.0;
    'dcee.airGapDC.support.tau' + 'dcee.strayLoad.support.tau' + 'dcee.friction.support.tau' + 'dcee.fixed.flange.tau' + 'dcee.inertiaStator.flange_a.tau' - 'dcee.internalSupport.tau' = 0.0;
    'dcee.airGapDC.pin_ap.i' + 'dcee.la.n.i' = 0.0;
    'dcee.compoundDCExcitation.pin_p.i' + 'dcee.airGapDC.pin_ep.i' = 0.0;
    'dcee.airGapDC.pin_an.i' + 'dcee.core.n.i' + 'dcee.brush.p.i' = 0.0;
    'dcee.compoundDCExcitation.pin_n.i' + 'dcee.ground.p.i' + 'dcee.airGapDC.pin_en.i' = 0.0;
    'dcee.lesigma.n.i' + 'dcee.compoundDCExcitation.pin_ep.i' = 0.0;
    'dcee.compoundDCExcitation.pin_sep.i' = 0.0;
    'dcee.groundSE.p.i' + 'dcee.compoundDCExcitation.pin_sen.i' = 0.0;
    'dcee.re.p.i' - 'dcee.pin_ep.i' = 0.0;
    'dcee.lesigma.p.i' + 'dcee.re.n.i' = 0.0;
    'dcee.re.heatPort.Q_flow' + 'dcee.thermalAmbient.thermalPort.heatPortExcitation.Q_flow' - 'dcee.internalThermalPort.heatPortExcitation.Q_flow' = 0.0;
    'constantVoltage.p.i' + 'dcee.pin_ep.i' = 0.0;
    'signalVoltage.p.i' + 'dcee.pin_ap.i' = 0.0;
    'ground.p.i' + 'signalVoltage.n.i' + 'dcee.pin_an.i' = 0.0;
    'groundExcitation.p.i' + 'constantVoltage.n.i' + 'dcee.pin_en.i' = 0.0;
    'loadTorqueStep.flange.tau' + 'loadInertia.flange_b.tau' = 0.0;
    'dcee.inertiaRotor.phi' = 'dcee.inertiaRotor.flange_a.phi';
    'dcee.inertiaRotor.phi' = 'dcee.inertiaRotor.flange_b.phi';
    'dcee.inertiaRotor.w' = der('dcee.inertiaRotor.phi');
    'dcee.inertiaRotor.a' = der('dcee.inertiaRotor.w');
    0.15 * 'dcee.inertiaRotor.a' = 'dcee.inertiaRotor.flange_a.tau' + 'dcee.inertiaRotor.flange_b.tau';
    'dcee.inertiaStator.phi' = 'dcee.inertiaStator.flange_a.phi';
    'dcee.inertiaStator.phi' = 'dcee.inertiaStator.flange_b.phi';
    'dcee.inertiaStator.w' = der('dcee.inertiaStator.phi');
    'dcee.inertiaStator.a' = der('dcee.inertiaStator.w');
    0.15 * 'dcee.inertiaStator.a' = 'dcee.inertiaStator.flange_a.tau' + 'dcee.inertiaStator.flange_b.tau';
    'dcee.fixed.flange.phi' = 0.0;
    'dcee.friction.tau' = 0.0;
    'dcee.friction.lossPower' = -'dcee.friction.tau' * 'dcee.friction.w';
    'dcee.friction.phi' = 'dcee.friction.flange.phi' - 'dcee.friction.support.phi';
    'dcee.friction.w' = der('dcee.friction.phi');
    'dcee.friction.tau' = -'dcee.friction.flange.tau';
    'dcee.friction.tau' = 'dcee.friction.support.tau';
    'dcee.ra.R_actual' = 0.05;
    'dcee.ra.v' = 'dcee.ra.R_actual' * 'dcee.ra.i';
    'dcee.ra.LossPower' = 'dcee.ra.v' * 'dcee.ra.i';
    0.0 = 'dcee.ra.p.i' + 'dcee.ra.n.i';
    'dcee.ra.i' = 'dcee.ra.p.i';
    'dcee.ra.v' = 'dcee.ra.p.v' - 'dcee.ra.n.v';
    'dcee.la.v' = 0.0015 * der('dcee.la.i');
    0.0 = 'dcee.la.p.i' + 'dcee.la.n.i';
    'dcee.la.i' = 'dcee.la.p.i';
    'dcee.la.v' = 'dcee.la.p.v' - 'dcee.la.n.v';
    'dcee.brush.v' = 0.0;
    'dcee.brush.lossPower' = 'dcee.brush.v' * 'dcee.brush.i';
    0.0 = 'dcee.brush.p.i' + 'dcee.brush.n.i';
    'dcee.brush.i' = 'dcee.brush.p.i';
    'dcee.brush.v' = 'dcee.brush.p.v' - 'dcee.brush.n.v';
    'dcee.core.Gc' = 0.0;
    'dcee.core.i' = 0.0;
    'dcee.core.lossPower' = 'dcee.core.v' * 'dcee.core.i';
    0.0 = 'dcee.core.p.i' + 'dcee.core.n.i';
    'dcee.core.i' = 'dcee.core.p.i';
    'dcee.core.v' = 'dcee.core.p.v' - 'dcee.core.n.v';
    'dcee.strayLoad.v' = 0.0;
    'dcee.strayLoad.tau' = 0.0;
    'dcee.strayLoad.lossPower' = -'dcee.strayLoad.tau' * 'dcee.strayLoad.w';
    'dcee.strayLoad.phi' = 'dcee.strayLoad.flange.phi' - 'dcee.strayLoad.support.phi';
    'dcee.strayLoad.w' = der('dcee.strayLoad.phi');
    'dcee.strayLoad.tau' = -'dcee.strayLoad.flange.tau';
    'dcee.strayLoad.tau' = 'dcee.strayLoad.support.tau';
    0.0 = 'dcee.strayLoad.p.i' + 'dcee.strayLoad.n.i';
    'dcee.strayLoad.i' = 'dcee.strayLoad.p.i';
    'dcee.strayLoad.v' = 'dcee.strayLoad.p.v' - 'dcee.strayLoad.n.v';
    'dcee.thermalAmbient.temperatureArmature.port.T' = 'dcee.thermalAmbient.temperatureArmature.T';
    'dcee.thermalAmbient.temperatureCore.port.T' = 293.15;
    'dcee.thermalAmbient.temperatureStrayLoad.port.T' = 293.15;
    'dcee.thermalAmbient.temperatureFriction.port.T' = 293.15;
    'dcee.thermalAmbient.constTa.y' = 293.15;
    'dcee.thermalAmbient.temperatureBrush.port.T' = 293.15;
    'dcee.thermalAmbient.temperatureExcitation.port.T' = 'dcee.thermalAmbient.temperatureExcitation.T';
    'dcee.thermalAmbient.constTe.y' = 293.15;
    'dcee.airGapDC.psi_e' = 'dcee.airGapDC.ie';
    'dcee.airGapDC.vai' = 'dcee.airGapDC.pin_ap.v' - 'dcee.airGapDC.pin_an.v';
    'dcee.airGapDC.ia' = 'dcee.airGapDC.pin_ap.i';
    'dcee.airGapDC.ia' = -'dcee.airGapDC.pin_an.i';
    'dcee.airGapDC.vei' = 'dcee.airGapDC.pin_ep.v' - 'dcee.airGapDC.pin_en.v';
    'dcee.airGapDC.ie' = 'dcee.airGapDC.pin_ep.i';
    'dcee.airGapDC.ie' = -'dcee.airGapDC.pin_en.i';
    'dcee.airGapDC.vei' = der('dcee.airGapDC.psi_e');
    'dcee.airGapDC.w' = der('dcee.airGapDC.flange.phi') - der('dcee.airGapDC.support.phi');
    'dcee.airGapDC.vai' = 0.6366197723675815 * 'dcee.airGapDC.psi_e' * 'dcee.airGapDC.w';
    'dcee.airGapDC.tauElectrical' = 0.6366197723675815 * 'dcee.airGapDC.psi_e' * 'dcee.airGapDC.ia';
    'dcee.airGapDC.flange.tau' = -'dcee.airGapDC.tauElectrical';
    'dcee.airGapDC.support.tau' = 'dcee.airGapDC.tauElectrical';
    'dcee.ground.p.v' = 0.0;
    'dcee.compoundDCExcitation.pin_p.i' + 'dcee.compoundDCExcitation.pin_n.i' = 0.0;
    'dcee.compoundDCExcitation.pin_ep.i' + 'dcee.compoundDCExcitation.pin_en.i' = 0.0;
    'dcee.compoundDCExcitation.pin_sep.i' + 'dcee.compoundDCExcitation.pin_sen.i' = 0.0;
    -'dcee.compoundDCExcitation.i' = 'dcee.compoundDCExcitation.ie' + 'dcee.compoundDCExcitation.ise';
    'dcee.compoundDCExcitation.ve' = 'dcee.compoundDCExcitation.v';
    'dcee.compoundDCExcitation.vse' = 'dcee.compoundDCExcitation.v';
    'dcee.groundSE.p.v' = 0.0;
    'dcee.re.R_actual' = 100.0;
    'dcee.re.v' = 'dcee.re.R_actual' * 'dcee.re.i';
    'dcee.re.LossPower' = 'dcee.re.v' * 'dcee.re.i';
    0.0 = 'dcee.re.p.i' + 'dcee.re.n.i';
    'dcee.re.i' = 'dcee.re.p.i';
    'dcee.re.v' = 'dcee.re.p.v' - 'dcee.re.n.v';
    'dcee.lesigma.v' = 0.0;
    0.0 = 'dcee.lesigma.p.i' + 'dcee.lesigma.n.i';
    'dcee.lesigma.i' = 'dcee.lesigma.p.i';
    'dcee.lesigma.v' = 'dcee.lesigma.p.v' - 'dcee.lesigma.n.v';
    'ramp.y' = if time < 0.2 then 0.0 else if time < 1.0 then (time - 0.2) * 100.0 / 0.8 else 100.0;
    'signalVoltage.v' = 'signalVoltage.p.v' - 'signalVoltage.n.v';
    0.0 = 'signalVoltage.p.i' + 'signalVoltage.n.i';
    'signalVoltage.i' = 'signalVoltage.p.i';
    'ground.p.v' = 0.0;
    'constantVoltage.v' = 100.0;
    0.0 = 'constantVoltage.p.i' + 'constantVoltage.n.i';
    'constantVoltage.i' = 'constantVoltage.p.i';
    'constantVoltage.v' = 'constantVoltage.p.v' - 'constantVoltage.n.v';
    'groundExcitation.p.v' = 0.0;
    'loadInertia.phi' = 'loadInertia.flange_a.phi';
    'loadInertia.phi' = 'loadInertia.flange_b.phi';
    'loadInertia.w' = der('loadInertia.phi');
    'loadInertia.a' = der('loadInertia.w');
    0.15 * 'loadInertia.a' = 'loadInertia.flange_a.tau' + 'loadInertia.flange_b.tau';
    'loadTorqueStep.tau' = -'loadTorqueStep.flange.tau';
    'loadTorqueStep.tau' = if time < 1.5 then 0.0 else -63.66;
    'loadTorqueStep.phi' = 'loadTorqueStep.flange.phi' - 'loadTorqueStep.phi_support';
    'loadTorqueStep.phi_support' = 0.0;
    annotation(experiment(StopTime = 2.0, Interval = 1E-4, Tolerance = 1E-6));
  end 'DCEE_Start';
end 'DCEE_Start';
