    'dcee.thermalAmbient.temperatureStrayLoad.port.T' = 'dcee.thermalAmbient.thermalPort.heatPortStrayLoad.T';
    'dcee.thermalAmbient.temperatureFriction.port.T' = 'dcee.thermalAmbient.thermalPort.heatPortFriction.T';
    'dcee.airGapDC.pin_ap.v' = 'dcee.la.n.v';
    'dcee.friction.support.phi' = 'dcee.internalSupport.phi';
