    parameter Real 'td'(unit = "s", quantity = "Time") = 3.162277660168379e-4 "Transmission delay";
    parameter Real 'z0'(unit = "Ohm", quantity = "Resistance") = 316.22776601683796 "Characteristic impedance for very high frequency";
