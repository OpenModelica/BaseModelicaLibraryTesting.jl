//! base 0.1.0
package 'SmoothStep'
  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'SmoothStep' "Compares oLine and tLine behaviour"
    parameter Real 'Rload'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Load resistance";
    parameter Real 'r1'(min = 2.2250738585072014e-308, unit = "Ohm/m") = 1e-6 "Resistance per meter";
