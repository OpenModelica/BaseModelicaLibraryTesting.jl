//! base 0.1.0
package 'InvertingAmp'
  model 'InvertingAmp' "Inverting amplifier"
    parameter Real 'Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply";
    parameter Real 'Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply";
    parameter Real 'Vin'(unit = "V", quantity = "ElectricPotential") = 5.0 "Amplitude of input voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of input voltage";
    parameter Real 'k' = 2.0 "Desired amplification";
    parameter Real 'R1'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Arbitrary resistance";
    parameter Real 'R2'(unit = "Ohm", quantity = "Resistance") = 2000.0 "Calculated resistance to reach desired amplification k";
    Real 'opAmp.in_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'opAmp.in_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'opAmp.in_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'opAmp.in_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'opAmp.out.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'opAmp.out.i'(fixed = false, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'opAmp.VMax.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'opAmp.VMax.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'opAmp.VMin.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'opAmp.VMin.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'opAmp.vin'(unit = "V", quantity = "ElectricPotential") "Input voltage";
    Real 'opAmp.s'(start = 0.0, unit = "1") "Auxiliary variable";
    constant Real 'opAmp.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'vIn.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 10.0 "Amplitude of trapezoid";
    parameter Real 'vIn.rising'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 0.02 "Rising duration of trapezoid";
    parameter Real 'vIn.width'(start = 0.5, min = 0.0, unit = "s", quantity = "Time") = 0.03 "Width duration of trapezoid";
    parameter Real 'vIn.falling'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 0.02 "Falling duration of trapezoid";
    parameter Real 'vIn.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time for one period";
    parameter Integer 'vIn.nperiod'(start = -1) = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'vIn.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'vIn.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vIn.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vIn.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vIn.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vIn.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'vIn.signalSource.amplitude' = 10.0 "Amplitude of trapezoid";
    parameter Real 'vIn.signalSource.rising'(min = 0.0, unit = "s", quantity = "Time") = 0.02 "Rising duration of trapezoid";
    parameter Real 'vIn.signalSource.width'(min = 0.0, unit = "s", quantity = "Time") = 0.03 "Width duration of trapezoid";
    parameter Real 'vIn.signalSource.falling'(min = 0.0, unit = "s", quantity = "Time") = 0.02 "Falling duration of trapezoid";
    parameter Real 'vIn.signalSource.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time for one period";
    parameter Integer 'vIn.signalSource.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'vIn.signalSource.y' "Connector of Real output signal";
    parameter Real 'vIn.signalSource.offset' = -5.0 "Offset of output signal y";
    parameter Real 'vIn.signalSource.startTime'(unit = "s", quantity = "Time") = -0.035 "Output y = offset for time < startTime";
    parameter Real 'vIn.signalSource.T_rising'(unit = "s", quantity = "Time") = 0.02 "End time of rising phase within one period";
    parameter Real 'vIn.signalSource.T_width'(unit = "s", quantity = "Time") = 0.05 "End time of width phase within one period";
    parameter Real 'vIn.signalSource.T_falling'(unit = "s", quantity = "Time") = 0.07 "End time of falling phase within one period";
    Real 'vIn.signalSource.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'vIn.signalSource.count' "Period count";
    parameter Real 'vIn.offset'(unit = "V", quantity = "ElectricPotential") = -5.0 "Voltage offset";
    parameter Real 'vIn.startTime'(unit = "s", quantity = "Time") = -0.035 "Time offset";
    Real 'vOut.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vOut.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vOut.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as output signal";
    parameter Real 'r1.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at temperature T_ref";
    parameter Real 'r1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'r1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'r1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'r1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'r1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'r1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'r1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'r1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'r1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'r1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'r1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'r1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'r1.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'r2.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 2000.0 "Resistance at temperature T_ref";
    parameter Real 'r2.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'r2.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'r2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'r2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'r2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'r2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'r2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'r2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'r2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'r2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'r2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'r2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'r2.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ground1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'vSourcePos.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 15.0 "Value of constant voltage";
    Real 'vSourcePos.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'vSourcePos.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSourcePos.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSourcePos.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSourcePos.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSourcePos.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'vSourceNeg.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = -15.0 "Value of constant voltage";
    Real 'vSourceNeg.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'vSourceNeg.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSourceNeg.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSourceNeg.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSourceNeg.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSourceNeg.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
  equation
    'r2.n.v' = 'opAmp.in_n.v';
    'r2.n.v' = 'r1.n.v';
    'opAmp.out.v' = 'vOut.p.v';
    'opAmp.out.v' = 'r2.p.v';
    'vIn.p.v' = 'r1.p.v';
    'ground.p.v' = 'vOut.n.v';
    'ground.p.v' = 'vIn.n.v';
    'ground.p.v' = 'opAmp.in_p.v';
    'vSourcePos.n.v' = 'vSourceNeg.n.v';
    'vSourcePos.n.v' = 'ground1.p.v';
    'vSourcePos.p.v' = 'opAmp.VMax.v';
    'vSourceNeg.p.v' = 'opAmp.VMin.v';
    'r1.p.i' + 'vIn.p.i' = 0.0;
    'vOut.n.i' + 'vIn.n.i' + 'ground.p.i' + 'opAmp.in_p.i' = 0.0;
    'r2.n.i' + 'r1.n.i' + 'opAmp.in_n.i' = 0.0;
    'r2.p.i' + 'vOut.p.i' + 'opAmp.out.i' = 0.0;
    'vSourceNeg.n.i' + 'vSourcePos.n.i' + 'ground1.p.i' = 0.0;
    'vSourcePos.p.i' + 'opAmp.VMax.i' = 0.0;
    'vSourceNeg.p.i' + 'opAmp.VMin.i' = 0.0;
    'opAmp.in_p.i' = 0.0;
    'opAmp.in_n.i' = 0.0;
    'opAmp.VMax.i' = 0.0;
    'opAmp.VMin.i' = 0.0;
    'opAmp.vin' = 'opAmp.in_p.v' - 'opAmp.in_n.v';
    'opAmp.in_p.v' - 'opAmp.in_n.v' = smooth(0, if 'opAmp.s' < (-1.0) then 'opAmp.s' + 1.0 else if 'opAmp.s' > 1.0 then 'opAmp.s' - 1.0 else 0.0);
    'opAmp.out.v' = smooth(0, if 'opAmp.s' < (-1.0) then 'opAmp.VMin.v' else if 'opAmp.s' > 1.0 then 'opAmp.VMax.v' else ('opAmp.VMax.v' - 'opAmp.VMin.v') * 'opAmp.s' / 2.0 + ('opAmp.VMax.v' + 'opAmp.VMin.v') / 2.0);
    'ground.p.v' = 0.0;

    when time >= (pre('vIn.signalSource.count') + 1) * 0.1 - 0.035 then
      'vIn.signalSource.count' = pre('vIn.signalSource.count') + 1;
      'vIn.signalSource.T_start' = time;
    end when;

    'vIn.signalSource.y' = (if time < (-0.035) then 0.0 else if time < 'vIn.signalSource.T_start' + 0.02 then 10.0 * (time - 'vIn.signalSource.T_start') / 0.02 else if time < 'vIn.signalSource.T_start' + 0.05 then 10.0 else if time < 'vIn.signalSource.T_start' + 0.07 then 10.0 * ('vIn.signalSource.T_start' + 0.07 - time) / 0.02 else 0.0) - 5.0;
    'vIn.v' = 'vIn.signalSource.y';
    0.0 = 'vIn.p.i' + 'vIn.n.i';
    'vIn.i' = 'vIn.p.i';
    'vIn.v' = 'vIn.p.v' - 'vIn.n.v';
    'vOut.p.i' = 0.0;
    'vOut.n.i' = 0.0;
    'vOut.v' = 'vOut.p.v' - 'vOut.n.v';
    'r1.R_actual' = 1000.0;
    'r1.v' = 'r1.R_actual' * 'r1.i';
    'r1.LossPower' = 'r1.v' * 'r1.i';
    'r1.T_heatPort' = 300.15;
    0.0 = 'r1.p.i' + 'r1.n.i';
    'r1.i' = 'r1.p.i';
    'r1.v' = 'r1.p.v' - 'r1.n.v';
    'r2.R_actual' = 2000.0;
    'r2.v' = 'r2.R_actual' * 'r2.i';
    'r2.LossPower' = 'r2.v' * 'r2.i';
    'r2.T_heatPort' = 300.15;
    0.0 = 'r2.p.i' + 'r2.n.i';
    'r2.i' = 'r2.p.i';
    'r2.v' = 'r2.p.v' - 'r2.n.v';
    'ground1.p.v' = 0.0;
    'vSourcePos.v' = 15.0;
    0.0 = 'vSourcePos.p.i' + 'vSourcePos.n.i';
    'vSourcePos.i' = 'vSourcePos.p.i';
    'vSourcePos.v' = 'vSourcePos.p.v' - 'vSourcePos.n.v';
    'vSourceNeg.v' = -15.0;
    0.0 = 'vSourceNeg.p.i' + 'vSourceNeg.n.i';
    'vSourceNeg.i' = 'vSourceNeg.p.i';
    'vSourceNeg.v' = 'vSourceNeg.p.v' - 'vSourceNeg.n.v';
  initial algorithm
    'vIn.signalSource.count' := integer((time + 0.035) / 0.1);
    'vIn.signalSource.T_start' := 'vIn.signalSource.count' * 0.1 - 0.035;
    annotation(experiment(StartTime = 0, StopTime = 1, Tolerance = 1e-006, Interval = 0.001));
  end 'InvertingAmp';
end 'InvertingAmp';
