    parameter Boolean 'speed.exact' = true "Is true/false for exact treatment/filtering of the input signal, respectively" annotation(Evaluate = true);
    parameter Real 'speed.f_crit'(unit = "Hz", quantity = "Frequency") = 50.0 "If exact=false, critical frequency of filter to filter input signal";
    Real 'speed.phi'(stateSelect = StateSelect.prefer, fixed = false, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotation angle of flange with respect to support";
    Real 'speed.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange with respect to support";
    Real 'speed.a'(unit = "rad/s2", quantity = "AngularAcceleration") "If exact=false, angular acceleration of flange with respect to support else dummy";
