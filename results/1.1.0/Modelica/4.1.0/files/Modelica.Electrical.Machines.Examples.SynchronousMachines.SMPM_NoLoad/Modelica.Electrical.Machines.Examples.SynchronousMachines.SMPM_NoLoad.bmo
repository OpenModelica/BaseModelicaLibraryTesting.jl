    Real 'ramp.y' "Connector of Real output signal";
    parameter Real 'ramp.offset' = -157.07963267948966 "Offset of output signal y";
    parameter Real 'ramp.startTime'(unit = "s", quantity = "Time") = 0.08 "Output y = offset for time < startTime";
  equation
    'smpm.rs.resistor[1].p.v' = 'smpm.rs.plug_p.pin[1].v';
    'smpm.rs.resistor[2].p.v' = 'smpm.rs.plug_p.pin[2].v';
    'smpm.rs.resistor[3].p.v' = 'smpm.rs.plug_p.pin[3].v';
    'smpm.rs.resistor[1].n.v' = 'smpm.rs.plug_n.pin[1].v';
    'smpm.rs.resistor[2].n.v' = 'smpm.rs.plug_n.pin[2].v';
    'smpm.rs.resistor[3].n.v' = 'smpm.rs.plug_n.pin[3].v';
    'smpm.rs.resistor[1].heatPort.T' = 'smpm.rs.heatPort[1].T';
    'smpm.rs.resistor[2].heatPort.T' = 'smpm.rs.heatPort[2].T';
    'smpm.rs.resistor[3].heatPort.T' = 'smpm.rs.heatPort[3].T';
    'smpm.thermalAmbient.constTr.y' = 'smpm.thermalAmbient.temperatureRotorWinding.T';
    'smpm.thermalAmbient.temperaturePermanentMagnet.port.T' = 'smpm.thermalAmbient.thermalPort.heatPortPermanentMagnet.T';
    'smpm.thermalAmbient.constTpm.y' = 'smpm.thermalAmbient.temperaturePermanentMagnet.T';
    'smpm.thermalAmbient.constTs.y' = 'smpm.thermalAmbient.temperatureStatorWinding.T';
    'smpm.thermalAmbient.temperatureStrayLoad.port.T' = 'smpm.thermalAmbient.thermalPort.heatPortStrayLoad.T';
    'smpm.thermalAmbient.temperatureFriction.port.T' = 'smpm.thermalAmbient.thermalPort.heatPortFriction.T';
    'smpm.thermalAmbient.thermalCollectorStator.port_b.T' = 'smpm.thermalAmbient.temperatureStatorWinding.port.T';
    'smpm.thermalAmbient.thermalCollectorStator.port_a[1].T' = 'smpm.thermalAmbient.thermalPort.heatPortStatorWinding[1].T';
    'smpm.thermalAmbient.thermalCollectorStator.port_a[2].T' = 'smpm.thermalAmbient.thermalPort.heatPortStatorWinding[2].T';
    'smpm.thermalAmbient.thermalCollectorStator.port_a[3].T' = 'smpm.thermalAmbient.thermalPort.heatPortStatorWinding[3].T';
    'smpm.thermalAmbient.temperatureStatorCore.port.T' = 'smpm.thermalAmbient.thermalPort.heatPortStatorCore.T';
