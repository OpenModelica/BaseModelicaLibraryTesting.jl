    Real 'hollowCylinderAxialInner.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('hollowCylinderAxialInner.Phi.im', 'hollowCylinderAxialInner.Phi.re', 0.0) "Argument of complex magnetic flux";
    Real 'hollowCylinderAxialInner.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'hollowCylinderAxialInner.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 100.0 "Constant relative permeability";
    Real 'hollowCylinderAxialInner.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'hollowCylinderAxialInner.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'hollowCylinderAxialInner.B.re'(unit = "T", quantity = "MagneticFluxDensity") "Real part of complex number";
