    'source.omega' = 6.283185307179586 * 'source.f';
    'source.V_m.re' = 'source.port_p.V_m.re' - 'source.port_n.V_m.re';
    'source.V_m.im' = 'source.port_p.V_m.im' - 'source.port_n.V_m.im';
    0.0 = 'source.port_p.Phi.re' + 'source.port_n.Phi.re';
    0.0 = 'source.port_p.Phi.im' + 'source.port_n.Phi.im';
    'source.Phi.re' = 'source.port_p.Phi.re';
    'source.Phi.im' = 'source.port_p.Phi.im';
    'source.port_p.reference.gamma' = 'source.port_n.reference.gamma';
    'source.omega' = der('source.port_p.reference.gamma');
    'crossing.port_p1.reference.gamma' = 'crossing.port_p2.reference.gamma';
    'crossing.port_n1.reference.gamma' = 'crossing.port_n2.reference.gamma';
    'crossing.port_p1.V_m.re' = 'crossing.port_p2.V_m.re';
    'crossing.port_p1.V_m.im' = 'crossing.port_p2.V_m.im';
    'crossing.port_p1.Phi.re' + 'crossing.port_p2.Phi.re' = 0.0;
    'crossing.port_p1.Phi.im' + 'crossing.port_p2.Phi.im' = 0.0;
    'crossing.port_n1.V_m.re' = 'crossing.port_n2.V_m.re';
    'crossing.port_n1.V_m.im' = 'crossing.port_n2.V_m.im';
    'crossing.port_n1.Phi.re' + 'crossing.port_n2.Phi.re' = 0.0;
    'crossing.port_n1.Phi.im' + 'crossing.port_n2.Phi.im' = 0.0;
    'complexRamp.magnitude' = if time < 0.0 then 0.0 else if time < 1.0 then time * 8e-4 else 8e-4;
    'complexRamp.y.re' = 'complexRamp.magnitude';
    'complexRamp.y.im' = 0.0;
    annotation(experiment(StopTime = 1, Interval = 0.001));
  end 'CylinderSections';
end 'CylinderSections';
