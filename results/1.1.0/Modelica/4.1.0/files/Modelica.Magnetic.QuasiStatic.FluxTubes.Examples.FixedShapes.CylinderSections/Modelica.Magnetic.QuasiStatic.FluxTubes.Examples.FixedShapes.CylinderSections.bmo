    Real 'hollowCylinderAxialInner.abs_B'(unit = "T", quantity = "MagneticFluxDensity") = sqrt('hollowCylinderAxialInner.B.re' ^ 2.0 + 'hollowCylinderAxialInner.B.im' ^ 2.0) "Magnitude of complex magnetic flux density";
    Real 'hollowCylinderAxialInner.arg_B'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('hollowCylinderAxialInner.B.im', 'hollowCylinderAxialInner.B.re', 0.0) "Argument of complex magnetic flux density";
    Real 'hollowCylinderAxialInner.A'(unit = "m2", quantity = "Area") "Area of cross section penetrated by magnetic flux";
    Real 'hollowCylinderAxialInner.H.re'(unit = "A/m", quantity = "MagneticFieldStrength") "Real part of complex number";
