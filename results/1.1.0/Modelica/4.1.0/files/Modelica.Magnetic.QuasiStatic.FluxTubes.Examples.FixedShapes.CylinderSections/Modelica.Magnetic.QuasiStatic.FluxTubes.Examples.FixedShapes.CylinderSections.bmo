    Real 'hollowCylinderAxialInner.abs_V_m'(unit = "A", quantity = "MagneticPotential") = sqrt('hollowCylinderAxialInner.V_m.re' ^ 2.0 + 'hollowCylinderAxialInner.V_m.im' ^ 2.0) "Magnitude of complex magnetic potential difference";
    Real 'hollowCylinderAxialInner.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('hollowCylinderAxialInner.V_m.im', 'hollowCylinderAxialInner.V_m.re', 0.0) "Argument of complex magnetic potential difference";
    Real 'hollowCylinderAxialInner.Phi.re'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'hollowCylinderAxialInner.Phi.im'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
