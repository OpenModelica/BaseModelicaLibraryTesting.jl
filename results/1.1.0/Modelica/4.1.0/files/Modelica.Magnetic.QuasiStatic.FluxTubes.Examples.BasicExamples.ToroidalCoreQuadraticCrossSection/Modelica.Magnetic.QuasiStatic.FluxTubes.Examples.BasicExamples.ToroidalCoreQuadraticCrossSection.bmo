    Real 'measuringCoil.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'measuringCoil.i.re'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'measuringCoil.i.im'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'measuringCoil.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'measuringCoil.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
