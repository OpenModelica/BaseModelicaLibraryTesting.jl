    Real 'measuringCoil.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'measuringCoil.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'measuringCoil.N' = 1.0 "Number of turns";
    Real 'measuringCoil.Psi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'measuringCoil.Psi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'measuringCoil.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i) for information only";
    Real 'measuringCoil.eps' = 2.220446049250313e-14;
    Real 'magneticGround.port.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'magneticGround.port.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'magneticGround.port.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'magneticGround.port.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'magneticGround.port.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'electricGround1.pin.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'electricGround1.pin.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'electricGround1.pin.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'electricGround1.pin.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'electricGround1.pin.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'currentSource.omega'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of reference frame";
    Real 'currentSource.pin_p.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'currentSource.pin_p.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'currentSource.pin_p.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'currentSource.pin_p.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'currentSource.pin_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'currentSource.pin_n.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'currentSource.pin_n.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'currentSource.pin_n.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'currentSource.pin_n.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'currentSource.pin_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'currentSource.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'currentSource.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'currentSource.abs_v'(unit = "V", quantity = "ElectricPotential") = sqrt('currentSource.v.re' ^ 2.0 + 'currentSource.v.im' ^ 2.0) "Magnitude of complex voltage";
    Real 'currentSource.arg_v'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('currentSource.v.im', 'currentSource.v.re', 0.0) "Argument of complex voltage";
    Real 'currentSource.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'currentSource.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'currentSource.abs_i'(unit = "A", quantity = "ElectricCurrent") = sqrt('currentSource.i.re' ^ 2.0 + 'currentSource.i.im' ^ 2.0) "Magnitude of complex current";
    Real 'currentSource.arg_i'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('currentSource.i.im', 'currentSource.i.re', 0.0) "Argument of complex current";
    Real 'currentSource.P'(unit = "W", quantity = "Power") = 'currentSource.v.re' * 'currentSource.i.re' - 'currentSource.v.im' * (-'currentSource.i.im') "Active power";
    Real 'currentSource.Q'(unit = "var", quantity = "Power") = 'currentSource.v.re' * (-'currentSource.i.im') + 'currentSource.v.im' * 'currentSource.i.re' "Reactive power";
    Real 'currentSource.S'(unit = "V.A", quantity = "Power") = sqrt(('currentSource.v.re' * 'currentSource.i.re' - 'currentSource.v.im' * (-'currentSource.i.im')) ^ 2.0 + ('currentSource.v.re' * (-'currentSource.i.im') + 'currentSource.v.im' * 'currentSource.i.re') ^ 2.0) "Magnitude of complex apparent power";
    Real 'currentSource.pf' = cos('Modelica.Math.atan3'('currentSource.Q', 'currentSource.P', 0.0)) "Power factor";
    Real 'currentSource.gamma'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 'currentSource.pin_p.reference.gamma';
    Real 'currentSource.f'(unit = "Hz");
    Real 'currentSource.I.re' "Real part of complex number";
    Real 'currentSource.I.im' "Imaginary part of complex number";
    Real 'magFluxSensor.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'magFluxSensor.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'magFluxSensor.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'magFluxSensor.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'magFluxSensor.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'magFluxSensor.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'magFluxSensor.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'magFluxSensor.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'magFluxSensor.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'magFluxSensor.port_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'magFluxSensor.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'magFluxSensor.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'magFluxSensor.abs_V_m'(unit = "A", quantity = "MagneticPotential") = sqrt('magFluxSensor.V_m.re' ^ 2.0 + 'magFluxSensor.V_m.im' ^ 2.0) "Magnitude of complex magnetic potential difference";
    Real 'magFluxSensor.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('magFluxSensor.V_m.im', 'magFluxSensor.V_m.re', 0.0) "Argument of complex magnetic potential difference";
    Real 'magFluxSensor.Phi.re'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'magFluxSensor.Phi.im'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'magFluxSensor.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") = sqrt('magFluxSensor.Phi.re' ^ 2.0 + 'magFluxSensor.Phi.im' ^ 2.0) "Magnitude of complex magnetic flux";
    Real 'magFluxSensor.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('magFluxSensor.Phi.im', 'magFluxSensor.Phi.re', 0.0) "Argument of complex magnetic flux";
    Real 'magFluxSensor.omega'(unit = "rad/s", quantity = "AngularVelocity");
    Real 'magFluxSensor.y.re' "Real part of complex number";
    Real 'magFluxSensor.y.im' "Imaginary part of complex number";
    Real 'electricGround2.pin.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'electricGround2.pin.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'electricGround2.pin.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'electricGround2.pin.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'electricGround2.pin.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'voltageSensor.omega'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of reference frame";
    Real 'voltageSensor.pin_p.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSensor.pin_p.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSensor.pin_p.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSensor.pin_p.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSensor.pin_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'voltageSensor.pin_n.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSensor.pin_n.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSensor.pin_n.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSensor.pin_n.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSensor.pin_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'voltageSensor.v.re'(unit = "V") "Real part of complex number";
    Real 'voltageSensor.v.im'(unit = "V") "Imaginary part of complex number";
    Real 'voltageSensor.abs_v'(unit = "V", quantity = "ElectricPotential") = sqrt('voltageSensor.v.re' ^ 2.0 + 'voltageSensor.v.im' ^ 2.0) "Magnitude of complex voltage";
    Real 'voltageSensor.arg_v'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('voltageSensor.v.im', 'voltageSensor.v.re', 0.0) "Argument of complex voltage";
    Real 'voltageSensor.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSensor.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    parameter Real 'const.k'(start = 1.0) = 50.0 "Constant output value";
    Real 'const.y' "Connector of Real output signal";
    Real 'complexRamp.y.re' "Real part of complex number";
    Real 'complexRamp.y.im' "Imaginary part of complex number";
    parameter Real 'complexRamp.magnitude1'(start = 1.0, min = 0.0) = 0.0 "Magnitude of complex phasor at startTime";
    parameter Real 'complexRamp.magnitude2'(start = 1.0, min = 0.0) = 1.5 "Magnitude of complex phasor at startTime+duration";
    parameter Boolean 'complexRamp.useLogRamp' = false "Ramp appears linear on a logarithmic scale, if true";
    parameter Real 'complexRamp.phi'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Angle of complex phasor";
    parameter Real 'complexRamp.startTime'(unit = "s", quantity = "Time") = 0.01 "Start time of frequency sweep";
    parameter Real 'complexRamp.duration'(start = 1.0, min = 0.0, unit = "s", quantity = "Time") = 0.015 "Duration of ramp (= 0.0 gives a Step)";
    Real 'complexRamp.magnitude' "Actual magnitude of complex phasor";
  equation
    'excitingCoil.port_n.V_m.re' = 'magFluxSensor.port_n.V_m.re';
    'excitingCoil.port_n.V_m.im' = 'magFluxSensor.port_n.V_m.im';
    'magneticGround.port.V_m.re' = 'airGap.port_n.V_m.re';
    'magneticGround.port.V_m.re' = 'magFluxSensor.port_p.V_m.re';
    'magneticGround.port.V_m.im' = 'airGap.port_n.V_m.im';
    'magneticGround.port.V_m.im' = 'magFluxSensor.port_p.V_m.im';
    'magneticGround.port.reference.gamma' = 'airGap.port_n.reference.gamma';
    'magneticGround.port.reference.gamma' = 'magFluxSensor.port_p.reference.gamma';
    'excitingCoil.port_p.V_m.re' = 'core.port_p.V_m.re';
    'excitingCoil.port_p.V_m.im' = 'core.port_p.V_m.im';
    'excitingCoil.port_p.reference.gamma' = 'core.port_p.reference.gamma';
    'currentSource.pin_n.v.re' = 'excitingCoil.pin_p.v.re';
    'currentSource.pin_n.v.im' = 'excitingCoil.pin_p.v.im';
    'electricGround1.pin.reference.gamma' = 'excitingCoil.pin_n.reference.gamma';
    'electricGround1.pin.reference.gamma' = 'currentSource.pin_p.reference.gamma';
    'electricGround1.pin.v.re' = 'excitingCoil.pin_n.v.re';
    'electricGround1.pin.v.re' = 'currentSource.pin_p.v.re';
    'electricGround1.pin.v.im' = 'excitingCoil.pin_n.v.im';
    'electricGround1.pin.v.im' = 'currentSource.pin_p.v.im';
    'measuringCoil.pin_n.v.re' = 'electricGround2.pin.v.re';
    'measuringCoil.pin_n.v.re' = 'voltageSensor.pin_n.v.re';
    'measuringCoil.pin_n.v.im' = 'electricGround2.pin.v.im';
    'measuringCoil.pin_n.v.im' = 'voltageSensor.pin_n.v.im';
    'const.y' = 'currentSource.f';
    'complexRamp.y.re' = 'currentSource.I.re';
    'complexRamp.y.im' = 'currentSource.I.im';
    'measuringCoil.pin_n.reference.gamma' = 'electricGround2.pin.reference.gamma';
    'measuringCoil.pin_p.reference.gamma' = 'voltageSensor.pin_p.reference.gamma';
    'measuringCoil.pin_p.v.re' = 'voltageSensor.pin_p.v.re';
    'measuringCoil.pin_p.v.im' = 'voltageSensor.pin_p.v.im';
    'core.port_n.V_m.re' = 'measuringCoil.port_p.V_m.re';
    'core.port_n.V_m.im' = 'measuringCoil.port_p.V_m.im';
    'core.port_n.reference.gamma' = 'measuringCoil.port_p.reference.gamma';
    'airGap.port_p.V_m.re' = 'measuringCoil.port_n.V_m.re';
    'airGap.port_p.V_m.im' = 'measuringCoil.port_n.V_m.im';
    'airGap.port_p.reference.gamma' = 'measuringCoil.port_n.reference.gamma';
    'core.port_p.Phi.re' + 'excitingCoil.port_p.Phi.re' = 0.0;
    'core.port_p.Phi.im' + 'excitingCoil.port_p.Phi.im' = 0.0;
    'magFluxSensor.port_n.Phi.re' + 'excitingCoil.port_n.Phi.re' = 0.0;
    'magFluxSensor.port_n.Phi.im' + 'excitingCoil.port_n.Phi.im' = 0.0;
    'measuringCoil.port_p.Phi.re' + 'core.port_n.Phi.re' = 0.0;
    'measuringCoil.port_p.Phi.im' + 'core.port_n.Phi.im' = 0.0;
    'measuringCoil.port_n.Phi.re' + 'airGap.port_p.Phi.re' = 0.0;
    'measuringCoil.port_n.Phi.im' + 'airGap.port_p.Phi.im' = 0.0;
    'voltageSensor.pin_p.i.re' + 'measuringCoil.pin_p.i.re' = 0.0;
    'voltageSensor.pin_p.i.im' + 'measuringCoil.pin_p.i.im' = 0.0;
    'currentSource.pin_p.i.re' + 'electricGround1.pin.i.re' + 'excitingCoil.pin_n.i.re' = 0.0;
    'currentSource.pin_p.i.im' + 'electricGround1.pin.i.im' + 'excitingCoil.pin_n.i.im' = 0.0;
    'currentSource.pin_n.i.re' + 'excitingCoil.pin_p.i.re' = 0.0;
    'currentSource.pin_n.i.im' + 'excitingCoil.pin_p.i.im' = 0.0;
    'magFluxSensor.port_p.Phi.re' + 'magneticGround.port.Phi.re' + 'airGap.port_n.Phi.re' = 0.0;
    'magFluxSensor.port_p.Phi.im' + 'magneticGround.port.Phi.im' + 'airGap.port_n.Phi.im' = 0.0;
    'voltageSensor.pin_n.i.re' + 'electricGround2.pin.i.re' + 'measuringCoil.pin_n.i.re' = 0.0;
    'voltageSensor.pin_n.i.im' + 'electricGround2.pin.i.im' + 'measuringCoil.pin_n.i.im' = 0.0;
    'excitingCoil.v.re' = 'excitingCoil.pin_p.v.re' - 'excitingCoil.pin_n.v.re';
    'excitingCoil.v.im' = 'excitingCoil.pin_p.v.im' - 'excitingCoil.pin_n.v.im';
    0.0 = 'excitingCoil.pin_p.i.re' + 'excitingCoil.pin_n.i.re';
    0.0 = 'excitingCoil.pin_p.i.im' + 'excitingCoil.pin_n.i.im';
    'excitingCoil.i.re' = 'excitingCoil.pin_p.i.re';
    'excitingCoil.i.im' = 'excitingCoil.pin_p.i.im';
    'excitingCoil.V_m.re' = 'excitingCoil.port_p.V_m.re' - 'excitingCoil.port_n.V_m.re';
    'excitingCoil.V_m.im' = 'excitingCoil.port_p.V_m.im' - 'excitingCoil.port_n.V_m.im';
    0.0 = 'excitingCoil.port_p.Phi.re' + 'excitingCoil.port_n.Phi.re';
    0.0 = 'excitingCoil.port_p.Phi.im' + 'excitingCoil.port_n.Phi.im';
    'excitingCoil.Phi.re' = 'excitingCoil.port_p.Phi.re';
    'excitingCoil.Phi.im' = 'excitingCoil.port_p.Phi.im';
    'excitingCoil.v.re' = 'excitingCoil.omega' * 500.0 * 'excitingCoil.Phi.im';
    'excitingCoil.v.im' = -'excitingCoil.omega' * 500.0 * 'excitingCoil.Phi.re';
    'excitingCoil.V_m.re' = 500.0 * 'excitingCoil.i.re';
    'excitingCoil.V_m.im' = 500.0 * 'excitingCoil.i.im';
    'excitingCoil.Psi.re' = 500.0 * 'excitingCoil.Phi.re';
    'excitingCoil.Psi.im' = 500.0 * 'excitingCoil.Phi.im';
    'excitingCoil.L_stat' = noEvent(if sqrt('excitingCoil.i.re' ^ 2.0 + 'excitingCoil.i.im' ^ 2.0) > 'excitingCoil.eps' then sqrt((('excitingCoil.Psi.re' * 'excitingCoil.i.re' + 'excitingCoil.Psi.im' * 'excitingCoil.i.im') / ('excitingCoil.i.re' * 'excitingCoil.i.re' + 'excitingCoil.i.im' * 'excitingCoil.i.im')) ^ 2.0 + (('excitingCoil.Psi.im' * 'excitingCoil.i.re' - 'excitingCoil.Psi.re' * 'excitingCoil.i.im') / ('excitingCoil.i.re' * 'excitingCoil.i.re' + 'excitingCoil.i.im' * 'excitingCoil.i.im')) ^ 2.0) else sqrt(('excitingCoil.Psi.re' * 'excitingCoil.eps' / ('excitingCoil.eps' * 'excitingCoil.eps')) ^ 2.0 + ('excitingCoil.Psi.im' * 'excitingCoil.eps' / ('excitingCoil.eps' * 'excitingCoil.eps')) ^ 2.0));
    'excitingCoil.omega' = der('excitingCoil.port_p.reference.gamma');
    'excitingCoil.port_p.reference.gamma' = 'excitingCoil.port_n.reference.gamma';
    'excitingCoil.pin_p.reference.gamma' = 'excitingCoil.pin_n.reference.gamma';
    'excitingCoil.port_p.reference.gamma' = 'excitingCoil.pin_p.reference.gamma';
    'core.A' = 1.0000000000000002e-4;
    'core.G_m' = 1.25663706212e-6 * 'core.mu_r' * 'core.A' / 0.31315926535897937;
    'core.mu_r' = 1000.0;
    'core.R_m' = 1.0 / 'core.G_m';
    'core.V_m.re' = 'core.Phi.re' * 'core.R_m';
    'core.V_m.im' = 'core.Phi.im' * 'core.R_m';
    'core.B.re' = 'core.Phi.re' * 'core.A' / ('core.A' * 'core.A');
    'core.B.im' = 'core.Phi.im' * 'core.A' / ('core.A' * 'core.A');
    'core.H.re' = 'core.B.re' * (1.25663706212e-6 * 'core.mu_r') / (1.25663706212e-6 * 'core.mu_r' * (1.25663706212e-6 * 'core.mu_r'));
    'core.H.im' = 'core.B.im' * (1.25663706212e-6 * 'core.mu_r') / (1.25663706212e-6 * 'core.mu_r' * (1.25663706212e-6 * 'core.mu_r'));
    0.0 = 'core.port_p.Phi.re' + 'core.port_n.Phi.re';
    0.0 = 'core.port_p.Phi.im' + 'core.port_n.Phi.im';
    'core.port_p.reference.gamma' = 'core.port_n.reference.gamma';
    'core.omega' = der('core.port_p.reference.gamma');
    'core.V_m.re' = 'core.port_p.V_m.re' - 'core.port_n.V_m.re';
    'core.V_m.im' = 'core.port_p.V_m.im' - 'core.port_n.V_m.im';
    'core.Phi.re' = 'core.port_p.Phi.re';
    'core.Phi.im' = 'core.port_p.Phi.im';
    'airGap.A' = 1.0000000000000002e-4;
    'airGap.G_m' = 1.25663706212e-6 * 'airGap.mu_r' * 'airGap.A' / 9.999999999999788e-4;
    'airGap.mu_r' = 1.0;
    'airGap.R_m' = 1.0 / 'airGap.G_m';
    'airGap.V_m.re' = 'airGap.Phi.re' * 'airGap.R_m';
    'airGap.V_m.im' = 'airGap.Phi.im' * 'airGap.R_m';
    'airGap.B.re' = 'airGap.Phi.re' * 'airGap.A' / ('airGap.A' * 'airGap.A');
    'airGap.B.im' = 'airGap.Phi.im' * 'airGap.A' / ('airGap.A' * 'airGap.A');
    'airGap.H.re' = 'airGap.B.re' * (1.25663706212e-6 * 'airGap.mu_r') / (1.25663706212e-6 * 'airGap.mu_r' * (1.25663706212e-6 * 'airGap.mu_r'));
    'airGap.H.im' = 'airGap.B.im' * (1.25663706212e-6 * 'airGap.mu_r') / (1.25663706212e-6 * 'airGap.mu_r' * (1.25663706212e-6 * 'airGap.mu_r'));
    0.0 = 'airGap.port_p.Phi.re' + 'airGap.port_n.Phi.re';
    0.0 = 'airGap.port_p.Phi.im' + 'airGap.port_n.Phi.im';
    'airGap.port_p.reference.gamma' = 'airGap.port_n.reference.gamma';
    'airGap.omega' = der('airGap.port_p.reference.gamma');
    'airGap.V_m.re' = 'airGap.port_p.V_m.re' - 'airGap.port_n.V_m.re';
    'airGap.V_m.im' = 'airGap.port_p.V_m.im' - 'airGap.port_n.V_m.im';
    'airGap.Phi.re' = 'airGap.port_p.Phi.re';
    'airGap.Phi.im' = 'airGap.port_p.Phi.im';
    'measuringCoil.v.re' = 'measuringCoil.pin_p.v.re' - 'measuringCoil.pin_n.v.re';
    'measuringCoil.v.im' = 'measuringCoil.pin_p.v.im' - 'measuringCoil.pin_n.v.im';
    0.0 = 'measuringCoil.pin_p.i.re' + 'measuringCoil.pin_n.i.re';
    0.0 = 'measuringCoil.pin_p.i.im' + 'measuringCoil.pin_n.i.im';
    'measuringCoil.i.re' = 'measuringCoil.pin_p.i.re';
    'measuringCoil.i.im' = 'measuringCoil.pin_p.i.im';
    'measuringCoil.V_m.re' = 'measuringCoil.port_p.V_m.re' - 'measuringCoil.port_n.V_m.re';
    'measuringCoil.V_m.im' = 'measuringCoil.port_p.V_m.im' - 'measuringCoil.port_n.V_m.im';
    0.0 = 'measuringCoil.port_p.Phi.re' + 'measuringCoil.port_n.Phi.re';
    0.0 = 'measuringCoil.port_p.Phi.im' + 'measuringCoil.port_n.Phi.im';
    'measuringCoil.Phi.re' = 'measuringCoil.port_p.Phi.re';
    'measuringCoil.Phi.im' = 'measuringCoil.port_p.Phi.im';
    'measuringCoil.v.re' = 'measuringCoil.omega' * 'measuringCoil.Phi.im';
    'measuringCoil.v.im' = -'measuringCoil.omega' * 'measuringCoil.Phi.re';
    'measuringCoil.V_m.re' = 'measuringCoil.i.re';
    'measuringCoil.V_m.im' = 'measuringCoil.i.im';
    'measuringCoil.Psi.re' = 'measuringCoil.Phi.re';
    'measuringCoil.Psi.im' = 'measuringCoil.Phi.im';
    'measuringCoil.L_stat' = noEvent(if sqrt('measuringCoil.i.re' ^ 2.0 + 'measuringCoil.i.im' ^ 2.0) > 'measuringCoil.eps' then sqrt((('measuringCoil.Psi.re' * 'measuringCoil.i.re' + 'measuringCoil.Psi.im' * 'measuringCoil.i.im') / ('measuringCoil.i.re' * 'measuringCoil.i.re' + 'measuringCoil.i.im' * 'measuringCoil.i.im')) ^ 2.0 + (('measuringCoil.Psi.im' * 'measuringCoil.i.re' - 'measuringCoil.Psi.re' * 'measuringCoil.i.im') / ('measuringCoil.i.re' * 'measuringCoil.i.re' + 'measuringCoil.i.im' * 'measuringCoil.i.im')) ^ 2.0) else sqrt(('measuringCoil.Psi.re' * 'measuringCoil.eps' / ('measuringCoil.eps' * 'measuringCoil.eps')) ^ 2.0 + ('measuringCoil.Psi.im' * 'measuringCoil.eps' / ('measuringCoil.eps' * 'measuringCoil.eps')) ^ 2.0));
    'measuringCoil.omega' = der('measuringCoil.port_p.reference.gamma');
    'measuringCoil.port_p.reference.gamma' = 'measuringCoil.port_n.reference.gamma';
    'measuringCoil.pin_p.reference.gamma' = 'measuringCoil.pin_n.reference.gamma';
    'measuringCoil.port_p.reference.gamma' = 'measuringCoil.pin_p.reference.gamma';
    'magneticGround.port.V_m.re' = 0.0;
    'magneticGround.port.V_m.im' = 0.0;
    'electricGround1.pin.v.re' = 0.0;
    'electricGround1.pin.v.im' = 0.0;
    'currentSource.omega' = 6.283185307179586 * 'currentSource.f';
    'currentSource.i.re' = 'currentSource.I.re';
    'currentSource.i.im' = 'currentSource.I.im';
    'currentSource.pin_p.i.re' + 'currentSource.pin_n.i.re' = 0.0;
    'currentSource.pin_p.i.im' + 'currentSource.pin_n.i.im' = 0.0;
    'currentSource.v.re' = 'currentSource.pin_p.v.re' - 'currentSource.pin_n.v.re';
    'currentSource.v.im' = 'currentSource.pin_p.v.im' - 'currentSource.pin_n.v.im';
    'currentSource.i.re' = 'currentSource.pin_p.i.re';
    'currentSource.i.im' = 'currentSource.pin_p.i.im';
    'currentSource.pin_p.reference.gamma' = 'currentSource.pin_n.reference.gamma';
    'currentSource.omega' = der('currentSource.pin_p.reference.gamma');
    'magFluxSensor.V_m.re' = 0.0;
    'magFluxSensor.V_m.im' = 0.0;
    'magFluxSensor.y.re' = 'magFluxSensor.Phi.re';
    'magFluxSensor.y.im' = 'magFluxSensor.Phi.im';
    0.0 = 'magFluxSensor.port_p.Phi.re' + 'magFluxSensor.port_n.Phi.re';
    0.0 = 'magFluxSensor.port_p.Phi.im' + 'magFluxSensor.port_n.Phi.im';
    'magFluxSensor.port_p.reference.gamma' = 'magFluxSensor.port_n.reference.gamma';
    'magFluxSensor.omega' = der('magFluxSensor.port_p.reference.gamma');
    'magFluxSensor.V_m.re' = 'magFluxSensor.port_p.V_m.re' - 'magFluxSensor.port_n.V_m.re';
    'magFluxSensor.V_m.im' = 'magFluxSensor.port_p.V_m.im' - 'magFluxSensor.port_n.V_m.im';
    'magFluxSensor.Phi.re' = 'magFluxSensor.port_p.Phi.re';
    'magFluxSensor.Phi.im' = 'magFluxSensor.port_p.Phi.im';
    'electricGround2.pin.v.re' = 0.0;
    'electricGround2.pin.v.im' = 0.0;
    'voltageSensor.v.re' = 'voltageSensor.pin_p.v.re' - 'voltageSensor.pin_n.v.re';
    'voltageSensor.v.im' = 'voltageSensor.pin_p.v.im' - 'voltageSensor.pin_n.v.im';
    'voltageSensor.i.re' = 'voltageSensor.pin_p.i.re';
    'voltageSensor.i.im' = 'voltageSensor.pin_p.i.im';
    'voltageSensor.i.re' = 0.0;
    'voltageSensor.i.im' = 0.0;
    0.0 = 'voltageSensor.pin_p.i.re' + 'voltageSensor.pin_n.i.re' "Current balance";
    0.0 = 'voltageSensor.pin_p.i.im' + 'voltageSensor.pin_n.i.im' "Current balance";
    'voltageSensor.pin_p.reference.gamma' = 'voltageSensor.pin_n.reference.gamma';
    'voltageSensor.omega' = der('voltageSensor.pin_p.reference.gamma');
    'const.y' = 50.0;
    'complexRamp.magnitude' = if time < 0.01 then 0.0 else if time < 0.025 then (time - 0.01) * 1.5 / 0.015 else 1.5;
    'complexRamp.y.re' = 'complexRamp.magnitude';
    'complexRamp.y.im' = 0.0;
    annotation(experiment(StopTime = 0.05, Interval = 0.0001));
  end 'ToroidalCoreQuadraticCrossSection';
end 'ToroidalCoreQuadraticCrossSection';
