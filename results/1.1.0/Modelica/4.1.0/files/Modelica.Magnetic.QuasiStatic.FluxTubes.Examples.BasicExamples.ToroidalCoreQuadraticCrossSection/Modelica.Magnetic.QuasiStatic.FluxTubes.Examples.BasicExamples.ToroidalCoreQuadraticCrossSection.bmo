  model 'ToroidalCoreQuadraticCrossSection' "Educational example: iron core with airgap"
    parameter Real 'r_o'(unit = "m", quantity = "Length") = 0.055 "Outer radius of iron core";
    parameter Real 'r_i'(unit = "m", quantity = "Length") = 0.045 "Inner radius of iron core";
    parameter Real 'l'(unit = "m", quantity = "Length") = 0.01 "Length of rectangular cross section";
    parameter Real 'mu_r'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Relative permeability of core";
    parameter Real 'delta'(unit = "m", quantity = "Length") = 0.001 "Length of airgap";
    parameter Real 'alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 6.263185307179587 "Section angle of toroidal core";
    parameter Integer 'N' = 500 "Number of exciting coil turns";
    parameter Real 'I'(unit = "A", quantity = "ElectricCurrent") = 1.5 "Maximum exciting current";
    constant Real 'excitingCoil.j.re' = 0.0 "Real part of complex number";
    constant Real 'excitingCoil.j.im' = 1.0 "Imaginary part of complex number";
    Real 'excitingCoil.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'excitingCoil.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'excitingCoil.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'excitingCoil.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'excitingCoil.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'excitingCoil.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'excitingCoil.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'excitingCoil.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'excitingCoil.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'excitingCoil.port_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'excitingCoil.pin_p.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'excitingCoil.pin_p.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'excitingCoil.pin_p.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'excitingCoil.pin_p.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'excitingCoil.pin_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'excitingCoil.pin_n.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'excitingCoil.pin_n.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'excitingCoil.pin_n.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'excitingCoil.pin_n.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'excitingCoil.pin_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'excitingCoil.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'excitingCoil.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'excitingCoil.i.re'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'excitingCoil.i.im'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'excitingCoil.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'excitingCoil.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'excitingCoil.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'excitingCoil.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'excitingCoil.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'excitingCoil.N' = 500.0 "Number of turns";
    Real 'excitingCoil.Psi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'excitingCoil.Psi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'excitingCoil.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i) for information only";
    Real 'excitingCoil.eps' = 2.220446049250313e-14;
    Real 'core.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'core.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'core.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'core.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'core.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'core.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'core.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'core.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'core.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'core.port_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'core.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'core.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'core.abs_V_m'(unit = "A", quantity = "MagneticPotential") = sqrt('core.V_m.re' ^ 2.0 + 'core.V_m.im' ^ 2.0) "Magnitude of complex magnetic potential difference";
    Real 'core.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('core.V_m.im', 'core.V_m.re', 0.0) "Argument of complex magnetic potential difference";
    Real 'core.Phi.re'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'core.Phi.im'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'core.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") = sqrt('core.Phi.re' ^ 2.0 + 'core.Phi.im' ^ 2.0) "Magnitude of complex magnetic flux";
    Real 'core.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('core.Phi.im', 'core.Phi.re', 0.0) "Argument of complex magnetic flux";
    Real 'core.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'core.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Constant relative permeability";
    Real 'core.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'core.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'core.B.re'(unit = "T", quantity = "MagneticFluxDensity") "Real part of complex number";
    Real 'core.B.im'(unit = "T", quantity = "MagneticFluxDensity") "Imaginary part of complex number";
    Real 'core.abs_B'(unit = "T", quantity = "MagneticFluxDensity") = sqrt('core.B.re' ^ 2.0 + 'core.B.im' ^ 2.0) "Magnitude of complex magnetic flux density";
    Real 'core.arg_B'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('core.B.im', 'core.B.re', 0.0) "Argument of complex magnetic flux density";
    Real 'core.A'(unit = "m2", quantity = "Area") "Area of cross section penetrated by magnetic flux";
    Real 'core.H.re'(unit = "A/m", quantity = "MagneticFieldStrength") "Real part of complex number";
    Real 'core.H.im'(unit = "A/m", quantity = "MagneticFieldStrength") "Imaginary part of complex number";
    Real 'core.abs_H'(unit = "A/m", quantity = "MagneticFieldStrength") = sqrt('core.H.re' ^ 2.0 + 'core.H.im' ^ 2.0) "Magnitude of complex magnetic field strength";
    Real 'core.arg_H'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('core.H.im', 'core.H.re', 0.0) "Argument of complex magnetic field strength";
    Real 'core.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    parameter Real 'core.l'(unit = "m", quantity = "Length") = 0.01 "Width (orthogonal to flux direction)";
    parameter Real 'core.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.045 "Inner radius of hollow cylinder";
    parameter Real 'core.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.055 "Outer radius of hollow cylinder";
    parameter Real 'core.alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 6.263185307179587 "Angle of cylinder section";
    Real 'airGap.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'airGap.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'airGap.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'airGap.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'airGap.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'airGap.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'airGap.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'airGap.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'airGap.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'airGap.port_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'airGap.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'airGap.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'airGap.abs_V_m'(unit = "A", quantity = "MagneticPotential") = sqrt('airGap.V_m.re' ^ 2.0 + 'airGap.V_m.im' ^ 2.0) "Magnitude of complex magnetic potential difference";
    Real 'airGap.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('airGap.V_m.im', 'airGap.V_m.re', 0.0) "Argument of complex magnetic potential difference";
    Real 'airGap.Phi.re'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'airGap.Phi.im'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'airGap.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") = sqrt('airGap.Phi.re' ^ 2.0 + 'airGap.Phi.im' ^ 2.0) "Magnitude of complex magnetic flux";
    Real 'airGap.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('airGap.Phi.im', 'airGap.Phi.re', 0.0) "Argument of complex magnetic flux";
    Real 'airGap.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'airGap.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability";
    Real 'airGap.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'airGap.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'airGap.B.re'(unit = "T", quantity = "MagneticFluxDensity") "Real part of complex number";
    Real 'airGap.B.im'(unit = "T", quantity = "MagneticFluxDensity") "Imaginary part of complex number";
    Real 'airGap.abs_B'(unit = "T", quantity = "MagneticFluxDensity") = sqrt('airGap.B.re' ^ 2.0 + 'airGap.B.im' ^ 2.0) "Magnitude of complex magnetic flux density";
    Real 'airGap.arg_B'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('airGap.B.im', 'airGap.B.re', 0.0) "Argument of complex magnetic flux density";
    Real 'airGap.A'(unit = "m2", quantity = "Area") "Area of cross section penetrated by magnetic flux";
    Real 'airGap.H.re'(unit = "A/m", quantity = "MagneticFieldStrength") "Real part of complex number";
    Real 'airGap.H.im'(unit = "A/m", quantity = "MagneticFieldStrength") "Imaginary part of complex number";
    Real 'airGap.abs_H'(unit = "A/m", quantity = "MagneticFieldStrength") = sqrt('airGap.H.re' ^ 2.0 + 'airGap.H.im' ^ 2.0) "Magnitude of complex magnetic field strength";
    Real 'airGap.arg_H'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('airGap.H.im', 'airGap.H.re', 0.0) "Argument of complex magnetic field strength";
    Real 'airGap.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    parameter Real 'airGap.l'(unit = "m", quantity = "Length") = 0.01 "Width (orthogonal to flux direction)";
    parameter Real 'airGap.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.045 "Inner radius of hollow cylinder";
    parameter Real 'airGap.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.055 "Outer radius of hollow cylinder";
    parameter Real 'airGap.alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.019999999999999574 "Angle of cylinder section";
    constant Real 'measuringCoil.j.re' = 0.0 "Real part of complex number";
    constant Real 'measuringCoil.j.im' = 1.0 "Imaginary part of complex number";
    Real 'measuringCoil.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'measuringCoil.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
