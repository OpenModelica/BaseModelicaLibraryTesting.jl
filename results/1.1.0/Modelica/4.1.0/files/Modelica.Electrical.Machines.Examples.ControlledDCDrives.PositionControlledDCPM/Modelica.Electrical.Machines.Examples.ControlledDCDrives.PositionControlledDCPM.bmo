//! base 0.1.0
package 'PositionControlledDCPM'
  type 'Modelica.Blocks.Types.VariableLimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'Fixed');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'PositionControlledDCPM' "Position controlled DC PM drive with H-bridge from battery"
    parameter Real 'driveData.motorData.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Rotor's moment of inertia";
    parameter Real 'driveData.motorData.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Stator's moment of inertia";
    parameter Real 'driveData.motorData.VaNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal armature voltage";
    parameter Real 'driveData.motorData.IaNominal'(unit = "A", quantity = "ElectricCurrent") = 100.0 "Nominal armature current (>0..Motor, <0..Generator)";
    parameter Real 'driveData.motorData.wNominal'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Nominal speed";
    parameter Real 'driveData.motorData.TaNominal'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Nominal armature temperature";
    parameter Real 'driveData.motorData.Ra'(unit = "Ohm", quantity = "Resistance") = 0.05 "Armature resistance at TaRef";
    parameter Real 'driveData.motorData.TaRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of armature resistance";
    parameter Real 'driveData.motorData.alpha20a'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of armature resistance";
    parameter Real 'driveData.motorData.La'(unit = "H", quantity = "Inductance") = 0.0015 "Armature inductance";
    parameter Real 'driveData.motorData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'driveData.motorData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that the PRef refer to";
    parameter Real 'driveData.motorData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'driveData.motorData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'driveData.motorData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'driveData.motorData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.14922565104551516 "Linear angular velocity range";
    parameter Real 'driveData.motorData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Real 'driveData.motorData.ViNominal'(unit = "V", quantity = "ElectricPotential") = 95.0 "Induced voltage at nominal operating point";
    parameter Integer 'driveData.motorData.coreParameters.m' = 1 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'driveData.motorData.coreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'driveData.motorData.coreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 95.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'driveData.motorData.coreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'driveData.motorData.coreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'driveData.motorData.coreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'driveData.motorData.coreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 1.4922565104551514e-4 "Angular velocity limit";
    parameter Real 'driveData.motorData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'driveData.motorData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'driveData.motorData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that PRef refers to";
    parameter Real 'driveData.motorData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'driveData.motorData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'driveData.motorData.brushParameters.V'(unit = "V", quantity = "ElectricPotential") = 0.0 "Total voltage drop of brushes for currents > ILinear";
    parameter Real 'driveData.motorData.brushParameters.ILinear'(start = 0.01, unit = "A", quantity = "ElectricCurrent") = 1.0 "Current indicating linear voltage region of brush voltage drop";
    parameter Real 'driveData.Ra'(unit = "Ohm", quantity = "Resistance") = 0.05 "Armature resistance at nominal temperature";
    parameter Real 'driveData.Ta'(unit = "s", quantity = "Time") = 0.03 "Armature time constant";
    parameter Real 'driveData.PNominal'(unit = "W", quantity = "Power") = 9500.0 "Nominal mechanical output";
    parameter Real 'driveData.tauNominal'(unit = "N.m", quantity = "Torque") = 63.66197723675815 "Nominal torque";
    parameter Real 'driveData.kPhi'(unit = "N.m/A", quantity = "ElectricalTorqueConstant") = 0.6366197723675815 "Torque constant";
    parameter Real 'driveData.w0'(unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948963 "No-load speed";
    parameter Real 'driveData.fS'(unit = "Hz", quantity = "Frequency") = 2000.0 "Switching frequency";
    parameter Real 'driveData.VBat'(unit = "V", quantity = "ElectricPotential") = 120.0 "DC no-load voltage";
    parameter Real 'driveData.Td'(unit = "s", quantity = "Time") = 2.5e-4 "Dead time of inverter";
    parameter Real 'driveData.Tmf'(unit = "s", quantity = "Time") = 0.001 "Measurement filter time constant";
    parameter Real 'driveData.Tsigma'(unit = "s", quantity = "Time") = 0.00125 "Sum of small time constants";
    parameter Real 'driveData.JL'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Load inertia";
    parameter Real 'driveData.VaMax'(unit = "V", quantity = "ElectricPotential") = 120.0 "Maximum Voltage";
    parameter Real 'driveData.IaMax'(unit = "A", quantity = "ElectricCurrent") = 150.0 "Maximum current";
    parameter Real 'driveData.tauMax'(unit = "N.m", quantity = "Torque") = 95.49296585513723 "Maximum torque";
    parameter Real 'driveData.wMax'(unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948963 "Maximum speed";
    parameter Real 'driveData.aMax'(unit = "rad/s2", quantity = "AngularAcceleration") = 318.30988618379075 "Maximum acceleration";
    parameter Real 'driveData.kpI' = 0.6 "Proportional gain";
    parameter Real 'driveData.TiI'(unit = "s", quantity = "Time") = 0.03 "Integral time constant";
    parameter Real 'driveData.Tsub'(unit = "s", quantity = "Time") = 0.0025 "Substitute time constant";
    parameter Real 'driveData.kpw' = 60.0 "Proportional gain";
    parameter Real 'driveData.Tiw'(unit = "s", quantity = "Time") = 0.01 "Integral time constant";
    parameter Real 'driveData.Tfw'(unit = "s", quantity = "Time") = 0.01 "Filter time constant";
    parameter Real 'driveData.kpP' = 25.0 "Proportional gain";
    Real 'loadInertia.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadInertia.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'loadInertia.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadInertia.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'loadInertia.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Moment of inertia";
    parameter StateSelect 'loadInertia.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'loadInertia.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'loadInertia.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'loadInertia.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'speedSensor.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'speedSensor.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'speedSensor.w'(unit = "rad/s") "Absolute angular velocity of flange as output signal";
    parameter Real 'dcpm.TaOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational armature temperature";
    parameter Real 'dcpm.VaNominal'(start = 100.0, unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal armature voltage";
    parameter Real 'dcpm.IaNominal'(start = 100.0, unit = "A", quantity = "ElectricCurrent") = 100.0 "Nominal armature current (>0..Motor, <0..Generator)";
    parameter Real 'dcpm.wNominal'(start = 149.22565104551515, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Nominal speed";
    parameter Real 'dcpm.TaNominal'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Nominal armature temperature";
    parameter Real 'dcpm.Ra'(start = 0.05, unit = "Ohm", quantity = "Resistance") = 0.05 "Armature resistance at TaRef";
    parameter Real 'dcpm.TaRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of armature resistance";
    parameter Real 'dcpm.alpha20a'(start = 0.0, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of armature resistance";
    parameter Real 'dcpm.La'(start = 0.0015, unit = "H", quantity = "Inductance") = 0.0015 "Armature inductance";
    parameter Real 'dcpm.Jr'(start = 0.15, unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Rotor's moment of inertia";
    parameter Boolean 'dcpm.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'dcpm.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Stator's moment of inertia";
    parameter Boolean 'dcpm.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Real 'dcpm.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'dcpm.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that the PRef refer to";
    parameter Real 'dcpm.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'dcpm.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'dcpm.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'dcpm.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.14922565104551516 "Linear angular velocity range";
    parameter Real 'dcpm.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    Real 'dcpm.phiMechanical'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 'dcpm.flange.phi' - 'dcpm.internalSupport.phi' "Mechanical angle of rotor against stator";
    Real 'dcpm.wMechanical'(fixed = true, start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = der('dcpm.phiMechanical') "Mechanical angular velocity of rotor against stator";
    Real 'dcpm.tauElectrical'(unit = "N.m", quantity = "Torque") = 'dcpm.inertiaRotor.flange_a.tau' "Electromagnetic torque";
    Real 'dcpm.tauShaft'(unit = "N.m", quantity = "Torque") = -'dcpm.flange.tau' "Shaft torque";
    Real 'dcpm.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'dcpm.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Moment of inertia";
    parameter StateSelect 'dcpm.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'dcpm.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'dcpm.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'dcpm.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'dcpm.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.inertiaStator.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.inertiaStator.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.inertiaStator.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'dcpm.inertiaStator.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Moment of inertia";
    parameter StateSelect 'dcpm.inertiaStator.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'dcpm.inertiaStator.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'dcpm.inertiaStator.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'dcpm.inertiaStator.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'dcpm.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'dcpm.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.friction.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.friction.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.friction.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.friction.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.friction.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between shaft and support";
    Real 'dcpm.friction.tau'(unit = "N.m", quantity = "Torque") "Torque";
    Real 'dcpm.friction.w'(unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity of flange and support";
    parameter Real 'dcpm.friction.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'dcpm.friction.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that the PRef refer to";
    parameter Real 'dcpm.friction.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'dcpm.friction.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'dcpm.friction.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'dcpm.friction.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.14922565104551516 "Linear angular velocity range";
    parameter Real 'dcpm.friction.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Boolean 'dcpm.friction.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'dcpm.friction.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.friction.heatPort.Q_flow'(unit = "W", quantity = "Power") = -'dcpm.friction.lossPower' "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.friction.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'dcpm.internalSupport.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.internalSupport.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Integer 'dcpm.coreParameters.m' = 1 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'dcpm.coreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'dcpm.coreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 95.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'dcpm.coreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'dcpm.coreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'dcpm.coreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'dcpm.coreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 1.4922565104551514e-4 "Angular velocity limit";
    parameter Real 'dcpm.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'dcpm.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'dcpm.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that PRef refers to";
    parameter Real 'dcpm.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'dcpm.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'dcpm.brushParameters.V'(unit = "V", quantity = "ElectricPotential") = 0.0 "Total voltage drop of brushes for currents > ILinear";
    parameter Real 'dcpm.brushParameters.ILinear'(start = 0.01, unit = "A", quantity = "ElectricCurrent") = 1.0 "Current indicating linear voltage region of brush voltage drop";
    Real 'dcpm.powerBalance.powerArmature'(unit = "W", quantity = "Power") = 'dcpm.va' * 'dcpm.ia' "Electrical armature power";
    Real 'dcpm.powerBalance.powerMechanical'(unit = "W", quantity = "Power") = 'dcpm.wMechanical' * 'dcpm.tauShaft' "Mechanical power";
    Real 'dcpm.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") = 0.15 * 'dcpm.inertiaStator.a' * 'dcpm.inertiaStator.w' "Stator inertia power";
    Real 'dcpm.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") = 0.15 * 'dcpm.inertiaRotor.a' * 'dcpm.inertiaRotor.w' "Rotor inertia power";
    Real 'dcpm.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") = 'dcpm.powerBalance.lossPowerArmature' + 'dcpm.powerBalance.lossPowerCore' + 'dcpm.powerBalance.lossPowerStrayLoad' + 'dcpm.powerBalance.lossPowerFriction' + 'dcpm.powerBalance.lossPowerBrush' + 'dcpm.powerBalance.lossPowerPermanentMagnet' "Total loss power";
    Real 'dcpm.powerBalance.lossPowerArmature'(unit = "W", quantity = "Power") = 'dcpm.ra.LossPower' "Armature copper losses";
    Real 'dcpm.powerBalance.lossPowerCore'(unit = "W", quantity = "Power") = 'dcpm.core.lossPower' "Core losses";
    Real 'dcpm.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") = 'dcpm.strayLoad.lossPower' "Stray load losses";
    Real 'dcpm.powerBalance.lossPowerFriction'(unit = "W", quantity = "Power") = 'dcpm.friction.lossPower' "Friction losses";
    Real 'dcpm.powerBalance.lossPowerBrush'(unit = "W", quantity = "Power") = 'dcpm.brush.lossPower' "Brush losses";
    Real 'dcpm.powerBalance.lossPowerPermanentMagnet'(unit = "W", quantity = "Power") = 0.0 "Permanent magnet losses";
    Real 'dcpm.va'(unit = "V", quantity = "ElectricPotential") = 'dcpm.pin_ap.v' - 'dcpm.pin_an.v' "Armature voltage";
    Real 'dcpm.ia'(fixed = true, start = 0.0, unit = "A", quantity = "ElectricCurrent") = 'dcpm.pin_ap.i' "Armature current";
    Real 'dcpm.pin_ap.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.pin_ap.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.pin_an.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.pin_an.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'dcpm.ra.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.05 "Resistance at temperature T_ref";
    parameter Real 'dcpm.ra.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'dcpm.ra.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'dcpm.ra.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'dcpm.ra.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.ra.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.ra.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.ra.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.ra.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'dcpm.ra.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'dcpm.ra.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'dcpm.ra.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 'dcpm.ra.T_heatPort' "Port temperature";
