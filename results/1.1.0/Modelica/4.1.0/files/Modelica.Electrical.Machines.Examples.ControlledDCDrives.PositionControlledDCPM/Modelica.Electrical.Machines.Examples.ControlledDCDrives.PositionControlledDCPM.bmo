    'armatureInverter.idealDcDc.powerBat.currentSensor.p.v' = 'armatureInverter.idealDcDc.powerBat.currentSensor.n.v';
    'armatureInverter.idealDcDc.powerBat.currentSensor.p.i' = 'armatureInverter.idealDcDc.powerBat.currentSensor.i';
    'armatureInverter.idealDcDc.powerBat.currentSensor.n.i' = -'armatureInverter.idealDcDc.powerBat.currentSensor.i';
    'armatureInverter.idealDcDc.powerBat.product.y' = 'armatureInverter.idealDcDc.powerBat.product.u1' * 'armatureInverter.idealDcDc.powerBat.product.u2';
    'armatureInverter.idealDcDc.powerMot.voltageSensor.p.i' = 0.0;
    'armatureInverter.idealDcDc.powerMot.voltageSensor.n.i' = 0.0;
    'armatureInverter.idealDcDc.powerMot.voltageSensor.v' = 'armatureInverter.idealDcDc.powerMot.voltageSensor.p.v' - 'armatureInverter.idealDcDc.powerMot.voltageSensor.n.v';
    'armatureInverter.idealDcDc.powerMot.currentSensor.p.v' = 'armatureInverter.idealDcDc.powerMot.currentSensor.n.v';
    'armatureInverter.idealDcDc.powerMot.currentSensor.p.i' = 'armatureInverter.idealDcDc.powerMot.currentSensor.i';
    'armatureInverter.idealDcDc.powerMot.currentSensor.n.i' = -'armatureInverter.idealDcDc.powerMot.currentSensor.i';
    'armatureInverter.idealDcDc.powerMot.product.y' = 'armatureInverter.idealDcDc.powerMot.product.u1' * 'armatureInverter.idealDcDc.powerMot.product.u2';
    der('armatureInverter.idealDcDc.deadTime.y') = ('armatureInverter.idealDcDc.deadTime.u' - 'armatureInverter.idealDcDc.deadTime.y') / 2.5e-4;
    'armatureInverter.idealDcDc.feedback.y' = 'armatureInverter.idealDcDc.feedback.u1' - 'armatureInverter.idealDcDc.feedback.u2';
    'armatureInverter.idealDcDc.powerController.local_reset' = false;
    'armatureInverter.idealDcDc.powerController.local_set' = 0.0;
    der('armatureInverter.idealDcDc.powerController.y') = 1e6 * 'armatureInverter.idealDcDc.powerController.u';
    'armatureInverter.idealDcDc.groundMotor.p.v' = 0.0;
    'armatureInverter.iDCSensor.p.v' = 'armatureInverter.iDCSensor.n.v';
    'armatureInverter.iDCSensor.p.i' = 'armatureInverter.iDCSensor.i';
    'armatureInverter.iDCSensor.n.i' = -'armatureInverter.iDCSensor.i';
    'armatureInverter.vMotSensor.p.i' = 0.0;
    'armatureInverter.vMotSensor.n.i' = 0.0;
    'armatureInverter.vMotSensor.v' = 'armatureInverter.vMotSensor.p.v' - 'armatureInverter.vMotSensor.n.v';
    der('armatureInverter.vMotFilter.y') = ('armatureInverter.vMotFilter.u' - 'armatureInverter.vMotFilter.y') / 0.001;
    der('armatureInverter.iDCFilter.y') = ('armatureInverter.iDCFilter.u' - 'armatureInverter.iDCFilter.y') / 0.001;
    'currentController.feedback.y' = 'currentController.feedback.u1' - 'currentController.feedback.u2';
    'currentController.addAntiWindup.y' = 'currentController.addAntiWindup.u1' + (-1.6666666666666667) * 'currentController.addAntiWindup.u2';
    'currentController.integrator.local_reset' = false;
    'currentController.integrator.local_set' = 0.0;
    der('currentController.integrator.y') = 33.333333333333336 * 'currentController.integrator.u';
    'currentController.add3.y' = 0.6 * 'currentController.add3.u1' + 0.6 * 'currentController.add3.u2' + 'currentController.add3.u3';
    assert('currentController.variableLimiter.limit1' >= 'currentController.variableLimiter.limit2', "Input signals are not consistent: limit1 < limit2", AssertionLevel.error);
    'currentController.variableLimiter.simplifiedExpr' = 'currentController.variableLimiter.u';
    'currentController.variableLimiter.y' = homotopy(smooth(0, if 'currentController.variableLimiter.u' > 'currentController.variableLimiter.limit1' then 'currentController.variableLimiter.limit1' else if 'currentController.variableLimiter.u' < 'currentController.variableLimiter.limit2' then 'currentController.variableLimiter.limit2' else 'currentController.variableLimiter.u'), 'currentController.variableLimiter.simplifiedExpr');
    'currentController.addSat.y' = 'currentController.addSat.u1' - 'currentController.addSat.u2';
    'currentController.product.y' = 'currentController.product.u1' * 'currentController.product.u2';
    'currentController.constantKFF.y' = 0.6366197723675815;
    'currentController.gain.y' = (-1.0) * 'currentController.gain.u';
    'tau2i.y' = 1.5707963267948963 * 'tau2i.u';
    'constantVoltage.v' = 120.0;
    0.0 = 'constantVoltage.p.i' + 'constantVoltage.n.i';
    'constantVoltage.i' = 'constantVoltage.p.i';
    'constantVoltage.v' = 'constantVoltage.p.v' - 'constantVoltage.n.v';
    'resistor.R_actual' = 0.06;
    'resistor.v' = 'resistor.R_actual' * 'resistor.i';
    'resistor.LossPower' = 'resistor.v' * 'resistor.i';
    'resistor.T_heatPort' = 300.15;
    0.0 = 'resistor.p.i' + 'resistor.n.i';
    'resistor.i' = 'resistor.p.i';
    'resistor.v' = 'resistor.p.v' - 'resistor.n.v';
    'ground.p.v' = 0.0;
    'loadTorque.tau' = -'loadTorque.flange.tau';
    'loadTorque.tau' = if time < 2.3 then 0.0 else -63.66197723675815;
    'loadTorque.phi' = 'loadTorque.flange.phi' - 'loadTorque.phi_support';
    'loadTorque.phi_support' = 0.0;
    'speedController.feedback.y' = 'speedController.feedback.u1' - 'speedController.feedback.u2';
    'speedController.addAntiWindup.y' = 'speedController.addAntiWindup.u1' + (-0.016666666666666666) * 'speedController.addAntiWindup.u2';
    'speedController.integrator.local_reset' = false;
    'speedController.integrator.local_set' = 0.0;
    der('speedController.integrator.y') = 100.0 * 'speedController.integrator.u';
    'speedController.add3.y' = 60.0 * 'speedController.add3.u1' + 60.0 * 'speedController.add3.u2' + 'speedController.add3.u3';
    assert('speedController.variableLimiter.limit1' >= 'speedController.variableLimiter.limit2', "Input signals are not consistent: limit1 < limit2", AssertionLevel.error);
    'speedController.variableLimiter.simplifiedExpr' = 'speedController.variableLimiter.u';
    'speedController.variableLimiter.y' = homotopy(smooth(0, if 'speedController.variableLimiter.u' > 'speedController.variableLimiter.limit1' then 'speedController.variableLimiter.limit1' else if 'speedController.variableLimiter.u' < 'speedController.variableLimiter.limit2' then 'speedController.variableLimiter.limit2' else 'speedController.variableLimiter.u'), 'speedController.variableLimiter.simplifiedExpr');
    'speedController.addSat.y' = 'speedController.addSat.u1' - 'speedController.addSat.u2';
    'speedController.product.y' = 'speedController.product.u1' * 'speedController.product.u2';
    'speedController.zeroFF.y' = 0.0;
    'speedController.constantKFF.y' = 1.0;
    'speedController.yMaxConst.y' = 95.49296585513723;
    'speedController.gain.y' = (-1.0) * 'speedController.gain.u';
    'positionController.feedback.y' = 'positionController.feedback.u1' - 'positionController.feedback.u2';
    'positionController.addAntiWindup.y' = 'positionController.addAntiWindup.u1' + (-0.04) * 'positionController.addAntiWindup.u2';
    'positionController.add3.y' = 25.0 * 'positionController.add3.u1' + 25.0 * 'positionController.add3.u2' + 'positionController.add3.u3';
    assert('positionController.variableLimiter.limit1' >= 'positionController.variableLimiter.limit2', "Input signals are not consistent: limit1 < limit2", AssertionLevel.error);
    'positionController.variableLimiter.simplifiedExpr' = 'positionController.variableLimiter.u';
    'positionController.variableLimiter.y' = homotopy(smooth(0, if 'positionController.variableLimiter.u' > 'positionController.variableLimiter.limit1' then 'positionController.variableLimiter.limit1' else if 'positionController.variableLimiter.u' < 'positionController.variableLimiter.limit2' then 'positionController.variableLimiter.limit2' else 'positionController.variableLimiter.u'), 'positionController.variableLimiter.simplifiedExpr');
    'positionController.addSat.y' = 'positionController.addSat.u1' - 'positionController.addSat.u2';
    'positionController.product.y' = 'positionController.product.u1' * 'positionController.product.u2';
    'positionController.zeroI.y' = 0.0;
    'positionController.zeroFF.y' = 0.0;
    'positionController.constantKFF.y' = 1.0;
    'positionController.yMaxConst.y' = 157.07963267948963;
    'positionController.gain.y' = (-1.0) * 'positionController.gain.u';
    'angleSensor.phi' = 'angleSensor.flange.phi';
    0.0 = 'angleSensor.flange.tau';
    'kinematicPTP.aux1[1]' = 1.273239544735163;
    'kinematicPTP.aux2[1]' = 0.6283185307179585;
    'kinematicPTP.sd_max_inv' = abs('kinematicPTP.aux1[1]');
    'kinematicPTP.sdd_max_inv' = abs('kinematicPTP.aux2[1]');

    if 'kinematicPTP.sd_max_inv' <= 2.220446049250313e-15 or 'kinematicPTP.sdd_max_inv' <= 2.220446049250313e-15 then
      'kinematicPTP.sd_max' = 0.0;
      'kinematicPTP.sdd_max' = 0.0;
      'kinematicPTP.Ta1' = 0.0;
      'kinematicPTP.Ta2' = 0.0;
      'kinematicPTP.noWphase' = false;
      'kinematicPTP.Tv' = 0.0;
      'kinematicPTP.Te' = 0.0;
      'kinematicPTP.Ta1s' = 0.0;
      'kinematicPTP.Ta2s' = 0.0;
      'kinematicPTP.Tvs' = 0.0;
      'kinematicPTP.Tes' = 0.0;
      'kinematicPTP.sd_max2' = 0.0;
      'kinematicPTP.s1' = 0.0;
      'kinematicPTP.s2' = 0.0;
      'kinematicPTP.s3' = 0.0;
      'kinematicPTP.s' = 0.0;
    elseif true then
      'kinematicPTP.sd_max' = 1.0 / abs('kinematicPTP.aux1[1]');
      'kinematicPTP.sdd_max' = 1.0 / abs('kinematicPTP.aux2[1]');
      'kinematicPTP.Ta1' = sqrt(1.0 / 'kinematicPTP.sdd_max');
      'kinematicPTP.Ta2' = 'kinematicPTP.sd_max' / 'kinematicPTP.sdd_max';
      'kinematicPTP.noWphase' = 'kinematicPTP.Ta2' >= 'kinematicPTP.Ta1';
      'kinematicPTP.Tv' = if 'kinematicPTP.noWphase' then 'kinematicPTP.Ta1' else 1.0 / 'kinematicPTP.sd_max';
      'kinematicPTP.Te' = if 'kinematicPTP.noWphase' then 'kinematicPTP.Ta1' + 'kinematicPTP.Ta1' else 'kinematicPTP.Tv' + 'kinematicPTP.Ta2';
      'kinematicPTP.Ta1s' = 'kinematicPTP.Ta1' + 0.2;
      'kinematicPTP.Ta2s' = 'kinematicPTP.Ta2' + 0.2;
      'kinematicPTP.Tvs' = 'kinematicPTP.Tv' + 0.2;
      'kinematicPTP.Tes' = 'kinematicPTP.Te' + 0.2;
      'kinematicPTP.sd_max2' = 'kinematicPTP.sdd_max' * 'kinematicPTP.Ta1';
      'kinematicPTP.s1' = 'kinematicPTP.sdd_max' * (if 'kinematicPTP.noWphase' then 'kinematicPTP.Ta1' * 'kinematicPTP.Ta1' else 'kinematicPTP.Ta2' * 'kinematicPTP.Ta2') / 2.0;
      'kinematicPTP.s2' = 'kinematicPTP.s1' + (if 'kinematicPTP.noWphase' then 'kinematicPTP.sd_max2' * ('kinematicPTP.Te' - 'kinematicPTP.Ta1') - 'kinematicPTP.sdd_max' / 2.0 * ('kinematicPTP.Te' - 'kinematicPTP.Ta1') ^ 2.0 else 'kinematicPTP.sd_max' * ('kinematicPTP.Tv' - 'kinematicPTP.Ta2'));
      'kinematicPTP.s3' = 'kinematicPTP.s2' + 'kinematicPTP.sd_max' * ('kinematicPTP.Te' - 'kinematicPTP.Tv') - 'kinematicPTP.sdd_max' / 2.0 * ('kinematicPTP.Te' - 'kinematicPTP.Tv') * ('kinematicPTP.Te' - 'kinematicPTP.Tv');

      if time < 0.2 then
        'kinematicPTP.s' = 0.0;
      elseif 'kinematicPTP.noWphase' then
        if time < 'kinematicPTP.Ta1s' then
          'kinematicPTP.s' = 'kinematicPTP.sdd_max' / 2.0 * (time - 0.2) * (time - 0.2);
        elseif time < 'kinematicPTP.Tes' then
          'kinematicPTP.s' = 'kinematicPTP.s1' + 'kinematicPTP.sd_max2' * (time - 'kinematicPTP.Ta1s') - 'kinematicPTP.sdd_max' / 2.0 * (time - 'kinematicPTP.Ta1s') * (time - 'kinematicPTP.Ta1s');
        elseif true then
          'kinematicPTP.s' = 'kinematicPTP.s2';
        end if;
      elseif time < 'kinematicPTP.Ta2s' then
        'kinematicPTP.s' = 'kinematicPTP.sdd_max' / 2.0 * (time - 0.2) * (time - 0.2);
      elseif time < 'kinematicPTP.Tvs' then
        'kinematicPTP.s' = 'kinematicPTP.s1' + 'kinematicPTP.sd_max' * (time - 'kinematicPTP.Ta2s');
      elseif time < 'kinematicPTP.Tes' then
        'kinematicPTP.s' = 'kinematicPTP.s2' + 'kinematicPTP.sd_max' * (time - 'kinematicPTP.Tvs') - 'kinematicPTP.sdd_max' / 2.0 * (time - 'kinematicPTP.Tvs') * (time - 'kinematicPTP.Tvs');
      elseif true then
        'kinematicPTP.s' = 'kinematicPTP.s3';
      end if;
    end if;

    'kinematicPTP.sd' = der('kinematicPTP.s');
    'kinematicPTP.sdd' = der('kinematicPTP.sd');
    'kinematicPTP.qdd[1]' = 200.0 * 'kinematicPTP.sdd';
    'kinematicPTP.qd[1]' = 200.0 * 'kinematicPTP.sd';
    'kinematicPTP.q[1]' = 200.0 * 'kinematicPTP.s';
    'kinematicPTP.endTime' = 'kinematicPTP.Tes';
    'kinematicPTP.motion_ref' = time < 'kinematicPTP.endTime';
    'kinematicPTP.moving[1]' = 'kinematicPTP.motion_ref';
    annotation(experiment(StopTime = 2.5, Interval = 0.0001));
  end 'PositionControlledDCPM';
end 'PositionControlledDCPM';
