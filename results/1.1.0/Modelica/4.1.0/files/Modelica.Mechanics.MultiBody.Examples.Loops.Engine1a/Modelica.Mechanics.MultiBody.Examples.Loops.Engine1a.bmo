    parameter StateSelect 'cylinder.stateSelect' = StateSelect.prefer "Priority to use distance s and v=der(s) as states";
    parameter Real 'cylinder.e[1]'(unit = "1") = 0.0 "Unit vector in direction of prismatic axis n";
