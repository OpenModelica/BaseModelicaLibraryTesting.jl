    'stack.cell[3,2].multiSensor.v' = 'stack.cell[3,2].multiSensor.pv.v' - 'stack.cell[3,2].multiSensor.nv.v';
    'stack.cell[3,2].multiSensor.power' = 'stack.cell[3,2].multiSensor.v' * 'stack.cell[3,2].multiSensor.i';
    'stack.cell[3,2].limIntegrator.local_reset' = false;
    'stack.cell[3,2].limIntegrator.local_set' = 0.0;
    der('stack.cell[3,2].limIntegrator.y') = if 'stack.cell[3,2].limIntegrator.y' < 1e-9 and 'stack.cell[3,2].limIntegrator.k' * 'stack.cell[3,2].limIntegrator.u' < 0.0 or 'stack.cell[3,2].limIntegrator.y' > 0.999999999 and 'stack.cell[3,2].limIntegrator.k' * 'stack.cell[3,2].limIntegrator.u' > 0.0 then 0.0 else 'stack.cell[3,2].limIntegrator.k' * 'stack.cell[3,2].limIntegrator.u';
    'stack.cell[3,2].temperatureSensor.T' = 'stack.cell[3,2].temperatureSensor.port.T';
    'stack.cell[3,2].temperatureSensor.port.Q_flow' = 0.0;
    'stack.cell[3,2].heatFlowSensor.port_a.T' = 'stack.cell[3,2].heatFlowSensor.port_b.T';
    'stack.cell[3,2].heatFlowSensor.port_a.Q_flow' + 'stack.cell[3,2].heatFlowSensor.port_b.Q_flow' = 0.0;
    'stack.cell[3,2].heatFlowSensor.Q_flow' = 'stack.cell[3,2].heatFlowSensor.port_a.Q_flow';
    'stack.cell[3,2].v' = 'stack.cell[3,2].p.v' - 'stack.cell[3,2].n.v';
    'stack.multiSensor.pc.i' + 'stack.multiSensor.nc.i' = 0.0;
    'stack.multiSensor.pc.v' - 'stack.multiSensor.nc.v' = 0.0;
    'stack.multiSensor.pv.i' = 0.0;
    'stack.multiSensor.nv.i' = 0.0;
    'stack.multiSensor.i' = 'stack.multiSensor.pc.i';
    'stack.multiSensor.v' = 'stack.multiSensor.pv.v' - 'stack.multiSensor.nv.v';
    'stack.multiSensor.power' = 'stack.multiSensor.v' * 'stack.multiSensor.i';
    'stack.v' = 'stack.p.v' - 'stack.n.v';
    'busTranscription.gainV[1,1].y' = 'busTranscription.gainV[1,1].u';
    'busTranscription.gainV[1,2].y' = 'busTranscription.gainV[1,2].u';
    'busTranscription.gainV[2,1].y' = 'busTranscription.gainV[2,1].u';
    'busTranscription.gainV[2,2].y' = 'busTranscription.gainV[2,2].u';
    'busTranscription.gainV[3,1].y' = 'busTranscription.gainV[3,1].u';
    'busTranscription.gainV[3,2].y' = 'busTranscription.gainV[3,2].u';
    'busTranscription.gainI[1,1].y' = 'busTranscription.gainI[1,1].u';
    'busTranscription.gainI[1,2].y' = 'busTranscription.gainI[1,2].u';
    'busTranscription.gainI[2,1].y' = 'busTranscription.gainI[2,1].u';
    'busTranscription.gainI[2,2].y' = 'busTranscription.gainI[2,2].u';
    'busTranscription.gainI[3,1].y' = 'busTranscription.gainI[3,1].u';
    'busTranscription.gainI[3,2].y' = 'busTranscription.gainI[3,2].u';
    'busTranscription.gainSOC[1,1].y' = 'busTranscription.gainSOC[1,1].u';
    'busTranscription.gainSOC[1,2].y' = 'busTranscription.gainSOC[1,2].u';
    'busTranscription.gainSOC[2,1].y' = 'busTranscription.gainSOC[2,1].u';
    'busTranscription.gainSOC[2,2].y' = 'busTranscription.gainSOC[2,2].u';
    'busTranscription.gainSOC[3,1].y' = 'busTranscription.gainSOC[3,1].u';
    'busTranscription.gainSOC[3,2].y' = 'busTranscription.gainSOC[3,2].u';
    'busTranscription.gainP[1,1].y' = 'busTranscription.gainP[1,1].u';
    'busTranscription.gainP[1,2].y' = 'busTranscription.gainP[1,2].u';
    'busTranscription.gainP[2,1].y' = 'busTranscription.gainP[2,1].u';
    'busTranscription.gainP[2,2].y' = 'busTranscription.gainP[2,2].u';
    'busTranscription.gainP[3,1].y' = 'busTranscription.gainP[3,1].u';
    'busTranscription.gainP[3,2].y' = 'busTranscription.gainP[3,2].u';
    'busTranscription.gainLosses[1,1].y' = 'busTranscription.gainLosses[1,1].u';
    'busTranscription.gainLosses[1,2].y' = 'busTranscription.gainLosses[1,2].u';
    'busTranscription.gainLosses[2,1].y' = 'busTranscription.gainLosses[2,1].u';
    'busTranscription.gainLosses[2,2].y' = 'busTranscription.gainLosses[2,2].u';
    'busTranscription.gainLosses[3,1].y' = 'busTranscription.gainLosses[3,1].u';
    'busTranscription.gainLosses[3,2].y' = 'busTranscription.gainLosses[3,2].u';
    'busTranscription.gainT[1,1].y' = 'busTranscription.gainT[1,1].u';
    'busTranscription.gainT[1,2].y' = 'busTranscription.gainT[1,2].u';
    'busTranscription.gainT[2,1].y' = 'busTranscription.gainT[2,1].u';
    'busTranscription.gainT[2,2].y' = 'busTranscription.gainT[2,2].u';
    'busTranscription.gainT[3,1].y' = 'busTranscription.gainT[3,1].u';
    'busTranscription.gainT[3,2].y' = 'busTranscription.gainT[3,2].u';
    'energy.local_reset' = false;
    'energy.local_set' = 0.0;
    der('energy.y') = 'energy.u';
    'multiSensor.pc.i' + 'multiSensor.nc.i' = 0.0;
    'multiSensor.pc.v' - 'multiSensor.nc.v' = 0.0;
    'multiSensor.pv.i' = 0.0;
    'multiSensor.nv.i' = 0.0;
    'multiSensor.i' = 'multiSensor.pc.i';
    'multiSensor.v' = 'multiSensor.pv.v' - 'multiSensor.nv.v';
    'multiSensor.power' = 'multiSensor.v' * 'multiSensor.i';
    annotation(experiment(StopTime = 1200, Interval = 0.1, Tolerance = 1e-06));
  end 'CCCV_StackRC';
end 'CCCV_StackRC';
