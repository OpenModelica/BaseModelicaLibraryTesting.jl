    Real 'transformer.core.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'transformer.core.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'transformer.core.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'transformer.core.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'transformer.core.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'transformer.core.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'transformer.core.l'(unit = "m", quantity = "Length") = 0.2 "Length in direction of flux";
    parameter Real 'transformer.core.A'(unit = "m2", quantity = "Area") = 1.5e-4 "Area of cross section";
    parameter Real 'transformer.core.V'(unit = "m3", quantity = "Volume") = 2.9999999999999997e-5 "Volume of FluxTube";
    parameter Boolean 'transformer.core.useHeatPort' = false "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'transformer.core.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'transformer.core.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via HeatPort";
    Real 'transformer.core.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of HeatPort";
    parameter Boolean 'transformer.core.includeEddyCurrents' = false "= true, if eddy current losses are enabled" annotation(Evaluate = true);
    parameter Real 'transformer.core.sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6 "Conductivity of core material";
    parameter Real 'transformer.core.d'(unit = "m", quantity = "Length") = 5e-4 "Thickness of lamination";
    Real 'transformer.core.H'(fixed = false, start = 0.0, unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'transformer.core.Hstat'(unit = "A/m", quantity = "MagneticFieldStrength") "Static (ferromagnetic) portion of the magnetic field strength";
    Real 'transformer.core.Heddy'(unit = "A/m", quantity = "MagneticFieldStrength") "Dynamic (eddy currents) portion of the magnetic field strength";
    Real 'transformer.core.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'transformer.core.MagRel'(fixed = true, start = 0.0, max = 1.0, min = -1.0, unit = "1", quantity = "Relative magnetization") "Relative magnetization at initialization (-1..1)";
    Real 'transformer.core.LossPowerStat'(unit = "W", quantity = "Power") "Ferromagnetic (static) hysteresis losses";
    Real 'transformer.core.LossPowerEddy'(unit = "W", quantity = "Power") "Eddy current losses (dynamic hysteresis losses)";
    Real 'transformer.core.derHstat'(start = 0.0, unit = "A/(m.s)") = der('transformer.core.Hstat');
    parameter Real 'transformer.core.eddyCurrentFactor'(unit = "S.m") = 0.04583333333333333;
    Boolean 'transformer.core.asc'(start = true) "True when der(Hstat)>0";
    Real 'transformer.core.hystR'(unit = "T", quantity = "MagneticFluxDensity") "Rising branch of limiting hysteresis loop";
    Real 'transformer.core.hystF'(unit = "T", quantity = "MagneticFluxDensity") "Falling branch of limiting hysteresis loop";
    Real 'transformer.core.diffHyst'(unit = "T", quantity = "MagneticFluxDensity") "Distance between rising and falling limiting hysteresis branch at the current operating point";
    Real 'transformer.core.dHyst'(unit = "T/s", quantity = "MagneticFluxDensitySlope") "Slope of the Rising (when der(H)>0) or Falling (when der(H)<0) limiting hysteresis branch at the current operating point";
    Real 'transformer.core.k';
    parameter Real 'transformer.core.mu0'(unit = "N/A2") = 6.2831853106e-5;
    parameter Real 'transformer.core.Js'(unit = "T", quantity = "MagneticFluxDensity") = 1.4331021782802786 "Saturation polarization";
    parameter Real 'transformer.core.eps'(unit = "T", quantity = "MagneticFluxDensity") = 9.67e-4;
    parameter Real 'transformer.core.P1' = 1.6930237203043585;
    parameter Real 'transformer.core.P4' = 0.011178593500680808;
    Real 'transformer.core.H2'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'transformer.core.H3'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'transformer.core.P2';
    Real 'transformer.core.P3';
    Real 'transformer.core.H_lim';
    constant Real 'transformer.core.unitT'(unit = "T", quantity = "MagneticFluxDensity") = 1.0;
  initial equation
    'transformer.core.B' = ('transformer.core.hystR' + 'transformer.core.hystF') / 2.0 + 'transformer.core.MagRel' * 'transformer.core.diffHyst' / 2.0;
    'transformer.core.derHstat' = 0.0;
  equation
    'transformer.winding2.port_n.V_m' = 'transformer.ground.port.V_m';
    'transformer.winding2.port_n.V_m' = 'transformer.winding1.port_n.V_m';
    'transformer.resistor1.n.v' = 'transformer.winding1.p.v';
    'transformer.resistor1.p.v' = 'transformer.p1.v';
    'transformer.resistor2.n.v' = 'transformer.p2.v';
    'transformer.winding1.n.v' = 'transformer.n1.v';
    'transformer.resistor2.heatPort.T' = 'transformer.tempSource.port.T';
    'transformer.resistor2.heatPort.T' = 'transformer.resistor1.heatPort.T';
    'transformer.winding2.n.v' = 'transformer.resistor2.p.v';
    'transformer.n2.v' = 'transformer.winding2.p.v';
    'transformer.winding2.p.i' - 'transformer.n2.i' = 0.0;
    'transformer.core.port_p.V_m' = 'transformer.winding1.port_p.V_m';
    'transformer.core.port_n.V_m' = 'transformer.winding2.port_p.V_m';
    'SineVoltage.p.v' = 'resistor1.p.v';
    'transformer.n1.v' = 'el_ground1.p.v';
    'transformer.n1.v' = 'SineVoltage.n.v';
    'transformer.n2.v' = 'el_ground2.p.v';
    'transformer.n2.v' = 'resistor2.n.v';
    'resistor1.n.v' = 'transformer.p1.v';
    'transformer.p2.v' = 'resistor2.p.v';
    'transformer.p1.i' + 'resistor1.n.i' = 0.0;
    'SineVoltage.p.i' + 'resistor1.p.i' = 0.0;
    'transformer.n1.i' + 'SineVoltage.n.i' + 'el_ground1.p.i' = 0.0;
    'transformer.n2.i' + 'el_ground2.p.i' + 'resistor2.n.i' = 0.0;
    'transformer.p2.i' + 'resistor2.p.i' = 0.0;
    'transformer.winding2.port_n.Phi' + 'transformer.winding1.port_n.Phi' + 'transformer.ground.port.Phi' = 0.0;
    'transformer.winding1.n.i' - 'transformer.n1.i' = 0.0;
    'transformer.resistor2.p.i' + 'transformer.winding2.n.i' = 0.0;
    'transformer.resistor1.p.i' - 'transformer.p1.i' = 0.0;
    'transformer.resistor1.n.i' + 'transformer.winding1.p.i' = 0.0;
    'transformer.resistor2.heatPort.Q_flow' + 'transformer.resistor1.heatPort.Q_flow' + 'transformer.tempSource.port.Q_flow' = 0.0;
    'transformer.resistor2.n.i' - 'transformer.p2.i' = 0.0;
    'transformer.core.port_p.Phi' + 'transformer.winding1.port_p.Phi' = 0.0;
    'transformer.core.port_n.Phi' + 'transformer.winding2.port_p.Phi' = 0.0;
    'el_ground1.p.v' = 0.0;
    'resistor1.R_actual' = 0.05;
    'resistor1.v' = 'resistor1.R_actual' * 'resistor1.i';
    'resistor1.LossPower' = 'resistor1.v' * 'resistor1.i';
    'resistor1.T_heatPort' = 300.15;
    0.0 = 'resistor1.p.i' + 'resistor1.n.i';
    'resistor1.i' = 'resistor1.p.i';
    'resistor1.v' = 'resistor1.p.v' - 'resistor1.n.v';
    'SineVoltage.signalSource.y' = if time < 0.0 then 0.0 else 6.0 * sin(2513.2741228718346 * time);
    'SineVoltage.v' = 'SineVoltage.signalSource.y';
    0.0 = 'SineVoltage.p.i' + 'SineVoltage.n.i';
    'SineVoltage.i' = 'SineVoltage.p.i';
    'SineVoltage.v' = 'SineVoltage.p.v' - 'SineVoltage.n.v';
    'resistor2.R_actual' = 2.0;
    'resistor2.v' = 'resistor2.R_actual' * 'resistor2.i';
    'resistor2.LossPower' = 'resistor2.v' * 'resistor2.i';
    'resistor2.T_heatPort' = 300.15;
    0.0 = 'resistor2.p.i' + 'resistor2.n.i';
    'resistor2.i' = 'resistor2.p.i';
    'resistor2.v' = 'resistor2.p.v' - 'resistor2.n.v';
    'el_ground2.p.v' = 0.0;
    'transformer.tempSource.port.T' = 'transformer.tempSource.T';
    'transformer.ground.port.V_m' = 0.0;
    'transformer.winding1.v' = 'transformer.winding1.p.v' - 'transformer.winding1.n.v';
    0.0 = 'transformer.winding1.p.i' + 'transformer.winding1.n.i';
    'transformer.winding1.i' = 'transformer.winding1.p.i';
    'transformer.winding1.V_m' = 'transformer.winding1.port_p.V_m' - 'transformer.winding1.port_n.V_m';
    0.0 = 'transformer.winding1.port_p.Phi' + 'transformer.winding1.port_n.Phi';
    'transformer.winding1.Phi' = 'transformer.winding1.port_p.Phi';
    'transformer.winding1.V_m' = 'transformer.winding1.i' * 10.0 "Ampere's law";
    10.0 * der('transformer.winding1.Phi_ind') = -'transformer.winding1.v' "Faraday's law";
    'transformer.winding1.Phi_leak' = 1.25663706212e-9 * 'transformer.winding1.V_m';
    'transformer.winding1.Phi' = 'transformer.winding1.Phi_ind' + 'transformer.winding1.Phi_leak';
    'transformer.winding1.Psi' = 10.0 * 'transformer.winding1.Phi_ind';
    'transformer.winding1.L_stat' = noEvent(if abs('transformer.winding1.i') > 2.220446049250313e-14 then abs('transformer.winding1.Psi' / 'transformer.winding1.i') else abs('transformer.winding1.Psi' / 2.220446049250313e-14));
    'transformer.winding2.v' = 'transformer.winding2.p.v' - 'transformer.winding2.n.v';
    0.0 = 'transformer.winding2.p.i' + 'transformer.winding2.n.i';
    'transformer.winding2.i' = 'transformer.winding2.p.i';
    'transformer.winding2.V_m' = 'transformer.winding2.port_p.V_m' - 'transformer.winding2.port_n.V_m';
    0.0 = 'transformer.winding2.port_p.Phi' + 'transformer.winding2.port_n.Phi';
    'transformer.winding2.Phi' = 'transformer.winding2.port_p.Phi';
    'transformer.winding2.V_m' = 'transformer.winding2.i' * 10.0 "Ampere's law";
    10.0 * der('transformer.winding2.Phi_ind') = -'transformer.winding2.v' "Faraday's law";
    'transformer.winding2.Phi_leak' = 1.25663706212e-9 * 'transformer.winding2.V_m';
    'transformer.winding2.Phi' = 'transformer.winding2.Phi_ind' + 'transformer.winding2.Phi_leak';
    'transformer.winding2.Psi' = 10.0 * 'transformer.winding2.Phi_ind';
    'transformer.winding2.L_stat' = noEvent(if abs('transformer.winding2.i') > 2.220446049250313e-14 then abs('transformer.winding2.Psi' / 'transformer.winding2.i') else abs('transformer.winding2.Psi' / 2.220446049250313e-14));
    'transformer.resistor1.R_actual' = 0.051275902945574464;
    'transformer.resistor1.v' = 'transformer.resistor1.R_actual' * 'transformer.resistor1.i';
    'transformer.resistor1.LossPower' = 'transformer.resistor1.v' * 'transformer.resistor1.i';
    0.0 = 'transformer.resistor1.p.i' + 'transformer.resistor1.n.i';
    'transformer.resistor1.i' = 'transformer.resistor1.p.i';
    'transformer.resistor1.v' = 'transformer.resistor1.p.v' - 'transformer.resistor1.n.v';
    'transformer.resistor2.R_actual' = 0.051275902945574464;
    'transformer.resistor2.v' = 'transformer.resistor2.R_actual' * 'transformer.resistor2.i';
    'transformer.resistor2.LossPower' = 'transformer.resistor2.v' * 'transformer.resistor2.i';
    0.0 = 'transformer.resistor2.p.i' + 'transformer.resistor2.n.i';
    'transformer.resistor2.i' = 'transformer.resistor2.p.i';
    'transformer.resistor2.v' = 'transformer.resistor2.p.v' - 'transformer.resistor2.n.v';
    'transformer.core.H_lim' = if 'transformer.core.Hstat' < (-650.0) then -650.0 else if 'transformer.core.Hstat' > 650.0 then 650.0 else 'transformer.core.Hstat';
    'transformer.core.H2' = 'transformer.core.H_lim' - 42.2283;
    'transformer.core.H3' = -('transformer.core.H_lim' + 42.2283);
    'transformer.core.P2' = 0.48597552 * (0.6366197723675814 * atan(0.039964 * 'transformer.core.H2') + 1.0) + 0.96204896 / (1.0 + 0.5 * (exp(-0.18807 * 'transformer.core.H2') + exp(-7.81e-4 * 'transformer.core.H2')));
    'transformer.core.P3' = 0.48597552 * (0.6366197723675814 * atan(0.039964 * 'transformer.core.H3') + 1.0) + 0.96204896 / (1.0 + 0.5 * (exp(-0.18807 * 'transformer.core.H3') + exp(-7.81e-4 * 'transformer.core.H3')));
    'transformer.core.hystR' = 1.6930237203043585 * 'transformer.core.P2' - 'transformer.core.P3' * 0.011178593500680808 - 1.4331021782802786 + 6.2831853106e-5 * 'transformer.core.Hstat' - 4.835e-4;
    'transformer.core.hystF' = 1.4331021782802786 + 0.011178593500680808 * 'transformer.core.P2' - 'transformer.core.P3' * 1.6930237203043585 + 6.2831853106e-5 * 'transformer.core.Hstat' + 4.835e-4;
    'transformer.core.asc' = der('transformer.core.Hstat') > 0.0;
    der('transformer.core.B') = 'transformer.core.k' * 'transformer.core.dHyst' + 6.2831853106e-5 * der('transformer.core.Hstat');
    'transformer.core.diffHyst' = 'transformer.core.hystF' - 'transformer.core.hystR';

    if initial() then
      'transformer.core.k' = 0.01;
      'transformer.core.dHyst' = 0.0;
    elseif 'transformer.core.asc' then
      'transformer.core.dHyst' = der('transformer.core.hystR' - 6.2831853106e-5 * 'transformer.core.Hstat');
      'transformer.core.k' = max(0.01, ('transformer.core.hystF' - 'transformer.core.B') / 'transformer.core.diffHyst');
    elseif true then
      'transformer.core.dHyst' = der('transformer.core.hystF' - 6.2831853106e-5 * 'transformer.core.Hstat');
      'transformer.core.k' = max(0.01, ('transformer.core.B' - 'transformer.core.hystR') / 'transformer.core.diffHyst');
    end if;

    der('transformer.core.MagRel') = 0.0;
    'transformer.core.H' = 'transformer.core.Hstat' + 'transformer.core.Heddy';
    'transformer.core.H' = 'transformer.core.V_m' / 0.2;
    'transformer.core.Phi' = 'transformer.core.B' * 1.5e-4;
    'transformer.core.Heddy' = 0.0;
    'transformer.core.LossPowerStat' = 'transformer.core.Hstat' * der('transformer.core.B') * 2.9999999999999997e-5;
    'transformer.core.LossPowerEddy' = 'transformer.core.Heddy' * der('transformer.core.B') * 2.9999999999999997e-5;
    'transformer.core.LossPower' = 'transformer.core.LossPowerStat' + 'transformer.core.LossPowerEddy';
    'transformer.core.T_heatPort' = 293.15;
    0.0 = 'transformer.core.port_p.Phi' + 'transformer.core.port_n.Phi';
    'transformer.core.V_m' = 'transformer.core.port_p.V_m' - 'transformer.core.port_n.V_m';
    'transformer.core.Phi' = 'transformer.core.port_p.Phi';
    'transformer.v1' = 'transformer.p1.v' - 'transformer.n1.v';
    'transformer.i1' = 'transformer.resistor1.i';
    'transformer.R1' = 'transformer.resistor1.R_actual';
    'transformer.v2' = 'transformer.p2.v' - 'transformer.n2.v';
    'transformer.i2' = 'transformer.resistor2.i';
    'transformer.R2' = 'transformer.resistor2.R_actual';
    'transformer.B' = 'transformer.core.B';
    'transformer.Hstat' = 'transformer.core.Hstat';
    'transformer.Heddy' = 'transformer.core.Heddy';
    'transformer.H' = 'transformer.core.H';
    'transformer.tempSource.T' = 293.15;
    'transformer.LossPowerWinding' = 'transformer.resistor1.LossPower' + 'transformer.resistor2.LossPower';
    'transformer.LossPowerStat' = 'transformer.core.LossPowerStat';
    'transformer.LossPowerEddy' = 'transformer.core.LossPowerEddy';
    'transformer.LossPower' = 'transformer.LossPowerWinding' + 'transformer.LossPowerEddy' + 'transformer.LossPowerStat';
    'transformer.T_heatPort' = 293.15;
    annotation(experiment(StartTime = 0, StopTime = 0.1, Interval = 2e-5, Tolerance = 1e-004));
  end 'SinglePhaseTransformerWithHysteresis2';
end 'SinglePhaseTransformerWithHysteresis2';
