//! base 0.1.0
package 'ThreeTanks'
  function '$OMC$PositiveMax'
    input Real 'flowValue';
    input Real 'eps';
    output Real 'positiveMax';
  algorithm
    'positiveMax' := max('flowValue', 'eps');
  end '$OMC$PositiveMax';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.Medium.density' "Return density"
    input 'pipe1.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.Medium.density';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.Medium.setState_phX' "Return thermodynamic state from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe1.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe1.Medium.ThermodynamicState'('p', 273.15 + 'h' / 4184.0);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.Medium.density' "Return density"
    input 'pipe1.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.Medium.dynamicViscosity' "Return dynamic viscosity"
    input 'pipe1.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'eta'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
  algorithm
    'eta' := 0.001;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.Medium.dynamicViscosity';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.Medium.pressure' "Return pressure"
    input 'pipe1.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / log10('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'lambda2';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'dRe_ddp';
    Real 'aux1';
    Real 'aux2';
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'lambda2' := abs('dp_fric') * 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' * 'mu') "Known as lambda2=f(dp)";
    'aux1' := 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' ^ 2.0);
    'Re' := 'lambda2' / 64.0 "Hagen-Poiseuille";
    'dRe_ddp' := 'aux1' / 64.0 "Hagen-Poiseuille";

    if 'Re' > 'Re1' then
      'Re' := -2.0 * sqrt('lambda2') * log10(2.51 / sqrt('lambda2') + 0.27 * 'Delta') "Colebrook-White";
      'aux2' := sqrt('aux1' * abs('dp_fric'));
      'dRe_ddp' := 0.43429448190325176 * (5.02 / (2.0 * abs('dp_fric') * (2.51 / 'aux2' + 0.27 * 'Delta')) - 2.0 * log(2.51 / 'aux2' + 0.27 * 'Delta') * 'aux1' / (2.0 * 'aux2'));

      if 'Re' < 'Re2' then
        ('Re', 'dRe_ddp') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative'('lambda2', 'Re1', 'Re2', 'Delta', 'dp_fric');
      end if;
    end if;

    'm_flow' := 'crossArea' / 'diameter' * 'mu' * (if 'dp_fric' >= 0.0 then 'Re' else -'Re');
    'dm_flow_ddp_fric' := 'crossArea' / 'diameter' * 'mu' * 'dRe_ddp';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative' "Interpolation in log-log space using a cubic Hermite polynomial, where x=log10(lambda2), y=log10(Re)"
    input Real 'lambda2';
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    output Real 'dRe_ddp';
    Real 'x1' = log10(64.0 * 'Re1');
    Real 'y1' = log10('Re1');
    Real 'y1d' = 1.0;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x' = log10('lambda2');
    Real 'y';
    Real 'dy_dx';
    Real 'aux3' = log10('aux2');
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'x2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'y2' = log10('aux5');
    Real 'y2d' = 0.5 + 1.0900791495771618 / ('aux5' * 'aux4');
  algorithm
    ('y', 'dy_dx') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('x', 'x1', 'x2', 'y1', 'y2', 'y1d', 'y2d');
    'Re' := 10.0 ^ 'y';
    'dRe_ddp' := 'Re' / abs('dp_fric') * 'dy_dx';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2' "Cubic Hermite spline interpolation in transition region"
    input Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta';
    output Real 'lambda2';
    Real 'x1' = log10('Re1');
    Real 'y1' = log10(64.0 * 'Re1');
    Real 'yd1' = 1.0;
    Real 'aux1' = 1.1217826467560994;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x2' = log10('Re2');
    Real 'dx' = log10('Re' / 'Re1');
    Real 'aux3' = log10('aux2');
    Real 'diff_x' = 'x2' - 'x1';
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'yd2' = 2.0 + 4.0 * 'aux1' / ('aux2' * 'aux3' * 'Re2' ^ 0.9);
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'y2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'm' = ('y2' - 'y1') / 'diff_x';
    Real 'c2' = (3.0 * 'm' - 2.0 * 'yd1' - 'yd2') / 'diff_x';
    Real 'c3' = ('yd1' + 'yd2' - 2.0 * 'm') / ('diff_x' * 'diff_x');
  algorithm
    'lambda2' := 64.0 * 'Re1' * ('Re' / 'Re1') ^ ('yd1' + 'dx' * ('c2' + 'dx' * 'c3'));
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe1.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.Medium.density' "Return density"
    input 'pipe2.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.Medium.density';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.Medium.setState_phX' "Return thermodynamic state from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe2.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe2.Medium.ThermodynamicState'('p', 273.15 + 'h' / 4184.0);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.Medium.density' "Return density"
    input 'pipe2.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.Medium.dynamicViscosity' "Return dynamic viscosity"
    input 'pipe2.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'eta'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
  algorithm
    'eta' := 0.001;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.Medium.dynamicViscosity';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.Medium.pressure' "Return pressure"
    input 'pipe2.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / log10('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'lambda2';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'dRe_ddp';
    Real 'aux1';
    Real 'aux2';
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'lambda2' := abs('dp_fric') * 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' * 'mu') "Known as lambda2=f(dp)";
    'aux1' := 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' ^ 2.0);
    'Re' := 'lambda2' / 64.0 "Hagen-Poiseuille";
    'dRe_ddp' := 'aux1' / 64.0 "Hagen-Poiseuille";

    if 'Re' > 'Re1' then
      'Re' := -2.0 * sqrt('lambda2') * log10(2.51 / sqrt('lambda2') + 0.27 * 'Delta') "Colebrook-White";
      'aux2' := sqrt('aux1' * abs('dp_fric'));
      'dRe_ddp' := 0.43429448190325176 * (5.02 / (2.0 * abs('dp_fric') * (2.51 / 'aux2' + 0.27 * 'Delta')) - 2.0 * log(2.51 / 'aux2' + 0.27 * 'Delta') * 'aux1' / (2.0 * 'aux2'));

      if 'Re' < 'Re2' then
        ('Re', 'dRe_ddp') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative'('lambda2', 'Re1', 'Re2', 'Delta', 'dp_fric');
      end if;
    end if;

    'm_flow' := 'crossArea' / 'diameter' * 'mu' * (if 'dp_fric' >= 0.0 then 'Re' else -'Re');
    'dm_flow_ddp_fric' := 'crossArea' / 'diameter' * 'mu' * 'dRe_ddp';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative' "Interpolation in log-log space using a cubic Hermite polynomial, where x=log10(lambda2), y=log10(Re)"
    input Real 'lambda2';
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    output Real 'dRe_ddp';
    Real 'x1' = log10(64.0 * 'Re1');
    Real 'y1' = log10('Re1');
    Real 'y1d' = 1.0;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x' = log10('lambda2');
    Real 'y';
    Real 'dy_dx';
    Real 'aux3' = log10('aux2');
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'x2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'y2' = log10('aux5');
    Real 'y2d' = 0.5 + 1.0900791495771618 / ('aux5' * 'aux4');
  algorithm
    ('y', 'dy_dx') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('x', 'x1', 'x2', 'y1', 'y2', 'y1d', 'y2d');
    'Re' := 10.0 ^ 'y';
    'dRe_ddp' := 'Re' / abs('dp_fric') * 'dy_dx';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2' "Cubic Hermite spline interpolation in transition region"
    input Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta';
    output Real 'lambda2';
    Real 'x1' = log10('Re1');
    Real 'y1' = log10(64.0 * 'Re1');
    Real 'yd1' = 1.0;
    Real 'aux1' = 1.1217826467560994;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x2' = log10('Re2');
    Real 'dx' = log10('Re' / 'Re1');
    Real 'aux3' = log10('aux2');
    Real 'diff_x' = 'x2' - 'x1';
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'yd2' = 2.0 + 4.0 * 'aux1' / ('aux2' * 'aux3' * 'Re2' ^ 0.9);
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'y2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'm' = ('y2' - 'y1') / 'diff_x';
    Real 'c2' = (3.0 * 'm' - 2.0 * 'yd1' - 'yd2') / 'diff_x';
    Real 'c3' = ('yd1' + 'yd2' - 2.0 * 'm') / ('diff_x' * 'diff_x');
  algorithm
    'lambda2' := 64.0 * 'Re1' * ('Re' / 'Re1') ^ ('yd1' + 'dx' * ('c2' + 'dx' * 'c3'));
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.Medium.density' "Return density"
    input 'pipe3.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.Medium.density';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.Medium.setState_phX' "Return thermodynamic state from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'pipe3.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'pipe3.Medium.ThermodynamicState'('p', 273.15 + 'h' / 4184.0);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.Medium.density' "Return density"
    input 'pipe3.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.Medium.dynamicViscosity' "Return dynamic viscosity"
    input 'pipe3.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'eta'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
  algorithm
    'eta' := 0.001;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.Medium.dynamicViscosity';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.Medium.pressure' "Return pressure"
    input 'pipe3.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / log10('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'lambda2';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'dRe_ddp';
    Real 'aux1';
    Real 'aux2';
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'lambda2' := abs('dp_fric') * 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' * 'mu') "Known as lambda2=f(dp)";
    'aux1' := 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' ^ 2.0);
    'Re' := 'lambda2' / 64.0 "Hagen-Poiseuille";
    'dRe_ddp' := 'aux1' / 64.0 "Hagen-Poiseuille";

    if 'Re' > 'Re1' then
      'Re' := -2.0 * sqrt('lambda2') * log10(2.51 / sqrt('lambda2') + 0.27 * 'Delta') "Colebrook-White";
      'aux2' := sqrt('aux1' * abs('dp_fric'));
      'dRe_ddp' := 0.43429448190325176 * (5.02 / (2.0 * abs('dp_fric') * (2.51 / 'aux2' + 0.27 * 'Delta')) - 2.0 * log(2.51 / 'aux2' + 0.27 * 'Delta') * 'aux1' / (2.0 * 'aux2'));

      if 'Re' < 'Re2' then
        ('Re', 'dRe_ddp') := 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative'('lambda2', 'Re1', 'Re2', 'Delta', 'dp_fric');
      end if;
    end if;

    'm_flow' := 'crossArea' / 'diameter' * 'mu' * (if 'dp_fric' >= 0.0 then 'Re' else -'Re');
    'dm_flow_ddp_fric' := 'crossArea' / 'diameter' * 'mu' * 'dRe_ddp';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative' "Interpolation in log-log space using a cubic Hermite polynomial, where x=log10(lambda2), y=log10(Re)"
    input Real 'lambda2';
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    output Real 'dRe_ddp';
    Real 'x1' = log10(64.0 * 'Re1');
    Real 'y1' = log10('Re1');
    Real 'y1d' = 1.0;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x' = log10('lambda2');
    Real 'y';
    Real 'dy_dx';
    Real 'aux3' = log10('aux2');
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'x2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'y2' = log10('aux5');
    Real 'y2d' = 0.5 + 1.0900791495771618 / ('aux5' * 'aux4');
  algorithm
    ('y', 'dy_dx') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('x', 'x1', 'x2', 'y1', 'y2', 'y1d', 'y2d');
    'Re' := 10.0 ^ 'y';
    'dRe_ddp' := 'Re' / abs('dp_fric') * 'dy_dx';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2' "Cubic Hermite spline interpolation in transition region"
    input Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta';
    output Real 'lambda2';
    Real 'x1' = log10('Re1');
    Real 'y1' = log10(64.0 * 'Re1');
    Real 'yd1' = 1.0;
    Real 'aux1' = 1.1217826467560994;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x2' = log10('Re2');
    Real 'dx' = log10('Re' / 'Re1');
    Real 'aux3' = log10('aux2');
    Real 'diff_x' = 'x2' - 'x1';
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'yd2' = 2.0 + 4.0 * 'aux1' / ('aux2' * 'aux3' * 'Re2' ^ 0.9);
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'y2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'm' = ('y2' - 'y1') / 'diff_x';
    Real 'c2' = (3.0 * 'm' - 2.0 * 'yd1' - 'yd2') / 'diff_x';
    Real 'c3' = ('yd1' + 'yd2' - 2.0 * 'm') / ('diff_x' * 'diff_x');
  algorithm
    'lambda2' := 64.0 * 'Re1' * ('Re' / 'Re1') ^ ('yd1' + 'dx' * ('c2' + 'dx' * 'c3'));
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.density' "Return density"
    input 'tank1.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 995.586;
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.density';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.setState_phX' "Return thermodynamic state from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {1.0};
    output 'tank1.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := 'tank1.Medium.ThermodynamicState'('p', 273.15 + 'h' / 4184.0);
  end 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
