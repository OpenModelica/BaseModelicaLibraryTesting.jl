    parameter Real 'pipe2.flowModel.dp_small'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Within regularization if |dp| < dp_small (may be wider for large discontinuities in static head)";
    parameter Boolean 'pipe2.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'pipe2.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'pipe2.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'pipe2.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe2.flowModel.WallFriction.pressureLoss_m_flow'('pipe2.flowModel.m_flow_nominal', 995.586, 995.586, 0.001, 0.001, 'pipe2.flowModel.pathLengths_internal[1]', 'pipe2.flowModel.diameters[1]', ('pipe2.flowModel.crossAreas[1]' + 'pipe2.flowModel.crossAreas[2]') / 2.0, ('pipe2.flowModel.roughnesses[1]' + 'pipe2.flowModel.roughnesses[2]') / 2.0, 'pipe2.flowModel.m_flow_small', 'pipe2.flowModel.Res_turbulent_internal[1]') "Pressure loss for nominal conditions";
    parameter Boolean 'pipe3.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'pipe3.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'pipe3.port_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe3.port_a.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'pipe3.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'pipe3.port_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe3.port_b.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'pipe3.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'pipe3.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'pipe3.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'pipe3.nParallel'(min = 1.0) = 1.0 "Number of identical parallel pipes";
    parameter Real 'pipe3.length'(unit = "m", quantity = "Length") = 2.0 "Length";
    parameter Boolean 'pipe3.isCircular' = true "= true, if cross sectional area is circular" annotation(Evaluate = true);
    parameter Real 'pipe3.diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Diameter of circular pipe";
    parameter Real 'pipe3.crossArea'(unit = "m2", quantity = "Area") = 0.007853981633974483 "Inner cross section area";
    parameter Real 'pipe3.perimeter'(min = 0.0, unit = "m", quantity = "Length") = 0.3141592653589793 "Inner perimeter";
    parameter Real 'pipe3.roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average height of surface asperities (default: smooth steel pipe)";
    parameter Real 'pipe3.V'(unit = "m3", quantity = "Volume") = 0.015707963267948967 "Volume size";
    parameter Real 'pipe3.height_ab'(unit = "m", quantity = "Length") = -1.0 "Height(port_b) - Height(port_a)";
    parameter Real 'pipe3.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port a";
    parameter Real 'pipe3.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port b";
    parameter Real 'pipe3.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 0.0 "Start value for mass flow rate" annotation(Evaluate = true);
    parameter Boolean 'pipe3.flowModel.from_dp' = true "= true, use m_flow = f(dp), otherwise dp = f(m_flow)" annotation(Evaluate = true);
    parameter Integer 'pipe3.flowModel.n' = 2 "Number of discrete flow volumes";
    Real 'pipe3.flowModel.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe3.flowModel.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe3.flowModel.states[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe3.flowModel.states[2].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe3.flowModel.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    Real 'pipe3.flowModel.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    parameter Real 'pipe3.flowModel.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'pipe3.flowModel.crossAreas[1]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe3.flowModel.crossAreas[2]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe3.flowModel.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe3.flowModel.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe3.flowModel.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe3.flowModel.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe3.flowModel.dheights[1]'(unit = "m", quantity = "Length") "Height(states[2:n]) - Height(states[1:n-1])";
    parameter Real 'pipe3.flowModel.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'pipe3.flowModel.allowFlowReversal' = true "= true, if flow reversal is enabled, otherwise restrict flow to design direction (states[1] -> states[n+1])" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe3.flowModel.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance" annotation(Evaluate = true);
    parameter Real 'pipe3.flowModel.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 0.0 "Start value of mass flow rates";
    parameter Real 'pipe3.flowModel.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[1] at design inflow";
    parameter Real 'pipe3.flowModel.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[n+1] at design outflow";
    parameter Integer 'pipe3.flowModel.m' = 1 "Number of flow segments";
    Real 'pipe3.flowModel.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe3.flowModel.m_flows[1]'(stateSelect = StateSelect.default, start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rates between states";
    Real 'pipe3.flowModel.Is[1]'(unit = "kg.m/s", quantity = "Momentum") "Momenta of flow segments";
    Real 'pipe3.flowModel.Ib_flows[1]'(unit = "N", quantity = "Force") "Flow of momentum across boundaries";
    Real 'pipe3.flowModel.Fs_p[1]'(unit = "N", quantity = "Force") "Pressure forces";
    Real 'pipe3.flowModel.Fs_fg[1]'(unit = "N", quantity = "Force") "Friction and gravity forces";
    parameter Boolean 'pipe3.flowModel.useUpstreamScheme' = true "= false to average upstream and downstream properties across flow segments" annotation(Evaluate = true);
    parameter Boolean 'pipe3.flowModel.use_Ib_flows' = false "= true to consider differences in flow of momentum through boundaries" annotation(Evaluate = true);
    Real 'pipe3.flowModel.rhos[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe3.flowModel.rhos[2]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe3.flowModel.rhos_act[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
    Real 'pipe3.flowModel.mus[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe3.flowModel.mus[2]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe3.flowModel.mus_act[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") "Actual viscosity per segment";
    Real 'pipe3.flowModel.dps_fg[1]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    parameter Real 'pipe3.flowModel.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0 "Start of turbulent regime, depending on type of flow device";
    parameter Boolean 'pipe3.flowModel.show_Res' = false "= true, if Reynolds numbers are included for plotting" annotation(Evaluate = true);
    parameter Boolean 'pipe3.flowModel.use_rho_nominal' = false "= true, if rho_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe3.flowModel.rho_nominal'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.586 "Nominal density (e.g., rho_liquidWater = 995, rho_air = 1.2)";
    parameter Boolean 'pipe3.flowModel.use_mu_nominal' = false "= true, if mu_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe3.flowModel.mu_nominal'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") = 0.001 "Nominal dynamic viscosity (e.g., mu_liquidWater = 1e-3, mu_air = 1.8e-5)";
    Real 'pipe3.flowModel.pathLengths_internal[1]'(unit = "m", quantity = "Length") "pathLengths used internally; to be defined by extending class";
    Real 'pipe3.flowModel.Res_turbulent_internal[1]'(unit = "1", quantity = "ReynoldsNumber") "Re_turbulent used internally; to be defined by extending class";
    parameter Real 'pipe3.flowModel.dp_nominal'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Nominal pressure loss (only for nominal models)";
    parameter Real 'pipe3.flowModel.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 100.0 * 'pipe3.flowModel.m_flow_small' "Nominal mass flow rate";
    parameter Real 'pipe3.flowModel.m_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Within regularization if |m_flows| < m_flow_small (may be wider for large discontinuities in static head)";
    parameter Real 'pipe3.flowModel.dp_small'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Within regularization if |dp| < dp_small (may be wider for large discontinuities in static head)";
    parameter Boolean 'pipe3.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'pipe3.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'pipe3.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'pipe3.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'Modelica.Fluid.Examples.Tanks.ThreeTanks.pipe3.flowModel.WallFriction.pressureLoss_m_flow'('pipe3.flowModel.m_flow_nominal', 995.586, 995.586, 0.001, 0.001, 'pipe3.flowModel.pathLengths_internal[1]', 'pipe3.flowModel.diameters[1]', ('pipe3.flowModel.crossAreas[1]' + 'pipe3.flowModel.crossAreas[2]') / 2.0, ('pipe3.flowModel.roughnesses[1]' + 'pipe3.flowModel.roughnesses[2]') / 2.0, 'pipe3.flowModel.m_flow_small', 'pipe3.flowModel.Res_turbulent_internal[1]') "Pressure loss for nominal conditions";
  initial equation
    'tank1.level' = 8.0;
    'tank1.medium.T' = 'tank1.T_start';
    'tank2.level' = 3.0;
    'tank2.medium.T' = 'tank2.T_start';
    'tank3.level' = 3.0;
    'tank3.medium.T' = 'tank3.T_start';
    'pipe1.flowModel.dp_nominal' = 1000.0 * 'pipe1.flowModel.dp_small';
    'pipe1.flowModel.dp_small' = 1.0;
    'pipe2.flowModel.dp_nominal' = 1000.0 * 'pipe2.flowModel.dp_small';
    'pipe2.flowModel.dp_small' = 1.0;
    'pipe3.flowModel.dp_nominal' = 1000.0 * 'pipe3.flowModel.dp_small';
    'pipe3.flowModel.dp_small' = 1.0;
  equation
    'tank1.portsData_diameter[1]' = 'tank1.portsData_diameter_internal[1]';
    'tank1.portsData_height[1]' = 'tank1.portsData_height_internal[1]';
    'tank1.portsData_zeta_in[1]' = 'tank1.portsData_zeta_in_internal[1]';
    'tank1.portsData_zeta_out[1]' = 'tank1.portsData_zeta_out_internal[1]';
    'tank2.portsData_diameter[1]' = 'tank2.portsData_diameter_internal[1]';
    'tank2.portsData_height[1]' = 'tank2.portsData_height_internal[1]';
    'tank2.portsData_zeta_in[1]' = 'tank2.portsData_zeta_in_internal[1]';
    'tank2.portsData_zeta_out[1]' = 'tank2.portsData_zeta_out_internal[1]';
    'tank3.portsData_diameter[1]' = 'tank3.portsData_diameter_internal[1]';
    'tank3.portsData_height[1]' = 'tank3.portsData_height_internal[1]';
    'tank3.portsData_zeta_in[1]' = 'tank3.portsData_zeta_in_internal[1]';
    'tank3.portsData_zeta_out[1]' = 'tank3.portsData_zeta_out_internal[1]';
    'pipe2.port_a.p' = 'pipe3.port_a.p';
    'pipe2.port_a.p' = 'pipe1.port_a.p';
    'pipe3.port_b.p' = 'tank3.ports[1].p';
    'pipe1.port_b.p' = 'tank1.ports[1].p';
    'pipe2.port_b.p' = 'tank2.ports[1].p';
    'tank1.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'tank2.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'tank3.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'pipe3.port_a.m_flow' + 'pipe2.port_a.m_flow' + 'pipe1.port_a.m_flow' = 0.0;
    'pipe1.port_b.m_flow' + 'tank1.ports[1].m_flow' = 0.0;
    'pipe2.port_b.m_flow' + 'tank2.ports[1].m_flow' = 0.0;
    'pipe3.port_b.m_flow' + 'tank3.ports[1].m_flow' = 0.0;
    assert('tank1.medium.T' >= 272.15 and 'tank1.medium.T' <= 403.15, "\nTemperature T (= " + String('tank1.medium.T') + " K) is not\nin the allowed range (" + String(272.15) + " K <= T <= " + String(403.15) + " K)\nrequired from medium model \"" + "SimpleLiquidWater" + "\".\n", AssertionLevel.error);
    'tank1.medium.h' = 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.specificEnthalpy_pTX'('tank1.medium.p', 'tank1.medium.T', {'tank1.medium.X[1]'});
    'tank1.medium.u' = 4184.0 * ('tank1.medium.T' - 273.15);
    'tank1.medium.d' = 995.586;
    'tank1.medium.R_s' = 0.0;
    'tank1.medium.MM' = 0.018015268;
    'tank1.medium.state.T' = 'tank1.medium.T';
    'tank1.medium.state.p' = 'tank1.medium.p';
    'tank1.medium.X[1]' = 1.0;
    assert('tank1.medium.X[1]' >= (-1e-5) and 'tank1.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('tank1.medium.X[1]') + "of substance " + "SimpleLiquidWater" + "\nof medium " + "SimpleLiquidWater" + " is not in the range 0..1", AssertionLevel.error);
    assert('tank1.medium.p' >= 0.0, "Pressure (= " + String('tank1.medium.p') + " Pa) of medium \"" + "SimpleLiquidWater" + "\" is negative\n(Temperature = " + String('tank1.medium.T') + " K)", AssertionLevel.error);
    'tank1.heatTransfer.surfaceAreas[1]' = 1.0 + 3.5449077018110318 * 'tank1.level';
    'tank1.heatTransfer.Ts[1]' = 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.heatTransfer.Medium.temperature'('tank1.heatTransfer.states[1]');
    'tank1.heatTransfer.Ts[1]' = 'tank1.heatTransfer.heatPorts[1].T';
    'tank1.heatTransfer.Q_flows[1]' = 'tank1.heatTransfer.heatPorts[1].Q_flow';
    'tank1.portAreas[1]' = 0.7853981633974483 * 'tank1.portsData_diameter[1]' ^ 2.0;
    'tank1.portsData_diameter_internal[1]' = 'tank1.portsData[1].diameter';
    'tank1.portsData_height_internal[1]' = 'tank1.portsData[1].height';
    'tank1.portsData_zeta_in_internal[1]' = 'tank1.portsData[1].zeta_in';
    'tank1.portsData_zeta_out_internal[1]' = 'tank1.portsData[1].zeta_out';
    'tank1.V' = 'tank1.level' "Volume of fluid";
    'tank1.medium.p' = 101325.0;
    'tank1.Wb_flow' = 0.0 "Mechanical work is neglected, since also neglected in medium model (otherwise unphysical small temperature change, if tank level changes)";
    'tank1.vessel_ps_static[1]' = max(0.0, 'tank1.level' - 'tank1.portsData_height[1]') * 9.80665 * 'tank1.medium.d' + 101325.0;
    assert('tank1.level' > 0.0, "Fluid level is too low; the energy balance equation becomes singular when the tank is completely empty.", AssertionLevel.error);
    'tank1.mb_flow' = 'tank1.ports[1].m_flow';
    'tank1.Hb_flow' = 'tank1.ports_H_flow[1]' + 'tank1.ports_E_flow[1]';
    'tank1.Qb_flow' = 'tank1.heatTransfer.Q_flows[1]';
    assert('tank1.fluidLevel' <= 12.0, "Vessel is overflowing (fluidLevel > fluidLevel_max = " + String('tank1.fluidLevel') + ")", AssertionLevel.error);
    'tank1.portInDensities[1]' = 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.density'('Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.setState_phX'('tank1.vessel_ps_static[1]', 'pipe1.port_b.h_outflow', fill(0.0, 0)));
    'tank1.portVelocities[1]' = smooth(0, 'tank1.ports[1].m_flow' / 'tank1.portAreas[1]' / 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.density'('Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.setState_phX'('tank1.vessel_ps_static[1]', if 'tank1.ports[1].m_flow' > 0.0 then 'pipe1.port_b.h_outflow' else 'tank1.ports[1].h_outflow', fill(0.0, 0))));
    'tank1.ports_penetration[1]' = 'Modelica.Fluid.Utilities.regStep'('tank1.fluidLevel' - 'tank1.portsData_height[1]' - 0.1 * 'tank1.portsData_diameter[1]', 1.0, 0.001, 0.1 * 'tank1.portsData_diameter[1]');
    'tank1.m_flow_turbulent[1]' = 0.01;
    'tank1.regularFlow[1]' = 'tank1.fluidLevel' >= 'tank1.portsData_height[1]';
    'tank1.inFlow[1]' = not 'tank1.regularFlow[1]' and ('tank1.s[1]' > 0.0 or 'tank1.portsData_height[1]' >= 12.0);

    if 'tank1.regularFlow[1]' then
      'tank1.ports[1].p' = 'tank1.vessel_ps_static[1]' + 0.5 / 'tank1.portAreas[1]' ^ 2.0 * 'Modelica.Fluid.Utilities.regSquare2'('tank1.ports[1].m_flow', 'tank1.m_flow_turbulent[1]', ('tank1.portsData_zeta_in[1]' - 1.0 + 'tank1.portAreas[1]' ^ 2.0) / 'tank1.portInDensities[1]' * 'tank1.ports_penetration[1]', ('tank1.portsData_zeta_out[1]' + 1.0 - 'tank1.portAreas[1]' ^ 2.0) / 'tank1.medium.d' / 'tank1.ports_penetration[1]', false, 1.0);
      'tank1.s[1]' = 'tank1.fluidLevel' - 'tank1.portsData_height[1]';
    elseif 'tank1.inFlow[1]' then
      'tank1.ports[1].p' = 'tank1.vessel_ps_static[1]';
      'tank1.s[1]' = 'tank1.ports[1].m_flow';
    elseif true then
      'tank1.ports[1].m_flow' = 0.0;
      'tank1.s[1]' = ('tank1.ports[1].p' - 'tank1.vessel_ps_static[1]') / 101325.0 * ('tank1.portsData_height[1]' - 'tank1.fluidLevel');
    end if;

    'tank1.ports[1].h_outflow' = 'tank1.medium.h';
    'tank1.ports_H_flow[1]' = smooth(0, 'tank1.ports[1].m_flow' * (if 'tank1.ports[1].m_flow' > 0.0 then 'pipe1.port_b.h_outflow' else 'tank1.ports[1].h_outflow')) "Enthalpy flow";
    'tank1.ports_E_flow[1]' = 'tank1.ports[1].m_flow' * (0.5 * 'tank1.portVelocities[1]' * 'tank1.portVelocities[1]' + 9.80665 * 'tank1.portsData_height[1]') "Flow of kinetic and potential energy";
    'tank1.m' = 'tank1.fluidVolume' * 'tank1.medium.d';
    'tank1.U' = 'tank1.m' * 'tank1.medium.u';
    der('tank1.U') = 'tank1.Hb_flow' + 'tank1.Qb_flow' + 'tank1.Wb_flow';
