  model 'ThreeTanks' "Demonstrating the usage of SimpleTank"
    Real 'tank1.level'(stateSelect = StateSelect.prefer, start = 8.0, min = 0.0, unit = "m", quantity = "Length") "Level height of tank";
    Real 'tank1.V'(stateSelect = StateSelect.never, unit = "m3", quantity = "Volume") "Actual tank volume";
    parameter Real 'tank1.height'(min = 0.0, unit = "m", quantity = "Length") = 12.0 "Height of tank";
    parameter Real 'tank1.crossArea'(unit = "m2", quantity = "Area") = 1.0 "Area of tank";
    parameter Real 'tank1.p_ambient'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Tank surface pressure";
    parameter Real 'tank1.T_ambient'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Tank surface Temperature";
    parameter Real 'tank1.level_start'(min = 0.0, unit = "m", quantity = "Length") = 8.0 "Start value of tank level";
    Real 'tank1.fluidVolume'(unit = "m3", quantity = "Volume") = 'tank1.V' "Volume";
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank1.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank1.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank1.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of substance balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank1.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of trace substance balance" annotation(Evaluate = true);
    parameter Real 'tank1.p_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Boolean 'tank1.use_T_start' = true "= true, use T_start, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'tank1.T_start'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Start value of temperature";
    parameter Real 'tank1.h_start'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Fluid.Examples.Tanks.ThreeTanks.tank1.Medium.specificEnthalpy_pTX'(101325.0, 'tank1.T_start', {1.0}) "Start value of specific enthalpy";
    parameter Real 'tank1.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    Real 'tank1.medium.p'(stateSelect = StateSelect.prefer, nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank1.medium.h'(start = 'tank1.h_start', unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'tank1.medium.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'tank1.medium.T'(stateSelect = StateSelect.prefer, nominal = 300.0, start = 'tank1.T_start', max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'tank1.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'tank1.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'tank1.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'tank1.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'tank1.medium.state.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank1.medium.state.T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    parameter Boolean 'tank1.medium.preferredMediumStates' = true "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'tank1.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'tank1.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") = 'tank1.medium.T' - 273.15 "Temperature of medium in [degC]";
    Real 'tank1.medium.p_bar'(unit = "bar", quantity = "Pressure") = 'tank1.medium.p' / 1e5 "Absolute pressure of medium in [bar]";
    Real 'tank1.U'(unit = "J", quantity = "Energy") "Internal energy of fluid";
    Real 'tank1.m'(min = 0.0, unit = "kg", quantity = "Mass") "Mass of fluid";
    Real 'tank1.mb_flow'(unit = "kg/s", quantity = "MassFlowRate") "Mass flows across boundaries";
    Real 'tank1.Hb_flow'(unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow across boundaries or energy source/sink";
    Real 'tank1.Qb_flow'(unit = "W", quantity = "Power") "Heat flow across boundaries or energy source/sink";
    Real 'tank1.Wb_flow'(unit = "W", quantity = "Power") "Work flow across boundaries or source term";
    parameter Boolean 'tank1.initialize_p' = false "= true to set up initial equations for pressure";
    parameter Integer 'tank1.nPorts' = 1 "Number of ports" annotation(Evaluate = true);
    Real 'tank1.ports[1].m_flow'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'tank1.ports[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'tank1.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'tank1.use_portsData' = true "= false to neglect pressure loss and kinetic energy" annotation(Evaluate = true);
    parameter Real 'tank1.portsData[1].diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Inner (hydraulic) diameter of inlet/outlet port";
    parameter Real 'tank1.portsData[1].height'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Height over the bottom of the vessel";
    parameter Real 'tank1.portsData[1].zeta_out'(min = 0.0) = 0.5 "Hydraulic resistance out of vessel, default 0.5 for small diameter mounted flush with the wall";
    parameter Real 'tank1.portsData[1].zeta_in'(min = 0.0) = 1.04 "Hydraulic resistance into vessel, default 1.04 for small diameter mounted flush with the wall";
    parameter Real 'tank1.m_flow_nominal'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 1.0 "Nominal value for mass flow rates in ports";
    parameter Real 'tank1.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Regularization range at zero mass flow rate";
    parameter Boolean 'tank1.use_Re' = false "= true, if turbulent region is defined by Re, otherwise by m_flow_small" annotation(Evaluate = true);
    Real 'tank1.ports_H_flow[1]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate");
    parameter Boolean 'tank1.use_HeatTransfer' = false "= true to use the HeatTransfer model";
    parameter Integer 'tank1.heatTransfer.n' = 1 "Number of heat transfer segments" annotation(Evaluate = true);
    Real 'tank1.heatTransfer.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'tank1.medium.state.p' "Absolute pressure of medium";
    Real 'tank1.heatTransfer.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 'tank1.medium.state.T' "Temperature of medium";
    Real 'tank1.heatTransfer.surfaceAreas[1]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'tank1.heatTransfer.Q_flows[1]'(unit = "W", quantity = "Power") "Heat flow rates";
    parameter Boolean 'tank1.heatTransfer.use_k' = false "= true to use k value for thermal isolation";
    parameter Real 'tank1.heatTransfer.k'(unit = "W/(m2.K)", quantity = "CoefficientOfHeatTransfer") = 0.0 "Heat transfer coefficient to ambient" annotation(Evaluate = true);
    parameter Real 'tank1.heatTransfer.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'tank1.heatTransfer.heatPorts[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'tank1.heatTransfer.heatPorts[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'tank1.heatTransfer.Ts[1]'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    Real 'tank1.portInDensities[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Densities of the fluid at the device boundary";
    Real 'tank1.portVelocities[1]'(unit = "m/s", quantity = "Velocity") "Velocities of fluid flow at device boundary";
    Real 'tank1.ports_E_flow[1]'(unit = "W", quantity = "Power") "Flow of kinetic and potential energy at device boundary";
    Real 'tank1.s[1]'(start = 12.0) "Curve parameters for port flows vs. port pressures; for further details see, Modelica Tutorial: Ideal switching devices";
    Real 'tank1.ports_penetration[1]' "Penetration of port with fluid, depending on fluid level and port diameter";
    Real 'tank1.portAreas[1]'(unit = "m2", quantity = "Area");
    Real 'tank1.vessel_ps_static[1]'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Static pressures inside the vessel at the height of the corresponding ports, zero flow velocity";
    constant Real 'tank1.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 100.0 "cf. suddenExpansion";
    Real 'tank1.m_flow_turbulent[1]'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'tank1.fluidLevel'(min = 0.0, unit = "m", quantity = "Length") = 'tank1.level' "Level of fluid in the vessel for treating heights of ports";
    parameter Real 'tank1.fluidLevel_max'(min = 0.0, unit = "m", quantity = "Length") = 12.0 "Maximum level of fluid in the vessel";
    parameter Real 'tank1.vesselArea'(unit = "m2", quantity = "Area") = 1.0 "Area of the vessel used to relate to cross flow area of ports";
    Real 'tank1.portsData_diameter_internal[1]';
    Real 'tank1.portsData_height_internal[1]';
    Real 'tank1.portsData_zeta_in_internal[1]';
    Real 'tank1.portsData_zeta_out_internal[1]';
    Real 'tank1.portsData_diameter[1]';
    Real 'tank1.portsData_height[1]';
    Real 'tank1.portsData_zeta_in[1]';
    Real 'tank1.portsData_zeta_out[1]';
    Boolean 'tank1.regularFlow[1]'(start = true);
    Boolean 'tank1.inFlow[1]'(start = false);
    parameter Real 'tank1.level_start_eps'(min = 0.0, unit = "m", quantity = "Length") = 8.0;
    Real 'tank2.level'(stateSelect = StateSelect.prefer, start = 3.0, min = 0.0, unit = "m", quantity = "Length") "Level height of tank";
    Real 'tank2.V'(stateSelect = StateSelect.never, unit = "m3", quantity = "Volume") "Actual tank volume";
    parameter Real 'tank2.height'(min = 0.0, unit = "m", quantity = "Length") = 12.0 "Height of tank";
    parameter Real 'tank2.crossArea'(unit = "m2", quantity = "Area") = 1.0 "Area of tank";
    parameter Real 'tank2.p_ambient'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Tank surface pressure";
    parameter Real 'tank2.T_ambient'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Tank surface Temperature";
    parameter Real 'tank2.level_start'(min = 0.0, unit = "m", quantity = "Length") = 3.0 "Start value of tank level";
    Real 'tank2.fluidVolume'(unit = "m3", quantity = "Volume") = 'tank2.V' "Volume";
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank2.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank2.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank2.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of substance balance" annotation(Evaluate = true);
