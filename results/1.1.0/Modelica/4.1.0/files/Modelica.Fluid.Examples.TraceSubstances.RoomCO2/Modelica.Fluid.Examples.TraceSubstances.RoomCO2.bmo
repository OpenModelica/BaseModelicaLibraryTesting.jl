    'pipe.flowModel.Ib_flows[1]' = 0.0;
    'pipe.flowModel.Fs_p[1]' = 0.5 * ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') * ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.Medium.pressure'('pipe.flowModel.states[2]') - 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.Medium.pressure'('pipe.flowModel.states[1]'));
    'pipe.flowModel.dps_fg[1]' = 'pipe.flowModel.Fs_fg[1]' * 2.0 / ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]');
    'pipe.flowModel.Is[1]' = 'pipe.flowModel.m_flows[1]' * 'pipe.flowModel.pathLengths[1]';
    0.0 = 'pipe.flowModel.Ib_flows[1]' - 'pipe.flowModel.Fs_p[1]' - 'pipe.flowModel.Fs_fg[1]';
    'pipe.port_a.m_flow' = 'pipe.flowModel.m_flows[1]';
    0.0 = 'pipe.port_a.m_flow' + 'pipe.port_b.m_flow';
    'pipe.port_a.Xi_outflow[1]' = 'boundary4.ports[1].Xi_outflow[1]';
    'pipe.port_b.Xi_outflow[1]' = 'volume.ports[2].Xi_outflow[1]';
    'pipe.port_a.C_outflow[1]' = 'boundary4.ports[1].C_outflow[1]';
    'pipe.port_b.C_outflow[1]' = 'volume.ports[2].C_outflow[1]';
    'pipe.port_b.h_outflow' = 'volume.ports[2].h_outflow';
    'pipe.port_a.h_outflow' = 'boundary4.ports[1].h_outflow';
    'traceSource.CVec[1]' = 'boundary1.ports[1].C_outflow[1]';
    'traceSource.C' = 'traceSource.CVec['traceSource.ind']';
    'traceSource.port.m_flow' = 0.0;
    'traceSource.port.h_outflow' = 45262.582490480156;
    'traceSource.port.Xi_outflow[1]' = 0.01;
    'traceSource.port.C_outflow[1]' = 0.0;
  initial algorithm
    'traceVolume.ind' := -1;
    'traceVolume.ind' := 1;
    assert('traceVolume.ind' > 0, "Trace substance 'CO2' is not present in medium 'Moist air'.\nCheck sensor parameter and medium model.", AssertionLevel.error);
  initial algorithm
    'traceSource.ind' := -1;
    'traceSource.ind' := 1;
    assert('traceSource.ind' > 0, "Trace substance 'CO2' is not present in medium 'Moist air'.\nCheck sensor parameter and medium model.", AssertionLevel.error);
    annotation(experiment(StopTime = 3600));
  end 'RoomCO2';
end 'RoomCO2';
