//! base 0.1.0
package 'Comparator'
  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'Comparator' "Comparator"
    parameter Real 'Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply";
    parameter Real 'Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply";
    parameter Real 'Vin'(unit = "V", quantity = "ElectricPotential") = 5.0 "Amplitude of input voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of input voltage";
    parameter Real 'Vref'(unit = "V", quantity = "ElectricPotential") = 0.0 "Reference voltage";
    parameter Real 'k' = 0.5 "Calculated potentiometer ratio to reach Vref";
    parameter Real 'R'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance of potentiometer";
    parameter Real 'opAmp.V0' = 15000.0 "No-load amplification";
    parameter Boolean 'opAmp.useSupply' = false "Use supply pins (otherwise constant supply)" annotation(Evaluate = true);
    parameter Real 'opAmp.Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply voltage";
    parameter Real 'opAmp.Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply voltage";
    parameter Boolean 'opAmp.strict' = true "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.LimiterHomotopy' 'opAmp.homotopyType' = 'Modelica.Blocks.Types.LimiterHomotopy'.'NoHomotopy' "Simplified model for homotopy-based initialization" annotation(Evaluate = true);
    Real 'opAmp.vps'(unit = "V", quantity = "ElectricPotential") "Positive supply voltage";
    Real 'opAmp.vns'(unit = "V", quantity = "ElectricPotential") "Negative supply voltage";
    Real 'opAmp.v_in'(unit = "V", quantity = "ElectricPotential") = 'opAmp.in_p.v' - 'opAmp.in_n.v' "Input voltage difference";
    Real 'opAmp.v_out'(unit = "V", quantity = "ElectricPotential") = 'opAmp.out.v' "Output voltage to ground";
    Real 'opAmp.p_in'(unit = "W", quantity = "Power") = 'opAmp.in_p.v' * 'opAmp.in_p.i' + 'opAmp.in_n.v' * 'opAmp.in_n.i' "Input power";
    Real 'opAmp.p_out'(unit = "W", quantity = "Power") = 'opAmp.out.v' * 'opAmp.out.i' "Output power";
    Real 'opAmp.p_s'(unit = "W", quantity = "Power") = -('opAmp.p_in' + 'opAmp.p_out') "Supply power";
    Real 'opAmp.i_s'(unit = "A", quantity = "ElectricCurrent") = 'opAmp.p_s' / ('opAmp.vps' - 'opAmp.vns') "Supply current";
    Real 'opAmp.in_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'opAmp.in_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'opAmp.in_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'opAmp.in_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'opAmp.out.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'opAmp.out.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'opAmp.simplifiedExpr'(unit = "V", quantity = "ElectricPotential") "Simplified expression for homotopy-based initialization";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'vIn.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 10.0 "Amplitude of trapezoid";
    parameter Real 'vIn.rising'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 0.02 "Rising duration of trapezoid";
    parameter Real 'vIn.width'(start = 0.5, min = 0.0, unit = "s", quantity = "Time") = 0.03 "Width duration of trapezoid";
    parameter Real 'vIn.falling'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 0.02 "Falling duration of trapezoid";
    parameter Real 'vIn.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time for one period";
    parameter Integer 'vIn.nperiod'(start = -1) = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'vIn.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'vIn.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vIn.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vIn.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vIn.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vIn.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'vIn.signalSource.amplitude' = 10.0 "Amplitude of trapezoid";
    parameter Real 'vIn.signalSource.rising'(min = 0.0, unit = "s", quantity = "Time") = 0.02 "Rising duration of trapezoid";
    parameter Real 'vIn.signalSource.width'(min = 0.0, unit = "s", quantity = "Time") = 0.03 "Width duration of trapezoid";
    parameter Real 'vIn.signalSource.falling'(min = 0.0, unit = "s", quantity = "Time") = 0.02 "Falling duration of trapezoid";
    parameter Real 'vIn.signalSource.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time for one period";
    parameter Integer 'vIn.signalSource.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'vIn.signalSource.y' "Connector of Real output signal";
    parameter Real 'vIn.signalSource.offset' = -5.0 "Offset of output signal y";
    parameter Real 'vIn.signalSource.startTime'(unit = "s", quantity = "Time") = -0.035 "Output y = offset for time < startTime";
    parameter Real 'vIn.signalSource.T_rising'(unit = "s", quantity = "Time") = 0.02 "End time of rising phase within one period";
    parameter Real 'vIn.signalSource.T_width'(unit = "s", quantity = "Time") = 0.05 "End time of width phase within one period";
    parameter Real 'vIn.signalSource.T_falling'(unit = "s", quantity = "Time") = 0.07 "End time of falling phase within one period";
    Real 'vIn.signalSource.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'vIn.signalSource.count' "Period count";
    parameter Real 'vIn.offset'(unit = "V", quantity = "ElectricPotential") = -5.0 "Voltage offset";
    parameter Real 'vIn.startTime'(unit = "s", quantity = "Time") = -0.035 "Time offset";
    Real 'vOut.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vOut.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vOut.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as output signal";
    parameter Real 'potentiometer.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at temperature T_ref";
    parameter Real 'potentiometer.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'potentiometer.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Boolean 'potentiometer.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'potentiometer.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'potentiometer.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'potentiometer.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    parameter Boolean 'potentiometer.useRinput' = false "Use input for 0<r<1 (else constant)" annotation(Evaluate = true);
    parameter Real 'potentiometer.rConstant'(max = 1.0, min = 0.0) = 0.5 "Contact between n (r=0) and p (r=1)";
    Real 'potentiometer.Rp'(unit = "Ohm", quantity = "Resistance") "Actual resistance between pin_p and contact";
    Real 'potentiometer.Rn'(unit = "Ohm", quantity = "Resistance") "Actual resistance between contact and pin_n";
    Real 'potentiometer.pin_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'potentiometer.pin_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'potentiometer.contact.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'potentiometer.contact.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'potentiometer.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'potentiometer.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'potentiometer.rConst.k'(start = 1.0) = 0.5 "Constant output value";
    Real 'potentiometer.rConst.y' "Connector of Real output signal";
    Real 'potentiometer.rInt';
    parameter Real 'supplyVoltage.Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply";
    parameter Real 'supplyVoltage.Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply";
    Real 'supplyVoltage.pin_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'supplyVoltage.pin_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'supplyVoltage.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'supplyVoltage.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'supplyVoltage.ground.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'supplyVoltage.ground.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'supplyVoltage.positiveSupply.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 15.0 "Value of constant voltage";
    Real 'supplyVoltage.positiveSupply.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'supplyVoltage.positiveSupply.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'supplyVoltage.positiveSupply.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'supplyVoltage.positiveSupply.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'supplyVoltage.positiveSupply.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'supplyVoltage.positiveSupply.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'supplyVoltage.negativeSupply.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 15.0 "Value of constant voltage";
    Real 'supplyVoltage.negativeSupply.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'supplyVoltage.negativeSupply.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'supplyVoltage.negativeSupply.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'supplyVoltage.negativeSupply.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'supplyVoltage.negativeSupply.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'supplyVoltage.negativeSupply.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
  equation
    'potentiometer.rInt' = 'potentiometer.rConst.y';
    'supplyVoltage.pin_p.v' = 'supplyVoltage.positiveSupply.p.v';
    'supplyVoltage.positiveSupply.p.i' - 'supplyVoltage.pin_p.i' = 0.0;
    'supplyVoltage.negativeSupply.n.v' = 'supplyVoltage.pin_n.v';
    'supplyVoltage.ground.v' = 'supplyVoltage.negativeSupply.p.v';
    'supplyVoltage.ground.v' = 'supplyVoltage.positiveSupply.n.v';
    'vIn.p.v' = 'opAmp.in_p.v';
    'opAmp.out.v' = 'vOut.p.v';
    'ground.p.v' = 'supplyVoltage.ground.v';
    'ground.p.v' = 'vIn.n.v';
    'ground.p.v' = 'vOut.n.v';
    'potentiometer.contact.v' = 'opAmp.in_n.v';
    'potentiometer.pin_p.v' = 'supplyVoltage.pin_p.v';
    'potentiometer.pin_n.v' = 'supplyVoltage.pin_n.v';
    'vOut.p.i' + 'opAmp.out.i' = 0.0;
    'vIn.p.i' + 'opAmp.in_p.i' = 0.0;
    'supplyVoltage.ground.i' + 'vOut.n.i' + 'vIn.n.i' + 'ground.p.i' = 0.0;
    'supplyVoltage.pin_p.i' + 'potentiometer.pin_p.i' = 0.0;
    'potentiometer.contact.i' + 'opAmp.in_n.i' = 0.0;
    'supplyVoltage.pin_n.i' + 'potentiometer.pin_n.i' = 0.0;
    'supplyVoltage.negativeSupply.p.i' + 'supplyVoltage.positiveSupply.n.i' - 'supplyVoltage.ground.i' = 0.0;
    'supplyVoltage.negativeSupply.n.i' - 'supplyVoltage.pin_n.i' = 0.0;
    'opAmp.vps' = 15.0;
    'opAmp.vns' = -15.0;
    'opAmp.in_p.i' = 0.0;
    'opAmp.in_n.i' = 0.0;
    'opAmp.simplifiedExpr' = 0.0;
    'opAmp.v_out' = smooth(0, noEvent(if 15000.0 * 'opAmp.v_in' > 'opAmp.vps' then 'opAmp.vps' else if 15000.0 * 'opAmp.v_in' < 'opAmp.vns' then 'opAmp.vns' else 15000.0 * 'opAmp.v_in'));
    'ground.p.v' = 0.0;

    when time >= (pre('vIn.signalSource.count') + 1) * 0.1 - 0.035 then
      'vIn.signalSource.count' = pre('vIn.signalSource.count') + 1;
      'vIn.signalSource.T_start' = time;
    end when;

    'vIn.signalSource.y' = (if time < (-0.035) then 0.0 else if time < 'vIn.signalSource.T_start' + 0.02 then 10.0 * (time - 'vIn.signalSource.T_start') / 0.02 else if time < 'vIn.signalSource.T_start' + 0.05 then 10.0 else if time < 'vIn.signalSource.T_start' + 0.07 then 10.0 * ('vIn.signalSource.T_start' + 0.07 - time) / 0.02 else 0.0) - 5.0;
    'vIn.v' = 'vIn.signalSource.y';
    0.0 = 'vIn.p.i' + 'vIn.n.i';
    'vIn.i' = 'vIn.p.i';
    'vIn.v' = 'vIn.p.v' - 'vIn.n.v';
    'vOut.p.i' = 0.0;
    'vOut.n.i' = 0.0;
    'vOut.v' = 'vOut.p.v' - 'vOut.n.v';
    'potentiometer.rConst.y' = 0.5;
    'potentiometer.pin_p.i' + 'potentiometer.pin_n.i' + 'potentiometer.contact.i' = 0.0;
    'potentiometer.Rp' = 1000.0 * (1.0 - min(1.0, max(0.0, 'potentiometer.rInt')));
    'potentiometer.Rn' = 1000.0 * min(1.0, max(0.0, 'potentiometer.rInt'));
    'potentiometer.pin_p.v' - 'potentiometer.contact.v' = 'potentiometer.Rp' * 'potentiometer.pin_p.i';
    'potentiometer.pin_n.v' - 'potentiometer.contact.v' = 'potentiometer.Rn' * 'potentiometer.pin_n.i';
    'potentiometer.LossPower' = ('potentiometer.pin_p.v' - 'potentiometer.contact.v') * 'potentiometer.pin_p.i' + ('potentiometer.pin_n.v' - 'potentiometer.contact.v') * 'potentiometer.pin_n.i';
    'potentiometer.T_heatPort' = 293.15;
    'supplyVoltage.positiveSupply.v' = 15.0;
    0.0 = 'supplyVoltage.positiveSupply.p.i' + 'supplyVoltage.positiveSupply.n.i';
    'supplyVoltage.positiveSupply.i' = 'supplyVoltage.positiveSupply.p.i';
    'supplyVoltage.positiveSupply.v' = 'supplyVoltage.positiveSupply.p.v' - 'supplyVoltage.positiveSupply.n.v';
    'supplyVoltage.negativeSupply.v' = 15.0;
    0.0 = 'supplyVoltage.negativeSupply.p.i' + 'supplyVoltage.negativeSupply.n.i';
    'supplyVoltage.negativeSupply.i' = 'supplyVoltage.negativeSupply.p.i';
    'supplyVoltage.negativeSupply.v' = 'supplyVoltage.negativeSupply.p.v' - 'supplyVoltage.negativeSupply.n.v';
  initial algorithm
    'vIn.signalSource.count' := integer((time + 0.035) / 0.1);
    'vIn.signalSource.T_start' := 'vIn.signalSource.count' * 0.1 - 0.035;
    annotation(experiment(StartTime = 0, StopTime = 1, Tolerance = 1e-006, Interval = 0.001));
  end 'Comparator';
end 'Comparator';
