//! base 0.1.0
package 'ShowExceptions'
  model 'ShowExceptions' "Example to demonstrate how a hierarchically structured StateGraph can suspend and resume actions on different levels"
    parameter Integer 'compositeStep.nSuspend' = 1 "Number of suspend ports";
    parameter Integer 'compositeStep.nResume' = 1 "Number of resume ports";
    Boolean 'compositeStep.stateGraphRoot.suspend' "= true, if suspend transition of CompositeStep fires";
    Boolean 'compositeStep.stateGraphRoot.resume' "= true, if resume transition of CompositeStep fires";
    Boolean 'compositeStep.stateGraphRoot.subgraphStatePort.suspend' "= true, if suspend transition of CompositeStep fires";
    Boolean 'compositeStep.stateGraphRoot.subgraphStatePort.resume' "= true, if resume transition of CompositeStep fires";
    Real 'compositeStep.stateGraphRoot.subgraphStatePort.activeStepsDummy' "Dummy variable in order that connector fulfills restriction of connector";
    Real 'compositeStep.stateGraphRoot.subgraphStatePort.activeSteps' "Number of active steps in the CompositeStep";
    Boolean 'compositeStep.active' "= true, if step is active, otherwise the step is not active";
    Boolean 'compositeStep.inPort.occupied' "= true, if step is active";
    Boolean 'compositeStep.inPort.set' "= true, if transition fires and step is activated";
    Boolean 'compositeStep.outPort.available' "= true, if step is active";
    Boolean 'compositeStep.outPort.reset' "= true, if transition fires and step is deactivated";
    Boolean 'compositeStep.suspend[1].available' "= true, if step is active";
    Boolean 'compositeStep.suspend[1].reset' "= true, if transition fires and step is deactivated";
    Boolean 'compositeStep.resume[1].occupied' "= true, if step is active";
    Boolean 'compositeStep.resume[1].set' "= true, if transition fires and step is activated";
