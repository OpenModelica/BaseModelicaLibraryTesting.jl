    Boolean 'compositeStep.outerState.subgraphStatePort.resume' "= true, if resume transition of CompositeStep fires";
    Real 'compositeStep.outerState.subgraphStatePort.activeStepsDummy' "Dummy variable in order that connector fulfills restriction of connector";
    Real 'compositeStep.outerState.subgraphStatePort.activeSteps' "Number of active steps in the CompositeStep";
    Boolean 'compositeStep.outerState.active';
    Boolean 'compositeStep.newActive' "Value of active in the next iteration";
    Integer 'compositeStep.activeSteps' "Number of active steps within the CompositeStep";
    Boolean 'compositeStep.transition1.condition' "= true, if transition may fire (time varying expression)";
    Boolean 'compositeStep.transition1.localCondition' "= true, if transition may fire";
    parameter Boolean 'compositeStep.transition1.enableTimer' = false "= true, if timer is enabled" annotation(Evaluate = true);
    parameter Real 'compositeStep.transition1.waitTime'(min = 0.0, unit = "s", quantity = "Time") = 0.0 "Wait time before transition fires";
    Real 'compositeStep.transition1.t'(unit = "s", quantity = "Time") "Actual waiting time (transition will fire when t > waitTime)";
    Boolean 'compositeStep.transition1.enableFire' "= true, if all firing conditions are true";
    Boolean 'compositeStep.transition1.fire' "= true, if transition fires";
    Boolean 'compositeStep.transition1.inPort.available' "= true, if step connected to the transition input is active";
    Boolean 'compositeStep.transition1.inPort.reset' "= true, if transition fires and the step connected to the transition input is deactivated";
    Boolean 'compositeStep.transition1.outPort.occupied' "= true, if step connected to the transition output is active";
    Boolean 'compositeStep.transition1.outPort.set' "= true, if transition fires and step connected to the transition output becomes active";
    discrete Real 'compositeStep.transition1.t_start'(unit = "s", quantity = "Time") "Time instant at which the transition would fire, if waitTime would be zero";
    Real 'compositeStep.transition1.t_dummy';
