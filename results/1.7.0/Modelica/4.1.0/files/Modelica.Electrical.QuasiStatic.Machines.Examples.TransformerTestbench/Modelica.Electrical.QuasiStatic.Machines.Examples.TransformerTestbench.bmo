    'source.P_total' = 'source.P[1]' + 'source.P[2]' + 'source.P[3]';
    'source.Q_total' = 'source.Q[1]' + 'source.Q[2]' + 'source.Q[3]';
    'source.S_total' = sqrt('source.P_total' ^ 2.0 + 'source.Q_total' ^ 2.0);
    'source.gamma' = 'source.plug_p.reference.gamma';
    'electricalPowerSensorS.omega' = der('electricalPowerSensorS.currentP.reference.gamma');
    'electricalPowerSensorS.powerSensor[1].abs_apparentPower' = sqrt('electricalPowerSensorS.powerSensor[1].apparentPower.re' ^ 2.0 + 'electricalPowerSensorS.powerSensor[1].apparentPower.im' ^ 2.0);
    'electricalPowerSensorS.powerSensor[1].arg_apparentPower' = 'Modelica.Math.atan3'('electricalPowerSensorS.powerSensor[1].apparentPower.im', 'electricalPowerSensorS.powerSensor[1].apparentPower.re', 0.0);
