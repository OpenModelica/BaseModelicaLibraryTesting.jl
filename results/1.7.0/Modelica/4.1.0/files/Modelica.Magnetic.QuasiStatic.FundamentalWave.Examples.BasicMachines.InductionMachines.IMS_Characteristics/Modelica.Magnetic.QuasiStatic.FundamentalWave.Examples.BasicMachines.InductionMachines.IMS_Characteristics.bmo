    'resistor.resistor[2].T_heatPort' = 293.15;
    'resistor.resistor[2].pin_p.i.re' + 'resistor.resistor[2].pin_n.i.re' = 0.0;
    'resistor.resistor[2].pin_p.i.im' + 'resistor.resistor[2].pin_n.i.im' = 0.0;
    'resistor.resistor[2].v.re' = 'resistor.resistor[2].pin_p.v.re' - 'resistor.resistor[2].pin_n.v.re';
    'resistor.resistor[2].v.im' = 'resistor.resistor[2].pin_p.v.im' - 'resistor.resistor[2].pin_n.v.im';
    'resistor.resistor[2].i.re' = 'resistor.resistor[2].pin_p.i.re';
    'resistor.resistor[2].i.im' = 'resistor.resistor[2].pin_p.i.im';
    'resistor.resistor[2].pin_p.reference.gamma' = 'resistor.resistor[2].pin_n.reference.gamma';
    'resistor.resistor[2].omega' = der('resistor.resistor[2].pin_p.reference.gamma');
    'resistor.resistor[3].R_actual' = 0.16000000000000003;
    'resistor.resistor[3].v.re' = 'resistor.resistor[3].R_actual' * 'resistor.resistor[3].i.re' - 0.0 * 'resistor.resistor[3].i.im';
    'resistor.resistor[3].v.im' = 'resistor.resistor[3].R_actual' * 'resistor.resistor[3].i.im' + 0.0 * 'resistor.resistor[3].i.re';
    'resistor.resistor[3].LossPower' = 'resistor.resistor[3].v.re' * 'resistor.resistor[3].i.re' - 'resistor.resistor[3].v.im' * (-'resistor.resistor[3].i.im');
    'resistor.resistor[3].T_heatPort' = 293.15;
    'resistor.resistor[3].pin_p.i.re' + 'resistor.resistor[3].pin_n.i.re' = 0.0;
    'resistor.resistor[3].pin_p.i.im' + 'resistor.resistor[3].pin_n.i.im' = 0.0;
    'resistor.resistor[3].v.re' = 'resistor.resistor[3].pin_p.v.re' - 'resistor.resistor[3].pin_n.v.re';
    'resistor.resistor[3].v.im' = 'resistor.resistor[3].pin_p.v.im' - 'resistor.resistor[3].pin_n.v.im';
    'resistor.resistor[3].i.re' = 'resistor.resistor[3].pin_p.i.re';
    'resistor.resistor[3].i.im' = 'resistor.resistor[3].pin_p.i.im';
    'resistor.resistor[3].pin_p.reference.gamma' = 'resistor.resistor[3].pin_n.reference.gamma';
    'resistor.resistor[3].omega' = der('resistor.resistor[3].pin_p.reference.gamma');
    'resistor.v[1].re' = 'resistor.plug_p.pin[1].v.re' - 'resistor.plug_n.pin[1].v.re';
    'resistor.v[1].im' = 'resistor.plug_p.pin[1].v.im' - 'resistor.plug_n.pin[1].v.im';
    'resistor.v[2].re' = 'resistor.plug_p.pin[2].v.re' - 'resistor.plug_n.pin[2].v.re';
    'resistor.v[2].im' = 'resistor.plug_p.pin[2].v.im' - 'resistor.plug_n.pin[2].v.im';
    'resistor.v[3].re' = 'resistor.plug_p.pin[3].v.re' - 'resistor.plug_n.pin[3].v.re';
    'resistor.v[3].im' = 'resistor.plug_p.pin[3].v.im' - 'resistor.plug_n.pin[3].v.im';
    'resistor.i[1].re' = 'resistor.plug_p.pin[1].i.re';
    'resistor.i[1].im' = 'resistor.plug_p.pin[1].i.im';
    'resistor.i[2].re' = 'resistor.plug_p.pin[2].i.re';
    'resistor.i[2].im' = 'resistor.plug_p.pin[2].i.im';
    'resistor.i[3].re' = 'resistor.plug_p.pin[3].i.re';
    'resistor.i[3].im' = 'resistor.plug_p.pin[3].i.im';
    'resistor.omega' = der('resistor.plug_p.reference.gamma');
  initial algorithm
    assert(true, "3 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
    annotation(experiment(Interval = 0.001, StopTime = 1, Tolerance = 1e-06));
  end 'IMS_Characteristics';
end 'IMS_Characteristics';
