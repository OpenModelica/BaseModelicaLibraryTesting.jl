  equation
    'speedPerUnit' = 2.0 * 'imsQS.wMechanical' / 314.1592653589793;
    'slip' = 1.0 - 'speedPerUnit';
    'Iqs' = 'iSensorQS.I';
    'imsQS.gammas' = 'imsQS.airGap.gammas';
    'imsQS.gammar' = 'imsQS.airGap.gammar';
    'imsQS.gamma' = 'imsQS.airGap.gamma';
    'imsQS.phiMechanical' = 'imsQS.flange.phi' - 'imsQS.internalSupport.phi';
    'imsQS.wMechanical' = der('imsQS.phiMechanical');
    'imsQS.tauElectrical' = 'imsQS.inertiaRotor.flange_a.tau';
    'imsQS.tauShaft' = -'imsQS.flange.tau';
    'imsQS.powerBalance.powerStator' = sum('imsQS.vs[(1:size(\'imsQS.vs\', 1))[\'$i1419\']].re' * 'imsQS.is[(1:size(\'imsQS.vs\', 1))[\'$i1419\']].re' - 'imsQS.vs[(1:size(\'imsQS.vs\', 1))[\'$i1419\']].im' * (-'imsQS.is[(1:size(\'imsQS.vs\', 1))[\'$i1419\']].im') for '$i1419' in 1:size('imsQS.vs', 1));
    'imsQS.powerBalance.powerMechanical' = 'imsQS.wMechanical' * 'imsQS.tauShaft';
