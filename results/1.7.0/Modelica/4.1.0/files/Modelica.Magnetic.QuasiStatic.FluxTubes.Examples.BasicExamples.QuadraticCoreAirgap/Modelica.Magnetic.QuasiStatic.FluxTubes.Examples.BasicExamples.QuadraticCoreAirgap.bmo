//! base 0.1.0
package 'QuadraticCoreAirgap'
  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  model 'QuadraticCoreAirgap' "Educational example: iron core with airgap"
    parameter Real 'l'(unit = "m", quantity = "Length") = 0.1 "Outer length of iron core";
    parameter Real 'a'(unit = "m", quantity = "Length") = 0.01 "Side length of square cross section";
    parameter Real 'mu_r' = 1000.0 "Relative permeability of core";
    parameter Real 'delta'(unit = "m", quantity = "Length") = 0.001 "Length of airgap";
    parameter Real 'sigma' = 0.1 "Leakage coefficient";
    parameter Integer 'N' = 500 "Number of turns of exciting coil";
    parameter Real 'I'(unit = "A", quantity = "ElectricCurrent") = 1.5 "Maximum exciting current";
    constant Real 'excitingCoil.j.re' = 0.0 "Real part of complex number";
    constant Real 'excitingCoil.j.im' = 1.0 "Imaginary part of complex number";
