    'rightLeg.abs_V_m' = sqrt('rightLeg.V_m.re' ^ 2.0 + 'rightLeg.V_m.im' ^ 2.0);
    'rightLeg.arg_V_m' = 'Modelica.Math.atan3'('rightLeg.V_m.im', 'rightLeg.V_m.re', 0.0);
