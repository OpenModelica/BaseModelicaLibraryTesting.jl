    'measuringCoil.L_stat' = noEvent(if sqrt('measuringCoil.i.re' ^ 2.0 + 'measuringCoil.i.im' ^ 2.0) > 'measuringCoil.eps' then sqrt((('measuringCoil.Psi.re' * 'measuringCoil.i.re' + 'measuringCoil.Psi.im' * 'measuringCoil.i.im') / ('measuringCoil.i.re' * 'measuringCoil.i.re' + 'measuringCoil.i.im' * 'measuringCoil.i.im')) ^ 2.0 + (('measuringCoil.Psi.im' * 'measuringCoil.i.re' - 'measuringCoil.Psi.re' * 'measuringCoil.i.im') / ('measuringCoil.i.re' * 'measuringCoil.i.re' + 'measuringCoil.i.im' * 'measuringCoil.i.im')) ^ 2.0) else sqrt((('measuringCoil.Psi.re' * 'measuringCoil.eps' + 'measuringCoil.Psi.im' * 0.0) / ('measuringCoil.eps' * 'measuringCoil.eps' + 0.0 * 0.0)) ^ 2.0 + (('measuringCoil.Psi.im' * 'measuringCoil.eps' - 'measuringCoil.Psi.re' * 0.0) / ('measuringCoil.eps' * 'measuringCoil.eps' + 0.0 * 0.0)) ^ 2.0));
    'measuringCoil.omega' = der('measuringCoil.port_p.reference.gamma');
    'measuringCoil.port_p.reference.gamma' = 'measuringCoil.port_n.reference.gamma';
    'measuringCoil.pin_p.reference.gamma' = 'measuringCoil.pin_n.reference.gamma';
    'measuringCoil.port_p.reference.gamma' = 'measuringCoil.pin_p.reference.gamma';
    'lowerYoke.A' = 1e-4;
    'lowerYoke.G_m' = 1.25663706212e-6 * 'lowerYoke.mu_r' * 'lowerYoke.A' / 0.09000000000000001;
    'lowerYoke.mu_r' = 1000.0;
    'lowerYoke.R_m' = 1.0 / 'lowerYoke.G_m';
    'lowerYoke.V_m.re' = 'lowerYoke.Phi.re' * 'lowerYoke.R_m' - 'lowerYoke.Phi.im' * 0.0;
    'lowerYoke.V_m.im' = 'lowerYoke.Phi.re' * 0.0 + 'lowerYoke.Phi.im' * 'lowerYoke.R_m';
    'lowerYoke.B.re' = ('lowerYoke.Phi.re' * 'lowerYoke.A' + 'lowerYoke.Phi.im' * 0.0) / ('lowerYoke.A' * 'lowerYoke.A' + 0.0 * 0.0);
    'lowerYoke.B.im' = ('lowerYoke.Phi.im' * 'lowerYoke.A' - 'lowerYoke.Phi.re' * 0.0) / ('lowerYoke.A' * 'lowerYoke.A' + 0.0 * 0.0);
    'lowerYoke.H.re' = ('lowerYoke.B.re' * (1.25663706212e-6 * 'lowerYoke.mu_r') + 'lowerYoke.B.im' * 0.0) / (1.25663706212e-6 * 'lowerYoke.mu_r' * (1.25663706212e-6 * 'lowerYoke.mu_r') + 0.0 * 0.0);
    'lowerYoke.H.im' = ('lowerYoke.B.im' * (1.25663706212e-6 * 'lowerYoke.mu_r') - 'lowerYoke.B.re' * 0.0) / (1.25663706212e-6 * 'lowerYoke.mu_r' * (1.25663706212e-6 * 'lowerYoke.mu_r') + 0.0 * 0.0);
    0.0 = 'lowerYoke.port_p.Phi.re' + 'lowerYoke.port_n.Phi.re';
    0.0 = 'lowerYoke.port_p.Phi.im' + 'lowerYoke.port_n.Phi.im';
    'lowerYoke.port_p.reference.gamma' = 'lowerYoke.port_n.reference.gamma';
    'lowerYoke.omega' = der('lowerYoke.port_p.reference.gamma');
    'lowerYoke.V_m.re' = 'lowerYoke.port_p.V_m.re' - 'lowerYoke.port_n.V_m.re';
    'lowerYoke.V_m.im' = 'lowerYoke.port_p.V_m.im' - 'lowerYoke.port_n.V_m.im';
    'lowerYoke.Phi.re' = 'lowerYoke.port_p.Phi.re';
    'lowerYoke.Phi.im' = 'lowerYoke.port_p.Phi.im';
    'magneticGround.port.V_m.re' = 0.0;
    'magneticGround.port.V_m.im' = 0.0;
    'electricGround1.pin.v.re' = 0.0;
    'electricGround1.pin.v.im' = 0.0;
    'currentSource.omega' = 6.283185307179586 * 'currentSource.f';
    'currentSource.i.re' = 'currentSource.I.re';
    'currentSource.i.im' = 'currentSource.I.im';
    'currentSource.pin_p.i.re' + 'currentSource.pin_n.i.re' = 0.0;
    'currentSource.pin_p.i.im' + 'currentSource.pin_n.i.im' = 0.0;
    'currentSource.v.re' = 'currentSource.pin_p.v.re' - 'currentSource.pin_n.v.re';
    'currentSource.v.im' = 'currentSource.pin_p.v.im' - 'currentSource.pin_n.v.im';
    'currentSource.i.re' = 'currentSource.pin_p.i.re';
    'currentSource.i.im' = 'currentSource.pin_p.i.im';
    'currentSource.pin_p.reference.gamma' = 'currentSource.pin_n.reference.gamma';
    'currentSource.omega' = der('currentSource.pin_p.reference.gamma');
    'magFluxSensor.V_m.re' = 0.0;
    'magFluxSensor.V_m.im' = 0.0;
    'magFluxSensor.y.re' = 'magFluxSensor.Phi.re';
    'magFluxSensor.y.im' = 'magFluxSensor.Phi.im';
    0.0 = 'magFluxSensor.port_p.Phi.re' + 'magFluxSensor.port_n.Phi.re';
    0.0 = 'magFluxSensor.port_p.Phi.im' + 'magFluxSensor.port_n.Phi.im';
    'magFluxSensor.port_p.reference.gamma' = 'magFluxSensor.port_n.reference.gamma';
    'magFluxSensor.omega' = der('magFluxSensor.port_p.reference.gamma');
    'magFluxSensor.V_m.re' = 'magFluxSensor.port_p.V_m.re' - 'magFluxSensor.port_n.V_m.re';
    'magFluxSensor.V_m.im' = 'magFluxSensor.port_p.V_m.im' - 'magFluxSensor.port_n.V_m.im';
    'magFluxSensor.Phi.re' = 'magFluxSensor.port_p.Phi.re';
    'magFluxSensor.Phi.im' = 'magFluxSensor.port_p.Phi.im';
    'electricGround2.pin.v.re' = 0.0;
    'electricGround2.pin.v.im' = 0.0;
    'voltageSensor.v.re' = 'voltageSensor.pin_p.v.re' - 'voltageSensor.pin_n.v.re';
    'voltageSensor.v.im' = 'voltageSensor.pin_p.v.im' - 'voltageSensor.pin_n.v.im';
    'voltageSensor.i.re' = 'voltageSensor.pin_p.i.re';
    'voltageSensor.i.im' = 'voltageSensor.pin_p.i.im';
    'voltageSensor.i.re' = 0.0;
    'voltageSensor.i.im' = 0.0;
    0.0 = 'voltageSensor.pin_p.i.re' + 'voltageSensor.pin_n.i.re' "Current balance";
    0.0 = 'voltageSensor.pin_p.i.im' + 'voltageSensor.pin_n.i.im' "Current balance";
    'voltageSensor.pin_p.reference.gamma' = 'voltageSensor.pin_n.reference.gamma';
    'voltageSensor.omega' = der('voltageSensor.pin_p.reference.gamma');
    0.09999999999999998 * 'leakage.R_m' = 0.9 * 'leakage.R_mUsefulTot';
    'leakage.V_m.re' = 'leakage.Phi.re' * 'leakage.R_m' - 'leakage.Phi.im' * 0.0;
    'leakage.V_m.im' = 'leakage.Phi.re' * 0.0 + 'leakage.Phi.im' * 'leakage.R_m';
    'leakage.R_m' = 1.0 / 'leakage.G_m';
    0.0 = 'leakage.port_p.Phi.re' + 'leakage.port_n.Phi.re';
    0.0 = 'leakage.port_p.Phi.im' + 'leakage.port_n.Phi.im';
    'leakage.port_p.reference.gamma' = 'leakage.port_n.reference.gamma';
    'leakage.omega' = der('leakage.port_p.reference.gamma');
    'leakage.V_m.re' = 'leakage.port_p.V_m.re' - 'leakage.port_n.V_m.re';
    'leakage.V_m.im' = 'leakage.port_p.V_m.im' - 'leakage.port_n.V_m.im';
    'leakage.Phi.re' = 'leakage.port_p.Phi.re';
    'leakage.Phi.im' = 'leakage.port_p.Phi.im';
    'const.y' = 10.6103;
    'complexRamp.magnitude' = if time < 0.01 then 0.0 else if time < 0.025 then (time - 0.01) * 1.5 / 0.015 else 1.5;
    'complexRamp.y.re' = 'complexRamp.magnitude' * 1.0 - 0.0 * 0.0;
    'complexRamp.y.im' = 'complexRamp.magnitude' * 0.0 + 0.0 * 1.0;
    annotation(experiment(StopTime = 0.05, Interval = 0.0001));
  end 'QuadraticCoreAirgap';
end 'QuadraticCoreAirgap';
