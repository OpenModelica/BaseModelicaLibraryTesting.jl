    'currentSource.abs_v' = sqrt('currentSource.v.re' ^ 2.0 + 'currentSource.v.im' ^ 2.0);
    'currentSource.arg_v' = 'Modelica.Math.atan3'('currentSource.v.im', 'currentSource.v.re', 0.0);
    'currentSource.abs_i' = sqrt('currentSource.i.re' ^ 2.0 + 'currentSource.i.im' ^ 2.0);
    'currentSource.arg_i' = 'Modelica.Math.atan3'('currentSource.i.im', 'currentSource.i.re', 0.0);
    'currentSource.P' = 'currentSource.v.re' * 'currentSource.i.re' - 'currentSource.v.im' * (-'currentSource.i.im');
    'currentSource.Q' = 'currentSource.v.re' * (-'currentSource.i.im') + 'currentSource.v.im' * 'currentSource.i.re';
    'currentSource.S' = sqrt(('currentSource.v.re' * 'currentSource.i.re' - 'currentSource.v.im' * (-'currentSource.i.im')) ^ 2.0 + ('currentSource.v.re' * (-'currentSource.i.im') + 'currentSource.v.im' * 'currentSource.i.re') ^ 2.0);
    'currentSource.pf' = cos('Modelica.Math.atan3'('currentSource.Q', 'currentSource.P', 0.0));
    'currentSource.gamma' = 'currentSource.pin_p.reference.gamma';
    'magFluxSensor.abs_V_m' = sqrt('magFluxSensor.V_m.re' ^ 2.0 + 'magFluxSensor.V_m.im' ^ 2.0);
    'magFluxSensor.arg_V_m' = 'Modelica.Math.atan3'('magFluxSensor.V_m.im', 'magFluxSensor.V_m.re', 0.0);
    'magFluxSensor.abs_Phi' = sqrt('magFluxSensor.Phi.re' ^ 2.0 + 'magFluxSensor.Phi.im' ^ 2.0);
    'magFluxSensor.arg_Phi' = 'Modelica.Math.atan3'('magFluxSensor.Phi.im', 'magFluxSensor.Phi.re', 0.0);
    'voltageSensor.abs_v' = sqrt('voltageSensor.v.re' ^ 2.0 + 'voltageSensor.v.im' ^ 2.0);
    'voltageSensor.arg_v' = 'Modelica.Math.atan3'('voltageSensor.v.im', 'voltageSensor.v.re', 0.0);
    'leakage.abs_V_m' = sqrt('leakage.V_m.re' ^ 2.0 + 'leakage.V_m.im' ^ 2.0);
    'leakage.arg_V_m' = 'Modelica.Math.atan3'('leakage.V_m.im', 'leakage.V_m.re', 0.0);
    'leakage.abs_Phi' = sqrt('leakage.Phi.re' ^ 2.0 + 'leakage.Phi.im' ^ 2.0);
    'leakage.arg_Phi' = 'Modelica.Math.atan3'('leakage.Phi.im', 'leakage.Phi.re', 0.0);
    'usefulReluctance.y' = 1.0 / 'airGap.G_m';
    'excitingCoil.port_p.V_m.re' = 'leftLeg.port_p.V_m.re';
    'excitingCoil.port_p.V_m.im' = 'leftLeg.port_p.V_m.im';
    'leftLeg.port_n.V_m.re' = 'upperYoke.port_p.V_m.re';
    'leftLeg.port_n.V_m.im' = 'upperYoke.port_p.V_m.im';
