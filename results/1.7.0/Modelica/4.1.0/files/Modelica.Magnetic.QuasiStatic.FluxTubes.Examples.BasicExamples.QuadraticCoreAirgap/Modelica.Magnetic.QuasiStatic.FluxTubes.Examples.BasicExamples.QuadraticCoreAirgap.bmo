    'rightLeg.arg_H' = 'Modelica.Math.atan3'('rightLeg.H.im', 'rightLeg.H.re', 0.0);
    'airGap.abs_V_m' = sqrt('airGap.V_m.re' ^ 2.0 + 'airGap.V_m.im' ^ 2.0);
    'airGap.arg_V_m' = 'Modelica.Math.atan3'('airGap.V_m.im', 'airGap.V_m.re', 0.0);
    'airGap.abs_Phi' = sqrt('airGap.Phi.re' ^ 2.0 + 'airGap.Phi.im' ^ 2.0);
    'airGap.arg_Phi' = 'Modelica.Math.atan3'('airGap.Phi.im', 'airGap.Phi.re', 0.0);
    'airGap.abs_B' = sqrt('airGap.B.re' ^ 2.0 + 'airGap.B.im' ^ 2.0);
    'airGap.arg_B' = 'Modelica.Math.atan3'('airGap.B.im', 'airGap.B.re', 0.0);
    'airGap.abs_H' = sqrt('airGap.H.re' ^ 2.0 + 'airGap.H.im' ^ 2.0);
    'airGap.arg_H' = 'Modelica.Math.atan3'('airGap.H.im', 'airGap.H.re', 0.0);
    'measuringCoil.eps' = 2.220446049250313e-14;
    'lowerYoke.abs_V_m' = sqrt('lowerYoke.V_m.re' ^ 2.0 + 'lowerYoke.V_m.im' ^ 2.0);
    'lowerYoke.arg_V_m' = 'Modelica.Math.atan3'('lowerYoke.V_m.im', 'lowerYoke.V_m.re', 0.0);
    'lowerYoke.abs_Phi' = sqrt('lowerYoke.Phi.re' ^ 2.0 + 'lowerYoke.Phi.im' ^ 2.0);
