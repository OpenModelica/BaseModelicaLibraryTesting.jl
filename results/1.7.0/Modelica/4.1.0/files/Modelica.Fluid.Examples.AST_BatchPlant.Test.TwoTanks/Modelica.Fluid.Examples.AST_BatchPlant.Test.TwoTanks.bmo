//! base 0.1.0
package 'TwoTanks'
  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    else
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      else
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility' "Interpolating with two 3-order polynomials with a prescribed derivative at x=0"
    input Real 'x';
    input Real 'x1';
    input Real 'k1';
    input Real 'k2';
    input Boolean 'use_yd0' = false;
    input Real 'yd0'(min = 0.0) = 1.0;
    output Real 'y';
    Real 'x2';
    Real 'y1';
    Real 'y2';
    Real 'y1d';
    Real 'y2d';
    Real 'w';
    Real 'w1';
    Real 'w2';
    Real 'y0d';
    Real 'ww';
  algorithm
    'x2' := -'x1';

    if 'x' <= 'x2' then
      'y' := -'k2' * 'x' ^ 2.0;
    else
      'y1' := 'k1' * 'x1' ^ 2.0;
      'y2' := -'k2' * 'x2' ^ 2.0;
      'y1d' := 'k1' * 2.0 * 'x1';
      'y2d' := -'k2' * 2.0 * 'x2';

      if 'use_yd0' then
        'y0d' := 'yd0';
      else
        'w' := 'x2' / 'x1';
        'y0d' := ((3.0 * 'y2' - 'x2' * 'y2d') / 'w' - (3.0 * 'y1' - 'x1' * 'y1d') * 'w') / (2.0 * 'x1' * (1.0 - 'w'));
      end if;

      'w1' := 2.23606797749979 * 'k1' * 'x1';
      'w2' := 2.23606797749979 * 'k2' * abs('x2');
      'ww' := 0.9 * (if 'w1' < 'w2' then 'w1' else 'w2');

      if 'ww' < 'y0d' then
        'y0d' := 'ww';
      end if;

      'y' := if 'x' >= 0.0 then 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x', 'x1', 'y1', 'y1d', 'y0d') else 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x', 'x2', 'y2', 'y2d', 'y0d');
    end if;
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / 'Modelica.Math.log10'('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.pressureLoss_m_flow';

  type 'Modelica.Fluid.Types.Dynamics' = enumeration('DynamicFreeInitial', 'FixedInitial', 'SteadyStateInitial', 'SteadyState');

  model 'TwoTanks'
    parameter Boolean 'stiffCharacteristicForEmptyPort' = true "= true, if steep pressure loss characteristic for empty pipe port";
    parameter Real 'system.p_ambient'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default ambient pressure";
    parameter Real 'system.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default ambient temperature";
    parameter Real 'system.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'system.allowFlowReversal' = true "= false to restrict to design flow direction (port_a -> port_b)" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of energy balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of mass balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of trace substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Default formulation of momentum balances, if options available" annotation(Evaluate = true);
    parameter Real 'system.m_flow_start'(unit = "kg/s", quantity = "MassFlowRate") = 0.0 "Default start value for mass flow rates";
    parameter Real 'system.p_start'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default start value for pressures";
    parameter Real 'system.T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default start value for temperatures";
    parameter Boolean 'system.use_eps_Re' = false "= true to determine turbulent region automatically using Reynolds number" annotation(Evaluate = true);
    parameter Real 'system.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 1.0 "Default nominal mass flow rate";
    parameter Real 'system.eps_m_flow'(min = 0.0) = 1e-4 "Regularization of zero flow for |m_flow| < eps_m_flow*m_flow_nominal";
    parameter Real 'system.dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0 "Default small pressure drop for regularization of laminar and zero flow";
    parameter Real 'system.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Default small mass flow rate for regularization of laminar and zero flow";
    Real 'tank1.level'(stateSelect = StateSelect.prefer, start = 3.0, unit = "m", quantity = "Length") "Fluid level in the tank";
    parameter Real 'tank1.height'(min = 0.0, unit = "m", quantity = "Length") = 4.0 "Maximum level of tank before it overflows";
    parameter Real 'tank1.crossArea'(unit = "m2", quantity = "Area") = 1.0 "Area of tank";
    parameter Real 'tank1.V0'(unit = "m3", quantity = "Volume") = 0.0 "Volume of the liquid when level = 0";
    parameter Real 'tank1.p_ambient'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Tank surface pressure";
    parameter Real 'tank1.T_ambient'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Tank surface Temperature";
    parameter Real 'tank1.level_start'(min = 0.0, unit = "m", quantity = "Length") = 3.0 "Start value of tank level";
    Real 'tank1.fluidVolume'(unit = "m3", quantity = "Volume") "Volume";
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank1.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank1.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank1.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of substance balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank1.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of trace substance balance" annotation(Evaluate = true);
    parameter Real 'tank1.p_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Boolean 'tank1.use_T_start' = true "= true, use T_start, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'tank1.T_start'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 323.15 "Start value of temperature";
    parameter Real 'tank1.h_start'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 209200.0 "Start value of specific enthalpy";
    parameter Real 'tank1.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    Real 'tank1.medium.p'(stateSelect = StateSelect.prefer, nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank1.medium.h'(start = 209200.0, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'tank1.medium.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'tank1.medium.T'(stateSelect = StateSelect.prefer, nominal = 300.0, start = 323.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'tank1.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'tank1.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'tank1.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'tank1.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'tank1.medium.state.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank1.medium.state.T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    parameter Boolean 'tank1.medium.preferredMediumStates' = true "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'tank1.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'tank1.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'tank1.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'tank1.U'(unit = "J", quantity = "Energy") "Internal energy of fluid";
    Real 'tank1.m'(min = 0.0, unit = "kg", quantity = "Mass") "Mass of fluid";
    Real 'tank1.mb_flow'(unit = "kg/s", quantity = "MassFlowRate") "Mass flows across boundaries";
    Real 'tank1.Hb_flow'(unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow across boundaries or energy source/sink";
    Real 'tank1.Qb_flow'(unit = "W", quantity = "Power") "Heat flow across boundaries or energy source/sink";
    Real 'tank1.Wb_flow'(unit = "W", quantity = "Power") "Work flow across boundaries or source term";
    parameter Boolean 'tank1.initialize_p' = false "= true to set up initial equations for pressure";
    parameter Integer 'tank1.nTopPorts' = 0 "Number of inlet ports above height (>= 1)";
    parameter Integer 'tank1.nPorts' = 1 "Number of inlet/outlet ports (on bottom and on the side)";
    parameter Real 'tank1.portsData[1].diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Inner (hydraulic) diameter of inlet/outlet port";
    parameter Real 'tank1.portsData[1].height'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Height over the bottom of the vessel";
    parameter Real 'tank1.portsData[1].zeta_out'(min = 0.0) = 0.5 "Hydraulic resistance out of vessel, default 0.5 for small diameter mounted flush with the wall";
    parameter Real 'tank1.portsData[1].zeta_in'(min = 0.0) = 1.04 "Hydraulic resistance into vessel, default 1.04 for small diameter mounted flush with the wall";
    Real 'tank1.ports[1].m_flow'(start = 0.0, max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'tank1.ports[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'tank1.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'tank1.use_HeatTransfer' = false "= true, if HeatTransfer model is used";
    parameter Integer 'tank1.heatTransfer.n' = 1 "Number of heat transfer segments" annotation(Evaluate = true);
    Real 'tank1.heatTransfer.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank1.heatTransfer.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'tank1.heatTransfer.surfaceAreas[1]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'tank1.heatTransfer.Q_flows[1]'(unit = "W", quantity = "Power") "Heat flow rates";
    parameter Boolean 'tank1.heatTransfer.use_k' = false "= true to use k value for thermal isolation";
    parameter Real 'tank1.heatTransfer.k'(unit = "W/(m2.K)", quantity = "CoefficientOfHeatTransfer") = 0.0 "Heat transfer coefficient to ambient" annotation(Evaluate = true);
    parameter Real 'tank1.heatTransfer.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'tank1.heatTransfer.heatPorts[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'tank1.heatTransfer.heatPorts[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'tank1.heatTransfer.Ts[1]'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    parameter Real 'tank1.hysteresisFactor'(min = 0.0) = 0.1 "Hysteresis for empty pipe = diameter*hysteresisFactor";
    parameter Boolean 'tank1.stiffCharacteristicForEmptyPort' = true "= true, if steep pressure loss characteristic for empty pipe port" annotation(Evaluate = true);
    parameter Real 'tank1.zetaLarge'(min = 0.0) = 1e5 "Large pressure loss factor if mass flows out of empty pipe port";
    parameter Real 'tank1.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Regularization range at zero mass flow rate";
    Real 'tank1.V'(stateSelect = StateSelect.never, unit = "m3", quantity = "Volume") "Actual tank volume";
    Real 'tank1.port_b_H_flow_bottom[1]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates from the bottom ports in to the tank";
    Real 'tank1.bottomArea[1]'(unit = "m2", quantity = "Area");
    Real 'tank1.ports_emptyPipeHysteresis[1]'(min = 0.0, unit = "m", quantity = "Length");
    Real 'tank1.levelAbovePort[1]'(unit = "m", quantity = "Length") "Height of fluid over bottom ports";
    Boolean 'tank1.ports_m_flow_out[1]'(fixed = true, start = true);
    Boolean 'tank1.aboveLevel[1]' "= true, if level >= ports[i].height";
    Real 'tank1.zetas_out[1]';
    Real 'tank1.portsData_diameter[1]';
    Real 'tank1.portsData_diameter2[1]';
    Real 'tank1.portsData_height[1]';
    Real 'tank1.portsData_height2[1]';
    Real 'tank2.level'(stateSelect = StateSelect.prefer, start = 1.0, unit = "m", quantity = "Length") "Fluid level in the tank";
    parameter Real 'tank2.height'(min = 0.0, unit = "m", quantity = "Length") = 4.0 "Maximum level of tank before it overflows";
    parameter Real 'tank2.crossArea'(unit = "m2", quantity = "Area") = 1.0 "Area of tank";
    parameter Real 'tank2.V0'(unit = "m3", quantity = "Volume") = 0.0 "Volume of the liquid when level = 0";
    parameter Real 'tank2.p_ambient'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Tank surface pressure";
    parameter Real 'tank2.T_ambient'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Tank surface Temperature";
    parameter Real 'tank2.level_start'(min = 0.0, unit = "m", quantity = "Length") = 1.0 "Start value of tank level";
    Real 'tank2.fluidVolume'(unit = "m3", quantity = "Volume") "Volume";
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank2.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank2.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank2.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of substance balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'tank2.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of trace substance balance" annotation(Evaluate = true);
    parameter Real 'tank2.p_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Boolean 'tank2.use_T_start' = true "= true, use T_start, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'tank2.T_start'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 373.15 "Start value of temperature";
    parameter Real 'tank2.h_start'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 418400.0 "Start value of specific enthalpy";
    parameter Real 'tank2.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    Real 'tank2.medium.p'(stateSelect = StateSelect.prefer, nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank2.medium.h'(start = 418400.0, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'tank2.medium.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'tank2.medium.T'(stateSelect = StateSelect.prefer, nominal = 300.0, start = 373.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'tank2.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'tank2.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'tank2.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'tank2.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'tank2.medium.state.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank2.medium.state.T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    parameter Boolean 'tank2.medium.preferredMediumStates' = true "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'tank2.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'tank2.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'tank2.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'tank2.U'(unit = "J", quantity = "Energy") "Internal energy of fluid";
    Real 'tank2.m'(min = 0.0, unit = "kg", quantity = "Mass") "Mass of fluid";
    Real 'tank2.mb_flow'(unit = "kg/s", quantity = "MassFlowRate") "Mass flows across boundaries";
    Real 'tank2.Hb_flow'(unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow across boundaries or energy source/sink";
    Real 'tank2.Qb_flow'(unit = "W", quantity = "Power") "Heat flow across boundaries or energy source/sink";
    Real 'tank2.Wb_flow'(unit = "W", quantity = "Power") "Work flow across boundaries or source term";
    parameter Boolean 'tank2.initialize_p' = false "= true to set up initial equations for pressure";
    parameter Integer 'tank2.nTopPorts' = 0 "Number of inlet ports above height (>= 1)";
    parameter Integer 'tank2.nPorts' = 1 "Number of inlet/outlet ports (on bottom and on the side)";
    parameter Real 'tank2.portsData[1].diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Inner (hydraulic) diameter of inlet/outlet port";
    parameter Real 'tank2.portsData[1].height'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Height over the bottom of the vessel";
    parameter Real 'tank2.portsData[1].zeta_out'(min = 0.0) = 0.5 "Hydraulic resistance out of vessel, default 0.5 for small diameter mounted flush with the wall";
    parameter Real 'tank2.portsData[1].zeta_in'(min = 0.0) = 1.04 "Hydraulic resistance into vessel, default 1.04 for small diameter mounted flush with the wall";
    Real 'tank2.ports[1].m_flow'(start = 0.0, max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'tank2.ports[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'tank2.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'tank2.use_HeatTransfer' = false "= true, if HeatTransfer model is used";
    parameter Integer 'tank2.heatTransfer.n' = 1 "Number of heat transfer segments" annotation(Evaluate = true);
    Real 'tank2.heatTransfer.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'tank2.heatTransfer.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'tank2.heatTransfer.surfaceAreas[1]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'tank2.heatTransfer.Q_flows[1]'(unit = "W", quantity = "Power") "Heat flow rates";
    parameter Boolean 'tank2.heatTransfer.use_k' = false "= true to use k value for thermal isolation";
    parameter Real 'tank2.heatTransfer.k'(unit = "W/(m2.K)", quantity = "CoefficientOfHeatTransfer") = 0.0 "Heat transfer coefficient to ambient" annotation(Evaluate = true);
    parameter Real 'tank2.heatTransfer.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'tank2.heatTransfer.heatPorts[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'tank2.heatTransfer.heatPorts[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'tank2.heatTransfer.Ts[1]'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    parameter Real 'tank2.hysteresisFactor'(min = 0.0) = 0.1 "Hysteresis for empty pipe = diameter*hysteresisFactor";
    parameter Boolean 'tank2.stiffCharacteristicForEmptyPort' = true "= true, if steep pressure loss characteristic for empty pipe port" annotation(Evaluate = true);
    parameter Real 'tank2.zetaLarge'(min = 0.0) = 1e5 "Large pressure loss factor if mass flows out of empty pipe port";
    parameter Real 'tank2.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Regularization range at zero mass flow rate";
    Real 'tank2.V'(stateSelect = StateSelect.never, unit = "m3", quantity = "Volume") "Actual tank volume";
    Real 'tank2.port_b_H_flow_bottom[1]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates from the bottom ports in to the tank";
    Real 'tank2.bottomArea[1]'(unit = "m2", quantity = "Area");
    Real 'tank2.ports_emptyPipeHysteresis[1]'(min = 0.0, unit = "m", quantity = "Length");
    Real 'tank2.levelAbovePort[1]'(unit = "m", quantity = "Length") "Height of fluid over bottom ports";
    Boolean 'tank2.ports_m_flow_out[1]'(fixed = true, start = true);
    Boolean 'tank2.aboveLevel[1]' "= true, if level >= ports[i].height";
    Real 'tank2.zetas_out[1]';
    Real 'tank2.portsData_diameter[1]';
    Real 'tank2.portsData_diameter2[1]';
    Real 'tank2.portsData_height[1]';
    Real 'tank2.portsData_height2[1]';
    parameter Boolean 'pipe.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'pipe.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'pipe.port_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe.port_a.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'pipe.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'pipe.port_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe.port_b.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'pipe.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'pipe.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'pipe.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'pipe.nParallel'(min = 1.0) = 1.0 "Number of identical parallel pipes";
    parameter Real 'pipe.length'(unit = "m", quantity = "Length") = 1.0 "Length";
    parameter Boolean 'pipe.isCircular' = true "= true, if cross sectional area is circular" annotation(Evaluate = true);
    parameter Real 'pipe.diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Diameter of circular pipe";
    parameter Real 'pipe.crossArea'(unit = "m2", quantity = "Area") = 0.007853981633974483 "Inner cross section area";
    parameter Real 'pipe.perimeter'(min = 0.0, unit = "m", quantity = "Length") = 0.3141592653589793 "Inner perimeter";
    parameter Real 'pipe.roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average height of surface asperities (default: smooth steel pipe)";
    parameter Real 'pipe.V'(unit = "m3", quantity = "Volume") = 0.007853981633974483 "Volume size";
    parameter Real 'pipe.height_ab'(unit = "m", quantity = "Length") = 0.0 "Height(port_b) - Height(port_a)";
    parameter Real 'pipe.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port a";
    parameter Real 'pipe.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port b";
    parameter Real 'pipe.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 0.0 "Start value for mass flow rate" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.from_dp' = true "= true, use m_flow = f(dp), otherwise dp = f(m_flow)" annotation(Evaluate = true);
    parameter Integer 'pipe.flowModel.n' = 2 "Number of discrete flow volumes";
    Real 'pipe.flowModel.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.flowModel.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.flowModel.states[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.flowModel.states[2].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.flowModel.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    Real 'pipe.flowModel.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    parameter Real 'pipe.flowModel.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'pipe.flowModel.crossAreas[1]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe.flowModel.crossAreas[2]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe.flowModel.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe.flowModel.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe.flowModel.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe.flowModel.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe.flowModel.dheights[1]'(unit = "m", quantity = "Length") "Height(states[2:n]) - Height(states[1:n-1])";
    parameter Real 'pipe.flowModel.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'pipe.flowModel.allowFlowReversal' = true "= true, if flow reversal is enabled, otherwise restrict flow to design direction (states[1] -> states[n+1])" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe.flowModel.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 0.0 "Start value of mass flow rates";
    parameter Real 'pipe.flowModel.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[1] at design inflow";
    parameter Real 'pipe.flowModel.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[n+1] at design outflow";
    parameter Integer 'pipe.flowModel.m' = 1 "Number of flow segments";
    Real 'pipe.flowModel.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe.flowModel.m_flows[1]'(stateSelect = StateSelect.default, start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rates between states";
    Real 'pipe.flowModel.Is[1]'(unit = "kg.m/s", quantity = "Momentum") "Momenta of flow segments";
    Real 'pipe.flowModel.Ib_flows[1]'(unit = "N", quantity = "Force") "Flow of momentum across boundaries";
    Real 'pipe.flowModel.Fs_p[1]'(unit = "N", quantity = "Force") "Pressure forces";
    Real 'pipe.flowModel.Fs_fg[1]'(unit = "N", quantity = "Force") "Friction and gravity forces";
    parameter Boolean 'pipe.flowModel.useUpstreamScheme' = true "= false to average upstream and downstream properties across flow segments" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.use_Ib_flows' = false "= true to consider differences in flow of momentum through boundaries" annotation(Evaluate = true);
    Real 'pipe.flowModel.rhos[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe.flowModel.rhos[2]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe.flowModel.rhos_act[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
    Real 'pipe.flowModel.mus[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe.flowModel.mus[2]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe.flowModel.mus_act[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") "Actual viscosity per segment";
    Real 'pipe.flowModel.dps_fg[1]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    parameter Real 'pipe.flowModel.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0 "Start of turbulent regime, depending on type of flow device";
    parameter Boolean 'pipe.flowModel.show_Res' = false "= true, if Reynolds numbers are included for plotting" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.use_rho_nominal' = false "= true, if rho_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.rho_nominal'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 995.586 "Nominal density (e.g., rho_liquidWater = 995, rho_air = 1.2)";
    parameter Boolean 'pipe.flowModel.use_mu_nominal' = false "= true, if mu_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.mu_nominal'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") = 0.001 "Nominal dynamic viscosity (e.g., mu_liquidWater = 1e-3, mu_air = 1.8e-5)";
    Real 'pipe.flowModel.pathLengths_internal[1]'(unit = "m", quantity = "Length") "pathLengths used internally; to be defined by extending class";
    Real 'pipe.flowModel.Res_turbulent_internal[1]'(unit = "1", quantity = "ReynoldsNumber") "Re_turbulent used internally; to be defined by extending class";
    parameter Real 'pipe.flowModel.dp_nominal'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Nominal pressure loss (only for nominal models)";
    parameter Real 'pipe.flowModel.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 100.0 * 'pipe.flowModel.m_flow_small' "Nominal mass flow rate";
    parameter Real 'pipe.flowModel.m_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Within regularization if |m_flows| < m_flow_small (may be wider for large discontinuities in static head)";
    parameter Real 'pipe.flowModel.dp_small'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Within regularization if |dp| < dp_small (may be wider for large discontinuities in static head)";
    parameter Boolean 'pipe.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'pipe.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'pipe.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure loss for nominal conditions";
  initial equation
    pre('tank1.aboveLevel[1]') = 3.0 >= 'tank1.portsData_height2[1]';
    'tank1.level' = 3.0;
    'tank1.medium.T' = 323.15;
    pre('tank2.aboveLevel[1]') = 1.0 >= 'tank2.portsData_height2[1]';
    'tank2.level' = 1.0;
    'tank2.medium.T' = 373.15;
    'pipe.flowModel.dp_nominal' = 1000.0 * 'pipe.flowModel.dp_small';
    'pipe.flowModel.dp_small' = 1.0;
  equation
    'tank1.fluidVolume' = 'tank1.V';
    'tank1.medium.T_degC' = 'tank1.medium.T' - 273.15;
    'tank1.medium.p_bar' = 'tank1.medium.p' / 1e5;
    'tank1.heatTransfer.states[1].p' = 'tank1.medium.state.p';
    'tank1.heatTransfer.states[1].T' = 'tank1.medium.state.T';
    'tank2.fluidVolume' = 'tank2.V';
    'tank2.medium.T_degC' = 'tank2.medium.T' - 273.15;
    'tank2.medium.p_bar' = 'tank2.medium.p' / 1e5;
    'tank2.heatTransfer.states[1].p' = 'tank2.medium.state.p';
    'tank2.heatTransfer.states[1].T' = 'tank2.medium.state.T';
    'pipe.flowModel.dp_fric_nominal' = 'Modelica.Fluid.Examples.AST_BatchPlant.Test.TwoTanks.pipe.flowModel.WallFriction.pressureLoss_m_flow'('pipe.flowModel.m_flow_nominal', 995.586, 995.586, 0.001, 0.001, 'pipe.flowModel.pathLengths_internal[1]', 'pipe.flowModel.diameters[1]', ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') / 2.0, ('pipe.flowModel.roughnesses[1]' + 'pipe.flowModel.roughnesses[2]') / 2.0, 'pipe.flowModel.m_flow_small', 'pipe.flowModel.Res_turbulent_internal[1]');
    'tank1.portsData_diameter[1]' = 'tank1.portsData_diameter2[1]';
    'tank1.portsData_height[1]' = 'tank1.portsData_height2[1]';
    'tank2.portsData_diameter[1]' = 'tank2.portsData_diameter2[1]';
    'tank2.portsData_height[1]' = 'tank2.portsData_height2[1]';
    'tank1.ports[1].p' = 'pipe.port_a.p';
    'pipe.port_b.p' = 'tank2.ports[1].p';
    'pipe.port_a.m_flow' + 'tank1.ports[1].m_flow' = 0.0;
    'tank1.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'tank2.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'pipe.port_b.m_flow' + 'tank2.ports[1].m_flow' = 0.0;
