    'dcse.thermalAmbient.thermalPort.heatPortStrayLoad.Q_flow' + 'dcse.strayLoad.heatPort.Q_flow' - 'dcse.internalThermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcse.thermalAmbient.temperatureArmature.port.Q_flow' - 'dcse.thermalAmbient.thermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcse.thermalAmbient.temperatureCore.port.Q_flow' - 'dcse.thermalAmbient.thermalPort.heatPortCore.Q_flow' = 0.0;
    'dcse.thermalAmbient.temperatureStrayLoad.port.Q_flow' - 'dcse.thermalAmbient.thermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcse.thermalAmbient.temperatureFriction.port.Q_flow' - 'dcse.thermalAmbient.thermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcse.thermalAmbient.temperatureBrush.port.Q_flow' - 'dcse.thermalAmbient.thermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcse.thermalAmbient.temperatureSeriesExcitation.port.Q_flow' - 'dcse.thermalAmbient.thermalPort.heatPortSeriesExcitation.Q_flow' = 0.0;
    'dcse.internalThermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcse.internalThermalPort.heatPortCore.Q_flow' = 0.0;
