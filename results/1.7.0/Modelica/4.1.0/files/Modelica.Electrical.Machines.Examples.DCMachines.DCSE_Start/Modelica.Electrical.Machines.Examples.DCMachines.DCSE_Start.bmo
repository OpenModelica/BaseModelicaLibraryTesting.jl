    Real 'dcse.la.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'dcse.la.L'(start = 1.0, unit = "H", quantity = "Inductance") = 0.0015 "Inductance";
    parameter Boolean 'dcse.la.quasiStatic'(start = false) = false "No electrical transients if true" annotation(Evaluate = true);
    Real 'dcse.brush.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
