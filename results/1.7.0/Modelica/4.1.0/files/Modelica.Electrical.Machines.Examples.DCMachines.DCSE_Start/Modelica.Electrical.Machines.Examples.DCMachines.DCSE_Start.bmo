    'dcse.core.n.v' = 'dcse.airGapDC.pin_an.v';
    'dcse.thermalAmbient.thermalPort.heatPortSeriesExcitation.T' = 'dcse.internalThermalPort.heatPortSeriesExcitation.T';
    'dcse.thermalAmbient.thermalPort.heatPortSeriesExcitation.T' = 'dcse.re.heatPort.T';
