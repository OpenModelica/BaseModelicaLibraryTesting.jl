    'dcse.re.heatPort.Q_flow' + 'dcse.thermalAmbient.thermalPort.heatPortSeriesExcitation.Q_flow' - 'dcse.internalThermalPort.heatPortSeriesExcitation.Q_flow' = 0.0;
    'variableResistor.p.i' + 'constantVoltage.p.i' = 0.0;
