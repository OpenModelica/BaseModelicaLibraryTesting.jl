    'dcse.thermalAmbient.temperatureArmature.port.T' = 'dcse.thermalAmbient.temperatureArmature.T';
    'dcse.thermalAmbient.temperatureCore.port.T' = 293.15;
    'dcse.thermalAmbient.temperatureStrayLoad.port.T' = 293.15;
    'dcse.thermalAmbient.temperatureFriction.port.T' = 293.15;
    'dcse.thermalAmbient.constTa.y' = 293.15;
    'dcse.thermalAmbient.temperatureBrush.port.T' = 293.15;
    'dcse.thermalAmbient.temperatureSeriesExcitation.port.T' = 'dcse.thermalAmbient.temperatureSeriesExcitation.T';
    'dcse.thermalAmbient.constTse.y' = 293.15;
    'dcse.airGapDC.psi_e' = 5e-4 * 'dcse.airGapDC.ie';
    'dcse.airGapDC.vai' = 'dcse.airGapDC.pin_ap.v' - 'dcse.airGapDC.pin_an.v';
    'dcse.airGapDC.ia' = 'dcse.airGapDC.pin_ap.i';
    'dcse.airGapDC.ia' = -'dcse.airGapDC.pin_an.i';
    'dcse.airGapDC.vei' = 'dcse.airGapDC.pin_ep.v' - 'dcse.airGapDC.pin_en.v';
    'dcse.airGapDC.ie' = 'dcse.airGapDC.pin_ep.i';
    'dcse.airGapDC.ie' = -'dcse.airGapDC.pin_en.i';
    'dcse.airGapDC.vei' = der('dcse.airGapDC.psi_e');
    'dcse.airGapDC.w' = der('dcse.airGapDC.flange.phi') - der('dcse.airGapDC.support.phi');
    'dcse.airGapDC.vai' = 12.732395447351626 * 'dcse.airGapDC.psi_e' * 'dcse.airGapDC.w';
    'dcse.airGapDC.tauElectrical' = 12.732395447351626 * 'dcse.airGapDC.psi_e' * 'dcse.airGapDC.ia';
    'dcse.airGapDC.flange.tau' = -'dcse.airGapDC.tauElectrical';
    'dcse.airGapDC.support.tau' = 'dcse.airGapDC.tauElectrical';
    'dcse.compoundDCExcitation.pin_p.i' + 'dcse.compoundDCExcitation.pin_n.i' = 0.0;
    'dcse.compoundDCExcitation.pin_ep.i' + 'dcse.compoundDCExcitation.pin_en.i' = 0.0;
    'dcse.compoundDCExcitation.pin_sep.i' + 'dcse.compoundDCExcitation.pin_sen.i' = 0.0;
    -'dcse.compoundDCExcitation.i' = 'dcse.compoundDCExcitation.ie' + 'dcse.compoundDCExcitation.ise';
    'dcse.compoundDCExcitation.ve' = 'dcse.compoundDCExcitation.v';
    'dcse.compoundDCExcitation.vse' = 'dcse.compoundDCExcitation.v';
    'dcse.ground.p.v' = 0.0;
    'dcse.groundE.p.v' = 0.0;
    'dcse.re.R_actual' = 0.01;
    'dcse.re.v' = 'dcse.re.R_actual' * 'dcse.re.i';
    'dcse.re.LossPower' = 'dcse.re.v' * 'dcse.re.i';
    0.0 = 'dcse.re.p.i' + 'dcse.re.n.i';
    'dcse.re.i' = 'dcse.re.p.i';
    'dcse.re.v' = 'dcse.re.p.v' - 'dcse.re.n.v';
    'dcse.lesigma.v' = 0.0;
    0.0 = 'dcse.lesigma.p.i' + 'dcse.lesigma.n.i';
    'dcse.lesigma.i' = 'dcse.lesigma.p.i';
    'dcse.lesigma.v' = 'dcse.lesigma.p.v' - 'dcse.lesigma.n.v';
    'ramp.y' = 1.0 + (if time < 0.1 then 0.0 else if time < 1.0 then (time - 0.1) * (-1.0) / 0.9 else -1.0);
    'constantVoltage.v' = 100.0;
    0.0 = 'constantVoltage.p.i' + 'constantVoltage.n.i';
    'constantVoltage.i' = 'constantVoltage.p.i';
    'constantVoltage.v' = 'constantVoltage.p.v' - 'constantVoltage.n.v';
    'ground.p.v' = 0.0;
    'loadInertia.phi' = 'loadInertia.flange_a.phi';
    'loadInertia.phi' = 'loadInertia.flange_b.phi';
    'loadInertia.w' = der('loadInertia.phi');
    'loadInertia.a' = der('loadInertia.w');
    0.15 * 'loadInertia.a' = 'loadInertia.flange_a.tau' + 'loadInertia.flange_b.tau';
    'quadraticLoadTorque.w' = der('quadraticLoadTorque.phi');
    'quadraticLoadTorque.tau' = -'quadraticLoadTorque.flange.tau';
    'quadraticLoadTorque.tau' = (-63.66) * smooth(1, if 'quadraticLoadTorque.w' >= 0.0 then ('quadraticLoadTorque.w' / 147.6548547187203) ^ 2.0 else -('quadraticLoadTorque.w' / 147.6548547187203) ^ 2.0);
    'quadraticLoadTorque.phi' = 'quadraticLoadTorque.flange.phi' - 'quadraticLoadTorque.phi_support';
    'quadraticLoadTorque.phi_support' = 0.0;
    'variableResistor.R_actual' = 'variableResistor.R';
    'variableResistor.v' = 'variableResistor.R_actual' * 'variableResistor.i';
    'variableResistor.LossPower' = 'variableResistor.v' * 'variableResistor.i';
    'variableResistor.T_heatPort' = 300.15;
    0.0 = 'variableResistor.p.i' + 'variableResistor.n.i';
    'variableResistor.i' = 'variableResistor.p.i';
    'variableResistor.v' = 'variableResistor.p.v' - 'variableResistor.n.v';
    annotation(experiment(StopTime = 2.0, Interval = 1E-4, Tolerance = 1E-6));
  end 'DCSE_Start';
end 'DCSE_Start';
