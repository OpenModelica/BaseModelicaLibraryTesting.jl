    parameter Real 'dcseData.wNominal'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 147.6548547187203 "Nominal speed";
    parameter Real 'dcseData.TaNominal'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Nominal armature temperature";
    parameter Real 'dcseData.Ra'(unit = "Ohm", quantity = "Resistance") = 0.05 "Armature resistance at TaRef";
    parameter Real 'dcseData.TaRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of armature resistance";
    parameter Real 'dcseData.alpha20a'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of armature resistance";
    parameter Real 'dcseData.La'(unit = "H", quantity = "Inductance") = 0.0015 "Armature inductance";
    parameter Real 'dcseData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'dcseData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 147.6548547187203 "Reference angular velocity that the PRef refer to";
    parameter Real 'dcseData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'dcseData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'dcseData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'dcseData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.14765485471872028 "Linear angular velocity range";
    parameter Real 'dcseData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Real 'dcseData.ViNominal'(unit = "V", quantity = "ElectricPotential") = 95.0 "Induced voltage at nominal operating point";
    parameter Integer 'dcseData.coreParameters.m' = 1 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'dcseData.coreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'dcseData.coreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 95.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'dcseData.coreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 147.6548547187203 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'dcseData.coreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'dcseData.coreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'dcseData.coreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 1.4765485471872027e-4 "Angular velocity limit";
    parameter Real 'dcseData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'dcseData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'dcseData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 147.6548547187203 "Reference angular velocity that PRef refers to";
    parameter Real 'dcseData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'dcseData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'dcseData.brushParameters.V'(unit = "V", quantity = "ElectricPotential") = 0.0 "Total voltage drop of brushes for currents > ILinear";
    parameter Real 'dcseData.brushParameters.ILinear'(start = 0.01, unit = "A", quantity = "ElectricCurrent") = 1.0 "Current indicating linear voltage region of brush voltage drop";
    parameter Real 'dcseData.Re'(unit = "Ohm", quantity = "Resistance") = 0.01 "Series excitation resistance at TeRef";
    parameter Real 'dcseData.TeRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of excitation resistance";
    parameter Real 'dcseData.alpha20e'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of excitation resistance";
    parameter Real 'dcseData.Le'(unit = "H", quantity = "Inductance") = 5e-4 "Total field excitation inductance";
    parameter Real 'dcseData.sigmae'(max = 0.99, min = 0.0) = 0.0 "Stray fraction of total excitation inductance";
    parameter Real 'dcseData.TeNominal'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Nominal series excitation temperature";
  equation
    'dcse.phiMechanical' = 'dcse.flange.phi' - 'dcse.internalSupport.phi';
    'dcse.wMechanical' = der('dcse.phiMechanical');
    'dcse.tauElectrical' = 'dcse.inertiaRotor.flange_a.tau';
    'dcse.tauShaft' = -'dcse.flange.tau';
    'dcse.friction.heatPort.Q_flow' = -'dcse.friction.lossPower';
    'dcse.powerBalance.powerArmature' = 'dcse.va' * 'dcse.ia';
    'dcse.powerBalance.powerMechanical' = 'dcse.wMechanical' * 'dcse.tauShaft';
    'dcse.powerBalance.powerInertiaStator' = 0.15 * 'dcse.inertiaStator.a' * 'dcse.inertiaStator.w';
    'dcse.powerBalance.powerInertiaRotor' = 0.15 * 'dcse.inertiaRotor.a' * 'dcse.inertiaRotor.w';
    'dcse.powerBalance.lossPowerTotal' = 'dcse.powerBalance.lossPowerArmature' + 'dcse.powerBalance.lossPowerCore' + 'dcse.powerBalance.lossPowerStrayLoad' + 'dcse.powerBalance.lossPowerFriction' + 'dcse.powerBalance.lossPowerBrush' + 'dcse.powerBalance.lossPowerSeriesExcitation';
    'dcse.powerBalance.lossPowerArmature' = 'dcse.ra.LossPower';
    'dcse.powerBalance.lossPowerCore' = 'dcse.core.lossPower';
    'dcse.powerBalance.lossPowerStrayLoad' = 'dcse.strayLoad.lossPower';
    'dcse.powerBalance.lossPowerFriction' = 'dcse.friction.lossPower';
    'dcse.powerBalance.lossPowerBrush' = 'dcse.brush.lossPower';
    'dcse.powerBalance.powerSeriesExcitation' = 'dcse.ve' * 'dcse.ie';
    'dcse.powerBalance.lossPowerSeriesExcitation' = 'dcse.re.LossPower';
    'dcse.va' = 'dcse.pin_ap.v' - 'dcse.pin_an.v';
    'dcse.ia' = 'dcse.pin_ap.i';
    'dcse.ra.heatPort.T' = 'dcse.ra.T_heatPort';
    'dcse.ra.heatPort.Q_flow' = -'dcse.ra.LossPower';
    'dcse.brush.heatPort.Q_flow' = -'dcse.brush.lossPower';
    'dcse.core.heatPort.Q_flow' = -'dcse.core.lossPower';
    'dcse.core.w' = 'dcse.airGapDC.w';
    'dcse.core.wLimit' = noEvent(max(noEvent(abs('dcse.core.w')), 'dcse.core.coreParameters.wMin'));
    'dcse.strayLoad.heatPort.Q_flow' = -'dcse.strayLoad.lossPower';
    'dcse.thermalAmbient.Q_flowArmature' = 'dcse.thermalAmbient.temperatureArmature.port.Q_flow';
    'dcse.thermalAmbient.Q_flowCore' = 'dcse.thermalAmbient.temperatureCore.port.Q_flow';
