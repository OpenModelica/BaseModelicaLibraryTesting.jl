    'dcse.thermalAmbient.Q_flowFriction' = 'dcse.thermalAmbient.temperatureFriction.port.Q_flow';
    'dcse.thermalAmbient.Q_flowBrush' = 'dcse.thermalAmbient.temperatureBrush.port.Q_flow';
    'dcse.thermalAmbient.Q_flowSeriesExcitation' = 'dcse.thermalAmbient.temperatureSeriesExcitation.port.Q_flow';
    'dcse.thermalAmbient.Q_flowTotal' = 'dcse.thermalAmbient.Q_flowArmature' + 'dcse.thermalAmbient.Q_flowCore' + 'dcse.thermalAmbient.Q_flowStrayLoad' + 'dcse.thermalAmbient.Q_flowFriction' + 'dcse.thermalAmbient.Q_flowBrush' + 'dcse.thermalAmbient.Q_flowSeriesExcitation';
    'dcse.ve' = 'dcse.pin_ep.v' - 'dcse.pin_en.v';
    'dcse.ie' = 'dcse.pin_ep.i';
    'dcse.compoundDCExcitation.v' = 'dcse.compoundDCExcitation.pin_p.v' - 'dcse.compoundDCExcitation.pin_n.v';
    'dcse.compoundDCExcitation.i' = 'dcse.compoundDCExcitation.pin_p.i';
    'dcse.compoundDCExcitation.ve' = 'dcse.compoundDCExcitation.pin_ep.v' - 'dcse.compoundDCExcitation.pin_en.v';
    'dcse.compoundDCExcitation.ie' = 'dcse.compoundDCExcitation.pin_ep.i';
    'dcse.compoundDCExcitation.vse' = 'dcse.compoundDCExcitation.pin_sep.v' - 'dcse.compoundDCExcitation.pin_sen.v';
    'dcse.compoundDCExcitation.ise' = 'dcse.compoundDCExcitation.pin_sep.i';
    'dcse.re.heatPort.T' = 'dcse.re.T_heatPort';
    'dcse.re.heatPort.Q_flow' = -'dcse.re.LossPower';
    'dcse.thermalAmbient.constTse.y' = 'dcse.thermalAmbient.temperatureSeriesExcitation.T';
    'dcse.thermalAmbient.temperatureSeriesExcitation.port.T' = 'dcse.thermalAmbient.thermalPort.heatPortSeriesExcitation.T';
    'dcse.thermalAmbient.constTa.y' = 'dcse.thermalAmbient.temperatureArmature.T';
    'dcse.thermalAmbient.temperatureArmature.port.T' = 'dcse.thermalAmbient.thermalPort.heatPortArmature.T';
