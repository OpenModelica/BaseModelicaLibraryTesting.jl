    'dcse.re.n.v' = 'dcse.lesigma.p.v';
    'dcse.airGapDC.pin_en.v' = 'dcse.ground.p.v';
    'dcse.airGapDC.pin_en.v' = 'dcse.compoundDCExcitation.pin_n.v';
    'dcse.compoundDCExcitation.pin_p.v' = 'dcse.airGapDC.pin_ep.v';
    'dcse.compoundDCExcitation.pin_sen.v' = 'dcse.pin_en.v';
    'dcse.compoundDCExcitation.pin_sep.v' = 'dcse.lesigma.n.v';
