    'dcse.internalThermalPort.heatPortSeriesExcitation.Q_flow' = 0.0;
    'dcse.airGapDC.flange.tau' + 'dcse.inertiaRotor.flange_a.tau' = 0.0;
    'dcse.airGapDC.support.tau' + 'dcse.strayLoad.support.tau' + 'dcse.friction.support.tau' + 'dcse.fixed.flange.tau' + 'dcse.inertiaStator.flange_a.tau' - 'dcse.internalSupport.tau' = 0.0;
    'dcse.airGapDC.pin_ap.i' + 'dcse.la.n.i' = 0.0;
    'dcse.airGapDC.pin_an.i' + 'dcse.core.n.i' + 'dcse.brush.p.i' = 0.0;
