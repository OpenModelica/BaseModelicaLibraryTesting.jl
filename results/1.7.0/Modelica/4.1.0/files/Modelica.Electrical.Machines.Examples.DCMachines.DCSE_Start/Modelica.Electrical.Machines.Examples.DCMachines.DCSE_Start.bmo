    'dcse.thermalAmbient.temperatureFriction.port.T' = 'dcse.thermalAmbient.thermalPort.heatPortFriction.T';
    'dcse.airGapDC.pin_ap.v' = 'dcse.la.n.v';
    'dcse.friction.support.phi' = 'dcse.internalSupport.phi';
