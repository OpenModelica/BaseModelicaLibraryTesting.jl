    'dcse.la.p.v' = 'dcse.ra.n.v';
    'dcse.brush.n.v' = 'dcse.pin_an.v';
    'dcse.pin_ap.v' = 'dcse.strayLoad.p.v';
    'dcse.strayLoad.p.i' - 'dcse.pin_ap.i' = 0.0;
    'dcse.strayLoad.n.v' = 'dcse.ra.p.v';
    'dcse.thermalAmbient.thermalPort.heatPortCore.T' = 'dcse.internalThermalPort.heatPortCore.T';
    'dcse.thermalAmbient.thermalPort.heatPortCore.T' = 'dcse.core.heatPort.T';
    'dcse.thermalAmbient.thermalPort.heatPortBrush.T' = 'dcse.internalThermalPort.heatPortBrush.T';
    'dcse.thermalAmbient.thermalPort.heatPortBrush.T' = 'dcse.brush.heatPort.T';
    'dcse.thermalAmbient.thermalPort.heatPortStrayLoad.T' = 'dcse.internalThermalPort.heatPortStrayLoad.T';
    'dcse.thermalAmbient.thermalPort.heatPortStrayLoad.T' = 'dcse.strayLoad.heatPort.T';
    'dcse.thermalAmbient.thermalPort.heatPortFriction.T' = 'dcse.internalThermalPort.heatPortFriction.T';
    'dcse.thermalAmbient.thermalPort.heatPortFriction.T' = 'dcse.friction.heatPort.T';
    'dcse.thermalAmbient.thermalPort.heatPortArmature.T' = 'dcse.internalThermalPort.heatPortArmature.T';
    'dcse.thermalAmbient.thermalPort.heatPortArmature.T' = 'dcse.ra.heatPort.T';
    'dcse.inertiaRotor.flange_b.phi' = 'dcse.friction.flange.phi';
    'dcse.inertiaRotor.flange_b.phi' = 'dcse.flange.phi';
    'dcse.inertiaRotor.flange_b.phi' = 'dcse.strayLoad.flange.phi';
    'dcse.strayLoad.flange.tau' + 'dcse.friction.flange.tau' + 'dcse.inertiaRotor.flange_b.tau' - 'dcse.flange.tau' = 0.0;
    'dcse.pin_en.v' = 'constantVoltage.n.v';
    'dcse.pin_en.v' = 'ground.p.v';
    'loadInertia.flange_b.phi' = 'quadraticLoadTorque.flange.phi';
    'dcse.pin_an.v' = 'dcse.pin_ep.v';
    'dcse.flange.phi' = 'loadInertia.flange_a.phi';
    'constantVoltage.p.v' = 'variableResistor.p.v';
    'variableResistor.n.v' = 'dcse.pin_ap.v';
    'ramp.y' = 'variableResistor.R';
    'loadInertia.flange_a.tau' + 'dcse.flange.tau' = 0.0;
    'dcse.inertiaStator.flange_b.tau' = 0.0;
    'dcse.thermalAmbient.thermalPort.heatPortFriction.Q_flow' + 'dcse.friction.heatPort.Q_flow' - 'dcse.internalThermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcse.internalSupport.tau' = 0.0;
    'dcse.pin_ep.i' + 'dcse.pin_an.i' = 0.0;
    'dcse.core.p.i' + 'dcse.la.p.i' + 'dcse.ra.n.i' = 0.0;
    'dcse.thermalAmbient.thermalPort.heatPortArmature.Q_flow' + 'dcse.ra.heatPort.Q_flow' - 'dcse.internalThermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcse.brush.n.i' - 'dcse.pin_an.i' = 0.0;
    'dcse.thermalAmbient.thermalPort.heatPortBrush.Q_flow' + 'dcse.brush.heatPort.Q_flow' - 'dcse.internalThermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcse.thermalAmbient.thermalPort.heatPortCore.Q_flow' + 'dcse.core.heatPort.Q_flow' - 'dcse.internalThermalPort.heatPortCore.Q_flow' = 0.0;
