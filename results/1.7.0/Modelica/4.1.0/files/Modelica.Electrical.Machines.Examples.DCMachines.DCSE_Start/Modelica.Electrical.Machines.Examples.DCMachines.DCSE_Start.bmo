    parameter Real 'dcse.thermalAmbient.Ta'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Temperature of armature";
    Real 'dcse.thermalAmbient.Q_flowArmature'(unit = "W", quantity = "Power") "Heat flow rate of armature";
