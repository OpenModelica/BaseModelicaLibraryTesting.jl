    'mn2.G.v' = 'mp2.G.v';
    'mn1.S.v' = 'mn2.D.v';
    'mp2.S.v' = 'mn1.D.v';
    'mp2.S.v' = 'mp1.S.v';
    'mn1.D.i' + 'mp2.S.i' + 'mp1.S.i' = 0.0;
    'vconstant.p.i' + 'mp2.B.i' + 'mp2.D.i' + 'mp1.B.i' + 'mp1.D.i' = 0.0;
    'vin2.p.i' + 'mn2.G.i' + 'mp2.G.i' = 0.0;
    'vin1.p.i' + 'mn1.G.i' + 'mp1.G.i' = 0.0;
    'mn1.S.i' + 'mn2.D.i' = 0.0;
    'vin2.n.i' + 'vin1.n.i' + 'ground.p.i' + 'vconstant.n.i' + 'mn1.B.i' + 'mn2.B.i' + 'mn2.S.i' = 0.0;
