    'mn1.icGS' = 'mn1.cc.cGS' * (der('mn1.G.v') - der('mn1.Sinternal'));
    'mn1.ibsgmin' = 1e-12 * ('mn1.B.v' - 'mn1.Sinternal');
    'mn1.ibdgmin' = 1e-12 * ('mn1.B.v' - 'mn1.Dinternal');
    'mn1.G.i' = 'mn1.icGB' + 'mn1.icGD' + 'mn1.icGS';
    'mn1.B.i' = 'mn1.cc.iBD' + 'mn1.cc.iBS' + 'mn1.ibdgmin' + 'mn1.ibsgmin' - 'mn1.icGB' + 'mn1.icBD' + 'mn1.icBS';
    'mn1.D.i' = 'mn1.ird';
    'mn1.S.i' = 'mn1.irs';
    0.0 = 'mn1.cc.idrain' - 'mn1.ird' - 'mn1.cc.iBD' - 'mn1.ibdgmin' - 'mn1.icGD' - 'mn1.icBD';
    0.0 = -('mn1.irs' + 'mn1.cc.idrain' + 'mn1.cc.iBS' + 'mn1.ibsgmin' + 'mn1.icGS' + 'mn1.icBS');
    'vconstant.v' = 5.0;
    0.0 = 'vconstant.p.i' + 'vconstant.n.i';
    'vconstant.i' = 'vconstant.p.i';
    'vconstant.v' = 'vconstant.p.v' - 'vconstant.n.v';
    'ground.p.v' = 0.0;

    when pre('vin1.counter2') <> 0 and sample(2e-8, 8e-8) then
      'vin1.T0' = time;
      'vin1.counter2' = pre('vin1.counter');
      'vin1.counter' = pre('vin1.counter') - (if pre('vin1.counter') > 0 then 1 else 0);
    end when;

    'vin1.v' = if (time < 2e-8 or 'vin1.counter2' == 0) or time >= 'vin1.T0' + 4.2000000000000006e-8 then 0.0 else if time < 'vin1.T0' + 1e-9 then (time - 'vin1.T0') * 5.0 / 1e-9 else if time < 'vin1.T0' + 4.1e-8 then 5.0 else ('vin1.T0' + 4.2000000000000006e-8 - time) * 5.0 / 1.0000000000000023e-9;
    0.0 = 'vin1.p.i' + 'vin1.n.i';
    'vin1.i' = 'vin1.p.i';
    'vin1.v' = 'vin1.p.v' - 'vin1.n.v';

    when pre('vin2.counter2') <> 0 and sample(1e-8, 8e-8) then
      'vin2.T0' = time;
      'vin2.counter2' = pre('vin2.counter');
      'vin2.counter' = pre('vin2.counter') - (if pre('vin2.counter') > 0 then 1 else 0);
    end when;

    'vin2.v' = if (time < 1e-8 or 'vin2.counter2' == 0) or time >= 'vin2.T0' + 4.2000000000000006e-8 then 0.0 else if time < 'vin2.T0' + 1e-9 then (time - 'vin2.T0') * 5.0 / 1e-9 else if time < 'vin2.T0' + 4.1e-8 then 5.0 else ('vin2.T0' + 4.2000000000000006e-8 - time) * 5.0 / 1.0000000000000023e-9;
    0.0 = 'vin2.p.i' + 'vin2.n.i';
    'vin2.i' = 'vin2.p.i';
    'vin2.v' = 'vin2.p.v' - 'vin2.n.v';
    annotation(experiment(StopTime = 2e-007));
  end 'Nand';
end 'Nand';
