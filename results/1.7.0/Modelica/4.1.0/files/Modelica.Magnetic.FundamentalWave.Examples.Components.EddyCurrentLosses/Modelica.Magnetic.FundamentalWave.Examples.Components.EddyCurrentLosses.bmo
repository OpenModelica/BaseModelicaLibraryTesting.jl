    Real 'star_e.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'star_m.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star_m.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star_m.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
