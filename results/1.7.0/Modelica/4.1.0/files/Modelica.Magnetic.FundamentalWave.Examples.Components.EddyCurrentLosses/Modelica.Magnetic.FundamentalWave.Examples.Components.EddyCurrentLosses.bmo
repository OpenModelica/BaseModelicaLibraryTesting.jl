//! base 0.1.0
package 'EddyCurrentLosses'
  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  model 'EddyCurrentLosses' "Comparison of equivalent circuits of eddy current loss models"
    parameter Integer 'm' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'R'(unit = "Ohm", quantity = "Resistance") = 0.1 "Resistance of leader cables";
    parameter Real 'Gc'(unit = "S", quantity = "Conductance") = 1.0 "Loss conductance";
    parameter Real 'R_m'(unit = "H-1", quantity = "Reluctance") = 1.0 "Reluctance of the magnetic circuit";
    parameter Real 'N' = 1.0 "Number of turns";
    output Real 'lossPower_e'(unit = "W", quantity = "Power");
    output Real 'lossPower_m'(unit = "W", quantity = "Power");
    Real 'ground_e.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground_e.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ground_m.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground_m.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'star_e.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star_e.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star_e.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
