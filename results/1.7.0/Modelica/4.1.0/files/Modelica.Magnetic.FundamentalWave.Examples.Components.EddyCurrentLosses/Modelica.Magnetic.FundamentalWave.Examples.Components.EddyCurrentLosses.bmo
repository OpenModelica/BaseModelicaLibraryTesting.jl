    'powerb_m.voltageSensor.voltageSensor[3].p.i' = 0.0;
    'powerb_m.voltageSensor.voltageSensor[3].n.i' = 0.0;
    'powerb_m.voltageSensor.voltageSensor[3].v' = 'powerb_m.voltageSensor.voltageSensor[3].p.v' - 'powerb_m.voltageSensor.voltageSensor[3].n.v';
    'powerb_m.currentSensor.currentSensor[1].p.v' = 'powerb_m.currentSensor.currentSensor[1].n.v';
    'powerb_m.currentSensor.currentSensor[1].p.i' = 'powerb_m.currentSensor.currentSensor[1].i';
    'powerb_m.currentSensor.currentSensor[1].n.i' = -'powerb_m.currentSensor.currentSensor[1].i';
    'powerb_m.currentSensor.currentSensor[2].p.v' = 'powerb_m.currentSensor.currentSensor[2].n.v';
    'powerb_m.currentSensor.currentSensor[2].p.i' = 'powerb_m.currentSensor.currentSensor[2].i';
    'powerb_m.currentSensor.currentSensor[2].n.i' = -'powerb_m.currentSensor.currentSensor[2].i';
    'powerb_m.currentSensor.currentSensor[3].p.v' = 'powerb_m.currentSensor.currentSensor[3].n.v';
    'powerb_m.currentSensor.currentSensor[3].p.i' = 'powerb_m.currentSensor.currentSensor[3].i';
    'powerb_m.currentSensor.currentSensor[3].n.i' = -'powerb_m.currentSensor.currentSensor[3].i';
    'powerb_m.product[1].y' = 'powerb_m.product[1].u1' * 'powerb_m.product[1].u2';
    'powerb_m.product[2].y' = 'powerb_m.product[2].u1' * 'powerb_m.product[2].u2';
    'powerb_m.product[3].y' = 'powerb_m.product[3].u1' * 'powerb_m.product[3].u2';
    'powerb_m.sum.y' = 'powerb_m.sum.u[1]' + 'powerb_m.sum.u[2]' + 'powerb_m.sum.u[3]';
    annotation(experiment(StopTime = 40, Interval = 0.01));
  end 'EddyCurrentLosses';
end 'EddyCurrentLosses';
