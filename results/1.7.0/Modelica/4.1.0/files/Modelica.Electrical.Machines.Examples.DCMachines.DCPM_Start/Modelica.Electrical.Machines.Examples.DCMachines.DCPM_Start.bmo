    Real 'dcpm.thermalAmbient.thermalPort.heatPortArmature.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortArmature.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortCore.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortCore.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortStrayLoad.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortStrayLoad.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortFriction.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortFriction.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
