    Real 'dcpm.ra.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'dcpm.la.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'dcpm.la.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.la.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
