    parameter Real 'dcpm.thermalAmbient.constTpm.k'(start = 1.0) = 293.15 "Constant output value";
    Real 'dcpm.thermalAmbient.constTpm.y' "Connector of Real output signal";
    constant Real 'dcpm.pi' = 3.141592653589793;
    constant Boolean 'dcpm.quasiStatic' = false "No electrical transients if true" annotation(Evaluate = true);
    parameter Real 'dcpm.ViNominal'(unit = "V", quantity = "ElectricPotential") = 95.0 "Nominal induced Voltage";
    parameter Real 'dcpm.psi_eNominal'(unit = "Wb", quantity = "MagneticFlux") = 1.0 "Nominal magnetic flux";
    parameter Real 'dcpm.turnsRatio' = 0.6366197723675815 "Ratio of armature turns over number of turns of the excitation winding";
    Real 'dcpm.internalThermalPort.heatPortArmature.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.internalThermalPort.heatPortArmature.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.internalThermalPort.heatPortCore.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.internalThermalPort.heatPortCore.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.internalThermalPort.heatPortStrayLoad.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.internalThermalPort.heatPortStrayLoad.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.internalThermalPort.heatPortFriction.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.internalThermalPort.heatPortFriction.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.internalThermalPort.heatPortBrush.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.internalThermalPort.heatPortBrush.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.internalThermalPort.heatPortPermanentMagnet.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.internalThermalPort.heatPortPermanentMagnet.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'dcpm.TpmOperational'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of permanent magnet";
    parameter Boolean 'dcpm.airGapDC.quasiStatic'(start = false) = false "No electrical transients if true" annotation(Evaluate = true);
    parameter Real 'dcpm.airGapDC.turnsRatio' = 0.6366197723675815 "Ratio of armature turns over number of turns of the excitation winding";
    Real 'dcpm.airGapDC.w'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity";
    Real 'dcpm.airGapDC.vei'(unit = "V", quantity = "ElectricPotential") "Voltage drop across field excitation inductance";
    Real 'dcpm.airGapDC.ie'(unit = "A", quantity = "ElectricCurrent") "Excitation current";
    Real 'dcpm.airGapDC.psi_e'(unit = "Wb", quantity = "MagneticFlux") "Excitation flux";
    Real 'dcpm.airGapDC.vai'(unit = "V", quantity = "ElectricPotential") "Induced armature voltage";
    Real 'dcpm.airGapDC.ia'(unit = "A", quantity = "ElectricCurrent") "Armature current";
    Real 'dcpm.airGapDC.tauElectrical'(unit = "N.m", quantity = "Torque");
    Real 'dcpm.airGapDC.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.airGapDC.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.airGapDC.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.airGapDC.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.airGapDC.pin_ap.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.airGapDC.pin_ap.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.airGapDC.pin_ep.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.airGapDC.pin_ep.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.airGapDC.pin_an.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.airGapDC.pin_an.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.airGapDC.pin_en.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.airGapDC.pin_en.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'dcpm.airGapDC.Le'(unit = "H", quantity = "Inductance") = 1.0 "Excitation inductance";
    Real 'dcpm.eGround.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.eGround.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'dcpm.ie.I'(start = 1.0, unit = "A", quantity = "ElectricCurrent") = 1.0 "Value of constant current";
    Real 'dcpm.ie.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'dcpm.ie.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.ie.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.ie.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.ie.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.ie.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    constant Real 'dcpm.Lme'(unit = "H", quantity = "Inductance") = 1.0 "Field excitation inductance";
    constant Real 'dcpm.IeNominal'(unit = "A", quantity = "ElectricCurrent") = 1.0 "Equivalent excitation current";
    parameter Real 'ramp.height' = 100.0 "Height of ramp";
    parameter Real 'ramp.duration'(start = 2.0, min = 0.0, unit = "s", quantity = "Time") = 0.8 "Duration of ramp (= 0.0 gives a Step)";
    Real 'ramp.y' "Connector of Real output signal";
    parameter Real 'ramp.offset' = 0.0 "Offset of output signal y";
    parameter Real 'ramp.startTime'(unit = "s", quantity = "Time") = 0.2 "Output y = offset for time < startTime";
    Real 'signalVoltage.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalVoltage.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalVoltage.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalVoltage.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalVoltage.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'signalVoltage.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'loadInertia.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadInertia.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'loadInertia.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadInertia.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'loadInertia.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Moment of inertia";
    parameter StateSelect 'loadInertia.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'loadInertia.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'loadInertia.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'loadInertia.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Boolean 'loadTorqueStep.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'loadTorqueStep.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadTorqueStep.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'loadTorqueStep.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'loadTorqueStep.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of flange with respect to support (= flange.phi - support.phi)";
    parameter Real 'loadTorqueStep.stepTorque'(start = 1.0, unit = "N.m", quantity = "Torque") = -63.66 "Height of torque step (if negative, torque is acting as load)";
    parameter Real 'loadTorqueStep.offsetTorque'(start = 0.0, unit = "N.m", quantity = "Torque") = 0.0 "Offset of torque";
    parameter Real 'loadTorqueStep.startTime'(unit = "s", quantity = "Time") = 1.5 "Torque = offset for time < startTime";
    Real 'loadTorqueStep.tau'(unit = "N.m", quantity = "Torque") "Accelerating torque acting at flange (= -flange.tau)";
    parameter Real 'dcpmData.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Rotor's moment of inertia";
    parameter Real 'dcpmData.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Stator's moment of inertia";
    parameter Real 'dcpmData.VaNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal armature voltage";
    parameter Real 'dcpmData.IaNominal'(unit = "A", quantity = "ElectricCurrent") = 100.0 "Nominal armature current (>0..Motor, <0..Generator)";
    parameter Real 'dcpmData.wNominal'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Nominal speed";
    parameter Real 'dcpmData.TaNominal'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Nominal armature temperature";
    parameter Real 'dcpmData.Ra'(unit = "Ohm", quantity = "Resistance") = 0.05 "Armature resistance at TaRef";
    parameter Real 'dcpmData.TaRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of armature resistance";
    parameter Real 'dcpmData.alpha20a'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of armature resistance";
    parameter Real 'dcpmData.La'(unit = "H", quantity = "Inductance") = 0.0015 "Armature inductance";
    parameter Real 'dcpmData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'dcpmData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that the PRef refer to";
    parameter Real 'dcpmData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'dcpmData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'dcpmData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'dcpmData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.14922565104551516 "Linear angular velocity range";
    parameter Real 'dcpmData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Real 'dcpmData.ViNominal'(unit = "V", quantity = "ElectricPotential") = 95.0 "Induced voltage at nominal operating point";
    parameter Integer 'dcpmData.coreParameters.m' = 1 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'dcpmData.coreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'dcpmData.coreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 95.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'dcpmData.coreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'dcpmData.coreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'dcpmData.coreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'dcpmData.coreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 1.4922565104551514e-4 "Angular velocity limit";
    parameter Real 'dcpmData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'dcpmData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'dcpmData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that PRef refers to";
    parameter Real 'dcpmData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'dcpmData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'dcpmData.brushParameters.V'(unit = "V", quantity = "ElectricPotential") = 0.0 "Total voltage drop of brushes for currents > ILinear";
    parameter Real 'dcpmData.brushParameters.ILinear'(start = 0.01, unit = "A", quantity = "ElectricCurrent") = 1.0 "Current indicating linear voltage region of brush voltage drop";
  equation
    'dcpm.phiMechanical' = 'dcpm.flange.phi' - 'dcpm.internalSupport.phi';
    'dcpm.wMechanical' = der('dcpm.phiMechanical');
    'dcpm.tauElectrical' = 'dcpm.inertiaRotor.flange_a.tau';
    'dcpm.tauShaft' = -'dcpm.flange.tau';
    'dcpm.friction.heatPort.Q_flow' = -'dcpm.friction.lossPower';
    'dcpm.powerBalance.powerArmature' = 'dcpm.va' * 'dcpm.ia';
    'dcpm.powerBalance.powerMechanical' = 'dcpm.wMechanical' * 'dcpm.tauShaft';
    'dcpm.powerBalance.powerInertiaStator' = 0.15 * 'dcpm.inertiaStator.a' * 'dcpm.inertiaStator.w';
    'dcpm.powerBalance.powerInertiaRotor' = 0.15 * 'dcpm.inertiaRotor.a' * 'dcpm.inertiaRotor.w';
    'dcpm.powerBalance.lossPowerTotal' = 'dcpm.powerBalance.lossPowerArmature' + 'dcpm.powerBalance.lossPowerCore' + 'dcpm.powerBalance.lossPowerStrayLoad' + 'dcpm.powerBalance.lossPowerFriction' + 'dcpm.powerBalance.lossPowerBrush' + 'dcpm.powerBalance.lossPowerPermanentMagnet';
    'dcpm.powerBalance.lossPowerArmature' = 'dcpm.ra.LossPower';
    'dcpm.powerBalance.lossPowerCore' = 'dcpm.core.lossPower';
    'dcpm.powerBalance.lossPowerStrayLoad' = 'dcpm.strayLoad.lossPower';
    'dcpm.powerBalance.lossPowerFriction' = 'dcpm.friction.lossPower';
    'dcpm.powerBalance.lossPowerBrush' = 'dcpm.brush.lossPower';
    'dcpm.powerBalance.lossPowerPermanentMagnet' = 0.0;
    'dcpm.va' = 'dcpm.pin_ap.v' - 'dcpm.pin_an.v';
    'dcpm.ia' = 'dcpm.pin_ap.i';
    'dcpm.ra.heatPort.T' = 'dcpm.ra.T_heatPort';
    'dcpm.ra.heatPort.Q_flow' = -'dcpm.ra.LossPower';
    'dcpm.brush.heatPort.Q_flow' = -'dcpm.brush.lossPower';
    'dcpm.core.heatPort.Q_flow' = -'dcpm.core.lossPower';
    'dcpm.core.w' = 'dcpm.airGapDC.w';
    'dcpm.core.wLimit' = noEvent(max(noEvent(abs('dcpm.core.w')), 'dcpm.core.coreParameters.wMin'));
    'dcpm.strayLoad.heatPort.Q_flow' = -'dcpm.strayLoad.lossPower';
    'dcpm.thermalAmbient.Q_flowArmature' = 'dcpm.thermalAmbient.temperatureArmature.port.Q_flow';
    'dcpm.thermalAmbient.Q_flowCore' = 'dcpm.thermalAmbient.temperatureCore.port.Q_flow';
    'dcpm.thermalAmbient.Q_flowStrayLoad' = 'dcpm.thermalAmbient.temperatureStrayLoad.port.Q_flow';
    'dcpm.thermalAmbient.Q_flowFriction' = 'dcpm.thermalAmbient.temperatureFriction.port.Q_flow';
    'dcpm.thermalAmbient.Q_flowBrush' = 'dcpm.thermalAmbient.temperatureBrush.port.Q_flow';
    'dcpm.thermalAmbient.Q_flowPermanentMagnet' = 'dcpm.thermalAmbient.temperaturePermanentMagnet.port.Q_flow';
    'dcpm.thermalAmbient.Q_flowTotal' = 'dcpm.thermalAmbient.Q_flowArmature' + 'dcpm.thermalAmbient.Q_flowCore' + 'dcpm.thermalAmbient.Q_flowStrayLoad' + 'dcpm.thermalAmbient.Q_flowFriction' + 'dcpm.thermalAmbient.Q_flowBrush' + 'dcpm.thermalAmbient.Q_flowPermanentMagnet';
    'dcpm.thermalAmbient.temperaturePermanentMagnet.port.T' = 'dcpm.thermalAmbient.thermalPort.heatPortPermanentMagnet.T';
    'dcpm.thermalAmbient.constTpm.y' = 'dcpm.thermalAmbient.temperaturePermanentMagnet.T';
    'dcpm.thermalAmbient.constTa.y' = 'dcpm.thermalAmbient.temperatureArmature.T';
    'dcpm.thermalAmbient.temperatureArmature.port.T' = 'dcpm.thermalAmbient.thermalPort.heatPortArmature.T';
    'dcpm.thermalAmbient.temperatureBrush.port.T' = 'dcpm.thermalAmbient.thermalPort.heatPortBrush.T';
    'dcpm.thermalAmbient.temperatureCore.port.T' = 'dcpm.thermalAmbient.thermalPort.heatPortCore.T';
    'dcpm.thermalAmbient.temperatureStrayLoad.port.T' = 'dcpm.thermalAmbient.thermalPort.heatPortStrayLoad.T';
    'dcpm.thermalAmbient.temperatureFriction.port.T' = 'dcpm.thermalAmbient.thermalPort.heatPortFriction.T';
    'dcpm.airGapDC.pin_en.v' = 'dcpm.eGround.p.v';
    'dcpm.airGapDC.pin_en.v' = 'dcpm.ie.p.v';
    'dcpm.airGapDC.pin_ep.v' = 'dcpm.ie.n.v';
    'dcpm.airGapDC.pin_ap.v' = 'dcpm.la.n.v';
    'dcpm.friction.support.phi' = 'dcpm.internalSupport.phi';
    'dcpm.friction.support.phi' = 'dcpm.inertiaStator.flange_a.phi';
    'dcpm.friction.support.phi' = 'dcpm.fixed.flange.phi';
    'dcpm.friction.support.phi' = 'dcpm.strayLoad.support.phi';
    'dcpm.friction.support.phi' = 'dcpm.airGapDC.support.phi';
    'dcpm.airGapDC.flange.phi' = 'dcpm.inertiaRotor.flange_a.phi';
    'dcpm.core.n.v' = 'dcpm.brush.p.v';
    'dcpm.core.n.v' = 'dcpm.airGapDC.pin_an.v';
    'dcpm.la.p.v' = 'dcpm.core.p.v';
    'dcpm.la.p.v' = 'dcpm.ra.n.v';
    'dcpm.brush.n.v' = 'dcpm.pin_an.v';
    'dcpm.pin_ap.v' = 'dcpm.strayLoad.p.v';
    'dcpm.strayLoad.p.i' - 'dcpm.pin_ap.i' = 0.0;
    'dcpm.strayLoad.n.v' = 'dcpm.ra.p.v';
    'dcpm.thermalAmbient.thermalPort.heatPortCore.T' = 'dcpm.internalThermalPort.heatPortCore.T';
    'dcpm.thermalAmbient.thermalPort.heatPortCore.T' = 'dcpm.core.heatPort.T';
    'dcpm.thermalAmbient.thermalPort.heatPortBrush.T' = 'dcpm.internalThermalPort.heatPortBrush.T';
    'dcpm.thermalAmbient.thermalPort.heatPortBrush.T' = 'dcpm.brush.heatPort.T';
    'dcpm.thermalAmbient.thermalPort.heatPortStrayLoad.T' = 'dcpm.internalThermalPort.heatPortStrayLoad.T';
    'dcpm.thermalAmbient.thermalPort.heatPortStrayLoad.T' = 'dcpm.strayLoad.heatPort.T';
    'dcpm.thermalAmbient.thermalPort.heatPortFriction.T' = 'dcpm.internalThermalPort.heatPortFriction.T';
    'dcpm.thermalAmbient.thermalPort.heatPortFriction.T' = 'dcpm.friction.heatPort.T';
    'dcpm.thermalAmbient.thermalPort.heatPortArmature.T' = 'dcpm.internalThermalPort.heatPortArmature.T';
    'dcpm.thermalAmbient.thermalPort.heatPortArmature.T' = 'dcpm.ra.heatPort.T';
    'dcpm.thermalAmbient.thermalPort.heatPortPermanentMagnet.T' = 'dcpm.internalThermalPort.heatPortPermanentMagnet.T';
    'dcpm.inertiaRotor.flange_b.phi' = 'dcpm.friction.flange.phi';
    'dcpm.inertiaRotor.flange_b.phi' = 'dcpm.flange.phi';
    'dcpm.inertiaRotor.flange_b.phi' = 'dcpm.strayLoad.flange.phi';
    'dcpm.strayLoad.flange.tau' + 'dcpm.friction.flange.tau' + 'dcpm.inertiaRotor.flange_b.tau' - 'dcpm.flange.tau' = 0.0;
    'ramp.y' = 'signalVoltage.v';
    'signalVoltage.p.v' = 'dcpm.pin_ap.v';
    'dcpm.pin_an.v' = 'signalVoltage.n.v';
    'dcpm.pin_an.v' = 'ground.p.v';
    'loadInertia.flange_b.phi' = 'loadTorqueStep.flange.phi';
    'dcpm.flange.phi' = 'loadInertia.flange_a.phi';
    'loadInertia.flange_a.tau' + 'dcpm.flange.tau' = 0.0;
    'dcpm.inertiaStator.flange_b.tau' = 0.0;
    'dcpm.thermalAmbient.thermalPort.heatPortFriction.Q_flow' + 'dcpm.friction.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcpm.internalSupport.tau' = 0.0;
    'dcpm.core.p.i' + 'dcpm.la.p.i' + 'dcpm.ra.n.i' = 0.0;
    'dcpm.thermalAmbient.thermalPort.heatPortArmature.Q_flow' + 'dcpm.ra.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcpm.brush.n.i' - 'dcpm.pin_an.i' = 0.0;
    'dcpm.thermalAmbient.thermalPort.heatPortBrush.Q_flow' + 'dcpm.brush.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcpm.thermalAmbient.thermalPort.heatPortCore.Q_flow' + 'dcpm.core.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortCore.Q_flow' = 0.0;
    'dcpm.strayLoad.n.i' + 'dcpm.ra.p.i' = 0.0;
    'dcpm.thermalAmbient.thermalPort.heatPortStrayLoad.Q_flow' + 'dcpm.strayLoad.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcpm.thermalAmbient.thermalPort.heatPortPermanentMagnet.Q_flow' - 'dcpm.internalThermalPort.heatPortPermanentMagnet.Q_flow' = 0.0;
    'dcpm.thermalAmbient.temperatureArmature.port.Q_flow' - 'dcpm.thermalAmbient.thermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcpm.thermalAmbient.temperatureCore.port.Q_flow' - 'dcpm.thermalAmbient.thermalPort.heatPortCore.Q_flow' = 0.0;
    'dcpm.thermalAmbient.temperatureStrayLoad.port.Q_flow' - 'dcpm.thermalAmbient.thermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcpm.thermalAmbient.temperatureFriction.port.Q_flow' - 'dcpm.thermalAmbient.thermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcpm.thermalAmbient.temperatureBrush.port.Q_flow' - 'dcpm.thermalAmbient.thermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcpm.thermalAmbient.temperaturePermanentMagnet.port.Q_flow' - 'dcpm.thermalAmbient.thermalPort.heatPortPermanentMagnet.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortCore.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortPermanentMagnet.Q_flow' = 0.0;
    'dcpm.airGapDC.flange.tau' + 'dcpm.inertiaRotor.flange_a.tau' = 0.0;
    'dcpm.airGapDC.support.tau' + 'dcpm.strayLoad.support.tau' + 'dcpm.friction.support.tau' + 'dcpm.fixed.flange.tau' + 'dcpm.inertiaStator.flange_a.tau' - 'dcpm.internalSupport.tau' = 0.0;
    'dcpm.airGapDC.pin_ap.i' + 'dcpm.la.n.i' = 0.0;
    'dcpm.ie.n.i' + 'dcpm.airGapDC.pin_ep.i' = 0.0;
    'dcpm.airGapDC.pin_an.i' + 'dcpm.core.n.i' + 'dcpm.brush.p.i' = 0.0;
    'dcpm.ie.p.i' + 'dcpm.eGround.p.i' + 'dcpm.airGapDC.pin_en.i' = 0.0;
    'signalVoltage.p.i' + 'dcpm.pin_ap.i' = 0.0;
    'ground.p.i' + 'signalVoltage.n.i' + 'dcpm.pin_an.i' = 0.0;
    'loadTorqueStep.flange.tau' + 'loadInertia.flange_b.tau' = 0.0;
    'dcpm.inertiaRotor.phi' = 'dcpm.inertiaRotor.flange_a.phi';
    'dcpm.inertiaRotor.phi' = 'dcpm.inertiaRotor.flange_b.phi';
    'dcpm.inertiaRotor.w' = der('dcpm.inertiaRotor.phi');
    'dcpm.inertiaRotor.a' = der('dcpm.inertiaRotor.w');
    0.15 * 'dcpm.inertiaRotor.a' = 'dcpm.inertiaRotor.flange_a.tau' + 'dcpm.inertiaRotor.flange_b.tau';
    'dcpm.inertiaStator.phi' = 'dcpm.inertiaStator.flange_a.phi';
    'dcpm.inertiaStator.phi' = 'dcpm.inertiaStator.flange_b.phi';
    'dcpm.inertiaStator.w' = der('dcpm.inertiaStator.phi');
    'dcpm.inertiaStator.a' = der('dcpm.inertiaStator.w');
    0.15 * 'dcpm.inertiaStator.a' = 'dcpm.inertiaStator.flange_a.tau' + 'dcpm.inertiaStator.flange_b.tau';
    'dcpm.fixed.flange.phi' = 0.0;
    'dcpm.friction.tau' = 0.0;
    'dcpm.friction.lossPower' = -'dcpm.friction.tau' * 'dcpm.friction.w';
    'dcpm.friction.phi' = 'dcpm.friction.flange.phi' - 'dcpm.friction.support.phi';
    'dcpm.friction.w' = der('dcpm.friction.phi');
    'dcpm.friction.tau' = -'dcpm.friction.flange.tau';
    'dcpm.friction.tau' = 'dcpm.friction.support.tau';
    'dcpm.ra.R_actual' = 0.05;
    'dcpm.ra.v' = 'dcpm.ra.R_actual' * 'dcpm.ra.i';
    'dcpm.ra.LossPower' = 'dcpm.ra.v' * 'dcpm.ra.i';
    0.0 = 'dcpm.ra.p.i' + 'dcpm.ra.n.i';
    'dcpm.ra.i' = 'dcpm.ra.p.i';
    'dcpm.ra.v' = 'dcpm.ra.p.v' - 'dcpm.ra.n.v';
    'dcpm.la.v' = 0.0015 * der('dcpm.la.i');
    0.0 = 'dcpm.la.p.i' + 'dcpm.la.n.i';
    'dcpm.la.i' = 'dcpm.la.p.i';
    'dcpm.la.v' = 'dcpm.la.p.v' - 'dcpm.la.n.v';
    'dcpm.brush.v' = 0.0;
    'dcpm.brush.lossPower' = 'dcpm.brush.v' * 'dcpm.brush.i';
    0.0 = 'dcpm.brush.p.i' + 'dcpm.brush.n.i';
    'dcpm.brush.i' = 'dcpm.brush.p.i';
    'dcpm.brush.v' = 'dcpm.brush.p.v' - 'dcpm.brush.n.v';
    'dcpm.core.Gc' = 0.0;
    'dcpm.core.i' = 0.0;
    'dcpm.core.lossPower' = 'dcpm.core.v' * 'dcpm.core.i';
    0.0 = 'dcpm.core.p.i' + 'dcpm.core.n.i';
    'dcpm.core.i' = 'dcpm.core.p.i';
    'dcpm.core.v' = 'dcpm.core.p.v' - 'dcpm.core.n.v';
    'dcpm.strayLoad.v' = 0.0;
    'dcpm.strayLoad.tau' = 0.0;
    'dcpm.strayLoad.lossPower' = -'dcpm.strayLoad.tau' * 'dcpm.strayLoad.w';
    'dcpm.strayLoad.phi' = 'dcpm.strayLoad.flange.phi' - 'dcpm.strayLoad.support.phi';
    'dcpm.strayLoad.w' = der('dcpm.strayLoad.phi');
    'dcpm.strayLoad.tau' = -'dcpm.strayLoad.flange.tau';
    'dcpm.strayLoad.tau' = 'dcpm.strayLoad.support.tau';
    0.0 = 'dcpm.strayLoad.p.i' + 'dcpm.strayLoad.n.i';
    'dcpm.strayLoad.i' = 'dcpm.strayLoad.p.i';
    'dcpm.strayLoad.v' = 'dcpm.strayLoad.p.v' - 'dcpm.strayLoad.n.v';
    'dcpm.thermalAmbient.temperatureArmature.port.T' = 'dcpm.thermalAmbient.temperatureArmature.T';
    'dcpm.thermalAmbient.temperatureCore.port.T' = 293.15;
    'dcpm.thermalAmbient.temperatureStrayLoad.port.T' = 293.15;
    'dcpm.thermalAmbient.temperatureFriction.port.T' = 293.15;
    'dcpm.thermalAmbient.constTa.y' = 293.15;
    'dcpm.thermalAmbient.temperatureBrush.port.T' = 293.15;
    'dcpm.thermalAmbient.temperaturePermanentMagnet.port.T' = 'dcpm.thermalAmbient.temperaturePermanentMagnet.T';
    'dcpm.thermalAmbient.constTpm.y' = 293.15;
    'dcpm.airGapDC.psi_e' = 'dcpm.airGapDC.ie';
    'dcpm.airGapDC.vai' = 'dcpm.airGapDC.pin_ap.v' - 'dcpm.airGapDC.pin_an.v';
    'dcpm.airGapDC.ia' = 'dcpm.airGapDC.pin_ap.i';
    'dcpm.airGapDC.ia' = -'dcpm.airGapDC.pin_an.i';
    'dcpm.airGapDC.vei' = 'dcpm.airGapDC.pin_ep.v' - 'dcpm.airGapDC.pin_en.v';
    'dcpm.airGapDC.ie' = 'dcpm.airGapDC.pin_ep.i';
    'dcpm.airGapDC.ie' = -'dcpm.airGapDC.pin_en.i';
    'dcpm.airGapDC.vei' = der('dcpm.airGapDC.psi_e');
    'dcpm.airGapDC.w' = der('dcpm.airGapDC.flange.phi') - der('dcpm.airGapDC.support.phi');
    'dcpm.airGapDC.vai' = 0.6366197723675815 * 'dcpm.airGapDC.psi_e' * 'dcpm.airGapDC.w';
    'dcpm.airGapDC.tauElectrical' = 0.6366197723675815 * 'dcpm.airGapDC.psi_e' * 'dcpm.airGapDC.ia';
    'dcpm.airGapDC.flange.tau' = -'dcpm.airGapDC.tauElectrical';
    'dcpm.airGapDC.support.tau' = 'dcpm.airGapDC.tauElectrical';
    'dcpm.eGround.p.v' = 0.0;
    'dcpm.ie.i' = 1.0;
    0.0 = 'dcpm.ie.p.i' + 'dcpm.ie.n.i';
    'dcpm.ie.i' = 'dcpm.ie.p.i';
    'dcpm.ie.v' = 'dcpm.ie.p.v' - 'dcpm.ie.n.v';
    'ramp.y' = if time < 0.2 then 0.0 else if time < 1.0 then (time - 0.2) * 100.0 / 0.8 else 100.0;
    'signalVoltage.v' = 'signalVoltage.p.v' - 'signalVoltage.n.v';
    0.0 = 'signalVoltage.p.i' + 'signalVoltage.n.i';
    'signalVoltage.i' = 'signalVoltage.p.i';
    'ground.p.v' = 0.0;
    'loadInertia.phi' = 'loadInertia.flange_a.phi';
    'loadInertia.phi' = 'loadInertia.flange_b.phi';
    'loadInertia.w' = der('loadInertia.phi');
    'loadInertia.a' = der('loadInertia.w');
    0.15 * 'loadInertia.a' = 'loadInertia.flange_a.tau' + 'loadInertia.flange_b.tau';
    'loadTorqueStep.tau' = -'loadTorqueStep.flange.tau';
    'loadTorqueStep.tau' = if time < 1.5 then 0.0 else -63.66;
    'loadTorqueStep.phi' = 'loadTorqueStep.flange.phi' - 'loadTorqueStep.phi_support';
    'loadTorqueStep.phi_support' = 0.0;
    annotation(experiment(StopTime = 2.0, Interval = 1E-4, Tolerance = 1E-6));
  end 'DCPM_Start';
end 'DCPM_Start';
