    Real 'dcpm.thermalAmbient.thermalPort.heatPortBrush.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortPermanentMagnet.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.thermalPort.heatPortPermanentMagnet.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.thermalAmbient.temperatureArmature.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.temperatureArmature.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.thermalAmbient.temperatureArmature.T'(unit = "K");
    parameter Real 'dcpm.thermalAmbient.temperatureCore.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed temperature at port";
    Real 'dcpm.thermalAmbient.temperatureCore.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.temperatureCore.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'dcpm.thermalAmbient.temperatureStrayLoad.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed temperature at port";
    Real 'dcpm.thermalAmbient.temperatureStrayLoad.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.temperatureStrayLoad.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'dcpm.thermalAmbient.temperatureFriction.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed temperature at port";
    Real 'dcpm.thermalAmbient.temperatureFriction.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.temperatureFriction.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'dcpm.thermalAmbient.constTa.k'(start = 1.0) = 293.15 "Constant output value";
    Real 'dcpm.thermalAmbient.constTa.y' "Connector of Real output signal";
    parameter Real 'dcpm.thermalAmbient.temperatureBrush.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed temperature at port";
    Real 'dcpm.thermalAmbient.temperatureBrush.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.thermalAmbient.temperatureBrush.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'dcpm.thermalAmbient.Tpm'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Temperature of permanent magnet";
    Real 'dcpm.thermalAmbient.Q_flowPermanentMagnet'(unit = "W", quantity = "Power") "Heat flow rate of permanent magnets";
    Real 'dcpm.thermalAmbient.Q_flowTotal'(unit = "W", quantity = "Power");
