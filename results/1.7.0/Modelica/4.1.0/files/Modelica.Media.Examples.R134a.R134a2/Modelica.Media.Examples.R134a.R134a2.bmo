  function 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.vapourQuality' "Return vapour quality"
    input 'volume.Medium.ThermodynamicState' 'state';
    output Real 'x'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction");
    constant Real 'eps'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 1e-8;
  algorithm
    'x' := min(max(('Modelica.Media.Examples.R134a.R134a2.volume.Medium.specificEnthalpy'('state') - 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.bubbleEnthalpy'('Modelica.Media.Examples.R134a.R134a2.volume.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a2.volume.Medium.pressure'('state')))) / ('Modelica.Media.Examples.R134a.R134a2.volume.Medium.dewEnthalpy'('Modelica.Media.Examples.R134a.R134a2.volume.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a2.volume.Medium.pressure'('state'))) - 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.bubbleEnthalpy'('Modelica.Media.Examples.R134a.R134a2.volume.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a2.volume.Medium.pressure'('state'))) + 'eps'), 0.0), 1.0);
  end 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.vapourQuality';

