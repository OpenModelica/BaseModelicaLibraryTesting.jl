    Real 'hl'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.bubbleEnthalpy'('sat');
    Real 'hv'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.dewEnthalpy'('sat');
