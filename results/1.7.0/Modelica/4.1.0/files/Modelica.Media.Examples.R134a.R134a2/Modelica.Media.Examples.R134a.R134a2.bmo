    Real 'hv'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.dewEnthalpy'('sat');
  algorithm
    'phase' := if ('h' < 'hl' or 'h' > 'hv') or 'p' > 4.05928e6 then 1 else 2;
    annotation(GenerateEvents = true, Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.getPhase_ph';

