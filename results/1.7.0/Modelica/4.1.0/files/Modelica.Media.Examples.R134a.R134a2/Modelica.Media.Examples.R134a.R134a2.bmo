  end 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.saturationTemperature';

  function 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.derivsOf_ph' "Derivatives required for inversion of temperature and density functions"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase';
    output 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'volume1.Medium.SaturationProperties' 'sat';
    'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'liq';
    'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'vap';
    'Modelica.Media.Common.NewtonDerivatives_ph' 'newder';
    Real 'x';
    Real 'dxv';
  algorithm
    'derivs'.'p' := 'p';
    'derivs'.'h' := 'h';
    'derivs'.'phase' := 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.getPhase_ph'('p', 'h');
    'sat'.'psat' := 'p';
    'sat'.'Tsat' := 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.saturationTemperature'('p');
    ('derivs'.'rho', 'derivs'.'T') := 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.dt_ph'('p', 'h');

    if 'derivs'.'phase' == 2 then
      'liq' := 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.R134a_liqofdT'('derivs'.'T');
      'vap' := 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.R134a_vapofdT'('derivs'.'T');
      'x' := if 'liq'.'h' <> 'vap'.'h' then ('h' - 'liq'.'h') / ('vap'.'h' - 'liq'.'h') else if 'h' >= 'vap'.'h' then 1.0 else 0.0;
      'derivs'.'cv' := 'Modelica.Media.R134a.Common.cv2Phase'('liq', 'vap', 'x', 'derivs'.'T', 'p');
      'dxv' := if 'liq'.'d' <> 'vap'.'d' then 'liq'.'d' * 'vap'.'d' / ('liq'.'d' - 'vap'.'d') else 0.0;
      'derivs'.'dpT' := ('vap'.'s' - 'liq'.'s') * 'dxv';
    else
      'f' := 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.f_R134a'('derivs'.'rho', 'derivs'.'T');
      'f'.'d' := 'derivs'.'rho';
      'f'.'T' := 'derivs'.'T';
      'f'.'R_s' := 81.4888564372;
      'newder' := 'Modelica.Media.Common.Helmholtz_ph'('f');
      'derivs'.'cv' := -'f'.'R_s' * ('f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
      'derivs'.'pd' := 'newder'.'pd';
      'derivs'.'pt' := 'newder'.'pt';
    end if;
  end 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.derivsOf_ph';

  function 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.getPhase_ph' "Number of phases by pressure and specific enthalpy"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    output Integer 'phase';
    'fixedMassFlowRate.Medium.SaturationProperties' 'sat';
    Real 'hl'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.bubbleEnthalpy'('sat');
    Real 'hv'(unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.dewEnthalpy'('sat');
  algorithm
    'phase' := if ('h' < 'hl' or 'h' > 'hv') or 'p' > 4.05928e6 then 1 else 2;
    annotation(GenerateEvents = true, Inline = true);
  end 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.getPhase_ph';

  function 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.vapourQuality' "Return vapour quality"
    input 'volume1.Medium.ThermodynamicState' 'state';
    output Real 'x'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction");
    constant Real 'eps'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 1e-8;
  algorithm
    'x' := min(max(('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.specificEnthalpy'('state') - 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.bubbleEnthalpy'('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.pressure'('state')))) / ('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.dewEnthalpy'('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.pressure'('state'))) - 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.bubbleEnthalpy'('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.setSat_p'('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.pressure'('state'))) + 'eps'), 0.0), 1.0);
  end 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.vapourQuality';

  function 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.derivsOf_ph' "Derivatives required for inversion of temperature and density functions"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase';
    output 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'ambient.Medium.SaturationProperties' 'sat';
    'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'liq';
    'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'vap';
    'Modelica.Media.Common.NewtonDerivatives_ph' 'newder';
    Real 'x';
    Real 'dxv';
  algorithm
    'derivs'.'p' := 'p';
    'derivs'.'h' := 'h';
    'derivs'.'phase' := 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.getPhase_ph'('p', 'h');
    'sat'.'psat' := 'p';
    'sat'.'Tsat' := 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.saturationTemperature'('p');
    ('derivs'.'rho', 'derivs'.'T') := 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.dt_ph'('p', 'h');

    if 'derivs'.'phase' == 2 then
      'liq' := 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.R134a_liqofdT'('derivs'.'T');
      'vap' := 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.R134a_vapofdT'('derivs'.'T');
      'x' := if 'liq'.'h' <> 'vap'.'h' then ('h' - 'liq'.'h') / ('vap'.'h' - 'liq'.'h') else if 'h' >= 'vap'.'h' then 1.0 else 0.0;
      'derivs'.'cv' := 'Modelica.Media.R134a.Common.cv2Phase'('liq', 'vap', 'x', 'derivs'.'T', 'p');
      'dxv' := if 'liq'.'d' <> 'vap'.'d' then 'liq'.'d' * 'vap'.'d' / ('liq'.'d' - 'vap'.'d') else 0.0;
      'derivs'.'dpT' := ('vap'.'s' - 'liq'.'s') * 'dxv';
    else
      'f' := 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.f_R134a'('derivs'.'rho', 'derivs'.'T');
      'f'.'d' := 'derivs'.'rho';
      'f'.'T' := 'derivs'.'T';
      'f'.'R_s' := 81.4888564372;
      'newder' := 'Modelica.Media.Common.Helmholtz_ph'('f');
      'derivs'.'cv' := -'f'.'R_s' * ('f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
      'derivs'.'pd' := 'newder'.'pd';
      'derivs'.'pt' := 'newder'.'pt';
    end if;
