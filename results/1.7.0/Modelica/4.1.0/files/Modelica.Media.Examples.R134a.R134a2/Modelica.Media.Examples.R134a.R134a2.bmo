    Real 'volume1.medium.state.T'(nominal = 350.0, start = 293.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'volume1.medium.state.p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'volume1.medium.preferredMediumStates' = true "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'volume1.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'volume1.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'volume1.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'volume1.medium.sat.psat'(nominal = 1e6, start = 3e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Saturation pressure";
    Real 'volume1.medium.sat.Tsat'(nominal = 350.0, start = 273.0, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Saturation temperature";
    Integer 'volume1.medium.phase'(fixed = false, start = 1, max = 2, min = 0) "2 for two-phase, 1 for one-phase, 0 if not known";
    Real 'volume1.medium.quality'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Quality of vapour";
    Real 'volume1.U'(unit = "J", quantity = "Energy") "Internal energy of port volume";
    Real 'volume1.m'(min = 0.0, unit = "kg", quantity = "Mass") "Mass of junction volume";
    parameter Real 'shortPipe1.dp_nominal'(nominal = 1e6, start = 101325.0, max = 1e8, min = 1e-10, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e4 "Nominal pressure drop";
    parameter Real 'shortPipe1.m_flow_nominal'(max = 1e5, min = 1e-10, unit = "kg/s", quantity = "MassFlowRate.R134a_ph") = 1.0 "Nominal mass flow rate at nominal pressure drop";
    Real 'shortPipe1.port_a.p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure in the connection point";
    Real 'shortPipe1.port_a.m_flow'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.R134a_ph") "Mass flow rate from the connection point into the component";
    Real 'shortPipe1.port_a.h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific mixture enthalpy in the connection point";
    Real 'shortPipe1.port_a.H_flow'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rate into the component (if m_flow > 0, H_flow = m_flow*h)";
    Real 'shortPipe1.port_b.p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure in the connection point";
    Real 'shortPipe1.port_b.m_flow'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.R134a_ph") "Mass flow rate from the connection point into the component";
    Real 'shortPipe1.port_b.h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific mixture enthalpy in the connection point";
    Real 'shortPipe1.port_b.H_flow'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rate into the component (if m_flow > 0, H_flow = m_flow*h)";
    Real 'shortPipe1.m_flow'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.R134a_ph") "Mass flow rate from port_a to port_b (m_flow > 0 is design flow direction)";
    Real 'shortPipe1.dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop from port_a to port_b";
  initial equation
    'volume.medium.p' = 1e5;
    'volume.medium.h' = 107390.0;
    'volume1.medium.p' = 1e5;
    'volume1.medium.T' = 300.0;
  equation
    'volume.medium.T_degC' = 'volume.medium.T' - 273.15;
    'volume.medium.p_bar' = 'volume.medium.p' / 1e5;
    'fixedMassFlowRate.medium.T_degC' = 'fixedMassFlowRate.medium.T' - 273.15;
    'fixedMassFlowRate.medium.p_bar' = 'fixedMassFlowRate.medium.p' / 1e5;
    'ambient.medium.T_degC' = 'ambient.medium.T' - 273.15;
    'ambient.medium.p_bar' = 'ambient.medium.p' / 1e5;
    'volume1.medium.T_degC' = 'volume1.medium.T' - 273.15;
    'volume1.medium.p_bar' = 'volume1.medium.p' / 1e5;
    'volume.port.h' = 'shortPipe.port_a.h';
    'volume.port.h' = 'fixedMassFlowRate.port.h';
    'volume.port.p' = 'shortPipe.port_a.p';
    'volume.port.p' = 'fixedMassFlowRate.port.p';
    'shortPipe.port_b.h' = 'volume1.port.h';
    'shortPipe.port_b.h' = 'shortPipe1.port_a.h';
    'shortPipe.port_b.p' = 'volume1.port.p';
    'shortPipe.port_b.p' = 'shortPipe1.port_a.p';
    'shortPipe1.port_b.h' = 'ambient.port.h';
    'shortPipe1.port_b.p' = 'ambient.port.p';
    'shortPipe.port_a.m_flow' + 'fixedMassFlowRate.port.m_flow' + 'volume.port.m_flow' = 0.0;
    'shortPipe.port_a.H_flow' + 'fixedMassFlowRate.port.H_flow' + 'volume.port.H_flow' = 0.0;
    'shortPipe1.port_a.m_flow' + 'volume1.port.m_flow' + 'shortPipe.port_b.m_flow' = 0.0;
    'shortPipe1.port_a.H_flow' + 'volume1.port.H_flow' + 'shortPipe.port_b.H_flow' = 0.0;
    'shortPipe1.port_b.m_flow' + 'ambient.port.m_flow' = 0.0;
    'shortPipe1.port_b.H_flow' + 'ambient.port.H_flow' = 0.0;
    'volume.medium.MM' = 0.102032;
    'volume.medium.phase' = 0;
    'volume.medium.T' = ('Modelica.Media.Examples.R134a.R134a2.volume.Medium.derivsOf_ph'('volume.medium.p', 'volume.medium.h', 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.getPhase_ph'('volume.medium.p', 'volume.medium.h'))).T;
    'volume.medium.d' = ('Modelica.Media.Examples.R134a.R134a2.volume.Medium.derivsOf_ph'('volume.medium.p', 'volume.medium.h', 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.getPhase_ph'('volume.medium.p', 'volume.medium.h'))).rho;
    'volume.medium.sat.Tsat' = 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.saturationTemperature'('volume.medium.p');
    'volume.medium.sat.psat' = 'volume.medium.p';
    'volume.medium.quality' = 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.vapourQuality'('volume.medium.state');
    'volume.medium.u' = 'volume.medium.h' - 'volume.medium.p' / 'volume.medium.d';
    'volume.medium.R_s' = 81.4888564372;
    'volume.medium.h' = 'volume.medium.state.h';
    'volume.medium.p' = 'volume.medium.state.p';
    'volume.medium.T' = 'volume.medium.state.T';
    'volume.medium.d' = 'volume.medium.state.d';
    'volume.medium.phase' = 'volume.medium.state.phase';
    'volume.medium.X[1]' = 1.0;
    assert('volume.medium.X[1]' >= (-1e-5) and 'volume.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('volume.medium.X[1]') + "of substance " + "tetrafluoroethane" + "\nof medium " + "R134a_ph" + " is not in the range 0..1", AssertionLevel.error);
    assert('volume.medium.p' >= 0.0, "Pressure (= " + String('volume.medium.p') + " Pa) of medium \"" + "R134a_ph" + "\" is negative\n(Temperature = " + String('volume.medium.T') + " K)", AssertionLevel.error);
    'volume.medium.p' = 'volume.port.p';
    'volume.medium.h' = 'volume.port.h';
    'volume.m' = 0.1 * 'volume.medium.d';
    'volume.U' = 'volume.m' * 'volume.medium.u';
    der('volume.m') = 'volume.port.m_flow';
    der('volume.U') = 'volume.port.H_flow';
    'fixedMassFlowRate.medium.MM' = 0.102032;
    'fixedMassFlowRate.medium.phase' = 0;
    'fixedMassFlowRate.medium.T' = ('Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.derivsOf_ph'('fixedMassFlowRate.medium.p', 'fixedMassFlowRate.medium.h', 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.getPhase_ph'('fixedMassFlowRate.medium.p', 'fixedMassFlowRate.medium.h'))).T;
    'fixedMassFlowRate.medium.d' = ('Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.derivsOf_ph'('fixedMassFlowRate.medium.p', 'fixedMassFlowRate.medium.h', 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.getPhase_ph'('fixedMassFlowRate.medium.p', 'fixedMassFlowRate.medium.h'))).rho;
    'fixedMassFlowRate.medium.sat.Tsat' = 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.saturationTemperature'('fixedMassFlowRate.medium.p');
    'fixedMassFlowRate.medium.sat.psat' = 'fixedMassFlowRate.medium.p';
    'fixedMassFlowRate.medium.quality' = 'Modelica.Media.Examples.R134a.R134a2.fixedMassFlowRate.Medium.vapourQuality'('fixedMassFlowRate.medium.state');
    'fixedMassFlowRate.medium.u' = 'fixedMassFlowRate.medium.h' - 'fixedMassFlowRate.medium.p' / 'fixedMassFlowRate.medium.d';
    'fixedMassFlowRate.medium.R_s' = 81.4888564372;
    'fixedMassFlowRate.medium.h' = 'fixedMassFlowRate.medium.state.h';
    'fixedMassFlowRate.medium.p' = 'fixedMassFlowRate.medium.state.p';
    'fixedMassFlowRate.medium.T' = 'fixedMassFlowRate.medium.state.T';
    'fixedMassFlowRate.medium.d' = 'fixedMassFlowRate.medium.state.d';
    'fixedMassFlowRate.medium.phase' = 'fixedMassFlowRate.medium.state.phase';
    'fixedMassFlowRate.medium.X[1]' = 1.0;
    assert('fixedMassFlowRate.medium.X[1]' >= (-1e-5) and 'fixedMassFlowRate.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('fixedMassFlowRate.medium.X[1]') + "of substance " + "tetrafluoroethane" + "\nof medium " + "R134a_ph" + " is not in the range 0..1", AssertionLevel.error);
    assert('fixedMassFlowRate.medium.p' >= 0.0, "Pressure (= " + String('fixedMassFlowRate.medium.p') + " Pa) of medium \"" + "R134a_ph" + "\" is negative\n(Temperature = " + String('fixedMassFlowRate.medium.T') + " K)", AssertionLevel.error);
    'fixedMassFlowRate.medium.h' = 128868.0;
    'fixedMassFlowRate.medium.p' = 'fixedMassFlowRate.port.p';
    'fixedMassFlowRate.port.m_flow' = -1.0;
    'fixedMassFlowRate.port.H_flow' = semiLinear('fixedMassFlowRate.port.m_flow', 'fixedMassFlowRate.port.h', 'fixedMassFlowRate.medium.h');
    'ambient.medium.MM' = 0.102032;
    'ambient.medium.phase' = 0;
    'ambient.medium.T' = ('Modelica.Media.Examples.R134a.R134a2.ambient.Medium.derivsOf_ph'('ambient.medium.p', 'ambient.medium.h', 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.getPhase_ph'('ambient.medium.p', 'ambient.medium.h'))).T;
    'ambient.medium.d' = ('Modelica.Media.Examples.R134a.R134a2.ambient.Medium.derivsOf_ph'('ambient.medium.p', 'ambient.medium.h', 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.getPhase_ph'('ambient.medium.p', 'ambient.medium.h'))).rho;
    'ambient.medium.sat.Tsat' = 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.saturationTemperature'('ambient.medium.p');
    'ambient.medium.sat.psat' = 'ambient.medium.p';
    'ambient.medium.quality' = 'Modelica.Media.Examples.R134a.R134a2.ambient.Medium.vapourQuality'('ambient.medium.state');
    'ambient.medium.u' = 'ambient.medium.h' - 'ambient.medium.p' / 'ambient.medium.d';
    'ambient.medium.R_s' = 81.4888564372;
    'ambient.medium.h' = 'ambient.medium.state.h';
    'ambient.medium.p' = 'ambient.medium.state.p';
    'ambient.medium.T' = 'ambient.medium.state.T';
    'ambient.medium.d' = 'ambient.medium.state.d';
    'ambient.medium.phase' = 'ambient.medium.state.phase';
    'ambient.medium.X[1]' = 1.0;
    assert('ambient.medium.X[1]' >= (-1e-5) and 'ambient.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('ambient.medium.X[1]') + "of substance " + "tetrafluoroethane" + "\nof medium " + "R134a_ph" + " is not in the range 0..1", AssertionLevel.error);
    assert('ambient.medium.p' >= 0.0, "Pressure (= " + String('ambient.medium.p') + " Pa) of medium \"" + "R134a_ph" + "\" is negative\n(Temperature = " + String('ambient.medium.T') + " K)", AssertionLevel.error);
    'ambient.medium.p' = 1e5;
    'ambient.medium.h' = 107390.0;
    'ambient.port.p' = 'ambient.medium.p';
    'ambient.port.H_flow' = semiLinear('ambient.port.m_flow', 'ambient.port.h', 'ambient.medium.h');
    'shortPipe.port_a.H_flow' = semiLinear('shortPipe.port_a.m_flow', 'shortPipe.port_a.h', 'shortPipe.port_b.h');
    'shortPipe.port_a.H_flow' + 'shortPipe.port_b.H_flow' = 0.0;
    'shortPipe.port_a.m_flow' + 'shortPipe.port_b.m_flow' = 0.0;
    'shortPipe.m_flow' = 'shortPipe.port_a.m_flow';
    'shortPipe.dp' = 'shortPipe.port_a.p' - 'shortPipe.port_b.p';
    'shortPipe.m_flow' = 1e-4 * 'shortPipe.dp';
    'volume1.medium.MM' = 0.102032;
    'volume1.medium.phase' = 0;
    'volume1.medium.T' = ('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.derivsOf_ph'('volume1.medium.p', 'volume1.medium.h', 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.getPhase_ph'('volume1.medium.p', 'volume1.medium.h'))).T;
    'volume1.medium.d' = ('Modelica.Media.Examples.R134a.R134a2.volume1.Medium.derivsOf_ph'('volume1.medium.p', 'volume1.medium.h', 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.getPhase_ph'('volume1.medium.p', 'volume1.medium.h'))).rho;
    'volume1.medium.sat.Tsat' = 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.saturationTemperature'('volume1.medium.p');
    'volume1.medium.sat.psat' = 'volume1.medium.p';
    'volume1.medium.quality' = 'Modelica.Media.Examples.R134a.R134a2.volume1.Medium.vapourQuality'('volume1.medium.state');
    'volume1.medium.u' = 'volume1.medium.h' - 'volume1.medium.p' / 'volume1.medium.d';
    'volume1.medium.R_s' = 81.4888564372;
    'volume1.medium.h' = 'volume1.medium.state.h';
    'volume1.medium.p' = 'volume1.medium.state.p';
    'volume1.medium.T' = 'volume1.medium.state.T';
    'volume1.medium.d' = 'volume1.medium.state.d';
    'volume1.medium.phase' = 'volume1.medium.state.phase';
    'volume1.medium.X[1]' = 1.0;
    assert('volume1.medium.X[1]' >= (-1e-5) and 'volume1.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('volume1.medium.X[1]') + "of substance " + "tetrafluoroethane" + "\nof medium " + "R134a_ph" + " is not in the range 0..1", AssertionLevel.error);
    assert('volume1.medium.p' >= 0.0, "Pressure (= " + String('volume1.medium.p') + " Pa) of medium \"" + "R134a_ph" + "\" is negative\n(Temperature = " + String('volume1.medium.T') + " K)", AssertionLevel.error);
    'volume1.medium.p' = 'volume1.port.p';
    'volume1.medium.h' = 'volume1.port.h';
    'volume1.m' = 0.1 * 'volume1.medium.d';
    'volume1.U' = 'volume1.m' * 'volume1.medium.u';
    der('volume1.m') = 'volume1.port.m_flow';
    der('volume1.U') = 'volume1.port.H_flow';
    'shortPipe1.port_a.H_flow' = semiLinear('shortPipe1.port_a.m_flow', 'shortPipe1.port_a.h', 'shortPipe1.port_b.h');
    'shortPipe1.port_a.H_flow' + 'shortPipe1.port_b.H_flow' = 0.0;
    'shortPipe1.port_a.m_flow' + 'shortPipe1.port_b.m_flow' = 0.0;
    'shortPipe1.m_flow' = 'shortPipe1.port_a.m_flow';
    'shortPipe1.dp' = 'shortPipe1.port_a.p' - 'shortPipe1.port_b.p';
    'shortPipe1.m_flow' = 1e-4 * 'shortPipe1.dp';
    annotation(experiment(StopTime = 1.01));
  end 'R134a2';
end 'R134a2';
