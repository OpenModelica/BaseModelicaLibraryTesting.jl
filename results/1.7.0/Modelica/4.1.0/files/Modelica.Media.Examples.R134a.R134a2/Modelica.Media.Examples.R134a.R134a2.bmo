//! base 0.1.0
package 'R134a2'
  function 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.derivsOf_ph' "Derivatives required for inversion of temperature and density functions"
    input Real 'p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 5e5, start = 4.2e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase';
    output 'Modelica.Media.R134a.Common.InverseDerivatives_rhoT' 'derivs';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'volume.Medium.SaturationProperties' 'sat';
    'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'liq';
    'Modelica.Media.R134a.Common.PhaseBoundaryProperties' 'vap';
    'Modelica.Media.Common.NewtonDerivatives_ph' 'newder';
    Real 'x';
    Real 'dxv';
  algorithm
    'derivs'.'p' := 'p';
    'derivs'.'h' := 'h';
    'derivs'.'phase' := 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.getPhase_ph'('p', 'h');
    'sat'.'psat' := 'p';
    'sat'.'Tsat' := 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.saturationTemperature'('p');
    ('derivs'.'rho', 'derivs'.'T') := 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.dt_ph'('p', 'h');

    if 'derivs'.'phase' == 2 then
      'liq' := 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.R134a_liqofdT'('derivs'.'T');
      'vap' := 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.R134a_vapofdT'('derivs'.'T');
      'x' := if 'liq'.'h' <> 'vap'.'h' then ('h' - 'liq'.'h') / ('vap'.'h' - 'liq'.'h') else if 'h' >= 'vap'.'h' then 1.0 else 0.0;
      'derivs'.'cv' := 'Modelica.Media.R134a.Common.cv2Phase'('liq', 'vap', 'x', 'derivs'.'T', 'p');
      'dxv' := if 'liq'.'d' <> 'vap'.'d' then 'liq'.'d' * 'vap'.'d' / ('liq'.'d' - 'vap'.'d') else 0.0;
      'derivs'.'dpT' := ('vap'.'s' - 'liq'.'s') * 'dxv';
    else
      'f' := 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.f_R134a'('derivs'.'rho', 'derivs'.'T');
      'f'.'d' := 'derivs'.'rho';
      'f'.'T' := 'derivs'.'T';
      'f'.'R_s' := 81.4888564372;
      'newder' := 'Modelica.Media.Common.Helmholtz_ph'('f');
      'derivs'.'cv' := -'f'.'R_s' * ('f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
      'derivs'.'pd' := 'newder'.'pd';
      'derivs'.'pt' := 'newder'.'pt';
    end if;
  end 'Modelica.Media.Examples.R134a.R134a2.volume.Medium.derivsOf_ph';

