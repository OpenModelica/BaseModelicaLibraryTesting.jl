    'Q3.y[1]' = if 'Q3.x[1]' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'' then 0.5 else if 'Q3.x[1]' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'X\'' then 0.5 else if 'Q3.x[1]' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'0\'' then 0.0 else if 'Q3.x[1]' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'1\'' then 1.0 else if 'Q3.x[1]' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'Z\'' then 0.5 else if 'Q3.x[1]' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'W\'' then 0.5 else if 'Q3.x[1]' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'L\'' then 0.0 else if 'Q3.x[1]' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'H\'' then 1.0 else 0.5;
  algorithm
    if time >= 1.0 then
      'Enable.y' := 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'1\'';
    elseif true then
      'Enable.y' := 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'0\'';
    end if;
    annotation(experiment(StopTime = 100));
  end 'Counter';
end 'Counter';
