    parameter Real 'smpmData.Rrd'(unit = "Ohm", quantity = "Resistance") = 0.04 "Damper resistance in d-axis at TRef";
    parameter Real 'smpmData.Rrq'(unit = "Ohm", quantity = "Resistance") = 0.04 "Damper resistance in q-axis at TRef";
    parameter Real 'smpmData.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of damper resistances in d- and q-axis";
    parameter Real 'smpmData.alpha20r'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of damper resistances in d- and q-axis";
    parameter Real 'smpmData.VsOpenCircuit'(unit = "V", quantity = "ElectricPotential") = 112.3 "Open circuit RMS voltage per phase @ fsNominal";
    parameter Real 'smpmData.permanentMagnetLossParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference permanent magnet losses at IRef and wRef";
    parameter Real 'smpmData.permanentMagnetLossParameters.c'(max = 1.0, min = 0.0) = 0.0 "Part of permanent magnet losses at current = 0, i.e. independent of current";
    parameter Real 'smpmData.permanentMagnetLossParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference stator RMS current that PRef refers to";
    parameter Real 'smpmData.permanentMagnetLossParameters.power_I'(min = 2.2250738585072014e-308) = 2.0 "Exponent of permanent magnet loss torque w.r.t. stator current";
    parameter Real 'smpmData.permanentMagnetLossParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpmData.permanentMagnetLossParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of permanent magnet loss torque w.r.t. angular velocity";
    parameter Real 'smpmData.permanentMagnetLossParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference permanent magnet loss torque at reference angular velocity and reference current";
  initial equation
    'smpm.is[1]' = 0.0;
    'smpm.is[2]' = 0.0;
  equation
    'smpm.phiMechanical' = 'smpm.flange.phi' - 'smpm.internalSupport.phi';
    'smpm.wMechanical' = der('smpm.phiMechanical');
    'smpm.tauElectrical' = 'smpm.inertiaRotor.flange_a.tau';
    'smpm.tauShaft' = -'smpm.flange.tau';
    'smpm.friction.heatPort.Q_flow' = -'smpm.friction.lossPower';
    'smpm.powerBalance.powerStator' = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'('smpm.vs', 'smpm.is');
    'smpm.powerBalance.powerMechanical' = 'smpm.wMechanical' * 'smpm.tauShaft';
    'smpm.powerBalance.powerInertiaStator' = 0.29 * 'smpm.inertiaStator.a' * 'smpm.inertiaStator.w';
    'smpm.powerBalance.powerInertiaRotor' = 0.29 * 'smpm.inertiaRotor.a' * 'smpm.inertiaRotor.w';
    'smpm.powerBalance.lossPowerTotal' = 'smpm.powerBalance.lossPowerStatorWinding' + 'smpm.powerBalance.lossPowerStatorCore' + 'smpm.powerBalance.lossPowerRotorCore' + 'smpm.powerBalance.lossPowerStrayLoad' + 'smpm.powerBalance.lossPowerFriction' + 'smpm.powerBalance.lossPowerRotorWinding' + 'smpm.powerBalance.lossPowerPermanentMagnet';
    'smpm.powerBalance.lossPowerStatorWinding' = 'smpm.rs.resistor[1].LossPower' + 'smpm.rs.resistor[2].LossPower' + 'smpm.rs.resistor[3].LossPower';
    'smpm.powerBalance.lossPowerStatorCore' = 'smpm.statorCore.lossPower';
    'smpm.powerBalance.lossPowerRotorCore' = 0.0;
    'smpm.powerBalance.lossPowerStrayLoad' = 'smpm.strayLoad.lossPower';
    'smpm.powerBalance.lossPowerFriction' = 'smpm.friction.lossPower';
    'smpm.powerBalance.lossPowerRotorWinding' = 'smpm.damperCageLossPower';
    'smpm.powerBalance.lossPowerPermanentMagnet' = 'smpm.permanentMagnet.lossPower';
    'smpm.i_0_s' = 'smpm.spacePhasorS.zero.i';
    'smpm.rs.resistor[1].heatPort.T' = 'smpm.rs.resistor[1].T_heatPort';
    'smpm.rs.resistor[1].heatPort.Q_flow' = -'smpm.rs.resistor[1].LossPower';
    'smpm.rs.resistor[2].heatPort.T' = 'smpm.rs.resistor[2].T_heatPort';
    'smpm.rs.resistor[2].heatPort.Q_flow' = -'smpm.rs.resistor[2].LossPower';
    'smpm.rs.resistor[3].heatPort.T' = 'smpm.rs.resistor[3].T_heatPort';
    'smpm.rs.resistor[3].heatPort.Q_flow' = -'smpm.rs.resistor[3].LossPower';
    'smpm.statorCore.heatPort.Q_flow' = -'smpm.statorCore.lossPower';
    'smpm.statorCore.w' = 'smpm.statorCoreParameters.wRef';
    'smpm.statorCore.wLimit' = noEvent(max(noEvent(abs('smpm.statorCore.w')), 'smpm.statorCore.coreParameters.wMin'));
    'smpm.strayLoad.heatPort.Q_flow' = -'smpm.strayLoad.lossPower';
    'smpm.strayLoad.iRMS' = sqrt(sum('smpm.strayLoad.i' .^ 2.0 / size('smpm.strayLoad.i', 1)));
    'smpm.thermalAmbient.Q_flowStatorWinding' = 'smpm.thermalAmbient.temperatureStatorWinding.port.Q_flow';
    'smpm.thermalAmbient.Q_flowStatorCore' = 'smpm.thermalAmbient.temperatureStatorCore.port.Q_flow';
    'smpm.thermalAmbient.Q_flowRotorCore' = 'smpm.thermalAmbient.temperatureRotorCore.port.Q_flow';
    'smpm.thermalAmbient.Q_flowStrayLoad' = 'smpm.thermalAmbient.temperatureStrayLoad.port.Q_flow';
    'smpm.thermalAmbient.Q_flowFriction' = 'smpm.thermalAmbient.temperatureFriction.port.Q_flow';
    'smpm.thermalAmbient.Q_flowRotorWinding' = 'smpm.thermalAmbient.temperatureRotorWinding.port.Q_flow';
    'smpm.thermalAmbient.Q_flowPermanentMagnet' = 'smpm.thermalAmbient.temperaturePermanentMagnet.port.Q_flow';
    'smpm.thermalAmbient.Q_flowTotal' = 'smpm.thermalAmbient.Q_flowStatorWinding' + 'smpm.thermalAmbient.Q_flowRotorWinding' + 'smpm.thermalAmbient.Q_flowPermanentMagnet' + 'smpm.thermalAmbient.Q_flowStatorCore' + 'smpm.thermalAmbient.Q_flowRotorCore' + 'smpm.thermalAmbient.Q_flowStrayLoad' + 'smpm.thermalAmbient.Q_flowFriction';
    'smpm.permanentMagnet.heatPort.Q_flow' = -'smpm.permanentMagnet.lossPower';
    'smpm.permanentMagnet.iRMS' = sqrt(sum('smpm.permanentMagnet.is' .^ 2.0 / size('smpm.permanentMagnet.is', 1)));
