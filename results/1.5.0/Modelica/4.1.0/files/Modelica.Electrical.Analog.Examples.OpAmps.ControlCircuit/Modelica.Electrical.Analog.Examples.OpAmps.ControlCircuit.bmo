//! base 0.1.0
package 'ControlCircuit'
  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'ControlCircuit' "Control circuit"
    parameter Real 'T1'(unit = "s", quantity = "Time") = 0.01 "Small time constant";
    parameter Real 'T2'(unit = "s", quantity = "Time") = 0.01 "Large time constant";
    parameter Real 'Ti'(unit = "s", quantity = "Time") = 0.01 "Integral time constant";
    parameter Real 'kp' = 0.5 "Proportional gain";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'stepA.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 10.0 "Height of step";
    Real 'stepA.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'stepA.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'stepA.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'stepA.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'stepA.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'stepA.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'stepA.signalSource.height' = 10.0 "Height of step";
    Real 'stepA.signalSource.y' "Connector of Real output signal";
    parameter Real 'stepA.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'stepA.signalSource.startTime'(unit = "s", quantity = "Time") = 0.1 "Output y = offset for time < startTime";
    parameter Real 'stepA.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'stepA.startTime'(unit = "s", quantity = "Time") = 0.1 "Time offset";
    Real 'feedbackA.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'feedbackA.v2'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'feedbackA.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'feedbackA.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'feedbackA.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'feedbackA.p1.i'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'feedbackA.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'feedbackA.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'feedbackA.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'feedbackA.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'feedbackA.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'feedbackA.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'feedbackA.Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply";
    parameter Real 'feedbackA.Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply";
    parameter Real 'feedbackA.V0' = 15000.0 "No-load amplification";
    parameter Real 'feedbackA.opAmp.V0' = 15000.0 "No-load amplification";
    parameter Boolean 'feedbackA.opAmp.useSupply' = false "Use supply pins (otherwise constant supply)" annotation(Evaluate = true);
    parameter Real 'feedbackA.opAmp.Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply voltage";
    parameter Real 'feedbackA.opAmp.Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply voltage";
    parameter Boolean 'feedbackA.opAmp.strict' = true "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.LimiterHomotopy' 'feedbackA.opAmp.homotopyType' = 'Modelica.Blocks.Types.LimiterHomotopy'.'NoHomotopy' "Simplified model for homotopy-based initialization" annotation(Evaluate = true);
    Real 'feedbackA.opAmp.vps'(unit = "V", quantity = "ElectricPotential") "Positive supply voltage";
    Real 'feedbackA.opAmp.vns'(unit = "V", quantity = "ElectricPotential") "Negative supply voltage";
    Real 'feedbackA.opAmp.v_in'(unit = "V", quantity = "ElectricPotential") "Input voltage difference";
    Real 'feedbackA.opAmp.v_out'(unit = "V", quantity = "ElectricPotential") "Output voltage to ground";
    Real 'feedbackA.opAmp.p_in'(unit = "W", quantity = "Power") "Input power";
    Real 'feedbackA.opAmp.p_out'(unit = "W", quantity = "Power") "Output power";
    Real 'feedbackA.opAmp.p_s'(unit = "W", quantity = "Power") "Supply power";
    Real 'feedbackA.opAmp.i_s'(unit = "A", quantity = "ElectricCurrent") "Supply current";
    Real 'feedbackA.opAmp.in_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'feedbackA.opAmp.in_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'feedbackA.opAmp.in_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'feedbackA.opAmp.in_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'feedbackA.opAmp.out.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'feedbackA.opAmp.out.i'(fixed = false, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'feedbackA.opAmp.simplifiedExpr'(unit = "V", quantity = "ElectricPotential") "Simplified expression for homotopy-based initialization";
    Real 'feedbackA.v1_2'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1_2 (= p1_2.v - n1.v)";
    Real 'feedbackA.i1_2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1_2";
    parameter Real 'feedbackA.k'(min = 0.0) = 1.0 "Desired amplification";
    parameter Real 'feedbackA.R1'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at inputs of OpAmp";
    parameter Real 'feedbackA.R3'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Calculated resistance to reach desired amplification k";
    parameter Real 'feedbackA.r1.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at temperature T_ref";
    parameter Real 'feedbackA.r1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'feedbackA.r1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'feedbackA.r1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'feedbackA.r1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'feedbackA.r1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'feedbackA.r1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
