    'dcpm2.airGapDC.pin_en.v' = 'dcpm2.eGround.p.v';
    'dcpm2.airGapDC.pin_en.v' = 'dcpm2.ie.p.v';
    'dcpm2.airGapDC.pin_ep.v' = 'dcpm2.ie.n.v';
