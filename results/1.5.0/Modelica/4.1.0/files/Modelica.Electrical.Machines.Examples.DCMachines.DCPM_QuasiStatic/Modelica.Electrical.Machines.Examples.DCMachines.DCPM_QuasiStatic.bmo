  equation
    'dcpm1.phiMechanical' = 'dcpm1.flange.phi' - 'dcpm1.internalSupport.phi';
    'dcpm1.wMechanical' = der('dcpm1.phiMechanical');
    'dcpm1.tauElectrical' = 'dcpm1.inertiaRotor.flange_a.tau';
    'dcpm1.tauShaft' = -'dcpm1.flange.tau';
    'dcpm1.friction.heatPort.Q_flow' = -'dcpm1.friction.lossPower';
    'dcpm1.powerBalance.powerArmature' = 'dcpm1.va' * 'dcpm1.ia';
    'dcpm1.powerBalance.powerMechanical' = 'dcpm1.wMechanical' * 'dcpm1.tauShaft';
    'dcpm1.powerBalance.powerInertiaStator' = 0.15 * 'dcpm1.inertiaStator.a' * 'dcpm1.inertiaStator.w';
    'dcpm1.powerBalance.powerInertiaRotor' = 0.15 * 'dcpm1.inertiaRotor.a' * 'dcpm1.inertiaRotor.w';
    'dcpm1.powerBalance.lossPowerTotal' = 'dcpm1.powerBalance.lossPowerArmature' + 'dcpm1.powerBalance.lossPowerCore' + 'dcpm1.powerBalance.lossPowerStrayLoad' + 'dcpm1.powerBalance.lossPowerFriction' + 'dcpm1.powerBalance.lossPowerBrush' + 'dcpm1.powerBalance.lossPowerPermanentMagnet';
    'dcpm1.powerBalance.lossPowerArmature' = 'dcpm1.ra.LossPower';
