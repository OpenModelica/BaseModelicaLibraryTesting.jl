    'dcpm2.thermalAmbient.constTpm.y' = 'dcpm2.thermalAmbient.temperaturePermanentMagnet.T';
    'dcpm2.thermalAmbient.constTa.y' = 'dcpm2.thermalAmbient.temperatureArmature.T';
