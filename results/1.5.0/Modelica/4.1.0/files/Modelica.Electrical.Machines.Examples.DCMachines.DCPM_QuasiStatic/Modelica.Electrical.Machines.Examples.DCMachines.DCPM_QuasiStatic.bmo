    'dcpm1.powerBalance.lossPowerPermanentMagnet' = 0.0;
    'dcpm1.va' = 'dcpm1.pin_ap.v' - 'dcpm1.pin_an.v';
    'dcpm1.ia' = 'dcpm1.pin_ap.i';
    'dcpm1.ra.heatPort.T' = 'dcpm1.ra.T_heatPort';
    'dcpm1.ra.heatPort.Q_flow' = -'dcpm1.ra.LossPower';
    'dcpm1.brush.heatPort.Q_flow' = -'dcpm1.brush.lossPower';
    'dcpm1.core.heatPort.Q_flow' = -'dcpm1.core.lossPower';
    'dcpm1.core.w' = 'dcpm1.airGapDC.w';
    'dcpm1.core.wLimit' = noEvent(max(noEvent(abs('dcpm1.core.w')), 'dcpm1.core.coreParameters.wMin'));
    'dcpm1.strayLoad.heatPort.Q_flow' = -'dcpm1.strayLoad.lossPower';
    'dcpm1.thermalAmbient.Q_flowArmature' = 'dcpm1.thermalAmbient.temperatureArmature.port.Q_flow';
    'dcpm1.thermalAmbient.Q_flowCore' = 'dcpm1.thermalAmbient.temperatureCore.port.Q_flow';
    'dcpm1.thermalAmbient.Q_flowStrayLoad' = 'dcpm1.thermalAmbient.temperatureStrayLoad.port.Q_flow';
    'dcpm1.thermalAmbient.Q_flowFriction' = 'dcpm1.thermalAmbient.temperatureFriction.port.Q_flow';
    'dcpm1.thermalAmbient.Q_flowBrush' = 'dcpm1.thermalAmbient.temperatureBrush.port.Q_flow';
    'dcpm1.thermalAmbient.Q_flowPermanentMagnet' = 'dcpm1.thermalAmbient.temperaturePermanentMagnet.port.Q_flow';
    'dcpm1.thermalAmbient.Q_flowTotal' = 'dcpm1.thermalAmbient.Q_flowArmature' + 'dcpm1.thermalAmbient.Q_flowCore' + 'dcpm1.thermalAmbient.Q_flowStrayLoad' + 'dcpm1.thermalAmbient.Q_flowFriction' + 'dcpm1.thermalAmbient.Q_flowBrush' + 'dcpm1.thermalAmbient.Q_flowPermanentMagnet';
    'pulse.T_width' = 0.5;
    'dcpm2.phiMechanical' = 'dcpm2.flange.phi' - 'dcpm2.internalSupport.phi';
    'dcpm2.wMechanical' = der('dcpm2.phiMechanical');
    'dcpm2.tauElectrical' = 'dcpm2.inertiaRotor.flange_a.tau';
    'dcpm2.tauShaft' = -'dcpm2.flange.tau';
    'dcpm2.friction.heatPort.Q_flow' = -'dcpm2.friction.lossPower';
    'dcpm2.powerBalance.powerArmature' = 'dcpm2.va' * 'dcpm2.ia';
    'dcpm2.powerBalance.powerMechanical' = 'dcpm2.wMechanical' * 'dcpm2.tauShaft';
    'dcpm2.powerBalance.powerInertiaStator' = 0.15 * 'dcpm2.inertiaStator.a' * 'dcpm2.inertiaStator.w';
    'dcpm2.powerBalance.powerInertiaRotor' = 0.15 * 'dcpm2.inertiaRotor.a' * 'dcpm2.inertiaRotor.w';
    'dcpm2.powerBalance.lossPowerTotal' = 'dcpm2.powerBalance.lossPowerArmature' + 'dcpm2.powerBalance.lossPowerCore' + 'dcpm2.powerBalance.lossPowerStrayLoad' + 'dcpm2.powerBalance.lossPowerFriction' + 'dcpm2.powerBalance.lossPowerBrush' + 'dcpm2.powerBalance.lossPowerPermanentMagnet';
