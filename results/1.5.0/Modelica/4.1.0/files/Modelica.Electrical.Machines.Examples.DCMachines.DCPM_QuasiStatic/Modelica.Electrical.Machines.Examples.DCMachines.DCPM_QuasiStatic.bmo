    'dcpm2.thermalAmbient.Q_flowBrush' = 'dcpm2.thermalAmbient.temperatureBrush.port.Q_flow';
    'dcpm2.thermalAmbient.Q_flowPermanentMagnet' = 'dcpm2.thermalAmbient.temperaturePermanentMagnet.port.Q_flow';
