    'dcpm2.thermalAmbient.Q_flowCore' = 'dcpm2.thermalAmbient.temperatureCore.port.Q_flow';
    'dcpm2.thermalAmbient.Q_flowStrayLoad' = 'dcpm2.thermalAmbient.temperatureStrayLoad.port.Q_flow';
