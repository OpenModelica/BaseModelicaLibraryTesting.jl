    'dcpm1.thermalAmbient.temperaturePermanentMagnet.port.T' = 'dcpm1.thermalAmbient.thermalPort.heatPortPermanentMagnet.T';
    'dcpm1.thermalAmbient.constTpm.y' = 'dcpm1.thermalAmbient.temperaturePermanentMagnet.T';
    'dcpm1.thermalAmbient.constTa.y' = 'dcpm1.thermalAmbient.temperatureArmature.T';
    'dcpm1.thermalAmbient.temperatureArmature.port.T' = 'dcpm1.thermalAmbient.thermalPort.heatPortArmature.T';
    'dcpm1.thermalAmbient.temperatureBrush.port.T' = 'dcpm1.thermalAmbient.thermalPort.heatPortBrush.T';
    'dcpm1.thermalAmbient.temperatureCore.port.T' = 'dcpm1.thermalAmbient.thermalPort.heatPortCore.T';
    'dcpm1.thermalAmbient.temperatureStrayLoad.port.T' = 'dcpm1.thermalAmbient.thermalPort.heatPortStrayLoad.T';
    'dcpm1.thermalAmbient.temperatureFriction.port.T' = 'dcpm1.thermalAmbient.thermalPort.heatPortFriction.T';
    'dcpm1.airGapDC.pin_en.v' = 'dcpm1.eGround.p.v';
    'dcpm1.airGapDC.pin_en.v' = 'dcpm1.ie.p.v';
    'dcpm1.airGapDC.pin_ep.v' = 'dcpm1.ie.n.v';
    'dcpm1.airGapDC.pin_ap.v' = 'dcpm1.la.n.v';
    'dcpm1.friction.support.phi' = 'dcpm1.internalSupport.phi';
    'dcpm1.friction.support.phi' = 'dcpm1.inertiaStator.flange_a.phi';
    'dcpm1.friction.support.phi' = 'dcpm1.fixed.flange.phi';
    'dcpm1.friction.support.phi' = 'dcpm1.strayLoad.support.phi';
    'dcpm1.friction.support.phi' = 'dcpm1.airGapDC.support.phi';
    'dcpm1.airGapDC.flange.phi' = 'dcpm1.inertiaRotor.flange_a.phi';
    'dcpm1.core.n.v' = 'dcpm1.brush.p.v';
    'dcpm1.core.n.v' = 'dcpm1.airGapDC.pin_an.v';
    'dcpm1.la.p.v' = 'dcpm1.core.p.v';
    'dcpm1.la.p.v' = 'dcpm1.ra.n.v';
    'dcpm1.brush.n.v' = 'dcpm1.pin_an.v';
    'dcpm1.pin_ap.v' = 'dcpm1.strayLoad.p.v';
    'dcpm1.strayLoad.p.i' - 'dcpm1.pin_ap.i' = 0.0;
    'dcpm1.strayLoad.n.v' = 'dcpm1.ra.p.v';
