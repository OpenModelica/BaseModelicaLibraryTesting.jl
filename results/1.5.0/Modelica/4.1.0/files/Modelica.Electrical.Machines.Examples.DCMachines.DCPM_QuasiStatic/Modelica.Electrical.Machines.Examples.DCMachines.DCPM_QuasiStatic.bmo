    'dcpm1.inertiaRotor.flange_b.phi' = 'dcpm1.flange.phi';
    'dcpm1.inertiaRotor.flange_b.phi' = 'dcpm1.strayLoad.flange.phi';
    'dcpm1.strayLoad.flange.tau' + 'dcpm1.friction.flange.tau' + 'dcpm1.inertiaRotor.flange_b.tau' - 'dcpm1.flange.tau' = 0.0;
