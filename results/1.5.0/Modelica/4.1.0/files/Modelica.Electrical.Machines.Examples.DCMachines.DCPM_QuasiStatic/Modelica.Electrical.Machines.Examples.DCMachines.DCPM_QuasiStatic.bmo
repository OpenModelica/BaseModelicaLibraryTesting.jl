    'dcpm2.strayLoad.phi' = 'dcpm2.strayLoad.flange.phi' - 'dcpm2.strayLoad.support.phi';
    'dcpm2.strayLoad.w' = der('dcpm2.strayLoad.phi');
    'dcpm2.strayLoad.tau' = -'dcpm2.strayLoad.flange.tau';
    'dcpm2.strayLoad.tau' = 'dcpm2.strayLoad.support.tau';
    0.0 = 'dcpm2.strayLoad.p.i' + 'dcpm2.strayLoad.n.i';
    'dcpm2.strayLoad.i' = 'dcpm2.strayLoad.p.i';
    'dcpm2.strayLoad.v' = 'dcpm2.strayLoad.p.v' - 'dcpm2.strayLoad.n.v';
    'dcpm2.thermalAmbient.temperatureArmature.port.T' = 'dcpm2.thermalAmbient.temperatureArmature.T';
    'dcpm2.thermalAmbient.temperatureCore.port.T' = 293.15;
    'dcpm2.thermalAmbient.temperatureStrayLoad.port.T' = 293.15;
    'dcpm2.thermalAmbient.temperatureFriction.port.T' = 293.15;
    'dcpm2.thermalAmbient.constTa.y' = 293.15;
    'dcpm2.thermalAmbient.temperatureBrush.port.T' = 293.15;
    'dcpm2.thermalAmbient.temperaturePermanentMagnet.port.T' = 'dcpm2.thermalAmbient.temperaturePermanentMagnet.T';
    'dcpm2.thermalAmbient.constTpm.y' = 293.15;
    'dcpm2.airGapDC.psi_e' = 'dcpm2.airGapDC.ie';
    'dcpm2.airGapDC.vai' = 'dcpm2.airGapDC.pin_ap.v' - 'dcpm2.airGapDC.pin_an.v';
    'dcpm2.airGapDC.ia' = 'dcpm2.airGapDC.pin_ap.i';
    'dcpm2.airGapDC.ia' = -'dcpm2.airGapDC.pin_an.i';
    'dcpm2.airGapDC.vei' = 'dcpm2.airGapDC.pin_ep.v' - 'dcpm2.airGapDC.pin_en.v';
    'dcpm2.airGapDC.ie' = 'dcpm2.airGapDC.pin_ep.i';
    'dcpm2.airGapDC.ie' = -'dcpm2.airGapDC.pin_en.i';
    'dcpm2.airGapDC.vei' = 0.0;
    'dcpm2.airGapDC.w' = der('dcpm2.airGapDC.flange.phi') - der('dcpm2.airGapDC.support.phi');
    'dcpm2.airGapDC.vai' = 0.6366197723675815 * 'dcpm2.airGapDC.psi_e' * 'dcpm2.airGapDC.w';
    'dcpm2.airGapDC.tauElectrical' = 0.6366197723675815 * 'dcpm2.airGapDC.psi_e' * 'dcpm2.airGapDC.ia';
    'dcpm2.airGapDC.flange.tau' = -'dcpm2.airGapDC.tauElectrical';
    'dcpm2.airGapDC.support.tau' = 'dcpm2.airGapDC.tauElectrical';
    'dcpm2.eGround.p.v' = 0.0;
    'dcpm2.ie.i' = 1.0;
    0.0 = 'dcpm2.ie.p.i' + 'dcpm2.ie.n.i';
    'dcpm2.ie.i' = 'dcpm2.ie.p.i';
    'dcpm2.ie.v' = 'dcpm2.ie.p.v' - 'dcpm2.ie.n.v';
    'loadInertia2.phi' = 'loadInertia2.flange_a.phi';
    'loadInertia2.phi' = 'loadInertia2.flange_b.phi';
    'loadInertia2.w' = der('loadInertia2.phi');
    'loadInertia2.a' = der('loadInertia2.w');
    0.15 * 'loadInertia2.a' = 'loadInertia2.flange_a.tau' + 'loadInertia2.flange_b.tau';
    'loadTorque2.flange.tau' = -'loadTorque2.tau';
    'loadTorque2.phi_support' = 0.0;
  initial algorithm
    'pulse.count' := integer(time);
    'pulse.T_start' := 'pulse.count';
    annotation(experiment(StopTime = 2.0, Interval = 1E-4, Tolerance = 1E-6));
  end 'DCPM_QuasiStatic';
end 'DCPM_QuasiStatic';
