    Real 'dcpm.strayLoad.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcpm.strayLoad.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'dcpm.strayLoad.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'dcpm.strayLoad.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.strayLoad.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.strayLoad.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'dcpm.strayLoad.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'dcpm.strayLoad.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between shaft and support";
    Real 'dcpm.strayLoad.tau'(unit = "N.m", quantity = "Torque") "Torque";
