    parameter Real 'volumeFlow.constantVolumeFlow'(start = 1.0, unit = "m3/s", quantity = "VolumeFlowRate") = 50.0 "Volume flow rate";
    Real 'volumeFlow.internalVolumeFlow'(unit = "m3/s", quantity = "VolumeFlowRate");
    parameter Real 'cooling.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'cooling.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'cooling.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'cooling.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'cooling.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    parameter Real 'cooling.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.0 "Mass of medium";
    parameter Real 'cooling.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Initial temperature of medium";
    parameter Boolean 'cooling.T0fixed' = false "Initial temperature guess value or fixed";
    parameter Real 'cooling.tapT'(max = 1.0, min = 0.0) = 0.5 "Defines temperature of heatPort between inlet and outlet temperature";
    Real 'cooling.dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop a->b";
    Real 'cooling.V_flow'(start = 0.0, unit = "m3/s", quantity = "VolumeFlowRate") "Volume flow a->b";
    Real 'cooling.Q_flow'(unit = "W", quantity = "Power") "Heat exchange with ambient";
    Real 'cooling.T'(nominal = 300.0, fixed = false, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    Real 'cooling.T_a'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'cooling.T_b'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_b";
    Real 'cooling.dT'(unit = "K", quantity = "ThermodynamicTemperature");
    Real 'cooling.T_q'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature relevant for heat exchange with ambient";
    Real 'cooling.h'(start = 'cooling.medium.cp' * 293.15, unit = "J/kg", quantity = "SpecificEnergy") "Medium's specific enthalpy";
    parameter Real 'cooling.flowPort_a.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'cooling.flowPort_a.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'cooling.flowPort_a.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'cooling.flowPort_a.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'cooling.flowPort_a.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'cooling.flowPort_a.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'cooling.flowPort_a.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'cooling.flowPort_a.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'cooling.flowPort_a.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'cooling.flowPort_b.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'cooling.flowPort_b.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'cooling.flowPort_b.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'cooling.flowPort_b.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'cooling.flowPort_b.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'cooling.flowPort_b.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'cooling.flowPort_b.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'cooling.flowPort_b.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'cooling.flowPort_b.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'cooling.V_flowLaminar'(start = 0.1, min = 2.2250738585072014e-308, unit = "m3/s", quantity = "VolumeFlowRate") = 0.1 "Laminar volume flow";
    parameter Real 'cooling.dpLaminar'(start = 0.1, displayUnit = "Pa", unit = "Pa", quantity = "Pressure") = 0.1 "Laminar pressure drop";
    parameter Real 'cooling.V_flowNominal'(start = 1.0, unit = "m3/s", quantity = "VolumeFlowRate") = 1.0 "Nominal volume flow";
    parameter Real 'cooling.dpNominal'(start = 1.0, displayUnit = "Pa", unit = "Pa", quantity = "Pressure") = 1.0 "Nominal pressure drop";
    parameter Real 'cooling.frictionLoss'(max = 1.0, min = 0.0) = 0.0 "Part of friction losses fed to medium";
    Real 'cooling.pressureDrop'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'cooling.volumeFlow'(unit = "m3/s", quantity = "VolumeFlowRate");
    Real 'cooling.Q_friction'(unit = "W", quantity = "Power");
    parameter Real 'cooling.dpNomMin'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    parameter Real 'cooling.k'(fixed = false, unit = "Pa.s2/m6");
    parameter Boolean 'cooling.useHeatPort' = true "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'cooling.h_g'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Geodetic height (height difference from flowPort_a to flowPort_b)";
    parameter Real 'cooling.g'(min = 0.0, unit = "m/s2", quantity = "Acceleration") = 9.80665 "Gravitation";
    Real 'cooling.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 'cooling.T_q' "Port temperature";
    Real 'cooling.heatPort.Q_flow'(unit = "W", quantity = "Power") = 'cooling.Q_flowHeatPort' "Heat flow rate (positive if flowing from outside into the component)";
    Real 'cooling.Q_flowHeatPort'(unit = "W", quantity = "Power") "Heat flow at conditional heatPort";
    parameter Real 'outlet.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'outlet.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'outlet.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'outlet.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'outlet.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    parameter Real 'outlet.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Initial temperature of medium";
    parameter Boolean 'outlet.T0fixed' = false "Initial temperature guess value or fixed";
    Real 'outlet.T_port'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'outlet.T'(nominal = 300.0, fixed = false, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    parameter Real 'outlet.flowPort.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'outlet.flowPort.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'outlet.flowPort.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'outlet.flowPort.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'outlet.flowPort.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'outlet.flowPort.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'outlet.flowPort.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'outlet.flowPort.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'outlet.flowPort.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    constant Boolean 'outlet.Exchange' = true "Exchange of medium via flowport";
    Real 'outlet.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy in the volume";
    parameter Boolean 'outlet.usePressureInput' = false "Enable / disable pressure input" annotation(Evaluate = true);
    parameter Real 'outlet.constantAmbientPressure'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 0.0 "Ambient pressure";
    parameter Boolean 'outlet.useTemperatureInput' = false "Enable / disable temperature input" annotation(Evaluate = true);
    parameter Real 'outlet.constantAmbientTemperature'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'outlet.pAmbient'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'outlet.TAmbient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    parameter Real 'fixedTemperature.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed temperature at port";
    Real 'fixedTemperature.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'fixedTemperature.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'thermalPort.heatPortArmature.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'thermalPort.heatPortArmature.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'thermalPort.heatPortCore.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'thermalPort.heatPortCore.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'thermalPort.heatPortStrayLoad.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'thermalPort.heatPortStrayLoad.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'thermalPort.heatPortFriction.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'thermalPort.heatPortFriction.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'thermalPort.heatPortBrush.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'thermalPort.heatPortBrush.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'thermalPort.heatPortPermanentMagnet.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'thermalPort.heatPortPermanentMagnet.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'dcpmData.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Rotor's moment of inertia";
    parameter Real 'dcpmData.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.15 "Stator's moment of inertia";
    parameter Real 'dcpmData.VaNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal armature voltage";
    parameter Real 'dcpmData.IaNominal'(unit = "A", quantity = "ElectricCurrent") = 100.0 "Nominal armature current (>0..Motor, <0..Generator)";
    parameter Real 'dcpmData.wNominal'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Nominal speed";
    parameter Real 'dcpmData.TaNominal'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 353.15 "Nominal armature temperature";
    parameter Real 'dcpmData.Ra'(unit = "Ohm", quantity = "Resistance") = 0.05 "Armature resistance at TaRef";
    parameter Real 'dcpmData.TaRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 353.15 "Reference temperature of armature resistance";
    parameter Real 'dcpmData.alpha20a'(displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.00392 "Temperature coefficient of armature resistance";
    parameter Real 'dcpmData.La'(unit = "H", quantity = "Inductance") = 0.0015 "Armature inductance";
    parameter Real 'dcpmData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'dcpmData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that the PRef refer to";
    parameter Real 'dcpmData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'dcpmData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'dcpmData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'dcpmData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.14922565104551516 "Linear angular velocity range";
    parameter Real 'dcpmData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Real 'dcpmData.ViNominal'(unit = "V", quantity = "ElectricPotential") = 95.0 "Induced voltage at nominal operating point";
    parameter Integer 'dcpmData.coreParameters.m' = 1 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'dcpmData.coreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'dcpmData.coreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 95.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'dcpmData.coreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'dcpmData.coreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'dcpmData.coreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'dcpmData.coreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 1.4922565104551514e-4 "Angular velocity limit";
    parameter Real 'dcpmData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'dcpmData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'dcpmData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 149.22565104551515 "Reference angular velocity that PRef refers to";
    parameter Real 'dcpmData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'dcpmData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'dcpmData.brushParameters.V'(unit = "V", quantity = "ElectricPotential") = 0.0 "Total voltage drop of brushes for currents > ILinear";
    parameter Real 'dcpmData.brushParameters.ILinear'(start = 0.01, unit = "A", quantity = "ElectricCurrent") = 1.0 "Current indicating linear voltage region of brush voltage drop";
  equation
    'dcpm.airGapDC.pin_en.v' = 'dcpm.eGround.p.v';
    'dcpm.airGapDC.pin_en.v' = 'dcpm.ie.p.v';
    'dcpm.airGapDC.pin_ep.v' = 'dcpm.ie.n.v';
    'dcpm.airGapDC.pin_ap.v' = 'dcpm.la.n.v';
    'dcpm.friction.support.phi' = 'dcpm.internalSupport.phi';
    'dcpm.friction.support.phi' = 'dcpm.inertiaStator.flange_a.phi';
    'dcpm.friction.support.phi' = 'dcpm.fixed.flange.phi';
    'dcpm.friction.support.phi' = 'dcpm.strayLoad.support.phi';
    'dcpm.friction.support.phi' = 'dcpm.airGapDC.support.phi';
    'dcpm.airGapDC.flange.phi' = 'dcpm.inertiaRotor.flange_a.phi';
    'dcpm.core.n.v' = 'dcpm.brush.p.v';
    'dcpm.core.n.v' = 'dcpm.airGapDC.pin_an.v';
    'dcpm.la.p.v' = 'dcpm.core.p.v';
    'dcpm.la.p.v' = 'dcpm.ra.n.v';
    'dcpm.brush.n.v' = 'dcpm.pin_an.v';
    'dcpm.pin_ap.v' = 'dcpm.strayLoad.p.v';
    'dcpm.strayLoad.p.i' - 'dcpm.pin_ap.i' = 0.0;
    'dcpm.strayLoad.n.v' = 'dcpm.ra.p.v';
    'dcpm.internalThermalPort.heatPortCore.T' = 'dcpm.thermalPort.heatPortCore.T';
    'dcpm.internalThermalPort.heatPortCore.T' = 'dcpm.core.heatPort.T';
    'dcpm.internalThermalPort.heatPortBrush.T' = 'dcpm.thermalPort.heatPortBrush.T';
    'dcpm.internalThermalPort.heatPortBrush.T' = 'dcpm.brush.heatPort.T';
    'dcpm.internalThermalPort.heatPortStrayLoad.T' = 'dcpm.thermalPort.heatPortStrayLoad.T';
    'dcpm.internalThermalPort.heatPortStrayLoad.T' = 'dcpm.strayLoad.heatPort.T';
    'dcpm.internalThermalPort.heatPortFriction.T' = 'dcpm.thermalPort.heatPortFriction.T';
    'dcpm.internalThermalPort.heatPortFriction.T' = 'dcpm.friction.heatPort.T';
    'dcpm.internalThermalPort.heatPortArmature.T' = 'dcpm.thermalPort.heatPortArmature.T';
    'dcpm.internalThermalPort.heatPortArmature.T' = 'dcpm.ra.heatPort.T';
    'dcpm.internalThermalPort.heatPortPermanentMagnet.T' = 'dcpm.thermalPort.heatPortPermanentMagnet.T';
    -('dcpm.internalThermalPort.heatPortPermanentMagnet.Q_flow' + 'dcpm.thermalPort.heatPortPermanentMagnet.Q_flow') = 0.0;
    'dcpm.inertiaRotor.flange_b.phi' = 'dcpm.friction.flange.phi';
    'dcpm.inertiaRotor.flange_b.phi' = 'dcpm.flange.phi';
    'dcpm.inertiaRotor.flange_b.phi' = 'dcpm.strayLoad.flange.phi';
    'dcpm.strayLoad.flange.tau' + 'dcpm.friction.flange.tau' + 'dcpm.inertiaRotor.flange_b.tau' - 'dcpm.flange.tau' = 0.0;
    'loadInertia.flange_b.phi' = 'loadTorque.flange.phi';
    'dcpm.flange.phi' = 'loadInertia.flange_a.phi';
    'armatureVoltage.n.v' = 'dcpm.pin_an.v';
    'armatureVoltage.n.v' = 'groundArmature.p.v';
    'armatureVoltage.p.v' = 'dcpm.pin_ap.v';
    'dcpm.thermalPort.heatPortCore.T' = 'thermalPort.heatPortCore.T';
    'dcpm.thermalPort.heatPortCore.T' = 'core.port.T';
    'dcpm.thermalPort.heatPortCore.T' = 'coreCooling.port_a.T';
    'dcpm.thermalPort.heatPortCore.T' = 'armatureCore.port_b.T';
    'pulse.y' = 'loadTorque.tau';
    'coreCooling.port_b.T' = 'cooling.heatPort.T';
    'cooling.flowPort_b.h' = 'outlet.flowPort.h';
    assert(abs('cooling.flowPort_b.medium.rho' - 'outlet.flowPort.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('cooling.flowPort_b.medium.cp' - 'outlet.flowPort.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('cooling.flowPort_b.medium.cv' - 'outlet.flowPort.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('cooling.flowPort_b.medium.lambda' - 'outlet.flowPort.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('cooling.flowPort_b.medium.nu' - 'outlet.flowPort.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'cooling.flowPort_b.p' = 'outlet.flowPort.p';
    'inlet.flowPort.h' = 'volumeFlow.flowPort_a.h';
    assert(abs('inlet.flowPort.medium.rho' - 'volumeFlow.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('inlet.flowPort.medium.cp' - 'volumeFlow.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('inlet.flowPort.medium.cv' - 'volumeFlow.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('inlet.flowPort.medium.lambda' - 'volumeFlow.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('inlet.flowPort.medium.nu' - 'volumeFlow.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'inlet.flowPort.p' = 'volumeFlow.flowPort_a.p';
    'volumeFlow.flowPort_b.h' = 'cooling.flowPort_a.h';
    assert(abs('volumeFlow.flowPort_b.medium.rho' - 'cooling.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('volumeFlow.flowPort_b.medium.cp' - 'cooling.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('volumeFlow.flowPort_b.medium.cv' - 'cooling.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('volumeFlow.flowPort_b.medium.lambda' - 'cooling.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('volumeFlow.flowPort_b.medium.nu' - 'cooling.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'volumeFlow.flowPort_b.p' = 'cooling.flowPort_a.p';
    'dcpm.thermalPort.heatPortArmature.T' = 'thermalPort.heatPortArmature.T';
    'dcpm.thermalPort.heatPortArmature.T' = 'armature.port.T';
    'dcpm.thermalPort.heatPortArmature.T' = 'armatureCore.port_a.T';
    'dcpm.thermalPort.heatPortStrayLoad.T' = 'thermalPort.heatPortStrayLoad.T';
    'dcpm.thermalPort.heatPortStrayLoad.T' = 'dcpm.thermalPort.heatPortPermanentMagnet.T';
    'dcpm.thermalPort.heatPortStrayLoad.T' = 'thermalPort.heatPortPermanentMagnet.T';
    'dcpm.thermalPort.heatPortStrayLoad.T' = 'dcpm.thermalPort.heatPortFriction.T';
    'dcpm.thermalPort.heatPortStrayLoad.T' = 'thermalPort.heatPortFriction.T';
    'dcpm.thermalPort.heatPortStrayLoad.T' = 'dcpm.thermalPort.heatPortBrush.T';
    'dcpm.thermalPort.heatPortStrayLoad.T' = 'thermalPort.heatPortBrush.T';
    'dcpm.thermalPort.heatPortStrayLoad.T' = 'fixedTemperature.port.T';
    'loadInertia.flange_a.tau' + 'dcpm.flange.tau' = 0.0;
    'dcpm.inertiaStator.flange_b.tau' = 0.0;
    'dcpm.friction.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortFriction.Q_flow' - 'dcpm.thermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcpm.internalSupport.tau' = 0.0;
    'dcpm.core.p.i' + 'dcpm.la.p.i' + 'dcpm.ra.n.i' = 0.0;
    'dcpm.ra.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortArmature.Q_flow' - 'dcpm.thermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcpm.brush.n.i' - 'dcpm.pin_an.i' = 0.0;
    'dcpm.brush.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortBrush.Q_flow' - 'dcpm.thermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcpm.core.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortCore.Q_flow' - 'dcpm.thermalPort.heatPortCore.Q_flow' = 0.0;
    'dcpm.strayLoad.n.i' + 'dcpm.ra.p.i' = 0.0;
    'dcpm.strayLoad.heatPort.Q_flow' - 'dcpm.internalThermalPort.heatPortStrayLoad.Q_flow' - 'dcpm.thermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortArmature.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortCore.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortFriction.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortBrush.Q_flow' = 0.0;
    'dcpm.internalThermalPort.heatPortPermanentMagnet.Q_flow' = 0.0;
    'dcpm.airGapDC.flange.tau' + 'dcpm.inertiaRotor.flange_a.tau' = 0.0;
    'dcpm.airGapDC.support.tau' + 'dcpm.strayLoad.support.tau' + 'dcpm.friction.support.tau' + 'dcpm.fixed.flange.tau' + 'dcpm.inertiaStator.flange_a.tau' - 'dcpm.internalSupport.tau' = 0.0;
    'dcpm.airGapDC.pin_ap.i' + 'dcpm.la.n.i' = 0.0;
    'dcpm.ie.n.i' + 'dcpm.airGapDC.pin_ep.i' = 0.0;
    'dcpm.airGapDC.pin_an.i' + 'dcpm.core.n.i' + 'dcpm.brush.p.i' = 0.0;
    'dcpm.ie.p.i' + 'dcpm.eGround.p.i' + 'dcpm.airGapDC.pin_en.i' = 0.0;
    'armatureVoltage.p.i' + 'dcpm.pin_ap.i' = 0.0;
    'groundArmature.p.i' + 'armatureVoltage.n.i' + 'dcpm.pin_an.i' = 0.0;
    'loadTorque.flange.tau' + 'loadInertia.flange_b.tau' = 0.0;
    'armatureCore.port_a.Q_flow' + 'armature.port.Q_flow' + 'dcpm.thermalPort.heatPortArmature.Q_flow' - 'thermalPort.heatPortArmature.Q_flow' = 0.0;
    'coreCooling.port_a.Q_flow' + 'core.port.Q_flow' + 'armatureCore.port_b.Q_flow' + 'dcpm.thermalPort.heatPortCore.Q_flow' - 'thermalPort.heatPortCore.Q_flow' = 0.0;
    'cooling.heatPort.Q_flow' + 'coreCooling.port_b.Q_flow' = 0.0;
    'volumeFlow.flowPort_a.m_flow' + 'inlet.flowPort.m_flow' = 0.0;
    'volumeFlow.flowPort_a.H_flow' + 'inlet.flowPort.H_flow' = 0.0;
    'cooling.flowPort_a.m_flow' + 'volumeFlow.flowPort_b.m_flow' = 0.0;
    'cooling.flowPort_a.H_flow' + 'volumeFlow.flowPort_b.H_flow' = 0.0;
    'outlet.flowPort.m_flow' + 'cooling.flowPort_b.m_flow' = 0.0;
    'outlet.flowPort.H_flow' + 'cooling.flowPort_b.H_flow' = 0.0;
    'fixedTemperature.port.Q_flow' + 'dcpm.thermalPort.heatPortPermanentMagnet.Q_flow' + 'dcpm.thermalPort.heatPortBrush.Q_flow' + 'dcpm.thermalPort.heatPortFriction.Q_flow' + 'dcpm.thermalPort.heatPortStrayLoad.Q_flow' - 'thermalPort.heatPortStrayLoad.Q_flow' - 'thermalPort.heatPortPermanentMagnet.Q_flow' - 'thermalPort.heatPortFriction.Q_flow' - 'thermalPort.heatPortBrush.Q_flow' = 0.0;
    'thermalPort.heatPortArmature.Q_flow' = 0.0;
    'thermalPort.heatPortCore.Q_flow' = 0.0;
    'thermalPort.heatPortStrayLoad.Q_flow' = 0.0;
    'thermalPort.heatPortFriction.Q_flow' = 0.0;
    'thermalPort.heatPortBrush.Q_flow' = 0.0;
    'thermalPort.heatPortPermanentMagnet.Q_flow' = 0.0;
    'dcpm.inertiaRotor.phi' = 'dcpm.inertiaRotor.flange_a.phi';
    'dcpm.inertiaRotor.phi' = 'dcpm.inertiaRotor.flange_b.phi';
    'dcpm.inertiaRotor.w' = der('dcpm.inertiaRotor.phi');
    'dcpm.inertiaRotor.a' = der('dcpm.inertiaRotor.w');
    0.15 * 'dcpm.inertiaRotor.a' = 'dcpm.inertiaRotor.flange_a.tau' + 'dcpm.inertiaRotor.flange_b.tau';
    'dcpm.inertiaStator.phi' = 'dcpm.inertiaStator.flange_a.phi';
    'dcpm.inertiaStator.phi' = 'dcpm.inertiaStator.flange_b.phi';
    'dcpm.inertiaStator.w' = der('dcpm.inertiaStator.phi');
    'dcpm.inertiaStator.a' = der('dcpm.inertiaStator.w');
    0.15 * 'dcpm.inertiaStator.a' = 'dcpm.inertiaStator.flange_a.tau' + 'dcpm.inertiaStator.flange_b.tau';
    'dcpm.fixed.flange.phi' = 0.0;
    'dcpm.friction.tau' = 0.0;
    'dcpm.friction.lossPower' = -'dcpm.friction.tau' * 'dcpm.friction.w';
    'dcpm.friction.phi' = 'dcpm.friction.flange.phi' - 'dcpm.friction.support.phi';
    'dcpm.friction.w' = der('dcpm.friction.phi');
    'dcpm.friction.tau' = -'dcpm.friction.flange.tau';
    'dcpm.friction.tau' = 'dcpm.friction.support.tau';
    assert(1.0 + 0.0031735751295336786 * ('dcpm.ra.T_heatPort' - 353.15) >= 2.220446049250313e-16, "Temperature outside scope of model!", AssertionLevel.error);
    'dcpm.ra.R_actual' = 0.05 * (1.0 + 0.0031735751295336786 * ('dcpm.ra.T_heatPort' - 353.15));
    'dcpm.ra.v' = 'dcpm.ra.R_actual' * 'dcpm.ra.i';
    'dcpm.ra.LossPower' = 'dcpm.ra.v' * 'dcpm.ra.i';
    0.0 = 'dcpm.ra.p.i' + 'dcpm.ra.n.i';
    'dcpm.ra.i' = 'dcpm.ra.p.i';
    'dcpm.ra.v' = 'dcpm.ra.p.v' - 'dcpm.ra.n.v';
    'dcpm.la.v' = 0.0015 * der('dcpm.la.i');
    0.0 = 'dcpm.la.p.i' + 'dcpm.la.n.i';
    'dcpm.la.i' = 'dcpm.la.p.i';
    'dcpm.la.v' = 'dcpm.la.p.v' - 'dcpm.la.n.v';
    'dcpm.brush.v' = 0.0;
    'dcpm.brush.lossPower' = 'dcpm.brush.v' * 'dcpm.brush.i';
    0.0 = 'dcpm.brush.p.i' + 'dcpm.brush.n.i';
    'dcpm.brush.i' = 'dcpm.brush.p.i';
    'dcpm.brush.v' = 'dcpm.brush.p.v' - 'dcpm.brush.n.v';
    'dcpm.core.Gc' = 0.0;
    'dcpm.core.i' = 0.0;
    'dcpm.core.lossPower' = 'dcpm.core.v' * 'dcpm.core.i';
    0.0 = 'dcpm.core.p.i' + 'dcpm.core.n.i';
    'dcpm.core.i' = 'dcpm.core.p.i';
    'dcpm.core.v' = 'dcpm.core.p.v' - 'dcpm.core.n.v';
    'dcpm.strayLoad.v' = 0.0;
    'dcpm.strayLoad.tau' = 0.0;
    'dcpm.strayLoad.lossPower' = -'dcpm.strayLoad.tau' * 'dcpm.strayLoad.w';
    'dcpm.strayLoad.phi' = 'dcpm.strayLoad.flange.phi' - 'dcpm.strayLoad.support.phi';
    'dcpm.strayLoad.w' = der('dcpm.strayLoad.phi');
    'dcpm.strayLoad.tau' = -'dcpm.strayLoad.flange.tau';
    'dcpm.strayLoad.tau' = 'dcpm.strayLoad.support.tau';
    0.0 = 'dcpm.strayLoad.p.i' + 'dcpm.strayLoad.n.i';
    'dcpm.strayLoad.i' = 'dcpm.strayLoad.p.i';
    'dcpm.strayLoad.v' = 'dcpm.strayLoad.p.v' - 'dcpm.strayLoad.n.v';
    'dcpm.airGapDC.psi_e' = 'dcpm.airGapDC.ie';
    'dcpm.airGapDC.vai' = 'dcpm.airGapDC.pin_ap.v' - 'dcpm.airGapDC.pin_an.v';
    'dcpm.airGapDC.ia' = 'dcpm.airGapDC.pin_ap.i';
    'dcpm.airGapDC.ia' = -'dcpm.airGapDC.pin_an.i';
    'dcpm.airGapDC.vei' = 'dcpm.airGapDC.pin_ep.v' - 'dcpm.airGapDC.pin_en.v';
    'dcpm.airGapDC.ie' = 'dcpm.airGapDC.pin_ep.i';
    'dcpm.airGapDC.ie' = -'dcpm.airGapDC.pin_en.i';
    'dcpm.airGapDC.vei' = der('dcpm.airGapDC.psi_e');
    'dcpm.airGapDC.w' = der('dcpm.airGapDC.flange.phi') - der('dcpm.airGapDC.support.phi');
    'dcpm.airGapDC.vai' = 0.6366197723675815 * 'dcpm.airGapDC.psi_e' * 'dcpm.airGapDC.w';
    'dcpm.airGapDC.tauElectrical' = 0.6366197723675815 * 'dcpm.airGapDC.psi_e' * 'dcpm.airGapDC.ia';
    'dcpm.airGapDC.flange.tau' = -'dcpm.airGapDC.tauElectrical';
    'dcpm.airGapDC.support.tau' = 'dcpm.airGapDC.tauElectrical';
    'dcpm.eGround.p.v' = 0.0;
    'dcpm.ie.i' = 1.0;
    0.0 = 'dcpm.ie.p.i' + 'dcpm.ie.n.i';
    'dcpm.ie.i' = 'dcpm.ie.p.i';
    'dcpm.ie.v' = 'dcpm.ie.p.v' - 'dcpm.ie.n.v';
    'armatureVoltage.v' = 100.0;
    0.0 = 'armatureVoltage.p.i' + 'armatureVoltage.n.i';
    'armatureVoltage.i' = 'armatureVoltage.p.i';
    'armatureVoltage.v' = 'armatureVoltage.p.v' - 'armatureVoltage.n.v';
    'groundArmature.p.v' = 0.0;
    'loadInertia.phi' = 'loadInertia.flange_a.phi';
    'loadInertia.phi' = 'loadInertia.flange_b.phi';
    'loadInertia.w' = der('loadInertia.phi');
    'loadInertia.a' = der('loadInertia.w');
    0.15 * 'loadInertia.a' = 'loadInertia.flange_a.tau' + 'loadInertia.flange_b.tau';
    'loadTorque.flange.tau' = -'loadTorque.tau';
    'loadTorque.phi_support' = 0.0;

    when time >= (pre('pulse.count') + 1) then
      'pulse.count' = pre('pulse.count') + 1;
      'pulse.T_start' = time;
    end when;

    'pulse.y' = if time < 0.0 then 0.0 else if time < 'pulse.T_start' + 'pulse.T_width' then -95.49 else 0.0;
    'armature.T' = 'armature.port.T';
    'armature.der_T' = der('armature.T');
    20.0 * der('armature.T') = 'armature.port.Q_flow';
    'armatureCore.Q_flow' = 18.181818181818183 * 'armatureCore.dT';
    'armatureCore.dT' = 'armatureCore.port_a.T' - 'armatureCore.port_b.T';
    'armatureCore.port_a.Q_flow' = 'armatureCore.Q_flow';
    'armatureCore.port_b.Q_flow' = -'armatureCore.Q_flow';
    'core.T' = 'core.port.T';
    'core.der_T' = der('core.T');
    50.0 * der('core.T') = 'core.port.Q_flow';
    'coreCooling.Q_flow' = 18.181818181818183 * 'coreCooling.dT';
    'coreCooling.dT' = 'coreCooling.port_a.T' - 'coreCooling.port_b.T';
    'coreCooling.port_a.Q_flow' = 'coreCooling.Q_flow';
    'coreCooling.port_b.Q_flow' = -'coreCooling.Q_flow';
    'inlet.pAmbient' = 0.0;
    'inlet.TAmbient' = 293.15;
    'inlet.flowPort.p' = 'inlet.pAmbient';
    'inlet.T' = 'inlet.TAmbient';
    'inlet.T_port' = 'inlet.flowPort.h' / 'inlet.medium.cp';
    'inlet.T' = 'inlet.h' / 'inlet.medium.cp';
    'inlet.flowPort.H_flow' = semiLinear('inlet.flowPort.m_flow', 'inlet.flowPort.h', 'inlet.h');
    'volumeFlow.internalVolumeFlow' = 50.0;
    'volumeFlow.Q_flow' = 0.0;
    'volumeFlow.V_flow' = 'volumeFlow.internalVolumeFlow';
    'volumeFlow.dp' = 'volumeFlow.flowPort_a.p' - 'volumeFlow.flowPort_b.p';
    'volumeFlow.V_flow' = 'volumeFlow.flowPort_a.m_flow' / 'volumeFlow.medium.rho';
    'volumeFlow.T_a' = 'volumeFlow.flowPort_a.h' / 'volumeFlow.medium.cp';
    'volumeFlow.T_b' = 'volumeFlow.flowPort_b.h' / 'volumeFlow.medium.cp';
    'volumeFlow.dT' = if noEvent('volumeFlow.V_flow' >= 0.0) then 'volumeFlow.T' - 'volumeFlow.T_a' else 'volumeFlow.T_b' - 'volumeFlow.T';
    'volumeFlow.h' = 'volumeFlow.medium.cp' * 'volumeFlow.T';
    'volumeFlow.T_q' = 'volumeFlow.T';
    'volumeFlow.flowPort_a.m_flow' + 'volumeFlow.flowPort_b.m_flow' = 0.0;
    'volumeFlow.flowPort_a.H_flow' + 'volumeFlow.flowPort_b.H_flow' + 'volumeFlow.Q_flow' = 0.0;
    'volumeFlow.flowPort_a.H_flow' = semiLinear('volumeFlow.flowPort_a.m_flow', 'volumeFlow.flowPort_a.h', 'volumeFlow.h');
    'volumeFlow.flowPort_b.H_flow' = semiLinear('volumeFlow.flowPort_b.m_flow', 'volumeFlow.flowPort_b.h', 'volumeFlow.h');
    'cooling.volumeFlow' = 'cooling.V_flow';
    'cooling.dp' = 'cooling.pressureDrop';
    'cooling.Q_flow' = 'cooling.Q_flowHeatPort' + 'cooling.Q_friction';

    if 'cooling.volumeFlow' > 0.1 then
      'cooling.pressureDrop' = 'cooling.volumeFlow' + 'cooling.k' * ('cooling.volumeFlow' - 0.1) ^ 2.0;
    elseif 'cooling.volumeFlow' < (-0.1) then
      'cooling.pressureDrop' = 'cooling.volumeFlow' - 'cooling.k' * ('cooling.volumeFlow' + 0.1) ^ 2.0;
    elseif true then
      'cooling.pressureDrop' = 'cooling.volumeFlow';
    end if;

    'cooling.Q_friction' = 0.0;
    'cooling.dp' = 'cooling.flowPort_a.p' - 'cooling.flowPort_b.p';
    'cooling.V_flow' = 'cooling.flowPort_a.m_flow' / 'cooling.medium.rho';
    'cooling.T_a' = 'cooling.flowPort_a.h' / 'cooling.medium.cp';
    'cooling.T_b' = 'cooling.flowPort_b.h' / 'cooling.medium.cp';
    'cooling.dT' = if noEvent('cooling.V_flow' >= 0.0) then 'cooling.T' - 'cooling.T_a' else 'cooling.T_b' - 'cooling.T';
    'cooling.h' = 'cooling.medium.cp' * 'cooling.T';
    'cooling.T_q' = 'cooling.T' - noEvent(sign('cooling.V_flow')) * 0.5 * 'cooling.dT';
    'cooling.flowPort_a.m_flow' + 'cooling.flowPort_b.m_flow' = 0.0;
    'cooling.flowPort_a.H_flow' + 'cooling.flowPort_b.H_flow' + 'cooling.Q_flow' = 0.0;
    'cooling.flowPort_a.H_flow' = semiLinear('cooling.flowPort_a.m_flow', 'cooling.flowPort_a.h', 'cooling.h');
    'cooling.flowPort_b.H_flow' = semiLinear('cooling.flowPort_b.m_flow', 'cooling.flowPort_b.h', 'cooling.h');
    'outlet.pAmbient' = 0.0;
    'outlet.TAmbient' = 293.15;
    'outlet.flowPort.p' = 'outlet.pAmbient';
    'outlet.T' = 'outlet.TAmbient';
    'outlet.T_port' = 'outlet.flowPort.h' / 'outlet.medium.cp';
    'outlet.T' = 'outlet.h' / 'outlet.medium.cp';
    'outlet.flowPort.H_flow' = semiLinear('outlet.flowPort.m_flow', 'outlet.flowPort.h', 'outlet.h');
    'fixedTemperature.port.T' = 293.15;
  initial algorithm
    'pulse.count' := integer(time);
    'pulse.T_start' := 'pulse.count';
  initial algorithm
    assert(true, "SimpleFriction: V_flowNominal has to be > V_flowLaminar!", AssertionLevel.error);
    assert(true, "SimpleFriction: dpNominal has to be > dpLaminar/V_flowLaminar*V_flowNominal!", AssertionLevel.error);
    'cooling.k' := 0.0;
    annotation(experiment(StopTime = 25, Interval = 1E-4, Tolerance = 1E-6));
  end 'DCPM_Cooling';
end 'DCPM_Cooling';
