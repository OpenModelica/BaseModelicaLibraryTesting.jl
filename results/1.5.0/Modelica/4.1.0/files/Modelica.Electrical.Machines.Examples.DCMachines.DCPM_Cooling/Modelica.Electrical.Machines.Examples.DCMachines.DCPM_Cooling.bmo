    parameter Real 'dcpm.core.coreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'dcpm.core.coreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'dcpm.core.coreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 1.4922565104551514e-4 "Angular velocity limit";
    parameter Boolean 'dcpm.core.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'dcpm.core.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'dcpm.core.heatPort.Q_flow'(unit = "W", quantity = "Power") = -'dcpm.core.lossPower' "Heat flow rate (positive if flowing from outside into the component)";
    Real 'dcpm.core.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'dcpm.core.w'(unit = "rad/s", quantity = "AngularVelocity") = 'dcpm.airGapDC.w' "Remagnetization angular velocity";
    Real 'dcpm.core.Gc'(unit = "S", quantity = "Conductance") "Variable core loss conductance";
    Real 'dcpm.core.wLimit'(unit = "rad/s", quantity = "AngularVelocity") = noEvent(max(noEvent(abs('dcpm.core.w')), 'dcpm.core.coreParameters.wMin')) "Limited angular velocity";
