//! base 0.1.0
package 'ChopperBuckBoost_DutyCycle'
  type 'Modelica.Electrical.PowerConverters.Types.SingleReferenceType' = enumeration('Sawtooth', 'Triangle');

  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'ChopperBuckBoost_DutyCycle'
    parameter Real 'VLV'(unit = "V", quantity = "ElectricPotential") = 12.0 "LV voltage";
    parameter Real 'RiLV'(unit = "Ohm", quantity = "Resistance") = 0.01 "LV inner resistance";
    parameter Real 'VHV'(unit = "V", quantity = "ElectricPotential") = 24.0 "HV voltage";
