    Real 'dcdc.vDC1'(unit = "V", quantity = "ElectricPotential") = 'dcdc.dc_p1.v' - 'dcdc.dc_n1.v' "DC voltage side 1";
    Real 'dcdc.iDC1'(unit = "A", quantity = "ElectricCurrent") = 'dcdc.dc_p1.i' "DC current side 1";
    Real 'dcdc.powerDC1'(unit = "W", quantity = "Power") = 'dcdc.vDC1' * 'dcdc.iDC1' "DC power side 1";
    Real 'dcdc.dc_p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'dcdc.dc_p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
