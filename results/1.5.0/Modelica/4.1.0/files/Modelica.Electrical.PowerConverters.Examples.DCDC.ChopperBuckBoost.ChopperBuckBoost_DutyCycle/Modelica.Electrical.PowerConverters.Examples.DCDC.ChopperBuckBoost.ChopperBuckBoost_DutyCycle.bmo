    Real 'mean_vLV.u' "Connector of Real input signal";
    Real 'mean_vLV.y' "Connector of Real output signal";
    parameter Real 'mean_vLV.f'(start = 50.0, unit = "Hz", quantity = "Frequency") = 4e4 "Base frequency";
    parameter Real 'mean_vLV.x0' = 0.0 "Start value of integrator state";
    parameter Real 'mean_vLV.y0' = 0.0 "Start value of output";
    parameter Boolean 'mean_vLV.yGreaterOrEqualZero' = false "= true, if output y is guaranteed to be >= 0 for the exact solution" annotation(Evaluate = true);
    parameter Real 'mean_vLV.t0'(fixed = false, unit = "s", quantity = "Time") "Start time of simulation";
    Real 'mean_vLV.x' "Integrator state";
    discrete Real 'mean_vLV.y_last' "Last sampled mean value";
    Real 'mean_iLV.u' "Connector of Real input signal";
    Real 'mean_iLV.y' "Connector of Real output signal";
    parameter Real 'mean_iLV.f'(start = 50.0, unit = "Hz", quantity = "Frequency") = 4e4 "Base frequency";
    parameter Real 'mean_iLV.x0' = 0.0 "Start value of integrator state";
    parameter Real 'mean_iLV.y0' = 0.0 "Start value of output";
    parameter Boolean 'mean_iLV.yGreaterOrEqualZero' = false "= true, if output y is guaranteed to be >= 0 for the exact solution" annotation(Evaluate = true);
    parameter Real 'mean_iLV.t0'(fixed = false, unit = "s", quantity = "Time") "Start time of simulation";
    Real 'mean_iLV.x' "Integrator state";
    discrete Real 'mean_iLV.y_last' "Last sampled mean value";
    Real 'mean_vHV.u' "Connector of Real input signal";
    Real 'mean_vHV.y' "Connector of Real output signal";
    parameter Real 'mean_vHV.f'(start = 50.0, unit = "Hz", quantity = "Frequency") = 4e4 "Base frequency";
    parameter Real 'mean_vHV.x0' = 0.0 "Start value of integrator state";
    parameter Real 'mean_vHV.y0' = 0.0 "Start value of output";
    parameter Boolean 'mean_vHV.yGreaterOrEqualZero' = false "= true, if output y is guaranteed to be >= 0 for the exact solution" annotation(Evaluate = true);
    parameter Real 'mean_vHV.t0'(fixed = false, unit = "s", quantity = "Time") "Start time of simulation";
    Real 'mean_vHV.x' "Integrator state";
    discrete Real 'mean_vHV.y_last' "Last sampled mean value";
    Real 'mean_iHV.u' "Connector of Real input signal";
    Real 'mean_iHV.y' "Connector of Real output signal";
    parameter Real 'mean_iHV.f'(start = 50.0, unit = "Hz", quantity = "Frequency") = 4e4 "Base frequency";
    parameter Real 'mean_iHV.x0' = 0.0 "Start value of integrator state";
    parameter Real 'mean_iHV.y0' = 0.0 "Start value of output";
    parameter Boolean 'mean_iHV.yGreaterOrEqualZero' = false "= true, if output y is guaranteed to be >= 0 for the exact solution" annotation(Evaluate = true);
    parameter Real 'mean_iHV.t0'(fixed = false, unit = "s", quantity = "Time") "Start time of simulation";
    Real 'mean_iHV.x' "Integrator state";
    discrete Real 'mean_iHV.y_last' "Last sampled mean value";
    parameter Boolean 'pwm.useConstantDutyCycle' = false "Enables constant duty cycle";
    parameter Real 'pwm.constantDutyCycle' = 0.0 "Constant duty cycle";
    parameter Real 'pwm.f'(unit = "Hz", quantity = "Frequency") = 4e4 "Switching frequency";
    parameter 'Modelica.Electrical.PowerConverters.Types.SingleReferenceType' 'pwm.refType' = 'Modelica.Electrical.PowerConverters.Types.SingleReferenceType'.'Sawtooth' "Type of reference signal";
    parameter Boolean 'pwm.commonComparison' = true "Common or separated comparison for fire_p and fire_n";
    parameter Real 'pwm.startTime'(unit = "s", quantity = "Time") = 0.0 "Start time";
    Real 'pwm.dutyCycle' "Duty cycle";
    Boolean 'pwm.fire' "Firing PWM signal";
    Boolean 'pwm.notFire' "Firing PWM signal";
    parameter Real 'pwm.limiter.uMax'(start = 1.0) = 1.0 "Upper limits of input signals";
    parameter Real 'pwm.limiter.uMin' = 0.0 "Lower limits of input signals";
    parameter Boolean 'pwm.limiter.strict' = false "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.LimiterHomotopy' 'pwm.limiter.homotopyType' = 'Modelica.Blocks.Types.LimiterHomotopy'.'Linear' "Simplified model for homotopy-based initialization" annotation(Evaluate = true);
    Real 'pwm.limiter.u' "Connector of Real input signal";
    Real 'pwm.limiter.y' "Connector of Real output signal";
    Real 'pwm.limiter.simplifiedExpr' "Simplified expression for homotopy-based initialization";
    parameter Real 'pwm.zeroOrderHold.samplePeriod'(start = 0.1, min = 2.220446049250313e-14, unit = "s", quantity = "Time") = 2.5e-5 "Sample period of component";
    parameter Real 'pwm.zeroOrderHold.startTime'(unit = "s", quantity = "Time") = 0.0 "First sample time instant";
    Boolean 'pwm.zeroOrderHold.sampleTrigger' "True, if sample time instant";
    Boolean 'pwm.zeroOrderHold.firstTrigger'(fixed = true, start = false) "Rising edge signals first sample instant";
    Real 'pwm.zeroOrderHold.u' "Connector of Real input signal";
    Real 'pwm.zeroOrderHold.y' "Connector of Real output signal";
    Real 'pwm.zeroOrderHold.ySample'(fixed = true, start = 0.0);
    parameter Real 'pwm.sawtooth.amplitude' = 1.0 "Amplitude of saw tooth";
    parameter Real 'pwm.sawtooth.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 2.5e-5 "Time for one period";
    parameter Integer 'pwm.sawtooth.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'pwm.sawtooth.y' "Connector of Real output signal";
    parameter Real 'pwm.sawtooth.offset' = 0.0 "Offset of output signal y";
    parameter Real 'pwm.sawtooth.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    Real 'pwm.sawtooth.T_start'(start = 0.0, unit = "s", quantity = "Time") "Start time of current period";
    Integer 'pwm.sawtooth.count' "Period count";
    Real 'pwm.greaterEqual_p.u1' "Connector of first Real input signal";
    Real 'pwm.greaterEqual_p.u2' "Connector of second Real input signal";
    Boolean 'pwm.greaterEqual_p.y' "Connector of Boolean output signal";
    Boolean 'pwm.inverse.u' "Connector of Boolean input signal";
    Boolean 'pwm.inverse.y' "Connector of Boolean output signal";
    Real 'currentSensor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensor.i'(unit = "A") "Current in the branch from p to n as output signal";
    parameter Real 'dutyCycle.height' = 0.2 "Height of step";
    Real 'dutyCycle.y' "Connector of Real output signal";
    parameter Real 'dutyCycle.offset' = 0.4 "Offset of output signal y";
    parameter Real 'dutyCycle.startTime'(unit = "s", quantity = "Time") = 0.05 "Output y = offset for time < startTime";
  initial equation
    'mean_vLV.t0' = time;
    'mean_vLV.x' = 0.0;
    'mean_vLV.y_last' = 0.0;
    'mean_iLV.t0' = time;
    'mean_iLV.x' = 0.0;
    'mean_iLV.y_last' = 0.0;
    'mean_vHV.t0' = time;
    'mean_vHV.x' = 0.0;
    'mean_vHV.y_last' = 0.0;
    'mean_iHV.t0' = time;
    'mean_iHV.x' = 0.0;
    'mean_iHV.y_last' = 0.0;
  equation
    'dcdc.enableLogic.internalEnable[1]' = 'dcdc.enableLogic.booleanReplicator.y[1]';
    'dcdc.enableLogic.enableConstantSource.y' = 'dcdc.enableLogic.booleanReplicator.u';
    'dcdc.transistorHS.n.v' = 'dcdc.dc_p1.v';
    'dcdc.transistorHS.n.v' = 'dcdc.transistorLS.p.v';
    'dcdc.transistorHS.n.v' = 'dcdc.diodeHS.p.v';
    'dcdc.transistorHS.n.v' = 'dcdc.diodeLS.n.v';
    'dcdc.transistorHS.p.v' = 'dcdc.dc_p2.v';
    'dcdc.transistorHS.p.v' = 'dcdc.diodeHS.n.v';
    'dcdc.dc_n1.v' = 'dcdc.dc_n2.v';
    'dcdc.dc_n1.v' = 'dcdc.transistorLS.n.v';
    'dcdc.dc_n1.v' = 'dcdc.diodeLS.p.v';
    'dcdc.diodeLS.p.i' + 'dcdc.transistorLS.n.i' - 'dcdc.dc_n1.i' - 'dcdc.dc_n2.i' = 0.0;
    'dcdc.andCondition_n.y' = 'dcdc.transistorHS.fire';
    'dcdc.andCondition_p.y' = 'dcdc.transistorLS.fire';
    'dcdc.fire_n' = 'dcdc.andCondition_n.u1';
    'dcdc.enableLogic.internalEnable[1]' = 'dcdc.andCondition_p.u2';
    'dcdc.enableLogic.internalEnable[1]' = 'dcdc.andCondition_n.u2';
    'dcdc.andCondition_p.u1' = 'dcdc.fire_p';
    'pwm.dutyCycle' = 'pwm.limiter.u';
    'pwm.limiter.y' = 'pwm.zeroOrderHold.u';
    'pwm.zeroOrderHold.y' = 'pwm.greaterEqual_p.u1';
    'pwm.greaterEqual_p.y' = 'pwm.inverse.u';
    'pwm.greaterEqual_p.y' = 'pwm.fire';
    'pwm.inverse.y' = 'pwm.notFire';
    'pwm.greaterEqual_p.u2' = 'pwm.sawtooth.y';
    'dutyCycle.y' = 'pwm.dutyCycle';
    'constantVoltageLV.p.v' = 'resistorLV.p.v';
    'ground.p.v' = 'currentSensor.n.v';
    'ground.p.v' = 'constantVoltageLV.n.v';
    'resistorHV.p.v' = 'constantVoltageHV.p.v';
    'vLV.y' = 'mean_vLV.u';
    'iLV.y' = 'mean_iLV.u';
    'mean_iHV.u' = 'iHV.y';
    'vHV.y' = 'mean_vHV.u';
    'capacitorHV.n.v' = 'constantVoltageHV.n.v';
    'capacitorHV.n.v' = 'dcdc.dc_n2.v';
    'capacitorHV.p.v' = 'resistorHV.n.v';
    'capacitorHV.p.v' = 'dcdc.dc_p2.v';
    'resistor.p.v' = 'capacitorLV.p.v';
    'resistor.p.v' = 'resistorLV.n.v';
    'resistor.n.v' = 'inductor.p.v';
    'dcdc.dc_p1.v' = 'inductor.n.v';
    'dcdc.fire_p' = 'pwm.fire';
    'dcdc.fire_n' = 'pwm.notFire';
    'capacitorLV.n.v' = 'dcdc.dc_n1.v';
    'capacitorLV.n.v' = 'currentSensor.p.v';
    'inductor.n.i' + 'dcdc.dc_p1.i' = 0.0;
    'resistorHV.n.i' + 'capacitorHV.p.i' + 'dcdc.dc_p2.i' = 0.0;
    'constantVoltageHV.n.i' + 'capacitorHV.n.i' + 'dcdc.dc_n2.i' = 0.0;
    'dcdc.diodeHS.p.i' + 'dcdc.transistorHS.n.i' + 'dcdc.diodeLS.n.i' + 'dcdc.transistorLS.p.i' - 'dcdc.dc_p1.i' = 0.0;
    'dcdc.diodeHS.n.i' + 'dcdc.transistorHS.p.i' - 'dcdc.dc_p2.i' = 0.0;
    'resistorLV.p.i' + 'constantVoltageLV.p.i' = 0.0;
    'currentSensor.n.i' + 'ground.p.i' + 'constantVoltageLV.n.i' = 0.0;
    'resistor.p.i' + 'capacitorLV.p.i' + 'resistorLV.n.i' = 0.0;
    'inductor.p.i' + 'resistor.n.i' = 0.0;
    'resistorHV.p.i' + 'constantVoltageHV.p.i' = 0.0;
    'currentSensor.p.i' + 'capacitorLV.n.i' + 'dcdc.dc_n1.i' = 0.0;
    'dcdc.enableLogic.enableConstantSource.y' = true;
    'dcdc.enableLogic.booleanReplicator.y[1]' = 'dcdc.enableLogic.booleanReplicator.u';
    'dcdc.andCondition_p.y' = 'dcdc.andCondition_p.u1' and 'dcdc.andCondition_p.u2';
    'dcdc.andCondition_n.y' = 'dcdc.andCondition_n.u1' and 'dcdc.andCondition_n.u2';
    'dcdc.transistorLS.off' = 'dcdc.transistorLS.s' < 0.0 or not 'dcdc.transistorLS.fire';
    'dcdc.transistorLS.v' = 'dcdc.transistorLS.s' * (if 'dcdc.transistorLS.off' then 1.0 else 1e-5);
    'dcdc.transistorLS.i' = 'dcdc.transistorLS.s' * (if 'dcdc.transistorLS.off' then 1e-5 else 1.0);
    'dcdc.transistorLS.LossPower' = 'dcdc.transistorLS.v' * 'dcdc.transistorLS.i';
    'dcdc.transistorLS.T_heatPort' = 293.15;
    0.0 = 'dcdc.transistorLS.p.i' + 'dcdc.transistorLS.n.i';
    'dcdc.transistorLS.i' = 'dcdc.transistorLS.p.i';
    'dcdc.transistorLS.v' = 'dcdc.transistorLS.p.v' - 'dcdc.transistorLS.n.v';
    'dcdc.diodeLS.off' = 'dcdc.diodeLS.s' < 0.0;
    'dcdc.diodeLS.v' = 'dcdc.diodeLS.s' * (if 'dcdc.diodeLS.off' then 1.0 else 1e-5);
    'dcdc.diodeLS.i' = 'dcdc.diodeLS.s' * (if 'dcdc.diodeLS.off' then 1e-5 else 1.0);
    'dcdc.diodeLS.LossPower' = 'dcdc.diodeLS.v' * 'dcdc.diodeLS.i';
    'dcdc.diodeLS.T_heatPort' = 293.15;
    0.0 = 'dcdc.diodeLS.p.i' + 'dcdc.diodeLS.n.i';
    'dcdc.diodeLS.i' = 'dcdc.diodeLS.p.i';
    'dcdc.diodeLS.v' = 'dcdc.diodeLS.p.v' - 'dcdc.diodeLS.n.v';
    'dcdc.transistorHS.off' = 'dcdc.transistorHS.s' < 0.0 or not 'dcdc.transistorHS.fire';
    'dcdc.transistorHS.v' = 'dcdc.transistorHS.s' * (if 'dcdc.transistorHS.off' then 1.0 else 1e-5);
    'dcdc.transistorHS.i' = 'dcdc.transistorHS.s' * (if 'dcdc.transistorHS.off' then 1e-5 else 1.0);
    'dcdc.transistorHS.LossPower' = 'dcdc.transistorHS.v' * 'dcdc.transistorHS.i';
    'dcdc.transistorHS.T_heatPort' = 293.15;
    0.0 = 'dcdc.transistorHS.p.i' + 'dcdc.transistorHS.n.i';
    'dcdc.transistorHS.i' = 'dcdc.transistorHS.p.i';
    'dcdc.transistorHS.v' = 'dcdc.transistorHS.p.v' - 'dcdc.transistorHS.n.v';
    'dcdc.diodeHS.off' = 'dcdc.diodeHS.s' < 0.0;
    'dcdc.diodeHS.v' = 'dcdc.diodeHS.s' * (if 'dcdc.diodeHS.off' then 1.0 else 1e-5);
    'dcdc.diodeHS.i' = 'dcdc.diodeHS.s' * (if 'dcdc.diodeHS.off' then 1e-5 else 1.0);
    'dcdc.diodeHS.LossPower' = 'dcdc.diodeHS.v' * 'dcdc.diodeHS.i';
    'dcdc.diodeHS.T_heatPort' = 293.15;
    0.0 = 'dcdc.diodeHS.p.i' + 'dcdc.diodeHS.n.i';
    'dcdc.diodeHS.i' = 'dcdc.diodeHS.p.i';
    'dcdc.diodeHS.v' = 'dcdc.diodeHS.p.v' - 'dcdc.diodeHS.n.v';
    'dcdc.LossPower' = 'dcdc.diodeLS.LossPower' + 'dcdc.transistorLS.LossPower' + 'dcdc.diodeHS.LossPower' + 'dcdc.transistorHS.LossPower';
    'dcdc.T_heatPort' = 293.15;
    'constantVoltageLV.v' = 12.0;
    0.0 = 'constantVoltageLV.p.i' + 'constantVoltageLV.n.i';
    'constantVoltageLV.i' = 'constantVoltageLV.p.i';
    'constantVoltageLV.v' = 'constantVoltageLV.p.v' - 'constantVoltageLV.n.v';
    'resistorLV.R_actual' = 0.01;
    'resistorLV.v' = 'resistorLV.R_actual' * 'resistorLV.i';
    'resistorLV.LossPower' = 'resistorLV.v' * 'resistorLV.i';
    'resistorLV.T_heatPort' = 300.15;
    0.0 = 'resistorLV.p.i' + 'resistorLV.n.i';
    'resistorLV.i' = 'resistorLV.p.i';
    'resistorLV.v' = 'resistorLV.p.v' - 'resistorLV.n.v';
    'ground.p.v' = 0.0;
    'capacitorLV.i' = 5e-4 * der('capacitorLV.v');
    0.0 = 'capacitorLV.p.i' + 'capacitorLV.n.i';
    'capacitorLV.i' = 'capacitorLV.p.i';
    'capacitorLV.v' = 'capacitorLV.p.v' - 'capacitorLV.n.v';
    'resistor.R_actual' = 0.001;
    'resistor.v' = 'resistor.R_actual' * 'resistor.i';
    'resistor.LossPower' = 'resistor.v' * 'resistor.i';
    'resistor.T_heatPort' = 300.15;
    0.0 = 'resistor.p.i' + 'resistor.n.i';
    'resistor.i' = 'resistor.p.i';
    'resistor.v' = 'resistor.p.v' - 'resistor.n.v';
    1e-5 * der('inductor.i') = 'inductor.v';
    0.0 = 'inductor.p.i' + 'inductor.n.i';
    'inductor.i' = 'inductor.p.i';
    'inductor.v' = 'inductor.p.v' - 'inductor.n.v';
    'capacitorHV.i' = 2.5e-4 * der('capacitorHV.v');
    0.0 = 'capacitorHV.p.i' + 'capacitorHV.n.i';
    'capacitorHV.i' = 'capacitorHV.p.i';
    'capacitorHV.v' = 'capacitorHV.p.v' - 'capacitorHV.n.v';
    'constantVoltageHV.v' = 24.0;
    0.0 = 'constantVoltageHV.p.i' + 'constantVoltageHV.n.i';
    'constantVoltageHV.i' = 'constantVoltageHV.p.i';
    'constantVoltageHV.v' = 'constantVoltageHV.p.v' - 'constantVoltageHV.n.v';
    'resistorHV.R_actual' = 0.01;
    'resistorHV.v' = 'resistorHV.R_actual' * 'resistorHV.i';
    'resistorHV.LossPower' = 'resistorHV.v' * 'resistorHV.i';
    'resistorHV.T_heatPort' = 300.15;
    0.0 = 'resistorHV.p.i' + 'resistorHV.n.i';
    'resistorHV.i' = 'resistorHV.p.i';
    'resistorHV.v' = 'resistorHV.p.v' - 'resistorHV.n.v';
    der('mean_vLV.x') = 'mean_vLV.u';

    when sample('mean_vLV.t0' + 2.5e-5, 2.5e-5) then
      'mean_vLV.y_last' = 4e4 * pre('mean_vLV.x');
      reinit('mean_vLV.x', 0.0);
    end when;

    'mean_vLV.y' = 'mean_vLV.y_last';
    der('mean_iLV.x') = 'mean_iLV.u';

    when sample('mean_iLV.t0' + 2.5e-5, 2.5e-5) then
      'mean_iLV.y_last' = 4e4 * pre('mean_iLV.x');
      reinit('mean_iLV.x', 0.0);
    end when;

    'mean_iLV.y' = 'mean_iLV.y_last';
    der('mean_vHV.x') = 'mean_vHV.u';

    when sample('mean_vHV.t0' + 2.5e-5, 2.5e-5) then
      'mean_vHV.y_last' = 4e4 * pre('mean_vHV.x');
      reinit('mean_vHV.x', 0.0);
    end when;

    'mean_vHV.y' = 'mean_vHV.y_last';
    der('mean_iHV.x') = 'mean_iHV.u';

    when sample('mean_iHV.t0' + 2.5e-5, 2.5e-5) then
      'mean_iHV.y_last' = 4e4 * pre('mean_iHV.x');
      reinit('mean_iHV.x', 0.0);
    end when;

    'mean_iHV.y' = 'mean_iHV.y_last';
    'pwm.limiter.simplifiedExpr' = 'pwm.limiter.u';
    'pwm.limiter.y' = homotopy(smooth(0, if 'pwm.limiter.u' > 1.0 then 1.0 else if 'pwm.limiter.u' < 0.0 then 0.0 else 'pwm.limiter.u'), 'pwm.limiter.simplifiedExpr');

    when {'pwm.zeroOrderHold.sampleTrigger', initial()} then
      'pwm.zeroOrderHold.ySample' = if time >= 0.0 then 'pwm.zeroOrderHold.u' else pre('pwm.zeroOrderHold.ySample');
    end when;

    'pwm.zeroOrderHold.y' = pre('pwm.zeroOrderHold.ySample');
    'pwm.zeroOrderHold.sampleTrigger' = sample(0.0, 2.5e-5);

    when 'pwm.zeroOrderHold.sampleTrigger' then
      'pwm.zeroOrderHold.firstTrigger' = time <= 1.25e-5;
    end when;

    when time >= (pre('pwm.sawtooth.count') + 1) * 2.5e-5 then
      'pwm.sawtooth.count' = pre('pwm.sawtooth.count') + 1;
      'pwm.sawtooth.T_start' = time;
    end when;

    'pwm.sawtooth.y' = if time < 0.0 then 0.0 else (time - 'pwm.sawtooth.T_start') / 2.5e-5;
    'pwm.greaterEqual_p.y' = 'pwm.greaterEqual_p.u1' > 'pwm.greaterEqual_p.u2';
    'pwm.inverse.y' = not 'pwm.inverse.u';
    'currentSensor.p.v' = 'currentSensor.n.v';
    'currentSensor.p.i' = 'currentSensor.i';
    'currentSensor.n.i' = -'currentSensor.i';
    'dutyCycle.y' = 0.4 + (if time < 0.05 then 0.0 else 0.2);
  initial algorithm
    'pwm.sawtooth.count' := integer(time / 2.5e-5);
    'pwm.sawtooth.T_start' := 'pwm.sawtooth.count' * 2.5e-5;
    annotation(experiment(StopTime = 0.1, Interval = 1e-06, Tolerance = 1e-06));
  end 'ChopperBuckBoost_DutyCycle';
end 'ChopperBuckBoost_DutyCycle';
