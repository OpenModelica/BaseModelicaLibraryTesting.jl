//! base 0.1.0
package 'HighPass'
  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'HighPass' "High-pass filter"
    parameter Real 'Vin'(unit = "V", quantity = "ElectricPotential") = 5.0 "Amplitude of input voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of input voltage";
    parameter Real 'fG'(unit = "Hz", quantity = "Frequency") = 1.0 "Limiting frequency";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vOut.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vOut.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as output signal";
    Real 'derivative.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'derivative.v2'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'derivative.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'derivative.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'derivative.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'derivative.Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply";
    parameter Real 'derivative.Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply";
    parameter Real 'derivative.V0' = 15000.0 "No-load amplification";
    parameter Real 'derivative.opAmp.V0' = 15000.0 "No-load amplification";
    parameter Boolean 'derivative.opAmp.useSupply' = false "Use supply pins (otherwise constant supply)" annotation(Evaluate = true);
    parameter Real 'derivative.opAmp.Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply voltage";
    parameter Real 'derivative.opAmp.Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply voltage";
    parameter Boolean 'derivative.opAmp.strict' = true "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.LimiterHomotopy' 'derivative.opAmp.homotopyType' = 'Modelica.Blocks.Types.LimiterHomotopy'.'NoHomotopy' "Simplified model for homotopy-based initialization" annotation(Evaluate = true);
    Real 'derivative.opAmp.vps'(unit = "V", quantity = "ElectricPotential") "Positive supply voltage";
    Real 'derivative.opAmp.vns'(unit = "V", quantity = "ElectricPotential") "Negative supply voltage";
    Real 'derivative.opAmp.v_in'(unit = "V", quantity = "ElectricPotential") "Input voltage difference";
    Real 'derivative.opAmp.v_out'(unit = "V", quantity = "ElectricPotential") "Output voltage to ground";
    Real 'derivative.opAmp.p_in'(unit = "W", quantity = "Power") "Input power";
    Real 'derivative.opAmp.p_out'(unit = "W", quantity = "Power") "Output power";
    Real 'derivative.opAmp.p_s'(unit = "W", quantity = "Power") "Supply power";
    Real 'derivative.opAmp.i_s'(unit = "A", quantity = "ElectricCurrent") "Supply current";
    Real 'derivative.opAmp.in_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.opAmp.in_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.opAmp.in_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.opAmp.in_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.opAmp.out.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.opAmp.out.i'(fixed = false, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.opAmp.simplifiedExpr'(unit = "V", quantity = "ElectricPotential") "Simplified expression for homotopy-based initialization";
    parameter Real 'derivative.k'(min = 0.0) = 1.0 "Desired amplification";
    parameter Real 'derivative.R1'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at negative input of OpAmp";
    parameter Real 'derivative.R2'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Calculated resistance to reach k";
    parameter Real 'derivative.T'(unit = "s", quantity = "Time") = 0.15915494309189535 "Time constant";
    parameter Real 'derivative.C'(min = 0.0, unit = "F", quantity = "Capacitance") = 1.5915494309189535e-4 "Calculated capacitance to reach T";
    Real 'derivative.v'(fixed = true, start = 0.0, unit = "V", quantity = "ElectricPotential") "Capacitor voltage = state";
    parameter Real 'derivative.r1.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at temperature T_ref";
    parameter Real 'derivative.r1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'derivative.r1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'derivative.r1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'derivative.r1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.r1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.r1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.r1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.r1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'derivative.r1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'derivative.r1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'derivative.r1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'derivative.r1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'derivative.r1.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'derivative.r2.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at temperature T_ref";
    parameter Real 'derivative.r2.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'derivative.r2.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'derivative.r2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'derivative.r2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.r2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.r2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.r2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.r2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'derivative.r2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'derivative.r2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'derivative.r2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'derivative.r2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'derivative.r2.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'derivative.c.v'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'derivative.c.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.c.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.c.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'derivative.c.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'derivative.c.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'derivative.c.C'(start = 1.0, min = 0.0, unit = "F", quantity = "Capacitance") = 1.5915494309189535e-4 "Capacitance";
    parameter Real 'vIn.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 5.0 "Amplitude of trapezoid";
    parameter Real 'vIn.rising'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 0.02 "Rising duration of trapezoid";
    parameter Real 'vIn.width'(start = 0.5, min = 0.0, unit = "s", quantity = "Time") = 0.03 "Width duration of trapezoid";
    parameter Real 'vIn.falling'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 0.02 "Falling duration of trapezoid";
    parameter Real 'vIn.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time for one period";
    parameter Integer 'vIn.nperiod'(start = -1) = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'vIn.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'vIn.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vIn.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vIn.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vIn.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vIn.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'vIn.signalSource.amplitude' = 5.0 "Amplitude of trapezoid";
    parameter Real 'vIn.signalSource.rising'(min = 0.0, unit = "s", quantity = "Time") = 0.02 "Rising duration of trapezoid";
    parameter Real 'vIn.signalSource.width'(min = 0.0, unit = "s", quantity = "Time") = 0.03 "Width duration of trapezoid";
    parameter Real 'vIn.signalSource.falling'(min = 0.0, unit = "s", quantity = "Time") = 0.02 "Falling duration of trapezoid";
    parameter Real 'vIn.signalSource.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time for one period";
    parameter Integer 'vIn.signalSource.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'vIn.signalSource.y' "Connector of Real output signal";
    parameter Real 'vIn.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'vIn.signalSource.startTime'(unit = "s", quantity = "Time") = -0.035 "Output y = offset for time < startTime";
    parameter Real 'vIn.signalSource.T_rising'(unit = "s", quantity = "Time") = 0.02 "End time of rising phase within one period";
    parameter Real 'vIn.signalSource.T_width'(unit = "s", quantity = "Time") = 0.05 "End time of width phase within one period";
    parameter Real 'vIn.signalSource.T_falling'(unit = "s", quantity = "Time") = 0.07 "End time of falling phase within one period";
    Real 'vIn.signalSource.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'vIn.signalSource.count' "Period count";
    parameter Real 'vIn.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'vIn.startTime'(unit = "s", quantity = "Time") = -0.035 "Time offset";
  equation
    'derivative.opAmp.v_in' = 'derivative.opAmp.in_p.v' - 'derivative.opAmp.in_n.v';
    'derivative.opAmp.v_out' = 'derivative.opAmp.out.v';
    'derivative.opAmp.p_in' = 'derivative.opAmp.in_p.v' * 'derivative.opAmp.in_p.i' + 'derivative.opAmp.in_n.v' * 'derivative.opAmp.in_n.i';
    'derivative.opAmp.p_out' = 'derivative.opAmp.out.v' * 'derivative.opAmp.out.i';
    'derivative.opAmp.p_s' = -('derivative.opAmp.p_in' + 'derivative.opAmp.p_out');
    'derivative.opAmp.i_s' = 'derivative.opAmp.p_s' / ('derivative.opAmp.vps' - 'derivative.opAmp.vns');
    'derivative.v' = 'derivative.c.v';
    'derivative.n1.v' = 'derivative.opAmp.in_p.v';
    'derivative.n1.v' = 'derivative.n2.v';
    'derivative.opAmp.in_p.i' - 'derivative.n1.i' - 'derivative.n2.i' = 0.0;
    'derivative.opAmp.out.v' = 'derivative.r2.p.v';
    'derivative.opAmp.out.v' = 'derivative.p2.v';
    'derivative.r2.p.i' + 'derivative.opAmp.out.i' - 'derivative.p2.i' = 0.0;
    'derivative.opAmp.in_n.v' = 'derivative.r2.n.v';
    'derivative.opAmp.in_n.v' = 'derivative.r1.n.v';
    'derivative.c.n.v' = 'derivative.r1.p.v';
    'derivative.c.p.v' = 'derivative.p1.v';
    'vIn.n.v' = 'derivative.n1.v';
    'vIn.n.v' = 'ground.p.v';
    'derivative.p2.v' = 'vOut.p.v';
    'derivative.n2.v' = 'vOut.n.v';
    'vIn.p.v' = 'derivative.p1.v';
    'vIn.n.i' + 'derivative.n1.i' + 'ground.p.i' = 0.0;
    'derivative.p2.i' + 'vOut.p.i' = 0.0;
    'derivative.n2.i' + 'vOut.n.i' = 0.0;
    'derivative.r2.n.i' + 'derivative.r1.n.i' + 'derivative.opAmp.in_n.i' = 0.0;
    'derivative.c.p.i' - 'derivative.p1.i' = 0.0;
    'derivative.c.n.i' + 'derivative.r1.p.i' = 0.0;
    'vIn.p.i' + 'derivative.p1.i' = 0.0;
    'ground.p.v' = 0.0;
    'vOut.p.i' = 0.0;
    'vOut.n.i' = 0.0;
    'vOut.v' = 'vOut.p.v' - 'vOut.n.v';
    'derivative.opAmp.vps' = 15.0;
    'derivative.opAmp.vns' = -15.0;
    'derivative.opAmp.in_p.i' = 0.0;
    'derivative.opAmp.in_n.i' = 0.0;
    'derivative.opAmp.simplifiedExpr' = 0.0;
    'derivative.opAmp.v_out' = smooth(0, noEvent(if 15000.0 * 'derivative.opAmp.v_in' > 'derivative.opAmp.vps' then 'derivative.opAmp.vps' else if 15000.0 * 'derivative.opAmp.v_in' < 'derivative.opAmp.vns' then 'derivative.opAmp.vns' else 15000.0 * 'derivative.opAmp.v_in'));
    'derivative.r1.R_actual' = 1000.0;
    'derivative.r1.v' = 'derivative.r1.R_actual' * 'derivative.r1.i';
    'derivative.r1.LossPower' = 'derivative.r1.v' * 'derivative.r1.i';
    'derivative.r1.T_heatPort' = 300.15;
    0.0 = 'derivative.r1.p.i' + 'derivative.r1.n.i';
    'derivative.r1.i' = 'derivative.r1.p.i';
    'derivative.r1.v' = 'derivative.r1.p.v' - 'derivative.r1.n.v';
    'derivative.r2.R_actual' = 1000.0;
    'derivative.r2.v' = 'derivative.r2.R_actual' * 'derivative.r2.i';
    'derivative.r2.LossPower' = 'derivative.r2.v' * 'derivative.r2.i';
    'derivative.r2.T_heatPort' = 300.15;
    0.0 = 'derivative.r2.p.i' + 'derivative.r2.n.i';
    'derivative.r2.i' = 'derivative.r2.p.i';
    'derivative.r2.v' = 'derivative.r2.p.v' - 'derivative.r2.n.v';
    'derivative.c.i' = 1.5915494309189535e-4 * der('derivative.c.v');
    0.0 = 'derivative.c.p.i' + 'derivative.c.n.i';
    'derivative.c.i' = 'derivative.c.p.i';
    'derivative.c.v' = 'derivative.c.p.v' - 'derivative.c.n.v';
    'derivative.v1' = 'derivative.p1.v' - 'derivative.n1.v';
    'derivative.v2' = 'derivative.p2.v' - 'derivative.n2.v';
    'derivative.i1' = 'derivative.p1.i';
    'derivative.i2' = 'derivative.p2.i';

    when time >= (pre('vIn.signalSource.count') + 1) * 0.1 - 0.035 then
      'vIn.signalSource.count' = pre('vIn.signalSource.count') + 1;
      'vIn.signalSource.T_start' = time;
    end when;

    'vIn.signalSource.y' = if time < (-0.035) then 0.0 else if time < 'vIn.signalSource.T_start' + 0.02 then 5.0 * (time - 'vIn.signalSource.T_start') / 0.02 else if time < 'vIn.signalSource.T_start' + 0.05 then 5.0 else if time < 'vIn.signalSource.T_start' + 0.07 then 5.0 * ('vIn.signalSource.T_start' + 0.07 - time) / 0.02 else 0.0;
    'vIn.v' = 'vIn.signalSource.y';
    0.0 = 'vIn.p.i' + 'vIn.n.i';
    'vIn.i' = 'vIn.p.i';
    'vIn.v' = 'vIn.p.v' - 'vIn.n.v';
  initial algorithm
    'vIn.signalSource.count' := integer((time + 0.035) / 0.1);
    'vIn.signalSource.T_start' := 'vIn.signalSource.count' * 0.1 - 0.035;
    annotation(experiment(StartTime = 0, StopTime = 1, Tolerance = 1e-006, Interval = 0.001));
  end 'HighPass';
end 'HighPass';
