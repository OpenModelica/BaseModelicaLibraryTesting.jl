  model 'FourInverters' "Four inverters with MOSFET level 1, using private record as model card"
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'modp.VTO'(unit = "V", quantity = "ElectricPotential") = -1e40 "Zero-bias threshold voltage, default 0";
    parameter Real 'modp.KP'(unit = "A/V2", quantity = "Transconductance") = -1e40 "Transconductance parameter, default 2e-5";
    parameter Real 'modp.GAMMA' = -1e40 "Bulk threshold parameter, default 0";
    parameter Real 'modp.PHI'(unit = "V", quantity = "ElectricPotential") = -1e40 "Surface potential, default 0.6";
    parameter Real 'modp.LAMBDA'(unit = "1/V", quantity = "InversePotential") = 0.0 "Channel-length modulation, default 0";
    parameter Real 'modp.RD'(unit = "Ohm", quantity = "Resistance") = -1e40 "Drain ohmic resistance, default 0";
    parameter Real 'modp.RS'(unit = "Ohm", quantity = "Resistance") = -1e40 "Source ohmic resistance, default 0";
    parameter Real 'modp.CBD'(min = -1e60, unit = "F", quantity = "Capacitance") = 0.0 "Zero-bias B-D junction capacitance, default 0";
    parameter Real 'modp.CBS'(min = -1e60, unit = "F", quantity = "Capacitance") = 0.0 "Zero-bias B-S junction capacitance, default 0";
    parameter Real 'modp.IS'(unit = "A", quantity = "ElectricCurrent") = 1e-14 "Bulk junction saturation current";
    parameter Real 'modp.PB'(unit = "V", quantity = "ElectricPotential") = 0.8 "Bulk junction potential";
    parameter Real 'modp.CGSO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-source overlap capacitance per meter channel width";
    parameter Real 'modp.CGDO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-drain overlap capacitance per meter channel width";
    parameter Real 'modp.CGBO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-bulk overlap capacitance per meter channel width";
    parameter Real 'modp.RSH'(unit = "Ohm", quantity = "Resistance") = 0.0 "Drain and source diffusion sheet resistance";
    parameter Real 'modp.CJ'(unit = "F/m2", quantity = "CapacitancePerArea") = 0.0 "Zero-bias bulk junction bottom cap. per sq-meter of junction area";
    parameter Real 'modp.MJ' = 0.5 "Bulk junction bottom grading coefficient";
    parameter Real 'modp.CJSW'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Zero-bias junction sidewall cap. per meter of junction perimeter";
    parameter Real 'modp.MJSW' = 0.5 "Bulk junction sidewall grading coefficient";
    parameter Real 'modp.JS'(unit = "A/m2", quantity = "CurrentDensity") = 0.0 "Bulk junction saturation current per sq-meter of junction area";
    parameter Real 'modp.TOX'(unit = "m", quantity = "Length") = -1e40 "Oxide thickness, default 1e-7";
    parameter Real 'modp.NSUB' = -1e40 "Substrate doping, default 0";
    parameter Real 'modp.NSS'(unit = "1/cm2", quantity = "PerArea") = 0.0 "Surface state density";
    parameter Real 'modp.TPG' = 1.0 "Type of gate material: +1 opp. to substrate, -1 same as substrate, 0 Al gate";
    parameter Real 'modp.LD'(unit = "m", quantity = "Length") = 0.0 "Lateral diffusion";
    parameter Real 'modp.UO'(unit = "cm2/(V.s)", quantity = "AreaPerVoltageSecond") = 600.0 "Surface mobility";
    parameter Real 'modp.KF' = 0.0 "Flicker noise coefficient";
    parameter Real 'modp.AF' = 1.0 "Flicker noise exponent";
    parameter Real 'modp.FC' = 0.5 "Coefficient for forward-bias depletion capacitance formula";
    parameter Real 'modp.TNOM'(unit = "degC", quantity = "ThermodynamicTemperature") = 27.0 "Parameter measurement temperature, default 27";
    constant Integer 'modp.LEVEL' = 1 "Model level: Shichman-Hodges";
    parameter Real 'modn.VTO'(unit = "V", quantity = "ElectricPotential") = -1e40 "Zero-bias threshold voltage, default 0";
    parameter Real 'modn.KP'(unit = "A/V2", quantity = "Transconductance") = -1e40 "Transconductance parameter, default 2e-5";
