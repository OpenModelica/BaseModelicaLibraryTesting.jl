//! base 0.1.0
package 'SampleWithADeffects'
  function 'Modelica.Clocked.RealSignals.Sampler.Utilities.Internal.random' "Pseudo random number generator"
    input Integer[3] 'seedIn';
    output Real 'x';
    output Integer[3] 'seedOut';
  algorithm
    'seedOut'[1] := 171 * 'seedIn'[1] - div(171 * 'seedIn'[1], 30269) * 30269;
    'seedOut'[2] := 172 * 'seedIn'[2] - div(172 * 'seedIn'[2], 30307) * 30307;
    'seedOut'[3] := 170 * 'seedIn'[3] - div(170 * 'seedIn'[3], 30323) * 30323;

    if 'seedOut'[1] == 0 then
      'seedOut'[1] := 1;
    end if;

    if 'seedOut'[2] == 0 then
      'seedOut'[2] := 1;
    end if;

    if 'seedOut'[3] == 0 then
      'seedOut'[3] := 1;
    end if;

    'x' := 'seedOut'[1] / 30269.0 + 'seedOut'[2] / 30307.0 + 'seedOut'[3] / 30323.0 - div('seedOut'[1] / 30269.0 + 'seedOut'[2] / 30307.0 + 'seedOut'[3] / 30323.0, 1.0);
  end 'Modelica.Clocked.RealSignals.Sampler.Utilities.Internal.random';

  type 'Modelica.Clocked.Types.Resolution' = enumeration('y', 'd', 'h', 'm', 's', 'ms', 'us', 'ns');

  model 'SampleWithADeffects' "Example of a SampleWithADeffects block for Real signals"
    parameter Real 'sine.amplitude' = 0.95 "Amplitude of sine wave";
    parameter Real 'sine.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of sine wave";
    parameter Real 'sine.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine.y' "Connector of Real output signal";
    parameter Real 'sine.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    Real 'sample1.u' "Connector of continuous-time, Real input signal";
    Real 'sample1.y' "Connector of clocked, Real output signal";
    parameter Boolean 'sample1.noisy' = true "= true, if output should be superimposed with noise" annotation(Evaluate = true);
    parameter Boolean 'sample1.limited' = true "= true, if output is limited" annotation(Evaluate = true);
    parameter Boolean 'sample1.quantized' = true "= true, if output quantization effects included" annotation(Evaluate = true);
    parameter Real 'sample1.yMax' = 0.8 "Upper limit of output (if limited = true)";
    parameter Real 'sample1.yMin' = -0.8 "Lower limit of output (if limited = true)";
    parameter Integer 'sample1.bits'(min = 1) = 8 "Number of bits of quantization (if quantized = true)";
    Real 'sample1.sample1.u' "Connector of continuous-time, Real input signal";
    Real 'sample1.sample1.y' "Connector of clocked, Real output signal";
    Real 'sample1.noise.u' "Connector of clocked, Real input signal";
    Real 'sample1.noise.y' "Connector of clocked, Real output signal";
    parameter Real 'sample1.noise.noiseMax' = 0.2 "Upper limit of noise band";
    parameter Real 'sample1.noise.noiseMin' = -0.2 "Lower limit of noise band";
    parameter Integer 'sample1.noise.firstSeed[1]'(max = 255, min = 0) = 23 "Integer[3] defining random sequence; required element range: 0..255";
    parameter Integer 'sample1.noise.firstSeed[2]'(max = 255, min = 0) = 87 "Integer[3] defining random sequence; required element range: 0..255";
    parameter Integer 'sample1.noise.firstSeed[3]'(max = 255, min = 0) = 187 "Integer[3] defining random sequence; required element range: 0..255";
    Integer 'sample1.noise.seedState[1]'(fixed = true, start = 23) "State of seed";
    Integer 'sample1.noise.seedState[2]'(fixed = true, start = 87) "State of seed";
    Integer 'sample1.noise.seedState[3]'(fixed = true, start = 187) "State of seed";
    Real 'sample1.noise.noise' "Noise in the range 0..1";
    Real 'sample1.limiter.u' "Connector of clocked, Real input signal";
    Real 'sample1.limiter.y' "Connector of clocked, Real output signal";
    parameter Real 'sample1.limiter.uMax'(start = 1.0) = 0.8 "Upper limits of input signals";
    parameter Real 'sample1.limiter.uMin' = -0.8 "Lower limits of input signals";
    Real 'sample1.quantization.u' "Connector of clocked, Real input signal";
    Real 'sample1.quantization.y' "Connector of clocked, Real output signal";
    parameter Boolean 'sample1.quantization.quantized' = true "= true, if quantization effects shall be computed";
    parameter Real 'sample1.quantization.yMax' = 0.8 "Upper limit of output";
    parameter Real 'sample1.quantization.yMin' = -0.8 "Lower limit of output";
    parameter Integer 'sample1.quantization.bits'(min = 1) = 8 "Number of bits of quantization (if quantized = true)";
    parameter Real 'sample1.quantization.resolution' = 0.00625;
    Real 'sample1.y1' "Connector with a Real output signal";
    Real 'sample1.y2';
    Real 'sample1.y3';
    Real 'sample1.y4';
    Real 'assignClock.u' "Connector of clocked, Real input signal";
    Real 'assignClock.y' "Connector of clocked, Real output signal";
    Clock 'assignClock.clock';
    parameter Integer 'periodicClock.factor'(min = 0) = 20 "Sample factor with respect to resolution" annotation(Evaluate = true);
    parameter 'Modelica.Clocked.Types.Resolution' 'periodicClock.resolution' = 'Modelica.Clocked.Types.Resolution'.'ms' "Clock resolution" annotation(Evaluate = true);
    parameter Boolean 'periodicClock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'periodicClock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'periodicClock.y';
    constant Integer 'periodicClock.conversionTable[1]' = 31536000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[2]' = 86400 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[3]' = 3600 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[4]' = 60 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[5]' = 1 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[6]' = 1000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[7]' = 1000000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[8]' = 1000000000 "Table to convert from Resolution to Integer clock resolution";
    parameter Integer 'periodicClock.resolutionFactor' = 1000 annotation(Evaluate = true);
    Clock 'periodicClock.c';
  equation
    'sample1.sample1.y' = 'sample1.y1';
    'sample1.sample1.y' = 'sample1.noise.u';
    'sample1.y2' = 'sample1.limiter.u';
    'sample1.y2' = 'sample1.noise.y';
    'sample1.y3' = 'sample1.quantization.u';
    'sample1.y3' = 'sample1.limiter.y';
    'sample1.y4' = 'sample1.y';
    'sample1.y4' = 'sample1.quantization.y';
    'sample1.u' = 'sample1.sample1.u';
    'sine.y' = 'sample1.u';
    'sample1.y' = 'assignClock.u';
    'periodicClock.y' = 'assignClock.clock';
    'sine.y' = if time < 0.0 then 0.0 else 0.95 * sin(12.566370614359172 * time);
    'sample1.sample1.y' = sample('sample1.sample1.u', Clock());
    ('sample1.noise.noise', 'sample1.noise.seedState') = 'Modelica.Clocked.RealSignals.Sampler.Utilities.Internal.random'({previous('sample1.noise.seedState[1]'), previous('sample1.noise.seedState[2]'), previous('sample1.noise.seedState[3]')});
    'sample1.noise.y' = 'sample1.noise.u' - 0.2 + 0.4 * 'sample1.noise.noise';
    'sample1.limiter.y' = if 'sample1.limiter.u' > 0.8 then 0.8 else if 'sample1.limiter.u' < (-0.8) then -0.8 else 'sample1.limiter.u';
    'sample1.quantization.y' = 0.00625 * floor(abs('sample1.quantization.u' / 0.00625) + 0.5) * (if 'sample1.quantization.u' >= 0.0 then 1.0 else -1.0);

    when 'assignClock.clock' then
      'assignClock.y' = 'assignClock.u';
    end when;

    'periodicClock.c' = Clock('periodicClock.factor', 1000);
    'periodicClock.y' = 'periodicClock.c';
    annotation(experiment(StopTime = 0.2));
  end 'SampleWithADeffects';
end 'SampleWithADeffects';
