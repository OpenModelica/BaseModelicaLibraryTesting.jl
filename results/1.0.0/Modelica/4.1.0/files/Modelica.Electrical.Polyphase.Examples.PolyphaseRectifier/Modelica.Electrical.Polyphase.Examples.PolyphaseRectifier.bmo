//! base 0.1.0
package 'PolyphaseRectifier'
  model 'PolyphaseRectifier' "Demonstrate a polyphase diode rectifier"
    parameter Integer 'data.m'(min = 2) = 6 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'data.mSystems' = 2 "Number of base systems";
    parameter Integer 'data.mBasic' = 3 "Number of phases per base system";
    parameter Integer 'data.kPolygon' = 1 "Alternative of largest polygon voltage";
    parameter Integer 'data.ParDesired'(max = 2, min = 1) = 2 "Desired parallel subsystems";
    parameter Integer 'data.Par' = 2 "Parallel connected subsystems";
    parameter Integer 'data.Ser' = 1 "Series connected subsystems";
    parameter Real 'data.VrmsY'(unit = "V", quantity = "ElectricPotential") = 100.0 "RMS voltage line to starpoint";
    parameter Real 'data.f'(unit = "Hz", quantity = "Frequency") = 50.0 "Source frequency";
    parameter Real 'data.RLoad'(unit = "Ohm", quantity = "Resistance") = 1.0 "Load resistance";
    parameter Real 'data.RDC'(unit = "Ohm", quantity = "Resistance") = 0.001 "DC resistance";
    parameter Real 'data.LDC'(unit = "H", quantity = "Inductance") = 0.003 "DC inductance";
    parameter Real 'data.RGnd'(unit = "Ohm", quantity = "Resistance") = 1e5 "Resistance to ground";
    parameter Integer 'sineVoltage.m'(min = 1) = 6 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltage.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
