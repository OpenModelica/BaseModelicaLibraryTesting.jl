      'gearbox.elastoBacklash.tau_c' = if 'gearbox.elastoBacklash.phi_diff' > 8.7266462599715e-4 then 1e6 * ('gearbox.elastoBacklash.phi_diff' - 8.7266462599715e-4) else if 'gearbox.elastoBacklash.phi_diff' < (-8.7266462599715e-4) then 1e6 * ('gearbox.elastoBacklash.phi_diff' + 8.7266462599715e-4) else 0.0;
      'gearbox.elastoBacklash.tau_d' = 1e4 * 'gearbox.elastoBacklash.w_rel';
      'gearbox.elastoBacklash.tau' = if 'gearbox.elastoBacklash.phi_diff' > 8.7266462599715e-4 then smooth(0, noEvent(if 'gearbox.elastoBacklash.tau_c' + 'gearbox.elastoBacklash.tau_d' <= 0.0 then 0.0 else 'gearbox.elastoBacklash.tau_c' + min('gearbox.elastoBacklash.tau_c', 'gearbox.elastoBacklash.tau_d'))) else if 'gearbox.elastoBacklash.phi_diff' < (-8.7266462599715e-4) then smooth(0, noEvent(if 'gearbox.elastoBacklash.tau_c' + 'gearbox.elastoBacklash.tau_d' >= 0.0 then 0.0 else 'gearbox.elastoBacklash.tau_c' + max('gearbox.elastoBacklash.tau_c', 'gearbox.elastoBacklash.tau_d'))) else 0.0;
      'gearbox.elastoBacklash.lossPower' = if 'gearbox.elastoBacklash.phi_diff' > 8.7266462599715e-4 then smooth(0, noEvent(if 'gearbox.elastoBacklash.tau_c' + 'gearbox.elastoBacklash.tau_d' <= 0.0 then 0.0 else min('gearbox.elastoBacklash.tau_c', 'gearbox.elastoBacklash.tau_d') * 'gearbox.elastoBacklash.w_rel')) else if 'gearbox.elastoBacklash.phi_diff' < (-8.7266462599715e-4) then smooth(0, noEvent(if 'gearbox.elastoBacklash.tau_c' + 'gearbox.elastoBacklash.tau_d' >= 0.0 then 0.0 else max('gearbox.elastoBacklash.tau_c', 'gearbox.elastoBacklash.tau_d') * 'gearbox.elastoBacklash.w_rel')) else 0.0;
    end if;

    'gearbox.elastoBacklash.phi_rel' = 'gearbox.elastoBacklash.flange_b.phi' - 'gearbox.elastoBacklash.flange_a.phi';
    'gearbox.elastoBacklash.w_rel' = der('gearbox.elastoBacklash.phi_rel');
    'gearbox.elastoBacklash.a_rel' = der('gearbox.elastoBacklash.w_rel');
    'gearbox.elastoBacklash.flange_b.tau' = 'gearbox.elastoBacklash.tau';
    'gearbox.elastoBacklash.flange_a.tau' = -'gearbox.elastoBacklash.tau';
    'idealGearR2T.internalSupportR.flange.tau' = 'idealGearR2T.internalSupportR.tau';
    'idealGearR2T.internalSupportR.flange.phi' = 'idealGearR2T.internalSupportR.phi';
    'idealGearR2T.internalSupportT.flange.f' = 'idealGearR2T.internalSupportT.f';
    'idealGearR2T.internalSupportT.flange.s' = 'idealGearR2T.internalSupportT.s';
    'idealGearR2T.fixedR.flange.phi' = 0.0;
    'idealGearR2T.fixedT.flange.s' = 0.0;
    'idealGearR2T.flangeR.phi' - 'idealGearR2T.internalSupportR.phi' = 300.0 * ('idealGearR2T.flangeT.s' - 'idealGearR2T.internalSupportT.s');
    0.0 = 300.0 * 'idealGearR2T.flangeR.tau' + 'idealGearR2T.flangeT.f';
    'mass.v' = der('mass.s');
    'mass.a' = der('mass.v');
    100.0 * 'mass.a' = 'mass.flange_a.f' + 'mass.flange_b.f';
    'mass.flange_a.s' = 'mass.s';
    'mass.flange_b.s' = 'mass.s';
    'constantForce.f' = -1e4;
    'constantForce.f' = 'constantForce.flange.f';
    'constantForce.s' = 'constantForce.flange.s' - 'constantForce.s_support';
    'constantForce.s_support' = 0.0;
    der('slewRateLimiter.y') = if 'slewRateLimiter.val' < (-50.0) then -50.0 else if 'slewRateLimiter.val' > 50.0 then 50.0 else 'slewRateLimiter.val';
    'rodMass.v' = der('rodMass.s');
    'rodMass.a' = der('rodMass.v');
    3.0 * 'rodMass.a' = 'rodMass.flange_a.f' + 'rodMass.flange_b.f';
    'rodMass.flange_a.s' = 'rodMass.s';
    'rodMass.flange_b.s' = 'rodMass.s';
    'elastoGap.f_c' = 1e8 * 'elastoGap.s_rel';
    'elastoGap.f_d' = 1e5 * 'elastoGap.v_rel';
    'elastoGap.f' = 'elastoGap.f_c' + 'elastoGap.f_d';
    'elastoGap.lossPower' = 'elastoGap.f_d' * 'elastoGap.v_rel';
    'elastoGap.s_rel' = 'elastoGap.flange_b.s' - 'elastoGap.flange_a.s';
    'elastoGap.v_rel' = der('elastoGap.s_rel');
    'elastoGap.flange_b.f' = 'elastoGap.f';
    'elastoGap.flange_a.f' = -'elastoGap.f';
    annotation(experiment(StopTime = 8, Interval = 0.01, Tolerance = 1e-005));
  end 'ActuatorWithNoise';
end 'ActuatorWithNoise';
