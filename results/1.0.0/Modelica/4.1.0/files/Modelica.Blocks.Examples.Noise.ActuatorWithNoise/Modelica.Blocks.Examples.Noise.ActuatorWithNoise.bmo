    Real 'gearbox.w_rel'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") = der('gearbox.phi_rel') "Relative angular velocity over gear elasticity (= der(phi_rel))";
