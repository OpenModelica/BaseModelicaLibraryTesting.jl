//! base 0.1.0
package 'ActuatorWithNoise'
  function 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer' "Derivative of interpolated 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    input Real 'der_u';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTable1D_getDerValue('tableID', 'icol', 'u', 'der_u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer';

  function 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2' "Interpolate 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTable1D_getValue('tableID', 'icol', 'u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1) = 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer');
  end 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2';

  function 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower' "Calculate active power of voltage and current input"
    input Real[3] 'v'(unit = {"V", "V", "V"}, quantity = {"ElectricPotential", "ElectricPotential", "ElectricPotential"});
    input Real[3] 'i'(unit = {"A", "A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent", "ElectricCurrent"});
    output Real 'p'(unit = "W", quantity = "Power");
    constant Integer 'm' = 3;
    Real[2] 'v_'(unit = {"V", "V"}, quantity = {"ElectricPotential", "ElectricPotential"});
    Real[2] 'i_'(unit = {"A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent"});
  algorithm
    'v_' := {0.0, 0.0};
    'i_' := {0.0, 0.0};

    for 'k' in 1:'m' loop
      'v_' := {'v_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k'], 'v_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k']};
      'i_' := {'i_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k'], 'i_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k']};
    end for;

    'p' := 'm' / 2.0 * ('v_'[1] * 'i_'[1] + 'v_'[2] * 'i_'[2]);
    annotation(Inline = true);
  end 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower';

  function 'Modelica.Math.wrapAngle' "Wrap angle to interval ]-pi,pi] or [0,2*pi["
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    input Boolean 'positiveRange' = false;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := mod('u', 6.283185307179586);

    if 'y' > 3.141592653589793 and not 'positiveRange' then
      'y' := 'y' - 6.283185307179586;
    end if;
  end 'Modelica.Math.wrapAngle';

  function 'Modelica.Math.Random.Generators.Xorshift128plus.random' "Returns a uniform random number with the xorshift128+ algorithm"
    input Integer[4] 'stateIn';
    output Real 'result';
    output Integer[4] 'stateOut';
  external "C" ModelicaRandom_xorshift128plus('stateIn', 'stateOut', 'result') annotation(Library = "ModelicaExternalC", LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Math.Random.Generators.Xorshift128plus.random';

  function 'Modelica.Math.Random.Generators.Xorshift64star.initialState' "Returns an initial state for the xorshift64* algorithm"
    input Integer 'localSeed';
    input Integer 'globalSeed';
    output Integer[2] 'state';
    Real 'r';
    constant Integer 'p' = 10;
  algorithm
    if 'localSeed' == 0 and 'globalSeed' == 0 then
      'state' := {126247697, 'globalSeed'};
    elseif true then
      'state' := {'localSeed', 'globalSeed'};
    end if;

    for 'i' in 1:'p' loop
      ('r', 'state') := 'Modelica.Math.Random.Generators.Xorshift64star.random'('state');
    end for;
  end 'Modelica.Math.Random.Generators.Xorshift64star.initialState';

  function 'Modelica.Math.Random.Generators.Xorshift64star.random' "Returns a uniform random number with the xorshift64* algorithm"
    input Integer[2] 'stateIn';
    output Real 'result';
    output Integer[2] 'stateOut';
  external "C" ModelicaRandom_xorshift64star('stateIn', 'stateOut', 'result') annotation(Library = "ModelicaExternalC", LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Math.Random.Generators.Xorshift64star.random';

  function 'Modelica.Math.Random.Utilities.initialStateWithXorshift64star' "Return an initial state vector for a random number generator (based on xorshift64star algorithm)"
    input Integer 'localSeed';
    input Integer 'globalSeed';
    input Integer 'nState'(min = 1);
    output Integer['nState'] 'state';
    Real 'r';
    Integer[2] 'aux';
    Integer 'nStateEven';
  algorithm
    'aux' := 'Modelica.Math.Random.Generators.Xorshift64star.initialState'('localSeed', 'globalSeed');

    if 'nState' >= 2 then
      'state'[1:2] := 'aux';
    elseif true then
      'state'[1] := 'aux'[1];
    end if;

    'nStateEven' := 2 * div('nState', 2);

    for 'i' in 3:2:'nStateEven' loop
      ('r', 'aux') := 'Modelica.Math.Random.Generators.Xorshift64star.random'('state'['i' - 2:'i' - 1]);
      'state'['i':'i' + 1] := 'aux';
    end for;

    if 'nState' >= 3 and 'nState' <> 'nStateEven' then
      ('r', 'aux') := 'Modelica.Math.Random.Generators.Xorshift64star.random'('state'['nState' - 2:'nState' - 1]);
      'state'['nState'] := 'aux'[1];
    end if;
  end 'Modelica.Math.Random.Utilities.initialStateWithXorshift64star';

  function 'Modelica.Math.Random.Utilities.initializeImpureRandom' "Initializes the internal state of the impure random number generator"
    input Integer 'seed';
    output Integer 'id';
    constant Integer 'localSeed' = 715827883;
    Integer[33] 'rngState';
  algorithm
    'rngState' := 'Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('localSeed', 'seed', 33);
    'id' := 'localSeed';
    'Modelica.Math.Random.Utilities.initializeImpureRandom.setInternalState'('rngState', 'id');
  end 'Modelica.Math.Random.Utilities.initializeImpureRandom';

  function 'Modelica.Math.Random.Utilities.initializeImpureRandom.setInternalState' "Stores the given state vector in an external static variable"
    input Integer[33] 'rngState';
    input Integer 'id';
  external "C" ModelicaRandom_setInternalState_xorshift1024star('rngState', size('rngState', 1), 'id') annotation(Library = "ModelicaExternalC", LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Math.Random.Utilities.initializeImpureRandom.setInternalState';

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  class 'Modelica.Blocks.Types.ExternalCombiTable1D'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table defined by matrix"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" 'externalCombiTable1D' = ModelicaStandardTables_CombiTable1D_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table defined by matrix"
      input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" ModelicaStandardTables_CombiTable1D_close('externalCombiTable1D') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTable1D';

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  model 'ActuatorWithNoise' "Demonstrates how to model measurement noise in an actuator"
    constant Integer 'motor.m' = 3 "Number of phases";
    parameter Real 'motor.VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'motor.fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'motor.f'(unit = "Hz", quantity = "Frequency") = 50.0 "Actual frequency";
    parameter Real 'motor.tRamp'(unit = "s", quantity = "Time") = 1.0 "Frequency ramp";
    parameter Real 'motor.TLoad'(unit = "N.m", quantity = "Torque") = 181.4 "Nominal load torque";
    parameter Real 'motor.tStep'(unit = "s", quantity = "Time") = 1.2 "Time of load torque step";
    parameter Real 'motor.JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load's moment of inertia";
    parameter Integer 'motor.smpm.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'motor.smpm.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'motor.smpm.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'motor.smpm.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
    parameter Real 'motor.smpm.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'motor.smpm.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'motor.smpm.alpha20s'(start = 0.0, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'motor.smpm.Lszero'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator zero sequence inductance";
    parameter Real 'motor.smpm.Lssigma'(start = 3.183098861837907e-4, unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'motor.smpm.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Boolean 'motor.smpm.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'motor.smpm.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Boolean 'motor.smpm.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Real 'motor.smpm.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'motor.smpm.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'motor.smpm.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'motor.smpm.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'motor.smpm.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'motor.smpm.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'motor.smpm.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    Real 'motor.smpm.phiMechanical'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 'motor.smpm.flange.phi' - 'motor.smpm.internalSupport.phi' "Mechanical angle of rotor against stator";
    Real 'motor.smpm.wMechanical'(fixed = true, start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = der('motor.smpm.phiMechanical') "Mechanical angular velocity of rotor against stator";
    Real 'motor.smpm.tauElectrical'(unit = "N.m", quantity = "Torque") = 'motor.smpm.inertiaRotor.flange_a.tau' "Electromagnetic torque";
    Real 'motor.smpm.tauShaft'(unit = "N.m", quantity = "Torque") = -'motor.smpm.flange.tau' "Shaft torque";
    Real 'motor.smpm.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'motor.smpm.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'motor.smpm.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'motor.smpm.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'motor.smpm.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'motor.smpm.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'motor.smpm.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'motor.smpm.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'motor.smpm.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.inertiaStator.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'motor.smpm.inertiaStator.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.inertiaStator.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'motor.smpm.inertiaStator.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'motor.smpm.inertiaStator.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'motor.smpm.inertiaStator.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'motor.smpm.inertiaStator.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'motor.smpm.inertiaStator.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'motor.smpm.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'motor.smpm.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'motor.smpm.friction.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.friction.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'motor.smpm.friction.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.friction.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'motor.smpm.friction.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between shaft and support";
    Real 'motor.smpm.friction.tau'(unit = "N.m", quantity = "Torque") "Torque";
    Real 'motor.smpm.friction.w'(unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity of flange and support";
    parameter Real 'motor.smpm.friction.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'motor.smpm.friction.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'motor.smpm.friction.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'motor.smpm.friction.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'motor.smpm.friction.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'motor.smpm.friction.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'motor.smpm.friction.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Boolean 'motor.smpm.friction.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'motor.smpm.friction.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'motor.smpm.friction.heatPort.Q_flow'(unit = "W", quantity = "Power") = -'motor.smpm.friction.lossPower' "Heat flow rate (positive if flowing from outside into the component)";
    Real 'motor.smpm.friction.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'motor.smpm.internalSupport.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'motor.smpm.internalSupport.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Integer 'motor.smpm.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'motor.smpm.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'motor.smpm.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'motor.smpm.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'motor.smpm.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'motor.smpm.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'motor.smpm.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'motor.smpm.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'motor.smpm.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'motor.smpm.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'motor.smpm.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'motor.smpm.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    Real 'motor.smpm.powerBalance.powerStator'(unit = "W", quantity = "Power") = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'('motor.smpm.vs', 'motor.smpm.is') "Electrical power (stator)";
    Real 'motor.smpm.powerBalance.powerMechanical'(unit = "W", quantity = "Power") = 'motor.smpm.wMechanical' * 'motor.smpm.tauShaft' "Mechanical power";
    Real 'motor.smpm.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") = 0.29 * 'motor.smpm.inertiaStator.a' * 'motor.smpm.inertiaStator.w' "Stator inertia power";
    Real 'motor.smpm.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") = 0.29 * 'motor.smpm.inertiaRotor.a' * 'motor.smpm.inertiaRotor.w' "Rotor inertia power";
    Real 'motor.smpm.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") = 'motor.smpm.powerBalance.lossPowerStatorWinding' + 'motor.smpm.powerBalance.lossPowerStatorCore' + 'motor.smpm.powerBalance.lossPowerRotorCore' + 'motor.smpm.powerBalance.lossPowerStrayLoad' + 'motor.smpm.powerBalance.lossPowerFriction' + 'motor.smpm.powerBalance.lossPowerRotorWinding' + 'motor.smpm.powerBalance.lossPowerPermanentMagnet' "Total loss power";
    Real 'motor.smpm.powerBalance.lossPowerStatorWinding'(unit = "W", quantity = "Power") = 'motor.smpm.rs.resistor[1].LossPower' + 'motor.smpm.rs.resistor[2].LossPower' + 'motor.smpm.rs.resistor[3].LossPower' "Stator copper losses";
    Real 'motor.smpm.powerBalance.lossPowerStatorCore'(unit = "W", quantity = "Power") = 'motor.smpm.statorCore.lossPower' "Stator core losses";
    Real 'motor.smpm.powerBalance.lossPowerRotorCore'(unit = "W", quantity = "Power") = 0.0 "Rotor core losses";
    Real 'motor.smpm.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") = 'motor.smpm.strayLoad.lossPower' "Stray load losses";
    Real 'motor.smpm.powerBalance.lossPowerFriction'(unit = "W", quantity = "Power") = 'motor.smpm.friction.lossPower' "Friction losses";
    Real 'motor.smpm.powerBalance.lossPowerRotorWinding'(unit = "W", quantity = "Power") = 'motor.smpm.damperCageLossPower' "Rotor copper losses";
    Real 'motor.smpm.powerBalance.lossPowerPermanentMagnet'(unit = "W", quantity = "Power") = 'motor.smpm.permanentMagnet.lossPower' "Permanent magnet losses";
    Real 'motor.smpm.vs[1]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'motor.smpm.vs[2]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'motor.smpm.vs[3]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
