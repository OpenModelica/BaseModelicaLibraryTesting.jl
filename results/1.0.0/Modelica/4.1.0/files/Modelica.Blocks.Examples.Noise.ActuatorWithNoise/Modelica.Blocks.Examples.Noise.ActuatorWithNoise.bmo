  initial equation
    'motor.uniformNoise.r' = 'motor.uniformNoise.r_raw' * 0.02 - 0.01;
    'motor.uniformNoise.localSeed' = 188641931;
    pre('motor.uniformNoise.state[1]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('motor.uniformNoise.localSeed', 'motor.uniformNoise.actualGlobalSeed', 4))[1];
    pre('motor.uniformNoise.state[2]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('motor.uniformNoise.localSeed', 'motor.uniformNoise.actualGlobalSeed', 4))[2];
    pre('motor.uniformNoise.state[3]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('motor.uniformNoise.localSeed', 'motor.uniformNoise.actualGlobalSeed', 4))[3];
