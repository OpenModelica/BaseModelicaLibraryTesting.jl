    Real 'gearbox.lossyGear.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'gearbox.lossyGear.phi_a'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between left shaft flange and support";
    Real 'gearbox.lossyGear.phi_b'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between right shaft flange and support";
    Real 'gearbox.lossyGear.sa'(unit = "1") "Path parameter for acceleration and torque loss";
    Real 'gearbox.lossyGear.w_a'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange_a with respect to support";
    Real 'gearbox.lossyGear.a_a'(unit = "rad/s2", quantity = "AngularAcceleration") "Angular acceleration of flange_a with respect to support";
    Real 'gearbox.lossyGear.interpolation_result[1,1]' "Result of interpolation in lossTable (= [eta_mf1, eta_mf2, tau_bf1, tau_bf2])";
    Real 'gearbox.lossyGear.interpolation_result[1,2]' "Result of interpolation in lossTable (= [eta_mf1, eta_mf2, tau_bf1, tau_bf2])";
    Real 'gearbox.lossyGear.interpolation_result[1,3]' "Result of interpolation in lossTable (= [eta_mf1, eta_mf2, tau_bf1, tau_bf2])";
    Real 'gearbox.lossyGear.interpolation_result[1,4]' "Result of interpolation in lossTable (= [eta_mf1, eta_mf2, tau_bf1, tau_bf2])";
    Real 'gearbox.lossyGear.eta_mf1'(unit = "1") "Mesh efficiency in case that flange_a is driving";
    Real 'gearbox.lossyGear.eta_mf2'(unit = "1") "Mesh efficiency in case that flange_b is driving";
    Real 'gearbox.lossyGear.tau_bf_a'(unit = "N.m", quantity = "Torque") "Bearing friction torque on flange_a side";
    Real 'gearbox.lossyGear.tau_eta'(unit = "N.m", quantity = "Torque") "Torque that determines the driving side (= if forwardSliding then flange_a.tau-tau_bf_a else if backwardSliding then flange_a.tau+tau_bf_a else flange_a.tau)";
    Real 'gearbox.lossyGear.tau_bf1'(unit = "N.m", quantity = "Torque") "Absolute resultant bearing friction torque with respect to flange_a in case that flange_a is driving (= |tau_bf_a*eta_mf1 + tau_bf_b/i|)";
    Real 'gearbox.lossyGear.tau_bf2'(unit = "N.m", quantity = "Torque") "Absolute resultant bearing friction torque with respect to flange_a in case that flange_b is driving (= |tau_bf_a/eta_mf2 + tau_bf_b/i|)";
    Real 'gearbox.lossyGear.quadrant1'(unit = "N.m", quantity = "Torque") "Torque loss if w_a > 0 and flange_a.tau >= 0";
    Real 'gearbox.lossyGear.quadrant2'(unit = "N.m", quantity = "Torque") "Torque loss if w_a > 0 and flange_a.tau < 0";
    Real 'gearbox.lossyGear.quadrant3'(unit = "N.m", quantity = "Torque") "Torque loss if w_a < 0 and flange_a.tau >= 0";
    Real 'gearbox.lossyGear.quadrant4'(unit = "N.m", quantity = "Torque") "Torque loss if w_a < 0 and flange_a.tau < 0";
    Real 'gearbox.lossyGear.quadrant1_p'(unit = "N.m", quantity = "Torque") "Torque loss at w_a = 0+ to determine driving side (flange_a.tau >= 0)";
    Real 'gearbox.lossyGear.quadrant2_p'(unit = "N.m", quantity = "Torque") "Torque loss at w_a = 0+ to determine driving side (flange_a.tau < 0)";
    Real 'gearbox.lossyGear.quadrant3_m'(unit = "N.m", quantity = "Torque") "Torque loss at w_a = 0- to determine driving side (flange_a.tau >=0)";
    Real 'gearbox.lossyGear.quadrant4_m'(unit = "N.m", quantity = "Torque") "Torque loss at w_a = 0- to determine driving side (flange_a.tau < 0)";
    Real 'gearbox.lossyGear.tauLoss'(unit = "N.m", quantity = "Torque") "Torque loss due to friction in the gear teeth and in the bearings";
    Real 'gearbox.lossyGear.tauLossMax'(unit = "N.m", quantity = "Torque") "Torque loss for positive speed";
    Real 'gearbox.lossyGear.tauLossMin'(unit = "N.m", quantity = "Torque") "Torque loss for negative speed";
    Real 'gearbox.lossyGear.tauLossMax_p'(unit = "N.m", quantity = "Torque") "Torque loss for positive speed";
    Real 'gearbox.lossyGear.tauLossMin_m'(unit = "N.m", quantity = "Torque") "Torque loss for negative speed";
    Boolean 'gearbox.lossyGear.tau_aPos'(start = true) "Only for backwards compatibility (was previously: true, if torque of flange_a is not negative)";
    Boolean 'gearbox.lossyGear.tau_etaPos'(start = true) "= true, if torque tau_eta is not negative";
    Boolean 'gearbox.lossyGear.startForward'(start = false) "= true, if starting to roll forward";
    Boolean 'gearbox.lossyGear.startBackward'(start = false) "= true, if starting to roll backward";
    Boolean 'gearbox.lossyGear.locked'(start = false) "= true, if gear is locked";
    Boolean 'gearbox.lossyGear.ideal' "= true, if losses are neglected (that is lossTable = [0, 1, 1, 0, 0])";
    constant Integer 'gearbox.lossyGear.Unknown' = 3 "Value of mode is not known";
    constant Integer 'gearbox.lossyGear.Free' = 2 "Element is not active";
    constant Integer 'gearbox.lossyGear.Forward' = 1 "w_a > 0 (forward rolling)";
    constant Integer 'gearbox.lossyGear.Stuck' = 0 "w_a = 0 (forward rolling, locked or backward rolling)";
    constant Integer 'gearbox.lossyGear.Backward' = -1 "w_a < 0 (backward rolling)";
    Integer 'gearbox.lossyGear.mode'(fixed = true, start = 2, max = 3, min = -1) "Mode of friction element (unknown, not active, forward/backward rolling, stuck)";
    Real 'gearbox.lossyGear.tau_eta_p'(unit = "N.m", quantity = "Torque") "tau_eta assuming positive omega";
    Real 'gearbox.lossyGear.tau_eta_m'(unit = "N.m", quantity = "Torque") "tau_eta assuming negative omega";
    constant Real 'gearbox.lossyGear.unitAngularAcceleration'(unit = "rad/s2", quantity = "AngularAcceleration") = 1.0;
    constant Real 'gearbox.lossyGear.unitTorque'(unit = "N.m", quantity = "Torque") = 1.0;
    parameter Real 'gearbox.lossyGear.eta_mf1_0'(unit = "1") = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('gearbox.lossyGear.tableID', 1, 0.0);
    parameter Real 'gearbox.lossyGear.eta_mf2_0'(unit = "1") = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('gearbox.lossyGear.tableID', 2, 0.0);
    parameter Real 'gearbox.lossyGear.tau_bf1_0'(unit = "N.m", quantity = "Torque") = abs('Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('gearbox.lossyGear.tableID', 3, 0.0));
    parameter Real 'gearbox.lossyGear.tau_bf2_0'(unit = "N.m", quantity = "Torque") = abs('Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('gearbox.lossyGear.tableID', 4, 0.0));
    parameter Real 'gearbox.lossyGear.tau_bf_a_0'(unit = "N.m", quantity = "Torque") = if abs('gearbox.lossyGear.eta_mf1_0' - 1.0) <= 2.220446049250313e-16 and abs('gearbox.lossyGear.eta_mf2_0' - 1.0) <= 2.220446049250313e-16 then 'gearbox.lossyGear.tau_bf1_0' / 2.0 else ('gearbox.lossyGear.tau_bf1_0' - 'gearbox.lossyGear.tau_bf2_0') / ('gearbox.lossyGear.eta_mf1_0' - 1.0 / 'gearbox.lossyGear.eta_mf2_0');
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'gearbox.lossyGear.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 0.85, 0.8, 0.1, 0.1}}, {2, 3, 4, 5}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object for sliding friction coefficient";
    parameter Real 'gearbox.elastoBacklash.c'(start = 1e5, min = 2.2250738585072014e-308, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 1e6 "Spring constant (c > 0 required)";
    parameter Real 'gearbox.elastoBacklash.d'(start = 0.0, min = 0.0, unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 1e4 "Damping constant";
    parameter Real 'gearbox.elastoBacklash.b'(min = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0017453292519943 "Total backlash";
    parameter Real 'gearbox.elastoBacklash.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    Real 'gearbox.elastoBacklash.phi_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'gearbox.elastoBacklash.w_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity (= der(phi_rel))";
    Real 'gearbox.elastoBacklash.a_rel'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration (= der(w_rel))";
    Real 'gearbox.elastoBacklash.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'gearbox.elastoBacklash.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'gearbox.elastoBacklash.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'gearbox.elastoBacklash.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'gearbox.elastoBacklash.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'gearbox.elastoBacklash.phi_nominal'(min = 0.0, displayUnit = "rad", unit = "rad", quantity = "Angle") = 1e-4 "Nominal value of phi_rel (used for scaling)";
    parameter StateSelect 'gearbox.elastoBacklash.stateSelect' = StateSelect.prefer "Priority to use phi_rel and w_rel as states";
    parameter Boolean 'gearbox.elastoBacklash.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'gearbox.elastoBacklash.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'gearbox.elastoBacklash.heatPort.Q_flow'(unit = "W", quantity = "Power") = -'gearbox.elastoBacklash.lossPower' "Heat flow rate (positive if flowing from outside into the component)";
    Real 'gearbox.elastoBacklash.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    parameter Real 'gearbox.elastoBacklash.bMax'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 8.7266462599715e-4 "Backlash in range bMin <= phi_rel - phi_rel0 <= bMax";
    parameter Real 'gearbox.elastoBacklash.bMin'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -8.7266462599715e-4 "Backlash in range bMin <= phi_rel - phi_rel0 <= bMax";
    Real 'gearbox.elastoBacklash.tau_c'(unit = "N.m", quantity = "Torque");
    Real 'gearbox.elastoBacklash.tau_d'(unit = "N.m", quantity = "Torque");
