//! base 0.1.0
package 'OneAxis'
  function 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer' "Derivative of interpolated 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    input Real 'der_u';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTable1D_getDerValue('tableID', 'icol', 'u', 'der_u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer';

  function 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2' "Interpolate 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTable1D_getValue('tableID', 'icol', 'u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1) = 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer');
  end 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2';

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  class 'Modelica.Blocks.Types.ExternalCombiTable1D'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table defined by matrix"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" 'externalCombiTable1D' = ModelicaStandardTables_CombiTable1D_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table defined by matrix"
      input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" ModelicaStandardTables_CombiTable1D_close('externalCombiTable1D') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTable1D';

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'OneAxis' "Model of one axis of robot (controller, motor, gearbox) with simple load"
    parameter Real 'mLoad'(min = 0.0, unit = "kg", quantity = "Mass") = 15.0 "Mass of load";
    parameter Real 'rg'(min = 0.0, unit = "m", quantity = "Length") = 1.14 "Radius of gyration of load";
    parameter Real 'kp' = 5.0 "Gain of position controller of axis";
    parameter Real 'ks' = 0.5 "Gain of speed controller of axis";
    parameter Real 'Ts'(unit = "s", quantity = "Time") = 0.05 "Time constant of integrator of speed controller of axis";
    parameter Real 'startAngle'(unit = "deg", quantity = "Angle") = 0.0 "Start angle of axis";
    parameter Real 'endAngle'(unit = "deg", quantity = "Angle") = 120.0 "End angle of axis";
    parameter Real 'swingTime'(unit = "s", quantity = "Time") = 0.5 "Additional time after reference motion is in rest before simulation is stopped";
    parameter Real 'refSpeedMax'(unit = "rad/s", quantity = "AngularVelocity") = 3.0 "Maximum reference speed";
    parameter Real 'refAccMax'(unit = "rad/s2", quantity = "AngularAcceleration") = 10.0 "Maximum reference acceleration";
    parameter Real 'axis.kp' = 5.0 "Gain of position controller";
    parameter Real 'axis.ks' = 0.5 "Gain of speed controller";
    parameter Real 'axis.Ts'(unit = "s", quantity = "Time") = 0.05 "Time constant of integrator of speed controller";
    parameter Real 'axis.k' = 1.1616 "Gain of motor";
    parameter Real 'axis.w' = 5500.0 "Time constant of motor";
    parameter Real 'axis.D' = 0.6 "Damping constant of motor";
    parameter Real 'axis.J'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0013 "Moment of inertia of motor";
    parameter Real 'axis.ratio' = 210.0 "Gear ratio";
    parameter Real 'axis.Rv0'(unit = "N.m", quantity = "Torque") = 0.5 "Viscous friction torque at zero velocity";
    parameter Real 'axis.Rv1'(unit = "N.m.s/rad") = 7.692307692307692e-4 "Viscous friction coefficient";
    parameter Real 'axis.peak' = 1.0 "Maximum static friction torque is peak*Rv0 (peak >= 1)";
    Real 'axis.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.gear.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.gear.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.gear.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.gear.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'axis.gear.i' = 210.0 "Gear ratio";
    parameter Real 'axis.gear.c'(unit = "N.m/rad", quantity = "RotationalSpringConstant") = 8.0 "Spring constant";
    parameter Real 'axis.gear.d'(unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 0.01 "Damper constant";
    parameter Real 'axis.gear.Rv0'(unit = "N.m", quantity = "Torque") = 0.5 "Viscous friction torque at zero velocity";
    parameter Real 'axis.gear.Rv1'(unit = "N.m.s/rad") = 7.692307692307692e-4 "Viscous friction coefficient (R=Rv0+Rv1*abs(qd))";
    parameter Real 'axis.gear.peak' = 1.0 "Maximum static friction torque is peak*Rv0 (peak >= 1)";
    Real 'axis.gear.a_rel'(unit = "rad/s2", quantity = "AngularAcceleration") = der('axis.gear.spring.w_rel') "Relative angular acceleration of spring";
    constant Real 'axis.gear.unitAngularVelocity'(unit = "rad/s", quantity = "AngularVelocity") = 1.0;
    constant Real 'axis.gear.unitTorque'(unit = "N.m", quantity = "Torque") = 1.0;
    parameter Boolean 'axis.gear.gear.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'axis.gear.gear.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.gear.gear.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.gear.gear.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.gear.gear.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.gear.gear.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    parameter Real 'axis.gear.gear.ratio'(start = 1.0) = 210.0 "Transmission ratio (flange_a.phi/flange_b.phi)";
    Real 'axis.gear.gear.phi_a'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between left shaft flange and support";
    Real 'axis.gear.gear.phi_b'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between right shaft flange and support";
    parameter Real 'axis.gear.spring.c'(start = 1e5, min = 0.0, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 8.0 "Spring constant";
    parameter Real 'axis.gear.spring.d'(start = 0.0, min = 0.0, unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 0.01 "Damping constant";
    parameter Real 'axis.gear.spring.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    Real 'axis.gear.spring.phi_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'axis.gear.spring.w_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity (= der(phi_rel))";
    Real 'axis.gear.spring.a_rel'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration (= der(w_rel))";
    Real 'axis.gear.spring.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'axis.gear.spring.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.gear.spring.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.gear.spring.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.gear.spring.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'axis.gear.spring.phi_nominal'(min = 0.0, displayUnit = "rad", unit = "rad", quantity = "Angle") = 1e-4 "Nominal value of phi_rel (used for scaling)";
    parameter StateSelect 'axis.gear.spring.stateSelect' = StateSelect.prefer "Priority to use phi_rel and w_rel as states";
    parameter Boolean 'axis.gear.spring.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'axis.gear.spring.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'axis.gear.spring.tau_c'(unit = "N.m", quantity = "Torque") "Spring torque";
    Real 'axis.gear.spring.tau_d'(unit = "N.m", quantity = "Torque") "Damping torque";
    parameter Boolean 'axis.gear.bearingFriction.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'axis.gear.bearingFriction.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.gear.bearingFriction.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.gear.bearingFriction.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.gear.bearingFriction.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.gear.bearingFriction.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    parameter Real 'axis.gear.bearingFriction.tau_pos[1,1]' = 0.0 "Positive sliding friction characteristic [N.m] as function of w [rad/s] (w>=0)";
    parameter Real 'axis.gear.bearingFriction.tau_pos[1,2]' = 0.5 "Positive sliding friction characteristic [N.m] as function of w [rad/s] (w>=0)";
    parameter Real 'axis.gear.bearingFriction.tau_pos[2,1]' = 1.0 "Positive sliding friction characteristic [N.m] as function of w [rad/s] (w>=0)";
    parameter Real 'axis.gear.bearingFriction.tau_pos[2,2]' = 0.5007692307692307 "Positive sliding friction characteristic [N.m] as function of w [rad/s] (w>=0)";
    parameter 'Modelica.Blocks.Types.Smoothness' 'axis.gear.bearingFriction.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' "Smoothness of interpolation in tau_pos table";
    parameter Real 'axis.gear.bearingFriction.peak'(min = 1.0) = 1.0 "Peak for maximum friction torque at w==0 (tau0_max = peak*tau_pos[1,2])";
    parameter Real 'axis.gear.bearingFriction.w_small'(unit = "rad/s", quantity = "AngularVelocity") = 1e10 "Relative angular velocity near to zero if jumps due to a reinit(..) of the velocity can occur (set to low value only if such impulses can occur)";
    Real 'axis.gear.bearingFriction.w_relfric'(unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity between frictional surfaces";
    Real 'axis.gear.bearingFriction.a_relfric'(unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration between frictional surfaces";
    Real 'axis.gear.bearingFriction.tau0'(unit = "N.m", quantity = "Torque") "Friction torque for w_relfric=0 and forward sliding";
    Real 'axis.gear.bearingFriction.tau0_max'(unit = "N.m", quantity = "Torque") "Maximum friction torque for w_relfric=0 and locked";
    Boolean 'axis.gear.bearingFriction.free' "= true, if frictional element is not active";
    Real 'axis.gear.bearingFriction.sa'(unit = "1") "Path parameter of friction characteristic tau = f(a_relfric)";
    Boolean 'axis.gear.bearingFriction.startForward'(fixed = true, start = false) "= true, if w_relfric=0 and start of forward sliding";
    Boolean 'axis.gear.bearingFriction.startBackward'(fixed = true, start = false) "= true, if w_relfric=0 and start of backward sliding";
    Boolean 'axis.gear.bearingFriction.locked'(start = false) "= true, if w_rel=0 and not sliding";
    constant Integer 'axis.gear.bearingFriction.Unknown' = 3 "Value of mode is not known";
    constant Integer 'axis.gear.bearingFriction.Free' = 2 "Element is not active";
    constant Integer 'axis.gear.bearingFriction.Forward' = 1 "w_relfric > 0 (forward sliding)";
    constant Integer 'axis.gear.bearingFriction.Stuck' = 0 "w_relfric = 0 (forward sliding, locked or backward sliding)";
    constant Integer 'axis.gear.bearingFriction.Backward' = -1 "w_relfric < 0 (backward sliding)";
    Integer 'axis.gear.bearingFriction.mode'(fixed = true, start = 3, max = 3, min = -1) "Mode of friction (-1: backward sliding, 0: stuck, 1: forward sliding, 2: inactive, 3: unknown)";
    constant Real 'axis.gear.bearingFriction.unitAngularAcceleration'(unit = "rad/s2", quantity = "AngularAcceleration") = 1.0;
    constant Real 'axis.gear.bearingFriction.unitTorque'(unit = "N.m", quantity = "Torque") = 1.0;
    parameter Boolean 'axis.gear.bearingFriction.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'axis.gear.bearingFriction.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'axis.gear.bearingFriction.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between shaft flanges (flange_a, flange_b) and support";
    Real 'axis.gear.bearingFriction.tau'(unit = "N.m", quantity = "Torque") "Friction torque";
    Real 'axis.gear.bearingFriction.w'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of flange_a and flange_b";
    Real 'axis.gear.bearingFriction.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of flange_a and flange_b";
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'axis.gear.bearingFriction.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 0.5}, {1.0, 0.5007692307692307}}, {2}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object for sliding friction coefficient";
    Real 'axis.gear.bearingFriction.table_signs[1]' "Signs for sliding friction coefficient table interpolation: [sign for w, sign for tau]";
    Real 'axis.gear.bearingFriction.table_signs[2]' "Signs for sliding friction coefficient table interpolation: [sign for w, sign for tau]";
    parameter Real 'axis.motor.J'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0013 "Moment of inertia of motor";
    parameter Real 'axis.motor.k' = 1.1616 "Gain of motor";
    parameter Real 'axis.motor.w' = 5500.0 "Time constant of motor";
    parameter Real 'axis.motor.D' = 0.6 "Damping constant of motor";
    parameter Real 'axis.motor.w_max'(unit = "rad/s", quantity = "AngularVelocity") = 315.0 "Maximum speed of motor";
    parameter Real 'axis.motor.i_max'(unit = "A", quantity = "ElectricCurrent") = 9.0 "Maximum current of motor";
    Real 'axis.motor.flange_motor.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.motor.flange_motor.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.motor.Vs.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.Vs.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.Vs.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.Vs.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.Vs.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'axis.motor.Vs.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'axis.motor.power.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop over the left port";
    Real 'axis.motor.power.v2'(unit = "V", quantity = "ElectricPotential") "Voltage drop over the right port";
    Real 'axis.motor.power.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of the left port";
    Real 'axis.motor.power.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of the right port";
    Real 'axis.motor.power.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.power.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.power.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.power.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.power.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.power.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.power.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.power.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.diff.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop over the left port";
    Real 'axis.motor.diff.v2'(unit = "V", quantity = "ElectricPotential") "Voltage drop over the right port";
    Real 'axis.motor.diff.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of the left port";
    Real 'axis.motor.diff.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of the right port";
    Real 'axis.motor.diff.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.diff.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.diff.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.diff.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.diff.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.diff.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.diff.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.diff.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Boolean 'axis.motor.emf.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    parameter Real 'axis.motor.emf.k'(start = 1.0, unit = "N.m/A", quantity = "ElectricalTorqueConstant") = 1.1616 "Transformation coefficient";
    Real 'axis.motor.emf.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop between the two pins";
    Real 'axis.motor.emf.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from positive to negative pin";
    Real 'axis.motor.emf.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of shaft flange with respect to support (= flange.phi - support.phi)";
    Real 'axis.motor.emf.w'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange relative to support";
    Real 'axis.motor.emf.tau'(unit = "N.m", quantity = "Torque") "Torque of flange";
    Real 'axis.motor.emf.tauElectrical'(unit = "N.m", quantity = "Torque") "Electrical torque";
    Real 'axis.motor.emf.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.emf.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.emf.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.emf.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.emf.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.motor.emf.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'axis.motor.emf.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'axis.motor.emf.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.motor.emf.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.motor.emf.internalSupport.tau'(unit = "N.m", quantity = "Torque") = -'axis.motor.emf.tau' "External support torque (must be computed via torque balance in model where InternalSupport is used; = flange.tau)";
    Real 'axis.motor.emf.internalSupport.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "External support angle (= flange.phi)";
    Real 'axis.motor.emf.internalSupport.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'axis.motor.emf.internalSupport.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'axis.motor.La.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'axis.motor.La.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.La.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.La.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.La.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.La.i'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'axis.motor.La.L'(start = 1.0, unit = "H", quantity = "Inductance") = 0.03787878787878788 "Inductance";
    parameter Real 'axis.motor.Ra.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 250.0 "Resistance at temperature T_ref";
    parameter Real 'axis.motor.Ra.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'axis.motor.Ra.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'axis.motor.Ra.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'axis.motor.Ra.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.Ra.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'axis.motor.Ra.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'axis.motor.Ra.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
