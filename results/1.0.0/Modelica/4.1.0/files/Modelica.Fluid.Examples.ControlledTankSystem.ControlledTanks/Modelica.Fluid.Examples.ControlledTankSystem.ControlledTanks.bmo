    parameter Integer 'shut.table.combiTimeTable.nHeaderLines' = 0 "Number of header lines to ignore for CSV file";
    parameter Boolean 'shut.table.combiTimeTable.verboseRead' = true "= true, if info message that file is loading is to be printed";
    parameter Integer 'shut.table.combiTimeTable.columns[1]' = 2 "Columns of table to be interpolated";
    parameter 'Modelica.Blocks.Types.Smoothness' 'shut.table.combiTimeTable.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments' "Smoothness of table interpolation";
    parameter 'Modelica.Blocks.Types.Extrapolation' 'shut.table.combiTimeTable.extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'HoldLastPoint' "Extrapolation of data outside the definition range";
    parameter Real 'shut.table.combiTimeTable.timeScale'(min = 2.220446049250313e-16, unit = "s", quantity = "Time") = 1.0 "Time scale of first table column" annotation(Evaluate = true);
    parameter Real 'shut.table.combiTimeTable.offset[1]' = 0.0 "Offsets of output signals";
    parameter Real 'shut.table.combiTimeTable.startTime'(unit = "s", quantity = "Time") = -1e60 "Output = offset for time < startTime";
    parameter Real 'shut.table.combiTimeTable.shiftTime'(unit = "s", quantity = "Time") = 0.0 "Shift time of first table column";
    parameter 'Modelica.Blocks.Types.TimeEvents' 'shut.table.combiTimeTable.timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always' "Time event handling of table interpolation";
    parameter Boolean 'shut.table.combiTimeTable.verboseExtrapolation' = false "= true, if warning messages are to be printed if time is outside the table definition range";
    parameter Real 'shut.table.combiTimeTable.t_min'(unit = "s", quantity = "Time") = 'shut.table.combiTimeTable.t_minScaled' "Minimum abscissa value defined in table";
    parameter Real 'shut.table.combiTimeTable.t_max'(unit = "s", quantity = "Time") = 'shut.table.combiTimeTable.t_maxScaled' "Maximum abscissa value defined in table";
    parameter Real 'shut.table.combiTimeTable.t_minScaled' = 'Modelica.Blocks.Tables.Internal.getTimeTableTmin'('shut.table.combiTimeTable.tableID') "Minimum (scaled) abscissa value defined in table";
    parameter Real 'shut.table.combiTimeTable.t_maxScaled' = 'Modelica.Blocks.Tables.Internal.getTimeTableTmax'('shut.table.combiTimeTable.tableID') "Maximum (scaled) abscissa value defined in table";
    parameter Real 'shut.table.combiTimeTable.p_offset[1]' = 0.0 "Offsets of output signals";
    parameter 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'shut.table.combiTimeTable.tableID' = 'Modelica.Blocks.Types.ExternalCombiTimeTable'("NoName", "NoName", {{700.0, 0.0}, {700.0, 1.0}}, -1e60, {2}, 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments', 'Modelica.Blocks.Types.Extrapolation'.'HoldLastPoint', 0.0, 'Modelica.Blocks.Types.TimeEvents'.'Always', false, ",", 0) "External table object";
    discrete Real 'shut.table.combiTimeTable.nextTimeEvent'(fixed = true, start = 0.0, unit = "s", quantity = "Time") "Next time event instant";
    discrete Real 'shut.table.combiTimeTable.nextTimeEventScaled'(fixed = true, start = 0.0) "Next scaled time event instant";
    Real 'shut.table.combiTimeTable.timeScaled' "Scaled time";
    parameter Boolean 'shut.table.combiTimeTable.isCsvExt' = false;
    Real 'shut.table.realToBoolean.u' "Connector of Real input signal";
    Boolean 'shut.table.realToBoolean.y' "Connector of Boolean output signal";
    parameter Real 'shut.table.realToBoolean.threshold' = 0.5 "Output signal y is true, if input u >= threshold";
    parameter Integer 'shut.table.n' = 1 "Number of table points";
    parameter Integer 'shut.nReset' = 2;
    Boolean 'shut.pre_reset[1]';
    Boolean 'shut.pre_reset[2]';
    parameter Boolean 'valve1.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'valve1.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'valve1.port_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'valve1.port_a.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'valve1.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'valve1.port_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'valve1.port_b.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'valve1.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'valve1.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'valve1.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'valve1.dp_start'(nominal = 1e5, start = 1e5, max = 1e8, min = -1e60, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1013.25 "Guess value of dp = port_a.p - port_b.p";
    parameter Real 'valve1.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 0.0 "Guess value of m_flow = port_a.m_flow";
    parameter Real 'valve1.m_flow_small'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 0.01 "Small mass flow rate for regularization of zero flow";
    parameter Boolean 'valve1.show_T' = true "= true, if temperatures at port_a and port_b are computed";
    parameter Boolean 'valve1.show_V_flow' = true "= true, if volume flow rate at inflowing port is computed";
    Real 'valve1.m_flow'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate in design flow direction";
    Real 'valve1.dp'(start = 1013.25, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure difference between port_a and port_b (= port_a.p - port_b.p)";
    Real 'valve1.V_flow'(unit = "m3/s", quantity = "VolumeFlowRate") = 'valve1.m_flow' / 'Modelica.Fluid.Utilities.regStep'('valve1.m_flow', 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.valve1.Medium.density'('valve1.state_a'), 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.valve1.Medium.density'('valve1.state_b'), 0.01) "Volume flow rate at inflowing port (positive when flow from port_a to port_b)";
    Real 'valve1.port_a_T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 'Modelica.Fluid.Utilities.regStep'('valve1.port_a.m_flow', 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.valve1.Medium.temperature'('valve1.state_a'), 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.valve1.Medium.temperature'('Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.valve1.Medium.setState_phX'('valve1.port_a.p', 'valve1.port_a.h_outflow', fill(0.0, 0))), 0.01) "Temperature close to port_a, if show_T = true";
    Real 'valve1.port_b_T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 'Modelica.Fluid.Utilities.regStep'('valve1.port_b.m_flow', 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.valve1.Medium.temperature'('valve1.state_b'), 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.valve1.Medium.temperature'('Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.valve1.Medium.setState_phX'('valve1.port_b.p', 'valve1.port_b.h_outflow', fill(0.0, 0))), 0.01) "Temperature close to port_b, if show_T = true";
    Real 'valve1.state_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'valve1.state_a.T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'valve1.state_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'valve1.state_b.T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    parameter Real 'valve1.dp_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Nominal pressure drop at full opening=1";
    parameter Real 'valve1.m_flow_nominal'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") = 40.0 "Nominal mass flowrate at full opening=1";
    parameter Real 'valve1.k'(unit = "kg/(s.Pa)", quantity = "HydraulicConductance") = 4e-4 "Hydraulic conductance at full opening=1";
    Boolean 'valve1.open';
