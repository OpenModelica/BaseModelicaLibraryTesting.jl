    'tank2.medium.p' = 101325.0;
    'tank2.Wb_flow' = 0.0 "Mechanical work is neglected, since also neglected in medium model (otherwise unphysical small temperature change, if tank level changes)";
    'tank2.vessel_ps_static[1]' = max(0.0, 'tank2.level' - 'tank2.portsData_height[1]') * 9.80665 * 'tank2.medium.d' + 101325.0;
    'tank2.vessel_ps_static[2]' = max(0.0, 'tank2.level' - 'tank2.portsData_height[2]') * 9.80665 * 'tank2.medium.d' + 101325.0;
    assert('tank2.level' > 0.0, "Fluid level is too low; the energy balance equation becomes singular when the tank is completely empty.", AssertionLevel.error);
    'tank2.mb_flow' = 'tank2.ports[1].m_flow' + 'tank2.ports[2].m_flow';
    'tank2.Hb_flow' = 'tank2.ports_H_flow[1]' + 'tank2.ports_H_flow[2]' + 'tank2.ports_E_flow[1]' + 'tank2.ports_E_flow[2]';
    'tank2.Qb_flow' = 'tank2.heatTransfer.Q_flows[1]';
    assert('tank2.fluidLevel' <= 5.0, "Vessel is overflowing (fluidLevel > fluidLevel_max = " + String('tank2.fluidLevel') + ")", AssertionLevel.error);
    'tank2.portInDensities[1]' = 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.tank2.Medium.density'('Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.tank2.Medium.setState_phX'('tank2.vessel_ps_static[1]', 'valve2.port_b.h_outflow', fill(0.0, 0)));
    'tank2.portVelocities[1]' = smooth(0, 'tank2.ports[1].m_flow' / 'tank2.portAreas[1]' / 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.tank2.Medium.density'('Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.tank2.Medium.setState_phX'('tank2.vessel_ps_static[1]', if 'tank2.ports[1].m_flow' > 0.0 then 'valve2.port_b.h_outflow' else 'tank2.ports[1].h_outflow', fill(0.0, 0))));
    'tank2.ports_penetration[1]' = 'Modelica.Fluid.Utilities.regStep'('tank2.fluidLevel' - 'tank2.portsData_height[1]' - 0.1 * 'tank2.portsData_diameter[1]', 1.0, 0.001, 0.1 * 'tank2.portsData_diameter[1]');
    'tank2.m_flow_turbulent[1]' = 0.01;
    'tank2.regularFlow[1]' = 'tank2.fluidLevel' >= 'tank2.portsData_height[1]';
    'tank2.inFlow[1]' = not 'tank2.regularFlow[1]' and ('tank2.s[1]' > 0.0 or 'tank2.portsData_height[1]' >= 5.0);

    if 'tank2.regularFlow[1]' then
      'tank2.ports[1].p' = 'tank2.vessel_ps_static[1]' + 0.5 / 'tank2.portAreas[1]' ^ 2.0 * 'Modelica.Fluid.Utilities.regSquare2'('tank2.ports[1].m_flow', 'tank2.m_flow_turbulent[1]', ('tank2.portsData_zeta_in[1]' - 1.0 + 'tank2.portAreas[1]' ^ 2.0 / 36.0) / 'tank2.portInDensities[1]' * 'tank2.ports_penetration[1]', ('tank2.portsData_zeta_out[1]' + 1.0 - 'tank2.portAreas[1]' ^ 2.0 / 36.0) / 'tank2.medium.d' / 'tank2.ports_penetration[1]', false, 1.0);
      'tank2.s[1]' = 'tank2.fluidLevel' - 'tank2.portsData_height[1]';
    elseif 'tank2.inFlow[1]' then
      'tank2.ports[1].p' = 'tank2.vessel_ps_static[1]';
      'tank2.s[1]' = 'tank2.ports[1].m_flow';
    elseif true then
      'tank2.ports[1].m_flow' = 0.0;
      'tank2.s[1]' = ('tank2.ports[1].p' - 'tank2.vessel_ps_static[1]') / 101325.0 * ('tank2.portsData_height[1]' - 'tank2.fluidLevel');
    end if;

    'tank2.ports[1].h_outflow' = 'tank2.medium.h';
    'tank2.ports_H_flow[1]' = smooth(0, 'tank2.ports[1].m_flow' * (if 'tank2.ports[1].m_flow' > 0.0 then 'valve2.port_b.h_outflow' else 'tank2.ports[1].h_outflow')) "Enthalpy flow";
    'tank2.ports_E_flow[1]' = 'tank2.ports[1].m_flow' * (0.5 * 'tank2.portVelocities[1]' * 'tank2.portVelocities[1]' + 9.80665 * 'tank2.portsData_height[1]') "Flow of kinetic and potential energy";
    'tank2.portInDensities[2]' = 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.tank2.Medium.density'('Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.tank2.Medium.setState_phX'('tank2.vessel_ps_static[2]', 'valve3.port_a.h_outflow', fill(0.0, 0)));
    'tank2.portVelocities[2]' = smooth(0, 'tank2.ports[2].m_flow' / 'tank2.portAreas[2]' / 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.tank2.Medium.density'('Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.tank2.Medium.setState_phX'('tank2.vessel_ps_static[2]', if 'tank2.ports[2].m_flow' > 0.0 then 'valve3.port_a.h_outflow' else 'tank2.ports[2].h_outflow', fill(0.0, 0))));
    'tank2.ports_penetration[2]' = 'Modelica.Fluid.Utilities.regStep'('tank2.fluidLevel' - 'tank2.portsData_height[2]' - 0.1 * 'tank2.portsData_diameter[2]', 1.0, 0.001, 0.1 * 'tank2.portsData_diameter[2]');
    'tank2.m_flow_turbulent[2]' = 0.01;
    'tank2.regularFlow[2]' = 'tank2.fluidLevel' >= 'tank2.portsData_height[2]';
    'tank2.inFlow[2]' = not 'tank2.regularFlow[2]' and ('tank2.s[2]' > 0.0 or 'tank2.portsData_height[2]' >= 5.0);

    if 'tank2.regularFlow[2]' then
      'tank2.ports[2].p' = 'tank2.vessel_ps_static[2]' + 0.5 / 'tank2.portAreas[2]' ^ 2.0 * 'Modelica.Fluid.Utilities.regSquare2'('tank2.ports[2].m_flow', 'tank2.m_flow_turbulent[2]', ('tank2.portsData_zeta_in[2]' - 1.0 + 'tank2.portAreas[2]' ^ 2.0 / 36.0) / 'tank2.portInDensities[2]' * 'tank2.ports_penetration[2]', ('tank2.portsData_zeta_out[2]' + 1.0 - 'tank2.portAreas[2]' ^ 2.0 / 36.0) / 'tank2.medium.d' / 'tank2.ports_penetration[2]', false, 1.0);
      'tank2.s[2]' = 'tank2.fluidLevel' - 'tank2.portsData_height[2]';
    elseif 'tank2.inFlow[2]' then
      'tank2.ports[2].p' = 'tank2.vessel_ps_static[2]';
      'tank2.s[2]' = 'tank2.ports[2].m_flow';
    elseif true then
      'tank2.ports[2].m_flow' = 0.0;
      'tank2.s[2]' = ('tank2.ports[2].p' - 'tank2.vessel_ps_static[2]') / 101325.0 * ('tank2.portsData_height[2]' - 'tank2.fluidLevel');
    end if;

    'tank2.ports[2].h_outflow' = 'tank2.medium.h';
    'tank2.ports_H_flow[2]' = smooth(0, 'tank2.ports[2].m_flow' * (if 'tank2.ports[2].m_flow' > 0.0 then 'valve3.port_a.h_outflow' else 'tank2.ports[2].h_outflow')) "Enthalpy flow";
    'tank2.ports_E_flow[2]' = 'tank2.ports[2].m_flow' * (0.5 * 'tank2.portVelocities[2]' * 'tank2.portVelocities[2]' + 9.80665 * 'tank2.portsData_height[2]') "Flow of kinetic and potential energy";
    'tank2.m' = 'tank2.fluidVolume' * 'tank2.medium.d';
    'tank2.U' = 'tank2.m' * 'tank2.medium.u';
    der('tank2.U') = 'tank2.Hb_flow' + 'tank2.Qb_flow' + 'tank2.Wb_flow';
    der('tank2.m') = 'tank2.mb_flow';
    assert('ambient1.medium.T' >= 272.15 and 'ambient1.medium.T' <= 403.15, "\nTemperature T (= " + String('ambient1.medium.T') + " K) is not\nin the allowed range (" + String(272.15) + " K <= T <= " + String(403.15) + " K)\nrequired from medium model \"" + "SimpleLiquidWater" + "\".\n", AssertionLevel.error);
    'ambient1.medium.h' = 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.ambient1.Medium.specificEnthalpy_pTX'('ambient1.medium.p', 'ambient1.medium.T', {'ambient1.medium.X[1]'});
    'ambient1.medium.u' = 4184.0 * ('ambient1.medium.T' - 273.15);
    'ambient1.medium.d' = 995.586;
    'ambient1.medium.R_s' = 0.0;
    'ambient1.medium.MM' = 0.018015268;
    'ambient1.medium.state.T' = 'ambient1.medium.T';
    'ambient1.medium.state.p' = 'ambient1.medium.p';
    'ambient1.medium.X[1]' = 1.0;
    assert('ambient1.medium.X[1]' >= (-1e-5) and 'ambient1.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('ambient1.medium.X[1]') + "of substance " + "SimpleLiquidWater" + "\nof medium " + "SimpleLiquidWater" + " is not in the range 0..1", AssertionLevel.error);
    assert('ambient1.medium.p' >= 0.0, "Pressure (= " + String('ambient1.medium.p') + " Pa) of medium \"" + "SimpleLiquidWater" + "\" is negative\n(Temperature = " + String('ambient1.medium.T') + " K)", AssertionLevel.error);
    'Modelica.Fluid.Utilities.checkBoundary'("SimpleLiquidWater", {"SimpleLiquidWater"}, true, true, {'ambient1.X_in_internal[1]'}, "Boundary_pT");
    'ambient1.p_in_internal' = 101325.0;
    'ambient1.T_in_internal' = 293.15;
    'ambient1.X_in_internal[1]' = 1.0;
    'ambient1.medium.p' = 'ambient1.p_in_internal';
    'ambient1.medium.T' = 'ambient1.T_in_internal';
    'ambient1.ports[1].p' = 'ambient1.medium.p';
    'ambient1.ports[1].h_outflow' = 'ambient1.medium.h';
    assert('source.medium.T' >= 272.15 and 'source.medium.T' <= 403.15, "\nTemperature T (= " + String('source.medium.T') + " K) is not\nin the allowed range (" + String(272.15) + " K <= T <= " + String(403.15) + " K)\nrequired from medium model \"" + "SimpleLiquidWater" + "\".\n", AssertionLevel.error);
    'source.medium.h' = 'Modelica.Fluid.Examples.ControlledTankSystem.ControlledTanks.source.Medium.specificEnthalpy_pTX'('source.medium.p', 'source.medium.T', {'source.medium.X[1]'});
    'source.medium.u' = 4184.0 * ('source.medium.T' - 273.15);
    'source.medium.d' = 995.586;
    'source.medium.R_s' = 0.0;
    'source.medium.MM' = 0.018015268;
    'source.medium.state.T' = 'source.medium.T';
    'source.medium.state.p' = 'source.medium.p';
    'source.medium.X[1]' = 1.0;
    assert('source.medium.X[1]' >= (-1e-5) and 'source.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('source.medium.X[1]') + "of substance " + "SimpleLiquidWater" + "\nof medium " + "SimpleLiquidWater" + " is not in the range 0..1", AssertionLevel.error);
    assert('source.medium.p' >= 0.0, "Pressure (= " + String('source.medium.p') + " Pa) of medium \"" + "SimpleLiquidWater" + "\" is negative\n(Temperature = " + String('source.medium.T') + " K)", AssertionLevel.error);
    'Modelica.Fluid.Utilities.checkBoundary'("SimpleLiquidWater", {"SimpleLiquidWater"}, true, true, {'source.X_in_internal[1]'}, "Boundary_pT");
    'source.p_in_internal' = 2.5e6;
    'source.T_in_internal' = 293.15;
    'source.X_in_internal[1]' = 1.0;
    'source.medium.p' = 'source.p_in_internal';
    'source.medium.T' = 'source.T_in_internal';
    'source.ports[1].p' = 'source.medium.p';
    'source.ports[1].h_outflow' = 'source.medium.h';
  algorithm
    'start.pre_reset' := pre('start.reset');

    when {'start.pre_reset[1]', 'start.pre_reset[2]'} then
      'start.on' := false;
    end when;

    when change('start.table.y') then
      'start.on' := true;
    end when;
  algorithm
    'stop.pre_reset' := pre('stop.reset');

    when {'stop.pre_reset[1]', 'stop.pre_reset[2]'} then
      'stop.on' := false;
    end when;

    when change('stop.table.y') then
      'stop.on' := true;
    end when;
  algorithm
    'shut.pre_reset' := pre('shut.reset');

    when {'shut.pre_reset[1]', 'shut.pre_reset[2]'} then
      'shut.on' := false;
    end when;

    when change('shut.table.y') then
      'shut.on' := true;
    end when;
    annotation(experiment(StopTime = 900));
  end 'ControlledTanks';
end 'ControlledTanks';
