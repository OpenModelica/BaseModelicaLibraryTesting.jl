    parameter Real 'tank1.fluidLevel_max'(min = 0.0, unit = "m", quantity = "Length") = 4.0 "Maximum level of fluid in the vessel";
    parameter Real 'tank1.vesselArea'(unit = "m2", quantity = "Area") = 6.0 "Area of the vessel used to relate to cross flow area of ports";
