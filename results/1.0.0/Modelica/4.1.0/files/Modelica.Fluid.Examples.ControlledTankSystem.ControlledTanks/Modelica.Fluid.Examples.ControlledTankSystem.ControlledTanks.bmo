    Real 'tank1.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'tank1.ports[2].m_flow'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.SimpleLiquidWater") "Mass flow rate from the connection point into the component";
    Real 'tank1.ports[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'tank1.ports[2].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'tank1.use_portsData' = true "= false to neglect pressure loss and kinetic energy" annotation(Evaluate = true);
    parameter Real 'tank1.portsData[1].diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.2 "Inner (hydraulic) diameter of inlet/outlet port";
