    'spring.lineForce.frame_a.f[2]' = -('Modelica.Mechanics.MultiBody.Frames.resolve2'('spring.lineForce.frame_a.R', {'spring.lineForce.e_rel_0[1]' * 'spring.lineForce.fa', 'spring.lineForce.e_rel_0[2]' * 'spring.lineForce.fa', 'spring.lineForce.e_rel_0[3]' * 'spring.lineForce.fa'}))[2];
    'spring.lineForce.frame_a.f[3]' = -('Modelica.Mechanics.MultiBody.Frames.resolve2'('spring.lineForce.frame_a.R', {'spring.lineForce.e_rel_0[1]' * 'spring.lineForce.fa', 'spring.lineForce.e_rel_0[2]' * 'spring.lineForce.fa', 'spring.lineForce.e_rel_0[3]' * 'spring.lineForce.fa'}))[3];
    'spring.lineForce.frame_b.f[1]' = -('Modelica.Mechanics.MultiBody.Frames.resolve2'('spring.lineForce.frame_b.R', {'spring.lineForce.e_rel_0[1]' * 'spring.lineForce.fb', 'spring.lineForce.e_rel_0[2]' * 'spring.lineForce.fb', 'spring.lineForce.e_rel_0[3]' * 'spring.lineForce.fb'}))[1];
    'spring.lineForce.frame_b.f[2]' = -('Modelica.Mechanics.MultiBody.Frames.resolve2'('spring.lineForce.frame_b.R', {'spring.lineForce.e_rel_0[1]' * 'spring.lineForce.fb', 'spring.lineForce.e_rel_0[2]' * 'spring.lineForce.fb', 'spring.lineForce.e_rel_0[3]' * 'spring.lineForce.fb'}))[2];
    'spring.lineForce.frame_b.f[3]' = -('Modelica.Mechanics.MultiBody.Frames.resolve2'('spring.lineForce.frame_b.R', {'spring.lineForce.e_rel_0[1]' * 'spring.lineForce.fb', 'spring.lineForce.e_rel_0[2]' * 'spring.lineForce.fb', 'spring.lineForce.e_rel_0[3]' * 'spring.lineForce.fb'}))[3];
    assert(noEvent('spring.lineForce.length' > 1e-10), "\nThe distance between the origin of frame_a and the origin of frame_b\nof a line force component became smaller as parameter s_small\n(= a small number, defined in the \"Advanced\" menu). The distance is\nset to s_small, although it is smaller, to avoid a division by zero\nwhen computing the direction of the line force. Possible reasons\nfor this situation:\n- At initial time the distance may already be zero: Change the initial\n  positions of the bodies connected by this element.\n- Hardware stops are not modeled or are modeled not stiff enough.\n  Include stops, e.g., stiff springs, or increase the stiffness\n  if already present.\n- Another error in your model may lead to unrealistically large forces\n  and torques that would in reality destroy the stops.\n- The flange_b connector might be defined by a pre-defined motion,\n  e.g., with Modelica.Mechanics.Translational.Position and the\n  predefined flange_b.s is zero or negative.\n", AssertionLevel.error);
    'spring.lineForce.r_rel_0[1]' = 'spring.lineForce.frame_b.r_0[1]' - 'spring.lineForce.frame_a.r_0[1]';
    'spring.lineForce.r_rel_0[2]' = 'spring.lineForce.frame_b.r_0[2]' - 'spring.lineForce.frame_a.r_0[2]';
    'spring.lineForce.r_rel_0[3]' = 'spring.lineForce.frame_b.r_0[3]' - 'spring.lineForce.frame_a.r_0[3]';
    'spring.lineForce.length' = sqrt('spring.lineForce.r_rel_0[1]' * 'spring.lineForce.r_rel_0[1]' + 'spring.lineForce.r_rel_0[2]' * 'spring.lineForce.r_rel_0[2]' + 'spring.lineForce.r_rel_0[3]' * 'spring.lineForce.r_rel_0[3]');
    'spring.lineForce.s' = 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent'('spring.lineForce.length', 1e-10);
    'spring.lineForce.e_rel_0[1]' = 'spring.lineForce.r_rel_0[1]' / 'spring.lineForce.s';
    'spring.lineForce.e_rel_0[2]' = 'spring.lineForce.r_rel_0[2]' / 'spring.lineForce.s';
    'spring.lineForce.e_rel_0[3]' = 'spring.lineForce.r_rel_0[3]' / 'spring.lineForce.s';
    'spring.lineForce.frame_a.t[1]' = 0.0;
    'spring.lineForce.frame_a.t[2]' = 0.0;
    'spring.lineForce.frame_a.t[3]' = 0.0;
    'spring.lineForce.frame_b.t[1]' = 0.0;
    'spring.lineForce.frame_b.t[2]' = 0.0;
    'spring.lineForce.frame_b.t[3]' = 0.0;
    'spring.spring.f' = 'spring.spring.c' * ('spring.spring.s_rel' - 0.1);
    'spring.spring.s_rel' = 'spring.spring.flange_b.s' - 'spring.spring.flange_a.s';
    'spring.spring.flange_b.f' = 'spring.spring.f';
    'spring.spring.flange_a.f' = -'spring.spring.f';
    'spring.r_rel_a[1]' = ('Modelica.Mechanics.MultiBody.Frames.resolve2'('spring.frame_a.R', 'spring.r_rel_0'))[1];
    'spring.r_rel_a[2]' = ('Modelica.Mechanics.MultiBody.Frames.resolve2'('spring.frame_a.R', 'spring.r_rel_0'))[2];
    'spring.r_rel_a[3]' = ('Modelica.Mechanics.MultiBody.Frames.resolve2'('spring.frame_a.R', 'spring.r_rel_0'))[3];
    'spring.e_a[1]' = 'spring.r_rel_a[1]' / 'spring.s';
    'spring.e_a[2]' = 'spring.r_rel_a[2]' / 'spring.s';
    'spring.e_a[3]' = 'spring.r_rel_a[3]' / 'spring.s';
    'spring.f' = 'spring.spring.f';
    'spring.length' = 'spring.lineForce.length';
    'spring.s' = 'spring.lineForce.s';
    'spring.r_rel_0[1]' = 'spring.lineForce.r_rel_0[1]';
    'spring.r_rel_0[2]' = 'spring.lineForce.r_rel_0[2]';
    'spring.r_rel_0[3]' = 'spring.lineForce.r_rel_0[3]';
    'spring.e_rel_0[1]' = 'spring.lineForce.e_rel_0[1]';
    'spring.e_rel_0[2]' = 'spring.lineForce.e_rel_0[2]';
    'spring.e_rel_0[3]' = 'spring.lineForce.e_rel_0[3]';
    annotation(experiment(StopTime = 1.01));
  end 'InitSpringConstant';
end 'InitSpringConstant';
