//! base 0.1.0
package 'ReadRealMatrixFromFile'
  function 'Modelica.Utilities.Streams.print' "Print string to terminal or file"
    input String 'string' = "";
    input String 'fileName' = "";
  external "C" ModelicaInternal_print('string', 'fileName') annotation(Library = "ModelicaExternalC", LibraryDirectory = "modelica://Modelica/Resources/Library", Include = "#include \"ModelicaInternal.h\"", IncludeDirectory = "modelica://Modelica/Resources/C-Sources");
  end 'Modelica.Utilities.Streams.print';

  function 'Modelica.Utilities.Streams.readRealMatrix' "Read Real matrix from MATLAB MAT file"
    input String 'fileName';
    input String 'matrixName';
    input Integer 'nrow';
    input Integer 'ncol';
    input Boolean 'verboseRead' = true;
    output Real['nrow', 'ncol'] 'matrix';
  external "C" ModelicaIO_readRealMatrix('fileName', 'matrixName', 'matrix', size('matrix', 1), size('matrix', 2), 'verboseRead') annotation(Library = {"ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library", Include = "#include \"ModelicaIO.h\"", IncludeDirectory = "modelica://Modelica/Resources/C-Sources");
  end 'Modelica.Utilities.Streams.readRealMatrix';

  model 'ReadRealMatrixFromFile' "Demonstrate usage of function Streams.readRealMatrix"
    parameter String 'file' = "/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat" "File name of matrix";
    parameter String 'matrixName' = "Matrix_A" "Matrix name in file";
    parameter Integer 'dim[1]' = 3 "Dimension of matrix";
    parameter Integer 'dim[2]' = 2 "Dimension of matrix";
    parameter Real 'A[1,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[1,1] "Matrix data";
    parameter Real 'A[1,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[1,2] "Matrix data";
    parameter Real 'A[2,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[2,1] "Matrix data";
    parameter Real 'A[2,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[2,2] "Matrix data";
    parameter Real 'A[3,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[3,1] "Matrix data";
    parameter Real 'A[3,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[3,2] "Matrix data";
    parameter String 'file1' = "/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat" "File name of check matrix 1";
    parameter String 'file2' = "/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v6.mat" "File name of check matrix 2";
    parameter String 'file3' = "/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v7.mat" "File name of check matrix 3";
    parameter String 'matrixName1' = "Matrix_A" "Names of check matrices";
    parameter Integer 'dim1[1]' = 3 "Dimension of check matrix 1";
    parameter Integer 'dim1[2]' = 2 "Dimension of check matrix 1";
    parameter Integer 'dim2[1]' = 3 "Dimension of check matrix 2";
    parameter Integer 'dim2[2]' = 2 "Dimension of check matrix 2";
    parameter Integer 'dim3[1]' = 3 "Dimension of check matrix 3";
    parameter Integer 'dim3[2]' = 2 "Dimension of check matrix 3";
    parameter Real 'A1[1,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[1,1] "Data of check matrix 1";
    parameter Real 'A1[1,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[1,2] "Data of check matrix 1";
    parameter Real 'A1[2,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[2,1] "Data of check matrix 1";
    parameter Real 'A1[2,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[2,2] "Data of check matrix 1";
    parameter Real 'A1[3,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[3,1] "Data of check matrix 1";
    parameter Real 'A1[3,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "Matrix_A", 3, 2, true))[3,2] "Data of check matrix 1";
    parameter Real 'A2[1,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v6.mat", "Matrix_A", 3, 2, true))[1,1] "Data of check matrix 2";
    parameter Real 'A2[1,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v6.mat", "Matrix_A", 3, 2, true))[1,2] "Data of check matrix 2";
    parameter Real 'A2[2,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v6.mat", "Matrix_A", 3, 2, true))[2,1] "Data of check matrix 2";
    parameter Real 'A2[2,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v6.mat", "Matrix_A", 3, 2, true))[2,2] "Data of check matrix 2";
    parameter Real 'A2[3,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v6.mat", "Matrix_A", 3, 2, true))[3,1] "Data of check matrix 2";
    parameter Real 'A2[3,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v6.mat", "Matrix_A", 3, 2, true))[3,2] "Data of check matrix 2";
    parameter Real 'A3[1,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v7.mat", "Matrix_A", 3, 2, true))[1,1] "Data of check matrix 3";
    parameter Real 'A3[1,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v7.mat", "Matrix_A", 3, 2, true))[1,2] "Data of check matrix 3";
    parameter Real 'A3[2,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v7.mat", "Matrix_A", 3, 2, true))[2,1] "Data of check matrix 3";
    parameter Real 'A3[2,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v7.mat", "Matrix_A", 3, 2, true))[2,2] "Data of check matrix 3";
    parameter Real 'A3[3,1]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v7.mat", "Matrix_A", 3, 2, true))[3,1] "Data of check matrix 3";
    parameter Real 'A3[3,2]' = ('Modelica.Utilities.Streams.readRealMatrix'("/home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v7.mat", "Matrix_A", 3, 2, true))[3,2] "Data of check matrix 3";
    Real 'x'(fixed = true, start = 1.0) "Dummy state";
    constant Real 'eps' = 2.220446049250313e-15;
  equation
    assert(abs('A1[1,1]' - 11.0) <= 2.220446049250313e-15, "Resources/Data/Utilities/Test_RealMatrix_v4.mat not correctly loaded", AssertionLevel.error);
    assert(abs('A2[1,1]' - 11.0) <= 2.220446049250313e-15, "Resources/Data/Utilities/Test_RealMatrix_v6.mat not correctly loaded", AssertionLevel.error);
    assert(abs('A3[1,1]' - 11.0) <= 2.220446049250313e-15, "Resources/Data/Utilities/Test_RealMatrix_v7.mat not correctly loaded", AssertionLevel.error);
    der('x') = -'A[1,1]' * 'x';
  algorithm
    when initial() then
      'Modelica.Utilities.Streams.print'("... Matrix Matrix_A[3,2] read from file /home/andreas/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Test_RealMatrix_v4.mat", "");
      'Modelica.Utilities.Streams.print'("...    Matrix_A[1,1] = " + String('A[1,1]'), "");
    end when;
    annotation(experiment(StopTime = 0.1));
  end 'ReadRealMatrixFromFile';
end 'ReadRealMatrixFromFile';
