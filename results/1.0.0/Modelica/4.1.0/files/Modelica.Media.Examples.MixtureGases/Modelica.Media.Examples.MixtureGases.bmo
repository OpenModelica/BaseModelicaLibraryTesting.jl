  function 'Modelica.Media.IdealGases.Common.Functions.dynamicViscosityLowPressure' "Dynamic viscosity of low pressure gases"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'Tc'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'M'(min = 0.0, unit = "kg/mol", quantity = "MolarMass");
    input Real 'Vc'(min = 0.0, unit = "m3/mol", quantity = "MolarVolume");
    input Real 'w';
    input Real 'mu'(max = 2.0, min = 0.0, unit = "debye", quantity = "ElectricDipoleMoment");
    input Real 'k' = 0.0;
    output Real 'eta'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    parameter Real 'Const1_SI' = 1.2897349436996735e-8;
    parameter Real 'Const2_SI' = 0.1313;
    Real 'Tstar';
    Real 'Ov';
    Real 'mur' = 'Const2_SI' * 'mu' / sqrt('Vc' * 'Tc');
    Real 'Fc' = 1.0 - 0.2756 * 'w' + 0.059035 * 'mur' ^ 4.0 + 'k';
  algorithm
    'Tstar' := 1.2593 * 'T' / 'Tc';
    'Ov' := 1.16145 * 'Tstar' ^ (-0.14874) + 0.52487 * exp(-0.7732 * 'Tstar') + 2.16178 * exp(-2.43787 * 'Tstar');
    'eta' := 'Const1_SI' * 'Fc' * sqrt('M' * 'T') / ('Vc' ^ 0.6666666666666666 * 'Ov');
    annotation(smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.dynamicViscosityLowPressure';

  function 'Modelica.Media.IdealGases.Common.Functions.h_T' "Compute specific enthalpy from temperature and gas data; reference is decided by the
    refChoice input, or by the referenceChoice package constant by default"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'exclEnthForm' = true;
    input 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' 'refChoice' = 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K';
    input Real 'h_off'(unit = "J/kg", quantity = "SpecificEnergy") = 0.0;
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := smooth(0, (if 'T' < 'data'.'Tlimit' then 'data'.'R_s' * (('T' * ('data'.'blow'[1] + 'data'.'alow'[2] * log('T') + 'T' * ('data'.'alow'[3] + 'T' * (0.5 * 'data'.'alow'[4] + 'T' * (0.3333333333333333 * 'data'.'alow'[5] + 'T' * (0.25 * 'data'.'alow'[6] + 0.2 * 'data'.'alow'[7] * 'T'))))) - 'data'.'alow'[1]) / 'T') else 'data'.'R_s' * (('T' * ('data'.'bhigh'[1] + 'data'.'ahigh'[2] * log('T') + 'T' * ('data'.'ahigh'[3] + 'T' * (0.5 * 'data'.'ahigh'[4] + 'T' * (0.3333333333333333 * 'data'.'ahigh'[5] + 'T' * (0.25 * 'data'.'ahigh'[6] + 0.2 * 'data'.'ahigh'[7] * 'T'))))) - 'data'.'ahigh'[1]) / 'T')) + (if 'exclEnthForm' then -'data'.'Hf' else 0.0) + (if 'refChoice' == 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K' then 'data'.'H0' else 0.0) + (if 'refChoice' == 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined' then 'h_off' else 0.0));
    annotation(Inline = false, smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.h_T';

  function 'Modelica.Media.IdealGases.Common.Functions.thermalConductivityEstimate' "Thermal conductivity of polyatomic gases (Eucken and Modified Eucken correlation)"
    input Real 'Cp'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    input Real 'eta'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Integer 'method'(max = 2, min = 1) = 1;
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    output Real 'lambda'(nominal = 1.0, start = 1.0, max = 500.0, min = 0.0, unit = "W/(m.K)", quantity = "ThermalConductivity");
  algorithm
    'lambda' := if 'method' == 1 then 'eta' * ('Cp' - 'data'.'R_s' + 2.25 * 'data'.'R_s') else 'eta' * ('Cp' - 'data'.'R_s') * (1.32 + 1.77 / ('Cp' / 'data'.'R_s' - 1.0));
    annotation(smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.thermalConductivityEstimate';

  record 'Medium1.ThermodynamicState'
    Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[2] 'X'(nominal = fill(0.1, 2), start = {0.768, 0.232}, max = fill(1.0, 2), min = fill(0.0, 2), unit = fill("kg/kg", 2), quantity = fill("MassFraction", 2));
  end 'Medium1.ThermodynamicState';

  record 'Medium2.ThermodynamicState'
    Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[6] 'X'(nominal = fill(0.1, 6), start = {0.92, 0.048, 0.005, 0.002, 0.015, 0.01}, max = fill(1.0, 6), min = fill(0.0, 6), unit = fill("kg/kg", 6), quantity = fill("MassFraction", 6));
  end 'Medium2.ThermodynamicState';

  type 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' = enumeration('ZeroAt0K', 'ZeroAt25C', 'UserDefined');

  record 'Modelica.Media.IdealGases.Common.DataRecord'
    String 'name';
    Real 'MM'(min = 0.0, unit = "kg/mol", quantity = "MolarMass");
