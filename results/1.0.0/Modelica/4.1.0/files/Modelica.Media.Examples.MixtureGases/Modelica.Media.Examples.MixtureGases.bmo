  function 'Modelica.Media.Examples.MixtureGases.Medium2.lowPressureThermalConductivity' "Return thermal conductivities of low-pressure gas mixtures (Mason and Saxena Modification)"
    input Real[:] 'y'(nominal = fill(0.1, size('y', 1)), max = fill(1.0, size('y', 1)), min = fill(0.0, size('y', 1)), unit = fill("mol/mol", size('y', 1)), quantity = fill("MoleFraction", size('y', 1)));
    input Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[size('y', 1)] 'Tc'(nominal = fill(500.0, size('y', 1)), start = fill(500.0, size('y', 1)), max = fill(6000.0, size('y', 1)), min = fill(200.0, size('y', 1)), displayUnit = fill("degC", size('y', 1)), unit = fill("K", size('y', 1)), quantity = fill("ThermodynamicTemperature", size('y', 1)));
    input Real[size('y', 1)] 'Pc'(nominal = fill(1e6, size('y', 1)), start = fill(1e6, size('y', 1)), max = fill(1e8, size('y', 1)), min = fill(0.0, size('y', 1)), displayUnit = fill("bar", size('y', 1)), unit = fill("Pa", size('y', 1)), quantity = fill("Pressure", size('y', 1)));
    input Real[size('y', 1)] 'M'(nominal = fill(0.032, size('y', 1)), max = fill(0.25, size('y', 1)), min = fill(0.001, size('y', 1)), unit = fill("kg/mol", size('y', 1)), quantity = fill("MolarMass", size('y', 1)));
    input Real[size('y', 1)] 'lambda'(nominal = fill(1.0, size('y', 1)), start = fill(1.0, size('y', 1)), max = fill(500.0, size('y', 1)), min = fill(0.0, size('y', 1)), unit = fill("W/(m.K)", size('y', 1)), quantity = fill("ThermalConductivity", size('y', 1)));
    output Real 'lambdam'(nominal = 1.0, start = 1.0, max = 500.0, min = 0.0, unit = "W/(m.K)", quantity = "ThermalConductivity");
    Real[size('y', 1)] 'gamma'(nominal = fill(0.032, size('y', 1)), max = fill(0.25, size('y', 1)), min = fill(0.001, size('y', 1)), unit = fill("kg/mol", size('y', 1)), quantity = fill("MolarMass", size('y', 1)));
    Real[size('y', 1)] 'Tr';
    Real[size('y', 1), size('y', 1)] 'A';
    constant Real 'epsilon' = 1.0;
  algorithm
    for 'i' in 1:size('y', 1) loop
      'gamma'['i'] := 210.0 * ('Tc'['i'] * 'M'['i'] ^ 3.0 / 'Pc'['i'] ^ 4.0) ^ 0.16666666666666666;
      'Tr'['i'] := 'T' / 'Tc'['i'];
    end for;

    for 'i' in 1:size('y', 1) loop
      for 'j' in 1:size('y', 1) loop
        'A'['i','j'] := 'epsilon' * (1.0 + ('gamma'['j'] * (exp(0.0464 * 'Tr'['i']) - exp(-0.2412 * 'Tr'['i'])) / ('gamma'['i'] * (exp(0.0464 * 'Tr'['j']) - exp(-0.2412 * 'Tr'['j'])))) ^ 0.5 * ('M'['i'] / 'M'['j']) ^ 0.25) ^ 2.0 / (8.0 * (1.0 + 'M'['i'] / 'M'['j'])) ^ 0.5;
      end for;
    end for;

    'lambdam' := sum('y'['i'] * 'lambda'['i'] / sum('y'['j'] * 'A'['i','j'] for 'j' in 1:size('y', 1)) for 'i' in 1:size('y', 1));
    annotation(smoothOrder = 2);
  end 'Modelica.Media.Examples.MixtureGases.Medium2.lowPressureThermalConductivity';

  function 'Modelica.Media.Examples.MixtureGases.Medium2.massToMoleFractions' "Return mole fractions from mass fractions X"
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real[:] 'MMX'(min = fill(0.0, size('MMX', 1)), unit = fill("kg/mol", size('MMX', 1)), quantity = fill("MolarMass", size('MMX', 1)));
    output Real[size('X', 1)] 'moleFractions'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MoleFraction", size('X', 1)));
    Real[size('X', 1)] 'invMMX';
    Real 'Mmix'(min = 0.0, unit = "kg/mol", quantity = "MolarMass");
  algorithm
    for 'i' in 1:size('X', 1) loop
      'invMMX'['i'] := 1.0 / 'MMX'['i'];
    end for;

    'Mmix' := 1.0 / ('X' * 'invMMX');

    for 'i' in 1:size('X', 1) loop
      'moleFractions'['i'] := 'Mmix' * 'X'['i'] / 'MMX'['i'];
    end for;
    annotation(smoothOrder = 5);
  end 'Modelica.Media.Examples.MixtureGases.Medium2.massToMoleFractions';

