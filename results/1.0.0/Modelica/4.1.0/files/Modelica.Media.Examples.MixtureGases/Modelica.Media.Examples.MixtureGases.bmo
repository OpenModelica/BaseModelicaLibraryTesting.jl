    assert('medium1.T' >= 200.0 and 'medium1.T' <= 6000.0, "\nTemperature T (=" + String('medium1.T') + " K = 200 K) is not in the allowed range\n200 K <= T <= 6000 K\nrequired from medium model \"" + "CombustionAirN2O2" + "\".", AssertionLevel.error);
    'medium1.MM' = 1.0 / ('medium1.state.X[1]' / 0.0280134 + 'medium1.state.X[2]' / 0.0319988);
    'medium1.h' = 'Modelica.Media.Examples.MixtureGases.Medium1.h_TX'('medium1.T', {'medium1.X[1]', 'medium1.X[2]'}, true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0);
    'medium1.R_s' = 296.80474344420884 * 'medium1.X[1]' + 259.8381814318037 * 'medium1.X[2]';
    'medium1.u' = 'medium1.h' - 'medium1.R_s' * 'medium1.T';
    'medium1.d' = 'medium1.p' / ('medium1.R_s' * 'medium1.T');
    'medium1.state.T' = 'medium1.T';
    'medium1.state.p' = 'medium1.p';
    'medium1.state.X[1]' = 'medium1.X[1]';
    'medium1.state.X[2]' = 'medium1.X[2]';
    'medium1.Xi[1]' = 'medium1.X[1]';
    'medium1.Xi[2]' = 'medium1.X[2]';
    assert('medium1.X[1]' >= (-1e-5) and 'medium1.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('medium1.X[1]') + "of substance " + "Nitrogen" + "\nof medium " + "CombustionAirN2O2" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium1.X[2]' >= (-1e-5) and 'medium1.X[2]' <= 1.00001, "Mass fraction X[" + String(2) + "] = " + String('medium1.X[2]') + "of substance " + "Oxygen" + "\nof medium " + "CombustionAirN2O2" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium1.p' >= 0.0, "Pressure (= " + String('medium1.p') + " Pa) of medium \"" + "CombustionAirN2O2" + "\" is negative\n(Temperature = " + String('medium1.T') + " K)", AssertionLevel.error);
    assert('medium2.T' >= 200.0 and 'medium2.T' <= 6000.0, "\nTemperature T (=" + String('medium2.T') + " K = 200 K) is not in the allowed range\n200 K <= T <= 6000 K\nrequired from medium model \"" + "SimpleNaturalGas" + "\".", AssertionLevel.error);
    'medium2.MM' = 1.0 / ('medium2.state.X[1]' / 0.01604246 + 'medium2.state.X[2]' / 0.03006904 + 'medium2.state.X[3]' / 0.04409562 + 'medium2.state.X[4]' / 0.0581222 + 'medium2.state.X[5]' / 0.0280134 + 'medium2.state.X[6]' / 0.0440095);
    'medium2.h' = 'Modelica.Media.Examples.MixtureGases.Medium2.h_TX'('medium2.T', {'medium2.X[1]', 'medium2.X[2]', 'medium2.X[3]', 'medium2.X[4]', 'medium2.X[5]', 'medium2.X[6]'}, true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0);
    'medium2.R_s' = 518.2814855078335 * 'medium2.X[1]' + 276.51398248830026 * 'medium2.X[2]' + 188.55636909062622 * 'medium2.X[3]' + 143.05222445124238 * 'medium2.X[4]' + 296.80474344420884 * 'medium2.X[5]' + 188.92534566400437 * 'medium2.X[6]';
    'medium2.u' = 'medium2.h' - 'medium2.R_s' * 'medium2.T';
    'medium2.d' = 'medium2.p' / ('medium2.R_s' * 'medium2.T');
    'medium2.state.T' = 'medium2.T';
    'medium2.state.p' = 'medium2.p';
    'medium2.state.X[1]' = 'medium2.X[1]';
    'medium2.state.X[2]' = 'medium2.X[2]';
    'medium2.state.X[3]' = 'medium2.X[3]';
    'medium2.state.X[4]' = 'medium2.X[4]';
    'medium2.state.X[5]' = 'medium2.X[5]';
    'medium2.state.X[6]' = 'medium2.X[6]';
    'medium2.Xi[1]' = 'medium2.X[1]';
    'medium2.Xi[2]' = 'medium2.X[2]';
    'medium2.Xi[3]' = 'medium2.X[3]';
    'medium2.Xi[4]' = 'medium2.X[4]';
    'medium2.Xi[5]' = 'medium2.X[5]';
    'medium2.Xi[6]' = 'medium2.X[6]';
    assert('medium2.X[1]' >= (-1e-5) and 'medium2.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('medium2.X[1]') + "of substance " + "Methane" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[2]' >= (-1e-5) and 'medium2.X[2]' <= 1.00001, "Mass fraction X[" + String(2) + "] = " + String('medium2.X[2]') + "of substance " + "Ethane" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[3]' >= (-1e-5) and 'medium2.X[3]' <= 1.00001, "Mass fraction X[" + String(3) + "] = " + String('medium2.X[3]') + "of substance " + "Propane" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[4]' >= (-1e-5) and 'medium2.X[4]' <= 1.00001, "Mass fraction X[" + String(4) + "] = " + String('medium2.X[4]') + "of substance " + "N-Butane," + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[5]' >= (-1e-5) and 'medium2.X[5]' <= 1.00001, "Mass fraction X[" + String(5) + "] = " + String('medium2.X[5]') + "of substance " + "Nitrogen" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[6]' >= (-1e-5) and 'medium2.X[6]' <= 1.00001, "Mass fraction X[" + String(6) + "] = " + String('medium2.X[6]') + "of substance " + "Carbondioxide" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.p' >= 0.0, "Pressure (= " + String('medium2.p') + " Pa) of medium \"" + "SimpleNaturalGas" + "\" is negative\n(Temperature = " + String('medium2.T') + " K)", AssertionLevel.error);
    'state2.X[1]' = 0.3;
    'state2.X[2]' = 0.2;
    'state2.X[3]' = 0.2;
    'state2.X[4]' = 0.1;
    'state2.X[5]' = 0.1;
    'state2.X[6]' = 0.1;
    'medium1.X[1]' = 0.8;
    'medium1.X[2]' = 0.2;
    'm1' = 'medium1.d';
    'U1' = 'm1' * 'medium1.u';
    der('m1') = 0.01;
    der('U1') = 5000.0;
    'medium2.X[1]' = 0.1;
    'medium2.X[2]' = 0.1;
    'medium2.X[3]' = 0.1;
    'medium2.X[4]' = 0.2;
    'medium2.X[5]' = 0.2;
    'medium2.X[6]' = 0.3;
    'm2' = 'medium2.d';
    'U2' = 'm2' * 'medium2.u';
    der('m2') = 0.01;
    der('U2') = 5000.0;
    'm_flow_ext2' = time - 0.5;
    'smoothState.p' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.p' else if 'm_flow_ext2' < (-0.2) then 'state2.p' else 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.p' - 'medium2.state.p') / 4.0 + ('medium2.state.p' + 'state2.p') / 2.0);
    'smoothState.T' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.T' else if 'm_flow_ext2' < (-0.2) then 'state2.T' else 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.T' - 'medium2.state.T') / 4.0 + ('medium2.state.T' + 'state2.T') / 2.0);
    'smoothState.X[1]' = 'Modelica.Media.Common.smoothStep'('m_flow_ext2', 'medium2.state.X[1]', 'state2.X[1]', 0.2);
    'smoothState.X[2]' = 'Modelica.Media.Common.smoothStep'('m_flow_ext2', 'medium2.state.X[2]', 'state2.X[2]', 0.2);
    'smoothState.X[3]' = 'Modelica.Media.Common.smoothStep'('m_flow_ext2', 'medium2.state.X[3]', 'state2.X[3]', 0.2);
    'smoothState.X[4]' = 'Modelica.Media.Common.smoothStep'('m_flow_ext2', 'medium2.state.X[4]', 'state2.X[4]', 0.2);
    'smoothState.X[5]' = 'Modelica.Media.Common.smoothStep'('m_flow_ext2', 'medium2.state.X[5]', 'state2.X[5]', 0.2);
    'smoothState.X[6]' = 'Modelica.Media.Common.smoothStep'('m_flow_ext2', 'medium2.state.X[6]', 'state2.X[6]', 0.2);
    'der_p' = der('smoothState.p');
    'der_T' = der('smoothState.T');
    annotation(experiment(StopTime = 1));
  end 'MixtureGases';
end 'MixtureGases';
