    parameter Real 'diode1.idealDiode[1].Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'diode1.idealDiode[1].Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'diode1.idealDiode[1].useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'diode1.idealDiode[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'diode1.idealDiode[1].LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
