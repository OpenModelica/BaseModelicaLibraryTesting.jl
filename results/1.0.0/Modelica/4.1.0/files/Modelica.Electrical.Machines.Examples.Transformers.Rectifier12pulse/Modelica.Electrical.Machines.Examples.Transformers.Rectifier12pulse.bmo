    parameter Real 'transformerData2.f'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'transformerData2.V1'(start = 100.0, unit = "V", quantity = "ElectricPotential") = 100.0 "Primary nominal line-to-line voltage (RMS)";
    parameter String 'transformerData2.C1'(start = "Y") = "D" "Choose primary connection";
    parameter Real 'transformerData2.V2'(start = 100.0, unit = "V", quantity = "ElectricPotential") = 100.0 "Secondary open circuit line-to-line voltage (RMS) @ primary nominal voltage";
    parameter String 'transformerData2.C2'(start = "y") = "d" "Choose secondary connection";
    parameter Real 'transformerData2.SNominal'(start = 3e4, unit = "V.A", quantity = "Power") = 3e4 "Nominal apparent power";
    parameter Real 'transformerData2.v_sc'(start = 0.05, max = 1.0, min = 0.0) = 0.05 "Impedance voltage drop pu";
    parameter Real 'transformerData2.P_sc'(start = 300.0, unit = "W", quantity = "Power") = 300.0 "Short-circuit (copper) losses";
    parameter Real 'transformerData2.n' = 1.0 "Ratio primary voltage (line-to-line) / secondary voltage (line-to-line)";
    parameter Real 'transformerData2.V1ph'(unit = "V", quantity = "ElectricPotential") = 100.0 "Primary phase voltage (RMS)";
    parameter Real 'transformerData2.I1ph'(unit = "A", quantity = "ElectricCurrent") = 100.0 "Primary phase current (RMS)";
    parameter Real 'transformerData2.V2ph'(unit = "V", quantity = "ElectricPotential") = 100.0 "Secondary phase voltage (RMS)";
    parameter Real 'transformerData2.I2ph'(unit = "A", quantity = "ElectricCurrent") = 100.0 "Secondary phase current (RMS)";
    parameter Real 'transformerData2.Z1ph'(unit = "Ohm", quantity = "Resistance") = 0.025 "Primary impedance per phase";
    parameter Real 'transformerData2.R1'(unit = "Ohm", quantity = "Resistance") = 0.005 "Warm primary resistance per phase";
    parameter Real 'transformerData2.L1sigma'(unit = "H", quantity = "Inductance") = 7.796968012336763e-5 "Primary stray inductance per phase";
    parameter Real 'transformerData2.Z2ph'(unit = "Ohm", quantity = "Resistance") = 0.025 "Secondary impedance per phase";
    parameter Real 'transformerData2.R2'(unit = "Ohm", quantity = "Resistance") = 0.005 "Warm secondary resistance per phase";
    parameter Real 'transformerData2.L2sigma'(unit = "H", quantity = "Inductance") = 7.796968012336763e-5 "Secondary stray inductance per phase";
  initial equation
    'transformer2.core.plug_p1.pin[1].i' = 0.0;
    'transformer2.core.plug_p1.pin[2].i' = 0.0;
    'transformer2.core.plug_p1.pin[3].i' = 0.0;
    'cDC1.v' = 70.71067811865474;
    'cDC2.v' = 70.71067811865474;
    'transformer1.i2[1]' = 0.0;
    'transformer1.i2[2]' = 0.0;
  equation
    'source.sineVoltage[1].p.v' = 'source.plug_p.pin[1].v';
    'source.sineVoltage[2].p.v' = 'source.plug_p.pin[2].v';
    'source.sineVoltage[3].p.v' = 'source.plug_p.pin[3].v';
    'source.sineVoltage[1].n.v' = 'source.plug_n.pin[1].v';
    'source.sineVoltage[2].n.v' = 'source.plug_n.pin[2].v';
    'source.sineVoltage[3].n.v' = 'source.plug_n.pin[3].v';
    'starAC.plug_p.pin[3].v' = 'starAC.pin_n.v';
    'starAC.plug_p.pin[3].v' = 'starAC.plug_p.pin[2].v';
    'starAC.plug_p.pin[3].v' = 'starAC.plug_p.pin[1].v';
    -('starAC.plug_p.pin[3].i' + 'starAC.pin_n.i' + 'starAC.plug_p.pin[2].i' + 'starAC.plug_p.pin[1].i') = 0.0;
    'currentSensor.plug_p.pin[1].v' = 'currentSensor.currentSensor[1].p.v';
    'currentSensor.currentSensor[1].p.i' - 'currentSensor.plug_p.pin[1].i' = 0.0;
    'currentSensor.plug_p.pin[2].v' = 'currentSensor.currentSensor[2].p.v';
    'currentSensor.currentSensor[2].p.i' - 'currentSensor.plug_p.pin[2].i' = 0.0;
    'currentSensor.plug_p.pin[3].v' = 'currentSensor.currentSensor[3].p.v';
    'currentSensor.currentSensor[3].p.i' - 'currentSensor.plug_p.pin[3].i' = 0.0;
    'currentSensor.currentSensor[1].n.v' = 'currentSensor.plug_n.pin[1].v';
    'currentSensor.currentSensor[2].n.v' = 'currentSensor.plug_n.pin[2].v';
    'currentSensor.currentSensor[3].n.v' = 'currentSensor.plug_n.pin[3].v';
    'currentSensor.currentSensor[1].i' = 'currentSensor.i[1]';
    'currentSensor.currentSensor[2].i' = 'currentSensor.i[2]';
    'currentSensor.currentSensor[3].i' = 'currentSensor.i[3]';
    'diode1.plug_p.pin[1].v' = 'diode1.idealDiode[1].p.v';
    'diode1.idealDiode[1].p.i' - 'diode1.plug_p.pin[1].i' = 0.0;
    'diode1.plug_p.pin[2].v' = 'diode1.idealDiode[2].p.v';
    'diode1.idealDiode[2].p.i' - 'diode1.plug_p.pin[2].i' = 0.0;
    'diode1.plug_p.pin[3].v' = 'diode1.idealDiode[3].p.v';
    'diode1.idealDiode[3].p.i' - 'diode1.plug_p.pin[3].i' = 0.0;
    'diode1.idealDiode[1].n.v' = 'diode1.plug_n.pin[1].v';
    'diode1.idealDiode[2].n.v' = 'diode1.plug_n.pin[2].v';
    'diode1.idealDiode[3].n.v' = 'diode1.plug_n.pin[3].v';
    'star1.plug_p.pin[3].v' = 'star1.pin_n.v';
    'star1.plug_p.pin[3].v' = 'star1.plug_p.pin[2].v';
    'star1.plug_p.pin[3].v' = 'star1.plug_p.pin[1].v';
