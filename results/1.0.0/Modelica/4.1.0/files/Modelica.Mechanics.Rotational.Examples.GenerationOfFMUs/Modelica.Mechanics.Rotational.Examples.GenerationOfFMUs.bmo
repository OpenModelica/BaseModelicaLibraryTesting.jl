    Real 'springDamper.angleToTorque1.move_w.u[2]' "Angle and angular velocity of flange with respect to support as input signals";
    Real 'springDamper.phi1'(unit = "rad") "Angle of left flange of force element";
    Real 'springDamper.w1'(unit = "rad/s") "Speed to left flange of force element";
    Real 'springDamper.tau1'(unit = "N.m") "Torque generated by the force element";
    parameter Real 'springDamper.springDamper.c'(start = 1e5, min = 0.0, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 1e4 "Spring constant";
    parameter Real 'springDamper.springDamper.d'(start = 0.0, min = 0.0, unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 100.0 "Damping constant";
    parameter Real 'springDamper.springDamper.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
