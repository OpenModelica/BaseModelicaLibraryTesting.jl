//! base 0.1.0
package 'GenerationOfFMUs'
  function 'Modelica.Mechanics.Rotational.Examples.GenerationOfFMUs.inverseInertia.angleToTorque.move.position'
    input Real[3] 'q_qd_qdd';
    input Real 'dummy';
    output Real 'q';
  algorithm
    'q' := 'q_qd_qdd'[1];
    annotation(derivative(order = 1, noDerivative = 'q_qd_qdd') = 'Modelica.Mechanics.Rotational.Examples.GenerationOfFMUs.inverseInertia.angleToTorque.move.position_der', InlineAfterIndexReduction = true);
  end 'Modelica.Mechanics.Rotational.Examples.GenerationOfFMUs.inverseInertia.angleToTorque.move.position';

  function 'Modelica.Mechanics.Rotational.Examples.GenerationOfFMUs.inverseInertia.angleToTorque.move.position_der'
    input Real[3] 'q_qd_qdd';
    input Real 'dummy';
    input Real 'dummy_der';
    output Real 'qd';
  algorithm
    'qd' := 'q_qd_qdd'[2];
    annotation(derivative(order = 2, noDerivative = 'q_qd_qdd') = 'Modelica.Mechanics.Rotational.Examples.GenerationOfFMUs.inverseInertia.angleToTorque.move.position_der2', InlineAfterIndexReduction = true);
  end 'Modelica.Mechanics.Rotational.Examples.GenerationOfFMUs.inverseInertia.angleToTorque.move.position_der';

