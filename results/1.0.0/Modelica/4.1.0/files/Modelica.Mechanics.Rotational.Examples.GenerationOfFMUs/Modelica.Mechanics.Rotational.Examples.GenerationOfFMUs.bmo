  model 'GenerationOfFMUs' "Example to demonstrate variants to generate FMUs (Functional Mock-up Units)"
    parameter Real 'sine1.amplitude' = 10.0 "Amplitude of sine wave";
    parameter Real 'sine1.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of sine wave";
    parameter Real 'sine1.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine1.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine1.y' "Connector of Real output signal";
    parameter Real 'sine1.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine1.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'directInertia.J'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 1.1 "Inertia";
    Real 'directInertia.inertia.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'directInertia.inertia.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'directInertia.inertia.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'directInertia.inertia.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'directInertia.inertia.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 1.1 "Moment of inertia";
    parameter StateSelect 'directInertia.inertia.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'directInertia.inertia.phi'(stateSelect = StateSelect.default, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'directInertia.inertia.w'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'directInertia.inertia.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Boolean 'directInertia.torqueSource.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'directInertia.torqueSource.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'directInertia.torqueSource.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'directInertia.torqueSource.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'directInertia.torqueSource.tau'(unit = "N.m") "Accelerating torque acting at flange (= -flange.tau)";
    Real 'directInertia.tauDrive'(unit = "N.m") "Accelerating torque acting at flange (= -flange.tau)";
    parameter Boolean 'directInertia.torqueToAngle.use_w' = true "= true, enable the output connector w (angular velocity)" annotation(Evaluate = true);
    parameter Boolean 'directInertia.torqueToAngle.use_a' = true "= true, enable the output connector a (angular acceleration)" annotation(Evaluate = true);
    Real 'directInertia.torqueToAngle.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'directInertia.torqueToAngle.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'directInertia.torqueToAngle.phi'(unit = "rad") "Flange moves with angle phi due to torque tau";
    Real 'directInertia.torqueToAngle.w'(unit = "rad/s") "Flange moves with speed w due to torque tau";
    Real 'directInertia.torqueToAngle.a'(unit = "rad/s2") "Flange moves with angular acceleration a due to torque tau";
    Real 'directInertia.torqueToAngle.tau'(unit = "N.m") "Torque to drive the flange";
    Real 'directInertia.torqueToAngle.w_internal'(unit = "rad/s") "Needed to connect to conditional connector w";
    Real 'directInertia.torqueToAngle.a_internal'(unit = "rad/s2") "Needed to connect to conditional connector a";
    Real 'directInertia.phi'(unit = "rad") "Inertia moves with angle phi due to torque tau";
    Real 'directInertia.w'(unit = "rad/s") "Inertia moves with speed w due to torque tau";
    Real 'directInertia.a'(unit = "rad/s2") "Inertia moves with acceleration a due to torque tau";
    Real 'directInertia.tau'(unit = "N.m") "Torque to drive the inertia";
    parameter Real 'inverseInertia.J'(unit = "kg.m2", quantity = "MomentOfInertia") = 2.2 "Inertia";
    Real 'inverseInertia.inertia.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inverseInertia.inertia.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inverseInertia.inertia.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inverseInertia.inertia.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'inverseInertia.inertia.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 2.2 "Moment of inertia";
    parameter StateSelect 'inverseInertia.inertia.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'inverseInertia.inertia.phi'(stateSelect = StateSelect.default, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'inverseInertia.inertia.w'(stateSelect = StateSelect.default, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'inverseInertia.inertia.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Boolean 'inverseInertia.angleToTorque.use_w' = true "= true, enable the input connector w (angular velocity)" annotation(Evaluate = true);
    parameter Boolean 'inverseInertia.angleToTorque.use_a' = true "= true, enable the input connector a (angular acceleration)" annotation(Evaluate = true);
    Real 'inverseInertia.angleToTorque.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inverseInertia.angleToTorque.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inverseInertia.angleToTorque.phi'(unit = "rad") "Angle to drive the flange";
    Real 'inverseInertia.angleToTorque.w'(unit = "rad/s") "Speed to drive the flange (w=der(phi) required)";
    Real 'inverseInertia.angleToTorque.a'(unit = "rad/s2") "Angular acceleration to drive the flange (a = der(w) required)";
    Real 'inverseInertia.angleToTorque.tau'(unit = "N.m") "Torque needed to drive the flange according to phi, w, a";
    parameter Boolean 'inverseInertia.angleToTorque.move.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'inverseInertia.angleToTorque.move.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inverseInertia.angleToTorque.move.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inverseInertia.angleToTorque.move.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'inverseInertia.angleToTorque.move.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotation angle of flange with respect to support";
    Real 'inverseInertia.angleToTorque.move.u[1]' "Angle, angular velocity and angular acceleration of flange with respect to support as input signals";
    Real 'inverseInertia.angleToTorque.move.u[2]' "Angle, angular velocity and angular acceleration of flange with respect to support as input signals";
    Real 'inverseInertia.angleToTorque.move.u[3]' "Angle, angular velocity and angular acceleration of flange with respect to support as input signals";
    parameter Integer 'inverseInertia.angleToTorque.multiplex3.n1' = 1 "Dimension of input signal connector 1";
    parameter Integer 'inverseInertia.angleToTorque.multiplex3.n2' = 1 "Dimension of input signal connector 2";
    parameter Integer 'inverseInertia.angleToTorque.multiplex3.n3' = 1 "Dimension of input signal connector 3";
    Real 'inverseInertia.angleToTorque.multiplex3.u1[1]' "Connector of Real input signals 1";
    Real 'inverseInertia.angleToTorque.multiplex3.u2[1]' "Connector of Real input signals 2";
    Real 'inverseInertia.angleToTorque.multiplex3.u3[1]' "Connector of Real input signals 3";
    Real 'inverseInertia.angleToTorque.multiplex3.y[1]' "Connector of Real output signals";
    Real 'inverseInertia.angleToTorque.multiplex3.y[2]' "Connector of Real output signals";
    Real 'inverseInertia.angleToTorque.multiplex3.y[3]' "Connector of Real output signals";
    Real 'inverseInertia.angleToTorque.torqueSensor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inverseInertia.angleToTorque.torqueSensor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inverseInertia.angleToTorque.torqueSensor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inverseInertia.angleToTorque.torqueSensor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inverseInertia.angleToTorque.torqueSensor.tau'(unit = "N.m") "Torque in flange flange_a and flange_b (tau = flange_a.tau = -flange_b.tau) as output signal";
    Real 'inverseInertia.phi'(unit = "rad") "Angle to drive the inertia";
    Real 'inverseInertia.w'(unit = "rad/s") "Speed to drive the inertia";
    Real 'inverseInertia.a'(unit = "rad/s2") "Acceleration to drive the inertia";
    Real 'inverseInertia.tau'(unit = "N.m") "Torque needed to drive the flange according to phi, w, a";
    parameter Real 'springDamper.c'(unit = "N.m/rad", quantity = "RotationalSpringConstant") = 1e4 "Spring constant";
    parameter Real 'springDamper.d'(unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 100.0 "Damping constant";
    parameter Real 'springDamper.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    parameter Boolean 'springDamper.angleToTorque1.use_w' = true "= true, enable the input connector w (angular velocity)" annotation(Evaluate = true);
    parameter Boolean 'springDamper.angleToTorque1.use_a' = false "= true, enable the input connector a (angular acceleration)" annotation(Evaluate = true);
