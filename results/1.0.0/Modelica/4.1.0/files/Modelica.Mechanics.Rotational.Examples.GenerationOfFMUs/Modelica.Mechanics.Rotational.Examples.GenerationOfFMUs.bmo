    input Real 'dummy';
    input Real 'dummy_der';
    input Real 'dummy_der2';
    output Real 'qdd';
  algorithm
    'qdd' := 'q_qd_qdd'[3];
  end 'Modelica.Mechanics.Rotational.Examples.GenerationOfFMUs.inverseInertia.angleToTorque.move.position_der2';

