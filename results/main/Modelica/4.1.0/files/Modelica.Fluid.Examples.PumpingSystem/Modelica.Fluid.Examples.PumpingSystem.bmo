    Real 'userValve.state_a.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'userValve.state_a.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Integer 'userValve.state_b.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'userValve.state_b.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'userValve.state_b.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'userValve.state_b.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'userValve.state_b.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Real 'userValve.dp_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2e5 "Nominal pressure drop at full opening";
    parameter Real 'userValve.m_flow_nominal'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 400.0 "Nominal mass flowrate at full opening";
    parameter Real 'userValve.k'(unit = "kg/(s.Pa)", quantity = "HydraulicConductance") = 0.002 "Hydraulic conductance at full opening";
    Real 'userValve.opening'(max = 1.0, min = 0.0) "=1: completely open, =0: completely closed";
    parameter Integer 'sink.nPorts' = 2 "Number of ports";
    Real 'sink.medium.p'(stateSelect = StateSelect.default, nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'sink.medium.h'(stateSelect = StateSelect.default, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'sink.medium.d'(stateSelect = StateSelect.default, nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'sink.medium.T'(stateSelect = StateSelect.default, nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'sink.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'sink.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'sink.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'sink.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Integer 'sink.medium.state.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'sink.medium.state.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'sink.medium.state.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'sink.medium.state.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'sink.medium.state.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'sink.medium.preferredMediumStates' = false "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'sink.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'sink.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'sink.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'sink.medium.sat.psat'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Saturation pressure";
    Real 'sink.medium.sat.Tsat'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Saturation temperature";
    Integer 'sink.medium.phase'(fixed = false, start = 1, max = 2, min = 0) "2 for two-phase, 1 for one-phase, 0 if not known";
    Real 'sink.ports[1].m_flow'(max = 1e60, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'sink.ports[1].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'sink.ports[1].h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'sink.ports[2].m_flow'(max = 1e60, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'sink.ports[2].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'sink.ports[2].h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter 'Modelica.Fluid.Types.PortFlowDirection' 'sink.flowDirection' = 'Modelica.Fluid.Types.PortFlowDirection'.'Bidirectional' "Allowed flow direction" annotation(Evaluate = true);
    parameter Boolean 'sink.use_p' = true "Select p or d" annotation(Evaluate = true);
    parameter Real 'sink.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Boundary pressure";
    parameter Real 'sink.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 998.2060924679472 "Boundary density";
    parameter Boolean 'sink.use_T' = true "Select T or h" annotation(Evaluate = true);
    parameter Real 'sink.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Boundary temperature";
    parameter Real 'sink.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 84013.0581525969 "Boundary specific enthalpy";
    parameter Real 'sink.X[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Boundary mass fractions m_i/m";
    Integer 'sink.state.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'sink.state.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'sink.state.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'sink.state.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'sink.state.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Real 'valveOpening.height' = 1.0 "Height of step";
    Real 'valveOpening.y' "Connector of Real output signal";
    parameter Real 'valveOpening.offset' = 1e-6 "Offset of output signal y";
    parameter Real 'valveOpening.startTime'(unit = "s", quantity = "Time") = 200.0 "Output y = offset for time < startTime";
    parameter Real 'RelativePressureSetPoint.k'(start = 1.0) = 2e4 "Constant output value";
    Real 'RelativePressureSetPoint.y' "Connector of Real output signal";
    Real 'controller.reference' "Connector of Real input signal used as reference signal";
    Real 'controller.u' "Connector of Real input signal used as measurement signal";
    Boolean 'controller.y' "Connector of Real output signal used as actuator signal";
    parameter Real 'controller.bandwidth'(start = 0.1) = 4000.0 "Bandwidth around reference signal";
    parameter Boolean 'controller.pre_y_start' = false "Value of pre(y) at initial time";
    parameter Real 'PumpRPMGenerator.amplitude' = 1200.0 "Amplitude of trapezoid";
    parameter Real 'PumpRPMGenerator.rising'(min = 0.0, unit = "s", quantity = "Time") = 3.0 "Rising duration of trapezoid";
    parameter Real 'PumpRPMGenerator.falling'(min = 0.0, unit = "s", quantity = "Time") = 3.0 "Falling duration of trapezoid";
    parameter Real 'PumpRPMGenerator.offset' = 0.001 "Offset of output signal";
    Boolean 'PumpRPMGenerator.u' "Connector of Boolean input signal";
    Real 'PumpRPMGenerator.y' "Connector of Real output signal";
    discrete Real 'PumpRPMGenerator.endValue' "Value of y at time of recent edge";
    discrete Real 'PumpRPMGenerator.rate' "Current rising/falling rate";
    discrete Real 'PumpRPMGenerator.T'(unit = "s", quantity = "Time") "Predicted time of output reaching endValue";
    Real 'reservoirPressure.port_a.m_flow'(max = 1e5, min = 0.0, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'reservoirPressure.port_a.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'reservoirPressure.port_a.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'reservoirPressure.port_b.m_flow'(max = 1e5, min = 0.0, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'reservoirPressure.port_b.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'reservoirPressure.port_b.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'reservoirPressure.p_rel'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Relative pressure signal";
    parameter Real 'PT1.k' = 1.0 "Gain";
    parameter Real 'PT1.T'(start = 1.0, unit = "s", quantity = "Time") = 2.0 "Time Constant";
    parameter 'Modelica.Blocks.Types.Init' 'PT1.initType' = 'Modelica.Blocks.Types.Init'.'InitialState' "Type of initialization (1: no init, 2: steady state, 3/4: initial output)" annotation(Evaluate = true);
    parameter Real 'PT1.y_start' = 0.0 "Initial or guess value of output (= state)";
    Real 'PT1.u' "Connector of Real input signal";
    Real 'PT1.y'(start = 0.0) "Connector of Real output signal";
    parameter Real 'system.p_ambient'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default ambient pressure";
    parameter Real 'system.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default ambient temperature";
    parameter Real 'system.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'system.allowFlowReversal' = true "= false to restrict to design flow direction (port_a -> port_b)" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of energy balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of mass balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of trace substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Default formulation of momentum balances, if options available" annotation(Evaluate = true);
    parameter Real 'system.m_flow_start'(unit = "kg/s", quantity = "MassFlowRate") = 0.0 "Default start value for mass flow rates";
    parameter Real 'system.p_start'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default start value for pressures";
    parameter Real 'system.T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default start value for temperatures";
    parameter Boolean 'system.use_eps_Re' = false "= true to determine turbulent region automatically using Reynolds number" annotation(Evaluate = true);
    parameter Real 'system.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 1.0 "Default nominal mass flow rate";
    parameter Real 'system.eps_m_flow'(min = 0.0) = 1e-4 "Regularization of zero flow for |m_flow| < eps_m_flow*m_flow_nominal";
    parameter Real 'system.dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0 "Default small pressure drop for regularization of laminar and zero flow";
    parameter Real 'system.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Default small mass flow rate for regularization of laminar and zero flow";
  initial equation
    'pipe.flowModel.dp_nominal' = 1000.0 * 'pipe.flowModel.dp_small';
    'pipe.flowModel.dp_small' = 1.0;
    'pumps.medium.T' = 293.15;
    'pumps.medium.p' = 6e5;
    'reservoir.level' = 2.2;
    'reservoir.medium.T' = 293.15;
    pre('controller.y') = false;
    'PT1.y' = 0.0;
  equation
    'source.medium.T_degC' = 'source.medium.T' - 273.15;
    'source.medium.p_bar' = 'source.medium.p' / 1e5;
    'pipe.flowModel.dp_fric_nominal' = 'Modelica.Fluid.Examples.PumpingSystem.pipe.flowModel.WallFriction.pressureLoss_m_flow'('pipe.flowModel.m_flow_nominal', 998.2060924679472, 998.2060924679472, 0.0010016053256479086, 0.0010016053256479086, 'pipe.flowModel.pathLengths_internal[1]', 'pipe.flowModel.diameters[1]', ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') / 2.0, ('pipe.flowModel.roughnesses[1]' + 'pipe.flowModel.roughnesses[2]') / 2.0, 'pipe.flowModel.m_flow_small', 'pipe.flowModel.Res_turbulent_internal[1]');
    'pumps.fluidVolume' = 0.05;
    'pumps.medium.T_degC' = 'pumps.medium.T' - 273.15;
    'pumps.medium.p_bar' = 'pumps.medium.p' / 1e5;
    'pumps.heatTransfer.states[1].phase' = 'pumps.medium.state.phase';
    'pumps.heatTransfer.states[1].h' = 'pumps.medium.state.h';
    'pumps.heatTransfer.states[1].d' = 'pumps.medium.state.d';
    'pumps.heatTransfer.states[1].T' = 'pumps.medium.state.T';
    'pumps.heatTransfer.states[1].p' = 'pumps.medium.state.p';
    'pumps.rho' = 'pumps.medium.d';
    'pumps.dp_pump' = 'pumps.port_b.p' - 'pumps.port_a.p';
    'pumps.head' = 'pumps.dp_pump' / ('pumps.rho' * 9.80665);
    'pumps.m_flow' = 'pumps.port_a.m_flow';
    'pumps.m_flow_single' = 'pumps.m_flow';
    'pumps.W_total' = 'pumps.W_single';
    'pumps.monitoring.state.phase' = 'pumps.medium.state.phase';
    'pumps.monitoring.state.h' = 'pumps.medium.state.h';
    'pumps.monitoring.state.d' = 'pumps.medium.state.d';
    'pumps.monitoring.state.T' = 'pumps.medium.state.T';
    'pumps.monitoring.state.p' = 'pumps.medium.state.p';
    'reservoir.fluidVolume' = 'reservoir.V';
    'reservoir.medium.T_degC' = 'reservoir.medium.T' - 273.15;
    'reservoir.medium.p_bar' = 'reservoir.medium.p' / 1e5;
    'reservoir.heatTransfer.states[1].phase' = 'reservoir.medium.state.phase';
    'reservoir.heatTransfer.states[1].h' = 'reservoir.medium.state.h';
    'reservoir.heatTransfer.states[1].d' = 'reservoir.medium.state.d';
    'reservoir.heatTransfer.states[1].T' = 'reservoir.medium.state.T';
    'reservoir.heatTransfer.states[1].p' = 'reservoir.medium.state.p';
