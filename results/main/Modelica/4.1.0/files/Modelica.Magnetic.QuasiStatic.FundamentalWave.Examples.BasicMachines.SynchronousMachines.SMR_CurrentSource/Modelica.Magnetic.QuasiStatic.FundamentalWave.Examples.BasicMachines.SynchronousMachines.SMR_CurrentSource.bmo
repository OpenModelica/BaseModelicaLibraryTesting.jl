    parameter Real 'dqToThreePhase.toPeak_d.k'(start = 1.0) = 1.4142135623730951 "Gain value multiplied with input signal";
    Real 'dqToThreePhase.toPeak_d.u' "Input signal connector";
    Real 'dqToThreePhase.toPeak_d.y' "Output signal connector";
    parameter Real 'dqToThreePhase.toPeak_q.k'(start = 1.0) = 1.4142135623730951 "Gain value multiplied with input signal";
    Real 'dqToThreePhase.toPeak_q.u' "Input signal connector";
    Real 'dqToThreePhase.toPeak_q.y' "Output signal connector";
    parameter Real 'dqToThreePhase.toGamma.k'(start = 1.0) = -2.0 "Gain value multiplied with input signal";
    Real 'dqToThreePhase.toGamma.u' "Input signal connector";
    Real 'dqToThreePhase.toGamma.y' "Output signal connector";
    parameter Integer 'dqToThreePhase.rotator.n' = 2 "Number of inputs (= number of outputs)";
    Real 'dqToThreePhase.rotator.u[1]' "Connector of Real input signals";
    Real 'dqToThreePhase.rotator.u[2]' "Connector of Real input signals";
    Real 'dqToThreePhase.rotator.y[1]' "Connector of Real output signals";
    Real 'dqToThreePhase.rotator.y[2]' "Connector of Real output signals";
    Real 'dqToThreePhase.rotator.RotationMatrix[1,1]';
    Real 'dqToThreePhase.rotator.RotationMatrix[1,2]';
    Real 'dqToThreePhase.rotator.RotationMatrix[2,1]';
    Real 'dqToThreePhase.rotator.RotationMatrix[2,2]';
    Real 'dqToThreePhase.rotator.angle'(unit = "rad");
    parameter Real 'dqToThreePhase.i0.k'(start = 1.0) = 0.0 "Constant output value";
    Real 'dqToThreePhase.i0.y' "Connector of Real output signal";
    parameter Integer 'dqToThreePhase.fromSpacePhasor.nin' = 2 "Number of inputs";
    parameter Integer 'dqToThreePhase.fromSpacePhasor.nout' = 3 "Number of outputs";
    Real 'dqToThreePhase.fromSpacePhasor.u[1]' "Connector of Real input signals";
    Real 'dqToThreePhase.fromSpacePhasor.u[2]' "Connector of Real input signals";
    Real 'dqToThreePhase.fromSpacePhasor.y[1]' "Connector of Real output signals";
    Real 'dqToThreePhase.fromSpacePhasor.y[2]' "Connector of Real output signals";
    Real 'dqToThreePhase.fromSpacePhasor.y[3]' "Connector of Real output signals";
    parameter Integer 'dqToThreePhase.fromSpacePhasor.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'dqToThreePhase.fromSpacePhasor.phi[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    parameter Real 'dqToThreePhase.fromSpacePhasor.phi[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 2.0943951023931953;
    parameter Real 'dqToThreePhase.fromSpacePhasor.phi[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 4.1887902047863905;
    parameter Real 'dqToThreePhase.fromSpacePhasor.TransformationMatrix[1,1]' = 0.6666666666666666;
    parameter Real 'dqToThreePhase.fromSpacePhasor.TransformationMatrix[1,2]' = -0.33333333333333315;
    parameter Real 'dqToThreePhase.fromSpacePhasor.TransformationMatrix[1,3]' = -0.3333333333333336;
    parameter Real 'dqToThreePhase.fromSpacePhasor.TransformationMatrix[2,1]' = 0.0;
    parameter Real 'dqToThreePhase.fromSpacePhasor.TransformationMatrix[2,2]' = 0.5773502691896257;
    parameter Real 'dqToThreePhase.fromSpacePhasor.TransformationMatrix[2,3]' = -0.5773502691896255;
    parameter Real 'dqToThreePhase.fromSpacePhasor.InverseTransformation[1,1]' = 1.0;
    parameter Real 'dqToThreePhase.fromSpacePhasor.InverseTransformation[1,2]' = 0.0;
    parameter Real 'dqToThreePhase.fromSpacePhasor.InverseTransformation[2,1]' = -0.4999999999999998;
    parameter Real 'dqToThreePhase.fromSpacePhasor.InverseTransformation[2,2]' = 0.8660254037844387;
    parameter Real 'dqToThreePhase.fromSpacePhasor.InverseTransformation[3,1]' = -0.5000000000000004;
    parameter Real 'dqToThreePhase.fromSpacePhasor.InverseTransformation[3,2]' = -0.8660254037844384;
