    parameter Integer 'dqToThreePhase.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'dqToThreePhase.p' = 2 "Number of pole pairs";
    parameter Boolean 'dqToThreePhase.useRMS' = true "If true, inputs dq are multiplied by sqrt(2)";
    parameter Integer 'dqToThreePhase.nout'(min = 1) = 3 "Number of outputs";
    Real 'dqToThreePhase.y[1]' "Connector of Real output signals";
    Real 'dqToThreePhase.y[2]' "Connector of Real output signals";
    Real 'dqToThreePhase.y[3]' "Connector of Real output signals";
    Real 'dqToThreePhase.d' "d-component";
    Real 'dqToThreePhase.q' "q-component";
