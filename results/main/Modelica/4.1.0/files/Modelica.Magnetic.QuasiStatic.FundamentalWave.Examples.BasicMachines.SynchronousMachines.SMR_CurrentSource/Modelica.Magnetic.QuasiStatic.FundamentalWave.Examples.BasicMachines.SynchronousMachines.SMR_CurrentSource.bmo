    Real 'signalCurrent.signalCurrent[3].i'(unit = "A") "Current flowing from pin p to pin n as input signal";
    Real 'signalCurrent.signalCurrent[3].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop between the two pins (= p.v - n.v)";
