//! base 0.1.0
package 'SMR_CurrentSource'
  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  record 'Modelica.Units.SI.ComplexVoltage'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexVoltage';

  record 'Modelica.Units.SI.ComplexCurrent'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexCurrent';

  record 'Modelica.Units.SI.ComplexMagneticPotentialDifference'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexMagneticPotentialDifference';

  record 'Modelica.Units.SI.ComplexMagneticFlux'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexMagneticFlux';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexOutput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexOutput';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexInput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexInput';

  model 'SMR_CurrentSource' "Test example: Synchronous reluctance machine fed by current source"
    parameter Integer 'm' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Actual frequency";
    parameter Real 'tRamp'(unit = "s", quantity = "Time") = 1.0 "Frequency ramp";
    parameter Real 'TLoad'(unit = "N.m", quantity = "Torque") = 181.4 "Nominal load torque";
    parameter Real 'tStep'(unit = "s", quantity = "Time") = 1.2 "Time of load torque step";
    parameter Real 'JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load's moment of inertia";
    Real 'thetaQS'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotor displacement angle, quasi-static";
    Real 'theta'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotor displacement angle, transient";
    parameter Integer 'signalCurrent.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'signalCurrent.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops between the two plugs";
    Real 'signalCurrent.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops between the two plugs";
    Real 'signalCurrent.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops between the two plugs";
    parameter Integer 'signalCurrent.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'signalCurrent.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'signalCurrent.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'signalCurrent.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.i[1]'(unit = "A") "Current flowing from pin p to pin n as input signal";
    Real 'signalCurrent.i[2]'(unit = "A") "Current flowing from pin p to pin n as input signal";
    Real 'signalCurrent.i[3]'(unit = "A") "Current flowing from pin p to pin n as input signal";
    Real 'signalCurrent.signalCurrent[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.signalCurrent[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.signalCurrent[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.signalCurrent[1].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.signalCurrent[1].i'(unit = "A") "Current flowing from pin p to pin n as input signal";
    Real 'signalCurrent.signalCurrent[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop between the two pins (= p.v - n.v)";
    Real 'signalCurrent.signalCurrent[2].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.signalCurrent[2].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.signalCurrent[2].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.signalCurrent[2].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.signalCurrent[2].i'(unit = "A") "Current flowing from pin p to pin n as input signal";
    Real 'signalCurrent.signalCurrent[2].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop between the two pins (= p.v - n.v)";
    Real 'signalCurrent.signalCurrent[3].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalCurrent.signalCurrent[3].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalCurrent.signalCurrent[3].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
