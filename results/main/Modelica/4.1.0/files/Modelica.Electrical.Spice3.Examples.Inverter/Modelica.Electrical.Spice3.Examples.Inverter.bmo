    Real 'm_qgb'(start = 0.0, unit = "C", quantity = "ElectricCharge");
  end 'Modelica.Electrical.Spice3.Internal.Mos1.Mos1Calc';

  record 'Modelica.Electrical.Spice3.Internal.Mos.MosModelLineParams'
    Real 'm_jctSatCurDensity'(start = 0.0);
    Real 'm_sheetResistance'(start = 0.0, unit = "Ohm", quantity = "Resistance");
    Real 'm_bulkJctPotential'(start = 0.8);
    Real 'm_bulkJctBotGradingCoeff'(start = 0.5, unit = "1/K", quantity = "LinearTemperatureCoefficient");
    Real 'm_bulkJctSideGradingCoeff'(start = 0.5, unit = "1/K", quantity = "LinearTemperatureCoefficient");
    Real 'm_oxideThickness'(start = 1e-7);
    Real 'm_oxideThicknessIsGiven';
    Real 'm_gateSourceOverlapCapFactor'(start = 0.0);
    Real 'm_gateDrainOverlapCapFactor'(start = 0.0);
    Real 'm_gateBulkOverlapCapFactor'(start = 0.0);
    Real 'm_fNcoef'(start = 0.0);
    Real 'm_fNexp'(start = 1.0);
    Real 'm_mjswIsGiven';
    Real 'm_cgsoIsGiven';
    Real 'm_cgdoIsGiven';
    Real 'm_cgboIsGiven';
    Real 'm_pbIsGiven';
    Real 'm_oxideCapFactor'(start = 0.0);
    Real 'm_vt0'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_vtOIsGiven';
    Real 'm_capBD'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_capBDIsGiven';
    Real 'm_capBS'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_capBSIsGiven';
    Real 'm_bulkCapFactor'(start = 0.0, unit = "F/m2", quantity = "CapacitancePerArea");
    Real 'm_bulkCapFactorIsGiven';
    Real 'm_sideWallCapFactor'(start = 0.0, min = 0.0, unit = "F/m", quantity = "Permittivity");
    Real 'm_fwdCapDepCoeff'(start = 0.5);
    Real 'm_phi'(start = 0.6, unit = "V", quantity = "ElectricPotential");
    Real 'm_phiIsGiven';
    Real 'm_gamma'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_gammaIsGiven';
    Real 'm_lambda'(unit = "1/V", quantity = "InversePotential");
    Real 'm_substrateDoping'(start = 0.0);
    Real 'm_substrateDopingIsGiven';
    Real 'm_gateType'(start = 1.0);
    Real 'm_surfaceStateDensity'(start = 0.0, unit = "1/cm2", quantity = "PerArea");
    Real 'm_surfaceStateDensityIsGiven'(start = 0.0);
    Real 'm_surfaceMobility'(start = 600.0, unit = "cm2/(V.s)", quantity = "AreaPerVoltageSecond");
    Real 'm_latDiff'(start = 0.0, unit = "m", quantity = "Length");
    Real 'm_jctSatCur'(start = 1e-14, unit = "A", quantity = "ElectricCurrent");
    Real 'm_drainResistance'(start = 0.0, unit = "Ohm", quantity = "Resistance");
    Real 'm_drainResistanceIsGiven';
    Real 'm_sourceResistance'(start = 0.0, unit = "Ohm", quantity = "Resistance");
    Real 'm_sourceResistanceIsGiven';
    Real 'm_transconductance'(unit = "A/V2", quantity = "Transconductance");
    Real 'm_transconductanceIsGiven';
    Real 'm_tnom'(nominal = 300.0, start = 300.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  end 'Modelica.Electrical.Spice3.Internal.Mos.MosModelLineParams';

  record 'Modelica.Electrical.Spice3.Internal.SpiceConstants'
    constant Real 'EPSSIL' = 11.7 * 8.854214871e-12;
    constant Real 'EPSOX' = 3.453133e-11;
    constant Real 'CHARGE'(unit = "C", quantity = "ElectricCharge") = 1.6021918e-19;
    constant Real 'CONSTCtoK'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.15;
    constant Real 'CONSTboltz'(unit = "J/K", quantity = "HeatCapacity") = 1.3806226e-23;
    constant Real 'REFTEMP'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'CONSTroot2' = sqrt(2.0);
    constant Real 'CONSTvt0'(unit = "(J)/(A.s)") = 1.380649e-23 * 'Modelica.Units.Conversions.from_degC'(27.0) / 1.6021918e-19;
    constant Real 'CONSTKoverQ'(unit = "(J/K)/(A.s)") = 1.380649e-23 / 1.6021918e-19;
    constant Real 'CONSTe' = exp(1.0);
    constant Real 'CKTgmin'(unit = "S", quantity = "Conductance") = 1e-12;
    constant Real 'CKTnomTemp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'CKTtemp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'CKTdefaultMosAD'(unit = "m2", quantity = "Area") = 0.0;
    constant Real 'CKTdefaultMosAS'(unit = "m2", quantity = "Area") = 0.0;
    constant Real 'CKTdefaultMosL'(unit = "m", quantity = "Length") = 1e-4;
    constant Real 'CKTdefaultMosW'(unit = "m", quantity = "Length") = 1e-4;
    constant Real 'CKTreltol' = 1e-10;
    constant Real 'CKTabstol' = 1e-15;
    constant Real 'CKTvolttol' = 1e-10;
    constant Real 'CKTtemptol' = 0.001;
  end 'Modelica.Electrical.Spice3.Internal.SpiceConstants';

  record 'Modelica.Electrical.Spice3.Internal.Mos.MosModelLineVariables'
    Real 'm_oxideCapFactor';
    Real 'm_vt0'(unit = "V", quantity = "ElectricPotential");
    Real 'm_phi'(unit = "V", quantity = "ElectricPotential");
    Real 'm_gamma';
    Real 'm_transconductance'(unit = "A/V2", quantity = "Transconductance");
  end 'Modelica.Electrical.Spice3.Internal.Mos.MosModelLineVariables';

  record 'Modelica.Electrical.Spice3.Internal.Mos.CurrrentsCapacitances'
    Real 'idrain'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'iBD'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'iBS'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'cGS'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'cGB'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'cGD'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'cBS'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'cBD'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_capgd'(min = -1e60, unit = "F", quantity = "Capacitance");
  end 'Modelica.Electrical.Spice3.Internal.Mos.CurrrentsCapacitances';

  model 'Inverter' "Simple inverter circuit"
    Real 'mp.G.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'mp.G.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'mp.D.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'mp.D.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'mp.S.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'mp.S.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'mp.B.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'mp.B.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'mp.mtype'(start = 0) = 1 "MOSFET type: 0 - N channel, 1 - P channel";
    parameter Real 'mp.L'(unit = "m", quantity = "Length") = 1e-4 "Length";
    parameter Real 'mp.W'(unit = "m", quantity = "Length") = 1e-4 "Width";
    parameter Real 'mp.AD'(unit = "m2", quantity = "Area") = 0.0 "Area of the drain diffusion";
    parameter Real 'mp.AS'(unit = "m2", quantity = "Area") = 0.0 "Area of the source diffusion";
    parameter Real 'mp.PD'(unit = "m", quantity = "Length") = 0.0 "Perimeter of the drain junction";
    parameter Real 'mp.PS'(unit = "m", quantity = "Length") = 0.0 "Perimeter of the source junction";
    parameter Real 'mp.NRD' = 1.0 "Number of squares of the drain diffusions";
    parameter Real 'mp.NRS' = 1.0 "Number of squares of the source diffusions";
    parameter Integer 'mp.OFF' = 0 "Optional initial condition: 0 - IC not used, 1 - IC used, not implemented yet";
    parameter Real 'mp.IC'(start = -1e40, unit = "V", quantity = "ElectricPotential") = -1e40 "Initial condition values, not implemented yet";
    parameter Real 'mp.TEMP'(unit = "degC", quantity = "ThermodynamicTemperature") = 27.0 "Operating temperature of the device";
    parameter Real 'mp.modelcard.VTO'(unit = "V", quantity = "ElectricPotential") = -1e40 "Zero-bias threshold voltage, default 0";
    parameter Real 'mp.modelcard.KP'(unit = "A/V2", quantity = "Transconductance") = -1e40 "Transconductance parameter, default 2e-5";
    parameter Real 'mp.modelcard.GAMMA' = -1e40 "Bulk threshold parameter, default 0";
    parameter Real 'mp.modelcard.PHI'(unit = "V", quantity = "ElectricPotential") = -1e40 "Surface potential, default 0.6";
    parameter Real 'mp.modelcard.LAMBDA'(unit = "1/V", quantity = "InversePotential") = 0.0 "Channel-length modulation, default 0";
    parameter Real 'mp.modelcard.RD'(unit = "Ohm", quantity = "Resistance") = 0.0 "Drain ohmic resistance, default 0";
    parameter Real 'mp.modelcard.RS'(unit = "Ohm", quantity = "Resistance") = 0.0 "Source ohmic resistance, default 0";
    parameter Real 'mp.modelcard.CBD'(min = -1e60, unit = "F", quantity = "Capacitance") = 0.0 "Zero-bias B-D junction capacitance, default 0";
    parameter Real 'mp.modelcard.CBS'(min = -1e60, unit = "F", quantity = "Capacitance") = 0.0 "Zero-bias B-S junction capacitance, default 0";
    parameter Real 'mp.modelcard.IS'(unit = "A", quantity = "ElectricCurrent") = 1e-14 "Bulk junction saturation current";
    parameter Real 'mp.modelcard.PB'(unit = "V", quantity = "ElectricPotential") = 0.8 "Bulk junction potential";
    parameter Real 'mp.modelcard.CGSO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-source overlap capacitance per meter channel width";
    parameter Real 'mp.modelcard.CGDO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-drain overlap capacitance per meter channel width";
    parameter Real 'mp.modelcard.CGBO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-bulk overlap capacitance per meter channel width";
    parameter Real 'mp.modelcard.RSH'(unit = "Ohm", quantity = "Resistance") = 0.0 "Drain and source diffusion sheet resistance";
    parameter Real 'mp.modelcard.CJ'(unit = "F/m2", quantity = "CapacitancePerArea") = 0.0 "Zero-bias bulk junction bottom cap. per sq-meter of junction area";
    parameter Real 'mp.modelcard.MJ' = 0.5 "Bulk junction bottom grading coefficient";
    parameter Real 'mp.modelcard.CJSW'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Zero-bias junction sidewall cap. per meter of junction perimeter";
    parameter Real 'mp.modelcard.MJSW' = 0.5 "Bulk junction sidewall grading coefficient";
    parameter Real 'mp.modelcard.JS'(unit = "A/m2", quantity = "CurrentDensity") = 0.0 "Bulk junction saturation current per sq-meter of junction area";
    parameter Real 'mp.modelcard.TOX'(unit = "m", quantity = "Length") = -1e40 "Oxide thickness, default 1e-7";
    parameter Real 'mp.modelcard.NSUB' = -1e40 "Substrate doping, default 0";
    parameter Real 'mp.modelcard.NSS'(unit = "1/cm2", quantity = "PerArea") = 0.0 "Surface state density";
    parameter Real 'mp.modelcard.TPG' = 1.0 "Type of gate material: +1 opp. to substrate, -1 same as substrate, 0 Al gate";
    parameter Real 'mp.modelcard.LD'(unit = "m", quantity = "Length") = 0.0 "Lateral diffusion";
    parameter Real 'mp.modelcard.UO'(unit = "cm2/(V.s)", quantity = "AreaPerVoltageSecond") = 600.0 "Surface mobility";
    parameter Real 'mp.modelcard.KF' = 0.0 "Flicker noise coefficient";
    parameter Real 'mp.modelcard.AF' = 1.0 "Flicker noise exponent";
    parameter Real 'mp.modelcard.FC' = 0.5 "Coefficient for forward-bias depletion capacitance formula";
    parameter Real 'mp.modelcard.TNOM'(unit = "degC", quantity = "ThermodynamicTemperature") = 27.0 "Parameter measurement temperature, default 27";
    constant Integer 'mp.modelcard.LEVEL' = 1 "Model level: Shichman-Hodges";
    constant Real 'mp.C.EPSSIL' = 1.0359431399069999e-10;
    constant Real 'mp.C.EPSOX' = 3.453133e-11;
    constant Real 'mp.C.CHARGE'(unit = "C", quantity = "ElectricCharge") = 1.6021918e-19;
    constant Real 'mp.C.CONSTCtoK'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.15;
    constant Real 'mp.C.CONSTboltz'(unit = "J/K", quantity = "HeatCapacity") = 1.3806226e-23;
    constant Real 'mp.C.REFTEMP'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'mp.C.CONSTroot2' = 1.4142135623730951;
    constant Real 'mp.C.CONSTvt0'(unit = "(J)/(A.s)") = 0.025864680954552383;
    constant Real 'mp.C.CONSTKoverQ'(unit = "(J/K)/(A.s)") = 8.617251692337959e-5;
    constant Real 'mp.C.CONSTe' = 2.718281828459045;
    constant Real 'mp.C.CKTgmin'(unit = "S", quantity = "Conductance") = 1e-12;
    constant Real 'mp.C.CKTnomTemp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'mp.C.CKTtemp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'mp.C.CKTdefaultMosAD'(unit = "m2", quantity = "Area") = 0.0;
    constant Real 'mp.C.CKTdefaultMosAS'(unit = "m2", quantity = "Area") = 0.0;
    constant Real 'mp.C.CKTdefaultMosL'(unit = "m", quantity = "Length") = 1e-4;
    constant Real 'mp.C.CKTdefaultMosW'(unit = "m", quantity = "Length") = 1e-4;
    constant Real 'mp.C.CKTreltol' = 1e-10;
    constant Real 'mp.C.CKTabstol' = 1e-15;
    constant Real 'mp.C.CKTvolttol' = 1e-10;
    constant Real 'mp.C.CKTtemptol' = 0.001;
    parameter Real 'mp.p.m_jctSatCurDensity'(start = 0.0) = 0.0 "JS, Bulk jct. sat. current density, input - use tSatCurDens";
    parameter Real 'mp.p.m_sheetResistance'(start = 0.0, unit = "Ohm", quantity = "Resistance") = 0.0 "RSH, Sheet resistance";
    parameter Real 'mp.p.m_bulkJctPotential'(start = 0.8) = 0.8 "PB, Bulk junction potential, input - use tBulkPot";
    parameter Real 'mp.p.m_bulkJctBotGradingCoeff'(start = 0.5, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.5 "MJ, Bottom grading coefficient";
    parameter Real 'mp.p.m_bulkJctSideGradingCoeff'(start = 0.5, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.5 "MJSW, Side grading coefficient";
    parameter Real 'mp.p.m_oxideThickness'(start = 1e-7) = 0.0 "TOX, Oxide thickness unit: micron";
    parameter Real 'mp.p.m_oxideThicknessIsGiven' = 0.0 "TOX, IsGiven value";
    parameter Real 'mp.p.m_gateSourceOverlapCapFactor'(start = 0.0) = 0.0 "CGS0, Gate-source overlap cap";
    parameter Real 'mp.p.m_gateDrainOverlapCapFactor'(start = 0.0) = 0.0 "CGD0, Gate-drain overlap cap";
    parameter Real 'mp.p.m_gateBulkOverlapCapFactor'(start = 0.0) = 0.0 "CGB0, Gate-bulk overlap cap";
    parameter Real 'mp.p.m_fNcoef'(start = 0.0) = 0.0 "KF, Flicker noise coefficient";
    parameter Real 'mp.p.m_fNexp'(start = 1.0) = 1.0 "AF, Flicker noise exponent";
    parameter Real 'mp.p.m_mjswIsGiven' = 0.0 "MJSW, IsGivenValue";
    parameter Real 'mp.p.m_cgsoIsGiven' = 0.0 "CGSO, IsGivenValue";
    parameter Real 'mp.p.m_cgdoIsGiven' = 0.0 "CGDO, IsGivenValue";
    parameter Real 'mp.p.m_cgboIsGiven' = 0.0 "CGBO, IsGivenValue";
    parameter Real 'mp.p.m_pbIsGiven' = 0.0 "PB, IsGivenValue";
    parameter Real 'mp.p.m_oxideCapFactor'(start = 0.0) = 0.0;
    parameter Real 'mp.p.m_vt0'(start = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "VTO, Threshold voltage";
    parameter Real 'mp.p.m_vtOIsGiven' = 0.0 "VTO IsGivenValue";
    parameter Real 'mp.p.m_capBD'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance") = 0.0 "CBD, B-D junction capacitance";
    parameter Real 'mp.p.m_capBDIsGiven' = 1.0 "CapBD IsGivenValue";
    parameter Real 'mp.p.m_capBS'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance") = 0.0 "CBS, B-S junction capacitance";
    parameter Real 'mp.p.m_capBSIsGiven' = 1.0 "CapBS IsGivenValue";
