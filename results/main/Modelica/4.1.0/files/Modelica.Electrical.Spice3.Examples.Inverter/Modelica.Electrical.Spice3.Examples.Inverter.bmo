    'mn.icGD' = 'mn.cc.cGD' * (der('mn.G.v') - der('mn.Dinternal'));
    'mn.icGS' = 'mn.cc.cGS' * (der('mn.G.v') - der('mn.Sinternal'));
    'mn.ibsgmin' = 1e-12 * ('mn.B.v' - 'mn.Sinternal');
    'mn.ibdgmin' = 1e-12 * ('mn.B.v' - 'mn.Dinternal');
    'mn.G.i' = 'mn.icGB' + 'mn.icGD' + 'mn.icGS';
    'mn.B.i' = 'mn.cc.iBD' + 'mn.cc.iBS' + 'mn.ibdgmin' + 'mn.ibsgmin' - 'mn.icGB' + 'mn.icBD' + 'mn.icBS';
    'mn.D.i' = 'mn.ird';
    'mn.S.i' = 'mn.irs';
    0.0 = 'mn.cc.idrain' - 'mn.ird' - 'mn.cc.iBD' - 'mn.ibdgmin' - 'mn.icGD' - 'mn.icBD';
    0.0 = -('mn.irs' + 'mn.cc.idrain' + 'mn.cc.iBS' + 'mn.ibsgmin' + 'mn.icGS' + 'mn.icBS');
    'ground.p.v' = 0.0;

    when pre('vin.counter2') <> 0 and sample(4e-12, 2e-12) then
      'vin.T0' = time;
      'vin.counter2' = pre('vin.counter');
      'vin.counter' = pre('vin.counter') - (if pre('vin.counter') > 0 then 1 else 0);
    end when;

    'vin.v' = if (time < 4e-12 or 'vin.counter2' == 0) or time >= 'vin.T0' + 1.2e-12 then 0.0 else if time < 'vin.T0' + 1e-13 then (time - 'vin.T0') * 5.0 / 1e-13 else if time < 'vin.T0' + 1.1e-12 then 5.0 else ('vin.T0' + 1.2e-12 - time) * 5.0 / 9.999999999999998e-14;
    0.0 = 'vin.p.i' + 'vin.n.i';
    'vin.i' = 'vin.p.i';
    'vin.v' = 'vin.p.v' - 'vin.n.v';

    when pre('v.counter2') <> 0 and sample(0.0, 1e60) then
      'v.T0' = time;
      'v.counter2' = pre('v.counter');
      'v.counter' = pre('v.counter') - (if pre('v.counter') > 0 then 1 else 0);
    end when;

    'v.v' = if (time < 0.0 or 'v.counter2' == 0) or time >= 'v.T0' + 1e60 then 0.0 else if time < 'v.T0' + 1e-13 then (time - 'v.T0') * 5.0 / 1e-13 else if time < 'v.T0' + 1e60 then 5.0 else ('v.T0' + 1e60 - time) * 5.0 / 0.0;
    0.0 = 'v.p.i' + 'v.n.i';
    'v.i' = 'v.p.i';
    'v.v' = 'v.p.v' - 'v.n.v';
    annotation(experiment(StopTime = 1e-11, Interval = 5e-15, Tolerance = 1e-7));
  end 'Inverter';
end 'Inverter';
