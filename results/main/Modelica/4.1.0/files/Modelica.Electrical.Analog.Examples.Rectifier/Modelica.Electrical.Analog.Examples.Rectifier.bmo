    output Real 'iAC[1]'(unit = "A", quantity = "ElectricCurrent");
    output Real 'iAC[2]'(unit = "A", quantity = "ElectricCurrent");
    output Real 'iAC[3]'(unit = "A", quantity = "ElectricCurrent");
