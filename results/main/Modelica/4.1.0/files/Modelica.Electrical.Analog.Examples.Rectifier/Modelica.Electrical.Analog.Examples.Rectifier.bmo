//! base 0.1.0
package 'Rectifier'
  model 'Rectifier' "B6 diode bridge"
    parameter Real 'VAC'(unit = "V", quantity = "ElectricPotential") = 400.0 "RMS line-to-line";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Line frequency";
    parameter Real 'LAC'(unit = "H", quantity = "Inductance") = 6e-5 "Line inductor";
    parameter Real 'Ron'(unit = "Ohm", quantity = "Resistance") = 0.001 "Diode forward resistance";
    parameter Real 'Goff'(unit = "S", quantity = "Conductance") = 0.001 "Diode backward conductance";
    parameter Real 'Vknee'(unit = "V", quantity = "ElectricPotential") = 2.0 "Diode threshold voltage";
    parameter Real 'CDC'(min = 0.0, unit = "F", quantity = "Capacitance") = 0.015 "DC capacitance";
    parameter Real 'IDC'(unit = "A", quantity = "ElectricCurrent") = 500.0 "Load current";
