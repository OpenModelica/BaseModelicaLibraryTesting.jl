//! base 0.1.0
package 'TestCylinder'
  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  type 'Modelica.Blocks.Types.TimeEvents' = enumeration('Always', 'AtDiscontinuities', 'NoTimeEvents');

  class 'Modelica.Blocks.Types.ExternalCombiTimeTable'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table where first column is time"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Real 'startTime';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation';
      input Real 'shiftTime' = 0.0;
      input 'Modelica.Blocks.Types.TimeEvents' 'timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" 'externalCombiTimeTable' = ModelicaStandardTables_CombiTimeTable_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'startTime', 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'shiftTime', 'timeEvents', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table where first column is time"
      input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" ModelicaStandardTables_CombiTimeTable_close('externalCombiTimeTable') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTimeTable';

  model 'TestCylinder' "Two cylinder system"
    output Real 'f1'(unit = "N", quantity = "Force") "10 x Force on piston 1";
    output Real 's1'(unit = "m", quantity = "Length") "0.1 x Position of piston 1";
    output Real 's2'(unit = "m", quantity = "Length") "Position of piston 2";
    output Real 'f2'(unit = "N", quantity = "Force") "Force on piston 2";
    output Real 'f'(unit = "N", quantity = "Force") "Force of springDamper";
    parameter Integer 'combiTimeTable.nout'(min = 1) = 1 "Number of outputs";
    Real 'combiTimeTable.y[1]' "Connector of Real output signals";
    parameter Boolean 'combiTimeTable.tableOnFile' = false "= true, if table is defined on file or in function usertab";
    parameter Real 'combiTimeTable.table[1,1]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'combiTimeTable.table[1,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'combiTimeTable.table[2,1]' = 0.25 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'combiTimeTable.table[2,2]' = -1.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'combiTimeTable.table[3,1]' = 0.5 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'combiTimeTable.table[3,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'combiTimeTable.table[4,1]' = 0.75 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'combiTimeTable.table[4,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter String 'combiTimeTable.tableName' = "NoName" "Table name on file or in function usertab (see docu)";
    parameter String 'combiTimeTable.fileName' = "NoName" "File where matrix is stored";
    parameter String 'combiTimeTable.delimiter' = "," "Column delimiter character for CSV file";
    parameter Integer 'combiTimeTable.nHeaderLines' = 0 "Number of header lines to ignore for CSV file";
    parameter Boolean 'combiTimeTable.verboseRead' = true "= true, if info message that file is loading is to be printed";
    parameter Integer 'combiTimeTable.columns[1]' = 2 "Columns of table to be interpolated";
    parameter 'Modelica.Blocks.Types.Smoothness' 'combiTimeTable.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments' "Smoothness of table interpolation";
    parameter 'Modelica.Blocks.Types.Extrapolation' 'combiTimeTable.extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints' "Extrapolation of data outside the definition range";
    parameter Real 'combiTimeTable.timeScale'(min = 2.220446049250313e-16, unit = "s", quantity = "Time") = 1.0 "Time scale of first table column" annotation(Evaluate = true);
    parameter Real 'combiTimeTable.offset[1]' = 0.0 "Offsets of output signals";
    parameter Real 'combiTimeTable.startTime'(unit = "s", quantity = "Time") = 0.0 "Output = offset for time < startTime";
    parameter Real 'combiTimeTable.shiftTime'(unit = "s", quantity = "Time") = 0.0 "Shift time of first table column";
    parameter 'Modelica.Blocks.Types.TimeEvents' 'combiTimeTable.timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always' "Time event handling of table interpolation";
    parameter Boolean 'combiTimeTable.verboseExtrapolation' = false "= true, if warning messages are to be printed if time is outside the table definition range";
    parameter Real 'combiTimeTable.t_min'(unit = "s", quantity = "Time") = 'combiTimeTable.t_minScaled' "Minimum abscissa value defined in table";
    parameter Real 'combiTimeTable.t_max'(unit = "s", quantity = "Time") = 'combiTimeTable.t_maxScaled' "Maximum abscissa value defined in table";
    parameter Real 'combiTimeTable.t_minScaled' = 'Modelica.Blocks.Tables.Internal.getTimeTableTmin'('combiTimeTable.tableID') "Minimum (scaled) abscissa value defined in table";
    parameter Real 'combiTimeTable.t_maxScaled' = 'Modelica.Blocks.Tables.Internal.getTimeTableTmax'('combiTimeTable.tableID') "Maximum (scaled) abscissa value defined in table";
    parameter Real 'combiTimeTable.p_offset[1]' = 0.0 "Offsets of output signals";
    parameter 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'combiTimeTable.tableID' = 'Modelica.Blocks.Types.ExternalCombiTimeTable'("NoName", "NoName", {{0.0, 0.0}, {0.25, -1.0}, {0.5, 0.0}, {0.75, 0.0}}, 0.0, {2}, 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', 0.0, 'Modelica.Blocks.Types.TimeEvents'.'Always', false, ",", 0) "External table object";
    discrete Real 'combiTimeTable.nextTimeEvent'(fixed = true, start = 0.0, unit = "s", quantity = "Time") "Next time event instant";
    discrete Real 'combiTimeTable.nextTimeEventScaled'(fixed = true, start = 0.0) "Next scaled time event instant";
    Real 'combiTimeTable.timeScaled' "Scaled time";
    parameter Boolean 'combiTimeTable.isCsvExt' = false;
    parameter Boolean 'force.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'force.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'force.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'force.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'force.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'force.f'(unit = "N") "Driving force as input signal";
    parameter Real 'cylinder1.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'cylinder1.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'cylinder1.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'cylinder1.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'cylinder1.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    parameter Real 'cylinder1.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 313.15 "Initial temperature of medium";
    parameter Boolean 'cylinder1.T0fixed' = true "Initial temperature guess value or fixed";
    Real 'cylinder1.T_port'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'cylinder1.T'(nominal = 300.0, fixed = true, start = 313.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    parameter Real 'cylinder1.flowPort.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'cylinder1.flowPort.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'cylinder1.flowPort.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'cylinder1.flowPort.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'cylinder1.flowPort.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'cylinder1.flowPort.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'cylinder1.flowPort.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'cylinder1.flowPort.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'cylinder1.flowPort.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    constant Boolean 'cylinder1.Exchange' = true "Exchange of medium via flowport";
    Real 'cylinder1.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy in the volume";
    parameter Real 'cylinder1.A'(unit = "m2", quantity = "Area") = 0.1 "Cross section of cylinder/piston";
    parameter Real 'cylinder1.L'(unit = "m", quantity = "Length") = 10.0 "Length of cylinder";
    parameter Boolean 'cylinder1.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'cylinder1.s'(fixed = true, start = 5.0, unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'cylinder1.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'cylinder1.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'cylinder1.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'cylinder1.f'(unit = "N", quantity = "Force") "Force at piston";
    Real 'cylinder1.m'(min = 0.0, unit = "kg", quantity = "Mass") "Mass of medium";
    Real 'cylinder1.H'(unit = "J", quantity = "Energy") "Enthalpy of medium";
    parameter Real 'cylinder2.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'cylinder2.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'cylinder2.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'cylinder2.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'cylinder2.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    parameter Real 'cylinder2.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 313.15 "Initial temperature of medium";
    parameter Boolean 'cylinder2.T0fixed' = true "Initial temperature guess value or fixed";
    Real 'cylinder2.T_port'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'cylinder2.T'(nominal = 300.0, fixed = true, start = 313.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    parameter Real 'cylinder2.flowPort.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'cylinder2.flowPort.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'cylinder2.flowPort.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'cylinder2.flowPort.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'cylinder2.flowPort.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'cylinder2.flowPort.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'cylinder2.flowPort.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'cylinder2.flowPort.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'cylinder2.flowPort.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    constant Boolean 'cylinder2.Exchange' = true "Exchange of medium via flowport";
    Real 'cylinder2.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy in the volume";
    parameter Real 'cylinder2.A'(unit = "m2", quantity = "Area") = 1.0 "Cross section of cylinder/piston";
    parameter Real 'cylinder2.L'(unit = "m", quantity = "Length") = 1.0 "Length of cylinder";
    parameter Boolean 'cylinder2.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'cylinder2.s'(start = 2.2250738585072014e-308, unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'cylinder2.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'cylinder2.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'cylinder2.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'cylinder2.f'(unit = "N", quantity = "Force") "Force at piston";
    Real 'cylinder2.m'(min = 0.0, unit = "kg", quantity = "Mass") "Mass of medium";
    Real 'cylinder2.H'(unit = "J", quantity = "Energy") "Enthalpy of medium";
    parameter Real 'mass.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass of the sliding mass";
    parameter StateSelect 'mass.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'mass.s'(stateSelect = StateSelect.default, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'mass.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'mass.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass.v'(stateSelect = StateSelect.default, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter StateSelect 'springDamper.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'springDamper.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'springDamper.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, fixed = true, start = 0.5, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'springDamper.v_rel'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'springDamper.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'springDamper.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'springDamper.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'springDamper.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'springDamper.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'springDamper.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 100.0 "Spring constant";
    parameter Real 'springDamper.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 10.0 "Damping constant";
    parameter Real 'springDamper.s_rel0'(unit = "m", quantity = "Length") = 0.5 "Unstretched spring length";
    parameter Boolean 'springDamper.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'springDamper.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'springDamper.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'springDamper.f_d'(unit = "N", quantity = "Force") "Damping force";
    parameter Real 'fixed.s0'(unit = "m", quantity = "Length") = 0.0 "Fixed offset position of housing";
    Real 'fixed.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'fixed.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
  equation
    'f1' = -10.0 * 'cylinder1.f';
    's1' = 0.1 * 'cylinder1.s';
    's2' = 'cylinder2.s';
    'f2' = -'cylinder2.f';
    'f' = 'springDamper.f';
    'cylinder1.f' = 'cylinder1.flange.f';
    'cylinder2.f' = 'cylinder2.flange.f';
    'cylinder1.flowPort.h' = 'cylinder2.flowPort.h';
    assert(abs('cylinder1.flowPort.medium.rho' - 'cylinder2.flowPort.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('cylinder1.flowPort.medium.cp' - 'cylinder2.flowPort.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('cylinder1.flowPort.medium.cv' - 'cylinder2.flowPort.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('cylinder1.flowPort.medium.lambda' - 'cylinder2.flowPort.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('cylinder1.flowPort.medium.nu' - 'cylinder2.flowPort.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'cylinder1.flowPort.p' = 'cylinder2.flowPort.p';
    'force.flange.s' = 'cylinder1.flange.s';
    'combiTimeTable.y[1]' = 'force.f';
    'cylinder2.flange.s' = 'mass.flange_a.s';
    'springDamper.flange_b.s' = 'mass.flange_b.s';
    'springDamper.flange_a.s' = 'fixed.flange.s';
    'cylinder1.flange.f' + 'force.flange.f' = 0.0;
    'cylinder2.flowPort.m_flow' + 'cylinder1.flowPort.m_flow' = 0.0;
    'cylinder2.flowPort.H_flow' + 'cylinder1.flowPort.H_flow' = 0.0;
    'mass.flange_a.f' + 'cylinder2.flange.f' = 0.0;
    'fixed.flange.f' + 'springDamper.flange_a.f' = 0.0;
    'springDamper.flange_b.f' + 'mass.flange_b.f' = 0.0;
    'combiTimeTable.timeScaled' = time;

    when {time >= pre('combiTimeTable.nextTimeEvent'), initial()} then
      'combiTimeTable.nextTimeEventScaled' = 'Modelica.Blocks.Tables.Internal.getNextTimeEvent'('combiTimeTable.tableID', 'combiTimeTable.timeScaled');
      'combiTimeTable.nextTimeEvent' = if 'combiTimeTable.nextTimeEventScaled' < 1e60 then 'combiTimeTable.nextTimeEventScaled' else 1e60;
    end when;

    'combiTimeTable.y[1]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer'('combiTimeTable.tableID', 1, 'combiTimeTable.timeScaled', 'combiTimeTable.nextTimeEventScaled', pre('combiTimeTable.nextTimeEventScaled'));
    'force.flange.f' = -'force.f';
    'force.s' = 'force.flange.s' - 'force.s_support';
    'force.s_support' = 0.0;
    assert('cylinder1.s' >= 2.2250738585072014e-308, "TestCylinder.cylinder1" + ": Piston hit bottom of cylinder!", AssertionLevel.error);
    assert('cylinder1.s' <= 10.0, "TestCylinder.cylinder1" + ":Piston hit top of cylinder!", AssertionLevel.error);
    'cylinder1.flowPort.p' * 0.1 = -'cylinder1.f';
    'cylinder1.m' = 'cylinder1.medium.rho' * 0.1 * 'cylinder1.s';
    der('cylinder1.m') = 'cylinder1.flowPort.m_flow';
    'cylinder1.H' = 'cylinder1.m' * 'cylinder1.h';
    der('cylinder1.H') = 'cylinder1.flowPort.H_flow';
    'cylinder1.s' = 'cylinder1.flange.s' - 'cylinder1.s_support';
    'cylinder1.s_support' = 0.0;
    'cylinder1.T_port' = 'cylinder1.flowPort.h' / 'cylinder1.medium.cp';
    'cylinder1.T' = 'cylinder1.h' / 'cylinder1.medium.cp';
    'cylinder1.flowPort.H_flow' = semiLinear('cylinder1.flowPort.m_flow', 'cylinder1.flowPort.h', 'cylinder1.h');
    assert('cylinder2.s' >= 2.2250738585072014e-308, "TestCylinder.cylinder2" + ": Piston hit bottom of cylinder!", AssertionLevel.error);
    assert('cylinder2.s' <= 1.0, "TestCylinder.cylinder2" + ":Piston hit top of cylinder!", AssertionLevel.error);
    'cylinder2.flowPort.p' = -'cylinder2.f';
    'cylinder2.m' = 'cylinder2.medium.rho' * 'cylinder2.s';
    der('cylinder2.m') = 'cylinder2.flowPort.m_flow';
    'cylinder2.H' = 'cylinder2.m' * 'cylinder2.h';
    der('cylinder2.H') = 'cylinder2.flowPort.H_flow';
    'cylinder2.s' = 'cylinder2.flange.s' - 'cylinder2.s_support';
    'cylinder2.s_support' = 0.0;
    'cylinder2.T_port' = 'cylinder2.flowPort.h' / 'cylinder2.medium.cp';
    'cylinder2.T' = 'cylinder2.h' / 'cylinder2.medium.cp';
    'cylinder2.flowPort.H_flow' = semiLinear('cylinder2.flowPort.m_flow', 'cylinder2.flowPort.h', 'cylinder2.h');
    'mass.v' = der('mass.s');
    'mass.a' = der('mass.v');
    'mass.a' = 'mass.flange_a.f' + 'mass.flange_b.f';
    'mass.flange_a.s' = 'mass.s';
    'mass.flange_b.s' = 'mass.s';
    'springDamper.f_c' = 100.0 * ('springDamper.s_rel' - 0.5);
    'springDamper.f_d' = 10.0 * 'springDamper.v_rel';
    'springDamper.f' = 'springDamper.f_c' + 'springDamper.f_d';
    'springDamper.lossPower' = 'springDamper.f_d' * 'springDamper.v_rel';
    'springDamper.s_rel' = 'springDamper.flange_b.s' - 'springDamper.flange_a.s';
    'springDamper.v_rel' = der('springDamper.s_rel');
    'springDamper.flange_b.f' = 'springDamper.f';
    'springDamper.flange_a.f' = -'springDamper.f';
    'fixed.flange.s' = 0.0;
    annotation(experiment(StopTime = 2, Interval = 0.001));
  end 'TestCylinder';
end 'TestCylinder';
