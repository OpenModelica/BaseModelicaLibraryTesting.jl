  initial equation
    'fi[1]' = 0.0;
    'fi[2]' = 0.2;
    'fi[3]' = 0.4;
    'fi[4]' = 0.6000000000000001;
    'fi[5]' = 0.8;
    'fi[6]' = 1.0;
    'fi[7]' = 1.2000000000000002;
    'fi[8]' = 1.4000000000000001;
    'fi[9]' = 1.6;
    'fi[10]' = 1.8;
    'fi[11]' = 2.0;
    'fi[12]' = 2.2;
    'fi[13]' = 2.4000000000000004;
    'fi[14]' = 2.6;
    'fi[15]' = 2.8000000000000003;
    'fi[16]' = 3.0;
    'fi[17]' = 3.2;
    'fi[18]' = 3.4000000000000004;
    'fi[19]' = 3.6;
    'fi[20]' = 3.8000000000000003;
    'fi[21]' = 4.0;
  algorithm
    when sample(0.0, 0.025) then
      'iTick' := pre('iTick') + 1;
      'y' := 5.0 + 3.0 * sin(12.566370614359172 * time) + 1.5 * cos(18.84955592153876 * time);

      if 'iTick' >= 1 and 'iTick' <= 200 then
        'y_buf['iTick']' := 'y';
      end if;

      if 'iTick' == 200 then
        ('info', 'Ai', 'Phii') := 'Modelica.Math.FastFourierTransform.realFFT'('y_buf', 21);
        'Modelica.Math.FastFourierTransform.realFFTwriteToFile'(time, "RealFFT1_resultFFT.mat", 4.0, 'Ai', 'Phii', "4");
      end if;
    end when;
    annotation(experiment(StopTime = 6));
  end 'RealFFT1';
end 'RealFFT1';
