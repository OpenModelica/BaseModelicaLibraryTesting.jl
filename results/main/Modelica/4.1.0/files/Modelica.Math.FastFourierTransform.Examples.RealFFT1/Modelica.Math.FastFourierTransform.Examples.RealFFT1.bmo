//! base 0.1.0
package 'RealFFT1'
  model 'RealFFT1' "Example demonstrating the use of an FFT calculation during simulation (and storing both amplitudes and phases on file)"
    parameter Real 'f_max'(unit = "Hz", quantity = "Frequency") = 4.0 "Maximum frequency of interest";
    parameter Real 'f_resolution'(unit = "Hz", quantity = "Frequency") = 0.2 "Frequency resolution";
    parameter Real 'f1'(unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of sine";
    parameter Real 'f2'(unit = "Hz", quantity = "Frequency") = 3.0 "Frequency of cosine";
    parameter String 'FFT_resultFileName' = "RealFFT1_resultFFT.mat" "File where FFT will be stored as [f,A,Phi], with f in [Hz] and A the amplitudes and Phi the phases in [rad]";
    parameter Integer 'nfi' = 21 "Number of frequency points of the interested frequency range (only up to f_max)";
    parameter Real 'fi[1]'(fixed = false, unit = "Hz", quantity = "Frequency") "FFT frequencies of interested frequency points";
    parameter Real 'fi[2]'(fixed = false, unit = "Hz", quantity = "Frequency") "FFT frequencies of interested frequency points";
    parameter Real 'fi[3]'(fixed = false, unit = "Hz", quantity = "Frequency") "FFT frequencies of interested frequency points";
