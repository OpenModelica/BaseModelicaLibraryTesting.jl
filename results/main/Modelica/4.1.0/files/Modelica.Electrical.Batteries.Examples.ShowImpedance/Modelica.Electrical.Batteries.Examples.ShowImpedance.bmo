    parameter Real 'cellData.OCV_SOC_internal[27,1]' = 0.9 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[27,2]' = 0.964 "OCV/OCVmax versus SOC used internal";
