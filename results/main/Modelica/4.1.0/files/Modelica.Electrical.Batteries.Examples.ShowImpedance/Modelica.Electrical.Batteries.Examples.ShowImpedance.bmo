    parameter Real 'cellData.OCV_SOC_internal[21,2]' = 0.855 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[22,1]' = 0.65 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[22,2]' = 0.871 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[23,1]' = 0.7 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[23,2]' = 0.888 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[24,1]' = 0.75 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[24,2]' = 0.905 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[25,1]' = 0.8 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[25,2]' = 0.926 "OCV/OCVmax versus SOC used internal";
