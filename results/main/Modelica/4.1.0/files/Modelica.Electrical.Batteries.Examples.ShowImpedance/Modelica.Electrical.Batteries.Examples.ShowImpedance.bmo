    parameter Real 'cellData.OCV_SOC_internal[29,1]' = 1.0 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.OCV_SOC_internal[29,2]' = 1.0 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData.Ri'(unit = "Ohm", quantity = "Resistance") = 0.01 "Total inner resistance (= OCVmax/Isc)";
    parameter Real 'cellData.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'cellData.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance at T_ref";
    parameter Real 'cellData.Idis'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Self-discharge current at SOC = SOCmax" annotation(Evaluate = true);
    parameter Real 'cellData.R0'(unit = "Ohm", quantity = "Resistance") = 0.007 "Inner resistance without parallel C";
    parameter Integer 'cellData.nRC' = 2 "Number of RC-elements" annotation(Evaluate = true);
    constant String 'cellData.rcData[1].CellType' = "RC elements" "Indicates cell type";
    parameter Real 'cellData.rcData[1].R'(unit = "Ohm", quantity = "Resistance") = 0.002 "Resistance of RC-element";
    parameter Real 'cellData.rcData[1].T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'cellData.rcData[1].alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance at T_ref";
    parameter Real 'cellData.rcData[1].C'(min = 0.0, unit = "F", quantity = "Capacitance") = 3e4 "Capacitance of RC-element (=T/R)";
    constant String 'cellData.rcData[2].CellType' = "RC elements" "Indicates cell type";
    parameter Real 'cellData.rcData[2].R'(unit = "Ohm", quantity = "Resistance") = 0.001 "Resistance of RC-element";
    parameter Real 'cellData.rcData[2].T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'cellData.rcData[2].alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance at T_ref";
    parameter Real 'cellData.rcData[2].C'(min = 0.0, unit = "F", quantity = "Capacitance") = 1e4 "Capacitance of RC-element (=T/R)";
  equation
    'logSweep.y' = 'impedance.f';
    'logSweep.y' = if time < 0.0 then 1e-6 else if time < 1.0 then 1e-6 * 1e9 ^ min(1.0, time) else 1000.0;
    'impedance.z.re' = 'impedance.cellData.R0' + sum((({'Complex'((1.0 * (1.0 / 'impedance.cellData.rcData[\'k\'].R') + 0.0 * (6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C')) / (1.0 / 'impedance.cellData.rcData[\'k\'].R' * (1.0 / 'impedance.cellData.rcData[\'k\'].R') + 6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C' * (6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C')), (0.0 * (1.0 / 'impedance.cellData.rcData[\'k\'].R') - 1.0 * (6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C')) / (1.0 / 'impedance.cellData.rcData[\'k\'].R' * (1.0 / 'impedance.cellData.rcData[\'k\'].R') + 6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C' * (6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C'))) for 'k' in 1:2}).re)[:]);
    'impedance.z.im' = 0.0 + sum((({'Complex'((1.0 * (1.0 / 'impedance.cellData.rcData[\'k\'].R') + 0.0 * (6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C')) / (1.0 / 'impedance.cellData.rcData[\'k\'].R' * (1.0 / 'impedance.cellData.rcData[\'k\'].R') + 6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C' * (6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C')), (0.0 * (1.0 / 'impedance.cellData.rcData[\'k\'].R') - 1.0 * (6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C')) / (1.0 / 'impedance.cellData.rcData[\'k\'].R' * (1.0 / 'impedance.cellData.rcData[\'k\'].R') + 6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C' * (6.283185307179586 * 'impedance.f' * 'impedance.cellData.rcData[\'k\'].C'))) for 'k' in 1:2}).im)[:]);
    annotation(experiment(Interval = 0.0001, StopTime = 1));
  end 'ShowImpedance';
end 'ShowImpedance';
