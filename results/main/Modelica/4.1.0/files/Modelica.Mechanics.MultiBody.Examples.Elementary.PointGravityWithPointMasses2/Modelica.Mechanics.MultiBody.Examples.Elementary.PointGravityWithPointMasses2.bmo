    Real 'pointMass1.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'pointMass1.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'pointMass1.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'pointMass1.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
