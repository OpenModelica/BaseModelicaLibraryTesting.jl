    Real 'pointMass1.v_0[2]'(stateSelect = StateSelect.avoid, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
    Real 'pointMass1.v_0[3]'(stateSelect = StateSelect.avoid, fixed = true, start = -1.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
