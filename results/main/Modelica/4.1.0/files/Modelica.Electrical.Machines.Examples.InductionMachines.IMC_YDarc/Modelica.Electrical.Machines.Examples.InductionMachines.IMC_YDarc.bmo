    Real 'resistor.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'resistor.R[1]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1e-4 "Resistances R_ref at temperatures T_ref";
    parameter Real 'resistor.R[2]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1e-4 "Resistances R_ref at temperatures T_ref";
    parameter Real 'resistor.R[3]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1e-4 "Resistances R_ref at temperatures T_ref";
    parameter Real 'resistor.T_ref[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperatures";
    parameter Real 'resistor.T_ref[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperatures";
    parameter Real 'resistor.T_ref[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperatures";
    parameter Real 'resistor.alpha[1]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Real 'resistor.alpha[2]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Real 'resistor.alpha[3]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Integer 'resistor.mh'(min = 1) = 3 "Number of heatPorts=number of phases";
    parameter Boolean 'resistor.useHeatPort' = false "= true, if all heat ports are enabled" annotation(Evaluate = true);
    parameter Real 'resistor.T[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'resistor.T[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'resistor.T[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'resistor.resistor[1].R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1e-4 "Resistance at temperature T_ref";
    parameter Real 'resistor.resistor[1].T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor.resistor[1].alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor.resistor[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor.resistor[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor.resistor[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
