    Real 'inductor.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'inductor.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'inductor.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'inductor.L[1]'(start = 1.0, unit = "H", quantity = "Inductance") = 3.183098861837907e-7 "Inductance";
    parameter Real 'inductor.L[2]'(start = 1.0, unit = "H", quantity = "Inductance") = 3.183098861837907e-7 "Inductance";
    parameter Real 'inductor.L[3]'(start = 1.0, unit = "H", quantity = "Inductance") = 3.183098861837907e-7 "Inductance";
    Real 'inductor.inductor[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inductor.inductor[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.inductor[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.inductor[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.inductor[1].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.inductor[1].i'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inductor.inductor[1].L'(start = 1.0, unit = "H", quantity = "Inductance") = 3.183098861837907e-7 "Inductance";
    Real 'inductor.inductor[2].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inductor.inductor[2].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.inductor[2].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
