    Real 'inductor.inductor[3].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.inductor[3].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.inductor[3].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.inductor[3].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.inductor[3].i'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inductor.inductor[3].L'(start = 1.0, unit = "H", quantity = "Inductance") = 3.183098861837907e-7 "Inductance";
  initial equation
    'switchYDwithArc.logicalDelay[1].tSwitch' = time - 0.04;
    'switchYDwithArc.logicalDelay[2].tSwitch' = time - 0.04;
    'switchYDwithArc.logicalDelay[3].tSwitch' = time - 0.04;
    'inductor.i[1]' = 0.0;
    'inductor.i[2]' = 0.0;
    'aimc.is[1]' = 0.0;
    'aimc.is[2]' = 0.0;
    'aimc.is[3]' = 0.0;
    'aimc.ir[1]' = 0.0;
    'aimc.ir[2]' = 0.0;
  equation
    'aimc.phiMechanical' = 'aimc.flange.phi' - 'aimc.internalSupport.phi';
    'aimc.wMechanical' = der('aimc.phiMechanical');
    'aimc.tauElectrical' = 'aimc.inertiaRotor.flange_a.tau';
    'aimc.tauShaft' = -'aimc.flange.tau';
    'aimc.friction.heatPort.Q_flow' = -'aimc.friction.lossPower';
    'aimc.powerBalance.powerStator' = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'('aimc.vs', 'aimc.is');
    'aimc.powerBalance.powerMechanical' = 'aimc.wMechanical' * 'aimc.tauShaft';
    'aimc.powerBalance.powerInertiaStator' = 0.29 * 'aimc.inertiaStator.a' * 'aimc.inertiaStator.w';
    'aimc.powerBalance.powerInertiaRotor' = 0.29 * 'aimc.inertiaRotor.a' * 'aimc.inertiaRotor.w';
    'aimc.powerBalance.lossPowerTotal' = 'aimc.powerBalance.lossPowerStatorWinding' + 'aimc.powerBalance.lossPowerStatorCore' + 'aimc.powerBalance.lossPowerRotorCore' + 'aimc.powerBalance.lossPowerStrayLoad' + 'aimc.powerBalance.lossPowerFriction' + 'aimc.powerBalance.lossPowerRotorWinding';
    'aimc.powerBalance.lossPowerStatorWinding' = 'aimc.rs.resistor[1].LossPower' + 'aimc.rs.resistor[2].LossPower' + 'aimc.rs.resistor[3].LossPower';
    'aimc.powerBalance.lossPowerStatorCore' = 'aimc.statorCore.lossPower';
    'aimc.powerBalance.lossPowerRotorCore' = 0.0;
    'aimc.powerBalance.lossPowerStrayLoad' = 'aimc.strayLoad.lossPower';
    'aimc.powerBalance.lossPowerFriction' = 'aimc.friction.lossPower';
    'aimc.powerBalance.lossPowerRotorWinding' = 'aimc.squirrelCageR.LossPower';
    'aimc.i_0_s' = 'aimc.spacePhasorS.zero.i';
    'aimc.rs.resistor[1].heatPort.T' = 'aimc.rs.resistor[1].T_heatPort';
    'aimc.rs.resistor[1].heatPort.Q_flow' = -'aimc.rs.resistor[1].LossPower';
    'aimc.rs.resistor[2].heatPort.T' = 'aimc.rs.resistor[2].T_heatPort';
    'aimc.rs.resistor[2].heatPort.Q_flow' = -'aimc.rs.resistor[2].LossPower';
    'aimc.rs.resistor[3].heatPort.T' = 'aimc.rs.resistor[3].T_heatPort';
    'aimc.rs.resistor[3].heatPort.Q_flow' = -'aimc.rs.resistor[3].LossPower';
    'aimc.statorCore.heatPort.Q_flow' = -'aimc.statorCore.lossPower';
    'aimc.statorCore.w' = 'aimc.statorCoreParameters.wRef';
    'aimc.statorCore.wLimit' = noEvent(max(noEvent(abs('aimc.statorCore.w')), 'aimc.statorCore.coreParameters.wMin'));
    'aimc.strayLoad.heatPort.Q_flow' = -'aimc.strayLoad.lossPower';
    'aimc.strayLoad.iRMS' = sqrt(sum('aimc.strayLoad.i' .^ 2.0 / size('aimc.strayLoad.i', 1)));
    'aimc.thermalAmbient.Q_flowStatorWinding' = 'aimc.thermalAmbient.temperatureStatorWinding.port.Q_flow';
    'aimc.thermalAmbient.Q_flowStatorCore' = 'aimc.thermalAmbient.temperatureStatorCore.port.Q_flow';
    'aimc.thermalAmbient.Q_flowRotorCore' = 'aimc.thermalAmbient.temperatureRotorCore.port.Q_flow';
    'aimc.thermalAmbient.Q_flowStrayLoad' = 'aimc.thermalAmbient.temperatureStrayLoad.port.Q_flow';
    'aimc.thermalAmbient.Q_flowFriction' = 'aimc.thermalAmbient.temperatureFriction.port.Q_flow';
    'aimc.thermalAmbient.Q_flowRotorWinding' = 'aimc.thermalAmbient.temperatureRotorWinding.port.Q_flow';
    'aimc.thermalAmbient.Q_flowTotal' = 'aimc.thermalAmbient.Q_flowStatorWinding' + 'aimc.thermalAmbient.Q_flowRotorWinding' + 'aimc.thermalAmbient.Q_flowStatorCore' + 'aimc.thermalAmbient.Q_flowRotorCore' + 'aimc.thermalAmbient.Q_flowStrayLoad' + 'aimc.thermalAmbient.Q_flowFriction';
    'aimc.squirrelCageR.heatPort.T' = 'aimc.squirrelCageR.T_heatPort';
    'aimc.squirrelCageR.heatPort.Q_flow' = -'aimc.squirrelCageR.LossPower';
    'aimc.rs.resistor[1].p.v' = 'aimc.rs.plug_p.pin[1].v';
    'aimc.rs.resistor[2].p.v' = 'aimc.rs.plug_p.pin[2].v';
    'aimc.rs.resistor[3].p.v' = 'aimc.rs.plug_p.pin[3].v';
    'aimc.rs.resistor[1].n.v' = 'aimc.rs.plug_n.pin[1].v';
