    Real 'inductor.inductor[2].i'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inductor.inductor[2].L'(start = 1.0, unit = "H", quantity = "Inductance") = 3.183098861837907e-7 "Inductance";
