  model 'LinearInductor' "Linear inductor with ferromagnetic core"
    output Real 'deviation'(unit = "A", quantity = "ElectricCurrent") = 'feedback.y' "Deviation of transient and quasi-static current";
    Real 'ground_mQS.port.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'ground_mQS.port.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'ground_mQS.port.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'ground_mQS.port.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'ground_mQS.port.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'sourceQS.omega'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of reference frame";
    Real 'sourceQS.pin_p.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'sourceQS.pin_p.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'sourceQS.pin_p.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'sourceQS.pin_p.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'sourceQS.pin_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'sourceQS.pin_n.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'sourceQS.pin_n.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'sourceQS.pin_n.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'sourceQS.pin_n.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'sourceQS.pin_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'sourceQS.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'sourceQS.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'sourceQS.abs_v'(unit = "V", quantity = "ElectricPotential") = sqrt('sourceQS.v.re' ^ 2.0 + 'sourceQS.v.im' ^ 2.0) "Magnitude of complex voltage";
    Real 'sourceQS.arg_v'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('sourceQS.v.im', 'sourceQS.v.re', 0.0) "Argument of complex voltage";
    Real 'sourceQS.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'sourceQS.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'sourceQS.abs_i'(unit = "A", quantity = "ElectricCurrent") = sqrt('sourceQS.i.re' ^ 2.0 + 'sourceQS.i.im' ^ 2.0) "Magnitude of complex current";
    Real 'sourceQS.arg_i'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('sourceQS.i.im', 'sourceQS.i.re', 0.0) "Argument of complex current";
    Real 'sourceQS.P'(unit = "W", quantity = "Power") = 'sourceQS.v.re' * 'sourceQS.i.re' - 'sourceQS.v.im' * (-'sourceQS.i.im') "Active power";
    Real 'sourceQS.Q'(unit = "var", quantity = "Power") = 'sourceQS.v.re' * (-'sourceQS.i.im') + 'sourceQS.v.im' * 'sourceQS.i.re' "Reactive power";
    Real 'sourceQS.S'(unit = "V.A", quantity = "Power") = sqrt(('sourceQS.v.re' * 'sourceQS.i.re' - 'sourceQS.v.im' * (-'sourceQS.i.im')) ^ 2.0 + ('sourceQS.v.re' * (-'sourceQS.i.im') + 'sourceQS.v.im' * 'sourceQS.i.re') ^ 2.0) "Magnitude of complex apparent power";
    Real 'sourceQS.pf' = cos('Modelica.Math.atan3'('sourceQS.Q', 'sourceQS.P', 0.0)) "Power factor";
    Real 'sourceQS.gamma'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 'sourceQS.pin_p.reference.gamma';
    parameter Real 'sourceQS.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of the source";
    parameter Real 'sourceQS.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 230.0 "RMS voltage of the source";
    parameter Real 'sourceQS.phi'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267949 "Phase shift of the source";
    Real 'rQS.omega'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of reference frame";
    Real 'rQS.pin_p.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'rQS.pin_p.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'rQS.pin_p.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'rQS.pin_p.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'rQS.pin_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'rQS.pin_n.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'rQS.pin_n.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'rQS.pin_n.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'rQS.pin_n.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'rQS.pin_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'rQS.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'rQS.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'rQS.abs_v'(unit = "V", quantity = "ElectricPotential") = sqrt('rQS.v.re' ^ 2.0 + 'rQS.v.im' ^ 2.0) "Magnitude of complex voltage";
    Real 'rQS.arg_v'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('rQS.v.im', 'rQS.v.re', 0.0) "Argument of complex voltage";
    Real 'rQS.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'rQS.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'rQS.abs_i'(unit = "A", quantity = "ElectricCurrent") = sqrt('rQS.i.re' ^ 2.0 + 'rQS.i.im' ^ 2.0) "Magnitude of complex current";
    Real 'rQS.arg_i'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('rQS.i.im', 'rQS.i.re', 0.0) "Argument of complex current";
    Real 'rQS.P'(unit = "W", quantity = "Power") = 'rQS.v.re' * 'rQS.i.re' - 'rQS.v.im' * (-'rQS.i.im') "Active power";
    Real 'rQS.Q'(unit = "var", quantity = "Power") = 'rQS.v.re' * (-'rQS.i.im') + 'rQS.v.im' * 'rQS.i.re' "Reactive power";
    Real 'rQS.S'(unit = "V.A", quantity = "Power") = sqrt(('rQS.v.re' * 'rQS.i.re' - 'rQS.v.im' * (-'rQS.i.im')) ^ 2.0 + ('rQS.v.re' * (-'rQS.i.im') + 'rQS.v.im' * 'rQS.i.re') ^ 2.0) "Magnitude of complex apparent power";
    Real 'rQS.pf' = cos('Modelica.Math.atan3'('rQS.Q', 'rQS.P', 0.0)) "Power factor";
    parameter Real 'rQS.R_ref'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 7.5 "Reference resistance at T_ref";
    parameter Real 'rQS.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'rQS.alpha_ref'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R_ref*(1 + alpha_ref*(heatPort.T - T_ref))";
    parameter Boolean 'rQS.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'rQS.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'rQS.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'rQS.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'rQS.R_actual'(unit = "Ohm", quantity = "Resistance") "Resistance = R_ref*(1 + alpha_ref*(heatPort.T - T_ref))";
    constant Real 'coilQS.j.re' = 0.0 "Real part of complex number";
    constant Real 'coilQS.j.im' = 1.0 "Imaginary part of complex number";
    Real 'coilQS.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'coilQS.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'coilQS.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'coilQS.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'coilQS.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'coilQS.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'coilQS.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'coilQS.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'coilQS.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'coilQS.port_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'coilQS.pin_p.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'coilQS.pin_p.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'coilQS.pin_p.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'coilQS.pin_p.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'coilQS.pin_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'coilQS.pin_n.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'coilQS.pin_n.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'coilQS.pin_n.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'coilQS.pin_n.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'coilQS.pin_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'coilQS.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'coilQS.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'coilQS.i.re'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'coilQS.i.im'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'coilQS.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'coilQS.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'coilQS.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'coilQS.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'coilQS.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'coilQS.N' = 600.0 "Number of turns";
    Real 'coilQS.Psi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'coilQS.Psi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'coilQS.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i) for information only";
    Real 'coilQS.eps' = 2.220446049250313e-14;
    Real 'r_mLeakQS.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'r_mLeakQS.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'r_mLeakQS.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'r_mLeakQS.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'r_mLeakQS.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'r_mLeakQS.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'r_mLeakQS.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'r_mLeakQS.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'r_mLeakQS.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'r_mLeakQS.port_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'r_mLeakQS.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'r_mLeakQS.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'r_mLeakQS.abs_V_m'(unit = "A", quantity = "MagneticPotential") = sqrt('r_mLeakQS.V_m.re' ^ 2.0 + 'r_mLeakQS.V_m.im' ^ 2.0) "Magnitude of complex magnetic potential difference";
    Real 'r_mLeakQS.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('r_mLeakQS.V_m.im', 'r_mLeakQS.V_m.re', 0.0) "Argument of complex magnetic potential difference";
    Real 'r_mLeakQS.Phi.re'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'r_mLeakQS.Phi.im'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'r_mLeakQS.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") = sqrt('r_mLeakQS.Phi.re' ^ 2.0 + 'r_mLeakQS.Phi.im' ^ 2.0) "Magnitude of complex magnetic flux";
    Real 'r_mLeakQS.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('r_mLeakQS.Phi.im', 'r_mLeakQS.Phi.re', 0.0) "Argument of complex magnetic flux";
    Real 'r_mLeakQS.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'r_mLeakQS.R_m'(unit = "H-1", quantity = "Reluctance") = 1.2e6 "Magnetic reluctance";
    Real 'r_mAirParQS.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'r_mAirParQS.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'r_mAirParQS.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'r_mAirParQS.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'r_mAirParQS.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'r_mAirParQS.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'r_mAirParQS.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'r_mAirParQS.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'r_mAirParQS.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'r_mAirParQS.port_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'r_mAirParQS.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'r_mAirParQS.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'r_mAirParQS.abs_V_m'(unit = "A", quantity = "MagneticPotential") = sqrt('r_mAirParQS.V_m.re' ^ 2.0 + 'r_mAirParQS.V_m.im' ^ 2.0) "Magnitude of complex magnetic potential difference";
    Real 'r_mAirParQS.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('r_mAirParQS.V_m.im', 'r_mAirParQS.V_m.re', 0.0) "Argument of complex magnetic potential difference";
    Real 'r_mAirParQS.Phi.re'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'r_mAirParQS.Phi.im'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'r_mAirParQS.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") = sqrt('r_mAirParQS.Phi.re' ^ 2.0 + 'r_mAirParQS.Phi.im' ^ 2.0) "Magnitude of complex magnetic flux";
    Real 'r_mAirParQS.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('r_mAirParQS.Phi.im', 'r_mAirParQS.Phi.re', 0.0) "Argument of complex magnetic flux";
    Real 'r_mAirParQS.omega'(unit = "rad/s", quantity = "AngularVelocity");
    parameter Real 'r_mAirParQS.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability";
    Real 'r_mAirParQS.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'r_mAirParQS.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'r_mAirParQS.B.re'(unit = "T", quantity = "MagneticFluxDensity") "Real part of complex number";
    Real 'r_mAirParQS.B.im'(unit = "T", quantity = "MagneticFluxDensity") "Imaginary part of complex number";
    Real 'r_mAirParQS.abs_B'(unit = "T", quantity = "MagneticFluxDensity") = sqrt('r_mAirParQS.B.re' ^ 2.0 + 'r_mAirParQS.B.im' ^ 2.0) "Magnitude of complex magnetic flux density";
    Real 'r_mAirParQS.arg_B'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('r_mAirParQS.B.im', 'r_mAirParQS.B.re', 0.0) "Argument of complex magnetic flux density";
    Real 'r_mAirParQS.A'(unit = "m2", quantity = "Area") "Area of cross section penetrated by magnetic flux";
