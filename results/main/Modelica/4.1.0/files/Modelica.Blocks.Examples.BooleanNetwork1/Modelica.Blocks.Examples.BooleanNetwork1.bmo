    'nand1.y' = 'or2.u[1]';
    'or2.y' = 'nor1.u';
    'nor1.y' = 'showValue4.activePort';
    'rising.y' = 'set1.u[1]';
    'falling.y' = 'set1.u[2]';
    'booleanTable.y' = 'onDelay.u';
    'integerConstant.y' = 'triggeredAdd.u';
    'changing.y' = 'triggeredAdd.trigger';
    'triggeredAdd.y' = 'showValue1.numberPort';
    'set1.y' = 'showValue5.activePort';
    'onDelay.y' = 'showValue6.activePort';
    'sampleTriggerSet.y' = 'rSFlipFlop.S';
    'sampleTriggerReset.y' = 'rSFlipFlop.R';
    'and1.y' = size('and1.u', 1) == 0 or min('and1.u');

    when sample(0.0, 1.0) then
      'booleanPulse1.pulseStart' = time;
    end when;

    'booleanPulse1.y' = time >= 'booleanPulse1.pulseStart' and time < 'booleanPulse1.pulseStart' + 0.2;

    when sample(0.0, 1.0) then
      'booleanPulse2.pulseStart' = time;
    end when;

    'booleanPulse2.y' = time >= 'booleanPulse2.pulseStart' and time < 'booleanPulse2.pulseStart' + 0.8;
    'booleanStep.y' = time >= 1.5;
    'or1.y' = size('or1.u', 1) > 0 and max('or1.u');
    'xor1.y' = sum(if 'xor1.u['i']' then 1 else 0 for 'i' in 1:size('xor1.u', 1)) == 1;
    'nand1.y' = not (size('nand1.u', 1) == 0 or min('nand1.u'));
    'or2.y' = not (size('or2.u', 1) > 0 and max('or2.u'));
    'nor1.y' = not 'nor1.u';

    if 'onDelay.delaySignal' then
      'onDelay.y' = time >= 'onDelay.t_next';
    else
      'onDelay.y' = false;
    end if;

    'rising.y' = edge('rising.u');
    'set1.expr[1]' = false;
    'set1.expr[2]' = true;
    'set1.firstActiveIndex' = 'Modelica.Math.BooleanVectors.firstTrueIndex'({'set1.u[1]', 'set1.u[2]'});
    'set1.y' = if 'set1.firstActiveIndex' == 0 then pre('set1.y') else 'set1.expr['set1.firstActiveIndex']';
    'falling.y' = edge('falling.not_u');
    'booleanTable.combiTimeTable.timeScaled' = time;

    when {time >= pre('booleanTable.combiTimeTable.nextTimeEvent'), initial()} then
      'booleanTable.combiTimeTable.nextTimeEventScaled' = 'Modelica.Blocks.Tables.Internal.getNextTimeEvent'('booleanTable.combiTimeTable.tableID', 'booleanTable.combiTimeTable.timeScaled');
      'booleanTable.combiTimeTable.nextTimeEvent' = if 'booleanTable.combiTimeTable.nextTimeEventScaled' < 1e60 then 'booleanTable.combiTimeTable.nextTimeEventScaled' else 1e60;
    end when;

    'booleanTable.combiTimeTable.y[1]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer'('booleanTable.combiTimeTable.tableID', 1, 'booleanTable.combiTimeTable.timeScaled', 'booleanTable.combiTimeTable.nextTimeEventScaled', pre('booleanTable.combiTimeTable.nextTimeEventScaled'));
    'booleanTable.realToBoolean.y' = 'booleanTable.realToBoolean.u' >= 0.5;
    'changing.y' = change('changing.u');
    'triggeredAdd.local_reset' = false;
    'triggeredAdd.local_set' = 0;

    when {'triggeredAdd.trigger', 'triggeredAdd.local_reset'} then
      'triggeredAdd.y' = if 'triggeredAdd.local_reset' then 'triggeredAdd.local_set' else pre('triggeredAdd.y') + 'triggeredAdd.u';
    end when;

    'integerConstant.y' = 2;
    'rSFlipFlop.nor.y' = not ('rSFlipFlop.nor.u1' or 'rSFlipFlop.nor.u2');
    'rSFlipFlop.nor1.y' = not ('rSFlipFlop.nor1.u1' or 'rSFlipFlop.nor1.u2');
    'rSFlipFlop.pre.y' = pre('rSFlipFlop.pre.u');
    'sampleTriggerSet.y' = sample(0.0, 0.5);
    'sampleTriggerReset.y' = sample(0.3, 0.5);
  algorithm
    when initial() then
      'onDelay.delaySignal' := 'onDelay.u';
      'onDelay.t_next' := time - 1.0;
    elsewhen 'onDelay.u' then
      'onDelay.delaySignal' := true;
      'onDelay.t_next' := time + 1.0;
    elsewhen not 'onDelay.u' then
      'onDelay.delaySignal' := false;
      'onDelay.t_next' := time - 1.0;
    end when;
    annotation(experiment(StopTime = 10));
  end 'BooleanNetwork1';
end 'BooleanNetwork1';
