//! base 0.1.0
package 'RotationalSample'
  model 'RotationalSample' "Simple example of a rotational clock with variable trigger interval and switching rotation-direction."
    parameter Real 'angle_input.amplitude' = 10.0 "Amplitude of sine wave";
    parameter Real 'angle_input.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1.0 "Frequency of sine wave";
    parameter Real 'angle_input.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'angle_input.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'angle_input.y' "Connector of Real output signal";
    parameter Real 'angle_input.offset' = 0.0 "Offset of output signal y";
    parameter Real 'angle_input.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'trigger_interval_input.amplitude' = 2.0 "Amplitude of pulse";
    parameter Real 'trigger_interval_input.width'(max = 100.0, min = 2.2250738585072014e-308) = 50.0 "Width of pulse in % of period";
    parameter Real 'trigger_interval_input.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 1.0 "Time for one period";
    parameter Integer 'trigger_interval_input.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'trigger_interval_input.y' "Connector of Real output signal";
    parameter Real 'trigger_interval_input.offset' = 1.0 "Offset of output signal y";
    parameter Real 'trigger_interval_input.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    Real 'trigger_interval_input.T_width'(unit = "s", quantity = "Time");
    Real 'trigger_interval_input.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'trigger_interval_input.count' "Period count";
    parameter Boolean 'rotationalClock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'rotationalClock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'rotationalClock.y';
    Real 'rotationalClock.angle'(unit = "rad") "Input angle observed for generating clock ticks.";
    Integer 'rotationalClock.direction' "Rotation direction (sign: +1 or -1). Sampled with the provided clock signal
     'y'.";
    Boolean 'rotationalClock.direction_changed'(start = false) "= true, if the rotation direction of the observed angle changed since the last tick of y', otherwise false. Sampled with the provided clock signal y.";
    Real 'rotationalClock.trigger_interval'(unit = "rad") "Rotational-interval the input angle must be changed to trigger the next clock tick";
    parameter Boolean 'rotationalClock.y_clock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'rotationalClock.y_clock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'rotationalClock.y_clock.y';
    Boolean 'rotationalClock.y_clock.u';
    Real 'rotationalClock.update_offset.u' "Connector of continuous-time, Real input signal";
    Real 'rotationalClock.update_offset.y' "Connector of clocked, Real output signal";
    Clock 'rotationalClock.update_offset.clock' "Output signal y is associated with this clock input";
    parameter Real 'rotationalClock.angular_offset.y_start' = 0.0 "Value of output y before the first tick of the clock associated to input u";
    Real 'rotationalClock.angular_offset.u'(start = 0.0) "Connector of clocked, Real input signal";
    Real 'rotationalClock.angular_offset.y' "Connector of continuous-time, Real output signal";
    Real 'rotationalClock.sub.u1' "Connector of Real input signal 1";
    Real 'rotationalClock.sub.u2' "Connector of Real input signal 2";
    Real 'rotationalClock.sub.y' "Connector of Real output signal";
    parameter Real 'rotationalClock.sub.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'rotationalClock.sub.k2' = -1.0 "Gain of input signal 2";
    Real 'rotationalClock.less.u1' "Connector of first Real input signal";
    Real 'rotationalClock.less.u2' "Connector of second Real input signal";
    Boolean 'rotationalClock.less.y' "Connector of Boolean output signal";
    Real 'rotationalClock.abs2.u' "Connector of Real input signal";
    Real 'rotationalClock.abs2.y' "Connector of Real output signal";
    parameter Boolean 'rotationalClock.abs2.generateEvent' = false "Choose whether events shall be generated" annotation(Evaluate = true);
    Real 'rotationalClock.abs1.u' "Connector of Real input signal";
    Real 'rotationalClock.abs1.y' "Connector of Real output signal";
    parameter Boolean 'rotationalClock.abs1.generateEvent' = false "Choose whether events shall be generated" annotation(Evaluate = true);
    Real 'rotationalClock.direction_sign.u' "Connector of Real input signal";
    Real 'rotationalClock.direction_sign.y' "Connector of Real output signal";
    parameter Boolean 'rotationalClock.direction_sign.generateEvent' = false "Choose whether events shall be generated" annotation(Evaluate = true);
    Real 'rotationalClock.cast.u' "Connector of Real input signal";
    Integer 'rotationalClock.cast.y' "Connector of Integer output signal";
    Integer 'rotationalClock.changed.u'(start = 0) "Connector of Integer input signal.";
    Boolean 'rotationalClock.changed.y' "Connector of Boolean output signal.";
    Real 'rotationalClock.update_direction.u' "Connector of continuous-time, Real input signal";
    Real 'rotationalClock.update_direction.y' "Connector of clocked, Real output signal";
    Clock 'rotationalClock.update_direction.clock' "Output signal y is associated with this clock input";
    Real 'sample_angle.u' "Connector of continuous-time, Real input signal";
    Real 'sample_angle.y' "Connector of clocked, Real output signal";
    Clock 'sample_angle.clock' "Output signal y is associated with this clock input";
  equation
    'trigger_interval_input.T_width' = 0.5;
    'rotationalClock.angle' = 'rotationalClock.sub.u1';
    'rotationalClock.angle' = 'rotationalClock.update_offset.u';
    'rotationalClock.update_offset.y' = 'rotationalClock.angular_offset.u';
    'rotationalClock.angular_offset.y' = 'rotationalClock.sub.u2';
    'rotationalClock.less.y' = 'rotationalClock.y_clock.u';
    'rotationalClock.y_clock.y' = 'rotationalClock.update_direction.clock';
    'rotationalClock.y_clock.y' = 'rotationalClock.y';
    'rotationalClock.y_clock.y' = 'rotationalClock.update_offset.clock';
    'rotationalClock.sub.y' = 'rotationalClock.update_direction.u';
    'rotationalClock.sub.y' = 'rotationalClock.abs1.u';
    'rotationalClock.trigger_interval' = 'rotationalClock.abs2.u';
    'rotationalClock.abs1.y' = 'rotationalClock.less.u2';
    'rotationalClock.abs2.y' = 'rotationalClock.less.u1';
    'rotationalClock.direction_sign.y' = 'rotationalClock.cast.u';
    'rotationalClock.cast.y' = 'rotationalClock.direction';
    'rotationalClock.cast.y' = 'rotationalClock.changed.u';
    'rotationalClock.update_direction.y' = 'rotationalClock.direction_sign.u';
    'rotationalClock.changed.y' = 'rotationalClock.direction_changed';
    'angle_input.y' = 'sample_angle.u';
    'angle_input.y' = 'rotationalClock.angle';
    'rotationalClock.y' = 'sample_angle.clock';
    'trigger_interval_input.y' = 'rotationalClock.trigger_interval';
    'angle_input.y' = if time < 0.0 then 0.0 else 10.0 * sin(6.283185307179586 * time);

    when time >= (pre('trigger_interval_input.count') + 1) then
      'trigger_interval_input.count' = pre('trigger_interval_input.count') + 1;
      'trigger_interval_input.T_start' = time;
    end when;

    'trigger_interval_input.y' = 1.0 + (if time < 0.0 then 0.0 else if time < 'trigger_interval_input.T_start' + 'trigger_interval_input.T_width' then 2.0 else 0.0);
    'rotationalClock.y_clock.y' = Clock('rotationalClock.y_clock.u', 0.0);
    'rotationalClock.update_offset.y' = sample('rotationalClock.update_offset.u', 'rotationalClock.update_offset.clock');
    'rotationalClock.angular_offset.y' = hold('rotationalClock.angular_offset.u');
    'rotationalClock.sub.y' = 'rotationalClock.sub.u1' + (-1.0) * 'rotationalClock.sub.u2';
    'rotationalClock.less.y' = 'rotationalClock.less.u1' < 'rotationalClock.less.u2';
    'rotationalClock.abs2.y' = if noEvent('rotationalClock.abs2.u' >= 0.0) then 'rotationalClock.abs2.u' else -'rotationalClock.abs2.u';
    'rotationalClock.abs1.y' = if noEvent('rotationalClock.abs1.u' >= 0.0) then 'rotationalClock.abs1.u' else -'rotationalClock.abs1.u';
    'rotationalClock.direction_sign.y' = if noEvent('rotationalClock.direction_sign.u' > 0.0) then 1.0 else if noEvent('rotationalClock.direction_sign.u' < 0.0) then -1.0 else 0.0;
    'rotationalClock.cast.y' = if 'rotationalClock.cast.u' > 0.0 then integer(floor('rotationalClock.cast.u' + 0.5)) else integer(ceil('rotationalClock.cast.u' - 0.5));

    if firstTick() then
      'rotationalClock.changed.y' = false;
    elseif true then
      'rotationalClock.changed.y' = not 'rotationalClock.changed.u' == previous('rotationalClock.changed.u');
    end if;

    'rotationalClock.update_direction.y' = sample('rotationalClock.update_direction.u', 'rotationalClock.update_direction.clock');
    'sample_angle.y' = sample('sample_angle.u', 'sample_angle.clock');
  initial algorithm
    'trigger_interval_input.count' := integer(time);
    'trigger_interval_input.T_start' := 'trigger_interval_input.count';
  algorithm
    assert('rotationalClock.trigger_interval' > 0.0 or 'rotationalClock.trigger_interval' < 0.0, "The rotational-interval of rotational clocks must be non-zero.", AssertionLevel.error);
    annotation(experiment(StopTime = 2));
  end 'RotationalSample';
end 'RotationalSample';
