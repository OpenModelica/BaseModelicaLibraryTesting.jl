//! base 0.1.0
package 'EngineV6'
  function 'Modelica.Mechanics.MultiBody.Frames.resolve1' "Transform vector from frame 2 to frame 1"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v2';
    output Real[3] 'v1';
  algorithm
    'v1' := {'R'.'T'[1,1] * 'v2'[1] + 'R'.'T'[2,1] * 'v2'[2] + 'R'.'T'[3,1] * 'v2'[3], 'R'.'T'[1,2] * 'v2'[1] + 'R'.'T'[2,2] * 'v2'[2] + 'R'.'T'[3,2] * 'v2'[3], 'R'.'T'[1,3] * 'v2'[1] + 'R'.'T'[2,3] * 'v2'[2] + 'R'.'T'[3,3] * 'v2'[3]};
    annotation(derivative(order = 1, noDerivative = 'R') = 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der', InlineAfterIndexReduction = true);
  end 'Modelica.Mechanics.MultiBody.Frames.resolve1';

  function 'Modelica.Mechanics.MultiBody.Frames.resolve2' "Transform vector from frame 1 to frame 2"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v1';
    output Real[3] 'v2';
  algorithm
    'v2' := {'R'.'T'[1,1] * 'v1'[1] + 'R'.'T'[1,2] * 'v1'[2] + 'R'.'T'[1,3] * 'v1'[3], 'R'.'T'[2,1] * 'v1'[1] + 'R'.'T'[2,2] * 'v1'[2] + 'R'.'T'[2,3] * 'v1'[3], 'R'.'T'[3,1] * 'v1'[1] + 'R'.'T'[3,2] * 'v1'[2] + 'R'.'T'[3,3] * 'v1'[3]};
    annotation(derivative(order = 1, noDerivative = 'R') = 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der', InlineAfterIndexReduction = true);
  end 'Modelica.Mechanics.MultiBody.Frames.resolve2';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der' "Derivative of function Frames.resolve1(..)"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v2';
    input Real[3] 'v2_der';
    output Real[3] 'v1_der';
  algorithm
    'v1_der' := 'Modelica.Mechanics.MultiBody.Frames.resolve1'('R', {'v2_der'[1] + 'R'.'w'[2] * 'v2'[3] - 'R'.'w'[3] * 'v2'[2], 'v2_der'[2] + 'R'.'w'[3] * 'v2'[1] - 'R'.'w'[1] * 'v2'[3], 'v2_der'[3] + 'R'.'w'[1] * 'v2'[2] - 'R'.'w'[2] * 'v2'[1]});
    annotation(Inline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der' "Derivative of function Frames.resolve2(..)"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v1';
    input Real[3] 'v1_der';
    output Real[3] 'v2_der';
  algorithm
    'v2_der' := 'Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1_der') - {'R'.'w'[2] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[3] - 'R'.'w'[3] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[2], 'R'.'w'[3] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[1] - 'R'.'w'[1] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[3], 'R'.'w'[1] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[2] - 'R'.'w'[2] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[1]};
    annotation(Inline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der';

  function 'Modelica.Units.Conversions.to_unit1' "Change the unit of a Real number to unit=\"1\""
    input Real 'r';
    output Real 'result'(unit = "1");
  algorithm
    'result' := 'r';
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_unit1';

  type 'Modelica.Mechanics.MultiBody.Types.GravityTypes' = enumeration('NoGravity', 'UniformGravity', 'PointGravity');

  type 'Modelica.Mechanics.MultiBody.Types.RotationTypes' = enumeration('RotationAxis', 'TwoAxesVectors', 'PlanarRotationSequence');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  record 'Modelica.Mechanics.MultiBody.Frames.Orientation'
    Real[3, 3] 'T';
    Real[3] 'w'(unit = fill("rad/s", 3), quantity = fill("AngularVelocity", 3));
  end 'Modelica.Mechanics.MultiBody.Frames.Orientation';

  model 'EngineV6' "V6 engine with 6 cylinders, 6 planar loops and 1 degree-of-freedom"
    parameter Boolean 'animation' = true "= true, if animation shall be enabled";
    output Real 'engineSpeed_rpm'(unit = "rev/min", quantity = "AngularVelocity") "Engine speed";
    output Real 'engineTorque'(unit = "N.m", quantity = "Torque") "Torque generated by engine";
    output Real 'filteredEngineTorque'(unit = "N.m", quantity = "Torque") "Filtered torque generated by engine";
    Real 'bearing.axis.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'bearing.axis.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'bearing.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'bearing.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'bearing.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bearing.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bearing.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bearing.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bearing.frame_a.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bearing.frame_a.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bearing.frame_a.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bearing.frame_a.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bearing.frame_a.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bearing.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bearing.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bearing.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bearing.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.frame_b.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.frame_b.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.frame_b.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.frame_b.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bearing.frame_b.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bearing.frame_b.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bearing.frame_b.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bearing.frame_b.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bearing.frame_b.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    parameter Boolean 'bearing.useAxisFlange' = true "= true, if axis flange is enabled" annotation(Evaluate = true);
    parameter Boolean 'bearing.animation' = true "= true, if animation shall be enabled (show axis as cylinder)";
    parameter Real 'bearing.n[1]'(unit = "1") = 1.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'bearing.n[2]'(unit = "1") = 0.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'bearing.n[3]'(unit = "1") = 0.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'bearing.cylinderLength'(min = 0.0, unit = "m", quantity = "Length") = 0.02 "Length of cylinder representing the joint axis";
    parameter Real 'bearing.cylinderDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.06 "Diameter of cylinder representing the joint axis";
    Integer 'bearing.cylinderColor[1]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Integer 'bearing.cylinderColor[2]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Integer 'bearing.cylinderColor[3]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Real 'bearing.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter StateSelect 'bearing.stateSelect' = StateSelect.prefer "Priority to use joint angle phi and w=der(phi) as states";
    Real 'bearing.phi'(stateSelect = StateSelect.prefer, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle from frame_a to frame_b";
    Real 'bearing.w'(stateSelect = StateSelect.prefer, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "First derivative of angle phi (relative angular velocity)";
    Real 'bearing.a'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Second derivative of angle phi (relative angular acceleration)";
    Real 'bearing.tau'(unit = "N.m", quantity = "Torque") "Driving torque in direction of axis of rotation";
    Real 'bearing.angle'(displayUnit = "deg", unit = "rad", quantity = "Angle") "= phi";
    parameter Real 'bearing.e[1]'(unit = "1") = 1.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    parameter Real 'bearing.e[2]'(unit = "1") = 0.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    parameter Real 'bearing.e[3]'(unit = "1") = 0.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    Real 'bearing.R_rel.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.R_rel.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.R_rel.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.R_rel.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    parameter String 'bearing.cylinder.shapeType' = "cylinder" "Type of shape (box, sphere, cylinder, pipecylinder, cone, pipe, beam, gearwheel, spring, <external shape>)";
    Real 'bearing.cylinder.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'bearing.cylinder.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.cylinder.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.cylinder.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bearing.cylinder.r[1]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'bearing.cylinder.r[2]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'bearing.cylinder.r[3]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'bearing.cylinder.r_shape[1]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'bearing.cylinder.r_shape[2]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'bearing.cylinder.r_shape[3]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'bearing.cylinder.lengthDirection[1]' "Vector in length direction, resolved in object frame";
    Real 'bearing.cylinder.lengthDirection[2]' "Vector in length direction, resolved in object frame";
    Real 'bearing.cylinder.lengthDirection[3]' "Vector in length direction, resolved in object frame";
    Real 'bearing.cylinder.widthDirection[1]' "Vector in width direction, resolved in object frame";
    Real 'bearing.cylinder.widthDirection[2]' "Vector in width direction, resolved in object frame";
    Real 'bearing.cylinder.widthDirection[3]' "Vector in width direction, resolved in object frame";
    Real 'bearing.cylinder.length'(unit = "m", quantity = "Length") "Length of visual object";
    Real 'bearing.cylinder.width'(unit = "m", quantity = "Length") "Width of visual object";
    Real 'bearing.cylinder.height'(unit = "m", quantity = "Length") "Height of visual object";
    Real 'bearing.cylinder.extra' "Additional size data for some of the shape types";
    Real 'bearing.cylinder.color[1]' "Color of shape";
    Real 'bearing.cylinder.color[2]' "Color of shape";
    Real 'bearing.cylinder.color[3]' "Color of shape";
    Real 'bearing.cylinder.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter Real 'bearing.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'bearing.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'bearing.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'bearing.internalAxis.tau'(unit = "N.m", quantity = "Torque") "External support torque (must be computed via torque balance in model where InternalSupport is used; = flange.tau)";
    Real 'bearing.internalAxis.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "External support angle (= flange.phi)";
    Real 'bearing.internalAxis.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'bearing.internalAxis.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'world.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.frame_b.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.frame_b.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.frame_b.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'world.frame_b.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'world.frame_b.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'world.frame_b.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'world.frame_b.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'world.frame_b.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    parameter Boolean 'world.enableAnimation' = true "= true, if animation of all components is enabled";
    parameter Boolean 'world.animateWorld' = false "= true, if world coordinate system shall be visualized";
    parameter Boolean 'world.animateGravity' = false "= true, if gravity field shall be visualized (acceleration vector or field center)";
    parameter Boolean 'world.animateGround' = false "= true, if ground plane shall be visualized";
    parameter String 'world.label1' = "x" "Label of horizontal axis in icon";
    parameter String 'world.label2' = "y" "Label of vertical axis in icon";
    parameter 'Modelica.Mechanics.MultiBody.Types.GravityTypes' 'world.gravityType' = 'Modelica.Mechanics.MultiBody.Types.GravityTypes'.'UniformGravity' "Type of gravity field" annotation(Evaluate = true);
    parameter Real 'world.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Real 'world.n[1]'(unit = "1") = 0.0 "Direction of gravity resolved in world frame (gravity = g*n/length(n))" annotation(Evaluate = true);
    parameter Real 'world.n[2]'(unit = "1") = -1.0 "Direction of gravity resolved in world frame (gravity = g*n/length(n))" annotation(Evaluate = true);
    parameter Real 'world.n[3]'(unit = "1") = 0.0 "Direction of gravity resolved in world frame (gravity = g*n/length(n))" annotation(Evaluate = true);
    parameter Real 'world.mu'(min = 0.0, unit = "m3/s2") = 3.986004418e14 "Gravity field constant (default = field constant of earth)";
    parameter Boolean 'world.driveTrainMechanics3D' = true "= true, if 3-dim. mechanical effects of Parts.Mounting1D/Rotor1D/BevelGear1D shall be taken into account";
    parameter Real 'world.axisLength'(min = 0.0, unit = "m", quantity = "Length") = 0.5 "Length of world axes arrows";
    parameter Real 'world.axisDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.0125 "Diameter of world axes arrows";
    parameter Boolean 'world.axisShowLabels' = true "= true, if labels shall be shown";
    Integer 'world.axisColor_x[1]'(max = 255, min = 0) "Color of x-arrow";
    Integer 'world.axisColor_x[2]'(max = 255, min = 0) "Color of x-arrow";
    Integer 'world.axisColor_x[3]'(max = 255, min = 0) "Color of x-arrow";
    Integer 'world.axisColor_y[1]'(max = 255, min = 0);
    Integer 'world.axisColor_y[2]'(max = 255, min = 0);
    Integer 'world.axisColor_y[3]'(max = 255, min = 0);
    Integer 'world.axisColor_z[1]'(max = 255, min = 0) "Color of z-arrow";
    Integer 'world.axisColor_z[2]'(max = 255, min = 0) "Color of z-arrow";
    Integer 'world.axisColor_z[3]'(max = 255, min = 0) "Color of z-arrow";
    parameter Real 'world.gravityArrowTail[1]'(unit = "m", quantity = "Length") = 0.0 "Position vector from origin of world frame to arrow tail, resolved in world frame";
    parameter Real 'world.gravityArrowTail[2]'(unit = "m", quantity = "Length") = 0.0 "Position vector from origin of world frame to arrow tail, resolved in world frame";
    parameter Real 'world.gravityArrowTail[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from origin of world frame to arrow tail, resolved in world frame";
    parameter Real 'world.gravityArrowLength'(unit = "m", quantity = "Length") = 0.25 "Length of gravity arrow";
    parameter Real 'world.gravityArrowDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.0125 "Diameter of gravity arrow";
    Integer 'world.gravityArrowColor[1]'(max = 255, min = 0) "Color of gravity arrow";
    Integer 'world.gravityArrowColor[2]'(max = 255, min = 0) "Color of gravity arrow";
    Integer 'world.gravityArrowColor[3]'(max = 255, min = 0) "Color of gravity arrow";
    parameter Real 'world.gravitySphereDiameter'(min = 0.0, unit = "m", quantity = "Length") = 1.2742e7 "Diameter of sphere representing gravity center (default = mean diameter of earth)";
    Integer 'world.gravitySphereColor[1]'(max = 255, min = 0) "Color of gravity sphere";
    Integer 'world.gravitySphereColor[2]'(max = 255, min = 0) "Color of gravity sphere";
    Integer 'world.gravitySphereColor[3]'(max = 255, min = 0) "Color of gravity sphere";
    parameter Real 'world.groundAxis_u[1]'(unit = "1") = 1.0 "Vector along 1st axis (called u) of ground plane, resolved in world frame (should be perpendicular to gravity direction)";
    parameter Real 'world.groundAxis_u[2]'(unit = "1") = 0.0 "Vector along 1st axis (called u) of ground plane, resolved in world frame (should be perpendicular to gravity direction)";
