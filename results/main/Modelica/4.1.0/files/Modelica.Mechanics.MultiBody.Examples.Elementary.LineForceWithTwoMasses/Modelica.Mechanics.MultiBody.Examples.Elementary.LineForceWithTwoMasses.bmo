    'lineForceWithTwoMasses.frame_a.f[3]' = 'lineForceWithTwoMasses.frame_a.R.T[3,1]' * ('lineForceWithTwoMasses.ag_CM1_0[1]' - 'lineForceWithTwoMasses.aux2_0[1]' - 'lineForceWithTwoMasses.e_rel_0[1]' * 'lineForceWithTwoMasses.fa') + 'lineForceWithTwoMasses.frame_a.R.T[3,2]' * ('lineForceWithTwoMasses.ag_CM1_0[2]' - 'lineForceWithTwoMasses.aux2_0[2]' - 'lineForceWithTwoMasses.e_rel_0[2]' * 'lineForceWithTwoMasses.fa') + 'lineForceWithTwoMasses.frame_a.R.T[3,3]' * ('lineForceWithTwoMasses.ag_CM1_0[3]' - 'lineForceWithTwoMasses.aux2_0[3]' - 'lineForceWithTwoMasses.e_rel_0[3]' * 'lineForceWithTwoMasses.fa');
    'lineForceWithTwoMasses.frame_b.f[1]' = 'lineForceWithTwoMasses.frame_b.R.T[1,1]' * ('lineForceWithTwoMasses.ag_CM2_0[1]' + 'lineForceWithTwoMasses.aux2_0[1]' - 'lineForceWithTwoMasses.e_rel_0[1]' * 'lineForceWithTwoMasses.fb') + 'lineForceWithTwoMasses.frame_b.R.T[1,2]' * ('lineForceWithTwoMasses.ag_CM2_0[2]' + 'lineForceWithTwoMasses.aux2_0[2]' - 'lineForceWithTwoMasses.e_rel_0[2]' * 'lineForceWithTwoMasses.fb') + 'lineForceWithTwoMasses.frame_b.R.T[1,3]' * ('lineForceWithTwoMasses.ag_CM2_0[3]' + 'lineForceWithTwoMasses.aux2_0[3]' - 'lineForceWithTwoMasses.e_rel_0[3]' * 'lineForceWithTwoMasses.fb');
    'lineForceWithTwoMasses.frame_b.f[2]' = 'lineForceWithTwoMasses.frame_b.R.T[2,1]' * ('lineForceWithTwoMasses.ag_CM2_0[1]' + 'lineForceWithTwoMasses.aux2_0[1]' - 'lineForceWithTwoMasses.e_rel_0[1]' * 'lineForceWithTwoMasses.fb') + 'lineForceWithTwoMasses.frame_b.R.T[2,2]' * ('lineForceWithTwoMasses.ag_CM2_0[2]' + 'lineForceWithTwoMasses.aux2_0[2]' - 'lineForceWithTwoMasses.e_rel_0[2]' * 'lineForceWithTwoMasses.fb') + 'lineForceWithTwoMasses.frame_b.R.T[2,3]' * ('lineForceWithTwoMasses.ag_CM2_0[3]' + 'lineForceWithTwoMasses.aux2_0[3]' - 'lineForceWithTwoMasses.e_rel_0[3]' * 'lineForceWithTwoMasses.fb');
    'lineForceWithTwoMasses.frame_b.f[3]' = 'lineForceWithTwoMasses.frame_b.R.T[3,1]' * ('lineForceWithTwoMasses.ag_CM2_0[1]' + 'lineForceWithTwoMasses.aux2_0[1]' - 'lineForceWithTwoMasses.e_rel_0[1]' * 'lineForceWithTwoMasses.fb') + 'lineForceWithTwoMasses.frame_b.R.T[3,2]' * ('lineForceWithTwoMasses.ag_CM2_0[2]' + 'lineForceWithTwoMasses.aux2_0[2]' - 'lineForceWithTwoMasses.e_rel_0[2]' * 'lineForceWithTwoMasses.fb') + 'lineForceWithTwoMasses.frame_b.R.T[3,3]' * ('lineForceWithTwoMasses.ag_CM2_0[3]' + 'lineForceWithTwoMasses.aux2_0[3]' - 'lineForceWithTwoMasses.e_rel_0[3]' * 'lineForceWithTwoMasses.fb');
    assert(noEvent('lineForceWithTwoMasses.length' > 1e-10), "\nThe distance between the origin of frame_a and the origin of frame_b\nof a line force component became smaller as parameter s_small\n(= a small number, defined in the \"Advanced\" menu). The distance is\nset to s_small, although it is smaller, to avoid a division by zero\nwhen computing the direction of the line force. Possible reasons\nfor this situation:\n- At initial time the distance may already be zero: Change the initial\n  positions of the bodies connected by this element.\n- Hardware stops are not modeled or are modeled not stiff enough.\n  Include stops, e.g., stiff springs, or increase the stiffness\n  if already present.\n- Another error in your model may lead to unrealistically large forces\n  and torques that would in reality destroy the stops.\n- The flange_b connector might be defined by a pre-defined motion,\n  e.g., with Modelica.Mechanics.Translational.Position and the\n  predefined flange_b.s is zero or negative.\n", AssertionLevel.error);
    'lineForceWithTwoMasses.r_rel_0[1]' = 'lineForceWithTwoMasses.frame_b.r_0[1]' - 'lineForceWithTwoMasses.frame_a.r_0[1]';
    'lineForceWithTwoMasses.r_rel_0[2]' = 'lineForceWithTwoMasses.frame_b.r_0[2]' - 'lineForceWithTwoMasses.frame_a.r_0[2]';
    'lineForceWithTwoMasses.r_rel_0[3]' = 'lineForceWithTwoMasses.frame_b.r_0[3]' - 'lineForceWithTwoMasses.frame_a.r_0[3]';
    'lineForceWithTwoMasses.length' = sqrt('lineForceWithTwoMasses.r_rel_0[1]' * 'lineForceWithTwoMasses.r_rel_0[1]' + 'lineForceWithTwoMasses.r_rel_0[2]' * 'lineForceWithTwoMasses.r_rel_0[2]' + 'lineForceWithTwoMasses.r_rel_0[3]' * 'lineForceWithTwoMasses.r_rel_0[3]');
    'lineForceWithTwoMasses.s' = if 'lineForceWithTwoMasses.length' > 1e-10 then 'lineForceWithTwoMasses.length' else 1e-10;
    'lineForceWithTwoMasses.e_rel_0[1]' = 'lineForceWithTwoMasses.r_rel_0[1]' / 'lineForceWithTwoMasses.s';
    'lineForceWithTwoMasses.e_rel_0[2]' = 'lineForceWithTwoMasses.r_rel_0[2]' / 'lineForceWithTwoMasses.s';
    'lineForceWithTwoMasses.e_rel_0[3]' = 'lineForceWithTwoMasses.r_rel_0[3]' / 'lineForceWithTwoMasses.s';
    'lineForceWithTwoMasses.frame_a.t[1]' = 0.0;
    'lineForceWithTwoMasses.frame_a.t[2]' = 0.0;
    'lineForceWithTwoMasses.frame_a.t[3]' = 0.0;
    'lineForceWithTwoMasses.frame_b.t[1]' = 0.0;
    'lineForceWithTwoMasses.frame_b.t[2]' = 0.0;
    'lineForceWithTwoMasses.frame_b.t[3]' = 0.0;
    annotation(experiment(StopTime = 3));
  end 'LineForceWithTwoMasses';
end 'LineForceWithTwoMasses';
