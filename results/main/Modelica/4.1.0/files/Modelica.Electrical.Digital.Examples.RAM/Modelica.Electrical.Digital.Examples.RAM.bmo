//! base 0.1.0
package 'RAM'
  function 'Modelica.Electrical.Digital.Examples.RAM.dLATRAM.address' "Compute memory address"
    input Integer 'n_addr';
    input 'Modelica.Electrical.Digital.Interfaces.Logic'['n_addr'] 'addr';
    output Integer 'int_addr';
    'Modelica.Electrical.Digital.Interfaces.Logic' 'addr_bit';
  algorithm
    'int_addr' := 1;

    for 'i' in 1:'n_addr' loop
      'addr_bit' := ({'Modelica.Electrical.Digital.Interfaces.Logic'.'\'X\'', 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'X\'', 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'0\'', 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'1\'', 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'X\'', 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'X\'', 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'0\'', 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'1\'', 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'X\''})['addr'['i']];

      if 'addr_bit' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'1\'' then
        'int_addr' := 'int_addr' + integer(2.0 ^ ('i' - 1));
      elseif 'addr_bit' == 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'X\'' then
        'int_addr' := 0;
        break;
      end if;
    end for;
  end 'Modelica.Electrical.Digital.Examples.RAM.dLATRAM.address';

  type 'Modelica.Electrical.Digital.Interfaces.Strength' = enumeration('\'S_X01\'', '\'S_X0H\'', '\'S_XL1\'', '\'S_X0Z\'', '\'S_XZ1\'', '\'S_WLH\'', '\'S_WLZ\'', '\'S_WZH\'', '\'S_W0H\'', '\'S_WL1\'');

  type 'Modelica.Electrical.Digital.Interfaces.Logic' = enumeration('\'U\'', '\'X\'', '\'0\'', '\'1\'', '\'Z\'', '\'W\'', '\'L\'', '\'H\'', '\'-\'');

  model 'RAM' "Simple RAM test example"
    parameter Real 'dLATRAM.tHL'(unit = "s", quantity = "Time") = 0.0 "High->Low delay";
    parameter Real 'dLATRAM.tLH'(unit = "s", quantity = "Time") = 0.0 "Low->High delay";
    parameter 'Modelica.Electrical.Digital.Interfaces.Strength' 'dLATRAM.strength' = 'Modelica.Electrical.Digital.Interfaces.Strength'.'\'S_X01\'' "Output strength";
    parameter Integer 'dLATRAM.n_addr'(min = 1) = 2 "Addr width";
    parameter Integer 'dLATRAM.n_data'(min = 1) = 2 "Data width";
    parameter String 'dLATRAM.fileName' = "/home/runner/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Electrical/Digital/Memory_Matrix.txt" "File where matrix for memory is stored";
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.RE' "Read enable";
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.addr[1]' "Address";
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.addr[2]' "Address";
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.dataOut[1]' "Data output";
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.dataOut[2]' "Data output";
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.nextstate[1]'(start = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'');
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.nextstate[2]'(start = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'');
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.mem_word[1]'(start = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'');
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.mem_word[2]'(start = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'');
    Integer 'dLATRAM.int_addr';
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.yy[1]'(start = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'');
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.yy[2]'(start = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'');
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.inertialDelaySensitive[1].x'(fixed = true, start = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'') "Connector of Digital input signal";
    'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.inertialDelaySensitive[1].y'(fixed = true, start = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'') "Connector of Digital output signal";
    parameter Real 'dLATRAM.inertialDelaySensitive[1].tLH'(start = 0.0, unit = "s", quantity = "Time") = 0.0 "Rise inertial delay";
    parameter Real 'dLATRAM.inertialDelaySensitive[1].tHL'(start = 0.0, unit = "s", quantity = "Time") = 0.0 "Fall inertial delay";
    parameter 'Modelica.Electrical.Digital.Interfaces.Logic' 'dLATRAM.inertialDelaySensitive[1].y0' = 'Modelica.Electrical.Digital.Interfaces.Logic'.'\'U\'' "Initial value of output";
