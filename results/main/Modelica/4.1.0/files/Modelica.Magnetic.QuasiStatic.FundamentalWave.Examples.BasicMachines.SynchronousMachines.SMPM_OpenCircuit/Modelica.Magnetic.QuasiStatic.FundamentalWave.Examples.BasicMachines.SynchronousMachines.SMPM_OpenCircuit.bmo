    Real 'smpmQS.stator.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smpmQS.stator.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smpmQS.stator.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smpmQS.stator.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'smpmQS.stator.port_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
