    Real 'battery.resistor[1].heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'battery.resistor[1].heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'battery.resistor[1].LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'battery.resistor[1].T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'battery.resistor[1].R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'battery.resistor[2].R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.0017500000000000003 "Resistance at temperature T_ref";
    parameter Real 'battery.resistor[2].T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'battery.resistor[2].alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'battery.resistor[2].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'battery.resistor[2].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery.resistor[2].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
