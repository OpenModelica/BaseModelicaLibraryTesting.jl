    Real 'battery.resistor[2].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery.resistor[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'battery.resistor[2].useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'battery.resistor[2].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'battery.resistor[2].heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'battery.resistor[2].heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'battery.resistor[2].LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'battery.resistor[2].T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'battery.resistor[2].R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'battery.capacitor[1].v'(fixed = true, start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'battery.capacitor[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery.capacitor[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery.capacitor[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery.capacitor[1].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery.capacitor[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'battery.capacitor[1].C'(start = 1.0, min = 0.0, unit = "F", quantity = "Capacitance") = 17142.857142857138 "Capacitance";
    Real 'battery.capacitor[2].v'(fixed = true, start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'battery.capacitor[2].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery.capacitor[2].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery.capacitor[2].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery.capacitor[2].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery.capacitor[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'battery.capacitor[2].C'(start = 1.0, min = 0.0, unit = "F", quantity = "Capacitance") = 5714.285714285714 "Capacitance";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.pc.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'powerSensor.pc.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.nc.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'powerSensor.nc.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.pv.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'powerSensor.pv.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.nv.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'powerSensor.nv.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.power'(unit = "W") "Instantaneous power as output signal";
    Real 'powerSensor.voltageSensor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'powerSensor.voltageSensor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.voltageSensor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'powerSensor.voltageSensor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.voltageSensor.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as output signal";
    Real 'powerSensor.currentSensor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'powerSensor.currentSensor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.currentSensor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'powerSensor.currentSensor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'powerSensor.currentSensor.i'(unit = "A") "Current in the branch from p to n as output signal";
    Real 'powerSensor.product.u1' "Connector of Real input signal 1";
    Real 'powerSensor.product.u2' "Connector of Real input signal 2";
    Real 'powerSensor.product.y' "Connector of Real output signal";
    parameter Real 'energy.k' = 1.0 "Integrator gain";
    parameter Boolean 'energy.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'energy.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'energy.initType' = 'Modelica.Blocks.Types.Init'.'InitialState' "Type of initialization (1: no init, 2: steady state, 3,4: initial output)" annotation(Evaluate = true);
    parameter Real 'energy.y_start' = 0.0 "Initial or guess value of output (= state)";
    Real 'energy.u'(unit = "W") "Connector of Real input signal";
    Real 'energy.y'(unit = "J") "Connector of Real output signal";
    Boolean 'energy.local_reset';
    Real 'energy.local_set';
    Real 'cccvCharger.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'cccvCharger.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'cccvCharger.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'cccvCharger.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'cccvCharger.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'cccvCharger.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'cccvCharger.I'(unit = "A", quantity = "ElectricCurrent") = 50.0 "Constant charge current";
    parameter Real 'cccvCharger.startTime'(unit = "s", quantity = "Time") = 0.0 "Start time of charging";
    parameter Real 'cccvCharger.rampTime'(unit = "s", quantity = "Time") = 60.0 "Ramp up charging current";
    parameter Real 'cccvCharger.Vend'(unit = "V", quantity = "ElectricPotential") = 42.0 "End of charge voltage";
    Boolean 'cccvCharger.CV'(fixed = true, start = false) "Indicates CV charging";
  initial equation
    'energy.y' = 0.0;
  equation
    'battery.displaySOC' = 'battery.SOC';
    'battery.i' = 'battery.p.i';
    'battery.power' = 'battery.v' * 'battery.i';
    'battery.SOC' = 'battery.limIntegrator.y';
    'battery.selfDischarge.heatPort.T' = 'battery.selfDischarge.T_heatPort';
    'battery.selfDischarge.heatPort.Q_flow' = -'battery.selfDischarge.LossPower';
    'battery.r0.heatPort.T' = 'battery.r0.T_heatPort';
    'battery.r0.heatPort.Q_flow' = -'battery.r0.LossPower';
    'battery.resistor[1].heatPort.T' = 'battery.resistor[1].T_heatPort';
    'battery.resistor[1].heatPort.Q_flow' = -'battery.resistor[1].LossPower';
    'battery.resistor[2].heatPort.T' = 'battery.resistor[2].T_heatPort';
    'battery.resistor[2].heatPort.Q_flow' = -'battery.resistor[2].LossPower';
    'battery.capacitor[1].p.v' = 'battery.resistor[1].p.v';
    'battery.capacitor[1].p.v' = 'battery.r0.n.v';
    'battery.capacitor[2].p.v' = 'battery.resistor[2].p.v';
    'battery.capacitor[2].p.v' = 'battery.resistor[1].n.v';
    'battery.capacitor[2].p.v' = 'battery.capacitor[1].n.v';
    'battery.resistor[2].n.v' = 'battery.n.v';
    'battery.resistor[2].n.v' = 'battery.capacitor[2].n.v';
    'battery.fixedTemperature.port.T' = 'battery.internalHeatPort.T';
    'battery.fixedTemperature.port.T' = 'battery.r0.heatPort.T';
    'battery.fixedTemperature.port.T' = 'battery.selfDischarge.heatPort.T';
    'battery.fixedTemperature.port.T' = 'battery.resistor[2].heatPort.T';
    'battery.fixedTemperature.port.T' = 'battery.resistor[1].heatPort.T';
    'battery.gainV.y' = 'battery.ocv.v';
    'battery.ocv_soc.y[1]' = 'battery.gainV.u';
    'battery.limIntegrator.y' = 'battery.ocv_soc.u';
    'battery.currentSensor.n.v' = 'battery.ocv.p.v';
    'battery.limIntegrator.u' = 'battery.currentSensor.i';
    'battery.currentSensor.p.v' = 'battery.selfDischarge.p.v';
    'battery.currentSensor.p.v' = 'battery.p.v';
    'battery.selfDischarge.p.i' + 'battery.currentSensor.p.i' - 'battery.p.i' = 0.0;
    'battery.ocv.n.v' = 'battery.selfDischarge.n.v';
    'battery.ocv.n.v' = 'battery.r0.p.v';
    'powerSensor.pv.v' = 'powerSensor.voltageSensor.p.v';
    'powerSensor.voltageSensor.p.i' - 'powerSensor.pv.i' = 0.0;
    'powerSensor.voltageSensor.n.v' = 'powerSensor.nv.v';
    'powerSensor.pc.v' = 'powerSensor.currentSensor.p.v';
    'powerSensor.currentSensor.p.i' - 'powerSensor.pc.i' = 0.0;
    'powerSensor.currentSensor.n.v' = 'powerSensor.nc.v';
    'powerSensor.currentSensor.i' = 'powerSensor.product.u2';
    'powerSensor.voltageSensor.v' = 'powerSensor.product.u1';
    'powerSensor.product.y' = 'powerSensor.power';
    'ground.p.v' = 'cccvCharger.n.v';
    'ground.p.v' = 'powerSensor.nv.v';
    'ground.p.v' = 'battery.n.v';
    'powerSensor.nc.v' = 'battery.p.v';
    'powerSensor.pc.v' = 'cccvCharger.p.v';
    'powerSensor.pc.v' = 'powerSensor.pv.v';
    'powerSensor.power' = 'energy.u';
    'cccvCharger.n.i' + 'powerSensor.nv.i' + 'ground.p.i' + 'battery.n.i' = 0.0;
    'battery.ocv.p.i' + 'battery.currentSensor.n.i' = 0.0;
    'battery.r0.p.i' + 'battery.selfDischarge.n.i' + 'battery.ocv.n.i' = 0.0;
    'battery.capacitor[1].p.i' + 'battery.resistor[1].p.i' + 'battery.r0.n.i' = 0.0;
    'battery.internalHeatPort.Q_flow' = 0.0;
    'battery.resistor[2].heatPort.Q_flow' + 'battery.resistor[1].heatPort.Q_flow' + 'battery.fixedTemperature.port.Q_flow' + 'battery.r0.heatPort.Q_flow' + 'battery.selfDischarge.heatPort.Q_flow' - 'battery.internalHeatPort.Q_flow' = 0.0;
    'battery.capacitor[2].p.i' + 'battery.capacitor[1].n.i' + 'battery.resistor[2].p.i' + 'battery.resistor[1].n.i' = 0.0;
    'battery.capacitor[2].n.i' + 'battery.resistor[2].n.i' - 'battery.n.i' = 0.0;
    'powerSensor.nc.i' + 'battery.p.i' = 0.0;
    'cccvCharger.p.i' + 'powerSensor.pv.i' + 'powerSensor.pc.i' = 0.0;
    'powerSensor.voltageSensor.n.i' - 'powerSensor.nv.i' = 0.0;
    'powerSensor.currentSensor.n.i' - 'powerSensor.nc.i' = 0.0;
    'battery.currentSensor.p.v' = 'battery.currentSensor.n.v';
    'battery.currentSensor.p.i' = 'battery.currentSensor.i';
    'battery.currentSensor.n.i' = -'battery.currentSensor.i';
    'battery.limIntegrator.local_reset' = false;
    'battery.limIntegrator.local_set' = 0.0;
    der('battery.limIntegrator.y') = if 'battery.limIntegrator.y' < 1e-9 and 'battery.limIntegrator.k' * 'battery.limIntegrator.u' < 0.0 or 'battery.limIntegrator.y' > 0.999999999 and 'battery.limIntegrator.k' * 'battery.limIntegrator.u' > 0.0 then 0.0 else 'battery.limIntegrator.k' * 'battery.limIntegrator.u';

    if 'battery.ocv_soc.smoothness' == 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments' then
      'battery.ocv_soc.y[1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer'('battery.ocv_soc.tableID', 1, 'battery.ocv_soc.u');
    elseif 'battery.ocv_soc.smoothness' == 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' then
      'battery.ocv_soc.y[1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('battery.ocv_soc.tableID', 1, 'battery.ocv_soc.u');
    elseif true then
      'battery.ocv_soc.y[1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValue'('battery.ocv_soc.tableID', 1, 'battery.ocv_soc.u');
    end if;

    'battery.gainV.y' = 'battery.gainV.k' * 'battery.gainV.u';
    'battery.ocv.v' = 'battery.ocv.p.v' - 'battery.ocv.n.v';
    0.0 = 'battery.ocv.p.i' + 'battery.ocv.n.i';
    'battery.ocv.i' = 'battery.ocv.p.i';
    'battery.selfDischarge.G_actual' = 'battery.selfDischarge.G';
    'battery.selfDischarge.i' = 'battery.selfDischarge.G_actual' * 'battery.selfDischarge.v';
    'battery.selfDischarge.LossPower' = 'battery.selfDischarge.v' * 'battery.selfDischarge.i';
    0.0 = 'battery.selfDischarge.p.i' + 'battery.selfDischarge.n.i';
    'battery.selfDischarge.i' = 'battery.selfDischarge.p.i';
    'battery.selfDischarge.v' = 'battery.selfDischarge.p.v' - 'battery.selfDischarge.n.v';
    assert(1.0 + 'battery.r0.alpha' * ('battery.r0.T_heatPort' - 293.15) >= 2.220446049250313e-16, "Temperature outside scope of model!", AssertionLevel.error);
    'battery.r0.R_actual' = 'battery.r0.R' * (1.0 + 'battery.r0.alpha' * ('battery.r0.T_heatPort' - 293.15));
    'battery.r0.v' = 'battery.r0.R_actual' * 'battery.r0.i';
    'battery.r0.LossPower' = 'battery.r0.v' * 'battery.r0.i';
    0.0 = 'battery.r0.p.i' + 'battery.r0.n.i';
    'battery.r0.i' = 'battery.r0.p.i';
    'battery.r0.v' = 'battery.r0.p.v' - 'battery.r0.n.v';
    'battery.fixedTemperature.port.T' = 293.15;
    'battery.resistor[1].R_actual' = 0.0035000000000000005;
    'battery.resistor[1].v' = 'battery.resistor[1].R_actual' * 'battery.resistor[1].i';
    'battery.resistor[1].LossPower' = 'battery.resistor[1].v' * 'battery.resistor[1].i';
    0.0 = 'battery.resistor[1].p.i' + 'battery.resistor[1].n.i';
    'battery.resistor[1].i' = 'battery.resistor[1].p.i';
    'battery.resistor[1].v' = 'battery.resistor[1].p.v' - 'battery.resistor[1].n.v';
    'battery.resistor[2].R_actual' = 0.0017500000000000003;
    'battery.resistor[2].v' = 'battery.resistor[2].R_actual' * 'battery.resistor[2].i';
    'battery.resistor[2].LossPower' = 'battery.resistor[2].v' * 'battery.resistor[2].i';
    0.0 = 'battery.resistor[2].p.i' + 'battery.resistor[2].n.i';
    'battery.resistor[2].i' = 'battery.resistor[2].p.i';
    'battery.resistor[2].v' = 'battery.resistor[2].p.v' - 'battery.resistor[2].n.v';
    'battery.capacitor[1].i' = 17142.857142857138 * der('battery.capacitor[1].v');
    0.0 = 'battery.capacitor[1].p.i' + 'battery.capacitor[1].n.i';
    'battery.capacitor[1].i' = 'battery.capacitor[1].p.i';
    'battery.capacitor[1].v' = 'battery.capacitor[1].p.v' - 'battery.capacitor[1].n.v';
    'battery.capacitor[2].i' = 5714.285714285714 * der('battery.capacitor[2].v');
    0.0 = 'battery.capacitor[2].p.i' + 'battery.capacitor[2].n.i';
    'battery.capacitor[2].i' = 'battery.capacitor[2].p.i';
    'battery.capacitor[2].v' = 'battery.capacitor[2].p.v' - 'battery.capacitor[2].n.v';
    assert('battery.cellData.R0' > 0.0, "Ri has to be greater than sum(rcParameters.R)", AssertionLevel.error);
    assert('battery.cellData.OCVmax' > 2.5, "Specify 0 <= OCVmin < OCVmax", AssertionLevel.error);
    assert('battery.cellData.SOCmax' > 'battery.cellData.SOCmin', "Specify 0 <= SOCmin < SOCmax <= 1", AssertionLevel.error);
    assert('battery.cellData.OCV_SOC[1,1]' >= 0.0, "Specify OCV(SOC) table with minimum SOC >= 0", AssertionLevel.error);
    assert('battery.cellData.OCV_SOC[29,1]' <= 1.0, "Specify OCV(SOC) table with maximum SOC <= 1", AssertionLevel.error);
    assert('battery.cellData.OCV_SOC[1,2]' >= 0.0, "Specify OCV(SOC) table with minimum OCV/OCVmax >= 0", AssertionLevel.error);
    assert('battery.cellData.OCV_SOC[29,2]' <= 1.0, "Specify OCV(SOC) table with maximum OCV/OCVmax <= 1", AssertionLevel.error);
    assert('battery.SOC' < 'battery.cellData.SOCmax' + 1e-9, "Battery overcharged!", AssertionLevel.error);
    assert('battery.SOC' > 'battery.cellData.SOCmin' - 1e-9, "Battery exhausted!", AssertionLevel.error);
    'battery.v' = 'battery.p.v' - 'battery.n.v';
    'ground.p.v' = 0.0;
    'powerSensor.voltageSensor.p.i' = 0.0;
    'powerSensor.voltageSensor.n.i' = 0.0;
    'powerSensor.voltageSensor.v' = 'powerSensor.voltageSensor.p.v' - 'powerSensor.voltageSensor.n.v';
    'powerSensor.currentSensor.p.v' = 'powerSensor.currentSensor.n.v';
    'powerSensor.currentSensor.p.i' = 'powerSensor.currentSensor.i';
    'powerSensor.currentSensor.n.i' = -'powerSensor.currentSensor.i';
    'powerSensor.product.y' = 'powerSensor.product.u1' * 'powerSensor.product.u2';
    'energy.local_reset' = false;
    'energy.local_set' = 0.0;
    der('energy.y') = 'energy.u';
    'cccvCharger.CV' = 'cccvCharger.v' >= 42.0;

    if 'cccvCharger.CV' then
      'cccvCharger.v' = 42.0;
    elseif true then
      'cccvCharger.i' = -50.0 * (if time < 0.0 then 0.0 else min(1.0, time / 60.0));
    end if;

    0.0 = 'cccvCharger.p.i' + 'cccvCharger.n.i';
    'cccvCharger.i' = 'cccvCharger.p.i';
    'cccvCharger.v' = 'cccvCharger.p.v' - 'cccvCharger.n.v';
    annotation(experiment(StopTime = 1200, Interval = 0.1, Tolerance = 1e-06));
  end 'CCCVcharging';
end 'CCCVcharging';
