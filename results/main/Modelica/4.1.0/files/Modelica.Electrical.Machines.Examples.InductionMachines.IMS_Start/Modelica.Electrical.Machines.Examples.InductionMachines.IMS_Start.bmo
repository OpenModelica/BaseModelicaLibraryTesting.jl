    'switchedRheostat.idealCommutingSwitch.idealCommutingSwitch[3].p.v' - 'switchedRheostat.idealCommutingSwitch.idealCommutingSwitch[3].n1.v' = 'switchedRheostat.idealCommutingSwitch.idealCommutingSwitch[3].s1' * (if 'switchedRheostat.idealCommutingSwitch.idealCommutingSwitch[3].control' then 1.0 else 1e-5);
