    'switchedRheostat.idealCommutingSwitch.idealCommutingSwitch[1].p.v' - 'switchedRheostat.idealCommutingSwitch.idealCommutingSwitch[1].n1.v' = 'switchedRheostat.idealCommutingSwitch.idealCommutingSwitch[1].s1' * (if 'switchedRheostat.idealCommutingSwitch.idealCommutingSwitch[1].control' then 1.0 else 1e-5);
