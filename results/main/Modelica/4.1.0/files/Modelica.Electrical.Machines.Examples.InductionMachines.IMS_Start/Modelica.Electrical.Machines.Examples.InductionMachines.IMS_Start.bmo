//! base 0.1.0
package 'IMS_Start'
  model 'IMS_Start' "Test example: InductionMachineSlipRing"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'tStart1'(unit = "s", quantity = "Time") = 0.1 "Start time";
    parameter Real 'Rstart'(unit = "Ohm", quantity = "Resistance") = 0.16000000000000003 "Starting resistance";
    parameter Real 'tStart2'(unit = "s", quantity = "Time") = 1.0 "Start time of shorting starting resistance";
    parameter Real 'TLoad'(unit = "N.m", quantity = "Torque") = 161.4 "Nominal load torque";
    parameter Real 'wLoad'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal load speed";
    parameter Real 'JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load's moment of inertia";
    parameter Integer 'aims.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'aims.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'aims.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'aims.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
    parameter Real 'aims.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'aims.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
