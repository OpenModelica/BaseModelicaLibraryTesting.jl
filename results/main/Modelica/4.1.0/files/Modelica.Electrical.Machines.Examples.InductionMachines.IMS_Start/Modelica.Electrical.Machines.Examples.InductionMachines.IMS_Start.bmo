    parameter Real 'aimsData.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'aimsData.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'aimsData.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'aimsData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'aimsData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'aimsData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'aimsData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'aimsData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'aimsData.Lm'(unit = "H", quantity = "Inductance") = 0.009225332222963813 "Stator main field inductance per phase";
    parameter Real 'aimsData.Lrsigma'(unit = "H", quantity = "Inductance") = 3.2396436254990697e-4 "Rotor stray inductance per phase w.r.t. rotor side";
    parameter Real 'aimsData.ratioCommonRotorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of rotor winding";
    parameter Real 'aimsData.Lrzero'(unit = "H", quantity = "Inductance") = 3.23964362549907e-4 "Rotor zero sequence inductance w.r.t. rotor side";
    parameter Real 'aimsData.Rr'(unit = "Ohm", quantity = "Resistance") = 0.04000000000000001 "Rotor resistance per phase at TRef w.r.t. rotor side";
    parameter Real 'aimsData.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of rotor resistance";
    parameter Real 'aimsData.alpha20r'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of rotor resistance at 20 degC";
    parameter Boolean 'aimsData.useTurnsRatio' = true "Use turnsRatio or calculate from locked-rotor voltage?";
    parameter Real 'aimsData.turnsRatio'(min = 2.2250738585072014e-308) = 0.9999999999999999 "Effective number of stator turns / effective number of rotor turns";
    parameter Real 'aimsData.VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal stator voltage per phase";
    parameter Real 'aimsData.VrLockedRotor'(unit = "V", quantity = "ElectricPotential") = 96.60262311821904 "Locked-rotor voltage per phase";
    parameter Integer 'aimsData.rotorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'aimsData.rotorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'aimsData.rotorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 1.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'aimsData.rotorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 1.0 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'aimsData.rotorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'aimsData.rotorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'aimsData.rotorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 1e-6 "Angular velocity limit";
  initial equation
    'aims.is[1]' = 0.0;
    'aims.is[2]' = 0.0;
