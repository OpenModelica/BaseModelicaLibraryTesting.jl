    parameter Real 'aims.Lszero'(unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator zero sequence inductance";
    parameter Real 'aims.Lssigma'(start = 3.239643625499069e-4, unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator stray inductance per phase";
    parameter Real 'aims.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
