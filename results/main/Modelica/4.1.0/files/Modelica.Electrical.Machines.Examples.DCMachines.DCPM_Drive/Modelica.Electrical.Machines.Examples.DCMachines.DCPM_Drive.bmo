    'dcdcInverter1.iDCSensor.p.v' = 'dcdcInverter1.iDCSensor.n.v';
    'dcdcInverter1.iDCSensor.p.i' = 'dcdcInverter1.iDCSensor.i';
    'dcdcInverter1.iDCSensor.n.i' = -'dcdcInverter1.iDCSensor.i';
    'dcdcInverter1.vMotSensor.p.i' = 0.0;
    'dcdcInverter1.vMotSensor.n.i' = 0.0;
    'dcdcInverter1.vMotSensor.v' = 'dcdcInverter1.vMotSensor.p.v' - 'dcdcInverter1.vMotSensor.n.v';
    der('dcdcInverter1.vMotFilter.y') = ('dcdcInverter1.vMotFilter.u' - 'dcdcInverter1.vMotFilter.y') / 0.002;
    der('dcdcInverter1.iDCFilter.y') = ('dcdcInverter1.iDCFilter.u' - 'dcdcInverter1.iDCFilter.y') / 0.002;
    'dcdcInverter2.vDCSensor.p.i' = 0.0;
    'dcdcInverter2.vDCSensor.n.i' = 0.0;
    'dcdcInverter2.vDCSensor.v' = 'dcdcInverter2.vDCSensor.p.v' - 'dcdcInverter2.vDCSensor.n.v';
    'dcdcInverter2.iMotSensor.p.v' = 'dcdcInverter2.iMotSensor.n.v';
    'dcdcInverter2.iMotSensor.p.i' = 'dcdcInverter2.iMotSensor.i';
    'dcdcInverter2.iMotSensor.n.i' = -'dcdcInverter2.iMotSensor.i';
    assert('dcdcInverter2.variableLimiter.limit1' >= 'dcdcInverter2.variableLimiter.limit2', "Input signals are not consistent: limit1 < limit2", AssertionLevel.error);
    'dcdcInverter2.variableLimiter.simplifiedExpr' = 'dcdcInverter2.variableLimiter.u';
    'dcdcInverter2.variableLimiter.y' = homotopy(smooth(0, if 'dcdcInverter2.variableLimiter.u' > 'dcdcInverter2.variableLimiter.limit1' then 'dcdcInverter2.variableLimiter.limit1' else if 'dcdcInverter2.variableLimiter.u' < 'dcdcInverter2.variableLimiter.limit2' then 'dcdcInverter2.variableLimiter.limit2' else 'dcdcInverter2.variableLimiter.u'), 'dcdcInverter2.variableLimiter.simplifiedExpr');
    'dcdcInverter2.gain.y' = (-1.0) * 'dcdcInverter2.gain.u';
    der('dcdcInverter2.vDCFilter.y') = ('dcdcInverter2.vDCFilter.u' - 'dcdcInverter2.vDCFilter.y') / 0.002;
    der('dcdcInverter2.iMotFilter.y') = ('dcdcInverter2.iMotFilter.u' - 'dcdcInverter2.iMotFilter.y') / 0.002;
    'dcdcInverter2.idealDcDc.signalVoltage.v' = 'dcdcInverter2.idealDcDc.signalVoltage.p.v' - 'dcdcInverter2.idealDcDc.signalVoltage.n.v';
    0.0 = 'dcdcInverter2.idealDcDc.signalVoltage.p.i' + 'dcdcInverter2.idealDcDc.signalVoltage.n.i';
    'dcdcInverter2.idealDcDc.signalVoltage.i' = 'dcdcInverter2.idealDcDc.signalVoltage.p.i';
    'dcdcInverter2.idealDcDc.signalCurrent.v' = 'dcdcInverter2.idealDcDc.signalCurrent.p.v' - 'dcdcInverter2.idealDcDc.signalCurrent.n.v';
    0.0 = 'dcdcInverter2.idealDcDc.signalCurrent.p.i' + 'dcdcInverter2.idealDcDc.signalCurrent.n.i';
    'dcdcInverter2.idealDcDc.signalCurrent.i' = 'dcdcInverter2.idealDcDc.signalCurrent.p.i';
    'dcdcInverter2.idealDcDc.powerBat.voltageSensor.p.i' = 0.0;
    'dcdcInverter2.idealDcDc.powerBat.voltageSensor.n.i' = 0.0;
    'dcdcInverter2.idealDcDc.powerBat.voltageSensor.v' = 'dcdcInverter2.idealDcDc.powerBat.voltageSensor.p.v' - 'dcdcInverter2.idealDcDc.powerBat.voltageSensor.n.v';
    'dcdcInverter2.idealDcDc.powerBat.currentSensor.p.v' = 'dcdcInverter2.idealDcDc.powerBat.currentSensor.n.v';
    'dcdcInverter2.idealDcDc.powerBat.currentSensor.p.i' = 'dcdcInverter2.idealDcDc.powerBat.currentSensor.i';
    'dcdcInverter2.idealDcDc.powerBat.currentSensor.n.i' = -'dcdcInverter2.idealDcDc.powerBat.currentSensor.i';
    'dcdcInverter2.idealDcDc.powerBat.product.y' = 'dcdcInverter2.idealDcDc.powerBat.product.u1' * 'dcdcInverter2.idealDcDc.powerBat.product.u2';
    'dcdcInverter2.idealDcDc.powerMot.voltageSensor.p.i' = 0.0;
    'dcdcInverter2.idealDcDc.powerMot.voltageSensor.n.i' = 0.0;
    'dcdcInverter2.idealDcDc.powerMot.voltageSensor.v' = 'dcdcInverter2.idealDcDc.powerMot.voltageSensor.p.v' - 'dcdcInverter2.idealDcDc.powerMot.voltageSensor.n.v';
    'dcdcInverter2.idealDcDc.powerMot.currentSensor.p.v' = 'dcdcInverter2.idealDcDc.powerMot.currentSensor.n.v';
    'dcdcInverter2.idealDcDc.powerMot.currentSensor.p.i' = 'dcdcInverter2.idealDcDc.powerMot.currentSensor.i';
    'dcdcInverter2.idealDcDc.powerMot.currentSensor.n.i' = -'dcdcInverter2.idealDcDc.powerMot.currentSensor.i';
    'dcdcInverter2.idealDcDc.powerMot.product.y' = 'dcdcInverter2.idealDcDc.powerMot.product.u1' * 'dcdcInverter2.idealDcDc.powerMot.product.u2';
    der('dcdcInverter2.idealDcDc.deadTime.y') = ('dcdcInverter2.idealDcDc.deadTime.u' - 'dcdcInverter2.idealDcDc.deadTime.y') / 5e-4;
    'dcdcInverter2.idealDcDc.feedback.y' = 'dcdcInverter2.idealDcDc.feedback.u1' - 'dcdcInverter2.idealDcDc.feedback.u2';
    'dcdcInverter2.idealDcDc.powerController.local_reset' = false;
    'dcdcInverter2.idealDcDc.powerController.local_set' = 0.0;
    der('dcdcInverter2.idealDcDc.powerController.y') = 1e6 * 'dcdcInverter2.idealDcDc.powerController.u';
    'dcdcInverter2.idealDcDc.groundMotor.p.v' = 0.0;
    'dcdcInverter2.iDCSensor.p.v' = 'dcdcInverter2.iDCSensor.n.v';
    'dcdcInverter2.iDCSensor.p.i' = 'dcdcInverter2.iDCSensor.i';
    'dcdcInverter2.iDCSensor.n.i' = -'dcdcInverter2.iDCSensor.i';
    'dcdcInverter2.vMotSensor.p.i' = 0.0;
    'dcdcInverter2.vMotSensor.n.i' = 0.0;
    'dcdcInverter2.vMotSensor.v' = 'dcdcInverter2.vMotSensor.p.v' - 'dcdcInverter2.vMotSensor.n.v';
    der('dcdcInverter2.vMotFilter.y') = ('dcdcInverter2.vMotFilter.u' - 'dcdcInverter2.vMotFilter.y') / 0.002;
    der('dcdcInverter2.iDCFilter.y') = ('dcdcInverter2.iDCFilter.u' - 'dcdcInverter2.iDCFilter.y') / 0.002;
    'ramp1.y' = if time < 0.25 then 0.0 else if time < 0.75 then (time - 0.25) * 50.0 / 0.5 else 50.0;
    'ramp2.y' = 50.0 + (if time < 1.25 then 0.0 else if time < 1.75 then (time - 1.25) * 10.0 / 0.5 else 10.0);
    'switch.off' = not 'switch.control';
    'switch.v' = 'switch.s' * (if 'switch.off' then 1.0 else 1e-5);
    'switch.i' = 'switch.s' * (if 'switch.off' then 1e-5 else 1.0);
    'switch.LossPower' = 'switch.v' * 'switch.i';
    'switch.T_heatPort' = 293.15;
    0.0 = 'switch.p.i' + 'switch.n.i';
    'switch.i' = 'switch.p.i';
    'switch.v' = 'switch.p.v' - 'switch.n.v';
    'booleanStep.y' = time >= 1.0;
    'multiSensor.pc.i' + 'multiSensor.nc.i' = 0.0;
    'multiSensor.pc.v' - 'multiSensor.nc.v' = 0.0;
    'multiSensor.pv.i' = 0.0;
    'multiSensor.nv.i' = 0.0;
    'multiSensor.i' = 'multiSensor.pc.i';
    'multiSensor.v' = 'multiSensor.pv.v' - 'multiSensor.nv.v';
    'multiSensor.power' = 'multiSensor.v' * 'multiSensor.i';
    'constantVoltage.v' = 100.0;
    0.0 = 'constantVoltage.p.i' + 'constantVoltage.n.i';
    'constantVoltage.i' = 'constantVoltage.p.i';
    'constantVoltage.v' = 'constantVoltage.p.v' - 'constantVoltage.n.v';
    'resistor.R_actual' = 0.005;
    'resistor.v' = 'resistor.R_actual' * 'resistor.i';
    'resistor.LossPower' = 'resistor.v' * 'resistor.i';
    'resistor.T_heatPort' = 300.15;
    0.0 = 'resistor.p.i' + 'resistor.n.i';
    'resistor.i' = 'resistor.p.i';
    'resistor.v' = 'resistor.p.v' - 'resistor.n.v';
    'ground.p.v' = 0.0;
    'speedSensor1.w' = der('speedSensor1.flange.phi');
    0.0 = 'speedSensor1.flange.tau';
    'speedSensor2.w' = der('speedSensor2.flange.phi');
    0.0 = 'speedSensor2.flange.tau';
    annotation(experiment(StopTime = 2.0, Interval = 1E-4, Tolerance = 1E-6));
  end 'DCPM_Drive';
end 'DCPM_Drive';
