      'iH01.mean2.y_last' = 50.0 * pre('iH01.mean2.x');
      reinit('iH01.mean2.x', 0.0);
    end when;

    'iH01.mean2.y' = 'iH01.mean2.y_last';
    'iH01.rectangularToPolar.y_abs' = sqrt('iH01.rectangularToPolar.u_re' * 'iH01.rectangularToPolar.u_re' + 'iH01.rectangularToPolar.u_im' * 'iH01.rectangularToPolar.u_im');
    'iH01.rectangularToPolar.y_arg' = atan2('iH01.rectangularToPolar.u_im', 'iH01.rectangularToPolar.u_re');
    'iH01.gain.y' = 'iH01.gain.u';
    'loadResistor.R_actual' = 12.1;
    'loadResistor.v' = 'loadResistor.R_actual' * 'loadResistor.i';
    'loadResistor.LossPower' = 'loadResistor.v' * 'loadResistor.i';
    'loadResistor.T_heatPort' = 300.15;
    0.0 = 'loadResistor.p.i' + 'loadResistor.n.i';
    'loadResistor.i' = 'loadResistor.p.i';
    'loadResistor.v' = 'loadResistor.p.v' - 'loadResistor.n.v';
  initial algorithm
    'trapezoid.count' := integer((time - 1.0) / 8.0);
    'trapezoid.T_start' := 1.0 + 'trapezoid.count' * 8.0;
    annotation(experiment(StopTime = 8, Interval = 0.0001, Tolerance = 1e-06));
  end 'Dimmer_R';
end 'Dimmer_R';
