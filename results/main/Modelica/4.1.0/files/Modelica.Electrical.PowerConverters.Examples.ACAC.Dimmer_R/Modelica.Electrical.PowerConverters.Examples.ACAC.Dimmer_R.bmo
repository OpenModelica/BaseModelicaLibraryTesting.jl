    parameter Real 'adaptor.firingAngleMin'(max = 3.141592653589793, min = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Minimum firing angle";
    parameter Real 'adaptor.positiveThreshold[1].threshold' = 0.0 "Comparison with respect to threshold";
    Real 'adaptor.positiveThreshold[1].u' "Connector of Real input signal";
    Boolean 'adaptor.positiveThreshold[1].y' "Connector of Boolean output signal";
    parameter Real 'adaptor.negativeThreshold[1].threshold' = 0.0 "Comparison with respect to threshold";
