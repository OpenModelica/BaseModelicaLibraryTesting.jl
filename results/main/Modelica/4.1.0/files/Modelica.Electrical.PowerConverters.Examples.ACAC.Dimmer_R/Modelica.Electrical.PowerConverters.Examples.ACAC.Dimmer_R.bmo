    'triac.thyristor1.v' = 'triac.thyristor1.s' * (if 'triac.thyristor1.off' then 1.0 else 1e-9);
    'triac.thyristor1.i' = 'triac.thyristor1.s' * (if 'triac.thyristor1.off' then 1e-9 else 1.0);
    'triac.thyristor1.LossPower' = 'triac.thyristor1.v' * 'triac.thyristor1.i';
