    'voltageToAngle.combiTable1Ds.y[1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('voltageToAngle.combiTable1Ds.tableID', 1, 'voltageToAngle.combiTable1Ds.u');
    'voltageToAngle.gain_alpha.y' = 3.141592653589793 * 'voltageToAngle.gain_alpha.u';

