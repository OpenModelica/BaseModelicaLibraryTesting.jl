    parameter Real 'triac.thyristor1.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-9 "Backward state-off conductance (opened conductance)";
    parameter Real 'triac.thyristor1.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'triac.thyristor1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'triac.thyristor1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'triac.thyristor1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
