    'loadResistor.p.i' + 'multiSensor.nc.i' = 0.0;
    'loadResistor.n.i' + 'multiSensor.nv.i' + 'voltageSensor.n.i' + 'ground.p.i' + 'sineVoltage.n.i' = 0.0;
    'sineVoltage.signalSource.y' = if time < 0.0 then 0.0 else 155.56349186104046 * sin(314.1592653589793 * time);
