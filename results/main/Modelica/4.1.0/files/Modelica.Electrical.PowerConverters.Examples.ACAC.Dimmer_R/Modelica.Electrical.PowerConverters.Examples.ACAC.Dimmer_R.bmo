    der('adaptor.filter[1].firstOrder.y') = ('adaptor.filter[1].firstOrder.u' - 'adaptor.filter[1].firstOrder.y') / 0.0015915494309189533;
    der('adaptor.filter[1].transferFunction[1].x_scaled[1]') = ('adaptor.filter[1].transferFunction[1].u' - 'adaptor.filter[1].transferFunction[1].x_scaled[1]') / 0.027338266680282546;
    'adaptor.filter[1].transferFunction[1].y' = 2.0 * 'adaptor.filter[1].transferFunction[1].x_scaled[1]' + (-1.0) * 'adaptor.filter[1].transferFunction[1].u';
