    parameter Real 'leftBoundary1.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Fixed value of pressure";
    parameter Real 'leftBoundary1.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed value of temperature";
    parameter Real 'leftBoundary1.X[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Fixed value of composition";
    Real 'leftBoundary1.p_in_internal'(unit = "Pa") "Needed to connect to conditional connector";
    Real 'leftBoundary1.T_in_internal'(unit = "K") "Needed to connect to conditional connector";
    Real 'leftBoundary1.X_in_internal[1]'(unit = "1") "Needed to connect to conditional connector";
    parameter Integer 'rightBoundary1.nPorts' = 1 "Number of ports";
