    Real 'rightAdaptor.state_b.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'rightAdaptor.state_b.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'rightAdaptor.state_b.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Real 'rightAdaptor.pathLength'(unit = "m", quantity = "Length") "Length flow path";
    parameter 'Modelica.Fluid.Types.Dynamics' 'rightAdaptor.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance" annotation(Evaluate = true);
    Real 'rightAdaptor.I'(unit = "kg.m/s", quantity = "Momentum") "Momenta of flow segments";
    Real 'rightAdaptor.Ib_flow'(unit = "N", quantity = "Force") "Flow of momentum across boundaries";
    Real 'rightAdaptor.F_p'(unit = "N", quantity = "Force") "Pressure force";
    Real 'rightAdaptor.F_fg'(unit = "N", quantity = "Force") "Friction and gravity force";
    parameter Real 'rightAdaptor.data.diameter_a'(min = 0.0, unit = "m", quantity = "Length") = 0.2 "Diameter at port_a";
    parameter Real 'rightAdaptor.data.diameter_b'(min = 0.0, unit = "m", quantity = "Length") = 1e60 "Diameter at port_b";
    parameter Real 'rightAdaptor.data.zeta1' = 1.0 "Loss factor for flow port_a -> port_b";
    parameter Real 'rightAdaptor.data.zeta2' = 0.5 "Loss factor for flow port_b -> port_a";
    parameter Real 'rightAdaptor.data.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 100.0 "Loss factors suited for Re >= Re_turbulent";
    parameter Real 'rightAdaptor.data.D_Re'(min = 0.0, unit = "m", quantity = "Length") = 0.2 "Diameter used to compute Re";
    parameter Boolean 'rightAdaptor.data.zeta1_at_a' = true "dp = zeta1*(if zeta1_at_a then rho_a*v_a^2/2 else rho_b*v_b^2/2)";
    parameter Boolean 'rightAdaptor.data.zeta2_at_a' = true "dp = -zeta2*(if zeta2_at_a then rho_a*v_a^2/2 else rho_b*v_b^2/2)";
    parameter Boolean 'rightAdaptor.data.zetaLaminarKnown' = true "= true, if zeta = c0/Re in laminar region";
    parameter Real 'rightAdaptor.data.c0' = 30.0 "zeta = c0/Re; dp = zeta*rho_Re*v_Re^2/2, Re=v_Re*D_Re*rho_Re/mu_Re)";
    parameter Real 'rightAdaptor.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 1.0 "Nominal mass flow rate";
    parameter Boolean 'rightAdaptor.use_Re' = false "= true, if turbulent region is defined by Re, otherwise by m_flow_small" annotation(Evaluate = true);
    parameter Boolean 'rightAdaptor.from_dp' = false "= true, use m_flow = f(dp) else dp = f(m_flow)" annotation(Evaluate = true);
    parameter Integer 'rightAdaptor.state_nominal.phase'(max = 2, min = 0) = 1 "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    parameter Real 'rightAdaptor.state_nominal.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 104929.29464256502 "Specific enthalpy";
    parameter Real 'rightAdaptor.state_nominal.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 997.0480319717385 "Density";
    parameter Real 'rightAdaptor.state_nominal.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 298.15 "Temperature";
    parameter Real 'rightAdaptor.state_nominal.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Pressure";
    parameter Real 'rightAdaptor.dp_nominal'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 0.5081058303779377 "Nominal pressure loss";
    parameter Real 'rightAdaptor.dp_small'(nominal = 1e6, start = 5e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0 "Regularization of zero flow if |dp| < dp_small";
    parameter Boolean 'rightAdaptor.show_Re' = false "= true, if Reynolds number is included for plotting" annotation(Evaluate = true);
    parameter Boolean 'rightAdaptor.show_totalPressures' = false "= true, if total pressures are included for plotting" annotation(Evaluate = true);
    parameter Boolean 'rightAdaptor.show_portVelocities' = false "= true, if port velocities are included for plotting" annotation(Evaluate = true);
    Real 'rightAdaptor.dp_fg'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure loss due to friction and gravity";
    Real 'rightAdaptor.A_mean'(unit = "m2", quantity = "Area") "Mean cross flow area";
    Integer 'rightAdaptor.state_b_des.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'rightAdaptor.state_b_des.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'rightAdaptor.state_b_des.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'rightAdaptor.state_b_des.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'rightAdaptor.state_b_des.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Integer 'rightAdaptor.state_a_nondes.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'rightAdaptor.state_a_nondes.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'rightAdaptor.state_a_nondes.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'rightAdaptor.state_a_nondes.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'rightAdaptor.state_a_nondes.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Real 'rightAdaptor.diameter_a'(min = 0.0, unit = "m", quantity = "Length") = 0.2 "Inner diameter of pipe at port_a";
    parameter Real 'rightAdaptor.diameter_b'(min = 0.0, unit = "m", quantity = "Length") = 1e60 "Inner diameter of pipe at port_b";
    parameter Real 'system.p_ambient'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default ambient pressure";
    parameter Real 'system.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default ambient temperature";
    parameter Real 'system.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'system.allowFlowReversal' = true "= false to restrict to design flow direction (port_a -> port_b)" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'DynamicFreeInitial' "Default formulation of energy balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'DynamicFreeInitial' "Default formulation of mass balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'DynamicFreeInitial' "Default formulation of substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'DynamicFreeInitial' "Default formulation of trace substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Default formulation of momentum balances, if options available" annotation(Evaluate = true);
    parameter Real 'system.m_flow_start'(unit = "kg/s", quantity = "MassFlowRate") = 0.0 "Default start value for mass flow rates";
    parameter Real 'system.p_start'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default start value for pressures";
    parameter Real 'system.T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default start value for temperatures";
    parameter Boolean 'system.use_eps_Re' = false "= true to determine turbulent region automatically using Reynolds number" annotation(Evaluate = true);
    parameter Real 'system.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 1.0 "Default nominal mass flow rate";
    parameter Real 'system.eps_m_flow'(min = 0.0) = 1e-4 "Regularization of zero flow for |m_flow| < eps_m_flow*m_flow_nominal";
    parameter Real 'system.dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0 "Default small pressure drop for regularization of laminar and zero flow";
    parameter Real 'system.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Default small mass flow rate for regularization of laminar and zero flow";
  equation
    'leftBoundary1.medium.T_degC' = 'leftBoundary1.medium.T' - 273.15;
    'leftBoundary1.medium.p_bar' = 'leftBoundary1.medium.p' / 1e5;
    'rightBoundary1.medium.T_degC' = 'rightBoundary1.medium.T' - 273.15;
    'rightBoundary1.medium.p_bar' = 'rightBoundary1.medium.p' / 1e5;
    'suddenExpansion1.V_flow' = 'suddenExpansion1.m_flow' / smooth(1, if 'suddenExpansion1.m_flow' > 0.01 then 'suddenExpansion1.state_a.d' else if 'suddenExpansion1.m_flow' < (-0.01) then 'suddenExpansion1.state_b.d' else if 0.01 > 0.0 then 'suddenExpansion1.m_flow' / 0.01 * (('suddenExpansion1.m_flow' / 0.01) ^ 2.0 - 3.0) * ('suddenExpansion1.state_b.d' - 'suddenExpansion1.state_a.d') / 4.0 + ('suddenExpansion1.state_a.d' + 'suddenExpansion1.state_b.d') / 2.0 else ('suddenExpansion1.state_a.d' + 'suddenExpansion1.state_b.d') / 2.0);
    'suddenExpansion1.port_a_T' = smooth(1, if 'suddenExpansion1.port_a.m_flow' > 0.01 then 'suddenExpansion1.state_a.T' else if 'suddenExpansion1.port_a.m_flow' < (-0.01) then ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion1.port_a.p', 'suddenExpansion1.port_a.h_outflow', 0, 0)).T else if 0.01 > 0.0 then 'suddenExpansion1.port_a.m_flow' / 0.01 * (('suddenExpansion1.port_a.m_flow' / 0.01) ^ 2.0 - 3.0) * (('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion1.port_a.p', 'suddenExpansion1.port_a.h_outflow', 0, 0)).T - 'suddenExpansion1.state_a.T') / 4.0 + ('suddenExpansion1.state_a.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion1.port_a.p', 'suddenExpansion1.port_a.h_outflow', 0, 0)).T) / 2.0 else ('suddenExpansion1.state_a.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion1.port_a.p', 'suddenExpansion1.port_a.h_outflow', 0, 0)).T) / 2.0);
    'suddenExpansion1.port_b_T' = smooth(1, if 'suddenExpansion1.port_b.m_flow' > 0.01 then 'suddenExpansion1.state_b.T' else if 'suddenExpansion1.port_b.m_flow' < (-0.01) then ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion1.port_b.p', 'suddenExpansion1.port_b.h_outflow', 0, 0)).T else if 0.01 > 0.0 then 'suddenExpansion1.port_b.m_flow' / 0.01 * (('suddenExpansion1.port_b.m_flow' / 0.01) ^ 2.0 - 3.0) * (('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion1.port_b.p', 'suddenExpansion1.port_b.h_outflow', 0, 0)).T - 'suddenExpansion1.state_b.T') / 4.0 + ('suddenExpansion1.state_b.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion1.port_b.p', 'suddenExpansion1.port_b.h_outflow', 0, 0)).T) / 2.0 else ('suddenExpansion1.state_b.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion1.port_b.p', 'suddenExpansion1.port_b.h_outflow', 0, 0)).T) / 2.0);
    'suddenExpansion1.pathLength' = 0.0;
    'suddenExpansion1.p_total_a' = 'suddenExpansion1.port_a.p' + 0.5 * 'suddenExpansion1.m_flow' ^ 2.0 / ((0.7853981633974483 * 'suddenExpansion1.data.diameter_a' ^ 2.0) ^ 2.0 * noEvent(if 'suddenExpansion1.port_a.m_flow' > 0.0 then 'suddenExpansion1.state_a.d' else 'suddenExpansion1.state_b.d'));
    'suddenExpansion1.p_total_b' = 'suddenExpansion1.port_b.p' + 0.5 * 'suddenExpansion1.m_flow' ^ 2.0 / ((0.7853981633974483 * 'suddenExpansion1.data.diameter_b' ^ 2.0) ^ 2.0 * noEvent(if 'suddenExpansion1.port_b.m_flow' > 0.0 then 'suddenExpansion1.state_b.d' else 'suddenExpansion1.state_a.d'));
    'suddenExpansion1.v_a' = 'suddenExpansion1.port_a.m_flow' / (0.7853981633974483 * 'suddenExpansion1.data.diameter_a' ^ 2.0 * noEvent(if 'suddenExpansion1.port_a.m_flow' > 0.0 then 'suddenExpansion1.state_a.d' else 'suddenExpansion1.state_b.d'));
    'suddenExpansion1.v_b' = 'suddenExpansion1.port_b.m_flow' / (0.7853981633974483 * 'suddenExpansion1.data.diameter_b' ^ 2.0 * noEvent(if 'suddenExpansion1.port_b.m_flow' > 0.0 then 'suddenExpansion1.state_b.d' else 'suddenExpansion1.state_a.d'));
    'suddenExpansion1.A_mean' = 0.7853981633974483 * ('suddenExpansion1.data.diameter_a' ^ 2.0 + 'suddenExpansion1.data.diameter_b' ^ 2.0) / 2.0;
    'leftBoundary2.medium.T_degC' = 'leftBoundary2.medium.T' - 273.15;
    'leftBoundary2.medium.p_bar' = 'leftBoundary2.medium.p' / 1e5;
    'rightBoundary2.medium.T_degC' = 'rightBoundary2.medium.T' - 273.15;
    'rightBoundary2.medium.p_bar' = 'rightBoundary2.medium.p' / 1e5;
    'suddenExpansion2.V_flow' = 'suddenExpansion2.m_flow' / smooth(1, if 'suddenExpansion2.m_flow' > 0.01 then 'suddenExpansion2.state_a.d' else if 'suddenExpansion2.m_flow' < (-0.01) then 'suddenExpansion2.state_b.d' else if 0.01 > 0.0 then 'suddenExpansion2.m_flow' / 0.01 * (('suddenExpansion2.m_flow' / 0.01) ^ 2.0 - 3.0) * ('suddenExpansion2.state_b.d' - 'suddenExpansion2.state_a.d') / 4.0 + ('suddenExpansion2.state_a.d' + 'suddenExpansion2.state_b.d') / 2.0 else ('suddenExpansion2.state_a.d' + 'suddenExpansion2.state_b.d') / 2.0);
    'suddenExpansion2.port_a_T' = smooth(1, if 'suddenExpansion2.port_a.m_flow' > 0.01 then 'suddenExpansion2.state_a.T' else if 'suddenExpansion2.port_a.m_flow' < (-0.01) then ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion2.port_a.p', 'suddenExpansion2.port_a.h_outflow', 0, 0)).T else if 0.01 > 0.0 then 'suddenExpansion2.port_a.m_flow' / 0.01 * (('suddenExpansion2.port_a.m_flow' / 0.01) ^ 2.0 - 3.0) * (('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion2.port_a.p', 'suddenExpansion2.port_a.h_outflow', 0, 0)).T - 'suddenExpansion2.state_a.T') / 4.0 + ('suddenExpansion2.state_a.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion2.port_a.p', 'suddenExpansion2.port_a.h_outflow', 0, 0)).T) / 2.0 else ('suddenExpansion2.state_a.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion2.port_a.p', 'suddenExpansion2.port_a.h_outflow', 0, 0)).T) / 2.0);
    'suddenExpansion2.port_b_T' = smooth(1, if 'suddenExpansion2.port_b.m_flow' > 0.01 then 'suddenExpansion2.state_b.T' else if 'suddenExpansion2.port_b.m_flow' < (-0.01) then ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion2.port_b.p', 'suddenExpansion2.port_b.h_outflow', 0, 0)).T else if 0.01 > 0.0 then 'suddenExpansion2.port_b.m_flow' / 0.01 * (('suddenExpansion2.port_b.m_flow' / 0.01) ^ 2.0 - 3.0) * (('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion2.port_b.p', 'suddenExpansion2.port_b.h_outflow', 0, 0)).T - 'suddenExpansion2.state_b.T') / 4.0 + ('suddenExpansion2.state_b.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion2.port_b.p', 'suddenExpansion2.port_b.h_outflow', 0, 0)).T) / 2.0 else ('suddenExpansion2.state_b.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('suddenExpansion2.port_b.p', 'suddenExpansion2.port_b.h_outflow', 0, 0)).T) / 2.0);
    'suddenExpansion2.pathLength' = 0.0;
    'suddenExpansion2.p_total_a' = 'suddenExpansion2.port_a.p' + 0.5 * 'suddenExpansion2.m_flow' ^ 2.0 / ((0.7853981633974483 * 'suddenExpansion2.data.diameter_a' ^ 2.0) ^ 2.0 * noEvent(if 'suddenExpansion2.port_a.m_flow' > 0.0 then 'suddenExpansion2.state_a.d' else 'suddenExpansion2.state_b.d'));
    'suddenExpansion2.p_total_b' = 'suddenExpansion2.port_b.p' + 0.5 * 'suddenExpansion2.m_flow' ^ 2.0 / ((0.7853981633974483 * 'suddenExpansion2.data.diameter_b' ^ 2.0) ^ 2.0 * noEvent(if 'suddenExpansion2.port_b.m_flow' > 0.0 then 'suddenExpansion2.state_b.d' else 'suddenExpansion2.state_a.d'));
    'suddenExpansion2.v_a' = 'suddenExpansion2.port_a.m_flow' / (0.7853981633974483 * 'suddenExpansion2.data.diameter_a' ^ 2.0 * noEvent(if 'suddenExpansion2.port_a.m_flow' > 0.0 then 'suddenExpansion2.state_a.d' else 'suddenExpansion2.state_b.d'));
    'suddenExpansion2.v_b' = 'suddenExpansion2.port_b.m_flow' / (0.7853981633974483 * 'suddenExpansion2.data.diameter_b' ^ 2.0 * noEvent(if 'suddenExpansion2.port_b.m_flow' > 0.0 then 'suddenExpansion2.state_b.d' else 'suddenExpansion2.state_a.d'));
    'suddenExpansion2.A_mean' = 0.7853981633974483 * ('suddenExpansion2.data.diameter_a' ^ 2.0 + 'suddenExpansion2.data.diameter_b' ^ 2.0) / 2.0;
    'leftAdaptor.V_flow' = 'leftAdaptor.m_flow' / smooth(1, if 'leftAdaptor.m_flow' > 0.01 then 'leftAdaptor.state_a.d' else if 'leftAdaptor.m_flow' < (-0.01) then 'leftAdaptor.state_b.d' else if 0.01 > 0.0 then 'leftAdaptor.m_flow' / 0.01 * (('leftAdaptor.m_flow' / 0.01) ^ 2.0 - 3.0) * ('leftAdaptor.state_b.d' - 'leftAdaptor.state_a.d') / 4.0 + ('leftAdaptor.state_a.d' + 'leftAdaptor.state_b.d') / 2.0 else ('leftAdaptor.state_a.d' + 'leftAdaptor.state_b.d') / 2.0);
    'leftAdaptor.port_a_T' = smooth(1, if 'leftAdaptor.port_a.m_flow' > 0.01 then 'leftAdaptor.state_a.T' else if 'leftAdaptor.port_a.m_flow' < (-0.01) then ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('leftAdaptor.port_a.p', 'leftAdaptor.port_a.h_outflow', 0, 0)).T else if 0.01 > 0.0 then 'leftAdaptor.port_a.m_flow' / 0.01 * (('leftAdaptor.port_a.m_flow' / 0.01) ^ 2.0 - 3.0) * (('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('leftAdaptor.port_a.p', 'leftAdaptor.port_a.h_outflow', 0, 0)).T - 'leftAdaptor.state_a.T') / 4.0 + ('leftAdaptor.state_a.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('leftAdaptor.port_a.p', 'leftAdaptor.port_a.h_outflow', 0, 0)).T) / 2.0 else ('leftAdaptor.state_a.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('leftAdaptor.port_a.p', 'leftAdaptor.port_a.h_outflow', 0, 0)).T) / 2.0);
    'leftAdaptor.port_b_T' = smooth(1, if 'leftAdaptor.port_b.m_flow' > 0.01 then 'leftAdaptor.state_b.T' else if 'leftAdaptor.port_b.m_flow' < (-0.01) then ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('leftAdaptor.port_b.p', 'leftAdaptor.port_b.h_outflow', 0, 0)).T else if 0.01 > 0.0 then 'leftAdaptor.port_b.m_flow' / 0.01 * (('leftAdaptor.port_b.m_flow' / 0.01) ^ 2.0 - 3.0) * (('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('leftAdaptor.port_b.p', 'leftAdaptor.port_b.h_outflow', 0, 0)).T - 'leftAdaptor.state_b.T') / 4.0 + ('leftAdaptor.state_b.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('leftAdaptor.port_b.p', 'leftAdaptor.port_b.h_outflow', 0, 0)).T) / 2.0 else ('leftAdaptor.state_b.T' + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('leftAdaptor.port_b.p', 'leftAdaptor.port_b.h_outflow', 0, 0)).T) / 2.0);
