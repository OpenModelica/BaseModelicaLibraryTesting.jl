    Real 'rightBoundary1.X_in_internal[1]'(unit = "1") "Needed to connect to conditional connector";
    parameter Boolean 'suddenExpansion1.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'suddenExpansion1.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'suddenExpansion1.port_a.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'suddenExpansion1.port_a.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'suddenExpansion1.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'suddenExpansion1.port_b.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'suddenExpansion1.port_b.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'suddenExpansion1.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'suddenExpansion1.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'suddenExpansion1.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'suddenExpansion1.dp_start'(nominal = 1e6, start = 5e6, max = 1e8, min = -1e60, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 4.572952473401439 "Guess value of dp = port_a.p - port_b.p";
    parameter Real 'suddenExpansion1.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 60.0 "Guess value of m_flow = port_a.m_flow";
    parameter Real 'suddenExpansion1.m_flow_small'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 0.01 "Small mass flow rate for regularization of zero flow";
    parameter Boolean 'suddenExpansion1.show_T' = true "= true, if temperatures at port_a and port_b are computed";
    parameter Boolean 'suddenExpansion1.show_V_flow' = true "= true, if volume flow rate at inflowing port is computed";
    Real 'suddenExpansion1.m_flow'(stateSelect = StateSelect.default, start = 60.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate in design flow direction";
    Real 'suddenExpansion1.dp'(start = 4.572952473401439, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure difference between port_a and port_b (= port_a.p - port_b.p)";
    Real 'suddenExpansion1.V_flow'(unit = "m3/s", quantity = "VolumeFlowRate") "Volume flow rate at inflowing port (positive when flow from port_a to port_b)";
    Real 'suddenExpansion1.port_a_T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature close to port_a, if show_T = true";
    Real 'suddenExpansion1.port_b_T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature close to port_b, if show_T = true";
    Integer 'suddenExpansion1.state_a.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'suddenExpansion1.state_a.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'suddenExpansion1.state_a.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'suddenExpansion1.state_a.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'suddenExpansion1.state_a.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Integer 'suddenExpansion1.state_b.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'suddenExpansion1.state_b.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'suddenExpansion1.state_b.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'suddenExpansion1.state_b.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'suddenExpansion1.state_b.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Real 'suddenExpansion1.pathLength'(unit = "m", quantity = "Length") "Length flow path";
