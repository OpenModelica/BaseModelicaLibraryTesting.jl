package 'BatchPlant_StandardWater'
  function '$OMC$PositiveMax'
    input Real 'flowValue';
    input Real 'eps';
    output Real 'positiveMax';
  algorithm
    'positiveMax' := max('flowValue', 'eps');
  end '$OMC$PositiveMax';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.B1.Medium.specificEnthalpy_pTX' "Return specific enthalpy from pressure, temperature and mass fraction"
    input Real 'p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Integer 'phase'(max = 2, min = 0) = 0;
    output Real 'h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Media.Water.IF97_Utilities.h_props_pT'('p', 'T', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT'('p', 'T', 0));
  end 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.B1.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.B1.heatTransfer.Medium.temperature' "Return temperature of ideal gas"
    input 'B1.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(Inline = true);
  end 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.B1.heatTransfer.Medium.temperature';

