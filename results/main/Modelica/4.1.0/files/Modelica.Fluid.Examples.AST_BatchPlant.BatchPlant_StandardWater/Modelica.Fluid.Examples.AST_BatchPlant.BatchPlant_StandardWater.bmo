  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g5' "Base function for region 5: g(p,T)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.GibbsDerivs' 'g';
    Real[11] 'o';
  algorithm
    assert('p' > 0.0, "IF97 medium function g5 called with too low pressure\np = " + String('p') + " Pa <=  0.0 Pa", AssertionLevel.error);
    assert('p' <= 1e7, "IF97 medium function g5: input pressure (= " + String('p') + " Pa) is higher than 10 MPa in region 5", AssertionLevel.error);
    assert('T' <= 2273.15, "IF97 medium function g5: input temperature (= " + String('T') + " K) is higher than limit of 2273.15K in region 5", AssertionLevel.error);
    'g'.'p' := 'p';
    'g'.'T' := 'T';
    'g'.'R_s' := 461.526;
    'g'.'pi' := 'p' / 1e6;
    'g'.'tau' := 1000.0 / 'T';
    'o'[1] := 'g'.'tau' * 'g'.'tau';
    'o'[2] := -0.004594282089991 * 'o'[1];
    'o'[3] := 0.0021774678714571 + 'o'[2];
    'o'[4] := 'o'[3] * 'g'.'tau';
    'o'[5] := 'o'[1] * 'g'.'tau';
    'o'[6] := 'o'[1] * 'o'[1];
    'o'[7] := 'o'[6] * 'o'[6];
    'o'[8] := 'o'[7] * 'g'.'tau';
    'o'[9] := -7.9449656719138e-6 * 'o'[8];
    'o'[10] := 'g'.'pi' * 'g'.'pi';
    'o'[11] := -0.013782846269973 * 'o'[1];
    'g'.'g' := 'g'.'pi' * ('o'[4] - 1.2563183589592e-4 + 'g'.'pi' * (1.2919228289784e-7 * 'o'[5] * 'g'.'pi' - 3.9724828359569e-6 * 'o'[8])) + ('g'.'tau' * (0.36901534980333 + 'g'.'tau' * ('g'.'tau' * ((6.8540841634434 - 0.32961626538917 * 'g'.'tau') * 'g'.'tau' - 13.179983674201 + log('g'.'pi')) - 3.1161318213925)) - 0.024805148933466) / 'o'[5];
    'g'.'gpi' := (1.0 + 'g'.'pi' * ('o'[4] - 1.2563183589592e-4 + 'g'.'pi' * ('o'[9] + 3.8757684869352e-7 * 'o'[5] * 'g'.'pi'))) / 'g'.'pi';
    'g'.'gpipi' := ('o'[10] * ('o'[9] + 7.7515369738704e-7 * 'o'[5] * 'g'.'pi') - 1.0) / 'o'[10];
    'g'.'gtau' := 'g'.'pi' * (0.0021774678714571 + 'o'[11] + 'g'.'pi' * (3.8757684869352e-7 * 'o'[1] * 'g'.'pi' - 3.5752345523612e-5 * 'o'[7])) + (0.074415446800398 + 'g'.'tau' * ((3.1161318213925 + 'o'[1] * (6.8540841634434 - 0.65923253077834 * 'g'.'tau')) * 'g'.'tau' - 0.73803069960666)) / 'o'[6];
    'g'.'gtautau' := ('g'.'tau' * (2.21409209881998 + (-(6.232263642785 + 0.65923253077834 * 'o'[5])) * 'g'.'tau') - 0.297661787201592) / ('o'[6] * 'g'.'tau') + 'g'.'pi' * ('g'.'pi' * (7.7515369738704e-7 * 'g'.'pi' * 'g'.'tau' - 2.86018764188897e-4 * 'o'[1] * 'o'[6] * 'g'.'tau') - 0.027565692539946 * 'g'.'tau');
    'g'.'gtaupi' := 0.0021774678714571 + 'o'[11] + 'g'.'pi' * (1.16273054608056e-6 * 'o'[1] * 'g'.'pi' - 7.1504691047224e-5 * 'o'[7]);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g5';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.h3ab_p' "Region 3 a b boundary for pressure/enthalpy"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    constant Real[:] 'n' = {2014.64004206875, 3.74696550136983, -0.0219921901054187, 8.7513168600995e-5};
    constant Real 'hstar'(unit = "J/kg", quantity = "SpecificEnergy") = 1000.0;
    constant Real 'pstar'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e6;
    Real 'pi' = 'p' / 'pstar';
  algorithm
    'h' := ('n'[1] + 'n'[2] * 'pi' + 'n'[3] * 'pi' ^ 2.0 + 'n'[4] * 'pi' ^ 3.0) * 'hstar';
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.h3ab_p';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat' "Region 4 saturation pressure as a function of temperature"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'p_sat'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real[8] 'o';
    Real 'Tlim' = min('T', 647.096);
  algorithm
    assert('T' >= 273.16, "IF97 medium function psat: input temperature (= 273.16 K).\nlower than the triple point temperature 273.16 K", AssertionLevel.error);
    'o'[1] := 'Tlim' - 650.17534844798;
    'o'[2] := 1.0 / 'o'[1];
    'o'[3] := -0.23855557567849 * 'o'[2];
    'o'[4] := 'o'[3] + 'Tlim';
    'o'[5] := -4823.2657361591 * 'o'[4];
    'o'[6] := 'o'[4] * 'o'[4];
    'o'[7] := 14.91510861353 * 'o'[6];
    'o'[8] := 405113.40542057 + 'o'[5] + 'o'[7];
    'p_sat' := 1.6e7 * 'o'[8] * 'o'[8] * 'o'[8] * 'o'[8] / (3.2325550322333e6 - 12020.82470247 * 'o'[4] + 17.073846940092 * 'o'[6] + sqrt((12020.82470247 * 'o'[4] - 3.2325550322333e6 - 17.073846940092 * 'o'[6]) ^ 2.0 - 4.0 * (1167.0521452767 * 'o'[4] - 724213.16703206 + 'o'[6]) * 'o'[8])) ^ 4.0;
    annotation(derivative(order = 1) = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat_der');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat_der' "Derivative function for psat"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'der_T'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'der_psat'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dpt';
  algorithm
    'dpt' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dptofT'('T');
    'der_psat' := 'dpt' * 'der_T';
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat_der';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tph1' "Inverse function for region 1: T(p,h)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
