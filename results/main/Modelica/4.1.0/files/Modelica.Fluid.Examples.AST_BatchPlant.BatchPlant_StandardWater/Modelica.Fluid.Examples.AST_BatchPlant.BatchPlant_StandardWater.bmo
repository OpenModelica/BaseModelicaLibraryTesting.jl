    assert('p' > 611.657, "IF97 medium function tph1 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'pi' := 'p' / 1e6;
    'eta1' := 'h' / 2.5e6 + 1.0;
    'o'[1] := 'eta1' * 'eta1';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
    'T' := 'eta1' * (404.21188637945 + 43.211039183559 * 'pi' + 'eta1' * (113.49746881718 - 54.010067170506 * 'pi' + 'eta1' * (30.535892203916 * 'pi' + 'eta1' * ('o'[1] * ('o'[2] * ('pi' * (0.0093965400878363 + (6.6456186191635e-8 * 'pi' - 2.5858641282073e-5) * 'pi') + 'o'[2] * 'o'[3] * ('o'[1] * 'o'[3] * ('pi' * (1.157364750534e-7 + 'pi' * ('pi' * (8.0670734103027e-11 + 'pi' * ((5.8265442020601e-15 - 1.5020185953503e-17 * 'pi') * 'pi' - 9.3477771213947e-13)) - 4.0644363084799e-9)) - 1.0866707695377e-6) - 1.528548241314e-4)) - 5.8457616048039) - 6.5964749423638 * 'pi')))) - (238.72489924521 + 13.391744872602 * 'pi');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tph1';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tph2' "Reverse function for region 2: T(p,h)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
