    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
