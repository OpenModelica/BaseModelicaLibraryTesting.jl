  algorithm
    'pi1' := 7.1 - 'p' / 1.653e7;
    assert('p' > 611.657, "IF97 medium function hlowerofp1 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'o'[1] := 'pi1' * 'pi1';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
    'h' := 639675.036 * (0.173379420894777 + 'pi1' * ('pi1' * ('pi1' * ('pi1' * ('pi1' * (1.73545618580828e-11 + 'o'[1] * 'pi1' * (8.43755552264362e-14 + 'o'[2] * 'o'[3] * 'pi1' * (5.35429206228374e-35 + 'o'[1] * ('o'[1] * 'o'[2] * ('pi1' * (1.73894459122923e-45 + (9.64504638626269e-49 * 'pi1' - 7.06381628462585e-47) * 'pi1') - 1.43870236842915e-44) - 8.12140581014818e-38)))) - 2.41630417490008e-7) - 4.18695814670391e-6) - 1.7146768241932e-4) - 0.022914084306349));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hlowerofp1';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hlowerofp2' "Explicit lower specific enthalpy limit of region 2 as function of pressure (meets region 4 saturation pressure curve at 623.15 K)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pi';
    Real 'q1';
    Real 'q2';
    Real[18] 'o';
  algorithm
    'pi' := 'p' / 1e6;
    assert('p' > 611.657, "IF97 medium function hlowerofp2 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'q1' := 572.54459862746 + 31.3220101646784 * sqrt('pi' - 13.91883977887);
    'q2' := 540.0 / 'q1' - 0.5;
    'o'[1] := 'q1' * 'q1';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
