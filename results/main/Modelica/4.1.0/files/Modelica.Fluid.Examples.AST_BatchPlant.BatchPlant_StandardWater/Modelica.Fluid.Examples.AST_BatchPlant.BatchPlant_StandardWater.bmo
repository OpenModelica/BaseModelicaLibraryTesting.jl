  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p' "Properties on the dew curve"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output 'Modelica.Media.Common.IF97PhaseBoundaryProperties' 'bpro';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Real 'plim'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = min('p', 2.20639999999999e7);
  algorithm
    'bpro'.'R_s' := 461.526;
    'bpro'.'T' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('plim');
    'bpro'.'dpT' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dptofT'('bpro'.'T');
    'bpro'.'region3boundary' := 'bpro'.'T' > 623.15;

    if not 'bpro'.'region3boundary' then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g2'('p', 'bpro'.'T', true);
      'bpro'.'d' := 'p' / ('bpro'.'R_s' * 'bpro'.'T' * 'g'.'pi' * 'g'.'gpi');
      'bpro'.'h' := if 'p' > 'plim' then 2.08754684511715e6 else 'bpro'.'R_s' * 'bpro'.'T' * 'g'.'tau' * 'g'.'gtau';
