  model 'BatchPlant_StandardWater' "Model of an experimental batch plant"
    parameter Real 'pipeDiameter'(unit = "m", quantity = "Length") = 0.01 "Pipe diameter";
    parameter Real 'B5.crossArea'(unit = "m2", quantity = "Area") = 0.05 "Tank area";
    parameter Real 'B5.top_pipeArea[1]'(unit = "m2", quantity = "Area") = 1e-4 "Area of outlet pipe";
    parameter Real 'B5.side_pipeArea[1]'(unit = "m2", quantity = "Area") = 1e-4 "Area of outlet pipe";
    parameter Real 'B5.bottom_pipeArea[1]'(unit = "m2", quantity = "Area") = 1e-4 "Area of outlet pipe";
    parameter Real 'B5.height'(min = 0.0, unit = "m", quantity = "Length") = 0.5 "Height of Tank";
    parameter Real 'B5.V0'(unit = "m3", quantity = "Volume") = 0.001 "Volume of the liquid when the level is zero";
    constant Real 'B5.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665;
    parameter Real 'B5.side_heights[1]'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Side heights";
    parameter Real 'B5.bottom_heights[1]'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Bottom heights";
    parameter Real 'B5.top_heights[1]'(min = 0.0, unit = "m", quantity = "Length") = 0.5 "Top heights";
    parameter Real 'B5.level_start'(min = 0.0, unit = "m", quantity = "Length") = 9e-4 "Initial tank level";
    parameter 'Modelica.Fluid.Examples.AST_BatchPlant.BaseClasses.Init' 'B5.initType' = 'Modelica.Fluid.Examples.AST_BatchPlant.BaseClasses.Init'.'InitialValues' "Initialization option";
    parameter Boolean 'B5.use_T_start' = true "= true, if T_start is used, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'B5.T_start'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Start value of temperature";
    parameter Real 'B5.h_start'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.B5.Medium.specificEnthalpy_pTX'(101325.0, 'B5.T_start', fill(0.0, 0), 0) "Start value of specific enthalpy";
    parameter Real 'B5.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    parameter Real 'B5.p_ambient'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Tank surface pressure";
    parameter Real 'B5.T_ambient'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Tank surface Temperature";
    parameter Integer 'B5.n_TopPorts' = 1 "Number of top connectors";
    parameter Integer 'B5.n_SidePorts' = 1 "Number of side connectors";
    parameter Integer 'B5.n_BottomPorts' = 1 "Number of bottom connectors";
    Real 'B5.medium.p'(stateSelect = StateSelect.prefer, nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'B5.medium.h'(stateSelect = StateSelect.prefer, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'B5.medium.d'(stateSelect = StateSelect.default, nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'B5.medium.T'(stateSelect = StateSelect.default, nominal = 500.0, start = 'B5.T_start', max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'B5.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'B5.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'B5.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'B5.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Integer 'B5.medium.state.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'B5.medium.state.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'B5.medium.state.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'B5.medium.state.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'B5.medium.state.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'B5.medium.preferredMediumStates' = true "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'B5.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'B5.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'B5.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'B5.medium.sat.psat'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Saturation pressure";
    Real 'B5.medium.sat.Tsat'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Saturation temperature";
    Integer 'B5.medium.phase'(fixed = false, start = 1, max = 2, min = 0) "2 for two-phase, 1 for one-phase, 0 if not known";
    Real 'B5.level'(stateSelect = StateSelect.prefer, max = 0.5, min = 0.0, unit = "m", quantity = "Length") "Level height of tank";
    Real 'B5.V'(stateSelect = StateSelect.never, unit = "m3", quantity = "Volume") "Actual tank volume";
    Real 'B5.U'(unit = "J", quantity = "Energy") "Internal energy of tank volume";
    Real 'B5.m'(unit = "kg") "Mass of tank volume";
    Real 'B5.H_flow_BottomPorts[1]';
    Real 'B5.H_flow_SidePorts[1]';
    Real 'B5.H_flow_TopPorts[1]';
    Real 'B5.m_flow_BottomPorts[1]';
    Real 'B5.m_flow_SidePorts[1]';
    Real 'B5.m_flow_TopPorts[1]';
    Real 'B5.m_flow_BottomPorts_pos[1]';
    Real 'B5.m_flow_SidePorts_pos[1]';
    Real 'B5.m_flow_TopPorts_pos[1]';
    Real 'B5.m_flow_pos';
    Real 'B5.BottomFluidPort[1].m_flow'(start = 0.0, max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'B5.BottomFluidPort[1].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'B5.BottomFluidPort[1].h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'B5.TopFluidPort[1].m_flow'(start = 0.0, max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'B5.TopFluidPort[1].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'B5.TopFluidPort[1].h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'B5.SideFluidPort[1].m_flow'(start = 0.0, max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'B5.SideFluidPort[1].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'B5.SideFluidPort[1].h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'B5.InnerTankTop[1].port.m_flow'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'B5.InnerTankTop[1].port.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'B5.InnerTankTop[1].port.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Boolean 'B5.InnerTankTop[1].m_flow_negative'(fixed = true, start = true) "= true, if mass flow out of tank";
    constant Real 'B5.InnerTankTop[1].g'(unit = "m/s2", quantity = "Acceleration") = 9.80665;
    Real 'B5.InnerTankTop[1].aboveLevel';
