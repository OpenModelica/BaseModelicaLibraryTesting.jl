  function 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.P1.efficiencyCharacteristic'
    input Real 'V_flow'(unit = "m3/s", quantity = "VolumeFlowRate");
    input Real 'eta_nominal' = 0.8;
    output Real 'eta';
  algorithm
    'eta' := 'eta_nominal';
  end 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.P1.efficiencyCharacteristic';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.P1.flowCharacteristic'
    input Real 'V_flow'(unit = "m3/s", quantity = "VolumeFlowRate");
    input Real[3] 'V_flow_nominal'(unit = {"m3/s", "m3/s", "m3/s"}, quantity = {"VolumeFlowRate", "VolumeFlowRate", "VolumeFlowRate"}) = {0.0, 1e-4, 1.5e-4};
    input Real[3] 'head_nominal'(unit = {"m", "m", "m"}, quantity = {"Length", "Length", "Length"}) = {10.0, 5.0, 0.0};
    output Real 'head'(unit = "m", quantity = "Length");
    Real[3] 'V_flow_nominal2' = {'V_flow_nominal'[1] ^ 2.0, 'V_flow_nominal'[2] ^ 2.0, 'V_flow_nominal'[3] ^ 2.0};
    Real 'V_flow_min'(unit = "m3/s", quantity = "VolumeFlowRate") = min('V_flow_nominal');
    Real 'V_flow_max'(unit = "m3/s", quantity = "VolumeFlowRate") = max('V_flow_nominal');
    Real[3] 'c' = 'Modelica.Math.Matrices.solve'({{1.0, 'V_flow_nominal'[1], 'V_flow_nominal2'[1]}, {1.0, 'V_flow_nominal'[2], 'V_flow_nominal2'[2]}, {1.0, 'V_flow_nominal'[3], 'V_flow_nominal2'[3]}}, 'head_nominal');
  algorithm
    assert(max({'c'[2] + 2.0 * 'c'[3] * 'V_flow_nominal'[1], 'c'[2] + 2.0 * 'c'[3] * 'V_flow_nominal'[2], 'c'[2] + 2.0 * 'c'[3] * 'V_flow_nominal'[3]}) <= (-2.2250738585072014e-308), "Wrong pump curve -- head_nominal must be monotonically decreasing with increasing V_flow_nominal", AssertionLevel.warning);

    if 'V_flow' < 'V_flow_min' then
      'head' := max('head_nominal') + ('V_flow' - 'V_flow_min') * ('c'[2] + 2.0 * 'c'[3] * 'V_flow_min');
    elseif 'V_flow' > 'V_flow_max' then
      'head' := min('head_nominal') + ('V_flow' - 'V_flow_max') * ('c'[2] + 2.0 * 'c'[3] * 'V_flow_max');
    elseif true then
      'head' := 'c'[1] + 'V_flow' * ('c'[2] + 'V_flow' * 'c'[3]);
    end if;
  end 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.P1.flowCharacteristic';

  function 'Modelica.Fluid.Examples.AST_BatchPlant.BatchPlant_StandardWater.P1.Medium.specificEnthalpy_pTX' "Return specific enthalpy from pressure, temperature and mass fraction"
