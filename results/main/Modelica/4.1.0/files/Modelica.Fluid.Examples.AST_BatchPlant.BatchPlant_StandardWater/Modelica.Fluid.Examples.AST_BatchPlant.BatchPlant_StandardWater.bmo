    'B6.heatTransfer.surfaceAreas[1]' = 0.05 + 0.7926654595212022 * 'B6.level';
    'B6.heatTransfer.Ts[1]' = 'B6.heatTransfer.states[1].T';
    'B6.heatTransfer.Ts[1]' = 'B6.heatTransfer.heatPorts[1].T';
    'B6.heatTransfer.Q_flows[1]' = 'B6.heatTransfer.heatPorts[1].Q_flow' + 4.9 * 'B6.heatTransfer.surfaceAreas[1]' * (293.15 - 'B6.heatTransfer.heatPorts[1].T');
    'B6.portsData_diameter[1]' = 'B6.portsData[1].diameter';
    'B6.portsData_height[1]' = 'B6.portsData[1].height';
    assert('B6.level' <= 0.5, "Tank starts to overflow (level = height = " + String('B6.level') + ")", AssertionLevel.error);
    assert('B6.m' >= 0.0, "Mass in tank is zero", AssertionLevel.error);
    'B6.bottomArea[1]' = 3.141592653589793 * ('B6.portsData_diameter2[1]' / 2.0) ^ 2.0;
    'B6.ports_emptyPipeHysteresis[1]' = 'B6.portsData_diameter2[1]' * 0.1;
    'B6.medium.p' = 101325.0;
    'B6.V' = 0.05 * 'B6.level' + 1e-4 "Volume of fluid";
    'B6.mb_flow' = 'B6.topPorts[1].m_flow' + 'B6.ports[1].m_flow';
    'B6.Hb_flow' = 'B6.H_flow_top[1]' + 'B6.port_b_H_flow_bottom[1]';
    'B6.Qb_flow' = 'B6.heatTransfer.Q_flows[1]';
    'B6.Wb_flow' = -101325.0 * der('B6.V');
    'B6.H_flow_top[1]' = 'B6.topPorts[1].m_flow' * 'B5.Condensed.h_outflow';
    'B6.topPorts[1].p' = 101325.0;
    'B6.topPorts[1].h_outflow' = 104302.00492025427;
    'B6.port_b_H_flow_bottom[1]' = smooth(0, 'B6.ports[1].m_flow' * (if 'B6.ports[1].m_flow' > 0.0 then 'pipeB6Pump.port_a.h_outflow' else 'B6.ports[1].h_outflow'));
    'B6.aboveLevel[1]' = 'B6.level' >= 'B6.portsData_height2[1]' + 'B6.ports_emptyPipeHysteresis[1]' or pre('B6.aboveLevel[1]') and 'B6.level' >= 'B6.portsData_height2[1]' - 'B6.ports_emptyPipeHysteresis[1]';
    'B6.levelAbovePort[1]' = if 'B6.aboveLevel[1]' then 'B6.level' - 'B6.portsData_height2[1]' else 0.0;
    'B6.ports[1].h_outflow' = 'B6.medium.h';
    'B6.ports_m_flow_out[1]' = pre('B6.ports_m_flow_out[1]') and not 'B6.ports[1].p' > 101325.0 or 'B6.ports[1].m_flow' < (-1e-6);

    if 'B6.aboveLevel[1]' then
      'B6.ports[1].p' = 101325.0 + 'B6.levelAbovePort[1]' * 9.80665 * 'B6.medium.d' - smooth(2, noEvent(if 'B6.ports[1].m_flow' < 0.0 then 'B6.ports[1].m_flow' ^ 2.0 / (2.0 * 'B6.medium.d' * 'B6.bottomArea[1]' ^ 2.0) else 0.0));
    elseif true then
      if pre('B6.ports_m_flow_out[1]') then
        'B6.ports[1].m_flow' = 0.0;
      elseif true then
        'B6.ports[1].p' = 101325.0;
      end if;
    end if;

    'B6.zetas_out[1]' = 0.0;
    'B6.m' = 'B6.fluidVolume' * 'B6.medium.d';
    'B6.U' = 'B6.m' * 'B6.medium.u';
    der('B6.U') = 'B6.Hb_flow' + 'B6.Qb_flow' + 'B6.Wb_flow';
    der('B6.m') = 'B6.mb_flow';
    0.0 = 'multiPort.port_a.m_flow' + 'multiPort.ports_b[1].m_flow' + 'multiPort.ports_b[2].m_flow' + 'multiPort.ports_b[3].m_flow';
    'multiPort.ports_b[1].p' = 'multiPort.port_a.p';
    'multiPort.ports_b[2].p' = 'multiPort.port_a.p';
    'multiPort.ports_b[3].p' = 'multiPort.port_a.p';
    'multiPort.port_a.h_outflow' = (max('multiPort.ports_b[1].m_flow', 1e-10) * 'V18.port_b.h_outflow' + max('multiPort.ports_b[2].m_flow', 1e-10) * 'V10.port_b.h_outflow' + max('multiPort.ports_b[3].m_flow', 1e-10) * 'V19.port_b.h_outflow') / (max('multiPort.ports_b[1].m_flow', 1e-10) + max('multiPort.ports_b[2].m_flow', 1e-10) + max('multiPort.ports_b[3].m_flow', 1e-10));
    'multiPort.ports_b[1].h_outflow' = 'volume4.port_3.h_outflow';
    'multiPort.ports_b[2].h_outflow' = 'volume4.port_3.h_outflow';
    'multiPort.ports_b[3].h_outflow' = 'volume4.port_3.h_outflow';
    'volume4.medium.MM' = 0.018015268;
    'volume4.medium.phase' = if ('volume4.medium.h' < ('Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boilingcurve_p'('volume4.medium.sat.psat')).h or 'volume4.medium.h' > ('Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p'('volume4.medium.sat.psat')).h) or 'volume4.medium.p' > 2.2064e7 then 1 else 2;
    'volume4.medium.d' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('volume4.medium.p', 'volume4.medium.h', 'volume4.medium.phase', 0)).rho;
    'volume4.medium.T' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('volume4.medium.p', 'volume4.medium.h', 'volume4.medium.phase', 0)).T;
    'volume4.medium.sat.Tsat' = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('volume4.medium.p');
    'volume4.medium.sat.psat' = 'volume4.medium.p';
    'volume4.medium.u' = 'volume4.medium.h' - 'volume4.medium.p' / 'volume4.medium.d';
    'volume4.medium.R_s' = 461.5231157345669;
    'volume4.medium.h' = 'volume4.medium.state.h';
    'volume4.medium.p' = 'volume4.medium.state.p';
    'volume4.medium.T' = 'volume4.medium.state.T';
    'volume4.medium.d' = 'volume4.medium.state.d';
    'volume4.medium.phase' = 'volume4.medium.state.phase';
    'volume4.medium.X[1]' = 1.0;
    assert('volume4.medium.X[1]' >= (-1e-5) and 'volume4.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('volume4.medium.X[1]') + "of substance " + "water" + "\nof medium " + "WaterIF97" + " is not in the range 0..1", AssertionLevel.error);
    assert('volume4.medium.p' >= 0.0, "Pressure (= " + String('volume4.medium.p') + " Pa) of medium \"" + "WaterIF97" + "\" is negative\n(Temperature = " + String('volume4.medium.T') + " K)", AssertionLevel.error);
    'volume4.port_1.h_outflow' = 'volume4.medium.h';
    'volume4.port_2.h_outflow' = 'volume4.medium.h';
    'volume4.port_3.h_outflow' = 'volume4.medium.h';
    'volume4.mb_flow' = 'volume4.port_1.m_flow' + 'volume4.port_2.m_flow' + 'volume4.port_3.m_flow' "Mass balance";
    'volume4.port_1.p' = 'volume4.medium.p';
    'volume4.port_2.p' = 'volume4.medium.p';
    'volume4.port_3.p' = 'volume4.medium.p';
    'volume4.Hb_flow' = smooth(0, 'volume4.port_1.m_flow' * (if 'volume4.port_1.m_flow' > 0.0 then 'V23.port_a.h_outflow' else 'volume4.port_1.h_outflow')) + smooth(0, 'volume4.port_2.m_flow' * (if 'volume4.port_2.m_flow' > 0.0 then 'V21.port_a.h_outflow' else 'volume4.port_2.h_outflow')) + smooth(0, 'volume4.port_3.m_flow' * (if 'volume4.port_3.m_flow' > 0.0 then 'multiPort.port_a.h_outflow' else 'volume4.port_3.h_outflow'));
    'volume4.Qb_flow' = 0.0;
    'volume4.Wb_flow' = 0.0;
    'volume4.m' = 'volume4.fluidVolume' * 'volume4.medium.d';
    'volume4.U' = 'volume4.m' * 'volume4.medium.u';
    der('volume4.U') = 'volume4.Hb_flow' + 'volume4.Qb_flow' + 'volume4.Wb_flow';
    der('volume4.m') = 'volume4.mb_flow';
    'controller.sensors.LIS_301' = 'B3.level';
    'controller.sensors.QI_302' = 0.0;
    'controller.sensors.LIS_501' = 'B5.level';
    'controller.sensors.QIS_502' = 0.0;
    'controller.sensors.TI_503' = 'B5.medium.T';
    'controller.sensors.LIS_601' = 'B6.level';
    'controller.sensors.TIS_602' = 'B6.medium.T';
    'controller.sensors.LIS_701' = 'B7.level';
    'controller.sensors.TIS_702' = 'B7.medium.T';
    'P1_on.u' = 'controller.actuators.P1';
    'P2_on.u' = 'controller.actuators.P2';
    'V1.open' = 'controller.actuators.V1';
    'V2.open' = 'controller.actuators.V2';
    'V3.open' = 'controller.actuators.V3';
    'V4.open' = 'controller.actuators.V4';
    'V5.open' = 'controller.actuators.V5';
    'V6.open' = 'controller.actuators.V6';
    'V8.open' = 'controller.actuators.V8';
    'V9.open' = 'controller.actuators.V9';
    'V10.open' = 'controller.actuators.V10';
    'V11.open' = 'controller.actuators.V11';
    'V12.open' = 'controller.actuators.V12';
    'V15.open' = 'controller.actuators.V15';
    'V18.open' = 'controller.actuators.V18';
    'V19.open' = 'controller.actuators.V19';
    'V20.open' = 'controller.actuators.V20';
    'V21.open' = 'controller.actuators.V21';
    'V22.open' = 'controller.actuators.V22';
    'V23.open' = 'controller.actuators.V23';
    'V24.open' = 'controller.actuators.V24';
    'V25.open' = 'controller.actuators.V25';
    'HeatB5.Q_flow' = if 'controller.actuators.T5_Heater' then 2e4 else 0.0;
    'CoolingB6.Q_flow' = if 'controller.actuators.T6_Cooling' then -2000.0 else 0.0;
    'CoolingB7.Q_flow' = if 'controller.actuators.T7_Cooling' then -2000.0 else 0.0;
    annotation(experiment(StopTime = 3600, Interval = 1));
  end 'BatchPlant_StandardWater';
end 'BatchPlant_StandardWater';
