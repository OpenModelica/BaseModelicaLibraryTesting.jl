  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13' "Density at the boundary between regions 1 and 3"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'p2';
    Real[3] 'o';
  algorithm
    'p2' := 7.1 - 6.04960677555959e-8 * 'p';
    'o'[1] := 'p2' * 'p2';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
    'd' := 57.4756752485113 / (0.0737412153522555 + 'p2' * (0.00145092247736023 + 'p2' * (1.02697173772229e-4 + 'p2' * (1.14683182476084e-5 + 'p2' * (1.99080616601101e-6 + 'o'[1] * 'p2' * (1.13217858826367e-8 + 'o'[2] * 'o'[3] * 'p2' * (1.35549330686006e-17 + 'o'[1] * ('o'[1] * 'o'[2] * ('p2' * (3.29199117056433e-22 + (2.73712834080283e-24 * 'p2' - 5.17859076694812e-23) * 'p2') - 7.02987180039442e-22) - 3.11228834832975e-19))))))));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp23' "Density at the boundary between regions 2 and 3"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[13] 'o';
    Real 'taug';
    Real 'pi';
    Real 'gpi23';
  algorithm
    'pi' := 'p' / 1e6;
    'T' := 572.54459862746 + 31.3220101646784 * ('pi' - 13.91883977887) ^ 0.5;
    'o'[1] := ('pi' - 13.91883977887) ^ 0.5;
    'taug' := 540.0 / (572.54459862746 + 31.3220101646784 * 'o'[1]) - 0.5;
    'o'[2] := 'taug' * 'taug';
    'o'[3] := 'o'[2] * 'taug';
    'o'[4] := 'o'[2] * 'o'[2];
    'o'[5] := 'o'[4] * 'o'[4];
    'o'[6] := 'o'[5] * 'o'[5];
    'o'[7] := 'o'[4] * 'o'[5] * 'o'[6] * 'taug';
    'o'[8] := 'o'[4] * 'o'[5] * 'taug';
    'o'[9] := 'o'[2] * 'o'[4] * 'o'[5];
    'o'[10] := 'pi' * 'pi';
    'o'[11] := 'o'[10] * 'o'[10];
    'o'[12] := 'o'[4] * 'o'[6] * 'taug';
    'o'[13] := 'o'[6] * 'o'[6];
    'gpi23' := (1.0 + 'pi' * ('taug' * ('taug' * ((-(0.057581259083432 + 0.05032527872793 * 'o'[3])) * 'taug' - 0.045996013696365) - 0.017834862292358) - 0.0017731742473213 + 'pi' * ('taug' * (('o'[2] * ('o'[3] * (-(0.087594591301146 + 5.3349095828174e-5 * 'o'[7])) - 0.007878555448671) - 3.789797503263e-4) * 'taug' - 6.6065283340406e-5) + 'pi' * (6.1445213076927e-8 + (1.31612001853305e-6 + 'o'[2] * ('o'[3] * (-(0.0045101773626444 + 0.122004760687947 * 'o'[7])) - 9.683303171571e-5)) * 'taug' + 'pi' * ('taug' * ((5.116287140914e-8 + 1.92901490874028e-6 * 'taug') * 'taug' - 3.15389238237468e-9) + 'pi' * (1.14610381688305e-5 * 'o'[2] * 'o'[4] * 'taug' + 'pi' * ('o'[3] * ('o'[8] * (-(0.012702883392813 + 143.374451604624 * 'o'[2] * 'o'[6] * 'taug')) - 1.00288598706366e-10) + 'pi' * ('o'[2] * 'o'[5] * (-(8.8352662293707e-6 + 0.272627897050173 * 'o'[9])) * 'taug' - 4.1341695026989e-17 + 'pi' * ('o'[5] * (9.0049690883672e-11 - 65.8490727183984 * 'o'[4] * 'o'[5] * 'o'[6]) + 'pi' * (1.78287415218792e-7 * 'o'[8] + 'pi' * ('o'[4] * (1.0406965210174e-18 + 'o'[2] * (-(1.0234747095929e-12 + 1.0018179379511e-8 * 'o'[4])) * 'o'[4]) + 'o'[10] * 'o'[11] * ((1.71088510070544 * 'o'[12] - 1.29412653835176e-9) * 'o'[7] + 'o'[10] * ('o'[10] * ('o'[4] * 'o'[6] * (1.78371690710842e-23 + 'o'[2] * 'o'[4] * 'o'[5] * (6.1258633752464e-12 - 8.4004935396416e-5 * 'o'[8]) * 'taug') + 'pi' * ('pi' * (8.32192847496054e-5 * 'o'[13] * 'o'[4] * 'o'[6] * 'taug' + 'pi' * ('o'[2] * 'o'[5] * 'o'[6] * (1.75410265428146e-27 + (1.32995316841867e-15 - 2.26487297378904e-5 * 'o'[2] * 'o'[6]) * 'o'[9]) * 'pi' - 2.93678005497663e-14 * 'o'[13] * 'o'[2] * 'o'[4] * 'taug')) - 1.24017662339842e-24 * 'o'[12])) - 6.05920510335078 * 'o'[13] * 'o'[5] * 'o'[6] * 'taug'))))))))))))) / 'pi';
    'd' := 'p' / (461.526 * 'T' * 'pi' * 'gpi23');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp23';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofpt3' "Inverse iteration in region 3: (d) = f(p,T)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'delp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    output Integer 'error' = 0;
    Real 'dguess'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Integer 'i' = 0;
    Real 'dp';
    Real 'deld'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'Modelica.Media.Common.NewtonDerivatives_pT' 'nDerivs';
    Boolean 'found' = false;
    Boolean 'supercritical';
    Boolean 'liquid';
    Real 'dmin'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'dmax'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Tmax'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'damping';
  algorithm
    'found' := false;
    assert('p' >= 1.65292e7, "BaseIF97.dofpt3: function called outside of region 3! p too low\np = " + String('p') + " Pa < " + "1.65292e+07" + " Pa", AssertionLevel.error);
    assert('T' >= 623.15, "BaseIF97.dofpt3: function called outside of region 3! T too low\nT = " + String('T') + " K < " + "623.15" + " K", AssertionLevel.error);
    assert('p' >= 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofT'('T'), "BaseIF97.dofpt3: function called outside of region 3! T too high\np = " + String('p') + " Pa, T = " + String('T') + " K", AssertionLevel.error);
    'supercritical' := 'p' > 2.2064e7;
    'damping' := 1.0;
    'Tmax' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofp'('p');

    if 'supercritical' then
      'dmax' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13'('p');
      'dmin' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp23'('p');
      'dguess' := 'dmax' - ('T' - 623.15) / (623.15 - 'Tmax') * ('dmax' - 'dmin');
    elseif true then
      'liquid' := 'T' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('p');

      if 'liquid' then
        'dmax' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13'('p');
        'dmin' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b'('p');
        'dguess' := 1.1 * 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_T'('T') "Guess: 10 percent more than on the phase boundary for same T";
      elseif true then
        'dmax' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b'('p');
        'dmin' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp23'('p');
        'dguess' := 0.9 * 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_T'('T') "Guess: 10% less than on the phase boundary for same T";
      end if;
    end if;

    while 'i' < 50 and not 'found' loop
      'd' := 'dguess';
      'f' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('d', 'T');
      'nDerivs' := 'Modelica.Media.Common.Helmholtz_pT'('f');
      'dp' := 'nDerivs'.'p' - 'p';

      if abs('dp' / 'p') <= 'delp' then
        'found' := true;
      end if;

      'deld' := 'dp' / 'nDerivs'.'pd' * 'damping';
      'd' := 'd' - 'deld';

      if 'd' > 'dmin' and 'd' < 'dmax' then
        'dguess' := 'd';
      elseif true then
        if 'd' > 'dmax' then
          'dguess' := 'dmax' - 1.4901161193847656e-8;
        elseif true then
          'dguess' := 'dmin' + 1.4901161193847656e-8;
        end if;
      end if;

      'i' := 'i' + 1;
    end while;

    if not 'found' then
      'error' := 1;
    end if;

    assert('error' <> 1, "Error in inverse function dofpt3: iteration failed", AssertionLevel.error);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofpt3';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dtofph3' "Inverse iteration in region 3: (d,T) = f(p,h)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    input Real 'delp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'delh'(unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    output Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Integer 'error';
    Real 'Tguess'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'dguess'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Integer 'i';
    Real 'dh';
    Real 'dp';
    Real 'det';
    Real 'deld';
    Real 'delt';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'Modelica.Media.Common.NewtonDerivatives_ph' 'nDerivs';
    Boolean 'found' = false;
    Integer 'subregion';
  algorithm
    if 'p' < 2.2064e7 then
      'subregion' := if 'h' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p'('p', 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boilingcurve_p'('p')) + 10.0 then 1 else if 'h' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p'('p', 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p'('p')) - 10.0 then 2 else 0;
      assert('subregion' <> 0, "Inverse iteration of dt from ph called in 2 phase region: this can not work", AssertionLevel.error);
    elseif true then
      'subregion' := if 'h' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.h3ab_p'('p') then 1 else 2;
    end if;

    'T' := if 'subregion' == 1 then 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.T3a_ph'('p', 'h') else 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.T3b_ph'('p', 'h');
    'd' := if 'subregion' == 1 then 1.0 / 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.v3a_ph'('p', 'h') else 1.0 / 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.v3b_ph'('p', 'h');
    'i' := 0;
    'error' := 0;

    while 'i' < 50 and not 'found' loop
      'f' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('d', 'T');
      'nDerivs' := 'Modelica.Media.Common.Helmholtz_ph'('f');
      'dh' := 'nDerivs'.'h' - 'h';
      'dp' := 'nDerivs'.'p' - 'p';

      if abs('dh' / 'h') <= 'delh' and abs('dp' / 'p') <= 'delp' then
        'found' := true;
      end if;

      'det' := 'nDerivs'.'ht' * 'nDerivs'.'pd' - 'nDerivs'.'pt' * 'nDerivs'.'hd';
      'delt' := ('nDerivs'.'pd' * 'dh' - 'nDerivs'.'hd' * 'dp') / 'det';
      'deld' := ('nDerivs'.'ht' * 'dp' - 'nDerivs'.'pt' * 'dh') / 'det';
      'T' := 'T' - 'delt';
      'd' := 'd' - 'deld';
      'dguess' := 'd';
      'Tguess' := 'T';
      'i' := 'i' + 1;
      ('d', 'T') := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.fixdT'('dguess', 'Tguess');
    end while;

    if not 'found' then
      'error' := 1;
    end if;

    assert('error' <> 1, "Error in inverse function dtofph3: iteration failed", AssertionLevel.error);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dtofph3';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.fixdT' "Region limits for inverse iteration in region 3"
    input Real 'din'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'Tin'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'dout'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    output Real 'Tout'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'Tmin'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'Tmax'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    if 'din' > 765.0 then
      'dout' := 765.0;
    elseif 'din' < 110.0 then
      'dout' := 110.0;
    elseif true then
      'dout' := 'din';
    end if;

    if 'dout' < 390.0 then
      'Tmax' := 554.3557377 + 'dout' * 0.809344262;
    elseif true then
      'Tmax' := 1116.85 - 'dout' * 0.632948717;
    end if;

    if 'dout' < 322.0 then
      'Tmin' := 647.096 * (1.0 - ('dout' - 322.0) * ('dout' - 322.0) / 1e6);
    elseif true then
      'Tmin' := 647.096 * (1.0 - ('dout' - 322.0) * ('dout' - 322.0) / 1.44e6);
    end if;

    if 'Tin' < 'Tmin' then
      'Tout' := 'Tmin';
    elseif 'Tin' > 'Tmax' then
      'Tout' := 'Tmax';
    elseif true then
      'Tout' := 'Tin';
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.fixdT';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.tofph5' "Inverse iteration in region 5: (p,T) = f(p,h)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    input Real 'reldh'(unit = "J/kg", quantity = "SpecificEnergy");
    output Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Integer 'error';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    Real 'proh'(unit = "J/kg", quantity = "SpecificEnergy");
    constant Real 'Tguess'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 1500.0;
    Integer 'i';
    Real 'relerr';
    Real 'dh';
    Real 'dT';
    Boolean 'found';
  algorithm
    'i' := 0;
    'error' := 0;
    'T' := 'Tguess';
    'found' := false;

    while 'i' < 50 and not 'found' loop
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g5'('p', 'T');
      'proh' := 461.526 * 'T' * 'g'.'tau' * 'g'.'gtau';
      'dh' := 'proh' - 'h';
      'relerr' := 'dh' / 'h';

      if abs('relerr') < 'reldh' then
        'found' := true;
      end if;

      'dT' := 'dh' / (-461.526 * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'T' := 'T' - 'dT';
      'i' := 'i' + 1;
    end while;

    if not 'found' then
      'error' := 1;
    end if;

    assert('error' <> 1, "Error in inverse function tofph5: iteration failed", AssertionLevel.error);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.tofph5';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Isentropic.hofpT1' "Intermediate function for isentropic specific enthalpy in region 1"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real[13] 'o';
    Real 'pi1';
    Real 'tau';
    Real 'tau1';
  algorithm
    'tau' := 1386.0 / 'T';
    'pi1' := 7.1 - 'p' / 1.653e7;
    assert('p' > 611.657, "IF97 medium function hofpT1 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'tau1' := 'tau' - 1.222;
    'o'[1] := 'tau1' * 'tau1';
    'o'[2] := 'o'[1] * 'tau1';
    'o'[3] := 'o'[1] * 'o'[1];
    'o'[4] := 'o'[3] * 'o'[3];
    'o'[5] := 'o'[1] * 'o'[4];
    'o'[6] := 'o'[1] * 'o'[3];
    'o'[7] := 'o'[3] * 'tau1';
    'o'[8] := 'o'[3] * 'o'[4];
    'o'[9] := 'pi1' * 'pi1';
    'o'[10] := 'o'[9] * 'o'[9];
    'o'[11] := 'o'[10] * 'o'[10];
    'o'[12] := 'o'[4] * 'o'[4];
    'o'[13] := 'o'[12] * 'o'[12];
    'h' := 461.526 * 'T' * 'tau' * ('pi1' * (('o'[1] * (0.00424944110961118 + (0.018990068218419 + (-(0.021841717175414 + 1.5851507390979e-4 * 'o'[1])) * 'o'[1]) * 'o'[6]) - 0.00254871721114236) / 'o'[5] + 'pi1' * ((0.00141552963219801 + 'o'[3] * (4.7661393906987e-5 + 'o'[1] * (-(1.32425535992538e-5 + 1.2358149370591e-14 * 'o'[1] * 'o'[3] * 'o'[4])))) / 'o'[3] + 'pi1' * ((1.26718579380216e-4 - 5.11230768720618e-9 * 'o'[5]) / 'o'[7] + 'pi1' * ((1.1212640954e-5 + 'o'[2] * (1.30342445791202e-6 - 1.4341729937924e-12 * 'o'[8])) / 'o'[6] + 'pi1' * ('o'[9] * 'pi1' * ((1.40077319158051e-8 + 1.04549227383804e-9 * 'o'[7]) / 'o'[8] + 'o'[10] * 'o'[11] * 'pi1' * (1.9941018075704e-17 / ('o'[1] * 'o'[12] * 'o'[3] * 'o'[4]) + 'o'[9] * ('o'[10] * 'o'[9] * ('pi1' * (4.65957282962769e-22 / ('o'[13] * 'o'[4]) + 'pi1' * (3.83502057899078e-24 * 'pi1' / ('o'[1] * 'o'[13] * 'o'[4]) - 7.2912378325616e-23 / ('o'[13] * 'o'[4] * 'tau1'))) - 1.00075970318621e-21 / ('o'[1] * 'o'[13] * 'o'[3] * 'tau1')) - 4.48827542684151e-19 / 'o'[13]))) + 3.24135974880936e-6 / ('o'[4] * 'tau1')))))) + ('tau1' * (0.84548187169114 + 'o'[1] * (3.3855169168385 + 'tau1' * ('tau1' * (0.47316115539684 + (0.0040607314991784 * 'tau1' - 0.066465668798004) * 'tau1') - 1.91583926775744))) - 0.29265942426334) / 'o'[2]);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Isentropic.hofpT1';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Isentropic.hofpT2' "Intermediate function for isentropic specific enthalpy in region 2"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real[16] 'o';
    Real 'pi';
    Real 'tau';
    Real 'tau2';
  algorithm
    assert('p' > 611.657, "IF97 medium function hofpT2 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'pi' := 'p' / 1e6;
    'tau' := 540.0 / 'T';
    'tau2' := 'tau' - 0.5;
    'o'[1] := 'tau' * 'tau';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'tau2' * 'tau2';
    'o'[4] := 'o'[3] * 'tau2';
    'o'[5] := 'o'[3] * 'o'[3];
    'o'[6] := 'o'[5] * 'o'[5];
    'o'[7] := 'o'[6] * 'o'[6];
    'o'[8] := 'o'[5] * 'o'[6] * 'o'[7] * 'tau2';
    'o'[9] := 'o'[3] * 'o'[5];
    'o'[10] := 'o'[5] * 'o'[6] * 'tau2';
    'o'[11] := 'o'[3] * 'o'[7] * 'tau2';
    'o'[12] := 'o'[3] * 'o'[5] * 'o'[6];
    'o'[13] := 'o'[5] * 'o'[6] * 'o'[7];
    'o'[14] := 'pi' * 'pi';
    'o'[15] := 'o'[14] * 'o'[14];
    'o'[16] := 'o'[7] * 'o'[7];
