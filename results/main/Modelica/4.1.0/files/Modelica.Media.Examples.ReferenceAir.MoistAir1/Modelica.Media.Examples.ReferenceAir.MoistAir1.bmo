    'T' := 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.temperature'('Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.temperature_phX';

