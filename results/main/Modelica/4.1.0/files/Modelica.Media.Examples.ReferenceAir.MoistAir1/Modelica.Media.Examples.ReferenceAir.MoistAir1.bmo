  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.g2';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT' "Specific enthalpy as function or pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Integer 'region' = 0;
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    'Modelica.Media.Common.GibbsDerivs' 'g';
  algorithm
    'g' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.g2'('p', 'T', false);
    'h' := 'g'.'R_s' * 'T' * 'g'.'tau' * 'g'.'gtau';
    annotation(derivative(order = 1, noDerivative = 'region') = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT_der' "Derivative function of h_pT for region 2"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Integer 'region' = 0;
    input Real 'p_der';
    input Real 'T_der';
    output Real 'h_der';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'vt';
  algorithm
    'g' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.g2'('p', 'T', false);
    'vt' := 'g'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
    'rho' := max('p' / ('g'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi'), 1e-9);
    'h_der' := (1.0 / 'rho' - 'T' * 'vt') * 'p_der' - 'g'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau' * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT' "Density as function or pressure and temperature for region 2"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    'Modelica.Media.Common.GibbsDerivs' 'g';
  algorithm
    'g' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.g2'('p', 'T', false);
    'rho' := 'p' / ('g'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi');
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT_der' "Derivative function of rho_pT for region 2"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'p_der';
    input Real 'T_der';
    output Real 'rho_der';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'vp';
    Real 'vt';
  algorithm
    'g' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.g2'('p', 'T', false);
    'vt' := 'g'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
    'vp' := 'g'.'R_s' * 'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
    'd' := 'p' / ('g'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi');
    'rho_der' := (-'d' ^ 2.0 * 'vp') * 'p_der' + (-'d' ^ 2.0 * 'vt') * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT' "Specific enthalpy as function or pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_props_pT'('p', 'T', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.ice09BaseProp_pT'('p', 'T'));
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT_der' "Derivative function of h_pT"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input 'Modelica.Media.Common.AuxiliaryProperties' 'aux';
    input Real 'p_der';
    input Real 'T_der';
    output Real 'h_der';
  algorithm
    'h_der' := (1.0 / 'aux'.'rho' - 'aux'.'T' * 'aux'.'vt') * 'p_der' + 'aux'.'cp' * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_props_pT' "Specific enthalpy as function or pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input 'Modelica.Media.Common.AuxiliaryProperties' 'aux';
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'aux'.'h';
    annotation(derivative(order = 1, noDerivative = 'aux') = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_props_pT';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.ice09BaseProp_pT' "Intermediate property record for water (p and T preferred states)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.AuxiliaryProperties' 'aux';
    'Modelica.Media.Common.GibbsDerivs2' 'g';
  algorithm
    'aux'.'p' := 'p';
    'aux'.'T' := 'T';
    'aux'.'R_s' := 461.52364;
    'g' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Gibbs'('aux'.'p', 'T');
    'aux'.'rho' := 1.0 / 'g'.'gp';
    'aux'.'h' := 'g'.'g' - 'g'.'T' * 'g'.'gT';
    'aux'.'s' := -'g'.'gT';
    'aux'.'cp' := -'g'.'T' * 'g'.'gTT';
    'aux'.'cv' := 'aux'.'cp' - 'g'.'T' / 'g'.'gpp' * 'g'.'gTp' ^ 2.0;
    'aux'.'vt' := 1.0 / 'aux'.'rho' * 'g'.'gTp' / 'g'.'gp';
    'aux'.'vp' := 1.0 / 'aux'.'rho' * 'g'.'gpp' / 'g'.'gp';
    'aux'.'pd' := -1.0 / ('aux'.'rho' * 'aux'.'rho' * 'aux'.'vp');
    'aux'.'pt' := -'aux'.'vt' / 'aux'.'vp';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.ice09BaseProp_pT';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT' "Density as function or pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'rho' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_props_pT'('p', 'T', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.ice09BaseProp_pT'('p', 'T'));
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT_der' "Derivative function of rho_pT"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input 'Modelica.Media.Common.AuxiliaryProperties' 'aux';
    input Real 'p_der';
    input Real 'T_der';
    output Real 'rho_der';
  algorithm
    'rho_der' := (-'aux'.'rho' * 'aux'.'rho' * 'aux'.'vp') * 'p_der' + (-'aux'.'rho' * 'aux'.'rho' * 'aux'.'vt') * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_props_pT' "Density as function or pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input 'Modelica.Media.Common.AuxiliaryProperties' 'aux';
    output Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'rho' := 'aux'.'rho';
    annotation(derivative(order = 1, noDerivative = 'aux') = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_props_pT';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Gibbs' "Gibbs equation of state"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.GibbsDerivs2' 'g';
    constant Real[5] 'g_0' = {-632020.233449497, 0.655022213658955, -1.89369929326131e-8, 3.39746123271053e-15, -5.56464869058991e-22};
    constant Real 's_0' = -3327.33756492168;
    'Complex'[2] 't' = {'Complex'(0.0368017112855051, 0.0510878114959572), 'Complex'(0.337315741065416, 0.335449415919309)};
    constant 'Complex' 'r_1' = 'Complex'(44.7050716285388, 65.6876847463481);
    'Complex'[3] 'r_2' = {'Complex'(-72.597457432922, -78.100842711287), 'Complex'(-5.57107698030123e-5, 4.64578634580806e-5), 'Complex'(2.34801409215913e-11, -2.85651142904972e-11)};
    Real 'pi0' = 165.65656895940043;
    Real 'g0' = 0.0;
    Real 'g0p' = 0.0;
    Real 'g0pp' = 0.0;
    'Complex' 'r2';
    'Complex' 'r2p';
    'Complex' 'r2pp';
    'Complex'[12] 'o';
  algorithm
    'g'.'p' := 'p';
    'g'.'T' := 'T';
    'g'.'R_s' := 461.52364;
    'g'.'pi' := 'g'.'p' / 611.657;
    'g'.'theta' := 'g'.'T' / 273.16;
    'g0' := 'g_0'[1];

    for 'k' in 2:5 loop
      'g0' := 'g0' + 'g_0'['k'] * ('g'.'pi' - 'pi0') ^ ('k' - 1);
    end for;

    'r2' := 'r_2'[1];

    for 'k' in 2:3 loop
      'r2' := 'Complex'('r2'.'re' + 'r_2['k']'.'re' * ('g'.'pi' - 'pi0') ^ ('k' - 1), 'r2'.'im' + 'r_2['k']'.'im' * ('g'.'pi' - 'pi0') ^ ('k' - 1));
    end for;

    'g0p' := 'g_0'[2] / 611.657;

    for 'k' in 3:5 loop
      'g0p' := 'g0p' + 'g_0'['k'] * ('k' - 1) / 611.657 * ('g'.'pi' - 'pi0') ^ ('k' - 2);
    end for;

    'r2p' := 'Complex'('r_2[2]'.'re' * 611.657 / 374124.285649 + 'r_2[3]'.'re' * 305.8285 / 93531.07141225 * ('g'.'pi' - 'pi0'), 'r_2[2]'.'im' * 611.657 / 374124.285649 + 'r_2[3]'.'im' * 305.8285 / 93531.07141225 * ('g'.'pi' - 'pi0'));
    'g0pp' := 'g_0'[3] * 2.0 / 374124.285649;

    for 'k' in 4:5 loop
      'g0pp' := 'g0pp' + 'g_0'['k'] * ('k' - 1) * ('k' - 2) / 374124.285649 * ('g'.'pi' - 'pi0') ^ ('k' - 3);
    end for;

    'r2pp' := 'Complex'('r_2[3]'.'re' * 5.345817089982717e-6, 'r_2[3]'.'im' * 5.345817089982717e-6);
    'o'[1] := 'Complex'(('t[1]'.'re' - 'g'.'theta') * log(sqrt(('t[1]'.'re' - 'g'.'theta') ^ 2.0 + 't[1]'.'im' ^ 2.0)) - 't[1]'.'im' * 'Modelica.Math.atan3'('t[1]'.'im', 't[1]'.'re' - 'g'.'theta', 0.0), ('t[1]'.'re' - 'g'.'theta') * 'Modelica.Math.atan3'('t[1]'.'im', 't[1]'.'re' - 'g'.'theta', 0.0) + 't[1]'.'im' * log(sqrt(('t[1]'.'re' - 'g'.'theta') ^ 2.0 + 't[1]'.'im' ^ 2.0)));
    'o'[2] := 'Complex'(('t[1]'.'re' + 'g'.'theta') * log(sqrt(('t[1]'.'re' + 'g'.'theta') ^ 2.0 + 't[1]'.'im' ^ 2.0)) - 't[1]'.'im' * 'Modelica.Math.atan3'('t[1]'.'im', 't[1]'.'re' + 'g'.'theta', 0.0), ('t[1]'.'re' + 'g'.'theta') * 'Modelica.Math.atan3'('t[1]'.'im', 't[1]'.'re' + 'g'.'theta', 0.0) + 't[1]'.'im' * log(sqrt(('t[1]'.'re' + 'g'.'theta') ^ 2.0 + 't[1]'.'im' ^ 2.0)));
    'o'[3] := 'Complex'(('t[2]'.'re' - 'g'.'theta') * log(sqrt(('t[2]'.'re' - 'g'.'theta') ^ 2.0 + 't[2]'.'im' ^ 2.0)) - 't[2]'.'im' * 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re' - 'g'.'theta', 0.0), ('t[2]'.'re' - 'g'.'theta') * 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re' - 'g'.'theta', 0.0) + 't[2]'.'im' * log(sqrt(('t[2]'.'re' - 'g'.'theta') ^ 2.0 + 't[2]'.'im' ^ 2.0)));
    'o'[4] := 'Complex'(('t[2]'.'re' + 'g'.'theta') * log(sqrt(('t[2]'.'re' + 'g'.'theta') ^ 2.0 + 't[2]'.'im' ^ 2.0)) - 't[2]'.'im' * 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re' + 'g'.'theta', 0.0), ('t[2]'.'re' + 'g'.'theta') * 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re' + 'g'.'theta', 0.0) + 't[2]'.'im' * log(sqrt(('t[2]'.'re' + 'g'.'theta') ^ 2.0 + 't[2]'.'im' ^ 2.0)));
    'o'[5] := 'Complex'(2.0 * 't[1]'.'re' * log(sqrt('t[1]'.'re' ^ 2.0 + 't[1]'.'im' ^ 2.0)) - 2.0 * 't[1]'.'im' * 'Modelica.Math.atan3'('t[1]'.'im', 't[1]'.'re', 0.0), 2.0 * 't[1]'.'re' * 'Modelica.Math.atan3'('t[1]'.'im', 't[1]'.'re', 0.0) + 2.0 * 't[1]'.'im' * log(sqrt('t[1]'.'re' ^ 2.0 + 't[1]'.'im' ^ 2.0)));
    'o'[6] := 'Complex'(2.0 * 't[2]'.'re' * log(sqrt('t[2]'.'re' ^ 2.0 + 't[2]'.'im' ^ 2.0)) - 2.0 * 't[2]'.'im' * 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re', 0.0), 2.0 * 't[2]'.'re' * 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re', 0.0) + 2.0 * 't[2]'.'im' * log(sqrt('t[2]'.'re' ^ 2.0 + 't[2]'.'im' ^ 2.0)));
    'o'[7] := 'Complex'('g'.'theta' ^ 2.0 * 't[1]'.'re' / ('t[1]'.'re' * 't[1]'.'re' + 't[1]'.'im' * 't[1]'.'im'), 'g'.'theta' ^ 2.0 * 't[1]'.'im' / (-('t[1]'.'re' * 't[1]'.'re' + 't[1]'.'im' * 't[1]'.'im')));
    'o'[8] := 'Complex'('g'.'theta' ^ 2.0 * 't[2]'.'re' / ('t[2]'.'re' * 't[2]'.'re' + 't[2]'.'im' * 't[2]'.'im'), 'g'.'theta' ^ 2.0 * 't[2]'.'im' / (-('t[2]'.'re' * 't[2]'.'re' + 't[2]'.'im' * 't[2]'.'im')));
    'o'[9] := 'Complex'('o[1]'.'re' + 'o[2]'.'re' - 'o[5]'.'re' - 'o[7]'.'re', 'o[1]'.'im' + 'o[2]'.'im' - 'o[5]'.'im' - 'o[7]'.'im');
    'o'[10] := 'Complex'('o[3]'.'re' + 'o[4]'.'re' - 'o[6]'.'re' - 'o[8]'.'re', 'o[3]'.'im' + 'o[4]'.'im' - 'o[6]'.'im' - 'o[8]'.'im');
    'g'.'g' := 'g0' - 's_0' * 273.16 * 'g'.'theta' + 273.16 * ('r_1'.'re' * 'o[9]'.'re' - 'r_1'.'im' * 'o[9]'.'im' + 'r2'.'re' * 'o[10]'.'re' - 'r2'.'im' * 'o[10]'.'im');
    'g'.'gp' := 'g0p' + 273.16 * ('r2p'.'re' * 'o[10]'.'re' - 'r2p'.'im' * 'o[10]'.'im');
    'g'.'gpp' := 'g0pp' + 273.16 * ('r2pp'.'re' * 'o[10]'.'re' - 'r2pp'.'im' * 'o[10]'.'im');
    'o'[11] := 'Complex'(log(sqrt(('t[1]'.'re' + 'g'.'theta') ^ 2.0 + 't[1]'.'im' ^ 2.0)) - 2.0 * 'g'.'theta' * 't[1]'.'re' / ('t[1]'.'re' * 't[1]'.'re' + 't[1]'.'im' * 't[1]'.'im') - log(sqrt(('t[1]'.'re' - 'g'.'theta') ^ 2.0 + 't[1]'.'im' ^ 2.0)), 'Modelica.Math.atan3'('t[1]'.'im', 't[1]'.'re' + 'g'.'theta', 0.0) - 2.0 * 'g'.'theta' * 't[1]'.'im' / (-('t[1]'.'re' * 't[1]'.'re' + 't[1]'.'im' * 't[1]'.'im')) - 'Modelica.Math.atan3'('t[1]'.'im', 't[1]'.'re' - 'g'.'theta', 0.0));
    'o'[12] := 'Complex'(log(sqrt(('t[2]'.'re' + 'g'.'theta') ^ 2.0 + 't[2]'.'im' ^ 2.0)) - log(sqrt(('t[2]'.'re' - 'g'.'theta') ^ 2.0 + 't[2]'.'im' ^ 2.0)) - 2.0 * 'g'.'theta' * 't[2]'.'re' / ('t[2]'.'re' * 't[2]'.'re' + 't[2]'.'im' * 't[2]'.'im'), 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re' + 'g'.'theta', 0.0) - 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re' - 'g'.'theta', 0.0) - 2.0 * 'g'.'theta' * 't[2]'.'im' / (-('t[2]'.'re' * 't[2]'.'re' + 't[2]'.'im' * 't[2]'.'im')));
    'g'.'gT' := 'r_1'.'re' * 'o[11]'.'re' - 'r_1'.'im' * 'o[11]'.'im' + 'r2'.'re' * 'o[12]'.'re' - 'r2'.'im' * 'o[12]'.'im' - 's_0';
    'g'.'gTT' := 0.0036608581051398447 * ('r_1'.'re' * (('t[1]'.'re' - 'g'.'theta') / (('t[1]'.'re' - 'g'.'theta') * ('t[1]'.'re' - 'g'.'theta') + 't[1]'.'im' * 't[1]'.'im') + ('t[1]'.'re' + 'g'.'theta') / (('t[1]'.'re' + 'g'.'theta') * ('t[1]'.'re' + 'g'.'theta') + 't[1]'.'im' * 't[1]'.'im') - 2.0 * 't[1]'.'re' / ('t[1]'.'re' * 't[1]'.'re' + 't[1]'.'im' * 't[1]'.'im')) - 'r_1'.'im' * ('t[1]'.'im' / (-(('t[1]'.'re' - 'g'.'theta') * ('t[1]'.'re' - 'g'.'theta') + 't[1]'.'im' * 't[1]'.'im')) + 't[1]'.'im' / (-(('t[1]'.'re' + 'g'.'theta') * ('t[1]'.'re' + 'g'.'theta') + 't[1]'.'im' * 't[1]'.'im')) - 2.0 * 't[1]'.'im' / (-('t[1]'.'re' * 't[1]'.'re' + 't[1]'.'im' * 't[1]'.'im'))) + 'r2'.'re' * (('t[2]'.'re' - 'g'.'theta') / (('t[2]'.'re' - 'g'.'theta') * ('t[2]'.'re' - 'g'.'theta') + 't[2]'.'im' * 't[2]'.'im') + ('t[2]'.'re' + 'g'.'theta') / (('t[2]'.'re' + 'g'.'theta') * ('t[2]'.'re' + 'g'.'theta') + 't[2]'.'im' * 't[2]'.'im') - 2.0 * 't[2]'.'re' / ('t[2]'.'re' * 't[2]'.'re' + 't[2]'.'im' * 't[2]'.'im')) - 'r2'.'im' * ('t[2]'.'im' / (-(('t[2]'.'re' - 'g'.'theta') * ('t[2]'.'re' - 'g'.'theta') + 't[2]'.'im' * 't[2]'.'im')) + 't[2]'.'im' / (-(('t[2]'.'re' + 'g'.'theta') * ('t[2]'.'re' + 'g'.'theta') + 't[2]'.'im' * 't[2]'.'im')) - 2.0 * 't[2]'.'im' / (-('t[2]'.'re' * 't[2]'.'re' + 't[2]'.'im' * 't[2]'.'im'))));
    'g'.'gTp' := 'r2p'.'re' * (log(sqrt(('t[2]'.'re' + 'g'.'theta') ^ 2.0 + 't[2]'.'im' ^ 2.0)) - (2.0 * 'g'.'theta' * 't[2]'.'re' / ('t[2]'.'re' * 't[2]'.'re' + 't[2]'.'im' * 't[2]'.'im') + log(sqrt(('t[2]'.'re' - 'g'.'theta') ^ 2.0 + 't[2]'.'im' ^ 2.0)))) - 'r2p'.'im' * ('Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re' + 'g'.'theta', 0.0) - (2.0 * 'g'.'theta' * 't[2]'.'im' / (-('t[2]'.'re' * 't[2]'.'re' + 't[2]'.'im' * 't[2]'.'im')) + 'Modelica.Math.atan3'('t[2]'.'im', 't[2]'.'re' - 'g'.'theta', 0.0)));
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Gibbs';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Tsub' "Sublimation temperature"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'T_sub'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T_sub' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Tsub.Tsub_res'(p = 'p'), 143.15, 2000.0, 1e-9);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Tsub';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub' "Sublimation pressure"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'p_sub'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    constant Real[3] 'a' = {-21.2144006, 27.3203819, -6.1059813};
    constant Real[3] 'b' = {0.00333333333, 1.20666667, 1.70333333};
    Real 'theta' = 0.0;
    Real 'sum' = 0.0;
  algorithm
    'theta' := 'T' / 273.16;

    for 'k' in 1:3 loop
      'sum' := 'sum' + 'a'['k'] * 'theta' ^ 'b'['k'];
    end for;

    'p_sub' := exp('sum' / 'theta') * 611.657;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub_der' "Derivative of sublimation pressure"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'T_der';
    output Real 'p_sub_der';
    constant Real[3] 'a' = {-21.2144006, 27.3203819, -6.1059813};
    constant Real[3] 'b' = {0.00333333333, 1.20666667, 1.70333333};
    Real 'theta';
    Real 'theta_der';
    Real 'sum' = 0.0;
    Real 'sum_der' = 0.0;
  algorithm
    'theta' := 'T' / 273.16;
    'theta_der' := 0.0036608581051398447;

    for 'k' in 1:3 loop
      'sum' := 'sum' + 'a'['k'] * 'theta' ^ 'b'['k'];
      'sum_der' := 'sum_der' + 'a'['k'] * 'b'['k'] * 'theta' ^ ('b'['k'] - 1.0) * 'theta_der';
    end for;

    'p_sub_der' := ('sum_der' * 'theta' - 'sum' * 'theta_der') / 'theta' ^ 2.0 * exp('sum' / 'theta') * 611.657 * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Tsub.Tsub_res'
    input Real 'u';
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'y';
  algorithm
    'y' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub'('u') - 'p';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Tsub.Tsub_res';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX' "Return temperature as a function of pressure, specific enthalpy and mass fractions"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[2] 'Xfull'(nominal = {0.1, 0.1}, max = {1.0, 1.0}, min = {0.0, 0.0}, unit = {"kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction"}) = if size('X', 1) == 2 then 'X' else cat(1, 'X', {1.0 - sum('X')});
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX.T_phX_res'(p = 'p', h = 'h', X = 'Xfull'), 173.15, 2000.0, 1e-9);
    annotation(inverse(h = Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX('p', 'T', 'X')));
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX.T_phX_res'
    input Real 'u';
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'y';
  algorithm
    'y' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX'('p', 'u', 'X') - 'h';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX.T_phX_res';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2' "Reaction index for formation of H2"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    output Real 'u';
  algorithm
    'u' := 1075.5 * 'moleFraction'[1] / sqrt('moleFraction'[3]) * ('p' / 101325.0) ^ (-0.5) * exp(30283.3 / (-'T'));
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2_der' "Derivative reaction index for formation of H2"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    input Real 'p_der';
    input Real 'T_der';
    input Real[4] 'moleFraction_der';
    output Real 'u_der';
    Real[4] 'o';
  algorithm
    'o'[1] := 1075.5 * sqrt('moleFraction'[3]) * ('p' / 101325.0) ^ (-0.5) * exp(30283.3 / (-'T'));
    'o'[2] := -537.75 * 'moleFraction'[1] / 'moleFraction'[3] ^ 1.5 * ('p' / 101325.0) ^ (-0.5) * exp(30283.3 / (-'T'));
    'o'[3] := -537.75 * 'moleFraction'[1] / sqrt('moleFraction'[3]) * 318.3158808479401 * 'p' ^ (-1.5) * exp(30283.3 / (-'T'));
    'o'[4] := -(-3.256968915e7) * 'moleFraction'[1] / sqrt('moleFraction'[3]) * ('p' / 101325.0) ^ (-0.5) * exp(30283.3 / (-'T')) / 'T' ^ 2.0;
    'u_der' := 'o'[1] * 'moleFraction_der'[1] + 'o'[2] * 'moleFraction_der'[3] + 'o'[3] * 'p_der' + 'o'[4] * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U3' "Reaction index for formation of OH"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    output Real 'u';
  algorithm
    'u' := 165.95 * sqrt('moleFraction'[1]) * sqrt(sqrt('moleFraction'[3])) * ('p' / 101325.0) ^ (-0.25) * exp(19526.8 / (-'T'));
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U3_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U3';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U3_der' "Derivative of reaction index for formation of OH"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    input Real 'p_der';
    input Real 'T_der';
    input Real[4] 'moleFraction_der';
    output Real 'u_der';
    Real[4] 'o';
  algorithm
    'o'[1] := 82.975 / sqrt('moleFraction'[1]) * sqrt(sqrt('moleFraction'[3])) * ('p' / 101325.0) ^ (-0.25) * exp(19526.8 / (-'T'));
    'o'[2] := 41.4875 * sqrt('moleFraction'[1]) / 'moleFraction'[3] ^ 0.75 * ('p' / 101325.0) ^ (-0.25) * exp(19526.8 / (-'T'));
    'o'[3] := -41.4875 * sqrt('moleFraction'[1]) * sqrt(sqrt('moleFraction'[3])) * 17.841409160936255 * 'p' ^ (-1.25) * exp(19526.8 / (-'T'));
    'o'[4] := (-3.2404724599999995e6) * 'moleFraction'[1] / sqrt(sqrt('moleFraction'[3])) * ('p' / 101325.0) ^ (-0.25) * exp(19526.8 / (-'T')) / 'T' ^ 2.0;
    'u_der' := 'o'[1] * 'moleFraction_der'[1] + 'o'[2] * 'moleFraction_der'[3] + 'o'[3] * 'p_der' + 'o'[4] * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U3_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U4' "Reaction index for formation of H"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    output Real 'u';
  algorithm
    'u' := 1491.75 * sqrt('Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2'('p', 'T', 'moleFraction')) * ('p' / 101325.0) ^ (-0.5) * exp(27488.0 / (-'T'));
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U4_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U4';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U4_der' "Derivative of reaction index for formation of H"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    input Real 'p_der';
    input Real 'T_der';
    input Real[4] 'moleFraction_der';
    output Real 'u_der';
    Real[3] 'o';
  algorithm
    'o'[1] := 745.875 / sqrt('Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2'('p', 'T', 'moleFraction')) * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2_der'('p', 'T', 'moleFraction', 'p_der', 'T_der', 'moleFraction_der') * ('p' / 101325.0) ^ (-0.5) * exp(27488.0 / (-'T'));
    'o'[2] := -745.875 * sqrt('Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2'('p', 'T', 'moleFraction')) * 318.3158808479401 * 'p' ^ (-1.5) * exp(27488.0 / (-'T'));
    'o'[3] := (-4.1005224e7) * sqrt('Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U2'('p', 'T', 'moleFraction')) * ('p' / 101325.0) ^ (-0.5) * exp(27488.0 / (-'T')) / 'T' ^ 2.0;
    'u_der' := 'o'[1] + 'o'[2] * 'p_der' + 'o'[3] * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U4_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U5' "Reaction index for formation of O"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    output Real 'u';
  algorithm
    'u' := 3235.34 * sqrt('moleFraction'[3]) * ('p' / 101325.0) ^ (-0.5) * exp(30807.8 / (-'T'));
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U5_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U5';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U5_der' "Derivative of reaction index for formation of O"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    input Real 'p_der';
    input Real 'T_der';
    input Real[4] 'moleFraction_der';
    output Real 'u_der';
    Real[3] 'o';
  algorithm
    'o'[1] := 1617.67 / sqrt('moleFraction'[3]) * ('p' / 101325.0) ^ (-0.5) * exp(30807.8 / (-'T'));
    'o'[2] := -1617.67 * sqrt('moleFraction'[3]) * 318.3158808479401 * 'p' ^ (-1.5) * exp(30807.8 / (-'T'));
    'o'[3] := (-9.9673707652e7) * sqrt('moleFraction'[3]) * ('p' / 101325.0) ^ (-0.5) * exp(30807.8 / (-'T')) / 'T' ^ 2.0;
    'u_der' := 'o'[1] * 'moleFraction'[3] + 'o'[2] * 'p_der' + 'o'[3] * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U5_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U6' "Reaction index for formation of NO"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    output Real 'u';
  algorithm
    'u' := 4.5542 * sqrt('moleFraction'[2] * 'moleFraction'[3]) * exp(10973.6 / (-'T'));
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U6_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U6';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U6_der' "Derivative of reaction index for formation of NO"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'moleFraction'(max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"1", "1", "1", "1"}, quantity = {"MoleFraction", "MoleFraction", "MoleFraction", "MoleFraction"});
    input Real 'p_der';
    input Real 'T_der';
    input Real[4] 'moleFraction_der';
    output Real 'u_der';
    Real[3] 'o';
  algorithm
    'o'[1] := 2.2771 / sqrt('moleFraction'[2] * 'moleFraction'[3]) * 'moleFraction'[3] * exp(10973.6 / (-'T'));
    'o'[2] := 2.2771 / sqrt('moleFraction'[2] * 'moleFraction'[3]) * 'moleFraction'[2] * exp(10973.6 / (-'T'));
    'o'[3] := (-49975.96912) * sqrt('moleFraction'[2] * 'moleFraction'[3]) * exp(10973.6 / (-'T')) / 'T' ^ 2.0;
    'u_der' := 'o'[1] * 'moleFraction'[2] + 'o'[2] * 'moleFraction'[3] + 'o'[3] * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.U6_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V2' "Energy index for formation of H2"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'v'(unit = "J/(mol.K)", quantity = "MolarHeatCapacity");
  algorithm
    'v' := 303000.0 / 'T' - 65.2 + 7.277e9 / 'T' ^ 2.0;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V2_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V2';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V2_der' "Derivative of energy index for formation of H2"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'T_der';
    output Real 'v_der';
  algorithm
    'v_der' := (-(303000.0 / 'T' ^ 2.0 + 1.4554e10 / 'T' ^ 3.0)) * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V2_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V3' "Energy index for formation of OH"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'v'(unit = "J/(mol.K)", quantity = "MolarHeatCapacity");
  algorithm
    'v' := 57200.0 / 'T' - 18.7 + 3.136e9 / 'T' ^ 2.0;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V3_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V3';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V3_der' "Derivative energy index for formation of OH"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'T_der';
    output Real 'v_der';
  algorithm
    'v_der' := (-(57200.0 / 'T' ^ 2.0 + 6.272e9 / 'T' ^ 3.0)) * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V3_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V4' "Energy index for formation of H"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'v'(unit = "J/(mol.K)", quantity = "MolarHeatCapacity");
  algorithm
    'v' := 393000.0 / 'T' - 3.6 + 5.826e9 / 'T' ^ 2.0;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V4_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V4';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V4_der' "Derivative of energy index for formation of H"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'T_der';
    output Real 'v_der';
  algorithm
    'v_der' := (-(393000.0 / 'T' ^ 2.0 + 1.1652e10 / 'T' ^ 3.0)) * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V4_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V5' "Energy index for formation of O"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'v'(unit = "J/(mol.K)", quantity = "MolarHeatCapacity");
  algorithm
    'v' := 1.5e5 / 'T' - 21.8 + 7.659e9 / 'T' ^ 2.0;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V5_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V5';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V5_der' "Derivative of energy index for formation of O"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'T_der';
    output Real 'v_der';
  algorithm
    'v_der' := (-(1.5e5 / 'T' ^ 2.0 + 1.5318e10 / 'T' ^ 3.0)) * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V5_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V6' "Energy index for formation of NO"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'v'(unit = "J/(mol.K)", quantity = "MolarHeatCapacity");
  algorithm
    'v' := 16200.0 / 'T' - 5.6 + 9.94e8 / 'T' ^ 2.0;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V6_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V6';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V6_der' "Derivative of energy index for formation of NO"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'T_der';
    output Real 'v_der';
  algorithm
    'v_der' := (-(16200.0 / 'T' ^ 2.0 + 1.988e9 / 'T' ^ 3.0)) * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.ReactionIndices.V6_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.Tsat' "Saturation temperature"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'beta';
    Real 'D';
    Real 'E';
    Real 'F';
    Real 'G';
    constant Real[10] 'n' = {1167.0521452767, -724213.16703206, -17.073846940092, 12020.82470247, -3.2325550322333e6, 14.91510861353, -4823.2657361591, 405113.40542057, -0.23855557567849, 650.17534844798};
  algorithm
    'beta' := ('p' * 1e-6) ^ 0.25;
    'E' := 'beta' ^ 2.0 + 'n'[3] * 'beta' + 'n'[6];
    'F' := 'n'[1] * 'beta' ^ 2.0 + 'n'[4] * 'beta' + 'n'[7];
    'G' := 'n'[2] * 'beta' ^ 2.0 + 'n'[5] * 'beta' + 'n'[8];
    'D' := 2.0 * 'G' / (-('F' + sqrt('F' ^ 2.0 - 4.0 * 'E' * 'G')));
    'T' := ('n'[10] + 'D' - sqrt(('n'[10] + 'D') ^ 2.0 - 4.0 * ('n'[9] + 'n'[10] * 'D'))) / 2.0;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.Tsat_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.Tsat';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.Tsat_der' "Derivative of saturation temperature"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'p_der';
    output Real 'T_der';
    Real 'beta';
    Real 'beta_der';
    Real 'D';
    Real 'D_der';
    Real 'E';
    Real 'E_der';
    Real 'F';
    Real 'F_der';
    Real 'G';
    Real 'G_der';
    Real[2] 'o_der';
    constant Real[10] 'n' = {1167.0521452767, -724213.16703206, -17.073846940092, 12020.82470247, -3.2325550322333e6, 14.91510861353, -4823.2657361591, 405113.40542057, -0.23855557567849, 650.17534844798};
  algorithm
    'beta' := ('p' * 1e-6) ^ 0.25;
    'beta_der' := 0.25 / ('p' * 1e-6) ^ 0.75 * 1e-6;
    'E' := 'beta' ^ 2.0 + 'n'[3] * 'beta' + 'n'[6];
    'E_der' := 2.0 * 'beta' * 'beta_der' + 'n'[3];
    'F' := 'n'[1] * 'beta' ^ 2.0 + 'n'[4] * 'beta' + 'n'[7];
    'F_der' := 2.0 * 'n'[1] * 'beta' * 'beta_der' + 'n'[4];
    'G' := 'n'[2] * 'beta' ^ 2.0 + 'n'[5] * 'beta' + 'n'[8];
    'G_der' := 2.0 * 'n'[2] * 'beta' * 'beta_der' + 'n'[5];
    'D' := 2.0 * 'G' / (-('F' + sqrt('F' ^ 2.0 - 4.0 * 'E' * 'G')));
    'o_der'[1] := 2.0 * 'F' * 'F_der' - 4.0 * ('E' * 'G_der' + 'E_der' * 'G');
    'o_der'[2] := -('F_der' + 0.5 / sqrt('F' ^ 2.0 - 4.0 * 'E' * 'G') * 'o_der'[1]);
    'D_der' := (2.0 * 'G_der' * (-('F' + sqrt('F' ^ 2.0 - 4.0 * 'E' * 'G'))) - 2.0 * 'G' * 'o_der'[2]) / (-('F' + sqrt('F' ^ 2.0 - 4.0 * 'E' * 'G'))) ^ 2.0;
    'T_der' := ('D_der' - 0.5 / sqrt(('n'[10] + 'D') ^ 2.0 - 4.0 * ('n'[9] + 'n'[10] * 'D')) * (2.0 * 'D' * 'D_der' - 2.0 * 'n'[10] * 'D_der')) / 2.0 * 'p_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.Tsat_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.psat' "Saturation pressure"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'theta_s';
    Real 'A';
    Real 'B';
    Real 'C';
    constant Real[10] 'n' = {1167.0521452767, -724213.16703206, -17.073846940092, 12020.82470247, -3.2325550322333e6, 14.91510861353, -4823.2657361591, 405113.40542057, -0.23855557567849, 650.17534844798};
  algorithm
    'theta_s' := min('T', 553.0) + 'n'[9] / (min('T', 553.0) - 'n'[10]);
    'A' := 'theta_s' ^ 2.0 + 'n'[1] * 'theta_s' + 'n'[2];
    'B' := 'n'[3] * 'theta_s' ^ 2.0 + 'n'[4] * 'theta_s' + 'n'[5];
    'C' := 'n'[6] * 'theta_s' ^ 2.0 + 'n'[7] * 'theta_s' + 'n'[8];
    'p' := (2.0 * 'C' / (sqrt('B' ^ 2.0 - 4.0 * 'A' * 'C') - 'B')) ^ 4.0 * 1e6;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.psat_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.psat';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.psat_der' "Saturation pressure"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'T_der';
    output Real 'p_der';
    Real 'theta_s';
    Real 'theta_s_der';
    Real 'A';
    Real 'A_der';
    Real 'B';
    Real 'B_der';
    Real 'C';
    Real 'C_der';
    Real[3] 'o_der';
    constant Real[10] 'n' = {1167.0521452767, -724213.16703206, -17.073846940092, 12020.82470247, -3.2325550322333e6, 14.91510861353, -4823.2657361591, 405113.40542057, -0.23855557567849, 650.17534844798};
  algorithm
    'theta_s' := min('T', 553.0) + 'n'[9] / (min('T', 553.0) - 'n'[10]);
    'theta_s_der' := 1.0 - 'n'[9] / (min('T', 553.0) - 'n'[10]) ^ 2.0;
    'A' := 'theta_s' ^ 2.0 + 'n'[1] * 'theta_s' + 'n'[2];
    'B' := 'n'[3] * 'theta_s' ^ 2.0 + 'n'[4] * 'theta_s' + 'n'[5];
    'C' := 'n'[6] * 'theta_s' ^ 2.0 + 'n'[7] * 'theta_s' + 'n'[8];
    'A_der' := 2.0 * 'theta_s' * 'theta_s_der' + 'n'[1] * 'theta_s_der';
    'B_der' := 2.0 * 'n'[3] * 'theta_s' * 'theta_s_der' + 'n'[4] * 'theta_s_der';
    'C_der' := 2.0 * 'n'[6] * 'theta_s' * 'theta_s_der' + 'n'[7] * 'theta_s_der';
    'o_der'[1] := 2.0 * 'B' * 'B_der' - 4.0 * ('A' * 'C_der' + 'A_der' * 'C');
    'o_der'[2] := 0.5 / sqrt('B' ^ 2.0 - 4.0 * 'A' * 'C') * 'o_der'[1] - 'B_der';
    'o_der'[3] := (2.0 * 'C_der' * (sqrt('B' ^ 2.0 - 4.0 * 'A' * 'C') - 'B') - 2.0 * 'C' * 'o_der'[2]) / (sqrt('B' ^ 2.0 - 4.0 * 'A' * 'C') - 'B') ^ 2.0;
    'p_der' := 4.0 * (2.0 * 'C' / (sqrt('B' ^ 2.0 - 4.0 * 'A' * 'C') - 'B')) ^ 3.0 * 'o_der'[3] * 1e6 * 'T_der';
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.psat_der';

  function 'Modelica.Media.Common.Helmholtz_pT' "Function to calculate analytic derivatives for computing d and t given p and t"
    input 'Modelica.Media.Common.HelmholtzDerivs' 'f';
    output 'Modelica.Media.Common.NewtonDerivatives_pT' 'nderivs';
  algorithm
    'nderivs'.'p' := 'f'.'d' * 'f'.'R_s' * 'f'.'T' * 'f'.'delta' * 'f'.'fdelta';
    'nderivs'.'pd' := 'f'.'R_s' * 'f'.'T' * 'f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta');
  end 'Modelica.Media.Common.Helmholtz_pT';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'ambient.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'ambient.Medium.ThermodynamicState'('p', 'T', 'X') else 'ambient.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.setState_pTX';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'ambient.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'ambient.Medium.ThermodynamicState'('p', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX'('p', 'h', 'X'), 'X') else 'ambient.Medium.ThermodynamicState'('p', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.setState_phX';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.specificEnthalpy' "Return specific enthalpy of moist air as a function of the thermodynamic state record"
    input 'ambient.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX'('state'.'p', 'state'.'T', 'state'.'X');
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.specificEnthalpy';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.specificEnthalpy'('Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.specificEnthalpy_pTX';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'ambient.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.temperature';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.temperature'('Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.ambient.Medium.temperature_phX';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'fixedMassFlowRate.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'fixedMassFlowRate.Medium.ThermodynamicState'('p', 'T', 'X') else 'fixedMassFlowRate.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.setState_pTX';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'fixedMassFlowRate.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'fixedMassFlowRate.Medium.ThermodynamicState'('p', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX'('p', 'h', 'X'), 'X') else 'fixedMassFlowRate.Medium.ThermodynamicState'('p', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.setState_phX';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.specificEnthalpy' "Return specific enthalpy of moist air as a function of the thermodynamic state record"
    input 'fixedMassFlowRate.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX'('state'.'p', 'state'.'T', 'state'.'X');
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.specificEnthalpy';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.specificEnthalpy'('Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.specificEnthalpy_pTX';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.fixedMassFlowRate.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'fixedMassFlowRate.Medium.ThermodynamicState' 'state';
