  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g5' "Base function for region 5: g(p,T)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.GibbsDerivs' 'g';
    Real[11] 'o';
  algorithm
    assert('p' > 0.0, "IF97 medium function g5 called with too low pressure\np = " + String('p') + " Pa <=  0.0 Pa", AssertionLevel.error);
    assert('p' <= 1e7, "IF97 medium function g5: input pressure (= " + String('p') + " Pa) is higher than 10 MPa in region 5", AssertionLevel.error);
    assert('T' <= 2273.15, "IF97 medium function g5: input temperature (= " + String('T') + " K) is higher than limit of 2273.15K in region 5", AssertionLevel.error);
    'g'.'p' := 'p';
    'g'.'T' := 'T';
    'g'.'R_s' := 461.526;
    'g'.'pi' := 'p' / 1e6;
    'g'.'tau' := 1000.0 / 'T';
    'o'[1] := 'g'.'tau' * 'g'.'tau';
    'o'[2] := -0.004594282089991 * 'o'[1];
    'o'[3] := 0.0021774678714571 + 'o'[2];
    'o'[4] := 'o'[3] * 'g'.'tau';
    'o'[5] := 'o'[1] * 'g'.'tau';
    'o'[6] := 'o'[1] * 'o'[1];
    'o'[7] := 'o'[6] * 'o'[6];
    'o'[8] := 'o'[7] * 'g'.'tau';
    'o'[9] := -7.9449656719138e-6 * 'o'[8];
    'o'[10] := 'g'.'pi' * 'g'.'pi';
    'o'[11] := -0.013782846269973 * 'o'[1];
    'g'.'g' := 'g'.'pi' * ('o'[4] - 1.2563183589592e-4 + 'g'.'pi' * (1.2919228289784e-7 * 'o'[5] * 'g'.'pi' - 3.9724828359569e-6 * 'o'[8])) + ('g'.'tau' * (0.36901534980333 + 'g'.'tau' * ('g'.'tau' * ((6.8540841634434 - 0.32961626538917 * 'g'.'tau') * 'g'.'tau' - 13.179983674201 + log('g'.'pi')) - 3.1161318213925)) - 0.024805148933466) / 'o'[5];
    'g'.'gpi' := (1.0 + 'g'.'pi' * ('o'[4] - 1.2563183589592e-4 + 'g'.'pi' * ('o'[9] + 3.8757684869352e-7 * 'o'[5] * 'g'.'pi'))) / 'g'.'pi';
    'g'.'gpipi' := ('o'[10] * ('o'[9] + 7.7515369738704e-7 * 'o'[5] * 'g'.'pi') - 1.0) / 'o'[10];
    'g'.'gtau' := 'g'.'pi' * (0.0021774678714571 + 'o'[11] + 'g'.'pi' * (3.8757684869352e-7 * 'o'[1] * 'g'.'pi' - 3.5752345523612e-5 * 'o'[7])) + (0.074415446800398 + 'g'.'tau' * ((3.1161318213925 + 'o'[1] * (6.8540841634434 - 0.65923253077834 * 'g'.'tau')) * 'g'.'tau' - 0.73803069960666)) / 'o'[6];
    'g'.'gtautau' := ('g'.'tau' * (2.21409209881998 + (-(6.232263642785 + 0.65923253077834 * 'o'[5])) * 'g'.'tau') - 0.297661787201592) / ('o'[6] * 'g'.'tau') + 'g'.'pi' * ('g'.'pi' * (7.7515369738704e-7 * 'g'.'pi' * 'g'.'tau' - 2.86018764188897e-4 * 'o'[1] * 'o'[6] * 'g'.'tau') - 0.027565692539946 * 'g'.'tau');
