  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.volume.Medium.temperature';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir1.volume.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Media.Examples.ReferenceAir.MoistAir1.volume.Medium.temperature'('Modelica.Media.Examples.ReferenceAir.MoistAir1.volume.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir1.volume.Medium.temperature_phX';

  function 'Modelica.Media.Water.IF97_Utilities.h_pT_der' "Derivative function of h_pT"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input 'Modelica.Media.Common.IF97BaseTwoPhase' 'aux';
    input Real 'p_der';
    input Real 'T_der';
    output Real 'h_der';
  algorithm
    if 'aux'.'region' == 3 then
      'h_der' := ('T' * 'aux'.'pt' - 'aux'.'rho' * 'aux'.'pd') / ('aux'.'rho' * 'aux'.'rho' * 'aux'.'pd') * 'p_der' + ('aux'.'rho' * 'aux'.'rho' * 'aux'.'pd' * 'aux'.'cv' + 'aux'.'T' * 'aux'.'pt' * 'aux'.'pt') / ('aux'.'rho' * 'aux'.'rho' * 'aux'.'pd') * 'T_der';
    elseif true then
      'h_der' := (1.0 / 'aux'.'rho' - 'aux'.'T' * 'aux'.'vt') * 'p_der' + 'aux'.'cp' * 'T_der';
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.h_pT_der';

  function 'Modelica.Media.Water.IF97_Utilities.h_props_pT' "Specific enthalpy as function or pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input 'Modelica.Media.Common.IF97BaseTwoPhase' 'aux';
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'aux'.'h';
    annotation(derivative(order = 1, noDerivative = 'aux') = 'Modelica.Media.Water.IF97_Utilities.h_pT_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Water.IF97_Utilities.h_props_pT';

  function 'Modelica.Media.Water.IF97_Utilities.rho_pT_der' "Derivative function of rho_pT"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input 'Modelica.Media.Common.IF97BaseTwoPhase' 'aux';
    input Real 'p_der';
    input Real 'T_der';
    output Real 'rho_der';
  algorithm
    if 'aux'.'region' == 3 then
      'rho_der' := 1.0 / 'aux'.'pd' * 'p_der' - 'aux'.'pt' / 'aux'.'pd' * 'T_der';
    elseif true then
      'rho_der' := (-'aux'.'rho' * 'aux'.'rho' * 'aux'.'vp') * 'p_der' + (-'aux'.'rho' * 'aux'.'rho' * 'aux'.'vt') * 'T_der';
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.rho_pT_der';

  function 'Modelica.Media.Water.IF97_Utilities.rho_props_pT' "Density as function or pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input 'Modelica.Media.Common.IF97BaseTwoPhase' 'aux';
    output Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'rho' := 'aux'.'rho';
    annotation(derivative(order = 1, noDerivative = 'aux') = 'Modelica.Media.Water.IF97_Utilities.rho_pT_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Water.IF97_Utilities.rho_props_pT';

  function 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT' "Intermediate property record for water (p and T preferred states)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Integer 'region' = 0;
    output 'Modelica.Media.Common.IF97BaseTwoPhase' 'aux';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Integer 'error';
  algorithm
    'aux'.'phase' := 1;
    'aux'.'region' := if 'region' == 0 then 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_pT'('p', 'T', 0) else 'region';
    'aux'.'R_s' := 461.526;
    'aux'.'p' := 'p';
    'aux'.'T' := 'T';
    'aux'.'vt' := 0.0 "Initialized in case it is not needed";
    'aux'.'vp' := 0.0 "Initialized in case it is not needed";

    if 'aux'.'region' == 1 then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g1'('p', 'T');
      'aux'.'h' := 'aux'.'R_s' * 'aux'.'T' * 'g'.'tau' * 'g'.'gtau';
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'vp' := 'aux'.'R_s' * 'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'x' := 0.0;
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
    elseif 'aux'.'region' == 2 then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g2'('p', 'T', true);
      'aux'.'h' := 'aux'.'R_s' * 'aux'.'T' * 'g'.'tau' * 'g'.'gtau';
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'vp' := 'aux'.'R_s' * 'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'x' := 1.0;
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
    elseif 'aux'.'region' == 3 then
      ('aux'.'rho', 'error') := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofpt3'('p', 'T', 1e-7);
      'f' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('aux'.'rho', 'T');
      'aux'.'h' := 'aux'.'R_s' * 'T' * ('f'.'tau' * 'f'.'ftau' + 'f'.'delta' * 'f'.'fdelta');
      'aux'.'s' := 'aux'.'R_s' * ('f'.'tau' * 'f'.'ftau' - 'f'.'f');
      'aux'.'pd' := 'aux'.'R_s' * 'T' * 'f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta');
      'aux'.'pt' := 'aux'.'R_s' * 'aux'.'rho' * 'f'.'delta' * ('f'.'fdelta' - 'f'.'tau' * 'f'.'fdeltatau');
      'aux'.'cv' := 'aux'.'R_s' * (-'f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
      'aux'.'x' := 0.0;
      'aux'.'dpT' := 'aux'.'pt';
    elseif 'aux'.'region' == 5 then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g5'('p', 'T');
      'aux'.'h' := 'aux'.'R_s' * 'aux'.'T' * 'g'.'tau' * 'g'.'gtau';
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'vp' := 'aux'.'R_s' * 'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'x' := 1.0;
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
    elseif true then
      assert(false, "Error in region computation of IF97 steam tables(p = " + String('p') + ", T = " + String('T') + ")", AssertionLevel.error);
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dptofT' "Derivative of pressure w.r.t. temperature along the saturation pressure curve"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'dpt'(unit = "Pa/K");
    Real[31] 'o';
    Real 'Tlim';
  algorithm
    'Tlim' := min('T', 647.096);
    'o'[1] := 'Tlim' - 650.17534844798;
    'o'[2] := 1.0 / 'o'[1];
    'o'[3] := -0.23855557567849 * 'o'[2];
    'o'[4] := 'o'[3] + 'Tlim';
    'o'[5] := -4823.2657361591 * 'o'[4];
    'o'[6] := 'o'[4] * 'o'[4];
    'o'[7] := 14.91510861353 * 'o'[6];
    'o'[8] := 405113.40542057 + 'o'[5] + 'o'[7];
    'o'[9] := 'o'[8] * 'o'[8];
    'o'[10] := 'o'[9] * 'o'[9];
    'o'[11] := 'o'[1] * 'o'[1];
    'o'[12] := 1.0 / 'o'[11];
    'o'[13] := 0.23855557567849 * 'o'[12];
    'o'[14] := 1.0 + 'o'[13];
    'o'[15] := 12020.82470247 * 'o'[4];
    'o'[16] := -17.073846940092 * 'o'[6];
    'o'[17] := 'o'[15] - 3.2325550322333e6 + 'o'[16];
    'o'[18] := -4823.2657361591 * 'o'[14];
    'o'[19] := 29.83021722706 * 'o'[14] * 'o'[4];
    'o'[20] := 'o'[18] + 'o'[19];
    'o'[21] := 1167.0521452767 * 'o'[4];
    'o'[22] := 'o'[21] - 724213.16703206 + 'o'[6];
    'o'[23] := 'o'[17] * 'o'[17];
    'o'[24] := -4.0 * 'o'[22] * 'o'[8];
    'o'[25] := 'o'[23] + 'o'[24];
    'o'[26] := sqrt('o'[25]);
    'o'[27] := -12020.82470247 * 'o'[4];
    'o'[28] := 17.073846940092 * 'o'[6];
    'o'[29] := 3.2325550322333e6 + 'o'[26] + 'o'[27] + 'o'[28];
    'o'[30] := 'o'[29] * 'o'[29];
    'o'[31] := 'o'[30] * 'o'[30];
    'dpt' := 1e6 * (64.0 * 'o'[10] * (34.147693880184 * 'o'[14] * 'o'[4] - 12020.82470247 * 'o'[14] + 0.5 * (2.0 * 'o'[17] * (12020.82470247 * 'o'[14] - 34.147693880184 * 'o'[14] * 'o'[4]) - 4.0 * 'o'[20] * 'o'[22] - 4.0 * (1167.0521452767 * 'o'[14] + 2.0 * 'o'[14] * 'o'[4]) * 'o'[8]) / 'o'[26]) / (-'o'[29] * 'o'[31]) + 64.0 * 'o'[20] * 'o'[8] * 'o'[9] / 'o'[31]);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dptofT';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dtsatofp' "Derivative of saturation temperature w.r.t. pressure"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'dtsat'(unit = "K/Pa");
    Real 'pi';
    Real[49] 'o';
  algorithm
    'pi' := max(2.2250738585072014e-308, 'p' * 1e-6);
    'o'[1] := 'pi' ^ 0.75;
    'o'[2] := 1.0 / 'o'[1];
    'o'[3] := -4.268461735023 * 'o'[2];
    'o'[4] := sqrt('pi');
    'o'[5] := 1.0 / 'o'[4];
    'o'[6] := 0.5 * 'o'[5];
    'o'[7] := 'o'[3] + 'o'[6];
    'o'[8] := 'pi' ^ 0.25;
    'o'[9] := -3.2325550322333e6 * 'o'[8];
    'o'[10] := -724213.16703206 * 'o'[4];
    'o'[11] := 405113.40542057 + 'o'[10] + 'o'[9];
    'o'[12] := -4.0 * 'o'[11] * 'o'[7];
    'o'[13] := -808138.758058325 * 'o'[2];
    'o'[14] := -362106.58351603 * 'o'[5];
    'o'[15] := 'o'[13] + 'o'[14];
    'o'[16] := -17.073846940092 * 'o'[8];
    'o'[17] := 14.91510861353 + 'o'[16] + 'o'[4];
    'o'[18] := -4.0 * 'o'[15] * 'o'[17];
    'o'[19] := 3005.2061756175 * 'o'[2];
    'o'[20] := 583.52607263835 * 'o'[5];
    'o'[21] := 'o'[19] + 'o'[20];
    'o'[22] := 12020.82470247 * 'o'[8];
    'o'[23] := 1167.0521452767 * 'o'[4];
    'o'[24] := 'o'[22] - 4823.2657361591 + 'o'[23];
    'o'[25] := 2.0 * 'o'[21] * 'o'[24];
    'o'[26] := 'o'[12] + 'o'[18] + 'o'[25];
    'o'[27] := -4.0 * 'o'[11] * 'o'[17];
    'o'[28] := 'o'[24] * 'o'[24];
    'o'[29] := 'o'[27] + 'o'[28];
    'o'[30] := sqrt('o'[29]);
    'o'[31] := 1.0 / 'o'[30];
    'o'[32] := -'o'[30];
    'o'[33] := -12020.82470247 * 'o'[8];
    'o'[34] := -1167.0521452767 * 'o'[4];
    'o'[35] := 4823.2657361591 + 'o'[32] + 'o'[33] + 'o'[34];
    'o'[36] := 'o'[30];
    'o'[37] := 'o'[22] - 4823.2657361591 + 'o'[23] + 'o'[36];
    'o'[38] := 'o'[37] * 'o'[37];
    'o'[39] := 1.0 / 'o'[38];
    'o'[40] := -1.72207339365771 * 'o'[30];
    'o'[41] := 21592.2055343628 * 'o'[8];
    'o'[42] := 'o'[30] * 'o'[8];
    'o'[43] := -8192.87114842946 * 'o'[4];
    'o'[44] := -0.510632954559659 * 'o'[30] * 'o'[4];
    'o'[45] := -3100.02526152368 * 'o'[1];
    'o'[46] := 'pi';
    'o'[47] := 1295.95640782102 * 'o'[46];
    'o'[48] := 2862.09212505088 + 'o'[40] + 'o'[41] + 'o'[42] + 'o'[43] + 'o'[44] + 'o'[45] + 'o'[47];
    'o'[49] := 1.0 / ('o'[35] * 'o'[35]);
    'dtsat' := 5e-7 * (2.0 * 'o'[15] / 'o'[35] - 2.0 * 'o'[11] * (-(3005.2061756175 * 'o'[2] + 0.5 * 'o'[26] * 'o'[31] + 583.52607263835 * 'o'[5])) * 'o'[49] - 20953.46356643991 * ('o'[39] * (1295.95640782102 + 5398.05138359071 * 'o'[2] + 0.25 * 'o'[2] * 'o'[30] - 0.861036696828853 * 'o'[26] * 'o'[31] - 0.255316477279829 * 'o'[26] * 'o'[31] * 'o'[4] - 4096.43557421473 * 'o'[5] - 0.255316477279829 * 'o'[30] * 'o'[5] - 2325.01894614276 / 'o'[8] + 0.5 * 'o'[26] * 'o'[31] * 'o'[8]) - 2.0 * ('o'[19] + 'o'[20] + 0.5 * 'o'[26] * 'o'[31]) * 'o'[48] * 'o'[37] ^ (-3.0)) / sqrt('o'[39] * 'o'[48]));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dtsatofp';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3' "Helmholtz function for region 3: f(d,T)"
    input Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Real[40] 'o';
  algorithm
    'f'.'T' := 'T';
    'f'.'d' := 'd';
    'f'.'R_s' := 461.526;
    'f'.'tau' := 647.096 / 'T';
    'f'.'delta' := if 'd' == 322.0 and 'T' == 647.096 then 0.9999999999999998 else abs('d' / 322.0);
    'o'[1] := 'f'.'tau' * 'f'.'tau';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'f'.'tau';
    'o'[4] := 'o'[1] * 'f'.'tau';
    'o'[5] := 'o'[2] * 'o'[2];
    'o'[6] := 'o'[1] * 'o'[5] * 'f'.'tau';
    'o'[7] := 'o'[5] * 'f'.'tau';
    'o'[8] := -0.64207765181607 * 'o'[1];
    'o'[9] := 0.88521043984318 + 'o'[8];
    'o'[10] := 'o'[7] * 'o'[9];
    'o'[11] := 'o'[10] - 1.1524407806681;
    'o'[12] := 'o'[11] * 'o'[2];
    'o'[13] := 'o'[12] - 1.2654315477714;
    'o'[14] := 'o'[1] * 'o'[13];
    'o'[15] := 'o'[1] * 'o'[2] * 'o'[5] * 'f'.'tau';
    'o'[16] := 'o'[2] * 'o'[5];
    'o'[17] := 'o'[1] * 'o'[5];
    'o'[18] := 'o'[5] * 'o'[5];
    'o'[19] := 'o'[1] * 'o'[18] * 'o'[2];
    'o'[20] := 'o'[1] * 'o'[18] * 'o'[2] * 'f'.'tau';
    'o'[21] := 'o'[18] * 'o'[5];
    'o'[22] := 'o'[1] * 'o'[18] * 'o'[5];
    'o'[23] := 0.25116816848616 * 'o'[2];
    'o'[24] := 0.078841073758308 + 'o'[23];
    'o'[25] := 'o'[15] * 'o'[24];
    'o'[26] := 'o'[25] - 6.100523451393;
    'o'[27] := 'o'[26] * 'f'.'tau';
    'o'[28] := 9.7944563083754 + 'o'[27];
    'o'[29] := 'o'[2] * 'o'[28];
    'o'[30] := 'o'[29] - 1.70429417648412;
    'o'[31] := 'o'[1] * 'o'[30];
    'o'[32] := 'f'.'delta' * 'f'.'delta';
    'o'[33] := -10.9153200808732 * 'o'[1];
    'o'[34] := 13.2781565976477 + 'o'[33];
    'o'[35] := 'o'[34] * 'o'[7];
    'o'[36] := 'o'[35] - 6.9146446840086;
    'o'[37] := 'o'[2] * 'o'[36];
    'o'[38] := 'o'[37] - 2.5308630955428;
    'o'[39] := 'o'[38] * 'f'.'tau';
    'o'[40] := 'o'[18] * 'o'[5] * 'f'.'tau';
    'f'.'f' := 'f'.'tau' * (20.944396974307 + ('o'[3] * (2.6185947787954 + 'o'[4] * ('o'[1] * (1.2053369696517 - 0.0084566812812502 * 'o'[6]) - 2.808078114862)) - 7.6867707878716) * 'f'.'tau') - 15.732845290239 + 'f'.'delta' * ('o'[14] + 'f'.'delta' * (0.38493460186671 + 'o'[1] * ('o'[2] * (4.8972281541877 + ('o'[15] * (0.039420536879154 + 0.12558408424308 * 'o'[2]) - 3.0502617256965) * 'f'.'tau') - 0.85214708824206) + 'f'.'delta' * ('o'[1] * (1.389979956946 + 'o'[1] * ('o'[16] * (-(0.0082147637173963 + 0.47596035734923 * 'o'[17])) - 2.018991502357)) - 0.2799932969871 + 'f'.'delta' * (0.0439840744735 + 'o'[1] * ('o'[1] * (0.90572070719733 + 0.70522450087967 * 'o'[19]) - 0.44476435428739) + 'f'.'delta' * ('f'.'delta' * ('o'[1] * (0.094260751665092 + 0.16436278447961 * 'o'[21]) - 0.022175400873096 + 'f'.'delta' * ('f'.'delta' * ('f'.'delta' * ('o'[1] * (5.7922953628084e-4 + 0.0032308904703711 * 'o'[21]) + 'f'.'delta' * (8.0964802996215e-5 - 4.4923899061815e-5 * 'f'.'delta' * 'o'[22] - 1.6557679795037e-4 * 'f'.'tau')) - 0.014834345352472 * 'o'[22]) - 0.013503372241348 * 'o'[1])) + (0.10770512626332 + 'o'[1] * (-(0.32913623258954 + 0.50871062041158 * 'o'[20]))) * 'f'.'tau'))))) + 1.0658070028513 * log('f'.'delta');
    'f'.'fdelta' := (1.0658070028513 + 'f'.'delta' * ('o'[14] + 'f'.'delta' * (0.76986920373342 + 'o'[31] + 'f'.'delta' * ('o'[1] * (4.169939870838 + 'o'[1] * ('o'[16] * (-(0.0246442911521889 + 1.42788107204769 * 'o'[17])) - 6.056974507071)) - 0.8399798909613 + 'f'.'delta' * (0.175936297894 + 'o'[1] * ('o'[1] * (3.6228828287893 + 2.82089800351868 * 'o'[19]) - 1.77905741714956) + 'f'.'delta' * ('f'.'delta' * ('o'[1] * (0.56556450999055 + 0.98617670687766 * 'o'[21]) - 0.133052405238576 + 'f'.'delta' * ('f'.'delta' * ('f'.'delta' * ('o'[1] * (0.0052130658265276 + 0.0290780142333399 * 'o'[21]) + 'f'.'delta' * (8.0964802996215e-4 - 4.9416288967996e-4 * 'f'.'delta' * 'o'[22] - 0.0016557679795037 * 'f'.'tau')) - 0.118674762819776 * 'o'[22]) - 0.094523605689436 * 'o'[1])) + (0.5385256313166 + 'o'[1] * (-(1.6456811629477 + 2.5435531020579 * 'o'[20]))) * 'f'.'tau')))))) / 'f'.'delta';
    'f'.'fdeltadelta' := ('o'[32] * (0.76986920373342 + 'o'[31] + 'f'.'delta' * ('o'[1] * (8.339879741676 + 'o'[1] * ('o'[16] * (-(0.049288582304378 + 2.85576214409538 * 'o'[17])) - 12.113949014142)) - 1.6799597819226 + 'f'.'delta' * (0.527808893682 + 'o'[1] * ('o'[1] * (10.868648486368 + 8.462694010556 * 'o'[19]) - 5.3371722514487) + 'f'.'delta' * ('f'.'delta' * ('o'[1] * (2.82782254995276 + 4.9308835343883 * 'o'[21]) - 0.66526202619288 + 'f'.'delta' * ('f'.'delta' * ('f'.'delta' * ('o'[1] * (0.04170452661222 + 0.232624113866719 * 'o'[21]) + 'f'.'delta' * (0.0072868322696594 - 0.0049416288967996 * 'f'.'delta' * 'o'[22] - 0.0149019118155333 * 'f'.'tau')) - 0.83072333973843 * 'o'[22]) - 0.56714163413662 * 'o'[1])) + (2.1541025252664 + 'o'[1] * (-(6.5827246517908 + 10.1742124082316 * 'o'[20]))) * 'f'.'tau')))) - 1.0658070028513) / 'o'[32];
    'f'.'ftau' := 20.944396974307 + ('o'[3] * (18.3301634515678 + 'o'[4] * ('o'[1] * (14.4640436358204 - 0.194503669468755 * 'o'[6]) - 28.08078114862)) - 15.3735415757432) * 'f'.'tau' + 'f'.'delta' * ('o'[39] + 'f'.'delta' * ('f'.'tau' * ('o'[2] * (29.3833689251262 + ('o'[15] * (0.86725181134139 + 3.2651861903201 * 'o'[2]) - 21.3518320798755) * 'f'.'tau') - 1.70429417648412) + 'f'.'delta' * ((2.779959913892 + 'o'[1] * ('o'[16] * (-(0.131436219478341 + 12.37496929108 * 'o'[17])) - 8.075966009428)) * 'f'.'tau' + 'f'.'delta' * (('o'[1] * (3.6228828287893 + 18.3358370228714 * 'o'[19]) - 0.88952870857478) * 'f'.'tau' + 'f'.'delta' * (0.10770512626332 + 'o'[1] * (-(0.98740869776862 + 13.2264761307011 * 'o'[20])) + 'f'.'delta' * ((0.188521503330184 + 4.2734323964699 * 'o'[21]) * 'f'.'tau' + 'f'.'delta' * ('f'.'delta' * ('f'.'delta' * ('f'.'delta' * (-(1.6557679795037e-4 + 0.00116802137560719 * 'f'.'delta' * 'o'[40])) + (0.00115845907256168 + 0.084003152229649 * 'o'[21]) * 'f'.'tau') - 0.38569297916427 * 'o'[40]) - 0.027006744482696 * 'f'.'tau')))))));
    'f'.'ftautau' := 'o'[3] * (109.980980709407 + 'o'[4] * ('o'[1] * (159.104479994024 - 4.2790807283126 * 'o'[6]) - 252.72703033758)) - 15.3735415757432 + 'f'.'delta' * ('o'[2] * ((185.894192367068 - 174.645121293971 * 'o'[1]) * 'o'[7] - 34.573223420043) - 2.5308630955428 + 'f'.'delta' * ('o'[2] * (146.916844625631 + ('o'[15] * (18.2122880381691 + 81.629654758002 * 'o'[2]) - 128.110992479253) * 'f'.'tau') - 1.70429417648412 + 'f'.'delta' * (2.779959913892 + 'o'[1] * ('o'[16] * (-(1.97154329217511 + 309.374232277 * 'o'[17])) - 24.227898028284) + 'f'.'delta' * ('o'[1] * (10.868648486368 + 458.39592557179 * 'o'[19]) - 0.88952870857478 + 'f'.'delta' * ('f'.'delta' * (0.188521503330184 + 106.835809911747 * 'o'[21] + 'f'.'delta' * ('f'.'delta' * ('f'.'delta' * (0.00115845907256168 + 2.10007880574121 * 'o'[21] - 0.0292005343901797 * 'o'[21] * 'o'[32]) - 9.6423244791068 * 'o'[21]) - 0.027006744482696)) + (-(1.97481739553724 + 330.66190326753 * 'o'[20])) * 'f'.'tau')))));
    'f'.'fdeltatau' := 'o'[39] + 'f'.'delta' * ('f'.'tau' * ('o'[2] * (58.766737850252 + ('o'[15] * (1.73450362268278 + 6.5303723806402 * 'o'[2]) - 42.703664159751) * 'f'.'tau') - 3.4085883529682) + 'f'.'delta' * ((8.339879741676 + 'o'[1] * ('o'[16] * (-(0.39430865843502 + 37.12490787324 * 'o'[17])) - 24.227898028284)) * 'f'.'tau' + 'f'.'delta' * (('o'[1] * (14.4915313151573 + 73.343348091486 * 'o'[19]) - 3.5581148342991) * 'f'.'tau' + 'f'.'delta' * (0.5385256313166 + 'o'[1] * (-(4.9370434888431 + 66.132380653505 * 'o'[20])) + 'f'.'delta' * ((1.1311290199811 + 25.6405943788192 * 'o'[21]) * 'f'.'tau' + 'f'.'delta' * ('f'.'delta' * ('f'.'delta' * ('f'.'delta' * (-(0.0016557679795037 + 0.0128482351316791 * 'f'.'delta' * 'o'[40])) + (0.0104261316530551 + 0.75602837006684 * 'o'[21]) * 'f'.'tau') - 3.08554383331418 * 'o'[40]) - 0.189047211378872 * 'f'.'tau'))))));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g1' "Gibbs function for region 1: g(p,T)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.GibbsDerivs' 'g';
    Real 'pi1';
    Real 'tau1';
    Real[45] 'o';
    Real 'pl';
  algorithm
    'pl' := min('p', 2.2063999e7);
    assert('p' > 611.657, "IF97 medium function g1 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    assert('p' <= 1e8, "IF97 medium function g1: the input pressure (= " + String('p') + " Pa) is higher than 100 MPa", AssertionLevel.error);
    assert('T' >= 273.15, "IF97 medium function g1: the temperature (= " + String('T') + " K) is lower than 273.15 K!", AssertionLevel.error);
    'g'.'p' := 'p';
    'g'.'T' := 'T';
    'g'.'R_s' := 461.526;
    'g'.'pi' := 'p' / 1.653e7;
    'g'.'tau' := 1386.0 / 'T';
    'pi1' := 7.1 - 'g'.'pi';
    'tau1' := 'g'.'tau' - 1.222;
    'o'[1] := 'tau1' * 'tau1';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
    'o'[4] := 'o'[3] * 'tau1';
    'o'[5] := 1.0 / 'o'[4];
    'o'[6] := 'o'[1] * 'o'[2];
    'o'[7] := 'o'[1] * 'tau1';
    'o'[8] := 1.0 / 'o'[7];
    'o'[9] := 'o'[1] * 'o'[2] * 'o'[3];
    'o'[10] := 1.0 / 'o'[2];
    'o'[11] := 'o'[2] * 'tau1';
