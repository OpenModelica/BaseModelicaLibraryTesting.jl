    'o'[10] := 1167.0521452767 * 'o'[3];
    'o'[11] := 'o'[10] - 4823.2657361591 + 'o'[9];
    'o'[12] := 'o'[11] * 'o'[11];
    'o'[13] := 'o'[12] + 'o'[8];
    'o'[14] := 'o'[13] ^ 0.5;
    'o'[15] := -'o'[14];
    'o'[16] := -12020.82470247 * 'o'[1];
    'o'[17] := -1167.0521452767 * 'o'[3];
    'o'[18] := 4823.2657361591 + 'o'[15] + 'o'[16] + 'o'[17];
    'o'[19] := 1.0 / 'o'[18];
    'o'[20] := 2.0 * 'o'[19] * 'o'[5];
    't_sat' := 0.5 * (650.17534844798 + 'o'[20] - ((650.17534844798 + 'o'[20]) ^ 2.0 - 4.0 * (1300.35069689596 * 'o'[19] * 'o'[5] - 0.23855557567849)) ^ 0.5);
    annotation(derivative(order = 1) = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der' "Derivative function for tsat"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'der_p'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    output Real 'der_tsat'(unit = "K/s", quantity = "TemperatureSlope");
    Real 'dtp';
  algorithm
    'dtp' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dtsatofp'('p');
    'der_tsat' := 'dtp' * 'der_p';
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13' "Density at the boundary between regions 1 and 3"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'p2';
    Real[3] 'o';
  algorithm
    'p2' := 7.1 - 6.04960677555959e-8 * 'p';
    'o'[1] := 'p2' * 'p2';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
    'd' := 57.4756752485113 / (0.0737412153522555 + 'p2' * (0.00145092247736023 + 'p2' * (1.02697173772229e-4 + 'p2' * (1.14683182476084e-5 + 'p2' * (1.99080616601101e-6 + 'o'[1] * 'p2' * (1.13217858826367e-8 + 'o'[2] * 'o'[3] * 'p2' * (1.35549330686006e-17 + 'o'[1] * ('o'[1] * 'o'[2] * ('p2' * (3.29199117056433e-22 + (2.73712834080283e-24 * 'p2' - 5.17859076694812e-23) * 'p2') - 7.02987180039442e-22) - 3.11228834832975e-19))))))));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp23' "Density at the boundary between regions 2 and 3"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[13] 'o';
    Real 'taug';
    Real 'pi';
    Real 'gpi23';
  algorithm
    'pi' := 'p' / 1e6;
    'T' := 572.54459862746 + 31.3220101646784 * ('pi' - 13.91883977887) ^ 0.5;
    'o'[1] := ('pi' - 13.91883977887) ^ 0.5;
    'taug' := 540.0 / (572.54459862746 + 31.3220101646784 * 'o'[1]) - 0.5;
    'o'[2] := 'taug' * 'taug';
    'o'[3] := 'o'[2] * 'taug';
    'o'[4] := 'o'[2] * 'o'[2];
    'o'[5] := 'o'[4] * 'o'[4];
    'o'[6] := 'o'[5] * 'o'[5];
    'o'[7] := 'o'[4] * 'o'[5] * 'o'[6] * 'taug';
    'o'[8] := 'o'[4] * 'o'[5] * 'taug';
    'o'[9] := 'o'[2] * 'o'[4] * 'o'[5];
    'o'[10] := 'pi' * 'pi';
    'o'[11] := 'o'[10] * 'o'[10];
    'o'[12] := 'o'[4] * 'o'[6] * 'taug';
    'o'[13] := 'o'[6] * 'o'[6];
    'gpi23' := (1.0 + 'pi' * ('taug' * ('taug' * ((-(0.057581259083432 + 0.05032527872793 * 'o'[3])) * 'taug' - 0.045996013696365) - 0.017834862292358) - 0.0017731742473213 + 'pi' * ('taug' * (('o'[2] * ('o'[3] * (-(0.087594591301146 + 5.3349095828174e-5 * 'o'[7])) - 0.007878555448671) - 3.789797503263e-4) * 'taug' - 6.6065283340406e-5) + 'pi' * (6.1445213076927e-8 + (1.31612001853305e-6 + 'o'[2] * ('o'[3] * (-(0.0045101773626444 + 0.122004760687947 * 'o'[7])) - 9.683303171571e-5)) * 'taug' + 'pi' * ('taug' * ((5.116287140914e-8 + 1.92901490874028e-6 * 'taug') * 'taug' - 3.15389238237468e-9) + 'pi' * (1.14610381688305e-5 * 'o'[2] * 'o'[4] * 'taug' + 'pi' * ('o'[3] * ('o'[8] * (-(0.012702883392813 + 143.374451604624 * 'o'[2] * 'o'[6] * 'taug')) - 1.00288598706366e-10) + 'pi' * ('o'[2] * 'o'[5] * (-(8.8352662293707e-6 + 0.272627897050173 * 'o'[9])) * 'taug' - 4.1341695026989e-17 + 'pi' * ('o'[5] * (9.0049690883672e-11 - 65.8490727183984 * 'o'[4] * 'o'[5] * 'o'[6]) + 'pi' * (1.78287415218792e-7 * 'o'[8] + 'pi' * ('o'[4] * (1.0406965210174e-18 + 'o'[2] * (-(1.0234747095929e-12 + 1.0018179379511e-8 * 'o'[4])) * 'o'[4]) + 'o'[10] * 'o'[11] * ((1.71088510070544 * 'o'[12] - 1.29412653835176e-9) * 'o'[7] + 'o'[10] * ('o'[10] * ('o'[4] * 'o'[6] * (1.78371690710842e-23 + 'o'[2] * 'o'[4] * 'o'[5] * (6.1258633752464e-12 - 8.4004935396416e-5 * 'o'[8]) * 'taug') + 'pi' * ('pi' * (8.32192847496054e-5 * 'o'[13] * 'o'[4] * 'o'[6] * 'taug' + 'pi' * ('o'[2] * 'o'[5] * 'o'[6] * (1.75410265428146e-27 + (1.32995316841867e-15 - 2.26487297378904e-5 * 'o'[2] * 'o'[6]) * 'o'[9]) * 'pi' - 2.93678005497663e-14 * 'o'[13] * 'o'[2] * 'o'[4] * 'taug')) - 1.24017662339842e-24 * 'o'[12])) - 6.05920510335078 * 'o'[13] * 'o'[5] * 'o'[6] * 'taug'))))))))))))) / 'pi';
    'd' := 'p' / (461.526 * 'T' * 'pi' * 'gpi23');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp23';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofpt3' "Inverse iteration in region 3: (d) = f(p,T)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'delp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    output Integer 'error' = 0;
    Real 'dguess'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Integer 'i' = 0;
    Real 'dp';
    Real 'deld'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    'Modelica.Media.Common.NewtonDerivatives_pT' 'nDerivs';
    Boolean 'found' = false;
    Boolean 'supercritical';
    Boolean 'liquid';
    Real 'dmin'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'dmax'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Tmax'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'damping';
  algorithm
    'found' := false;
    assert('p' >= 1.65292e7, "BaseIF97.dofpt3: function called outside of region 3! p too low\np = " + String('p') + " Pa < " + "1.65292e+07" + " Pa", AssertionLevel.error);
    assert('T' >= 623.15, "BaseIF97.dofpt3: function called outside of region 3! T too low\nT = " + String('T') + " K < " + "623.15" + " K", AssertionLevel.error);
    assert('p' >= 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofT'('T'), "BaseIF97.dofpt3: function called outside of region 3! T too high\np = " + String('p') + " Pa, T = " + String('T') + " K", AssertionLevel.error);
    'supercritical' := 'p' > 2.2064e7;
    'damping' := 1.0;
    'Tmax' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofp'('p');

    if 'supercritical' then
      'dmax' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13'('p');
      'dmin' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp23'('p');
      'dguess' := 'dmax' - ('T' - 623.15) / (623.15 - 'Tmax') * ('dmax' - 'dmin');
    elseif true then
      'liquid' := 'T' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('p');

      if 'liquid' then
        'dmax' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp13'('p');
        'dmin' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b'('p');
        'dguess' := 1.1 * 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_T'('T') "Guess: 10 percent more than on the phase boundary for same T";
      elseif true then
        'dmax' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b'('p');
        'dmin' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofp23'('p');
        'dguess' := 0.9 * 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_T'('T') "Guess: 10% less than on the phase boundary for same T";
      end if;
    end if;

    while 'i' < 50 and not 'found' loop
      'd' := 'dguess';
      'f' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('d', 'T');
      'nDerivs' := 'Modelica.Media.Common.Helmholtz_pT'('f');
      'dp' := 'nDerivs'.'p' - 'p';

      if abs('dp' / 'p') <= 'delp' then
        'found' := true;
      end if;

      'deld' := 'dp' / 'nDerivs'.'pd' * 'damping';
      'd' := 'd' - 'deld';

      if 'd' > 'dmin' and 'd' < 'dmax' then
        'dguess' := 'd';
      elseif true then
        if 'd' > 'dmax' then
          'dguess' := 'dmax' - 1.4901161193847656e-8;
        elseif true then
          'dguess' := 'dmin' + 1.4901161193847656e-8;
        end if;
      end if;

      'i' := 'i' + 1;
    end while;

    if not 'found' then
      'error' := 1;
    end if;

    assert('error' <> 1, "Error in inverse function dofpt3: iteration failed", AssertionLevel.error);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofpt3';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofT' "Boundary function for region boundary between regions 2 and 3 (input temperature)"
    input Real 't'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    constant Real[5] 'n' = {348.05185628969, -1.1671859879975, 0.0010192970039326, 572.54459862746, 13.91883977887};
  algorithm
    'p' := 1e6 * ('n'[1] + 't' * ('n'[2] + 't' * 'n'[3]));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofT';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofp' "Boundary function for region boundary between regions 2 and 3 (input pressure)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 't'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    constant Real[5] 'n' = {348.05185628969, -1.1671859879975, 0.0010192970039326, 572.54459862746, 13.91883977887};
    Real 'pi';
  algorithm
    'pi' := 'p' / 1e6;
    assert('p' > 611.657, "IF97 medium function boundary23ofp called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    't' := 'n'[4] + sqrt(('pi' - 'n'[5]) / 'n'[3]);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofp';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.d1n' "Density in region 1 as function of p and T"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pi';
    Real 'pi1';
    Real 'tau';
    Real 'tau1';
    Real 'gpi';
    Real[11] 'o';
  algorithm
    'pi' := 'p' / 1.653e7;
    'tau' := 1386.0 / 'T';
    'pi1' := 7.1 - 'pi';
    'tau1' := 'tau' - 1.222;
    'o'[1] := 'tau1' * 'tau1';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
    'o'[4] := 'o'[1] * 'o'[2];
    'o'[5] := 'o'[1] * 'tau1';
    'o'[6] := 'o'[2] * 'tau1';
    'o'[7] := 'pi1' * 'pi1';
    'o'[8] := 'o'[7] * 'o'[7];
    'o'[9] := 'o'[8] * 'o'[8];
    'o'[10] := 'o'[3] * 'o'[3];
    'o'[11] := 'o'[10] * 'o'[10];
    'gpi' := 'pi1' * ('pi1' * ((9.5038934535162e-5 + 'o'[2] * (8.4812393955936e-6 + 2.55615384360309e-9 * 'o'[4])) / 'o'[2] + 'pi1' * ((8.9701127632e-6 + (2.60684891582404e-6 + 5.7366919751696e-13 * 'o'[2] * 'o'[3]) * 'o'[5]) / 'o'[6] + 'pi1' * (2.02584984300585e-6 / 'o'[3] + 'o'[7] * 'pi1' * ('o'[8] * 'o'[9] * 'pi1' * ('o'[7] * ('o'[7] * 'o'[8] * ('pi1' * ('pi1' * (2.99318679335866e-24 * 'pi1' / ('o'[11] * 'o'[3] * 'tau1') - 5.65070932023524e-23 / ('o'[11] * 'o'[3])) + 3.5842867920213e-22 / ('o'[1] * 'o'[11] * 'o'[2] * 'tau1')) - 7.63737668221055e-22 / ('o'[1] * 'o'[11] * 'o'[2])) - 3.33001080055983e-19 / ('o'[1] * 'o'[10] * 'o'[2] * 'o'[3] * 'tau1')) + 1.44400475720615e-17 / ('o'[10] * 'o'[2] * 'o'[3] * 'tau1')) + (1.01874413933128e-8 + 1.39398969845072e-9 * 'o'[6]) / ('o'[1] * 'o'[3] * 'tau1'))))) + (9.4368642146534e-4 + 'o'[5] * (6.0003561586052e-4 + ('o'[1] * (8.8283690661692e-6 + 1.45389992595188e-15 * 'o'[1] * 'o'[2] * 'o'[3]) - 9.5322787813974e-5) * 'tau1')) / 'o'[5]) + ('o'[1] * (6.0706301565874e-4 + 'o'[4] * (0.018990068218419 + 'tau1' * (0.032529748770505 + (0.021841717175414 + 5.283835796993e-5 * 'o'[1]) * 'tau1'))) - 2.8319080123804e-4) / ('o'[3] * 'tau1');
    'd' := 'p' / (461.526 * 'T' * 'pi' * 'gpi');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.d1n';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.d2n' "Density in region 2 as function of p and T"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pi';
    Real 'tau';
    Real 'tau2';
    Real 'gpi';
    Real[12] 'o';
  algorithm
    'pi' := 'p' / 1e6;
    'tau' := 540.0 / 'T';
    'tau2' := 'tau' - 0.5;
    'o'[1] := 'tau2' * 'tau2';
    'o'[2] := 'o'[1] * 'tau2';
    'o'[3] := 'o'[1] * 'o'[1];
    'o'[4] := 'o'[3] * 'o'[3];
    'o'[5] := 'o'[4] * 'o'[4];
    'o'[6] := 'o'[3] * 'o'[4] * 'o'[5] * 'tau2';
    'o'[7] := 'o'[3] * 'o'[4] * 'tau2';
    'o'[8] := 'o'[1] * 'o'[3] * 'o'[4];
    'o'[9] := 'pi' * 'pi';
    'o'[10] := 'o'[9] * 'o'[9];
    'o'[11] := 'o'[3] * 'o'[5] * 'tau2';
    'o'[12] := 'o'[5] * 'o'[5];
    'gpi' := (1.0 + 'pi' * ('tau2' * ('tau2' * ((-(0.057581259083432 + 0.05032527872793 * 'o'[2])) * 'tau2' - 0.045996013696365) - 0.017834862292358) - 0.0017731742473213 + 'pi' * ('tau2' * (('o'[1] * ('o'[2] * (-(0.087594591301146 + 5.3349095828174e-5 * 'o'[6])) - 0.007878555448671) - 3.789797503263e-4) * 'tau2' - 6.6065283340406e-5) + 'pi' * (6.1445213076927e-8 + (1.31612001853305e-6 + 'o'[1] * ('o'[2] * (-(0.0045101773626444 + 0.122004760687947 * 'o'[6])) - 9.683303171571e-5)) * 'tau2' + 'pi' * ('tau2' * ((5.116287140914e-8 + 1.92901490874028e-6 * 'tau2') * 'tau2' - 3.15389238237468e-9) + 'pi' * (1.14610381688305e-5 * 'o'[1] * 'o'[3] * 'tau2' + 'pi' * ('o'[2] * ('o'[7] * (-(0.012702883392813 + 143.374451604624 * 'o'[1] * 'o'[5] * 'tau2')) - 1.00288598706366e-10) + 'pi' * ('o'[1] * 'o'[4] * (-(8.8352662293707e-6 + 0.272627897050173 * 'o'[8])) * 'tau2' - 4.1341695026989e-17 + 'pi' * ('o'[4] * (9.0049690883672e-11 - 65.8490727183984 * 'o'[3] * 'o'[4] * 'o'[5]) + 'pi' * (1.78287415218792e-7 * 'o'[7] + 'pi' * ('o'[3] * (1.0406965210174e-18 + 'o'[1] * (-(1.0234747095929e-12 + 1.0018179379511e-8 * 'o'[3])) * 'o'[3]) + 'o'[10] * 'o'[9] * ((1.71088510070544 * 'o'[11] - 1.29412653835176e-9) * 'o'[6] + 'o'[9] * ('o'[9] * ('o'[3] * 'o'[5] * (1.78371690710842e-23 + 'o'[1] * 'o'[3] * 'o'[4] * (6.1258633752464e-12 - 8.4004935396416e-5 * 'o'[7]) * 'tau2') + 'pi' * ('pi' * (8.32192847496054e-5 * 'o'[12] * 'o'[3] * 'o'[5] * 'tau2' + 'pi' * ('o'[1] * 'o'[4] * 'o'[5] * (1.75410265428146e-27 + (1.32995316841867e-15 - 2.26487297378904e-5 * 'o'[1] * 'o'[5]) * 'o'[8]) * 'pi' - 2.93678005497663e-14 * 'o'[1] * 'o'[12] * 'o'[3] * 'tau2')) - 1.24017662339842e-24 * 'o'[11])) - 6.05920510335078 * 'o'[12] * 'o'[4] * 'o'[5] * 'tau2'))))))))))))) / 'pi';
    'd' := 'p' / (461.526 * 'T' * 'pi' * 'gpi');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.d2n';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_pT' "Return the current region (valid values: 1,2,3,5) in IF97, given pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Integer 'mode' = 0;
    output Integer 'region';
  algorithm
    if 'mode' <> 0 then
      'region' := 'mode';
    elseif true then
      if 'p' < 1.65292e7 then
        if 'T' > 1073.15 then
          'region' := 5;
        elseif 'T' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('p') then
          'region' := 2;
        elseif true then
          'region' := 1;
        end if;
      elseif true then
        if 'T' < 623.15 then
          'region' := 1;
        elseif 'T' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofp'('p') then
          'region' := 3;
        elseif true then
          'region' := 2;
        end if;
      end if;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_pT';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_T' "Density of saturated water"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat'('T');

    if 'T' < 623.15 then
      'd' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.d1n'('p', 'T');
    elseif 'T' < 647.096 then
      'd' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b'('p');
    elseif true then
      'd' := 322.0;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_T';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b' "Explicit approximation of liquid density on the boundary between regions 4 and 3"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'dl'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'x';
  algorithm
    if 'p' < 2.2064e7 then
      'x' := acos('p' / 2.2064e7);
      'dl' := (1.0 + 'x' * (1.903224079094824 + 'x' * ('x' * ('x' * (94.34196116778385 + 'x' * ('x' * (796.6627910598293 + 'x' * ('x' * (673.2581177021598 + (5.2536560808895e-4 * 'x' - 191.43077336405156) * 'x') - 994.5385383600702)) - 369.3676833623383)) - 8.191449323843552) - 2.5314861802401123))) * 322.0;
    elseif true then
      'dl' := 322.0;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_T' "Density of saturated vapour"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat'('T');

    if 'T' < 623.15 then
      'd' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.d2n'('p', 'T');
    elseif 'T' < 647.096 then
      'd' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b'('p');
    elseif true then
      'd' := 322.0;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_T';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b' "Explicit approximation of vapour density on the boundary between regions 4 and 2"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'dv'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'x';
  algorithm
    if 'p' < 2.2064e7 then
      'x' := acos('p' / 2.2064e7);
      'dv' := (1.0 + 'x' * ('x' * ('x' * (59.18702203076563 + 'x' * ('x' * (1437.2007245332388 + 'x' * ('x' * (3740.5790348670057 + 'x' * ((725.8761975803782 - 0.0011151111658332337 * 'x') * 'x' - 2537.375817253895)) - 3015.853540307519)) - 403.5391431811611)) - 1.1447872718878493) - 1.8463850803362596)) * 322.0;
    elseif true then
      'dv' := 322.0;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b';

  function 'Modelica.Utilities.Streams.error' "Print error message and cancel all actions - in case of an unrecoverable error"
    input String 'string';
  algorithm
    assert(false, 'string', AssertionLevel.error);
  end 'Modelica.Utilities.Streams.error';

