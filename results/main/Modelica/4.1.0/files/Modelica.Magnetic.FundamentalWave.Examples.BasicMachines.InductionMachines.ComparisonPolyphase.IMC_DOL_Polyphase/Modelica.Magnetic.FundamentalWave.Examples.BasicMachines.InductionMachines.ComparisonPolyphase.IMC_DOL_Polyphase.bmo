    -'aimc3.rotorCage.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].v' = 'aimc3.rotorCage.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].N.re' * der('aimc3.rotorCage.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.re') - (-'aimc3.rotorCage.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].N.im') * der('aimc3.rotorCage.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.im');
    'aimc3.rotorCage.resistor.resistor[1].R_actual' = 0.04;
    'aimc3.rotorCage.resistor.resistor[1].v' = 'aimc3.rotorCage.resistor.resistor[1].R_actual' * 'aimc3.rotorCage.resistor.resistor[1].i';
    'aimc3.rotorCage.resistor.resistor[1].LossPower' = 'aimc3.rotorCage.resistor.resistor[1].v' * 'aimc3.rotorCage.resistor.resistor[1].i';
    0.0 = 'aimc3.rotorCage.resistor.resistor[1].p.i' + 'aimc3.rotorCage.resistor.resistor[1].n.i';
    'aimc3.rotorCage.resistor.resistor[1].i' = 'aimc3.rotorCage.resistor.resistor[1].p.i';
    'aimc3.rotorCage.resistor.resistor[1].v' = 'aimc3.rotorCage.resistor.resistor[1].p.v' - 'aimc3.rotorCage.resistor.resistor[1].n.v';
    'aimc3.rotorCage.resistor.resistor[2].R_actual' = 0.04;
    'aimc3.rotorCage.resistor.resistor[2].v' = 'aimc3.rotorCage.resistor.resistor[2].R_actual' * 'aimc3.rotorCage.resistor.resistor[2].i';
    'aimc3.rotorCage.resistor.resistor[2].LossPower' = 'aimc3.rotorCage.resistor.resistor[2].v' * 'aimc3.rotorCage.resistor.resistor[2].i';
    0.0 = 'aimc3.rotorCage.resistor.resistor[2].p.i' + 'aimc3.rotorCage.resistor.resistor[2].n.i';
    'aimc3.rotorCage.resistor.resistor[2].i' = 'aimc3.rotorCage.resistor.resistor[2].p.i';
    'aimc3.rotorCage.resistor.resistor[2].v' = 'aimc3.rotorCage.resistor.resistor[2].p.v' - 'aimc3.rotorCage.resistor.resistor[2].n.v';
    'aimc3.rotorCage.resistor.resistor[3].R_actual' = 0.04;
    'aimc3.rotorCage.resistor.resistor[3].v' = 'aimc3.rotorCage.resistor.resistor[3].R_actual' * 'aimc3.rotorCage.resistor.resistor[3].i';
    'aimc3.rotorCage.resistor.resistor[3].LossPower' = 'aimc3.rotorCage.resistor.resistor[3].v' * 'aimc3.rotorCage.resistor.resistor[3].i';
    0.0 = 'aimc3.rotorCage.resistor.resistor[3].p.i' + 'aimc3.rotorCage.resistor.resistor[3].n.i';
    'aimc3.rotorCage.resistor.resistor[3].i' = 'aimc3.rotorCage.resistor.resistor[3].p.i';
    'aimc3.rotorCage.resistor.resistor[3].v' = 'aimc3.rotorCage.resistor.resistor[3].p.v' - 'aimc3.rotorCage.resistor.resistor[3].n.v';
    'aimc3.rotorCage.resistor.v[1]' = 'aimc3.rotorCage.resistor.plug_p.pin[1].v' - 'aimc3.rotorCage.resistor.plug_n.pin[1].v';
    'aimc3.rotorCage.resistor.v[2]' = 'aimc3.rotorCage.resistor.plug_p.pin[2].v' - 'aimc3.rotorCage.resistor.plug_n.pin[2].v';
    'aimc3.rotorCage.resistor.v[3]' = 'aimc3.rotorCage.resistor.plug_p.pin[3].v' - 'aimc3.rotorCage.resistor.plug_n.pin[3].v';
    'aimc3.rotorCage.resistor.i[1]' = 'aimc3.rotorCage.resistor.plug_p.pin[1].i';
    'aimc3.rotorCage.resistor.i[2]' = 'aimc3.rotorCage.resistor.plug_p.pin[2].i';
    'aimc3.rotorCage.resistor.i[3]' = 'aimc3.rotorCage.resistor.plug_p.pin[3].i';
    'aimc3.rotorCage.ground.p.v' = 0.0;
    'aimc3.rotorCage.thermalCollector.port_b.Q_flow' + 'aimc3.rotorCage.thermalCollector.port_a[1].Q_flow' + 'aimc3.rotorCage.thermalCollector.port_a[2].Q_flow' + 'aimc3.rotorCage.thermalCollector.port_a[3].Q_flow' = 0.0;
    'aimc3.rotorCage.thermalCollector.port_a[1].T' = 'aimc3.rotorCage.thermalCollector.port_b.T';
    'aimc3.rotorCage.thermalCollector.port_a[2].T' = 'aimc3.rotorCage.thermalCollector.port_b.T';
    'aimc3.rotorCage.thermalCollector.port_a[3].T' = 'aimc3.rotorCage.thermalCollector.port_b.T';
    1.5707963267948966 * 'aimc3.rotorCage.strayReluctance.V_m.re' = 4630.138908469983 * 'aimc3.rotorCage.strayReluctance.Phi.re';
    1.5707963267948966 * 'aimc3.rotorCage.strayReluctance.V_m.im' = 4630.138908469983 * 'aimc3.rotorCage.strayReluctance.Phi.im';
    'aimc3.rotorCage.strayReluctance.port_p.Phi.re' + 'aimc3.rotorCage.strayReluctance.port_n.Phi.re' = 0.0;
    'aimc3.rotorCage.strayReluctance.port_p.Phi.im' + 'aimc3.rotorCage.strayReluctance.port_n.Phi.im' = 0.0;
    'loadInertia3.phi' = 'loadInertia3.flange_a.phi';
    'loadInertia3.phi' = 'loadInertia3.flange_b.phi';
    'loadInertia3.w' = der('loadInertia3.phi');
    'loadInertia3.a' = der('loadInertia3.w');
    0.29 * 'loadInertia3.a' = 'loadInertia3.flange_a.tau' + 'loadInertia3.flange_b.tau';
    'quadraticLoadTorque3.w' = der('quadraticLoadTorque3.phi');
    'quadraticLoadTorque3.tau' = -'quadraticLoadTorque3.flange.tau';
    'quadraticLoadTorque3.tau' = (-161.4) * smooth(1, if 'quadraticLoadTorque3.w' >= 0.0 then ('quadraticLoadTorque3.w' / 150.84357126211393) ^ 2.0 else -('quadraticLoadTorque3.w' / 150.84357126211393) ^ 2.0);
    'quadraticLoadTorque3.phi' = 'quadraticLoadTorque3.flange.phi' - 'quadraticLoadTorque3.phi_support';
    'quadraticLoadTorque3.phi_support' = 0.0;
    'gain.y' = 1.6666666666666667 * 'gain.u';
    'feedback.y' = 'feedback.u1' - 'feedback.u2';
  initial algorithm
    assert(true, "5 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
  initial algorithm
    assert(true, "3 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
    annotation(experiment(StopTime = 1.5, Interval = 1E-4, Tolerance = 1e-06));
  end 'IMC_DOL_Polyphase';
end 'IMC_DOL_Polyphase';
