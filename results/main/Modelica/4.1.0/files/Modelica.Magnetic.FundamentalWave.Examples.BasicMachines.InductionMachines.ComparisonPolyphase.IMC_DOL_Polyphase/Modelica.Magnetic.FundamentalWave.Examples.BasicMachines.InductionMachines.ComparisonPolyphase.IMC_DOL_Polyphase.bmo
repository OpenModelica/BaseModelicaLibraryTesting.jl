  model 'IMC_DOL_Polyphase' "Direct on line start of polyphase induction machine with squirrel cage"
    constant Integer 'm3' = 3 "Number of stator phases of three-phase system";
    parameter Integer 'm' = 5 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'tOn'(unit = "s", quantity = "Time") = 0.1 "Start time of machine";
    parameter Real 'T_Load'(unit = "N.m", quantity = "Torque") = 161.4 "Nominal load torque";
    parameter Real 'w_Load'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal load speed";
    parameter Real 'J_Load'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load inertia";
    parameter Integer 'p' = 2 "Number of pole pairs";
    Real 'groundM.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'groundM.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
