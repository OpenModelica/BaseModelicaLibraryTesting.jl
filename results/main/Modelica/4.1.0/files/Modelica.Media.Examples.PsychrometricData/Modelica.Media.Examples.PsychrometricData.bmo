  initial equation
    'x' = 0.0;
  equation
    'medium_T[1].T_degC' = 'medium_T[1].T' - 273.15;
    'medium_T[1].p_bar' = 'medium_T[1].p' / 1e5;
    'medium_T[2].T_degC' = 'medium_T[2].T' - 273.15;
