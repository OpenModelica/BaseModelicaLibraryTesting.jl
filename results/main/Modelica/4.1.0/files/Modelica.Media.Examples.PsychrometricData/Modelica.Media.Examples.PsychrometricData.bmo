    Real 'hx_T[10]'(unit = "J/kg", quantity = "SpecificEnergy") "h_1+x for constant T";
    Real 'hx_T[11]'(unit = "J/kg", quantity = "SpecificEnergy") "h_1+x for constant T";
    Real 'hx_h[1]'(fixed = true, start = -2e4, unit = "J/kg", quantity = "SpecificEnergy") "Constanst h_1+x";
    Real 'hx_h[2]'(fixed = true, start = -1e4, unit = "J/kg", quantity = "SpecificEnergy") "Constanst h_1+x";
    Real 'hx_h[3]'(fixed = true, start = 0.0, unit = "J/kg", quantity = "SpecificEnergy") "Constanst h_1+x";
    Real 'hx_h[4]'(fixed = true, start = 1e4, unit = "J/kg", quantity = "SpecificEnergy") "Constanst h_1+x";
