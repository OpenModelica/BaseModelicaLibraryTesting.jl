    Real 'ps_phi[9]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Saturation pressure for constant-phi-lines";
    Real 'ps_phi[10]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Saturation pressure for constant-phi-lines";
    Real 'T_phi[1]'(nominal = 300.0, start = 290.0, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'T_phi[2]'(nominal = 300.0, start = 290.0, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
