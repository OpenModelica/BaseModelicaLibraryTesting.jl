    Real 'T_phi[10]'(nominal = 300.0, start = 290.0, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Boolean 'fog[1]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[2]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[3]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[4]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[5]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[6]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[7]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[8]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[9]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[10]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Boolean 'fog[11]'(start = false) "Triggers events at intersection of isotherms with phi=1";
    Real 'pd[1]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[2]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[3]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[4]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[5]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[6]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[7]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[8]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[9]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[10]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
    Real 'pd[11]'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Steam partial pressure along isotherms";
  initial equation
    'x' = 0.0;
  equation
    'medium_T[1].T_degC' = 'medium_T[1].T' - 273.15;
    'medium_T[1].p_bar' = 'medium_T[1].p' / 1e5;
    'medium_T[2].T_degC' = 'medium_T[2].T' - 273.15;
    'medium_T[2].p_bar' = 'medium_T[2].p' / 1e5;
    'medium_T[3].T_degC' = 'medium_T[3].T' - 273.15;
    'medium_T[3].p_bar' = 'medium_T[3].p' / 1e5;
    'medium_T[4].T_degC' = 'medium_T[4].T' - 273.15;
    'medium_T[4].p_bar' = 'medium_T[4].p' / 1e5;
    'medium_T[5].T_degC' = 'medium_T[5].T' - 273.15;
    'medium_T[5].p_bar' = 'medium_T[5].p' / 1e5;
    'medium_T[6].T_degC' = 'medium_T[6].T' - 273.15;
    'medium_T[6].p_bar' = 'medium_T[6].p' / 1e5;
    'medium_T[7].T_degC' = 'medium_T[7].T' - 273.15;
    'medium_T[7].p_bar' = 'medium_T[7].p' / 1e5;
    'medium_T[8].T_degC' = 'medium_T[8].T' - 273.15;
    'medium_T[8].p_bar' = 'medium_T[8].p' / 1e5;
    'medium_T[9].T_degC' = 'medium_T[9].T' - 273.15;
    'medium_T[9].p_bar' = 'medium_T[9].p' / 1e5;
    'medium_T[10].T_degC' = 'medium_T[10].T' - 273.15;
    'medium_T[10].p_bar' = 'medium_T[10].p' / 1e5;
    'medium_T[11].T_degC' = 'medium_T[11].T' - 273.15;
    'medium_T[11].p_bar' = 'medium_T[11].p' / 1e5;
    'medium_phi[1].T_degC' = 'medium_phi[1].T' - 273.15;
    'medium_phi[1].p_bar' = 'medium_phi[1].p' / 1e5;
    'medium_phi[2].T_degC' = 'medium_phi[2].T' - 273.15;
    'medium_phi[2].p_bar' = 'medium_phi[2].p' / 1e5;
    'medium_phi[3].T_degC' = 'medium_phi[3].T' - 273.15;
    'medium_phi[3].p_bar' = 'medium_phi[3].p' / 1e5;
    'medium_phi[4].T_degC' = 'medium_phi[4].T' - 273.15;
    'medium_phi[4].p_bar' = 'medium_phi[4].p' / 1e5;
    'medium_phi[5].T_degC' = 'medium_phi[5].T' - 273.15;
    'medium_phi[5].p_bar' = 'medium_phi[5].p' / 1e5;
    'medium_phi[6].T_degC' = 'medium_phi[6].T' - 273.15;
    'medium_phi[6].p_bar' = 'medium_phi[6].p' / 1e5;
    'medium_phi[7].T_degC' = 'medium_phi[7].T' - 273.15;
    'medium_phi[7].p_bar' = 'medium_phi[7].p' / 1e5;
    'medium_phi[8].T_degC' = 'medium_phi[8].T' - 273.15;
    'medium_phi[8].p_bar' = 'medium_phi[8].p' / 1e5;
    'medium_phi[9].T_degC' = 'medium_phi[9].T' - 273.15;
    'medium_phi[9].p_bar' = 'medium_phi[9].p' / 1e5;
    'medium_phi[10].T_degC' = 'medium_phi[10].T' - 273.15;
    'medium_phi[10].p_bar' = 'medium_phi[10].p' / 1e5;
    assert('medium_T[1].T' >= 190.0 and 'medium_T[1].T' <= 647.0, "\nTemperature T is not in the allowed range\n190.0 K <= (T =" + String('medium_T[1].T') + " K) <= 647.0 K\nrequired from medium model \"" + "Moist air" + "\".", AssertionLevel.error);
    'medium_T[1].MM' = 1.0 / ('medium_T[1].Xi[1]' / 0.01801528 + (1.0 - 'medium_T[1].Xi[1]') / 0.0289651159);
    'medium_T[1].p_steam_sat' = min('Modelica.Media.Examples.PsychrometricData.Medium.saturationPressure'('medium_T[1].T'), 0.999 * 'medium_T[1].p');
    'medium_T[1].X_sat' = min('medium_T[1].p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'medium_T[1].p' - 'medium_T[1].p_steam_sat') * (1.0 - 'medium_T[1].Xi[1]'), 1.0) "Water content at saturation with respect to actual water content";
    'medium_T[1].X_liquid' = max('medium_T[1].Xi[1]' - 'medium_T[1].X_sat', 0.0);
    'medium_T[1].X_steam' = 'medium_T[1].Xi[1]' - 'medium_T[1].X_liquid';
    'medium_T[1].X_air' = 1.0 - 'medium_T[1].Xi[1]';
    'medium_T[1].h' = 'Modelica.Media.Examples.PsychrometricData.Medium.specificEnthalpy_pTX'('medium_T[1].p', 'medium_T[1].T', {'medium_T[1].Xi[1]'});
    'medium_T[1].R_s' = 287.0525368759184 * ('medium_T[1].X_air' / (1.0 - 'medium_T[1].X_liquid')) + 461.5254384056201 * 'medium_T[1].X_steam' / (1.0 - 'medium_T[1].X_liquid');
    'medium_T[1].u' = 'medium_T[1].h' - 'medium_T[1].R_s' * 'medium_T[1].T';
    'medium_T[1].d' = 'medium_T[1].p' / ('medium_T[1].R_s' * 'medium_T[1].T');
    'medium_T[1].state.p' = 'medium_T[1].p';
    'medium_T[1].state.T' = 'medium_T[1].T';
    'medium_T[1].state.X[1]' = 'medium_T[1].X[1]';
    'medium_T[1].state.X[2]' = 'medium_T[1].X[2]';
    'medium_T[1].x_sat' = 0.6219647130774989 * 'medium_T[1].p_steam_sat' / max(2.220446049250313e-14, 'medium_T[1].p' - 'medium_T[1].p_steam_sat');
    'medium_T[1].x_water' = 'medium_T[1].Xi[1]' / max('medium_T[1].X_air', 2.220446049250313e-14);
    'medium_T[1].phi' = 'medium_T[1].p' / 'medium_T[1].p_steam_sat' * 'medium_T[1].Xi[1]' / ('medium_T[1].Xi[1]' + 0.6219647130774989 * 'medium_T[1].X_air');
    'medium_T[1].Xi[1]' = 'medium_T[1].X[1]';
    'medium_T[1].X[2]' = 1.0 - 'medium_T[1].Xi[1]';
    assert('medium_T[1].X[1]' >= (-1e-5) and 'medium_T[1].X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('medium_T[1].X[1]') + "of substance " + "water" + "\nof medium " + "Moist air" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium_T[1].X[2]' >= (-1e-5) and 'medium_T[1].X[2]' <= 1.00001, "Mass fraction X[" + String(2) + "] = " + String('medium_T[1].X[2]') + "of substance " + "air" + "\nof medium " + "Moist air" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium_T[1].p' >= 0.0, "Pressure (= " + String('medium_T[1].p') + " Pa) of medium \"" + "Moist air" + "\" is negative\n(Temperature = " + String('medium_T[1].T') + " K)", AssertionLevel.error);
    assert('medium_T[2].T' >= 190.0 and 'medium_T[2].T' <= 647.0, "\nTemperature T is not in the allowed range\n190.0 K <= (T =" + String('medium_T[2].T') + " K) <= 647.0 K\nrequired from medium model \"" + "Moist air" + "\".", AssertionLevel.error);
    'medium_T[2].MM' = 1.0 / ('medium_T[2].Xi[1]' / 0.01801528 + (1.0 - 'medium_T[2].Xi[1]') / 0.0289651159);
    'medium_T[2].p_steam_sat' = min('Modelica.Media.Examples.PsychrometricData.Medium.saturationPressure'('medium_T[2].T'), 0.999 * 'medium_T[2].p');
    'medium_T[2].X_sat' = min('medium_T[2].p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'medium_T[2].p' - 'medium_T[2].p_steam_sat') * (1.0 - 'medium_T[2].Xi[1]'), 1.0) "Water content at saturation with respect to actual water content";
    'medium_T[2].X_liquid' = max('medium_T[2].Xi[1]' - 'medium_T[2].X_sat', 0.0);
    'medium_T[2].X_steam' = 'medium_T[2].Xi[1]' - 'medium_T[2].X_liquid';
    'medium_T[2].X_air' = 1.0 - 'medium_T[2].Xi[1]';
    'medium_T[2].h' = 'Modelica.Media.Examples.PsychrometricData.Medium.specificEnthalpy_pTX'('medium_T[2].p', 'medium_T[2].T', {'medium_T[2].Xi[1]'});
    'medium_T[2].R_s' = 287.0525368759184 * ('medium_T[2].X_air' / (1.0 - 'medium_T[2].X_liquid')) + 461.5254384056201 * 'medium_T[2].X_steam' / (1.0 - 'medium_T[2].X_liquid');
    'medium_T[2].u' = 'medium_T[2].h' - 'medium_T[2].R_s' * 'medium_T[2].T';
    'medium_T[2].d' = 'medium_T[2].p' / ('medium_T[2].R_s' * 'medium_T[2].T');
    'medium_T[2].state.p' = 'medium_T[2].p';
    'medium_T[2].state.T' = 'medium_T[2].T';
    'medium_T[2].state.X[1]' = 'medium_T[2].X[1]';
