    'terminalBox.star.plugToPins_p.plugToPin_p[2].plug_p.pin[2].i.im' = -'terminalBox.star.plugToPins_p.plugToPin_p[2].pin_p.i.im';
    'terminalBox.star.plugToPins_p.plugToPin_p[2].plug_p.pin[3].i.re' = 0.0;
    'terminalBox.star.plugToPins_p.plugToPin_p[2].plug_p.pin[3].i.im' = 0.0;
    'terminalBox.star.plugToPins_p.plugToPin_p[3].plug_p.reference.gamma' = 'terminalBox.star.plugToPins_p.plugToPin_p[3].pin_p.reference.gamma';
    'terminalBox.star.plugToPins_p.plugToPin_p[3].pin_p.v.re' = 'terminalBox.star.plugToPins_p.plugToPin_p[3].plug_p.pin[3].v.re';
    'terminalBox.star.plugToPins_p.plugToPin_p[3].pin_p.v.im' = 'terminalBox.star.plugToPins_p.plugToPin_p[3].plug_p.pin[3].v.im';
