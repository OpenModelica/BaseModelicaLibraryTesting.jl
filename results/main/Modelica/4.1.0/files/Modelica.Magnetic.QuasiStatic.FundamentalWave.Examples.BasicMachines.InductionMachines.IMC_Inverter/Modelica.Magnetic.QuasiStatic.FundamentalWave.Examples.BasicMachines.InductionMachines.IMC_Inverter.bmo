    'terminalBox.star.plugToPins_p.plugToPin_p[2].pin_p.v.re' = 'terminalBox.star.plugToPins_p.plugToPin_p[2].plug_p.pin[2].v.re';
    'terminalBox.star.plugToPins_p.plugToPin_p[2].pin_p.v.im' = 'terminalBox.star.plugToPins_p.plugToPin_p[2].plug_p.pin[2].v.im';
    'terminalBox.star.plugToPins_p.plugToPin_p[2].plug_p.pin[1].i.re' = 0.0;
    'terminalBox.star.plugToPins_p.plugToPin_p[2].plug_p.pin[1].i.im' = 0.0;
