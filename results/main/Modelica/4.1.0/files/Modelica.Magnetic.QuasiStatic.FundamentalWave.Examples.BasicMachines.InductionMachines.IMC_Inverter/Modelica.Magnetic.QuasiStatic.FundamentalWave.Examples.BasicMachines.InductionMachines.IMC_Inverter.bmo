    'terminalBox.star.plugToPins_p.plugToPin_p[3].plug_p.pin[3].i.re' = -'terminalBox.star.plugToPins_p.plugToPin_p[3].pin_p.i.re';
    'terminalBox.star.plugToPins_p.plugToPin_p[3].plug_p.pin[3].i.im' = -'terminalBox.star.plugToPins_p.plugToPin_p[3].pin_p.i.im';
    'ground1.pin.v.re' = 0.0;
    'ground1.pin.v.im' = 0.0;
  initial algorithm
