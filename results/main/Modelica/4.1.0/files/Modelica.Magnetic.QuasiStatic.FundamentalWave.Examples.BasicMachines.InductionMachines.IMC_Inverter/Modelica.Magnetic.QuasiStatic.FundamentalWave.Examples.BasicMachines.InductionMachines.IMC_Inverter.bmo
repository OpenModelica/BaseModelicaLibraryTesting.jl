    Real 'aimc.plug_sp.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'aimc.plug_sp.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'aimc.plug_sn.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'aimc.plug_sn.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
