    'body.frame_a.t[1]' = 0.001 * 'body.z_a[1]' + 'body.w_a[2]' * (0.001 * 'body.w_a[3]') - 'body.w_a[3]' * (0.001 * 'body.w_a[2]');
    'body.frame_a.t[2]' = 0.001 * 'body.z_a[2]' + 'body.w_a[3]' * (0.001 * 'body.w_a[1]') - 'body.w_a[1]' * (0.001 * 'body.w_a[3]') - 10.0 * 'body.frame_a.f[3]';
