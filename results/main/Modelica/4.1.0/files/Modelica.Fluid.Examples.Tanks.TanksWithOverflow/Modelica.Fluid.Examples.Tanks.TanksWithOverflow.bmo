    Real 'lowerTank.Qb_flow'(unit = "W", quantity = "Power") "Heat flow across boundaries or energy source/sink";
    Real 'lowerTank.Wb_flow'(unit = "W", quantity = "Power") "Work flow across boundaries or source term";
    parameter Boolean 'lowerTank.initialize_p' = false "= true to set up initial equations for pressure";
    parameter Integer 'lowerTank.nPorts' = 2 "Number of ports" annotation(Evaluate = true);
    Real 'lowerTank.ports[1].m_flow'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Linear cold water") "Mass flow rate from the connection point into the component";
    Real 'lowerTank.ports[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'lowerTank.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'lowerTank.ports[2].m_flow'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Linear cold water") "Mass flow rate from the connection point into the component";
    Real 'lowerTank.ports[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'lowerTank.ports[2].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'lowerTank.use_portsData' = true "= false to neglect pressure loss and kinetic energy" annotation(Evaluate = true);
    parameter Real 'lowerTank.portsData[1].diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Inner (hydraulic) diameter of inlet/outlet port";
    parameter Real 'lowerTank.portsData[1].height'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Height over the bottom of the vessel";
    parameter Real 'lowerTank.portsData[1].zeta_out'(min = 0.0) = 0.5 "Hydraulic resistance out of vessel, default 0.5 for small diameter mounted flush with the wall";
    parameter Real 'lowerTank.portsData[1].zeta_in'(min = 0.0) = 1.04 "Hydraulic resistance into vessel, default 1.04 for small diameter mounted flush with the wall";
    parameter Real 'lowerTank.portsData[2].diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Inner (hydraulic) diameter of inlet/outlet port";
    parameter Real 'lowerTank.portsData[2].height'(min = 0.0, unit = "m", quantity = "Length") = 6.0 "Height over the bottom of the vessel";
    parameter Real 'lowerTank.portsData[2].zeta_out'(min = 0.0) = 0.5 "Hydraulic resistance out of vessel, default 0.5 for small diameter mounted flush with the wall";
    parameter Real 'lowerTank.portsData[2].zeta_in'(min = 0.0) = 1.04 "Hydraulic resistance into vessel, default 1.04 for small diameter mounted flush with the wall";
    parameter Real 'lowerTank.m_flow_nominal'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Linear cold water") = 1.0 "Nominal value for mass flow rates in ports";
    parameter Real 'lowerTank.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Regularization range at zero mass flow rate";
    parameter Boolean 'lowerTank.use_Re' = false "= true, if turbulent region is defined by Re, otherwise by m_flow_small" annotation(Evaluate = true);
    Real 'lowerTank.ports_H_flow[1]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate");
    Real 'lowerTank.ports_H_flow[2]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate");
    parameter Boolean 'lowerTank.use_HeatTransfer' = false "= true to use the HeatTransfer model";
    parameter Integer 'lowerTank.heatTransfer.n' = 1 "Number of heat transfer segments" annotation(Evaluate = true);
    Real 'lowerTank.heatTransfer.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'lowerTank.heatTransfer.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'lowerTank.heatTransfer.surfaceAreas[1]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'lowerTank.heatTransfer.Q_flows[1]'(unit = "W", quantity = "Power") "Heat flow rates";
    parameter Boolean 'lowerTank.heatTransfer.use_k' = false "= true to use k value for thermal isolation";
    parameter Real 'lowerTank.heatTransfer.k'(unit = "W/(m2.K)", quantity = "CoefficientOfHeatTransfer") = 0.0 "Heat transfer coefficient to ambient" annotation(Evaluate = true);
    parameter Real 'lowerTank.heatTransfer.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'lowerTank.heatTransfer.heatPorts[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'lowerTank.heatTransfer.heatPorts[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'lowerTank.heatTransfer.Ts[1]'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    Real 'lowerTank.portInDensities[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Densities of the fluid at the device boundary";
    Real 'lowerTank.portInDensities[2]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Densities of the fluid at the device boundary";
    Real 'lowerTank.portVelocities[1]'(unit = "m/s", quantity = "Velocity") "Velocities of fluid flow at device boundary";
    Real 'lowerTank.portVelocities[2]'(unit = "m/s", quantity = "Velocity") "Velocities of fluid flow at device boundary";
    Real 'lowerTank.ports_E_flow[1]'(unit = "W", quantity = "Power") "Flow of kinetic and potential energy at device boundary";
    Real 'lowerTank.ports_E_flow[2]'(unit = "W", quantity = "Power") "Flow of kinetic and potential energy at device boundary";
    Real 'lowerTank.s[1]'(start = 20.0) "Curve parameters for port flows vs. port pressures; for further details see, Modelica Tutorial: Ideal switching devices";
    Real 'lowerTank.s[2]'(start = 20.0) "Curve parameters for port flows vs. port pressures; for further details see, Modelica Tutorial: Ideal switching devices";
    Real 'lowerTank.ports_penetration[1]' "Penetration of port with fluid, depending on fluid level and port diameter";
    Real 'lowerTank.ports_penetration[2]' "Penetration of port with fluid, depending on fluid level and port diameter";
    Real 'lowerTank.portAreas[1]'(unit = "m2", quantity = "Area");
    Real 'lowerTank.portAreas[2]'(unit = "m2", quantity = "Area");
    Real 'lowerTank.vessel_ps_static[1]'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Static pressures inside the vessel at the height of the corresponding ports, zero flow velocity";
    Real 'lowerTank.vessel_ps_static[2]'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Static pressures inside the vessel at the height of the corresponding ports, zero flow velocity";
    constant Real 'lowerTank.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 100.0 "cf. suddenExpansion";
    Real 'lowerTank.m_flow_turbulent[1]'(unit = "kg/s", quantity = "MassFlowRate");
