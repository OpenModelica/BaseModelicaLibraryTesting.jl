    Real 'lowerTank.portsData_zeta_in[2]';
    Real 'lowerTank.portsData_zeta_out[1]';
    Real 'lowerTank.portsData_zeta_out[2]';
    Boolean 'lowerTank.regularFlow[1]'(start = true);
    Boolean 'lowerTank.regularFlow[2]'(start = true);
    Boolean 'lowerTank.inFlow[1]'(start = false);
    Boolean 'lowerTank.inFlow[2]'(start = false);
    parameter Real 'lowerTank.level_start_eps'(min = 0.0, unit = "m", quantity = "Length") = 2.0;
    parameter Real 'hysteresis.uLow'(start = 0.0) = 1.1e5 "If y=true and u<uLow, switch to y=false";
    parameter Real 'hysteresis.uHigh'(start = 1.0) = 2.5e5 "If y=false and u>uHigh, switch to y=true";
    parameter Boolean 'hysteresis.pre_y_start' = true "Value of pre(y) at initial time";
    Real 'hysteresis.u';
    Boolean 'hysteresis.y';
    Real 'switch1.u1' "Connector of first Real input signal";
    Boolean 'switch1.u2' "Connector of Boolean input signal";
    Real 'switch1.u3' "Connector of second Real input signal";
    Real 'switch1.y' "Connector of Real output signal";
    parameter Real 'm_flow_off.k'(start = 1.0) = 0.0 "Constant output value";
    Real 'm_flow_off.y' "Connector of Real output signal";
    parameter Real 'm_flow_on.k'(start = 1.0) = 2.0 "Constant output value";
    Real 'm_flow_on.y' "Connector of Real output signal";
    parameter Boolean 'overflow.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'overflow.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Linear cold water") "Mass flow rate from the connection point into the component";
    Real 'overflow.port_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'overflow.port_a.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'overflow.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Linear cold water") "Mass flow rate from the connection point into the component";
    Real 'overflow.port_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'overflow.port_b.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'overflow.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'overflow.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'overflow.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'overflow.nParallel'(min = 1.0) = 1.0 "Number of identical parallel pipes";
    parameter Real 'overflow.length'(unit = "m", quantity = "Length") = 200.0 "Length";
    parameter Boolean 'overflow.isCircular' = true "= true, if cross sectional area is circular" annotation(Evaluate = true);
    parameter Real 'overflow.diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.02 "Diameter of circular pipe";
    parameter Real 'overflow.crossArea'(unit = "m2", quantity = "Area") = 3.1415926535897936e-4 "Inner cross section area";
    parameter Real 'overflow.perimeter'(min = 0.0, unit = "m", quantity = "Length") = 0.06283185307179587 "Inner perimeter";
    parameter Real 'overflow.roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average height of surface asperities (default: smooth steel pipe)";
    parameter Real 'overflow.V'(unit = "m3", quantity = "Volume") = 0.06283185307179587 "Volume size";
    parameter Real 'overflow.height_ab'(unit = "m", quantity = "Length") = -5.0 "Height(port_b) - Height(port_a)";
    parameter Real 'overflow.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port a";
    parameter Real 'overflow.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port b";
    parameter Real 'overflow.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Linear cold water") = 0.0 "Start value for mass flow rate" annotation(Evaluate = true);
    parameter Boolean 'overflow.flowModel.from_dp' = true "= true, use m_flow = f(dp), otherwise dp = f(m_flow)" annotation(Evaluate = true);
    parameter Integer 'overflow.flowModel.n' = 2 "Number of discrete flow volumes";
    Real 'overflow.flowModel.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'overflow.flowModel.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'overflow.flowModel.states[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'overflow.flowModel.states[2].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'overflow.flowModel.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    Real 'overflow.flowModel.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    parameter Real 'overflow.flowModel.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'overflow.flowModel.crossAreas[1]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'overflow.flowModel.crossAreas[2]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'overflow.flowModel.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'overflow.flowModel.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'overflow.flowModel.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'overflow.flowModel.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'overflow.flowModel.dheights[1]'(unit = "m", quantity = "Length") "Height(states[2:n]) - Height(states[1:n-1])";
    parameter Real 'overflow.flowModel.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'overflow.flowModel.allowFlowReversal' = true "= true, if flow reversal is enabled, otherwise restrict flow to design direction (states[1] -> states[n+1])" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'overflow.flowModel.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance" annotation(Evaluate = true);
    parameter Real 'overflow.flowModel.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Linear cold water") = 0.0 "Start value of mass flow rates";
    parameter Real 'overflow.flowModel.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[1] at design inflow";
    parameter Real 'overflow.flowModel.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[n+1] at design outflow";
    parameter Integer 'overflow.flowModel.m' = 1 "Number of flow segments";
    Real 'overflow.flowModel.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'overflow.flowModel.m_flows[1]'(stateSelect = StateSelect.default, start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Linear cold water") "Mass flow rates between states";
    Real 'overflow.flowModel.Is[1]'(unit = "kg.m/s", quantity = "Momentum") "Momenta of flow segments";
    Real 'overflow.flowModel.Ib_flows[1]'(unit = "N", quantity = "Force") "Flow of momentum across boundaries";
    Real 'overflow.flowModel.Fs_p[1]'(unit = "N", quantity = "Force") "Pressure forces";
    Real 'overflow.flowModel.Fs_fg[1]'(unit = "N", quantity = "Force") "Friction and gravity forces";
    parameter Boolean 'overflow.flowModel.useUpstreamScheme' = true "= false to average upstream and downstream properties across flow segments" annotation(Evaluate = true);
    parameter Boolean 'overflow.flowModel.use_Ib_flows' = false "= true to consider differences in flow of momentum through boundaries" annotation(Evaluate = true);
    Real 'overflow.flowModel.rhos[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'overflow.flowModel.rhos[2]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'overflow.flowModel.rhos_act[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
    Real 'overflow.flowModel.mus[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'overflow.flowModel.mus[2]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'overflow.flowModel.mus_act[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") "Actual viscosity per segment";
    Real 'overflow.flowModel.dps_fg[1]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    parameter Real 'overflow.flowModel.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0 "Start of turbulent regime, depending on type of flow device";
    parameter Boolean 'overflow.flowModel.show_Res' = false "= true, if Reynolds numbers are included for plotting" annotation(Evaluate = true);
    parameter Boolean 'overflow.flowModel.use_rho_nominal' = false "= true, if rho_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'overflow.flowModel.rho_nominal'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 993.2044280025 "Nominal density (e.g., rho_liquidWater = 995, rho_air = 1.2)";
    parameter Boolean 'overflow.flowModel.use_mu_nominal' = false "= true, if mu_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'overflow.flowModel.mu_nominal'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") = 0.0015 "Nominal dynamic viscosity (e.g., mu_liquidWater = 1e-3, mu_air = 1.8e-5)";
    Real 'overflow.flowModel.pathLengths_internal[1]'(unit = "m", quantity = "Length") "pathLengths used internally; to be defined by extending class";
    Real 'overflow.flowModel.Res_turbulent_internal[1]'(unit = "1", quantity = "ReynoldsNumber") "Re_turbulent used internally; to be defined by extending class";
    parameter Real 'overflow.flowModel.dp_nominal'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Nominal pressure loss (only for nominal models)";
    parameter Real 'overflow.flowModel.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 100.0 * 'overflow.flowModel.m_flow_small' "Nominal mass flow rate";
    parameter Real 'overflow.flowModel.m_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Within regularization if |m_flows| < m_flow_small (may be wider for large discontinuities in static head)";
    parameter Real 'overflow.flowModel.dp_small'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Within regularization if |dp| < dp_small (may be wider for large discontinuities in static head)";
    parameter Boolean 'overflow.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'overflow.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'overflow.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'overflow.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure loss for nominal conditions";
  initial equation
    'upperTank.level' = 2.0;
    'upperTank.medium.T' = 'upperTank.T_start';
    'pipe.flowModel.dp_nominal' = 1000.0 * 'pipe.flowModel.dp_small';
    'pipe.flowModel.dp_small' = 1.0;
    'lowerTank.level' = 2.0;
    'lowerTank.medium.T' = 'lowerTank.T_start';
    pre('hysteresis.y') = true;
    'overflow.flowModel.dp_nominal' = 1000.0 * 'overflow.flowModel.dp_small';
    'overflow.flowModel.dp_small' = 1.0;
  equation
    'upperTank.fluidVolume' = 'upperTank.V';
    'upperTank.medium.T_degC' = 'upperTank.medium.T' - 273.15;
    'upperTank.medium.p_bar' = 'upperTank.medium.p' / 1e5;
    'upperTank.heatTransfer.states[1].p' = 'upperTank.medium.state.p';
    'upperTank.heatTransfer.states[1].T' = 'upperTank.medium.state.T';
    'upperTank.fluidLevel' = 'upperTank.level';
    'massFlowRate.medium.T_degC' = 'massFlowRate.medium.T' - 273.15;
    'massFlowRate.medium.p_bar' = 'massFlowRate.medium.p' / 1e5;
    'pipe.flowModel.dp_fric_nominal' = 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.pressureLoss_m_flow'('pipe.flowModel.m_flow_nominal', 993.2044280025, 993.2044280025, 0.0015, 0.0015, 'pipe.flowModel.pathLengths_internal[1]', 'pipe.flowModel.diameters[1]', ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') / 2.0, ('pipe.flowModel.roughnesses[1]' + 'pipe.flowModel.roughnesses[2]') / 2.0, 'pipe.flowModel.m_flow_small', 'pipe.flowModel.Res_turbulent_internal[1]');
    'lowerTank.fluidVolume' = 'lowerTank.V';
    'lowerTank.medium.T_degC' = 'lowerTank.medium.T' - 273.15;
    'lowerTank.medium.p_bar' = 'lowerTank.medium.p' / 1e5;
    'lowerTank.heatTransfer.states[1].p' = 'lowerTank.medium.state.p';
    'lowerTank.heatTransfer.states[1].T' = 'lowerTank.medium.state.T';
    'lowerTank.fluidLevel' = 'lowerTank.level';
    'overflow.flowModel.dp_fric_nominal' = 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.pressureLoss_m_flow'('overflow.flowModel.m_flow_nominal', 993.2044280025, 993.2044280025, 0.0015, 0.0015, 'overflow.flowModel.pathLengths_internal[1]', 'overflow.flowModel.diameters[1]', ('overflow.flowModel.crossAreas[1]' + 'overflow.flowModel.crossAreas[2]') / 2.0, ('overflow.flowModel.roughnesses[1]' + 'overflow.flowModel.roughnesses[2]') / 2.0, 'overflow.flowModel.m_flow_small', 'overflow.flowModel.Res_turbulent_internal[1]');
    'upperTank.portsData_diameter[1]' = 'upperTank.portsData_diameter_internal[1]';
    'upperTank.portsData_diameter[2]' = 'upperTank.portsData_diameter_internal[2]';
    'upperTank.portsData_diameter[3]' = 'upperTank.portsData_diameter_internal[3]';
    'upperTank.portsData_height[1]' = 'upperTank.portsData_height_internal[1]';
    'upperTank.portsData_height[2]' = 'upperTank.portsData_height_internal[2]';
    'upperTank.portsData_height[3]' = 'upperTank.portsData_height_internal[3]';
    'upperTank.portsData_zeta_in[1]' = 'upperTank.portsData_zeta_in_internal[1]';
    'upperTank.portsData_zeta_in[2]' = 'upperTank.portsData_zeta_in_internal[2]';
    'upperTank.portsData_zeta_in[3]' = 'upperTank.portsData_zeta_in_internal[3]';
    'upperTank.portsData_zeta_out[1]' = 'upperTank.portsData_zeta_out_internal[1]';
    'upperTank.portsData_zeta_out[2]' = 'upperTank.portsData_zeta_out_internal[2]';
    'upperTank.portsData_zeta_out[3]' = 'upperTank.portsData_zeta_out_internal[3]';
    'massFlowRate.m_flow_in' = 'massFlowRate.m_flow_in_internal';
    'lowerTank.portsData_diameter[1]' = 'lowerTank.portsData_diameter_internal[1]';
    'lowerTank.portsData_diameter[2]' = 'lowerTank.portsData_diameter_internal[2]';
    'lowerTank.portsData_height[1]' = 'lowerTank.portsData_height_internal[1]';
    'lowerTank.portsData_height[2]' = 'lowerTank.portsData_height_internal[2]';
    'lowerTank.portsData_zeta_in[1]' = 'lowerTank.portsData_zeta_in_internal[1]';
    'lowerTank.portsData_zeta_in[2]' = 'lowerTank.portsData_zeta_in_internal[2]';
    'lowerTank.portsData_zeta_out[1]' = 'lowerTank.portsData_zeta_out_internal[1]';
    'lowerTank.portsData_zeta_out[2]' = 'lowerTank.portsData_zeta_out_internal[2]';
    'massFlowRate.ports[1].p' = 'upperTank.ports[1].p';
    'pressure.p' = 'hysteresis.u';
    'hysteresis.y' = 'switch1.u2';
    'm_flow_off.y' = 'switch1.u1';
    'm_flow_on.y' = 'switch1.u3';
    'switch1.y' = 'massFlowRate.m_flow_in';
    'pipe.port_a.p' = 'pressure.port.p';
    'pipe.port_a.p' = 'upperTank.ports[2].p';
    'pipe.port_b.p' = 'lowerTank.ports[1].p';
    'upperTank.ports[3].p' = 'overflow.port_a.p';
    'overflow.port_b.p' = 'lowerTank.ports[2].p';
    'pipe.port_a.m_flow' + 'pressure.port.m_flow' + 'upperTank.ports[2].m_flow' = 0.0;
    'overflow.port_a.m_flow' + 'upperTank.ports[3].m_flow' = 0.0;
    'upperTank.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'massFlowRate.ports[1].m_flow' + 'upperTank.ports[1].m_flow' = 0.0;
    'lowerTank.ports[1].m_flow' + 'pipe.port_b.m_flow' = 0.0;
    'lowerTank.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'overflow.port_b.m_flow' + 'lowerTank.ports[2].m_flow' = 0.0;
    'upperTank.medium.d' = (1.0 + ('upperTank.medium.p' - 101325.0) * 4.5154e-10 - ('upperTank.medium.T' - 278.15) * 2.5713e-4) * 997.05;
    'upperTank.medium.h' = 104929.0 + ('upperTank.medium.T' - 278.15) * 4181.9 + ('upperTank.medium.p' - 101325.0) * 0.9284792905 / 997.05;
    'upperTank.medium.u' = 'upperTank.medium.h' - 'upperTank.medium.p' / 'upperTank.medium.d';
    'upperTank.medium.p' = 'upperTank.medium.state.p';
    'upperTank.medium.T' = 'upperTank.medium.state.T';
    'upperTank.medium.MM' = 0.018015268;
    'upperTank.medium.R_s' = 8.31446261815324 / 'upperTank.medium.MM';
    'upperTank.medium.X[1]' = 1.0;
    assert('upperTank.medium.X[1]' >= (-1e-5) and 'upperTank.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('upperTank.medium.X[1]') + "of substance " + "Linear cold water" + "\nof medium " + "Linear cold water" + " is not in the range 0..1", AssertionLevel.error);
    assert('upperTank.medium.p' >= 0.0, "Pressure (= " + String('upperTank.medium.p') + " Pa) of medium \"" + "Linear cold water" + "\" is negative\n(Temperature = " + String('upperTank.medium.T') + " K)", AssertionLevel.error);
    'upperTank.heatTransfer.surfaceAreas[1]' = 0.2 + 1.5853309190424043 * 'upperTank.level';
    'upperTank.heatTransfer.Ts[1]' = 'upperTank.heatTransfer.states[1].T';
    'upperTank.heatTransfer.Ts[1]' = 'upperTank.heatTransfer.heatPorts[1].T';
    'upperTank.heatTransfer.Q_flows[1]' = 'upperTank.heatTransfer.heatPorts[1].Q_flow';
    'upperTank.portAreas[1]' = 0.7853981633974483 * 'upperTank.portsData_diameter[1]' ^ 2.0;
    'upperTank.portAreas[2]' = 0.7853981633974483 * 'upperTank.portsData_diameter[2]' ^ 2.0;
    'upperTank.portAreas[3]' = 0.7853981633974483 * 'upperTank.portsData_diameter[3]' ^ 2.0;
    'upperTank.portsData_diameter_internal[1]' = 'upperTank.portsData[1].diameter';
    'upperTank.portsData_diameter_internal[2]' = 'upperTank.portsData[2].diameter';
    'upperTank.portsData_diameter_internal[3]' = 'upperTank.portsData[3].diameter';
    'upperTank.portsData_height_internal[1]' = 'upperTank.portsData[1].height';
    'upperTank.portsData_height_internal[2]' = 'upperTank.portsData[2].height';
    'upperTank.portsData_height_internal[3]' = 'upperTank.portsData[3].height';
    'upperTank.portsData_zeta_in_internal[1]' = 'upperTank.portsData[1].zeta_in';
    'upperTank.portsData_zeta_in_internal[2]' = 'upperTank.portsData[2].zeta_in';
    'upperTank.portsData_zeta_in_internal[3]' = 'upperTank.portsData[3].zeta_in';
    'upperTank.portsData_zeta_out_internal[1]' = 'upperTank.portsData[1].zeta_out';
    'upperTank.portsData_zeta_out_internal[2]' = 'upperTank.portsData[2].zeta_out';
    'upperTank.portsData_zeta_out_internal[3]' = 'upperTank.portsData[3].zeta_out';
    'upperTank.V' = 0.2 * 'upperTank.level' "Volume of fluid";
    'upperTank.medium.p' = 101325.0;
    'upperTank.Wb_flow' = -101325.0 * der('upperTank.V');
    'upperTank.vessel_ps_static[1]' = max(0.0, 'upperTank.level' - 'upperTank.portsData_height[1]') * 9.80665 * 'upperTank.medium.d' + 101325.0;
    'upperTank.vessel_ps_static[2]' = max(0.0, 'upperTank.level' - 'upperTank.portsData_height[2]') * 9.80665 * 'upperTank.medium.d' + 101325.0;
    'upperTank.vessel_ps_static[3]' = max(0.0, 'upperTank.level' - 'upperTank.portsData_height[3]') * 9.80665 * 'upperTank.medium.d' + 101325.0;
    assert('upperTank.level' > 0.0, "Fluid level is too low; the energy balance equation becomes singular when the tank is completely empty.", AssertionLevel.error);
    'upperTank.mb_flow' = 'upperTank.ports[1].m_flow' + 'upperTank.ports[2].m_flow' + 'upperTank.ports[3].m_flow';
    'upperTank.Hb_flow' = 'upperTank.ports_H_flow[1]' + 'upperTank.ports_H_flow[2]' + 'upperTank.ports_H_flow[3]' + 'upperTank.ports_E_flow[1]' + 'upperTank.ports_E_flow[2]' + 'upperTank.ports_E_flow[3]';
    'upperTank.Qb_flow' = 'upperTank.heatTransfer.Q_flows[1]';
