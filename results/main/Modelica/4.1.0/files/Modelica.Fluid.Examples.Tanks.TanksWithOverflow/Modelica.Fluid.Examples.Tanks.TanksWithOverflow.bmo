//! base 0.1.0
package 'TanksWithOverflow'
  function 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / 'Modelica.Math.log10'('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility' "Interpolating with two 3-order polynomials with a prescribed derivative at x=0"
    input Real 'x';
    input Real 'x1';
    input Real 'k1';
    input Real 'k2';
    input Boolean 'use_yd0' = false;
    input Real 'yd0'(min = 0.0) = 1.0;
    output Real 'y';
    Real 'x2';
    Real 'y1';
    Real 'y2';
    Real 'y1d';
    Real 'y2d';
    Real 'w';
    Real 'w1';
    Real 'w2';
    Real 'y0d';
    Real 'ww';
  algorithm
    'x2' := -'x1';

    if 'x' <= 'x2' then
      'y' := -'k2' * 'x' ^ 2.0;
    else
      'y1' := 'k1' * 'x1' ^ 2.0;
      'y2' := -'k2' * 'x2' ^ 2.0;
      'y1d' := 'k1' * 2.0 * 'x1';
      'y2d' := -'k2' * 2.0 * 'x2';

      if 'use_yd0' then
        'y0d' := 'yd0';
      else
        'w' := 'x2' / 'x1';
        'y0d' := ((3.0 * 'y2' - 'x2' * 'y2d') / 'w' - (3.0 * 'y1' - 'x1' * 'y1d') * 'w') / (2.0 * 'x1' * (1.0 - 'w'));
      end if;

      'w1' := 2.23606797749979 * 'k1' * 'x1';
      'w2' := 2.23606797749979 * 'k2' * abs('x2');
      'ww' := 0.9 * (if 'w1' < 'w2' then 'w1' else 'w2');

      if 'ww' < 'y0d' then
        'y0d' := 'ww';
      end if;

      'y' := if 'x' >= 0.0 then 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x', 'x1', 'y1', 'y1d', 'y0d') else 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x', 'x2', 'y2', 'y2d', 'y0d');
    end if;
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility';

  function 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / 'Modelica.Math.log10'('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Utilities.checkBoundary' "Check whether boundary definition is correct"
    input String 'mediumName';
    input String 'substanceNames'[:];
    input Boolean 'singleState';
    input Boolean 'define_p';
    input Real 'X_boundary'[:];
    input String 'modelName' = "??? boundary ???";
    Integer 'nX' = size('X_boundary', 1);
    String 'X_str';
  algorithm
    assert(not 'singleState' or 'singleState' and 'define_p', "\nWrong value of parameter define_p (= false) in model \"" + 'modelName' + "\":\nThe selected medium \"" + 'mediumName' + "\" has Medium.singleState=true.\nTherefore, an boundary density cannot be defined and\ndefine_p = true is required.\n", AssertionLevel.error);

    for 'i' in 1:'nX' loop
      assert('X_boundary'['i'] >= 0.0, "\nWrong boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\":\nThe boundary value X_boundary(" + String('i') + ") = " + String('X_boundary'['i']) + "\nis negative. It must be positive.\n", AssertionLevel.error);
    end for;

    if 'nX' > 0 and abs(sum('X_boundary') - 1.0) > 1e-10 then
      'X_str' := "";

      for 'i' in 1:'nX' loop
        'X_str' := 'X_str' + "   X_boundary[" + String('i') + "] = " + String('X_boundary'['i']) + " \"" + 'substanceNames'['i'] + "\"\n";
      end for;

      'Modelica.Utilities.Streams.error'("The boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\"\n" + "do not sum up to 1. Instead, sum(X_boundary) = " + String(sum('X_boundary')) + ":\n" + 'X_str');
    end if;
  end 'Modelica.Fluid.Utilities.checkBoundary';

  function 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    else
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      else
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    else
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      else
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.Tanks.TanksWithOverflow.overflow.flowModel.WallFriction.massFlowRate_dp_staticHead';

  type 'Modelica.Fluid.Types.Dynamics' = enumeration('DynamicFreeInitial', 'FixedInitial', 'SteadyStateInitial', 'SteadyState');

  type 'Modelica.Fluid.Types.PortFlowDirection' = enumeration('Entering', 'Leaving', 'Bidirectional');

  model 'TanksWithOverflow' "Two tanks connected with pipes at different heights"
    Real 'upperTank.level'(stateSelect = StateSelect.prefer, start = 2.0, min = 0.0, unit = "m", quantity = "Length") "Level height of tank";
    Real 'upperTank.V'(stateSelect = StateSelect.never, unit = "m3", quantity = "Volume") "Actual tank volume";
    parameter Real 'upperTank.height'(min = 0.0, unit = "m", quantity = "Length") = 20.0 "Height of tank";
    parameter Real 'upperTank.crossArea'(unit = "m2", quantity = "Area") = 0.2 "Area of tank";
    parameter Real 'upperTank.p_ambient'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Tank surface pressure";
    parameter Real 'upperTank.T_ambient'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Tank surface Temperature";
    parameter Real 'upperTank.level_start'(min = 0.0, unit = "m", quantity = "Length") = 2.0 "Start value of tank level";
    Real 'upperTank.fluidVolume'(unit = "m3", quantity = "Volume") "Volume";
    parameter 'Modelica.Fluid.Types.Dynamics' 'upperTank.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'upperTank.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'upperTank.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of substance balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'upperTank.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of trace substance balance" annotation(Evaluate = true);
    parameter Real 'upperTank.p_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Boolean 'upperTank.use_T_start' = true "= true, use T_start, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'upperTank.T_start'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Start value of temperature";
    parameter Real 'upperTank.h_start'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 104929.0 + ('upperTank.T_start' - 278.15) * 4181.9 + (101325.0 - 101325.0) * 0.9284792905 / 997.05 "Start value of specific enthalpy";
    parameter Real 'upperTank.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    Real 'upperTank.medium.p'(stateSelect = StateSelect.prefer, nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'upperTank.medium.h'(start = 'upperTank.h_start', unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'upperTank.medium.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
