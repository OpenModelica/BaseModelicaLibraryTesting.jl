    'overflow.port_a.h_outflow' = 'lowerTank.ports[2].h_outflow' - 49.033249999999995;
    annotation(experiment(StopTime = 25000, Interval = 5.0));
  end 'TanksWithOverflow';
end 'TanksWithOverflow';
