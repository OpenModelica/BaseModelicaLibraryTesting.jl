    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    else
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      else
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe5.flowModel.WallFriction.massFlowRate_dp_staticHead';

  type 'Modelica.Fluid.Types.ModelStructure' = enumeration('av_vb', 'a_v_b', 'av_b', 'a_vb');

  type 'Modelica.Fluid.Types.Dynamics' = enumeration('DynamicFreeInitial', 'FixedInitial', 'SteadyStateInitial', 'SteadyState');

  type 'Modelica.Fluid.Types.PortFlowDirection' = enumeration('Entering', 'Leaving', 'Bidirectional');

  type 'Modelica.Fluid.Types.CvTypes' = enumeration('Av', 'Kv', 'Cv', 'OpPoint');

  record 'valve1.Medium.ThermodynamicState'
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  end 'valve1.Medium.ThermodynamicState';

  record 'valve2.Medium.ThermodynamicState'
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  end 'valve2.Medium.ThermodynamicState';

  record 'valve3.Medium.ThermodynamicState'
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  end 'valve3.Medium.ThermodynamicState';

  partial function 'Modelica.Math.Nonlinear.Interfaces.partialScalarFunction' "Interface for a function with one input and one output Real signal"
    input Real 'u';
    output Real 'y';
  end 'Modelica.Math.Nonlinear.Interfaces.partialScalarFunction';

  model 'IncompressibleFluidNetwork' "Multi-way connections of pipes and incompressible medium model"
    parameter 'Modelica.Fluid.Types.ModelStructure' 'pipeModelStructure' = 'Modelica.Fluid.Types.ModelStructure'.'av_vb' "Model structure in distributed pipe model";
    parameter 'Modelica.Fluid.Types.Dynamics' 'systemMassDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of mass balances";
    parameter Integer 'source.nPorts' = 1 "Number of ports";
    Real 'source.medium.p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'source.medium.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'source.medium.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'source.medium.T'(stateSelect = StateSelect.default, nominal = 300.0, start = 298.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'source.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'source.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'source.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'source.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'source.medium.state.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'source.medium.state.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'source.medium.preferredMediumStates' = false "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'source.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'source.medium.T_degC'(start = 25.0, unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'source.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'source.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Specific heat capacity";
    parameter Real 'source.medium.T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 298.15 "Initial temperature";
    Real 'source.ports[1].m_flow'(max = 1e60, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rate from the connection point into the component";
    Real 'source.ports[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'source.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter 'Modelica.Fluid.Types.PortFlowDirection' 'source.flowDirection' = 'Modelica.Fluid.Types.PortFlowDirection'.'Bidirectional' "Allowed flow direction" annotation(Evaluate = true);
    parameter Boolean 'source.use_p_in' = false "Get the pressure from the input connector" annotation(Evaluate = true);
    parameter Boolean 'source.use_T_in' = false "Get the temperature from the input connector" annotation(Evaluate = true);
    parameter Boolean 'source.use_X_in' = false "Get the composition from the input connector" annotation(Evaluate = true);
    parameter Boolean 'source.use_C_in' = false "Get the trace substances from the input connector" annotation(Evaluate = true);
    parameter Real 'source.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 5e5 "Fixed value of pressure";
    parameter Real 'source.T'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.0 "Fixed value of temperature";
    parameter Real 'source.X[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Fixed value of composition";
    Real 'source.p_in_internal'(unit = "Pa") "Needed to connect to conditional connector";
    Real 'source.T_in_internal'(unit = "K") "Needed to connect to conditional connector";
    Real 'source.X_in_internal[1]'(unit = "1") "Needed to connect to conditional connector";
    parameter Boolean 'pipe1.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'pipe1.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rate from the connection point into the component";
    Real 'pipe1.port_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe1.port_a.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'pipe1.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rate from the connection point into the component";
    Real 'pipe1.port_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe1.port_b.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'pipe1.port_a_exposesState' = true "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'pipe1.port_b_exposesState' = true "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'pipe1.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'pipe1.nParallel'(min = 1.0) = 1.0 "Number of identical parallel pipes";
    parameter Real 'pipe1.length'(unit = "m", quantity = "Length") = 10.0 "Length";
    parameter Boolean 'pipe1.isCircular' = true "= true, if cross sectional area is circular" annotation(Evaluate = true);
    parameter Real 'pipe1.diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.025 "Diameter of circular pipe";
    parameter Real 'pipe1.crossArea'(unit = "m2", quantity = "Area") = 4.908738521234052e-4 "Inner cross section area";
    parameter Real 'pipe1.perimeter'(min = 0.0, unit = "m", quantity = "Length") = 0.07853981633974483 "Inner perimeter";
    parameter Real 'pipe1.roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average height of surface asperities (default: smooth steel pipe)";
    parameter Real 'pipe1.V'(unit = "m3", quantity = "Volume") = 0.004908738521234052 "Volume size";
    parameter Real 'pipe1.height_ab'(unit = "m", quantity = "Length") = 0.0 "Height(port_b) - Height(port_a)";
    parameter Integer 'pipe1.n' = 2 "Number of discrete volumes";
    Real 'pipe1.fluidVolumes[1]'(unit = "m3", quantity = "Volume") "Discretized volume, determine in inheriting class";
    Real 'pipe1.fluidVolumes[2]'(unit = "m3", quantity = "Volume") "Discretized volume, determine in inheriting class";
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe1.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of energy balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe1.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of mass balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe1.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe1.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of trace substance balances" annotation(Evaluate = true);
    parameter Real 'pipe1.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port a";
    parameter Real 'pipe1.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port b";
    parameter Real 'pipe1.ps_start[1]'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Real 'pipe1.ps_start[2]'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Boolean 'pipe1.use_T_start' = true "Use T_start if true, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'pipe1.T_start'(nominal = 300.0, start = 288.15, max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Start value of temperature" annotation(Evaluate = true);
    parameter Real 'pipe1.h_start'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 'Modelica.Math.Polynomials.integralValue'({-7.666493085690878e-4, 3.406312561476593, 3555.6027310073478}, 'pipe1.T_start' - 273.15, 0.0) "Start value of specific enthalpy" annotation(Evaluate = true);
    parameter Real 'pipe1.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    Real 'pipe1.Us[1]'(unit = "J", quantity = "Energy") "Internal energy of fluid";
    Real 'pipe1.Us[2]'(unit = "J", quantity = "Energy") "Internal energy of fluid";
    Real 'pipe1.ms[1]'(min = 0.0, unit = "kg", quantity = "Mass") "Fluid mass";
    Real 'pipe1.ms[2]'(min = 0.0, unit = "kg", quantity = "Mass") "Fluid mass";
    Real 'pipe1.mediums[1].p'(nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe1.mediums[1].h'(start = 'pipe1.h_start', unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'pipe1.mediums[1].d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'pipe1.mediums[1].T'(stateSelect = StateSelect.prefer, nominal = 300.0, start = 'pipe1.T_start', max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe1.mediums[1].X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'pipe1.mediums[1].u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'pipe1.mediums[1].R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'pipe1.mediums[1].MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'pipe1.mediums[1].state.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'pipe1.mediums[1].state.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'pipe1.mediums[1].preferredMediumStates' = true "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'pipe1.mediums[1].standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'pipe1.mediums[1].T_degC'(start = 25.0, unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'pipe1.mediums[1].p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'pipe1.mediums[1].cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Specific heat capacity";
    parameter Real 'pipe1.mediums[1].T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 298.15 "Initial temperature";
    Real 'pipe1.mediums[2].p'(nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe1.mediums[2].h'(start = 'pipe1.h_start', unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'pipe1.mediums[2].d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'pipe1.mediums[2].T'(stateSelect = StateSelect.prefer, nominal = 300.0, start = 'pipe1.T_start', max = 373.15, min = 243.14999999999998, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe1.mediums[2].X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'pipe1.mediums[2].u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'pipe1.mediums[2].R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'pipe1.mediums[2].MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'pipe1.mediums[2].state.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'pipe1.mediums[2].state.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'pipe1.mediums[2].preferredMediumStates' = true "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'pipe1.mediums[2].standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'pipe1.mediums[2].T_degC'(start = 25.0, unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'pipe1.mediums[2].p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'pipe1.mediums[2].cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Specific heat capacity";
    parameter Real 'pipe1.mediums[2].T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 298.15 "Initial temperature";
    Real 'pipe1.mb_flows[1]'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rate, source or sink";
    Real 'pipe1.mb_flows[2]'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") "Mass flow rate, source or sink";
    Real 'pipe1.Hb_flows[1]'(unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rate, source or sink";
    Real 'pipe1.Hb_flows[2]'(unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rate, source or sink";
    Real 'pipe1.Qb_flows[1]'(unit = "W", quantity = "Power") "Heat flow rate, source or sink";
    Real 'pipe1.Qb_flows[2]'(unit = "W", quantity = "Power") "Heat flow rate, source or sink";
    Real 'pipe1.Wb_flows[1]'(unit = "W", quantity = "Power") "Mechanical power, p*der(V) etc.";
    Real 'pipe1.Wb_flows[2]'(unit = "W", quantity = "Power") "Mechanical power, p*der(V) etc.";
    parameter Boolean 'pipe1.initialize_p' = false "= true to set up initial equations for pressure";
    parameter Real 'pipe1.lengths[1]'(unit = "m", quantity = "Length") = 5.0 "Lengths of flow segments";
    parameter Real 'pipe1.lengths[2]'(unit = "m", quantity = "Length") = 5.0 "Lengths of flow segments";
    parameter Real 'pipe1.crossAreas[1]'(unit = "m2", quantity = "Area") = 4.908738521234052e-4 "Cross flow areas of flow segments";
    parameter Real 'pipe1.crossAreas[2]'(unit = "m2", quantity = "Area") = 4.908738521234052e-4 "Cross flow areas of flow segments";
    parameter Real 'pipe1.dimensions[1]'(unit = "m", quantity = "Length") = 0.025 "Hydraulic diameters of flow segments";
    parameter Real 'pipe1.dimensions[2]'(unit = "m", quantity = "Length") = 0.025 "Hydraulic diameters of flow segments";
    parameter Real 'pipe1.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average heights of surface asperities";
    parameter Real 'pipe1.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average heights of surface asperities";
    parameter Real 'pipe1.dheights[1]'(unit = "m", quantity = "Length") = 0.0 "Differences in heights of flow segments" annotation(Evaluate = true);
    parameter Real 'pipe1.dheights[2]'(unit = "m", quantity = "Length") = 0.0 "Differences in heights of flow segments" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe1.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balances" annotation(Evaluate = true);
    parameter Real 'pipe1.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Glycol-Water 47%") = 0.0 "Start value for mass flow rate" annotation(Evaluate = true);
    parameter Integer 'pipe1.nNodes'(min = 1) = 2 "Number of discrete flow volumes" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.ModelStructure' 'pipe1.modelStructure' = 'Modelica.Fluid.Types.ModelStructure'.'av_vb' "Determines whether flow or volume models are present at the ports" annotation(Evaluate = true);
    parameter Boolean 'pipe1.useLumpedPressure' = false "= true to lump pressure states together" annotation(Evaluate = true);
    parameter Integer 'pipe1.nFM' = 1 "Number of flow models in flowModel";
    parameter Integer 'pipe1.nFMDistributed' = 1 "Number of distributed flow models";
    parameter Integer 'pipe1.nFMLumped' = 1 "Number of lumped flow models";
    parameter Integer 'pipe1.iLumped' = 2 "Index of control volume with representative state if useLumpedPressure" annotation(Evaluate = true);
    parameter Boolean 'pipe1.useInnerPortProperties' = false "= true to take port properties for flow models from internal control volumes" annotation(Evaluate = true);
