    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe8.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe9.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
