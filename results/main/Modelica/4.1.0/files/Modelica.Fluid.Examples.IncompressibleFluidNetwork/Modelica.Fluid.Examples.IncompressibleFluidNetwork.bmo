  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'zeta';
    Real 'k0';
    Real 'k';
    Real 'yd0';
    Real 'm_flow_turbulent'(unit = "kg/s", quantity = "MassFlowRate");
  algorithm
    assert('roughness' > 1e-10, "roughness > 0 required for quadratic turbulent wall friction characteristic", AssertionLevel.error);
    'zeta' := 'length' / 'diameter' / (2.0 * 'Modelica.Math.log10'(3.7 / ('roughness' / 'diameter'))) ^ 2.0;
    'k0' := 128.0 * 'length' / (3.141592653589793 * 'diameter' ^ 4.0);
    'k' := 8.0 * 'zeta' / (3.141592653589793 * 'diameter' * 'diameter') ^ 2.0;
    'yd0' := 'k0' * ('mu_a' + 'mu_b') / ('rho_a' + 'rho_b');
    'm_flow_turbulent' := max(0.39269908169872414 * 'diameter' * ('mu_a' + 'mu_b') * 'Re_turbulent', 'm_flow_small');
    'dp' := 'Modelica.Fluid.Utilities.regSquare2'('m_flow', 'm_flow_turbulent', 'k' / 'rho_a', 'k' / 'rho_b', true, 'yd0');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe3.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.IncompressibleFluidNetwork.pipe1.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
