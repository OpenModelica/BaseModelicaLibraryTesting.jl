    parameter 'Modelica.Blocks.Types.Smoothness' 'core.tabfal.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'ContinuousDerivative' "Smoothness of table interpolation";
    parameter 'Modelica.Blocks.Types.Extrapolation' 'core.tabfal.extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints' "Extrapolation of data outside the definition range";
    parameter Boolean 'core.tabfal.verboseExtrapolation' = false "= true, if warning messages are to be printed if table input is outside the definition range";
    parameter Real 'core.tabfal.u_min' = 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmin'('core.tabfal.tableID') "Minimum abscissa value defined in table";
    parameter Real 'core.tabfal.u_max' = 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmax'('core.tabfal.tableID') "Maximum abscissa value defined in table";
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'core.tabfal.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{-5e4, -2.44743549087484}, {-37500.0, -2.43173549087484}, {-25000.0, -2.29175406960198}, {-12500.0, -2.02749122705627}, {-9500.0, -1.93424060373981}, {-9000.0, -1.91734557383536}, {-8500.0, -1.90003831579647}, {-8000.0, -1.88228336311722}, {-7500.0, -1.86396184546015}, {-7000.0, -1.84524857210249}, {-6500.0, -1.8259107052547}, {-6000.0, -1.80594439934052}, {-5500.0, -1.78531310330034}, {-5000.0, -1.76382025520505}, {-4500.0, -1.74142910912243}, {-4000.0, -1.71783221361736}, {-3500.0, -1.69280878752801}, {-3000.0, -1.66591530113576}, {-2500.0, -1.63649294648485}, {-2000.0, -1.60339863123377}, {-1500.0, -1.56442149385622}, {-1000.0, -1.51441561468259}, {-500.0, -1.43080809535224}, {-475.0, -1.42450289449529}, {-450.0, -1.41732721660085}, {-425.0, -1.40951882234757}, {-400.0, -1.40118064526704}, {-375.0, -1.39220914273277}, {-350.0, -1.38211113291766}, {-325.0, -1.37125742032855}, {-300.0, -1.35917182037113}, {-275.0, -1.34411680370286}, {-250.0, -1.32861822862062}, {-225.0, -1.30745835828352}, {-200.0, -1.28557369127376}, {-175.0, -1.2541981420506}, {-150.0, -1.21937409523818}, {-125.0, -1.16769743255509}, {-100.0, -1.08621953798151}, {-75.0, -0.949248973899088}, {-50.0, -0.463062524232745}, {-45.0, -0.241397022221927}, {-40.0, -0.0917328024445698}, {-35.0, 0.182881911670973}, {-30.0, 0.647941622043669}, {-25.0, 0.925720611599761}, {-20.0, 1.01589911772097}, {-15.0, 1.06212781456762}, {-10.0, 1.09723124440593}, {-5.0, 1.13156726933814}, {0.0, 1.154608220133}, {5.0, 1.17506808994058}, {10.0, 1.19012140311265}, {15.0, 1.20695474596496}, {20.0, 1.22235157331926}, {25.0, 1.23492992961726}, {30.0, 1.24500433228815}, {35.0, 1.2551114004705}, {40.0, 1.26642123811028}, {45.0, 1.27567122597037}, {50.0, 1.28254253926943}, {75.0, 1.31450423011738}, {100.0, 1.33781959105884}, {125.0, 1.35535350494447}, {150.0, 1.3707603888932}, {175.0, 1.38300521211089}, {200.0, 1.39317334290652}, {225.0, 1.40231271538781}, {250.0, 1.41003370402153}, {275.0, 1.41775224948779}, {300.0, 1.42443612181079}, {325.0, 1.43071011319246}, {350.0, 1.43632820821805}, {375.0, 1.44160298825063}, {400.0, 1.4468968519518}, {425.0, 1.45157598310516}, {450.0, 1.45604404631093}, {475.0, 1.46029335493483}, {500.0, 1.46434035987343}, {1000.0, 1.52527944546714}, {1500.0, 1.56827087926856}, {2000.0, 1.60364207715609}, {2500.0, 1.63460389841854}, {3000.0, 1.66261092660742}, {3500.0, 1.68850800352239}, {4000.0, 1.71272916087899}, {4500.0, 1.73572148025338}, {5000.0, 1.75764646474993}, {5500.0, 1.77872746673938}, {6000.0, 1.79900863540491}, {6500.0, 1.8186658158793}, {7000.0, 1.83769268690732}, {7500.0, 1.85624654695152}, {8000.0, 1.87427340278025}, {8500.0, 1.89178891688}, {9000.0, 1.90886536500246}, {9500.0, 1.92560023719942}, {12500.0, 2.01885086051588}, {25000.0, 2.28311370306159}, {37500.0, 2.42309512433445}, {5e4, 2.43879512433445}}, {2}, 'Modelica.Blocks.Types.Smoothness'.'ContinuousDerivative', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object";
    parameter Boolean 'core.tabfal.isCsvExt' = false;
  initial equation
    'core.B' = ('core.hystR' + 'core.hystF') / 2.0 + 'core.MagRel' * 'core.diffHyst' / 2.0;
    'core.derHstat' = 0.0;
  equation
    'core.derHstat' = der('core.Hstat');
    'winding2.port_n.V_m' = 'mag_ground.port.V_m';
    'winding2.port_n.V_m' = 'winding1.port_n.V_m';
    'vSource.p.v' = 'resistor1.p.v';
    'winding1.n.v' = 'el_ground1.p.v';
    'winding1.n.v' = 'vSource.n.v';
    'resistor1.n.v' = 'winding1.p.v';
    'winding2.p.v' = 'resistor2.p.v';
    'resistor2.n.v' = 'el_ground2.p.v';
    'resistor2.n.v' = 'winding2.n.v';
    'winding1.port_p.V_m' = 'core.port_p.V_m';
    'core.port_n.V_m' = 'winding2.port_p.V_m';
    'core.port_p.Phi' + 'winding1.port_p.Phi' = 0.0;
    'winding2.port_n.Phi' + 'winding1.port_n.Phi' + 'mag_ground.port.Phi' = 0.0;
    'resistor1.n.i' + 'winding1.p.i' = 0.0;
    'vSource.p.i' + 'resistor1.p.i' = 0.0;
    'vSource.n.i' + 'el_ground1.p.i' + 'winding1.n.i' = 0.0;
    'resistor2.p.i' + 'winding2.p.i' = 0.0;
    'el_ground2.p.i' + 'resistor2.n.i' + 'winding2.n.i' = 0.0;
    'core.port_n.Phi' + 'winding2.port_p.Phi' = 0.0;
    'mag_ground.port.V_m' = 0.0;
    'winding1.v' = 'winding1.p.v' - 'winding1.n.v';
    0.0 = 'winding1.p.i' + 'winding1.n.i';
    'winding1.i' = 'winding1.p.i';
    'winding1.V_m' = 'winding1.port_p.V_m' - 'winding1.port_n.V_m';
    0.0 = 'winding1.port_p.Phi' + 'winding1.port_n.Phi';
    'winding1.Phi' = 'winding1.port_p.Phi';
    'winding1.V_m' = 'winding1.i' * 10.0 "Ampere's law";
    10.0 * der('winding1.Phi_ind') = -'winding1.v' "Faraday's law";
    'winding1.Phi_leak' = 1.25663706212e-9 * 'winding1.V_m';
    'winding1.Phi' = 'winding1.Phi_ind' + 'winding1.Phi_leak';
    'winding1.Psi' = 10.0 * 'winding1.Phi_ind';
    'winding1.L_stat' = noEvent(if abs('winding1.i') > 2.220446049250313e-14 then abs('winding1.Psi' / 'winding1.i') else abs('winding1.Psi' / 2.220446049250313e-14));
    'el_ground1.p.v' = 0.0;
    'resistor1.R_actual' = 0.05;
    'resistor1.v' = 'resistor1.R_actual' * 'resistor1.i';
    'resistor1.LossPower' = 'resistor1.v' * 'resistor1.i';
    'resistor1.T_heatPort' = 300.15;
    0.0 = 'resistor1.p.i' + 'resistor1.n.i';
    'resistor1.i' = 'resistor1.p.i';
    'resistor1.v' = 'resistor1.p.v' - 'resistor1.n.v';
    'vSource.signalSource.y' = if time < 0.0 then 0.0 else 8.0 * sin(2513.2741228718346 * time);
    'vSource.v' = 'vSource.signalSource.y';
    0.0 = 'vSource.p.i' + 'vSource.n.i';
    'vSource.i' = 'vSource.p.i';
    'vSource.v' = 'vSource.p.v' - 'vSource.n.v';
    'winding2.v' = 'winding2.p.v' - 'winding2.n.v';
    0.0 = 'winding2.p.i' + 'winding2.n.i';
    'winding2.i' = 'winding2.p.i';
    'winding2.V_m' = 'winding2.port_p.V_m' - 'winding2.port_n.V_m';
    0.0 = 'winding2.port_p.Phi' + 'winding2.port_n.Phi';
    'winding2.Phi' = 'winding2.port_p.Phi';
    'winding2.V_m' = 'winding2.i' * 10.0 "Ampere's law";
    10.0 * der('winding2.Phi_ind') = -'winding2.v' "Faraday's law";
    'winding2.Phi_leak' = 1.25663706212e-9 * 'winding2.V_m';
    'winding2.Phi' = 'winding2.Phi_ind' + 'winding2.Phi_leak';
    'winding2.Psi' = 10.0 * 'winding2.Phi_ind';
    'winding2.L_stat' = noEvent(if abs('winding2.i') > 2.220446049250313e-14 then abs('winding2.Psi' / 'winding2.i') else abs('winding2.Psi' / 2.220446049250313e-14));
    'resistor2.R_actual' = 2.0;
    'resistor2.v' = 'resistor2.R_actual' * 'resistor2.i';
    'resistor2.LossPower' = 'resistor2.v' * 'resistor2.i';
    'resistor2.T_heatPort' = 300.15;
    0.0 = 'resistor2.p.i' + 'resistor2.n.i';
    'resistor2.i' = 'resistor2.p.i';
    'resistor2.v' = 'resistor2.p.v' - 'resistor2.n.v';
    'el_ground2.p.v' = 0.0;
    'core.tabris.y[1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValue'('core.tabris.tableID', 1, 'core.tabris.u[1]');
    'core.tabfal.y[1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValue'('core.tabfal.tableID', 1, 'core.tabfal.u[1]');
    'core.tabris.u[1]' = 'core.Hstat';
    'core.tabfal.u[1]' = 'core.Hstat';
    'core.hystR' = 'core.tabris.y[1]' + 1.25663706212e-6 * 'core.Hstat' - 0.00243879512433445;
    'core.hystF' = 'core.tabfal.y[1]' + 1.25663706212e-6 * 'core.Hstat' + 0.00243879512433445;
    'core.asc' = der('core.Hstat') > 0.0;
    der('core.B') = 'core.k' * 'core.dHyst' + 1.25663706212e-6 * der('core.Hstat');
    'core.diffHyst' = 'core.hystF' - 'core.hystR';

    if initial() then
      'core.k' = 0.01;
      'core.dHyst' = 0.0;
    elseif 'core.asc' then
      'core.dHyst' = der('core.hystR' - 1.25663706212e-6 * 'core.Hstat');
      'core.k' = max(0.01, ('core.hystF' - 'core.B') / 'core.diffHyst');
    elseif true then
      'core.dHyst' = der('core.hystF' - 1.25663706212e-6 * 'core.Hstat');
      'core.k' = max(0.01, ('core.B' - 'core.hystR') / 'core.diffHyst');
    end if;

    der('core.MagRel') = 0.0;
    'core.H' = 'core.Hstat' + 'core.Heddy';
    'core.H' = 'core.V_m' / 0.2;
    'core.Phi' = 'core.B' * 5e-4;
    'core.Heddy' = 0.04583333333333333 * der('core.B');
    'core.LossPowerStat' = 'core.Hstat' * der('core.B') * 1e-4;
    'core.LossPowerEddy' = 'core.Heddy' * der('core.B') * 1e-4;
    'core.LossPower' = 'core.LossPowerStat' + 'core.LossPowerEddy';
    'core.T_heatPort' = 293.15;
    0.0 = 'core.port_p.Phi' + 'core.port_n.Phi';
    'core.V_m' = 'core.port_p.V_m' - 'core.port_n.V_m';
    'core.Phi' = 'core.port_p.Phi';
    annotation(experiment(StartTime = 0, StopTime = 0.02, Interval = 4e-6, Tolerance = 1e-006));
  end 'SinglePhaseTransformerWithHysteresis1';
end 'SinglePhaseTransformerWithHysteresis1';
