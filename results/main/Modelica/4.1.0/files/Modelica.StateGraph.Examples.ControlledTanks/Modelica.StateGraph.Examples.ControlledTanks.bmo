      'start.on' := false;
    end when;

    when change('start.table.y') then
      'start.on' := true;
    end when;
  algorithm
    'stop.pre_reset' := pre('stop.reset');

    when {'stop.pre_reset[1]', 'stop.pre_reset[2]'} then
      'stop.on' := false;
    end when;

    when change('stop.table.y') then
      'stop.on' := true;
    end when;
  algorithm
    'shut.pre_reset' := pre('shut.reset');

    when {'shut.pre_reset[1]', 'shut.pre_reset[2]'} then
      'shut.on' := false;
    end when;

    when change('shut.table.y') then
      'shut.on' := true;
    end when;
    annotation(experiment(StopTime = 100));
  end 'ControlledTanks';
end 'ControlledTanks';
