    Real 'mass2.v'(stateSelect = StateSelect.default, fixed = false, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass2.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter Boolean 'supportFriction.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'supportFriction.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'supportFriction.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'supportFriction.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'supportFriction.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'supportFriction.s_a'(unit = "m", quantity = "Length") "Distance between left flange and support";
    Real 'supportFriction.s_b'(unit = "m", quantity = "Length") "Distance between right flange and support";
    Real 'supportFriction.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    parameter Boolean 'supportFriction.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'supportFriction.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'supportFriction.heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'supportFriction.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    parameter Real 'supportFriction.f_pos[1,1]' = 0.0 "Positive sliding friction characteristic [N] as function of v [m/s] (v>=0)";
    parameter Real 'supportFriction.f_pos[1,2]' = 1.0 "Positive sliding friction characteristic [N] as function of v [m/s] (v>=0)";
    parameter 'Modelica.Blocks.Types.Smoothness' 'supportFriction.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' "Smoothness of interpolation in f_pos table";
    parameter Real 'supportFriction.peak'(min = 1.0) = 1.0 "Peak for maximum friction force at v==0 (f0_max = peak*f_pos[1,2])";
    parameter Real 'supportFriction.v_small'(unit = "m/s", quantity = "Velocity") = 0.001 "Relative velocity near to zero (see model info text)";
    Real 'supportFriction.v_relfric'(unit = "m/s", quantity = "Velocity") "Relative velocity between frictional surfaces";
    Real 'supportFriction.a_relfric'(unit = "m/s2", quantity = "Acceleration") "Relative acceleration between frictional surfaces";
    Real 'supportFriction.f0'(unit = "N", quantity = "Force") "Friction force for v_relfric=0 and forward sliding";
    Real 'supportFriction.f0_max'(unit = "N", quantity = "Force") "Maximum friction force for v_relfric=0 and locked";
    Boolean 'supportFriction.free' "= true, if frictional element is not active";
    Real 'supportFriction.sa'(unit = "1") "Path parameter of friction characteristic f = f(a_relfric)";
    Boolean 'supportFriction.startForward'(fixed = true, start = false) "= true, if v_relfric=0 and start of forward sliding";
    Boolean 'supportFriction.startBackward'(fixed = true, start = false) "= true, if v_relfric=0 and start of backward sliding";
    Boolean 'supportFriction.locked'(start = false) "= true, if v_relfric=0 and not sliding";
    constant Integer 'supportFriction.Unknown' = 3 "Value of mode is not known";
    constant Integer 'supportFriction.Free' = 2 "Element is not active";
    constant Integer 'supportFriction.Forward' = 1 "v_relfric > 0 (forward sliding)";
    constant Integer 'supportFriction.Stuck' = 0 "v_relfric = 0 (forward sliding, locked or backward sliding)";
    constant Integer 'supportFriction.Backward' = -1 "v_relfric < 0 (backward sliding)";
    Integer 'supportFriction.mode'(fixed = true, start = 3, max = 3, min = -1) "Mode of friction (-1: backward sliding, 0: stuck, 1: forward sliding, 2: inactive, 3: unknown)";
    constant Real 'supportFriction.unitAcceleration'(unit = "m/s2", quantity = "Acceleration") = 1.0;
    constant Real 'supportFriction.unitForce'(unit = "N", quantity = "Force") = 1.0;
    Real 'supportFriction.s'(unit = "m", quantity = "Length") "= flange_a.s - support.s";
    Real 'supportFriction.f'(unit = "N", quantity = "Force") "Friction force";
    Real 'supportFriction.v'(unit = "m/s", quantity = "Velocity") "Absolute velocity of flange_a and flange_b";
    Real 'supportFriction.a'(unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of flange_a and flange_b";
