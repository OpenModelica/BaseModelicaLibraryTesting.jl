    Real 'spring.f'(unit = "N", quantity = "Force") "Force between flanges (positive in direction of flange axis R)";
    parameter Real 'spring.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 100.0 "Spring constant";
    parameter Real 'spring.s_rel0'(min = 0.0, unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
