    parameter Real 'smeeData.xmq' = 1.5 "Main field reactance per phase, q-axis [pu]";
    parameter Real 'smeeData.xe' = 1.5384615384615383 "Excitation reactance [pu]";
    parameter Real 'smeeData.xrd' = 1.5499999976666663 "Damper reactance per phase, d-axis [pu]";
    parameter Real 'smeeData.xrq' = 1.5500000002411112 "Damper reactance per phase, d-axis [pu]";
    parameter Real 'smeeData.rs' = 0.030000000995873476 "Stator resistance per phase at specification temperature [pu]";
    parameter Real 'smeeData.rrd' = 0.039999997556176274 "Damper resistance per phase at specification temperature, d-axis [pu]";
    parameter Real 'smeeData.rrq' = 0.03999999997256669 "Damper resistance per phase at specification temperature, q-axis [pu]";
    parameter Real 'smeeData.re' = 0.018749999964806738 "Excitation resistance per phase at specification temperature [pu]";
    parameter Real 'smeeData.Rs'(unit = "Ohm", quantity = "Resistance") = 0.030000000995873476 "Stator resistance per phase at TRef";
    parameter Real 'smeeData.Lssigma'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'smeeData.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'smeeData.Lmd'(unit = "H", quantity = "Inductance") = 0.00477464829275686 "Main field inductance per phase in d-axis";
    parameter Real 'smeeData.Lmq'(unit = "H", quantity = "Inductance") = 0.00477464829275686 "Main field inductance per phase in q-axis";
    parameter Real 'smeeData.Lrsigmad'(unit = "H", quantity = "Inductance") = 1.5915493566466348e-4 "Damper stray inductance in d-axis";
    parameter Real 'smeeData.Lrsigmaq'(unit = "H", quantity = "Inductance") = 1.5915494385937605e-4 "Damper stray inductance in q-axis";
    parameter Real 'smeeData.Rrd'(unit = "Ohm", quantity = "Resistance") = 0.039999997556176274 "Damper resistance in d-axis at TRef";
    parameter Real 'smeeData.Rrq'(unit = "Ohm", quantity = "Resistance") = 0.03999999997256669 "Damper resistance in q-axis at TRef";
    parameter Real 'smeeData.Re'(unit = "Ohm", quantity = "Resistance") = 2.499999995307565 "Excitation resistance at TRef";
    parameter Real 'smeeData.sigmae' = 0.02499999999999991 "Stray fraction of total excitation inductance";
    Real 'thetaM'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotor displacement angle, FundamentalWave machine";
    Real 'thetaE'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotor displacement angle, Electrical machine";
  initial equation
    'smeeE.is[1]' = 0.0;
    'smeeE.is[2]' = 0.0;
    'smeeM.is[1]' = 0.0;
    'smeeM.is[2]' = 0.0;
  equation
    'smeeM.phiMechanical' = 'smeeM.flange.phi' - 'smeeM.internalSupport.phi';
    'smeeM.wMechanical' = der('smeeM.phiMechanical');
    'smeeM.tauElectrical' = 'smeeM.inertiaRotor.flange_a.tau';
    'smeeM.tauShaft' = -'smeeM.flange.tau';
    'smeeM.powerBalance.powerStator' = 'smeeM.vs[1]' * 'smeeM.is[1]' + 'smeeM.vs[2]' * 'smeeM.is[2]' + 'smeeM.vs[3]' * 'smeeM.is[3]';
    'smeeM.powerBalance.powerMechanical' = 'smeeM.wMechanical' * 'smeeM.tauShaft';
    'smeeM.powerBalance.powerInertiaStator' = 0.29 * 'smeeM.inertiaStator.a' * 'smeeM.inertiaStator.w';
    'smeeM.powerBalance.powerInertiaRotor' = 0.29 * 'smeeM.inertiaRotor.a' * 'smeeM.inertiaRotor.w';
    'smeeM.powerBalance.lossPowerTotal' = 'smeeM.powerBalance.lossPowerStatorWinding' + 'smeeM.powerBalance.lossPowerStatorCore' + 'smeeM.powerBalance.lossPowerRotorCore' + 'smeeM.powerBalance.lossPowerStrayLoad' + 'smeeM.powerBalance.lossPowerFriction' + 'smeeM.powerBalance.lossPowerRotorWinding' + 'smeeM.powerBalance.lossPowerExcitation' + 'smeeM.powerBalance.lossPowerBrush';
    'smeeM.powerBalance.lossPowerStatorWinding' = 'smeeM.stator.resistor.resistor[1].LossPower' + 'smeeM.stator.resistor.resistor[2].LossPower' + 'smeeM.stator.resistor.resistor[3].LossPower';
    'smeeM.powerBalance.lossPowerStatorCore' = 'smeeM.stator.core.lossPower';
    'smeeM.powerBalance.lossPowerRotorCore' = 0.0;
    'smeeM.powerBalance.lossPowerStrayLoad' = 'smeeM.strayLoad.lossPower';
    'smeeM.powerBalance.lossPowerFriction' = 'smeeM.friction.lossPower';
    'smeeM.powerBalance.lossPowerRotorWinding' = 'smeeM.damperCageLossPower';
    'smeeM.powerBalance.powerExcitation' = 'smeeM.ve' * 'smeeM.ie';
    'smeeM.powerBalance.lossPowerExcitation' = 'smeeM.excitation.resistor.LossPower';
    'smeeM.powerBalance.lossPowerBrush' = 'smeeM.brush.lossPower';
    'smeeM.stator.V_m.re' = 'smeeM.stator.port_p.V_m.re' - 'smeeM.stator.port_n.V_m.re';
    'smeeM.stator.V_m.im' = 'smeeM.stator.port_p.V_m.im' - 'smeeM.stator.port_n.V_m.im';
    'smeeM.stator.abs_V_m' = sqrt('smeeM.stator.V_m.re' ^ 2.0 + 'smeeM.stator.V_m.im' ^ 2.0);
    'smeeM.stator.arg_V_m' = 'Modelica.Math.atan3'('smeeM.stator.V_m.im', 'smeeM.stator.V_m.re', 0.0);
    'smeeM.stator.Phi.re' = 'smeeM.stator.port_p.Phi.re';
    'smeeM.stator.Phi.im' = 'smeeM.stator.port_p.Phi.im';
    'smeeM.stator.abs_Phi' = sqrt('smeeM.stator.Phi.re' ^ 2.0 + 'smeeM.stator.Phi.im' ^ 2.0);
    'smeeM.stator.arg_Phi' = 'Modelica.Math.atan3'('smeeM.stator.Phi.im', 'smeeM.stator.Phi.re', 0.0);
    'smeeM.stator.electroMagneticConverter.V_m.re' = 'smeeM.stator.electroMagneticConverter.port_p.V_m.re' - 'smeeM.stator.electroMagneticConverter.port_n.V_m.re';
    'smeeM.stator.electroMagneticConverter.V_m.im' = 'smeeM.stator.electroMagneticConverter.port_p.V_m.im' - 'smeeM.stator.electroMagneticConverter.port_n.V_m.im';
    'smeeM.stator.electroMagneticConverter.abs_V_m' = sqrt('smeeM.stator.electroMagneticConverter.V_m.re' ^ 2.0 + 'smeeM.stator.electroMagneticConverter.V_m.im' ^ 2.0);
    'smeeM.stator.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('smeeM.stator.electroMagneticConverter.V_m.im', 'smeeM.stator.electroMagneticConverter.V_m.re', 0.0);
    'smeeM.stator.electroMagneticConverter.Phi.re' = 'smeeM.stator.electroMagneticConverter.port_p.Phi.re';
    'smeeM.stator.electroMagneticConverter.Phi.im' = 'smeeM.stator.electroMagneticConverter.port_p.Phi.im';
    'smeeM.stator.electroMagneticConverter.abs_Phi' = sqrt('smeeM.stator.electroMagneticConverter.Phi.re' ^ 2.0 + 'smeeM.stator.electroMagneticConverter.Phi.im' ^ 2.0);
    'smeeM.stator.electroMagneticConverter.arg_Phi' = 'Modelica.Math.atan3'('smeeM.stator.electroMagneticConverter.Phi.im', 'smeeM.stator.electroMagneticConverter.Phi.re', 0.0);
