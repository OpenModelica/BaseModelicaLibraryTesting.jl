    parameter Real 'smeeData.TrRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of damper resistances in d- and q-axis";
    parameter Real 'smeeData.alpha20r'(start = 0.0, displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of damper resistances in d- and q-axis";
    parameter Real 'smeeData.TeSpecification'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Specification excitation temperature";
