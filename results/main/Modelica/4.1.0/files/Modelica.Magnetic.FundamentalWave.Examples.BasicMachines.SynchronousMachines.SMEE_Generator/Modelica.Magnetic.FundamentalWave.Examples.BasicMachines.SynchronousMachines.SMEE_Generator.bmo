    parameter Real 'sineVoltage.sineVoltage[3].signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'sineVoltage.sineVoltage[3].signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -4.1887902047863905 "Phase of sine wave";
    parameter Boolean 'sineVoltage.sineVoltage[3].signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltage.sineVoltage[3].signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltage.sineVoltage[3].signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineVoltage.sineVoltage[3].signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sineVoltage.sineVoltage[3].offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'sineVoltage.sineVoltage[3].startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    constant Integer 'electricalPowerSensorM.m'(min = 1) = 3 "Number of phases";
    Real 'electricalPowerSensorM.P'(unit = "W", quantity = "Power");
    Real 'electricalPowerSensorM.Q'(unit = "var", quantity = "Power");
    parameter Integer 'electricalPowerSensorM.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'electricalPowerSensorM.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'electricalPowerSensorM.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'electricalPowerSensorM.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'electricalPowerSensorM.plug_ni.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'electricalPowerSensorM.plug_ni.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_ni.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'electricalPowerSensorM.plug_ni.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_ni.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'electricalPowerSensorM.plug_ni.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_ni.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'electricalPowerSensorM.plug_nv.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'electricalPowerSensorM.plug_nv.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_nv.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'electricalPowerSensorM.plug_nv.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_nv.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'electricalPowerSensorM.plug_nv.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricalPowerSensorM.plug_nv.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'electricalPowerSensorM.v_[1]'(unit = "V", quantity = "ElectricPotential");
