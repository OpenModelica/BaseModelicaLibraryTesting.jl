  end 'Modelica.Units.SI.ComplexMagneticPotentialDifference';

  model 'SMEE_Generator' "Electrical excited synchronous machine operating as generator"
    constant Integer 'm' = 3 "Number of stator phases";
    parameter Real 'VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'w'(unit = "rad/s", quantity = "AngularVelocity") = 156.97491292437 "Nominal speed";
    parameter Real 'Ie'(unit = "A", quantity = "ElectricCurrent") = 19.0 "Excitation current";
    parameter Real 'Ie0'(unit = "A", quantity = "ElectricCurrent") = 10.0 "Initial excitation current";
    parameter Real 'gamma0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial rotor displacement angle";
    parameter Integer 'p' = 2 "Number of pole pairs";
    parameter Real 'Rs'(unit = "Ohm", quantity = "Resistance") = 0.03 "Warm stator resistance per phase";
    parameter Real 'Lssigma'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'Lmd'(unit = "H", quantity = "Inductance") = 0.00477464829275686 "Main field inductance in d-axis";
    parameter Real 'Lmq'(unit = "H", quantity = "Inductance") = 0.00477464829275686 "Main field inductance in q-axis";
    parameter Real 'Lrsigmad'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance (equivalent three-phase winding) d-axis";
    parameter Real 'Lrsigmaq'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance (equivalent three-phase winding) q-axis";
    parameter Real 'Rrd'(unit = "Ohm", quantity = "Resistance") = 0.04 "Warm damper resistance (equivalent three-phase winding) d-axis";
    parameter Real 'Rrq'(unit = "Ohm", quantity = "Resistance") = 0.04 "Warm damper resistance (equivalent three-phase winding) q-axis";
    parameter Integer 'star.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'sineVoltage.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltage.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'sineVoltage.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'sineVoltage.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'sineVoltage.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    parameter Integer 'sineVoltage.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltage.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'sineVoltage.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'sineVoltage.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'sineVoltage.V[1]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitudes of sine waves";
    parameter Real 'sineVoltage.V[2]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitudes of sine waves";
    parameter Real 'sineVoltage.V[3]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitudes of sine waves";
    parameter Real 'sineVoltage.phase[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phases of sine waves";
    parameter Real 'sineVoltage.phase[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.0943951023931953 "Phases of sine waves";
    parameter Real 'sineVoltage.phase[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -4.1887902047863905 "Phases of sine waves";
    parameter Real 'sineVoltage.f[1]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'sineVoltage.f[2]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'sineVoltage.f[3]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'sineVoltage.offset[1]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'sineVoltage.offset[2]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'sineVoltage.offset[3]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'sineVoltage.startTime[1]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'sineVoltage.startTime[2]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'sineVoltage.startTime[3]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'sineVoltage.sineVoltage[1].V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltage.sineVoltage[1].phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase of sine wave";
    parameter Real 'sineVoltage.sineVoltage[1].f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    Real 'sineVoltage.sineVoltage[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sineVoltage.sineVoltage[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.sineVoltage[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.sineVoltage[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.sineVoltage[1].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.sineVoltage[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sineVoltage.sineVoltage[1].signalSource.amplitude' = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltage.sineVoltage[1].signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'sineVoltage.sineVoltage[1].signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase of sine wave";
    parameter Boolean 'sineVoltage.sineVoltage[1].signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltage.sineVoltage[1].signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltage.sineVoltage[1].signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineVoltage.sineVoltage[1].signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sineVoltage.sineVoltage[1].offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'sineVoltage.sineVoltage[1].startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'sineVoltage.sineVoltage[2].V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltage.sineVoltage[2].phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.0943951023931953 "Phase of sine wave";
    parameter Real 'sineVoltage.sineVoltage[2].f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    Real 'sineVoltage.sineVoltage[2].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sineVoltage.sineVoltage[2].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.sineVoltage[2].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.sineVoltage[2].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.sineVoltage[2].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.sineVoltage[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sineVoltage.sineVoltage[2].signalSource.amplitude' = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltage.sineVoltage[2].signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'sineVoltage.sineVoltage[2].signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.0943951023931953 "Phase of sine wave";
    parameter Boolean 'sineVoltage.sineVoltage[2].signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltage.sineVoltage[2].signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltage.sineVoltage[2].signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineVoltage.sineVoltage[2].signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sineVoltage.sineVoltage[2].offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'sineVoltage.sineVoltage[2].startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'sineVoltage.sineVoltage[3].V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 141.4213562373095 "Amplitude of sine wave";
    parameter Real 'sineVoltage.sineVoltage[3].phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -4.1887902047863905 "Phase of sine wave";
