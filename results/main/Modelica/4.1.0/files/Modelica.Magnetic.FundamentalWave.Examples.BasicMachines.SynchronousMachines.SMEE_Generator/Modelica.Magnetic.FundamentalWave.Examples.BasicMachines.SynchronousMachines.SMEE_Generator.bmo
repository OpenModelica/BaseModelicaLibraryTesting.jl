    parameter Real 'smeeData.IeOpenCircuit'(start = 10.0, unit = "A", quantity = "ElectricCurrent") = 10.0 "Open circuit excitation current @ nominal voltage and frequency";
    parameter Real 'smeeData.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'smeeData.turnsRatio' = 9.428090415820634 "Stator current / excitation current";
