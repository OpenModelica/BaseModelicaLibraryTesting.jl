    Real 'voltageSource1.P[2]'(unit = "W", quantity = "Power") "Active power";
    Real 'voltageSource1.P[3]'(unit = "W", quantity = "Power") "Active power";
    Real 'voltageSource1.P_total'(unit = "W", quantity = "Power") "Total active power";
    Real 'voltageSource1.Q[1]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSource1.Q[2]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSource1.Q[3]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSource1.Q_total'(unit = "var", quantity = "Power") "Total reactive power";
    Real 'voltageSource1.S[1]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSource1.S[2]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSource1.S[3]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSource1.S_total'(unit = "V.A", quantity = "Power") "Magnitude of total complex apparent power";
