//! base 0.1.0
package 'UnsymmetricalLoad'
  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  model 'UnsymmetricalLoad' "Unsymmetrical three-phase load"
    output Real 'i1_d'(unit = "A", quantity = "ElectricCurrent") "With neutral, direct component";
    output Real 'i1_i'(unit = "A", quantity = "ElectricCurrent") "With neutral, inverse component";
    output Real 'i1_0'(unit = "A", quantity = "ElectricCurrent") "With neutral, zero component";
    output Real 'i1_n'(unit = "A", quantity = "ElectricCurrent") "With neutral, neutral current";
    output Real 'i2_d'(unit = "A", quantity = "ElectricCurrent") "Without neutral, direct component";
    output Real 'i2_i'(unit = "A", quantity = "ElectricCurrent") "Without neutral, inverse component";
    output Real 'i2_0'(unit = "A", quantity = "ElectricCurrent") "Without neutral, zero component";
