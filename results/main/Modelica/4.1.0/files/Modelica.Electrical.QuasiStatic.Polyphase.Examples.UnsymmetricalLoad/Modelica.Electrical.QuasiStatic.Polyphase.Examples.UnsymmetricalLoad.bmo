    Real 'voltageSource1.arg_v[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'voltageSource1.arg_v[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
