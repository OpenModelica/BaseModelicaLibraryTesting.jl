    parameter Real 'voltageSource1.V[1]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 230.94010767585033 "RMS voltage of the source";
    parameter Real 'voltageSource1.V[2]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 230.94010767585033 "RMS voltage of the source";
