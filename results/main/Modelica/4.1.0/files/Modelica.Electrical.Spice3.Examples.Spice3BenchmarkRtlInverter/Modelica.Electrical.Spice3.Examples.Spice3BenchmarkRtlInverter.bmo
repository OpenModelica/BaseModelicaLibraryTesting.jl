  model 'Spice3BenchmarkRtlInverter' "Simple RTL inverter"
    parameter Real 'VCC.V'(unit = "V", quantity = "ElectricPotential") = 5.0 "Value of constant voltage";
    Real 'VCC.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'VCC.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'VCC.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
