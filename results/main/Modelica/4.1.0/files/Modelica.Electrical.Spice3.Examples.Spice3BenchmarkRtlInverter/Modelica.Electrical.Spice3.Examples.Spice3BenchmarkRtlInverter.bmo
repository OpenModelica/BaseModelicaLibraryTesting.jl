//! base 0.1.0
package 'Spice3BenchmarkRtlInverter'
  function 'Modelica.Electrical.Spice3.Internal.Bjt.bjtNoBypassCode' "Calculation of currents"
    input 'Modelica.Electrical.Spice3.Internal.Bjt.Bjt' 'in_p3';
    input 'Modelica.Electrical.Spice3.Internal.Bjt.BjtModelLineParams' 'in_p';
    input 'Modelica.Electrical.Spice3.Internal.Bjt.BjtCalc' 'in_c';
    input Real[6] 'in_m_pVoltageValues'(unit = {"V", "V", "V", "V", "V", "V"}, quantity = {"ElectricPotential", "ElectricPotential", "ElectricPotential", "ElectricPotential", "ElectricPotential", "ElectricPotential"});
    output 'Modelica.Electrical.Spice3.Internal.Bjt.CurrentsCapacitances' 'out_cc';
    Real 'vce'(unit = "V", quantity = "ElectricPotential");
    Real 'vbe'(unit = "V", quantity = "ElectricPotential");
    Real 'vbx'(unit = "V", quantity = "ElectricPotential");
    Real 'vbc'(unit = "V", quantity = "ElectricPotential");
    Real 'gbe'(unit = "S", quantity = "Conductance");
    Real 'cbe';
    Real 'gbc'(unit = "S", quantity = "Conductance");
    Real 'cbc'(unit = "A", quantity = "ElectricCurrent");
    Real 'gben'(unit = "S", quantity = "Conductance");
    Real 'cben'(unit = "A", quantity = "ElectricCurrent");
    Real 'gbcn'(unit = "S", quantity = "Conductance");
    Real 'cbcn'(unit = "A", quantity = "ElectricCurrent");
    Real 'cjbe'(unit = "A", quantity = "ElectricCurrent");
    Real 'cjbc'(unit = "A", quantity = "ElectricCurrent");
    Real 'dqbdve';
    Real 'dqbdvc';
    Real 'qb';
    Real 'q1';
    Real 'q2';
    Real 'arg';
    Real 'sqarg';
    Real 'cc';
    Real 'cex'(unit = "A", quantity = "ElectricCurrent");
    Real 'gex'(unit = "S", quantity = "Conductance");
    Real 'ttime'(unit = "s", quantity = "Time");
    Real 'step';
    Real 'laststep';
    Real 'bcex0'(unit = "A", quantity = "ElectricCurrent");
    Real 'bcex1'(unit = "A", quantity = "ElectricCurrent");
    Real 'arg1';
    Real 'arg2';
    Real 'denom';
    Real 'arg3';
    Real 'rbpr';
    Real 'rbpi';
    Real 'gx';
    Real 'xjrb';
    Real 'go';
    Real 'gm';
    Real 'captt'(min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'chargebe'(unit = "C", quantity = "ElectricCharge");
    Real 'chargebc'(unit = "C", quantity = "ElectricCharge");
    Real 'chargebx'(unit = "C", quantity = "ElectricCharge");
    Real 'argtf';
    Real 'exponent';
    Real 'temp';
    Real 'aux1';
    Real 'aux2';
    Real 'chargecs'(unit = "C", quantity = "ElectricCharge");
    Real 'vcs'(unit = "V", quantity = "ElectricPotential");
    Real 'sarg';
  algorithm
    'temp' := 0.0;
    'vce' := 'in_p'.'m_type' * ('in_m_pVoltageValues'[4] - 'in_m_pVoltageValues'[6]);
    'vbe' := 'in_p'.'m_type' * ('in_m_pVoltageValues'[5] - 'in_m_pVoltageValues'[6]);
    'vbx' := 'in_p'.'m_type' * ('in_m_pVoltageValues'[2] - 'in_m_pVoltageValues'[4]);

    if 'in_p3'.'m_uic' then
      if 'in_p3'.'m_bICvbeIsGiven' > 0.5 then
        'vbe' := 'in_p'.'m_type' * 'in_p3'.'m_dICvbe';
      end if;

      if 'in_p3'.'m_bICvceIsGiven' > 0.5 then
        'vce' := 'in_p'.'m_type' * 'in_p3'.'m_dICvce';
      end if;

      'vbx' := 'vbe' - 'vce';
    end if;

    'vbc' := 'vbe' - 'vce';
    ('cbe', 'gbe', 'cben', 'gben') := 'Modelica.Electrical.Spice3.Internal.Functions.junction2SPICE3BJT'('vbe', 'in_p3'.'m_dTemp', 'in_p'.'m_emissionCoeffF', 'in_p'.'m_leakBEemissionCoeff', 'in_c'.'m_tSatCur', 'in_c'.'m_tBEleakCur');
    'out_cc'.'iBE' := 'in_p'.'m_type' * 'cbe' / 'in_c'.'m_tBetaF';
    'out_cc'.'iBEN' := 'in_p'.'m_type' * 'cben';
    ('cbc', 'gbc', 'cbcn', 'gbcn') := 'Modelica.Electrical.Spice3.Internal.Functions.junction2SPICE3BJT'('vbc', 'in_p3'.'m_dTemp', 'in_p'.'m_emissionCoeffR', 'in_p'.'m_leakBCemissionCoeff', 'in_c'.'m_tSatCur', 'in_c'.'m_tBCleakCur');
    'out_cc'.'iBC' := 'in_p'.'m_type' * 'cbc' / 'in_c'.'m_tBetaR';
    'out_cc'.'iBCN' := 'in_p'.'m_type' * 'cbcn';
    'cjbe' := 'cbe' / 'in_c'.'m_tBetaF' + 'cben';
    'cjbc' := 'cbc' / 'in_c'.'m_tBetaR' + 'cbcn';
    'q1' := 1.0 / (1.0 - 'in_p'.'m_invEarlyVoltF' * 'vbc' - 'in_p'.'m_invEarlyVoltR' * 'vbe');

    if 'in_p'.'m_invRollOffF' == 0.0 and 'in_p'.'m_invRollOffR' == 0.0 then
      'qb' := 'q1';
      'dqbdve' := 'q1' * 'qb' * 'in_p'.'m_invEarlyVoltR';
      'dqbdvc' := 'q1' * 'qb' * 'in_p'.'m_invEarlyVoltF';
    elseif true then
      'q2' := 'in_p'.'m_invRollOffF' * 'cbe' + 'in_p'.'m_invRollOffR' * 'cbc';
      'arg' := max(0.0, 1.0 + 4.0 * 'q2');
      'sqarg' := 1.0;

      if 'arg' <> 0.0 then
        'sqarg' := sqrt('arg');
      end if;

      'qb' := 'q1' * (1.0 + 'sqarg') / 2.0;
      'dqbdve' := 'q1' * ('qb' * 'in_p'.'m_invEarlyVoltR' + 'in_p'.'m_invRollOffF' * 'gbe' / 'sqarg');
      'dqbdvc' := 'q1' * ('qb' * 'in_p'.'m_invEarlyVoltF' + 'in_p'.'m_invRollOffR' * 'gbc' / 'sqarg');
    end if;

    'cc' := 0.0;
    'cex' := 'cbe';
    'gex' := 'gbe';
    'ttime' := 1.0;

    if 'in_p'.'m_excessPhaseFactor' <> 0.0 and 'ttime' > 0.0 then
      'step' := 0.0;
      'laststep' := 1.0;
      'bcex0' := 0.0;
      'bcex1' := 0.0;

      if 'bcex1' == 0.0 then
        'bcex1' := 'cbe' / 'qb';
        'bcex0' := 'bcex1';
      end if;

      'arg1' := 'step' / 'in_p'.'m_excessPhaseFactor';
      'arg2' := 3.0 * 'arg1';
      'arg1' := 'arg2' * 'arg1';
      'denom' := 1.0 + 'arg1' + 'arg2';
      'arg3' := 'arg1' / 'denom';
      'cc' := ('bcex0' * (1.0 + 'step' / 'laststep' + 'arg2') - 'bcex1' * 'step' / 'laststep') / 'denom';
      'cex' := 'cbe' * 'arg3';
      'gex' := 'gbe' * 'arg3';
    end if;

    'cc' := 'cc' + ('cex' - 'cbc') / 'qb';
    'rbpr' := 'in_p'.'m_minBaseResist' / 'in_p3'.'m_area';
    'rbpi' := 'in_p'.'m_baseResist' / 'in_p3'.'m_area' - 'rbpr';
    'gx' := 'rbpr' + 'rbpi' / 'qb';
    'xjrb' := 'in_p'.'m_baseCurrentHalfResist' * 'in_p3'.'m_area';

    if 'xjrb' <> 0.0 then
      'arg1' := max(('cjbe' + 'cjbc') / 'xjrb', 1e-9);
      'arg2' := (sqrt(1.0 + 14.59025 * 'arg1') - 1.0) / 2.4317 / sqrt('arg1');
      'arg1' := tan('arg2');
      'gx' := 'rbpr' + 3.0 * 'rbpi' * ('arg1' - 'arg2') / 'arg2' / 'arg1' / 'arg1';
    end if;

    if 'gx' <> 0.0 then
      'gx' := 1.0 / 'gx';
    end if;

    'out_cc'.'rx' := 'gx';
    'go' := ('gbc' + ('cex' - 'cbc') * 'dqbdvc' / 'qb') / 'qb';
    'gm' := ('gex' - ('cex' - 'cbc') * 'dqbdve' / 'qb') / 'qb' - 'go';
    'out_cc'.'iCC' := 'in_p'.'m_type' * 'cc';
    'captt' := 0.0;

    if 'in_p'.'m_transitTimeF' <> 0.0 and 'vbe' > 0.0 then
      'argtf' := 0.0;
      'arg2' := 0.0;
      'arg3' := 0.0;

      if 'in_p'.'m_transitTimeBiasCoeffF' <> 0.0 then
        'argtf' := 'in_p'.'m_transitTimeBiasCoeffF';

        if 'in_p'.'m_transitTimeVBCFactor' <> 0.0 then
          'exponent' := min(50.0, 'vbc' * 'in_p'.'m_transitTimeVBCFactor');
          'argtf' := 'argtf' * exp('exponent');
        end if;

        'arg2' := 'argtf';

        if 'in_p'.'m_transitTimeHighCurrentF' <> 0.0 then
          'temp' := 'cbe' / ('cbe' + 'in_p'.'m_transitTimeHighCurrentF');
          'argtf' := 'argtf' * 'temp' * 'temp';
          'arg2' := 'argtf' * (3.0 - 'temp' - 'temp');
        end if;

        'arg3' := 'cbe' * 'argtf' * 'in_p'.'m_transitTimeVBCFactor';
      end if;

      'cbe' := 'cbe' * (1.0 + 'argtf') / 'qb';
      'gbe' := ('gbe' * (1.0 + 'arg2') - 'cbe' * 'dqbdve') / 'qb';
      'captt' := 'in_p'.'m_transitTimeF' * ('arg3' - 'cbe' * 'dqbdvc') / 'qb';
    end if;

    'out_cc'.'captt' := 'captt';
    ('out_cc'.'capbe', 'chargebe') := 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapTransTime'('in_c'.'m_tBEcap', 'vbe', 'in_c'.'m_tDepCapBE', 'in_p'.'m_junctionExpBE', 'in_c'.'m_tBEpot', 'in_c'.'m_tF1e', 'in_c'.'m_f2e', 'in_c'.'m_f3e', 'in_p'.'m_transitTimeF', 'gbe', 'cbe');
    'aux1' := 'in_c'.'m_tBCcap' * 'in_p'.'m_baseFractionBCcap';
    ('out_cc'.'capbc', 'chargebc') := 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapTransTime'('aux1', 'vbc', 'in_c'.'m_tDepCapBC', 'in_p'.'m_junctionExpBC', 'in_c'.'m_tBCpot', 'in_c'.'m_tF1c', 'in_c'.'m_f2c', 'in_c'.'m_f3c', 'in_p'.'m_transitTimeR', 'gbc', 'cbc');
    'aux2' := 'in_c'.'m_tBCcap' * (1.0 - 'in_p'.'m_baseFractionBCcap');
    ('out_cc'.'capbx', 'chargebx') := 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapRevised'('aux2', 'vbx', 'in_c'.'m_tDepCapBC', 'in_p'.'m_junctionExpBC', 'in_c'.'m_tBCpot', 'in_c'.'m_tF1c', 'in_c'.'m_f2c', 'in_c'.'m_f3c');
    'out_cc'.'capcs' := 0.0;
    'chargecs' := 0.0;
    'vcs' := 'in_p'.'m_type' * (-'in_m_pVoltageValues'[4]);

    if 'vcs' < 0.0 then
      'arg' := 1.0 - 'vcs' / 'in_p'.'m_potentialSubstrate';
      'sarg' := exp(-'in_p'.'m_exponentialSubstrate' * log('arg'));
      'out_cc'.'capcs' := 'in_p3'.'m_CScap' * 'sarg';
      'chargecs' := 'in_p'.'m_potentialSubstrate' * 'in_p3'.'m_CScap' * (1.0 - 'arg' * 'sarg') / (1.0 - 'in_p'.'m_exponentialSubstrate');
    elseif true then
      'out_cc'.'capcs' := 'in_p3'.'m_CScap' * (1.0 + 'in_p'.'m_exponentialSubstrate' * 'vcs' / 'in_p'.'m_potentialSubstrate');
      'chargecs' := 'vcs' * 'in_p3'.'m_CScap' * (1.0 + 'in_p'.'m_exponentialSubstrate' * 'vcs' / (2.0 * 'in_p'.'m_potentialSubstrate'));
    end if;

    'out_cc'.'iXX' := 1.0;
    annotation(smoothOrder(normallyConstant = 'in_p3') = 1);
  end 'Modelica.Electrical.Spice3.Internal.Bjt.bjtNoBypassCode';

  function 'Modelica.Electrical.Spice3.Internal.Functions.junction2SPICE3BJT' "Junction current and conductance calculation"
    input Real 'voltage'(unit = "V", quantity = "ElectricPotential");
    input Real 'temp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'ncoeff1';
    input Real 'ncoeff2';
    input Real 'satcur1'(unit = "A", quantity = "ElectricCurrent");
    input Real 'satcur2'(unit = "A", quantity = "ElectricCurrent");
    output Real 'current1'(unit = "A", quantity = "ElectricCurrent");
    output Real 'cond1'(unit = "S", quantity = "Conductance");
    output Real 'current2'(unit = "A", quantity = "ElectricCurrent");
    output Real 'cond2'(unit = "S", quantity = "Conductance");
    Real 'vte'(unit = "V", quantity = "ElectricPotential");
    Real 'vtn'(unit = "V", quantity = "ElectricPotential");
    Real 'evd';
  algorithm
    'vtn' := 8.617251692337959e-5 * 'temp' * 'ncoeff1';
    'vte' := 8.617251692337959e-5 * 'temp' * 'ncoeff2';

    if 'voltage' > (-5.0 * 'vtn') then
      'evd' := exp('voltage' / 'vtn');
      'current1' := 'satcur1' * ('evd' - 1.0) + 1e-12 * 'voltage';
      'cond1' := 'satcur1' * 'evd' / 'vtn' + 1e-12;

      if 'satcur2' == 0.0 then
        'current2' := 0.0;
        'cond2' := 0.0;
      elseif true then
        'evd' := exp('voltage' / 'vte');
        'current2' := 'satcur2' * ('evd' - 1.0);
        'cond2' := 'satcur2' * 'evd' / 'vte';
      end if;
    elseif true then
      'cond1' := 1e-12 - 'satcur1' / 'voltage';
      'current1' := 'cond1' * 'voltage';
      'cond2' := -'satcur2' / 'voltage';
      'current2' := -'satcur2';
    end if;
  end 'Modelica.Electrical.Spice3.Internal.Functions.junction2SPICE3BJT';

  function 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapRevised' "Junction capacity"
    input Real 'capin'(min = -1e60, unit = "F", quantity = "Capacitance");
    input Real 'voltage'(unit = "V", quantity = "ElectricPotential");
    input Real 'depcap'(unit = "V", quantity = "ElectricPotential");
    input Real 'mj';
    input Real 'phij';
    input Real 'f1'(unit = "V", quantity = "ElectricPotential");
    input Real 'f2';
    input Real 'f3';
    output Real 'capout'(min = -1e60, unit = "F", quantity = "Capacitance");
    output Real 'charge'(unit = "C", quantity = "ElectricCharge");
    Real 'arg';
    Real 'sarg';
    Real 'czof2';
  algorithm
    if 'voltage' < 'depcap' then
      'arg' := 1.0 - 'voltage' / 'phij';

      if 'mj' == 0.5 then
        'sarg' := 1.0 / sqrt('arg');
      elseif true then
        'sarg' := exp(-'mj' * log('arg'));
      end if;

      'capout' := 'capin' * 'sarg';
      'charge' := 'phij' * ('capin' * (1.0 - 'arg' * 'sarg') / (1.0 - 'mj'));
    elseif true then
      'czof2' := 'capin' / 'f2';
      'capout' := 'czof2' * ('f3' + 'mj' * 'voltage' / 'phij');
      'charge' := 'capin' * 'f1' + 'czof2' * ('f3' * ('voltage' - 'depcap') + 'mj' / (2.0 * 'phij') * ('voltage' ^ 2.0 - 'depcap' ^ 2.0));
    end if;
  end 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapRevised';

  function 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapTransTime' "Junction capacitance transittime calculation"
    input Real 'capin'(min = -1e60, unit = "F", quantity = "Capacitance");
    input Real 'voltage'(unit = "V", quantity = "ElectricPotential");
    input Real 'depcap'(unit = "V", quantity = "ElectricPotential");
    input Real 'mj';
    input Real 'phij';
    input Real 'f1'(unit = "V", quantity = "ElectricPotential");
    input Real 'f2';
    input Real 'f3';
    input Real 'transittime'(unit = "s", quantity = "Time");
    input Real 'conduct'(unit = "S", quantity = "Conductance");
    input Real 'current'(unit = "A", quantity = "ElectricCurrent");
    output Real 'capout'(min = -1e60, unit = "F", quantity = "Capacitance");
    output Real 'charge'(unit = "C", quantity = "ElectricCharge");
  algorithm
    ('capout', 'charge') := 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapRevised'('capin', 'voltage', 'depcap', 'mj', 'phij', 'f1', 'f2', 'f3');
    'capout' := 'capout' + 'transittime' * 'conduct';
    'charge' := 'charge' + 'transittime' * 'current';
  end 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapTransTime';

  record 'Modelica.Electrical.Spice3.Internal.Bjt.Bjt'
    Real 'm_dTemp'(nominal = 300.0, start = 300.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'm_area'(start = 1.0);
    Boolean 'm_bOff'(start = false);
    Real 'm_dICvbe'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_bICvbeIsGiven'(start = 0.0);
    Real 'm_dICvce'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_bICvceIsGiven'(start = 0.0);
    Boolean 'm_uic';
    Boolean 'm_bSensArea'(start = false);
    Real 'm_transitTimeHighCurrentF'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'm_invRollOffF'(start = 0.0, unit = "1/A", quantity = "InverseElectricCurrent");
    Real 'm_invRollOffR'(start = 0.0, unit = "1/A", quantity = "InverseElectricCurrent");
    Real 'm_CScap'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
  end 'Modelica.Electrical.Spice3.Internal.Bjt.Bjt';

  record 'Modelica.Electrical.Spice3.Internal.Bjt.BjtModelLineParams'
    Real 'm_type'(start = 1.0);
    Real 'm_tnom'(nominal = 300.0, start = 300.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'm_satCur'(start = 1e-16, unit = "A", quantity = "ElectricCurrent");
    Real 'm_betaF'(start = 100.0);
    Real 'm_emissionCoeffF'(start = 1.0);
    Real 'm_leakBEemissionCoeff'(start = 1.5);
    Real 'm_leakBEcurrent'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'm_c2'(start = 0.0);
    Real 'm_leakBCcurrent'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'm_c4'(start = 0.0);
    Real 'm_leakBEcurrentIsGiven';
    Real 'm_c2IsGiven';
    Real 'm_leakBCcurrentIsGiven';
    Real 'm_c4IsGiven';
    Real 'm_betaR'(start = 1.0);
    Real 'm_emissionCoeffR'(start = 1.0);
    Real 'm_leakBCemissionCoeff'(start = 2.0);
    Real 'm_earlyVoltF'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_rollOffF'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'm_earlyVoltR'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_rollOffR'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'm_emitterResist'(start = 0.0, unit = "Ohm", quantity = "Resistance");
    Real 'm_collectorResist'(start = 0.0, unit = "Ohm", quantity = "Resistance");
    Real 'm_baseCurrentHalfResist'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'm_baseResist'(start = 0.0, unit = "Ohm", quantity = "Resistance");
    Real 'm_minBaseResist'(start = 0.0, unit = "Ohm", quantity = "Resistance");
    Real 'm_minBaseResistIsGiven';
    Real 'm_depletionCapBE'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_potentialBE'(start = 0.75, unit = "V", quantity = "ElectricPotential");
    Real 'm_junctionExpBE'(start = 0.33);
    Real 'm_transitTimeF'(start = 0.0, unit = "s", quantity = "Time");
    Real 'm_transitTimeBiasCoeffF'(start = 0.0);
    Real 'm_transitTimeHighCurrentF'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
    Real 'm_transitTimeFVBC'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_excessPhase'(start = 0.0, unit = "Hz", quantity = "Frequency");
    Real 'm_depletionCapBC'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_potentialBC'(start = 0.75, unit = "V", quantity = "ElectricPotential");
    Real 'm_junctionExpBC'(start = 0.33);
    Real 'm_baseFractionBCcap'(start = 1.0);
    Real 'm_transitTimeR'(start = 0.0, unit = "s", quantity = "Time");
    Real 'm_capCS'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_potentialSubstrate'(start = 0.75, unit = "V", quantity = "ElectricPotential");
    Real 'm_exponentialSubstrate'(start = 0.0);
    Real 'm_betaExp'(start = 0.0);
    Real 'm_energyGap'(start = 1.11, unit = "eV", quantity = "Energy");
    Real 'm_tempExpIS'(start = 3.0);
    Real 'm_fNcoef'(start = 0.0);
    Real 'm_fNexp'(start = 1.0);
    Real 'm_depletionCapCoeff'(start = 0.5);
    Real 'm_collectorConduct'(start = 0.0, unit = "S", quantity = "Conductance");
    Real 'm_emitterConduct'(start = 0.0, unit = "S", quantity = "Conductance");
    Real 'm_transitTimeVBCFactor'(start = 0.0, unit = "1/V", quantity = "InversePotential");
    Real 'm_excessPhaseFactor'(start = 0.0);
    Real 'm_invEarlyVoltF'(start = 0.0, unit = "1/V", quantity = "InversePotential");
    Real 'm_invRollOffF'(start = 0.0, unit = "1/A", quantity = "InverseElectricCurrent");
    Real 'm_invEarlyVoltR'(start = 0.0, unit = "1/V", quantity = "InversePotential");
    Real 'm_invRollOffR'(start = 0.0, unit = "1/A", quantity = "InverseElectricCurrent");
    Real 'm_bNPN' = 1.0;
    Real 'm_bPNP' = 1.0;
    Real 'm_area' = 1.0;
    Boolean 'm_bOff' = false;
    Real 'm_dICvbe'(unit = "V", quantity = "ElectricPotential") = 0.0;
    Real 'm_bICvbeIsGiven' = 0.0;
    Real 'm_dICvce'(unit = "V", quantity = "ElectricPotential") = 0.0;
    Real 'm_bICvceIsGiven' = 0.0;
    Boolean 'm_bSensArea' = false;
    Real 'm_dTemp' = 1.0;
  end 'Modelica.Electrical.Spice3.Internal.Bjt.BjtModelLineParams';

  record 'Modelica.Electrical.Spice3.Internal.Bjt.BjtCalc'
    Real 'm_tSatCur'(start = 0.0, unit = "A", quantity = "ElectricCurrent");
