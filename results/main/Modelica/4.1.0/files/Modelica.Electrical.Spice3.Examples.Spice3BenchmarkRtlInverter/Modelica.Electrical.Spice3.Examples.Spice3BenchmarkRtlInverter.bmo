    Real 'VCC.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'VCC.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'VIN.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'VIN.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'VIN.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'VIN.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'VIN.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'VIN.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'VIN.V1'(unit = "V", quantity = "ElectricPotential") = 0.0 "Initial value";
    parameter Real 'VIN.V2'(unit = "V", quantity = "ElectricPotential") = 5.0 "Pulsed value";
    parameter Real 'VIN.TD'(unit = "s", quantity = "Time") = 2e-9 "Delay time";
    parameter Real 'VIN.TR'(start = 1.0, unit = "s", quantity = "Time") = 2e-9 "Rise time";
    parameter Real 'VIN.TF'(unit = "s", quantity = "Time") = 2e-9 "Fall time";
    parameter Real 'VIN.PW'(unit = "s", quantity = "Time") = 3e-8 "Pulse width";
    parameter Real 'VIN.PER'(unit = "s", quantity = "Time") = 1e60 "Period";
    parameter Real 'VIN.Trising'(unit = "s", quantity = "Time") = 2e-9 "End time of rising phase within one period";
    parameter Real 'VIN.Twidth'(unit = "s", quantity = "Time") = 3.1999999999999995e-8 "End time of width phase within one period";
    parameter Real 'VIN.Tfalling'(unit = "s", quantity = "Time") = 3.3999999999999993e-8 "End time of falling phase within one period";
    Real 'VIN.T0'(fixed = true, start = 2e-9, unit = "s", quantity = "Time") "Start time of current period";
    Integer 'VIN.counter'(fixed = true, start = -1) "Period counter";
    Integer 'VIN.counter2'(fixed = true, start = -1);
    Real 'RB.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'RB.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'RB.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'RB.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'RB.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'RB.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'RB.R'(start = 1000.0, unit = "Ohm", quantity = "Resistance") = 1e4 "Resistance";
    Real 'Q1.B.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'Q1.B.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'Q1.C.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
