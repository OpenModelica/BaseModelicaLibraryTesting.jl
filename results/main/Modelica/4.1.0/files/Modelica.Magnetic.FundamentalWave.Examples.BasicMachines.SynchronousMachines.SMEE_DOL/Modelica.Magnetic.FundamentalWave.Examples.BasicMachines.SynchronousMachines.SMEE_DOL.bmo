    parameter Real 'switch.idealClosingSwitch[1].Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Closed switch resistance";
    parameter Real 'switch.idealClosingSwitch[1].Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Opened switch conductance";
    parameter Boolean 'switch.idealClosingSwitch[1].useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
