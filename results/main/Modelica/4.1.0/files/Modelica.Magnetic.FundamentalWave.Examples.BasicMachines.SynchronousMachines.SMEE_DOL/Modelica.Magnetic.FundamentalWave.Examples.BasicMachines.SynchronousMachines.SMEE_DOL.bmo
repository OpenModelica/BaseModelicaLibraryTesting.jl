    constant Real 'switch.idealClosingSwitch[2].unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'switch.idealClosingSwitch[2].unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Boolean 'switch.idealClosingSwitch[2].control' "true => p--n connected, false => switch open";
    Real 'switch.idealClosingSwitch[3].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'switch.idealClosingSwitch[3].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
