    constant Real 'switch.idealClosingSwitch[1].unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'switch.idealClosingSwitch[1].unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Boolean 'switch.idealClosingSwitch[1].control' "true => p--n connected, false => switch open";
