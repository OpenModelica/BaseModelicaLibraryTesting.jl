    Boolean 'switch.idealClosingSwitch[3].off' "Indicates off-state";
    Real 'switch.idealClosingSwitch[3].s'(unit = "1") "Auxiliary variable";
    constant Real 'switch.idealClosingSwitch[3].unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'switch.idealClosingSwitch[3].unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Boolean 'switch.idealClosingSwitch[3].control' "true => p--n connected, false => switch open";
    parameter Real 'booleanStep.startTime'(unit = "s", quantity = "Time") = 0.0 "Time instant of step start";
    parameter Boolean 'booleanStep.startValue' = false "Output before startTime";
    Boolean 'booleanStep.y' "Connector of Boolean output signal";
    parameter Integer 'booleanReplicator.nout' = 3 "Number of outputs";
    Boolean 'booleanReplicator.u' "Connector of Boolean input signal";
    Boolean 'booleanReplicator.y[1]' "Connector of Boolean output signals";
    Boolean 'booleanReplicator.y[2]' "Connector of Boolean output signals";
    Boolean 'booleanReplicator.y[3]' "Connector of Boolean output signals";
    parameter Boolean 'torqueStep.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'torqueStep.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'torqueStep.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'torqueStep.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'torqueStep.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of flange with respect to support (= flange.phi - support.phi)";
    parameter Real 'torqueStep.stepTorque'(start = 1.0, unit = "N.m", quantity = "Torque") = 50.0 "Height of torque step (if negative, torque is acting as load)";
    parameter Real 'torqueStep.offsetTorque'(start = 0.0, unit = "N.m", quantity = "Torque") = 0.0 "Offset of torque";
    parameter Real 'torqueStep.startTime'(unit = "s", quantity = "Time") = 2.0 "Torque = offset for time < startTime";
    Real 'torqueStep.tau'(unit = "N.m", quantity = "Torque") "Accelerating torque acting at flange (= -flange.tau)";
  initial equation
    'smee.is[1]' = 0.0;
    'smee.is[2]' = 0.0;
    'smee.ie' = 0.0;
  equation
    'smee.phiMechanical' = 'smee.flange.phi' - 'smee.internalSupport.phi';
    'smee.wMechanical' = der('smee.phiMechanical');
    'smee.tauElectrical' = 'smee.inertiaRotor.flange_a.tau';
    'smee.tauShaft' = -'smee.flange.tau';
    'smee.powerBalance.powerStator' = sum('smee.vs' * 'smee.is');
    'smee.powerBalance.powerMechanical' = 'smee.wMechanical' * 'smee.tauShaft';
    'smee.powerBalance.powerInertiaStator' = 0.29 * 'smee.inertiaStator.a' * 'smee.inertiaStator.w';
    'smee.powerBalance.powerInertiaRotor' = 0.29 * 'smee.inertiaRotor.a' * 'smee.inertiaRotor.w';
    'smee.powerBalance.lossPowerTotal' = 'smee.powerBalance.lossPowerStatorWinding' + 'smee.powerBalance.lossPowerStatorCore' + 'smee.powerBalance.lossPowerRotorCore' + 'smee.powerBalance.lossPowerStrayLoad' + 'smee.powerBalance.lossPowerFriction' + 'smee.powerBalance.lossPowerRotorWinding' + 'smee.powerBalance.lossPowerExcitation' + 'smee.powerBalance.lossPowerBrush';
    'smee.powerBalance.lossPowerStatorWinding' = 'smee.stator.resistor.resistor[1].LossPower' + 'smee.stator.resistor.resistor[2].LossPower' + 'smee.stator.resistor.resistor[3].LossPower';
    'smee.powerBalance.lossPowerStatorCore' = 'smee.stator.core.lossPower';
    'smee.powerBalance.lossPowerRotorCore' = 0.0;
    'smee.powerBalance.lossPowerStrayLoad' = 'smee.strayLoad.lossPower';
    'smee.powerBalance.lossPowerFriction' = 'smee.friction.lossPower';
    'smee.powerBalance.lossPowerRotorWinding' = 'smee.damperCageLossPower';
    'smee.powerBalance.powerExcitation' = 'smee.ve' * 'smee.ie';
    'smee.powerBalance.lossPowerExcitation' = 'smee.excitation.resistor.LossPower';
    'smee.powerBalance.lossPowerBrush' = 'smee.brush.lossPower';
    'smee.stator.abs_V_m' = sqrt('smee.stator.V_m.re' ^ 2.0 + 'smee.stator.V_m.im' ^ 2.0);
    'smee.stator.arg_V_m' = 'Modelica.Math.atan3'('smee.stator.V_m.im', 'smee.stator.V_m.re', 0.0);
    'smee.stator.Phi.re' = 'smee.stator.port_p.Phi.re';
    'smee.stator.Phi.im' = 'smee.stator.port_p.Phi.im';
    'smee.stator.abs_Phi' = sqrt('smee.stator.Phi.re' ^ 2.0 + 'smee.stator.Phi.im' ^ 2.0);
    'smee.stator.arg_Phi' = 'Modelica.Math.atan3'('smee.stator.Phi.im', 'smee.stator.Phi.re', 0.0);
    'smee.stator.electroMagneticConverter.abs_V_m' = sqrt('smee.stator.electroMagneticConverter.V_m.re' ^ 2.0 + 'smee.stator.electroMagneticConverter.V_m.im' ^ 2.0);
    'smee.stator.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('smee.stator.electroMagneticConverter.V_m.im', 'smee.stator.electroMagneticConverter.V_m.re', 0.0);
    'smee.stator.electroMagneticConverter.Phi.re' = 'smee.stator.electroMagneticConverter.port_p.Phi.re';
    'smee.stator.electroMagneticConverter.Phi.im' = 'smee.stator.electroMagneticConverter.port_p.Phi.im';
    'smee.stator.electroMagneticConverter.abs_Phi' = sqrt('smee.stator.electroMagneticConverter.Phi.re' ^ 2.0 + 'smee.stator.electroMagneticConverter.Phi.im' ^ 2.0);
    'smee.stator.electroMagneticConverter.arg_Phi' = 'Modelica.Math.atan3'('smee.stator.electroMagneticConverter.Phi.im', 'smee.stator.electroMagneticConverter.Phi.re', 0.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_V_m' = sqrt('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.re' ^ 2.0 + 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.im' ^ 2.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].arg_V_m' = 'Modelica.Math.atan3'('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.im', 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.re', 0.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_Phi' = sqrt('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.re' ^ 2.0 + 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.im' ^ 2.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].arg_Phi' = 'Modelica.Math.atan3'('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.im', 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.re', 0.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_V_m' = sqrt('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.re' ^ 2.0 + 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.im' ^ 2.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_V_m' = 'Modelica.Math.atan3'('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.im', 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.re', 0.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_Phi' = sqrt('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.re' ^ 2.0 + 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.im' ^ 2.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_Phi' = 'Modelica.Math.atan3'('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.im', 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.re', 0.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].abs_V_m' = sqrt('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.re' ^ 2.0 + 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.im' ^ 2.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].arg_V_m' = 'Modelica.Math.atan3'('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.im', 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.re', 0.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].abs_Phi' = sqrt('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.re' ^ 2.0 + 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.im' ^ 2.0);
    'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].arg_Phi' = 'Modelica.Math.atan3'('smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.im', 'smee.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.re', 0.0);
    'smee.stator.resistor.resistor[1].heatPort.T' = 'smee.stator.resistor.resistor[1].T_heatPort';
    'smee.stator.resistor.resistor[1].heatPort.Q_flow' = -'smee.stator.resistor.resistor[1].LossPower';
    'smee.stator.resistor.resistor[2].heatPort.T' = 'smee.stator.resistor.resistor[2].T_heatPort';
    'smee.stator.resistor.resistor[2].heatPort.Q_flow' = -'smee.stator.resistor.resistor[2].LossPower';
    'smee.stator.resistor.resistor[3].heatPort.T' = 'smee.stator.resistor.resistor[3].T_heatPort';
    'smee.stator.resistor.resistor[3].heatPort.Q_flow' = -'smee.stator.resistor.resistor[3].LossPower';
    'smee.stator.core.abs_V_m' = sqrt('smee.stator.core.V_m.re' ^ 2.0 + 'smee.stator.core.V_m.im' ^ 2.0);
    'smee.stator.core.arg_V_m' = 'Modelica.Math.atan3'('smee.stator.core.V_m.im', 'smee.stator.core.V_m.re', 0.0);
    'smee.stator.core.Phi.re' = 'smee.stator.core.port_p.Phi.re';
    'smee.stator.core.Phi.im' = 'smee.stator.core.port_p.Phi.im';
    'smee.stator.core.abs_Phi' = sqrt('smee.stator.core.Phi.re' ^ 2.0 + 'smee.stator.core.Phi.im' ^ 2.0);
    'smee.stator.core.arg_Phi' = 'Modelica.Math.atan3'('smee.stator.core.Phi.im', 'smee.stator.core.Phi.re', 0.0);
    'smee.stator.core.heatPort.T' = 'smee.stator.core.TheatPort';
    'smee.stator.core.heatPort.Q_flow' = -'smee.stator.core.lossPower';
    'smee.stator.stray.abs_V_m' = sqrt('smee.stator.stray.V_m.re' ^ 2.0 + 'smee.stator.stray.V_m.im' ^ 2.0);
