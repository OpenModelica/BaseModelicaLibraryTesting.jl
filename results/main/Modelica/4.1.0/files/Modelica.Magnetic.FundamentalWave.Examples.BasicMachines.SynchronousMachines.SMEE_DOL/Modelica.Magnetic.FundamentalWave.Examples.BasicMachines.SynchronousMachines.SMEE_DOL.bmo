    parameter Real 'switch.Goff[3]'(start = 1e-5, min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Opened switch conductance";
    parameter Integer 'switch.mh'(min = 1) = 3 "Number of heatPorts=number of phases";
