    Real 'switch.idealClosingSwitch[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'switch.idealClosingSwitch[3].Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Closed switch resistance";
    parameter Real 'switch.idealClosingSwitch[3].Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Opened switch conductance";
    parameter Boolean 'switch.idealClosingSwitch[3].useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'switch.idealClosingSwitch[3].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'switch.idealClosingSwitch[3].LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
