    Real 'switch.idealClosingSwitch[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'switch.idealClosingSwitch[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'switch.idealClosingSwitch[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
