    parameter Real 'switch.idealClosingSwitch[2].Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Closed switch resistance";
    parameter Real 'switch.idealClosingSwitch[2].Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Opened switch conductance";
    parameter Boolean 'switch.idealClosingSwitch[2].useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
