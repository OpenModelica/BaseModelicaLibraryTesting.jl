//! base 0.1.0
package 'PlanarFourbar'
  function 'Modelica.Mechanics.MultiBody.Frames.axesRotationsAngles' "Return the 3 angles to rotate in sequence around 3 axes to construct the given orientation object"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Integer[3] 'sequence'(max = {3, 3, 3}, min = {1, 1, 1}) = {1, 2, 3};
    input Real 'guessAngle1'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real[3] 'angles'(displayUnit = {"deg", "deg", "deg"}, unit = {"rad", "rad", "rad"}, quantity = {"Angle", "Angle", "Angle"});
    Real[3] 'e1_1'(each unit = "1");
    Real[3] 'e2_1a'(each unit = "1");
    Real[3] 'e3_1'(each unit = "1");
    Real[3] 'e3_2'(each unit = "1");
    Real 'A';
    Real 'B';
    Real 'angle_1a'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'angle_1b'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real[3, 3] 'T_1a';
  algorithm
    assert('sequence'[1] <> 'sequence'[2] and 'sequence'[2] <> 'sequence'[3], "input argument 'sequence[1:3]' is not valid", AssertionLevel.error);
    'e1_1' := if 'sequence'[1] == 1 then {1.0, 0.0, 0.0} else if 'sequence'[1] == 2 then {0.0, 1.0, 0.0} else {0.0, 0.0, 1.0};
    'e2_1a' := if 'sequence'[2] == 1 then {1.0, 0.0, 0.0} else if 'sequence'[2] == 2 then {0.0, 1.0, 0.0} else {0.0, 0.0, 1.0};
    'e3_1' := 'R'.'T'['sequence'[3],:];
    'e3_2' := if 'sequence'[3] == 1 then {1.0, 0.0, 0.0} else if 'sequence'[3] == 2 then {0.0, 1.0, 0.0} else {0.0, 0.0, 1.0};
    'A' := 'e2_1a'[1] * 'e3_1'[1] + 'e2_1a'[2] * 'e3_1'[2] + 'e2_1a'[3] * 'e3_1'[3];
    'B' := ('e1_1'[2] * 'e2_1a'[3] - 'e1_1'[3] * 'e2_1a'[2]) * 'e3_1'[1] + ('e1_1'[3] * 'e2_1a'[1] - 'e1_1'[1] * 'e2_1a'[3]) * 'e3_1'[2] + ('e1_1'[1] * 'e2_1a'[2] - 'e1_1'[2] * 'e2_1a'[1]) * 'e3_1'[3];

    if abs('A') <= 1e-12 and abs('B') <= 1e-12 then
      'angles'[1] := 'guessAngle1';
    else
      'angle_1a' := 'Modelica.Math.atan2'('A', -'B');
      'angle_1b' := 'Modelica.Math.atan2'(-'A', 'B');
      'angles'[1] := if abs('angle_1a' - 'guessAngle1') <= abs('angle_1b' - 'guessAngle1') then 'angle_1a' else 'angle_1b';
    end if;

    'T_1a' := 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.planarRotation'('e1_1', 'angles'[1]);
    'angles'[2] := 'Modelica.Mechanics.MultiBody.Frames.planarRotationAngle'('e2_1a', 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.resolve2'('T_1a', 'e3_1'), 'e3_2');
    'angles'[3] := 'Modelica.Mechanics.MultiBody.Frames.planarRotationAngle'('e3_2', 'e2_1a', 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.resolve2'('R'.'T', 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.resolve1'('T_1a', 'e2_1a')));
  end 'Modelica.Mechanics.MultiBody.Frames.axesRotationsAngles';

  function 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy' "Return orientation object from n_x and n_y vectors"
    input Real[3] 'n_x';
    input Real[3] 'n_y';
    output Real[3, 3] 'T';
    Real[3] 'e_x'(each unit = "1") = if 'Modelica.Math.Vectors.length'('n_x') < 1e-10 then {1.0, 0.0, 0.0} else 'Modelica.Math.Vectors.normalize'('n_x', 2.220446049250313e-14);
    Real[3] 'e_y'(each unit = "1") = if 'Modelica.Math.Vectors.length'('n_y') < 1e-10 then {0.0, 1.0, 0.0} else 'Modelica.Math.Vectors.normalize'('n_y', 2.220446049250313e-14);
    Real[3] 'n_z_aux'(each unit = "1") = {'e_x'[2] * 'e_y'[3] - 'e_x'[3] * 'e_y'[2], 'e_x'[3] * 'e_y'[1] - 'e_x'[1] * 'e_y'[3], 'e_x'[1] * 'e_y'[2] - 'e_x'[2] * 'e_y'[1]};
    Real[3] 'n_y_aux'(each unit = "1") = if 'n_z_aux'[1] * 'n_z_aux'[1] + 'n_z_aux'[2] * 'n_z_aux'[2] + 'n_z_aux'[3] * 'n_z_aux'[3] > 1e-6 then 'e_y' else if abs('e_x'[1]) > 1e-6 then {0.0, 1.0, 0.0} else {1.0, 0.0, 0.0};
    Real[3] 'e_z_aux'(each unit = "1") = {'e_x'[2] * 'n_y_aux'[3] - 'e_x'[3] * 'n_y_aux'[2], 'e_x'[3] * 'n_y_aux'[1] - 'e_x'[1] * 'n_y_aux'[3], 'e_x'[1] * 'n_y_aux'[2] - 'e_x'[2] * 'n_y_aux'[1]};
    Real[3] 'e_z'(each unit = "1") = 'Modelica.Math.Vectors.normalize'('e_z_aux', 2.220446049250313e-14);
  algorithm
    'T' := {'e_x', {'e_z'[2] * 'e_x'[3] - 'e_z'[3] * 'e_x'[2], 'e_z'[3] * 'e_x'[1] - 'e_z'[1] * 'e_x'[3], 'e_z'[1] * 'e_x'[2] - 'e_z'[2] * 'e_x'[1]}, 'e_z'};
  end 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy';

  type 'Modelica.Mechanics.MultiBody.Types.GravityTypes' = enumeration('NoGravity', 'UniformGravity', 'PointGravity');

  type 'Modelica.Mechanics.MultiBody.Types.ResolveInFrameAB' = enumeration('world', 'frame_a', 'frame_b', 'frame_resolve');

  record 'Modelica.Mechanics.MultiBody.Frames.Orientation'
    Real[3, 3] 'T';
    Real[3] 'w'(unit = fill("rad/s", 3), quantity = fill("AngularVelocity", 3));
  end 'Modelica.Mechanics.MultiBody.Frames.Orientation';

  model 'PlanarFourbar' "Planar four bars mechanism with one kinematic loop (with RevolutePlanarLoopConstraint joint)"
    Real 'revolute1.axis.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'revolute1.axis.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'revolute1.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'revolute1.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'revolute1.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute1.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute1.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute1.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute1.frame_a.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute1.frame_a.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute1.frame_a.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'revolute1.frame_a.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'revolute1.frame_a.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'revolute1.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute1.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute1.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute1.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.frame_b.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.frame_b.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.frame_b.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.frame_b.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute1.frame_b.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute1.frame_b.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute1.frame_b.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'revolute1.frame_b.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'revolute1.frame_b.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    parameter Boolean 'revolute1.useAxisFlange' = true "= true, if axis flange is enabled" annotation(Evaluate = true);
    parameter Boolean 'revolute1.animation' = true "= true, if animation shall be enabled (show axis as cylinder)";
    parameter Real 'revolute1.n[1]'(unit = "1") = 0.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'revolute1.n[2]'(unit = "1") = 0.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'revolute1.n[3]'(unit = "1") = 1.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'revolute1.cylinderLength'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Length of cylinder representing the joint axis";
    parameter Real 'revolute1.cylinderDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.05 "Diameter of cylinder representing the joint axis";
    Integer 'revolute1.cylinderColor[1]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Integer 'revolute1.cylinderColor[2]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Integer 'revolute1.cylinderColor[3]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Real 'revolute1.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter StateSelect 'revolute1.stateSelect' = StateSelect.always "Priority to use joint angle phi and w=der(phi) as states";
    Real 'revolute1.phi'(stateSelect = StateSelect.always, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle from frame_a to frame_b";
    Real 'revolute1.w'(stateSelect = StateSelect.always, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "First derivative of angle phi (relative angular velocity)";
    Real 'revolute1.a'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Second derivative of angle phi (relative angular acceleration)";
    Real 'revolute1.tau'(unit = "N.m", quantity = "Torque") "Driving torque in direction of axis of rotation";
    Real 'revolute1.angle'(displayUnit = "deg", unit = "rad", quantity = "Angle") "= phi";
    parameter Real 'revolute1.e[1]'(unit = "1") = 0.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    parameter Real 'revolute1.e[2]'(unit = "1") = 0.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    parameter Real 'revolute1.e[3]'(unit = "1") = 1.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    Real 'revolute1.R_rel.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.R_rel.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.R_rel.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.R_rel.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    parameter String 'revolute1.cylinder.shapeType' = "cylinder" "Type of shape (box, sphere, cylinder, pipecylinder, cone, pipe, beam, gearwheel, spring, <external shape>)";
    Real 'revolute1.cylinder.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute1.cylinder.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.cylinder.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.cylinder.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute1.cylinder.r[1]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'revolute1.cylinder.r[2]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'revolute1.cylinder.r[3]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'revolute1.cylinder.r_shape[1]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'revolute1.cylinder.r_shape[2]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'revolute1.cylinder.r_shape[3]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'revolute1.cylinder.lengthDirection[1]' "Vector in length direction, resolved in object frame";
    Real 'revolute1.cylinder.lengthDirection[2]' "Vector in length direction, resolved in object frame";
    Real 'revolute1.cylinder.lengthDirection[3]' "Vector in length direction, resolved in object frame";
    Real 'revolute1.cylinder.widthDirection[1]' "Vector in width direction, resolved in object frame";
    Real 'revolute1.cylinder.widthDirection[2]' "Vector in width direction, resolved in object frame";
    Real 'revolute1.cylinder.widthDirection[3]' "Vector in width direction, resolved in object frame";
    Real 'revolute1.cylinder.length'(unit = "m", quantity = "Length") "Length of visual object";
    Real 'revolute1.cylinder.width'(unit = "m", quantity = "Length") "Width of visual object";
    Real 'revolute1.cylinder.height'(unit = "m", quantity = "Length") "Height of visual object";
    Real 'revolute1.cylinder.extra' "Additional size data for some of the shape types";
    Real 'revolute1.cylinder.color[1]' "Color of shape";
    Real 'revolute1.cylinder.color[2]' "Color of shape";
    Real 'revolute1.cylinder.color[3]' "Color of shape";
    Real 'revolute1.cylinder.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter Real 'revolute1.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'revolute1.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'revolute1.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'revolute1.internalAxis.tau'(unit = "N.m", quantity = "Torque") "External support torque (must be computed via torque balance in model where InternalSupport is used; = flange.tau)";
    Real 'revolute1.internalAxis.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "External support angle (= flange.phi)";
    Real 'revolute1.internalAxis.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'revolute1.internalAxis.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'revolute2.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute2.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute2.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute2.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute2.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute2.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'revolute2.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute2.frame_a.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute2.frame_a.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'revolute2.frame_a.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'revolute2.frame_a.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'revolute2.frame_a.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'revolute2.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute2.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute2.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'revolute2.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_b.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_b.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_b.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_b.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'revolute2.frame_b.R.T[3,1]' "Transformation matrix from world frame to local frame";
