//! base 0.1.0
package 'Oscillator'
  model 'Oscillator' "Oscillator demonstrates the use of initial conditions"
    parameter Real 'mass1.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass of the sliding mass";
    parameter StateSelect 'mass1.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'mass1.s'(stateSelect = StateSelect.default, fixed = true, start = -0.5, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'mass1.L'(start = 0.0, unit = "m", quantity = "Length") = 1.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'mass1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass1.v'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass1.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    Real 'spring1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'spring1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'spring1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'spring1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'spring1.s_rel'(start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'spring1.f'(unit = "N", quantity = "Force") "Force between flanges (positive in direction of flange axis R)";
    parameter Real 'spring1.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e4 "Spring constant";
    parameter Real 'spring1.s_rel0'(min = 0.0, unit = "m", quantity = "Length") = 1.0 "Unstretched spring length";
    parameter Real 'fixed1.s0'(unit = "m", quantity = "Length") = 1.0 "Fixed offset position of housing";
    Real 'fixed1.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'fixed1.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Boolean 'force1.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'force1.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'force1.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'force1.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'force1.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'force1.f'(unit = "N") "Driving force as input signal";
    parameter Real 'sine1.amplitude' = 1.0 "Amplitude of sine wave";
    parameter Real 'sine1.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 15.9155 "Frequency of sine wave";
    parameter Real 'sine1.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine1.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine1.y' "Connector of Real output signal";
    parameter Real 'sine1.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine1.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'mass2.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass of the sliding mass";
    parameter StateSelect 'mass2.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'mass2.s'(stateSelect = StateSelect.default, fixed = true, start = -0.5, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'mass2.L'(start = 0.0, unit = "m", quantity = "Length") = 1.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'mass2.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass2.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass2.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass2.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass2.v'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass2.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    Real 'spring2.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'spring2.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'spring2.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'spring2.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'spring2.s_rel'(start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'spring2.f'(unit = "N", quantity = "Force") "Force between flanges (positive in direction of flange axis R)";
    parameter Real 'spring2.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e4 "Spring constant";
    parameter Real 'spring2.s_rel0'(min = 0.0, unit = "m", quantity = "Length") = 1.0 "Unstretched spring length";
    parameter Real 'fixed2.s0'(unit = "m", quantity = "Length") = 1.0 "Fixed offset position of housing";
    Real 'fixed2.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'fixed2.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Boolean 'force2.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'force2.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'force2.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'force2.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'force2.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'force2.f'(unit = "N") "Driving force as input signal";
    parameter Real 'sine2.amplitude' = 1.0 "Amplitude of sine wave";
    parameter Real 'sine2.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 15.9155 "Frequency of sine wave";
    parameter Real 'sine2.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine2.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine2.y' "Connector of Real output signal";
    parameter Real 'sine2.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine2.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter StateSelect 'damper1.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'damper1.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'damper1.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'damper1.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'damper1.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'damper1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'damper1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'damper1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'damper1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'damper1.d'(start = 0.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 10.0 "Damping constant";
    parameter Boolean 'damper1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'damper1.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
  equation
    'mass1.flange_b.s' = 'spring1.flange_a.s';
    'mass2.flange_b.s' = 'spring2.flange_a.s';
    'mass2.flange_b.s' = 'damper1.flange_a.s';
    'spring2.flange_b.s' = 'fixed2.flange.s';
    'spring2.flange_b.s' = 'damper1.flange_b.s';
    'sine1.y' = 'force1.f';
    'sine2.y' = 'force2.f';
    'spring1.flange_b.s' = 'fixed1.flange.s';
    'force2.flange.s' = 'mass2.flange_a.s';
    'force1.flange.s' = 'mass1.flange_a.s';
    'spring1.flange_a.f' + 'mass1.flange_b.f' = 0.0;
    'fixed1.flange.f' + 'spring1.flange_b.f' = 0.0;
    'force1.flange.f' + 'mass1.flange_a.f' = 0.0;
    'force2.flange.f' + 'mass2.flange_a.f' = 0.0;
    'damper1.flange_a.f' + 'spring2.flange_a.f' + 'mass2.flange_b.f' = 0.0;
    'damper1.flange_b.f' + 'fixed2.flange.f' + 'spring2.flange_b.f' = 0.0;
    'mass1.v' = der('mass1.s');
    'mass1.a' = der('mass1.v');
    'mass1.a' = 'mass1.flange_a.f' + 'mass1.flange_b.f';
    'mass1.flange_a.s' = 'mass1.s' - 0.5;
    'mass1.flange_b.s' = 'mass1.s' + 0.5;
    'spring1.f' = 1e4 * ('spring1.s_rel' - 1.0);
    'spring1.s_rel' = 'spring1.flange_b.s' - 'spring1.flange_a.s';
    'spring1.flange_b.f' = 'spring1.f';
    'spring1.flange_a.f' = -'spring1.f';
    'fixed1.flange.s' = 1.0;
    'force1.flange.f' = -'force1.f';
    'force1.s' = 'force1.flange.s' - 'force1.s_support';
    'force1.s_support' = 0.0;
    'sine1.y' = if time < 0.0 then 0.0 else 'Modelica.Math.sin'(100.00003575641671 * time);
    'mass2.v' = der('mass2.s');
    'mass2.a' = der('mass2.v');
    'mass2.a' = 'mass2.flange_a.f' + 'mass2.flange_b.f';
    'mass2.flange_a.s' = 'mass2.s' - 0.5;
    'mass2.flange_b.s' = 'mass2.s' + 0.5;
    'spring2.f' = 1e4 * ('spring2.s_rel' - 1.0);
    'spring2.s_rel' = 'spring2.flange_b.s' - 'spring2.flange_a.s';
    'spring2.flange_b.f' = 'spring2.f';
    'spring2.flange_a.f' = -'spring2.f';
    'fixed2.flange.s' = 1.0;
    'force2.flange.f' = -'force2.f';
    'force2.s' = 'force2.flange.s' - 'force2.s_support';
    'force2.s_support' = 0.0;
    'sine2.y' = if time < 0.0 then 0.0 else 'Modelica.Math.sin'(100.00003575641671 * time);
    'damper1.f' = 10.0 * 'damper1.v_rel';
    'damper1.lossPower' = 'damper1.f' * 'damper1.v_rel';
    'damper1.s_rel' = 'damper1.flange_b.s' - 'damper1.flange_a.s';
    'damper1.v_rel' = der('damper1.s_rel');
    'damper1.flange_b.f' = 'damper1.f';
    'damper1.flange_a.f' = -'damper1.f';
    annotation(experiment(StopTime = 1.0, Interval = 0.001));
  end 'Oscillator';
end 'Oscillator';
