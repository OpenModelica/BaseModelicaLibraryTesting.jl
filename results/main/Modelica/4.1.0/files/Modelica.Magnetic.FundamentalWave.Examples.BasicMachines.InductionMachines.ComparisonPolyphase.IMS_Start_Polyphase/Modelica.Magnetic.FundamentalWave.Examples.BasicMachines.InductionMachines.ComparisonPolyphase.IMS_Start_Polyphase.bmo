    Real 'aimsM.powerBalance.powerRotor'(unit = "W", quantity = "Power") "Electrical power (rotor)";
    Real 'aimsM.vs[1]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimsM.vs[2]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimsM.vs[3]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimsM.vs[4]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimsM.vs[5]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimsM.is[1]'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
