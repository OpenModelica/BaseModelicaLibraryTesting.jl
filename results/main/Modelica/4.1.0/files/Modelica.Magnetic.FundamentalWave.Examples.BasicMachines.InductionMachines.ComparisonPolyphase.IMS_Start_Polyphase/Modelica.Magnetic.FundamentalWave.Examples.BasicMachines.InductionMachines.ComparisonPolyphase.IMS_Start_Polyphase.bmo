    Real 'terminalBoxM.plugSupply.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plugSupply.pin[4].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
