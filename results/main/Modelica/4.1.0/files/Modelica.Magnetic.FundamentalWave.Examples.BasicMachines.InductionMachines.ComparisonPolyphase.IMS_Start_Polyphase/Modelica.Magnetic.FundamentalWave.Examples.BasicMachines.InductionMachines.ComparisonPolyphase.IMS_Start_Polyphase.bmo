    Real 'aimsM.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'aimsM.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'aimsM.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'aimsM.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
