    Real 'terminalBoxM.star.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.star.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'terminalBoxM.plugSupply.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBoxM.plugSupply.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plugSupply.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
