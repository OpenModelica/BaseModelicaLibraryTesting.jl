    Real 'aimsM.is[5]'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'aimsM.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimsM.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
