  initial equation
    'aims3.is[1]' = 0.0;
    'aims3.is[2]' = 0.0;
    'aims3.ir[1]' = 0.0;
    'aims3.ir[2]' = 0.0;
    'aims3.ir[3]' = 0.0;
    'aimsM.is[1]' = 0.0;
    'aimsM.is[2]' = 0.0;
    'aimsM.ir[1]' = 0.0;
    'aimsM.ir[2]' = 0.0;
    'aimsM.ir[3]' = 0.0;
  equation
    'aimsM.phiMechanical' = 'aimsM.flange.phi' - 'aimsM.internalSupport.phi';
    'aimsM.wMechanical' = der('aimsM.phiMechanical');
    'aimsM.tauElectrical' = 'aimsM.inertiaRotor.flange_a.tau';
    'aimsM.tauShaft' = -'aimsM.flange.tau';
    'aimsM.powerBalance.powerStator' = sum('aimsM.vs' * 'aimsM.is');
    'aimsM.powerBalance.powerMechanical' = 'aimsM.wMechanical' * 'aimsM.tauShaft';
    'aimsM.powerBalance.powerInertiaStator' = 0.29 * 'aimsM.inertiaStator.a' * 'aimsM.inertiaStator.w';
    'aimsM.powerBalance.powerInertiaRotor' = 0.29 * 'aimsM.inertiaRotor.a' * 'aimsM.inertiaRotor.w';
    'aimsM.powerBalance.lossPowerTotal' = 'aimsM.powerBalance.lossPowerStatorWinding' + 'aimsM.powerBalance.lossPowerStatorCore' + 'aimsM.powerBalance.lossPowerRotorCore' + 'aimsM.powerBalance.lossPowerStrayLoad' + 'aimsM.powerBalance.lossPowerFriction' + 'aimsM.powerBalance.lossPowerRotorWinding' + 'aimsM.powerBalance.lossPowerBrush';
    'aimsM.powerBalance.lossPowerStatorWinding' = 'aimsM.stator.resistor.resistor[1].LossPower' + 'aimsM.stator.resistor.resistor[2].LossPower' + 'aimsM.stator.resistor.resistor[3].LossPower' + 'aimsM.stator.resistor.resistor[4].LossPower' + 'aimsM.stator.resistor.resistor[5].LossPower';
    'aimsM.powerBalance.lossPowerStatorCore' = 'aimsM.stator.core.lossPower';
    'aimsM.powerBalance.lossPowerRotorCore' = 'aimsM.rotor.core.lossPower';
    'aimsM.powerBalance.lossPowerStrayLoad' = 'aimsM.strayLoad.lossPower';
    'aimsM.powerBalance.lossPowerFriction' = 'aimsM.friction.lossPower';
    'aimsM.powerBalance.lossPowerRotorWinding' = 'aimsM.rotor.resistor.resistor[1].LossPower' + 'aimsM.rotor.resistor.resistor[2].LossPower' + 'aimsM.rotor.resistor.resistor[3].LossPower' + 'aimsM.rotor.resistor.resistor[4].LossPower' + 'aimsM.rotor.resistor.resistor[5].LossPower';
    'aimsM.powerBalance.lossPowerBrush' = 0.0;
    'aimsM.powerBalance.powerRotor' = sum('aimsM.vr' * 'aimsM.ir');
    'aimsM.stator.abs_V_m' = sqrt('aimsM.stator.V_m.re' ^ 2.0 + 'aimsM.stator.V_m.im' ^ 2.0);
    'aimsM.stator.arg_V_m' = 'Modelica.Math.atan3'('aimsM.stator.V_m.im', 'aimsM.stator.V_m.re', 0.0);
    'aimsM.stator.Phi.re' = 'aimsM.stator.port_p.Phi.re';
    'aimsM.stator.Phi.im' = 'aimsM.stator.port_p.Phi.im';
    'aimsM.stator.abs_Phi' = sqrt('aimsM.stator.Phi.re' ^ 2.0 + 'aimsM.stator.Phi.im' ^ 2.0);
    'aimsM.stator.arg_Phi' = 'Modelica.Math.atan3'('aimsM.stator.Phi.im', 'aimsM.stator.Phi.re', 0.0);
    'aimsM.stator.electroMagneticConverter.abs_V_m' = sqrt('aimsM.stator.electroMagneticConverter.V_m.re' ^ 2.0 + 'aimsM.stator.electroMagneticConverter.V_m.im' ^ 2.0);
    'aimsM.stator.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('aimsM.stator.electroMagneticConverter.V_m.im', 'aimsM.stator.electroMagneticConverter.V_m.re', 0.0);
    'aimsM.stator.electroMagneticConverter.Phi.re' = 'aimsM.stator.electroMagneticConverter.port_p.Phi.re';
    'aimsM.stator.electroMagneticConverter.Phi.im' = 'aimsM.stator.electroMagneticConverter.port_p.Phi.im';
    'aimsM.stator.electroMagneticConverter.abs_Phi' = sqrt('aimsM.stator.electroMagneticConverter.Phi.re' ^ 2.0 + 'aimsM.stator.electroMagneticConverter.Phi.im' ^ 2.0);
    'aimsM.stator.electroMagneticConverter.arg_Phi' = 'Modelica.Math.atan3'('aimsM.stator.electroMagneticConverter.Phi.im', 'aimsM.stator.electroMagneticConverter.Phi.re', 0.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_V_m' = sqrt('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.re' ^ 2.0 + 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.im' ^ 2.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].arg_V_m' = 'Modelica.Math.atan3'('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.im', 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.re', 0.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_Phi' = sqrt('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.re' ^ 2.0 + 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.im' ^ 2.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].arg_Phi' = 'Modelica.Math.atan3'('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.im', 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.re', 0.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_V_m' = sqrt('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.re' ^ 2.0 + 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.im' ^ 2.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_V_m' = 'Modelica.Math.atan3'('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.im', 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.re', 0.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_Phi' = sqrt('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.re' ^ 2.0 + 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.im' ^ 2.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_Phi' = 'Modelica.Math.atan3'('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.im', 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.re', 0.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].abs_V_m' = sqrt('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.re' ^ 2.0 + 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.im' ^ 2.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].arg_V_m' = 'Modelica.Math.atan3'('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.im', 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.re', 0.0);
    'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].abs_Phi' = sqrt('aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.re' ^ 2.0 + 'aimsM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.im' ^ 2.0);
