    parameter Integer 'terminalBox3.star.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'terminalBox3.star.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBox3.star.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox3.star.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox3.star.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox3.star.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox3.star.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox3.star.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox3.star.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox3.star.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'terminalBox3.plugSupply.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBox3.plugSupply.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox3.plugSupply.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox3.plugSupply.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox3.plugSupply.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox3.plugSupply.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox3.plugSupply.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox3.starpoint.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox3.starpoint.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'aimsM.mr'(min = 3) = 5 "Number of rotor phases" annotation(Evaluate = true);
    constant Real 'aimsM.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    parameter Integer 'aimsM.m'(min = 3) = 5 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'aimsM.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor inertia";
    parameter Boolean 'aimsM.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'aimsM.Js'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator inertia";
    parameter Boolean 'aimsM.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Integer 'aimsM.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'aimsM.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'aimsM.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
    parameter Real 'aimsM.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.049999999999999996 "Stator resistance per phase at TRef";
    parameter Real 'aimsM.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'aimsM.alpha20s'(start = 0.0, displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'aimsM.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'aimsM.Lssigma'(start = 3.239643625499069e-4, unit = "H", quantity = "Inductance") = 5.399406042498449e-4 "Stator stray inductance";
    parameter Real 'aimsM.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'aimsM.Lszero'(unit = "H", quantity = "Inductance") = 5.399406042498449e-4 "Stator zero inductance";
    parameter Real 'aimsM.L0.d'(start = 1.0, unit = "H", quantity = "Inductance") = 0.006150221481975876 "Component of d (direct) axis, aligned to real part";
    parameter Real 'aimsM.L0.q'(start = 1.0, unit = "H", quantity = "Inductance") = 0.006150221481975876 "Component of q (quadrature) axis, aligned to imaginary part";
    parameter Real 'aimsM.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'aimsM.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'aimsM.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'aimsM.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'aimsM.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'aimsM.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'aimsM.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'aimsM.statorCoreParameters.m' = 5 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'aimsM.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'aimsM.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'aimsM.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'aimsM.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'aimsM.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'aimsM.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'aimsM.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'aimsM.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'aimsM.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'aimsM.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'aimsM.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    Real 'aimsM.phiMechanical'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Mechanical angle of rotor against stator";
    Real 'aimsM.wMechanical'(fixed = true, start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") "Mechanical angular velocity of rotor against stator";
    Real 'aimsM.tauElectrical'(unit = "N.m", quantity = "Torque") "Electromagnetic torque";
    Real 'aimsM.tauShaft'(unit = "N.m", quantity = "Torque") "Shaft torque";
    Real 'aimsM.powerBalance.powerStator'(unit = "W", quantity = "Power") "Electrical power (stator)";
    Real 'aimsM.powerBalance.powerMechanical'(unit = "W", quantity = "Power") "Mechanical power";
