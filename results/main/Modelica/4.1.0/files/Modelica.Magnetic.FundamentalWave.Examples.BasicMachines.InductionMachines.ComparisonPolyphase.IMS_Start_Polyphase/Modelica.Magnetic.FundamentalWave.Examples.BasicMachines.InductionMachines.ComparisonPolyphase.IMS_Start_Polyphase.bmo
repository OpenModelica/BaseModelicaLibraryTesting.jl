//! base 0.1.0
package 'IMS_Start_Polyphase'
  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  model 'IMS_Start_Polyphase' "Starting of polyphase induction machine with slip rings"
    constant Integer 'm3' = 3 "Number of stator phases of three-phase system";
    parameter Integer 'm' = 5 "Number of stator phases" annotation(Evaluate = true);
    parameter Integer 'mr' = 5 "Number of rotor phases" annotation(Evaluate = true);
    parameter Real 'VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'tOn'(unit = "s", quantity = "Time") = 0.1 "Start time of machine";
    parameter Real 'RStart'(unit = "Ohm", quantity = "Resistance") = 0.16000000000000003 "Starting resistance";
    parameter Real 'tRheostat'(unit = "s", quantity = "Time") = 1.0 "Time of shortening the rheostat";
    parameter Real 'T_Load'(unit = "N.m", quantity = "Torque") = 161.4 "Nominal load torque";
    parameter Real 'w_Load'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal load speed";
    parameter Real 'J_Load'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load inertia";
    parameter Integer 'terminalBoxM.m' = 5 "Number of phases" annotation(Evaluate = true);
    parameter String 'terminalBoxM.terminalConnection'(start = "Y") = "Y" "Choose \"Y\" for star or \"D\" for delta connection";
    parameter Integer 'terminalBoxM.plug_sp.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBoxM.plug_sp.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sp.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plug_sp.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sp.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plug_sp.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sp.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plug_sp.pin[4].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sp.pin[4].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plug_sp.pin[5].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sp.pin[5].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'terminalBoxM.plug_sn.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBoxM.plug_sn.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sn.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plug_sn.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sn.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plug_sn.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sn.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plug_sn.pin[4].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sn.pin[4].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBoxM.plug_sn.pin[5].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.plug_sn.pin[5].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'terminalBoxM.star.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'terminalBoxM.star.plug_p.m'(min = 1) = 5 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBoxM.star.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBoxM.star.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
