    parameter Real 'aimcData.Rs'(unit = "Ohm", quantity = "Resistance") = 0.56 "Stator resistance per phase at TRef";
    parameter Real 'aimcData.TsRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'aimcData.alpha20s'(displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.00392 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'aimcData.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'aimcData.Lszero'(unit = "H", quantity = "Inductance") = 0.004838310269993618 "Stator zero sequence inductance";
    parameter Real 'aimcData.Lssigma'(unit = "H", quantity = "Inductance") = 0.004838310269993618 "Stator stray inductance per phase";
    parameter Real 'aimcData.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'aimcData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 180.0 "Reference friction losses at wRef";
    parameter Real 'aimcData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 153.1526418625024 "Reference angular velocity that the PRef refer to";
    parameter Real 'aimcData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'aimcData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 1.1752980412939964 "Reference friction torque at reference angular velocity";
    parameter Real 'aimcData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'aimcData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.1531526418625024 "Linear angular velocity range";
    parameter Real 'aimcData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 1.1752980412939964e-6 "Torque corresponding with linear angular velocity range";
    parameter Integer 'aimcData.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'aimcData.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 410.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'aimcData.statorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 387.9 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'aimcData.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'aimcData.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'aimcData.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 9.082868838743923e-4 "Reference conductance at reference frequency and voltage";
    parameter Real 'aimcData.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'aimcData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 102.18857277543316 "Reference stray load losses at IRef and wRef";
    parameter Real 'aimcData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 18.96595634287921 "Reference RMS current that PRef refers to";
    parameter Real 'aimcData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 153.1526418625024 "Reference angular velocity that PRef refers to";
    parameter Real 'aimcData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'aimcData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.6672334968088645 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'aimcData.Lm'(unit = "H", quantity = "Inductance") = 0.21135776442603701 "Stator main field inductance per phase";
    parameter Real 'aimcData.Lrsigma'(unit = "H", quantity = "Inductance") = 0.007352958370845565 "Rotor stray inductance per phase (equivalent three-phase winding)";
    parameter Real 'aimcData.Rr'(unit = "Ohm", quantity = "Resistance") = 0.42 "Rotor resistance per phase (equivalent three-phase winding) at TRef";
    parameter Real 'aimcData.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of rotor resistance";
    parameter Real 'aimcData.alpha20r'(displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.004 "Temperature coefficient of rotor resistance at 20 degC";
  initial equation
    'PI.x' = 0.0;
    'aimc.is[1]' + 'aimc.is[2]' + 'aimc.is[3]' = 0.0;
    der('aimc.airGap.V_msr.re') = 0.0;
    der('aimc.airGap.V_msr.im') = 0.0;
    der('aimc.airGap.V_mrr.re') = 0.0;
    der('aimc.airGap.V_mrr.im') = 0.0;
  equation
    'Pel' = 'electricalPowerSensor.P';
    'Qel' = 'electricalPowerSensor.Q';
    'Sel' = sqrt('Pel' ^ 2.0 + 'Qel' ^ 2.0);
    'Pmech' = 'powerSensor.power';
    'Ps_sim' = 692.8203230275509 * 'I_sim' * 'pf_sim';
    'Ps_meas' = 692.8203230275509 * 'I_meas' * 'pf_meas';
    'loss_sim' = 'Ps_sim' - 'Pmech';
    'loss_meas' = 'Ps_meas' - 'Pmech';
    'I_sim' = 'currentQuasiRMSSensor.I';
    'I_meas' = 'combiTable1Ds.y[1]';
    'w_sim' = 'aimc.wMechanical';
    'w_meas' = 'combiTable1Ds.y[2]';
    'pf_sim' = if noEvent('Sel' > 2.2250738585072014e-308) then 'Pel' / 'Sel' else 0.0;
    'pf_meas' = 'combiTable1Ds.y[3]';
    'eff_sim' = if noEvent(abs('Pel') > 2.2250738585072014e-308) then 'Pmech' / 'Pel' else 0.0;
    'eff_meas' = 'combiTable1Ds.y[4]';
    'aimc.phiMechanical' = 'aimc.flange.phi' - 'aimc.internalSupport.phi';
    'aimc.wMechanical' = der('aimc.phiMechanical');
    'aimc.tauElectrical' = 'aimc.inertiaRotor.flange_a.tau';
    'aimc.tauShaft' = -'aimc.flange.tau';
    'aimc.powerBalance.powerStator' = sum('aimc.vs' * 'aimc.is');
    'aimc.powerBalance.powerMechanical' = 'aimc.wMechanical' * 'aimc.tauShaft';
    'aimc.powerBalance.powerInertiaStator' = 0.12 * 'aimc.inertiaStator.a' * 'aimc.inertiaStator.w';
    'aimc.powerBalance.powerInertiaRotor' = 0.12 * 'aimc.inertiaRotor.a' * 'aimc.inertiaRotor.w';
    'aimc.powerBalance.lossPowerTotal' = 'aimc.powerBalance.lossPowerStatorWinding' + 'aimc.powerBalance.lossPowerStatorCore' + 'aimc.powerBalance.lossPowerRotorCore' + 'aimc.powerBalance.lossPowerStrayLoad' + 'aimc.powerBalance.lossPowerFriction' + 'aimc.powerBalance.lossPowerRotorWinding';
    'aimc.powerBalance.lossPowerStatorWinding' = 'aimc.stator.resistor.resistor[1].LossPower' + 'aimc.stator.resistor.resistor[2].LossPower' + 'aimc.stator.resistor.resistor[3].LossPower';
    'aimc.powerBalance.lossPowerStatorCore' = 'aimc.stator.core.lossPower';
    'aimc.powerBalance.lossPowerRotorCore' = 0.0;
    'aimc.powerBalance.lossPowerStrayLoad' = 'aimc.strayLoad.lossPower';
    'aimc.powerBalance.lossPowerFriction' = 'aimc.friction.lossPower';
    'aimc.powerBalance.lossPowerRotorWinding' = 'aimc.rotorCage.resistor.resistor[1].LossPower' + 'aimc.rotorCage.resistor.resistor[2].LossPower' + 'aimc.rotorCage.resistor.resistor[3].LossPower';
    'aimc.stator.abs_V_m' = sqrt('aimc.stator.V_m.re' ^ 2.0 + 'aimc.stator.V_m.im' ^ 2.0);
    'aimc.stator.arg_V_m' = 'Modelica.Math.atan3'('aimc.stator.V_m.im', 'aimc.stator.V_m.re', 0.0);
    'aimc.stator.Phi.re' = 'aimc.stator.port_p.Phi.re';
    'aimc.stator.Phi.im' = 'aimc.stator.port_p.Phi.im';
    'aimc.stator.abs_Phi' = sqrt('aimc.stator.Phi.re' ^ 2.0 + 'aimc.stator.Phi.im' ^ 2.0);
    'aimc.stator.arg_Phi' = 'Modelica.Math.atan3'('aimc.stator.Phi.im', 'aimc.stator.Phi.re', 0.0);
    'aimc.stator.electroMagneticConverter.abs_V_m' = sqrt('aimc.stator.electroMagneticConverter.V_m.re' ^ 2.0 + 'aimc.stator.electroMagneticConverter.V_m.im' ^ 2.0);
    'aimc.stator.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('aimc.stator.electroMagneticConverter.V_m.im', 'aimc.stator.electroMagneticConverter.V_m.re', 0.0);
    'aimc.stator.electroMagneticConverter.Phi.re' = 'aimc.stator.electroMagneticConverter.port_p.Phi.re';
    'aimc.stator.electroMagneticConverter.Phi.im' = 'aimc.stator.electroMagneticConverter.port_p.Phi.im';
    'aimc.stator.electroMagneticConverter.abs_Phi' = sqrt('aimc.stator.electroMagneticConverter.Phi.re' ^ 2.0 + 'aimc.stator.electroMagneticConverter.Phi.im' ^ 2.0);
    'aimc.stator.electroMagneticConverter.arg_Phi' = 'Modelica.Math.atan3'('aimc.stator.electroMagneticConverter.Phi.im', 'aimc.stator.electroMagneticConverter.Phi.re', 0.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_V_m' = sqrt('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.re' ^ 2.0 + 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.im' ^ 2.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].arg_V_m' = 'Modelica.Math.atan3'('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.im', 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.re', 0.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_Phi' = sqrt('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.re' ^ 2.0 + 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.im' ^ 2.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].arg_Phi' = 'Modelica.Math.atan3'('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.im', 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].Phi.re', 0.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_V_m' = sqrt('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.re' ^ 2.0 + 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.im' ^ 2.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_V_m' = 'Modelica.Math.atan3'('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.im', 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].V_m.re', 0.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_Phi' = sqrt('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.re' ^ 2.0 + 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.im' ^ 2.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_Phi' = 'Modelica.Math.atan3'('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.im', 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.re', 0.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].abs_V_m' = sqrt('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.re' ^ 2.0 + 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.im' ^ 2.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].arg_V_m' = 'Modelica.Math.atan3'('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.im', 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].V_m.re', 0.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].abs_Phi' = sqrt('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.re' ^ 2.0 + 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.im' ^ 2.0);
    'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].arg_Phi' = 'Modelica.Math.atan3'('aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.im', 'aimc.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[3].Phi.re', 0.0);
    'aimc.stator.resistor.resistor[1].heatPort.T' = 'aimc.stator.resistor.resistor[1].T_heatPort';
    'aimc.stator.resistor.resistor[1].heatPort.Q_flow' = -'aimc.stator.resistor.resistor[1].LossPower';
    'aimc.stator.resistor.resistor[2].heatPort.T' = 'aimc.stator.resistor.resistor[2].T_heatPort';
    'aimc.stator.resistor.resistor[2].heatPort.Q_flow' = -'aimc.stator.resistor.resistor[2].LossPower';
    'aimc.stator.resistor.resistor[3].heatPort.T' = 'aimc.stator.resistor.resistor[3].T_heatPort';
    'aimc.stator.resistor.resistor[3].heatPort.Q_flow' = -'aimc.stator.resistor.resistor[3].LossPower';
    'aimc.stator.core.abs_V_m' = sqrt('aimc.stator.core.V_m.re' ^ 2.0 + 'aimc.stator.core.V_m.im' ^ 2.0);
    'aimc.stator.core.arg_V_m' = 'Modelica.Math.atan3'('aimc.stator.core.V_m.im', 'aimc.stator.core.V_m.re', 0.0);
    'aimc.stator.core.Phi.re' = 'aimc.stator.core.port_p.Phi.re';
    'aimc.stator.core.Phi.im' = 'aimc.stator.core.port_p.Phi.im';
    'aimc.stator.core.abs_Phi' = sqrt('aimc.stator.core.Phi.re' ^ 2.0 + 'aimc.stator.core.Phi.im' ^ 2.0);
    'aimc.stator.core.arg_Phi' = 'Modelica.Math.atan3'('aimc.stator.core.Phi.im', 'aimc.stator.core.Phi.re', 0.0);
    'aimc.stator.core.heatPort.T' = 'aimc.stator.core.TheatPort';
    'aimc.stator.core.heatPort.Q_flow' = -'aimc.stator.core.lossPower';
    'aimc.stator.stray.abs_V_m' = sqrt('aimc.stator.stray.V_m.re' ^ 2.0 + 'aimc.stator.stray.V_m.im' ^ 2.0);
    'aimc.stator.stray.arg_V_m' = 'Modelica.Math.atan3'('aimc.stator.stray.V_m.im', 'aimc.stator.stray.V_m.re', 0.0);
    'aimc.stator.stray.Phi.re' = 'aimc.stator.stray.port_p.Phi.re';
    'aimc.stator.stray.Phi.im' = 'aimc.stator.stray.port_p.Phi.im';
    'aimc.stator.stray.abs_Phi' = sqrt('aimc.stator.stray.Phi.re' ^ 2.0 + 'aimc.stator.stray.Phi.im' ^ 2.0);
    'aimc.stator.stray.arg_Phi' = 'Modelica.Math.atan3'('aimc.stator.stray.Phi.im', 'aimc.stator.stray.Phi.re', 0.0);
    'aimc.thermalAmbient.Q_flowStatorWinding' = 'aimc.thermalAmbient.temperatureStatorWinding.port.Q_flow';
    'aimc.thermalAmbient.Q_flowStatorCore' = 'aimc.thermalAmbient.temperatureStatorCore.port.Q_flow';
    'aimc.thermalAmbient.Q_flowRotorCore' = 'aimc.thermalAmbient.temperatureRotorCore.port.Q_flow';
    'aimc.thermalAmbient.Q_flowStrayLoad' = 'aimc.thermalAmbient.temperatureStrayLoad.port.Q_flow';
    'aimc.thermalAmbient.Q_flowFriction' = 'aimc.thermalAmbient.temperatureFriction.port.Q_flow';
    'aimc.thermalAmbient.Q_flowRotorWinding' = 'aimc.thermalAmbient.temperatureRotorWinding.port.Q_flow';
    'aimc.thermalAmbient.Q_flowTotal' = 'aimc.thermalAmbient.Q_flowStatorWinding' + 'aimc.thermalAmbient.Q_flowRotorWinding' + 'aimc.thermalAmbient.Q_flowStatorCore' + 'aimc.thermalAmbient.Q_flowRotorCore' + 'aimc.thermalAmbient.Q_flowStrayLoad' + 'aimc.thermalAmbient.Q_flowFriction';
    'aimc.strayLoad.heatPort.Q_flow' = -'aimc.strayLoad.lossPower';
    'aimc.strayLoad.iRMS' = sqrt(sum('aimc.strayLoad.i' .^ 2.0 / size('aimc.strayLoad.i', 1)));
    'aimc.friction.heatPort.Q_flow' = -'aimc.friction.lossPower';
    'aimc.rotorCage.abs_V_m' = sqrt('aimc.rotorCage.V_m.re' ^ 2.0 + 'aimc.rotorCage.V_m.im' ^ 2.0);
