    'aimc.rotorCage.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('aimc.rotorCage.electroMagneticConverter.V_m.im', 'aimc.rotorCage.electroMagneticConverter.V_m.re', 0.0);
