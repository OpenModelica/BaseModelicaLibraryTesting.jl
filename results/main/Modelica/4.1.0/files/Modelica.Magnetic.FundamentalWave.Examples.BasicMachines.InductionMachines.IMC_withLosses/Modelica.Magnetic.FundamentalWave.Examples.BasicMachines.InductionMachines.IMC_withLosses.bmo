    output Real 'eff_sim' "Simulated efficiency";
    output Real 'eff_meas' "Measured efficiency";
    constant Real 'aimc.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    parameter Integer 'aimc.m'(min = 3) = 3 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'aimc.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Rotor inertia";
    parameter Boolean 'aimc.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'aimc.Js'(start = 0.12, unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Stator inertia";
    parameter Boolean 'aimc.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Integer 'aimc.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'aimc.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'aimc.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 363.15 "Operational temperature of stator resistance";
    parameter Real 'aimc.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.56 "Stator resistance per phase at TRef";
    parameter Real 'aimc.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'aimc.alpha20s'(start = 0.0, displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.00392 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'aimc.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'aimc.Lssigma'(start = 3.239643625499069e-4, unit = "H", quantity = "Inductance") = 0.004838310269993618 "Stator stray inductance";
    parameter Real 'aimc.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'aimc.Lszero'(unit = "H", quantity = "Inductance") = 0.004838310269993618 "Stator zero inductance";
    parameter Real 'aimc.L0.d'(start = 1.0, unit = "H", quantity = "Inductance") = 0.14090517628402469 "Component of d (direct) axis, aligned to real part";
    parameter Real 'aimc.L0.q'(start = 1.0, unit = "H", quantity = "Inductance") = 0.14090517628402469 "Component of q (quadrature) axis, aligned to imaginary part";
    parameter Real 'aimc.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 180.0 "Reference friction losses at wRef";
    parameter Real 'aimc.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 153.1526418625024 "Reference angular velocity that the PRef refer to";
    parameter Real 'aimc.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'aimc.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 1.1752980412939964 "Reference friction torque at reference angular velocity";
    parameter Real 'aimc.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'aimc.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.1531526418625024 "Linear angular velocity range";
    parameter Real 'aimc.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 1.1752980412939964e-6 "Torque corresponding with linear angular velocity range";
    parameter Integer 'aimc.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'aimc.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 410.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'aimc.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 387.9 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'aimc.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'aimc.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'aimc.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 9.082868838743923e-4 "Reference conductance at reference frequency and voltage";
    parameter Real 'aimc.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'aimc.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 102.18857277543316 "Reference stray load losses at IRef and wRef";
    parameter Real 'aimc.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 18.96595634287921 "Reference RMS current that PRef refers to";
    parameter Real 'aimc.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 153.1526418625024 "Reference angular velocity that PRef refers to";
    parameter Real 'aimc.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'aimc.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.6672334968088645 "Reference stray load torque at reference angular velocity and reference current";
    Real 'aimc.phiMechanical'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Mechanical angle of rotor against stator";
    Real 'aimc.wMechanical'(fixed = true, start = 157.07963267948966, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") "Mechanical angular velocity of rotor against stator";
    Real 'aimc.tauElectrical'(unit = "N.m", quantity = "Torque") "Electromagnetic torque";
    Real 'aimc.tauShaft'(unit = "N.m", quantity = "Torque") "Shaft torque";
    Real 'aimc.powerBalance.powerStator'(unit = "W", quantity = "Power") "Electrical power (stator)";
    Real 'aimc.powerBalance.powerMechanical'(unit = "W", quantity = "Power") "Mechanical power";
    Real 'aimc.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") "Stator inertia power";
    Real 'aimc.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") "Rotor inertia power";
    Real 'aimc.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") "Total loss power";
    Real 'aimc.powerBalance.lossPowerStatorWinding'(unit = "W", quantity = "Power") "Stator copper losses";
    Real 'aimc.powerBalance.lossPowerStatorCore'(unit = "W", quantity = "Power") "Stator core losses";
    Real 'aimc.powerBalance.lossPowerRotorCore'(unit = "W", quantity = "Power") "Rotor core losses";
    Real 'aimc.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") "Stray load losses";
