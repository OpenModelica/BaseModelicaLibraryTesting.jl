    'aimc.rotorCage.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].abs_V_m' = sqrt('aimc.rotorCage.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.re' ^ 2.0 + 'aimc.rotorCage.electroMagneticConverter.singlePhaseElectroMagneticConverter[1].V_m.im' ^ 2.0);
