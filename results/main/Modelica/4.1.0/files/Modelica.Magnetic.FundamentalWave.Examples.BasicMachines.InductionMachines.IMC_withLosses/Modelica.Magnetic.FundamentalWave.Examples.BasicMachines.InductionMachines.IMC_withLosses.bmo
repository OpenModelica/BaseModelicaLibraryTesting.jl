    output Real 'Pmech'(unit = "W", quantity = "Power") "Mechanical output";
    output Real 'Ps_sim'(unit = "W", quantity = "Power") "Simulated stator power";
    output Real 'Ps_meas'(unit = "W", quantity = "Power") "Simulated stator power";
    output Real 'loss_sim'(unit = "W", quantity = "Power") "Simulated total losses";
    output Real 'loss_meas'(unit = "W", quantity = "Power") "Measured total losses";
    output Real 'I_sim'(unit = "A", quantity = "ElectricCurrent") "Simulated current";
