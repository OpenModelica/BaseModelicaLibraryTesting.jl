    Real 'aimc.vs[1]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimc.vs[2]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimc.vs[3]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimc.is[1]'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'aimc.is[2]'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'aimc.is[3]'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'aimc.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'aimc.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Moment of inertia";
    parameter StateSelect 'aimc.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'aimc.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'aimc.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'aimc.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'aimc.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.inertiaStator.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.inertiaStator.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.inertiaStator.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'aimc.inertiaStator.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Moment of inertia";
    parameter StateSelect 'aimc.inertiaStator.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'aimc.inertiaStator.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'aimc.inertiaStator.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'aimc.inertiaStator.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'aimc.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'aimc.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Integer 'aimc.plug_sp.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'aimc.plug_sp.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.plug_sp.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.plug_sp.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.plug_sp.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.plug_sp.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
