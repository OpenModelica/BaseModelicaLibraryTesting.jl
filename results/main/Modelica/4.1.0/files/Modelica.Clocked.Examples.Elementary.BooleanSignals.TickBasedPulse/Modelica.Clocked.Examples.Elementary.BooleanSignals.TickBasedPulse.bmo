//! base 0.1.0
package 'TickBasedPulse'
  model 'TickBasedPulse' "Example of using the clock tick based Boolean Pulse source block"
    parameter Real 'periodicClock1.period'(unit = "s", quantity = "Time") = 0.1 "Period of clock (defined as Real number)" annotation(Evaluate = true);
    parameter Boolean 'periodicClock1.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'periodicClock1.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'periodicClock1.y';
    Boolean 'assignClock1.u' "Connector of clocked, Boolean input signal";
    Boolean 'assignClock1.y' "Connector of clocked, Boolean output signal";
    Clock 'assignClock1.clock';
    Boolean 'pulse.y' "Connector of clocked, Real output signal";
    parameter Integer 'pulse.widthTicks'(max = 4, min = 1) = 2 "Width of one pulse in clock ticks";
    parameter Integer 'pulse.periodTicks'(start = 1, min = 1) = 4 "Number of clock ticks for one period";
    parameter Integer 'pulse.startTick'(min = 1) = 2 "Clock tick at which the first pulse starts";
    Integer 'pulse.counter'(start = 0);
    Boolean 'pulse.startOutput'(start = false) "Flag whether counter >= startTick reached once";
  equation
    'periodicClock1.y' = 'assignClock1.clock';
    'pulse.y' = 'assignClock1.u';
    'periodicClock1.y' = Clock('periodicClock1.period');

    when 'assignClock1.clock' then
      'assignClock1.y' = 'assignClock1.u';
    end when;

    if previous('pulse.startOutput') then
      'pulse.counter' = if previous('pulse.counter') == 3 then 0 else previous('pulse.counter') + 1;
      'pulse.startOutput' = previous('pulse.startOutput');
    else
      'pulse.startOutput' = previous('pulse.counter') >= 1;
      'pulse.counter' = if 'pulse.startOutput' then 0 else previous('pulse.counter') + 1;
    end if;

    'pulse.y' = 'pulse.startOutput' and 'pulse.counter' < 2;
    annotation(experiment(StopTime = 1.0));
  end 'TickBasedPulse';
end 'TickBasedPulse';
