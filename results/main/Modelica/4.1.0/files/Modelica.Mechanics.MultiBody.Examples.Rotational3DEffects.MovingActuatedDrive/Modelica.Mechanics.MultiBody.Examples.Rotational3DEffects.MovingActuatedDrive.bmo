//! base 0.1.0
package 'MovingActuatedDrive'
  function 'Modelica.Mechanics.MultiBody.Frames.resolve1' "Transform vector from frame 2 to frame 1"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v2';
    output Real[3] 'v1';
  algorithm
    'v1' := {'R'.'T'[1,1] * 'v2'[1] + 'R'.'T'[2,1] * 'v2'[2] + 'R'.'T'[3,1] * 'v2'[3], 'R'.'T'[1,2] * 'v2'[1] + 'R'.'T'[2,2] * 'v2'[2] + 'R'.'T'[3,2] * 'v2'[3], 'R'.'T'[1,3] * 'v2'[1] + 'R'.'T'[2,3] * 'v2'[2] + 'R'.'T'[3,3] * 'v2'[3]};
    annotation(derivative(order = 1, noDerivative = 'R') = 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der', InlineAfterIndexReduction = true);
  end 'Modelica.Mechanics.MultiBody.Frames.resolve1';

  function 'Modelica.Mechanics.MultiBody.Frames.resolve2' "Transform vector from frame 1 to frame 2"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v1';
    output Real[3] 'v2';
  algorithm
    'v2' := {'R'.'T'[1,1] * 'v1'[1] + 'R'.'T'[1,2] * 'v1'[2] + 'R'.'T'[1,3] * 'v1'[3], 'R'.'T'[2,1] * 'v1'[1] + 'R'.'T'[2,2] * 'v1'[2] + 'R'.'T'[2,3] * 'v1'[3], 'R'.'T'[3,1] * 'v1'[1] + 'R'.'T'[3,2] * 'v1'[2] + 'R'.'T'[3,3] * 'v1'[3]};
    annotation(derivative(order = 1, noDerivative = 'R') = 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der', InlineAfterIndexReduction = true);
  end 'Modelica.Mechanics.MultiBody.Frames.resolve2';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der' "Derivative of function Frames.resolve1(..)"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v2';
    input Real[3] 'v2_der';
    output Real[3] 'v1_der';
  algorithm
    'v1_der' := 'Modelica.Mechanics.MultiBody.Frames.resolve1'('R', {'v2_der'[1] + 'R'.'w'[2] * 'v2'[3] - 'R'.'w'[3] * 'v2'[2], 'v2_der'[2] + 'R'.'w'[3] * 'v2'[1] - 'R'.'w'[1] * 'v2'[3], 'v2_der'[3] + 'R'.'w'[1] * 'v2'[2] - 'R'.'w'[2] * 'v2'[1]});
    annotation(Inline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der' "Derivative of function Frames.resolve2(..)"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v1';
    input Real[3] 'v1_der';
    output Real[3] 'v2_der';
  algorithm
    'v2_der' := 'Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1_der') - {'R'.'w'[2] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[3] - 'R'.'w'[3] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[2], 'R'.'w'[3] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[1] - 'R'.'w'[1] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[3], 'R'.'w'[1] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[2] - 'R'.'w'[2] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[1]};
    annotation(Inline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der';

  function 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy' "Return orientation object from n_x and n_y vectors"
    input Real[3] 'n_x';
    input Real[3] 'n_y';
    output Real[3, 3] 'T';
    Real[3] 'e_x'(each unit = "1") = if sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3]) < 1e-10 then {1.0, 0.0, 0.0} else smooth(0, if sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3]) >= 2.220446049250313e-14 then {'n_x'[1] / sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3]), 'n_x'[2] / sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3]), 'n_x'[3] / sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3])} else {'n_x'[1] / 2.220446049250313e-14, 'n_x'[2] / 2.220446049250313e-14, 'n_x'[3] / 2.220446049250313e-14});
    Real[3] 'e_y'(each unit = "1") = if sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3]) < 1e-10 then {0.0, 1.0, 0.0} else smooth(0, if sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3]) >= 2.220446049250313e-14 then {'n_y'[1] / sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3]), 'n_y'[2] / sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3]), 'n_y'[3] / sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3])} else {'n_y'[1] / 2.220446049250313e-14, 'n_y'[2] / 2.220446049250313e-14, 'n_y'[3] / 2.220446049250313e-14});
    Real[3] 'n_z_aux'(each unit = "1") = {'e_x'[2] * 'e_y'[3] - 'e_x'[3] * 'e_y'[2], 'e_x'[3] * 'e_y'[1] - 'e_x'[1] * 'e_y'[3], 'e_x'[1] * 'e_y'[2] - 'e_x'[2] * 'e_y'[1]};
    Real[3] 'n_y_aux'(each unit = "1") = if 'n_z_aux'[1] * 'n_z_aux'[1] + 'n_z_aux'[2] * 'n_z_aux'[2] + 'n_z_aux'[3] * 'n_z_aux'[3] > 1e-6 then 'e_y' else if abs('e_x'[1]) > 1e-6 then {0.0, 1.0, 0.0} else {1.0, 0.0, 0.0};
    Real[3] 'e_z_aux'(each unit = "1") = {'e_x'[2] * 'n_y_aux'[3] - 'e_x'[3] * 'n_y_aux'[2], 'e_x'[3] * 'n_y_aux'[1] - 'e_x'[1] * 'n_y_aux'[3], 'e_x'[1] * 'n_y_aux'[2] - 'e_x'[2] * 'n_y_aux'[1]};
    Real[3] 'e_z'(each unit = "1") = smooth(0, if sqrt('e_z_aux'[1] * 'e_z_aux'[1] + 'e_z_aux'[2] * 'e_z_aux'[2] + 'e_z_aux'[3] * 'e_z_aux'[3]) >= 2.220446049250313e-14 then {'e_z_aux'[1] / sqrt('e_z_aux'[1] * 'e_z_aux'[1] + 'e_z_aux'[2] * 'e_z_aux'[2] + 'e_z_aux'[3] * 'e_z_aux'[3]), 'e_z_aux'[2] / sqrt('e_z_aux'[1] * 'e_z_aux'[1] + 'e_z_aux'[2] * 'e_z_aux'[2] + 'e_z_aux'[3] * 'e_z_aux'[3]), 'e_z_aux'[3] / sqrt('e_z_aux'[1] * 'e_z_aux'[1] + 'e_z_aux'[2] * 'e_z_aux'[2] + 'e_z_aux'[3] * 'e_z_aux'[3])} else {'e_z_aux'[1] / 2.220446049250313e-14, 'e_z_aux'[2] / 2.220446049250313e-14, 'e_z_aux'[3] / 2.220446049250313e-14});
  algorithm
    'T' := {'e_x', {'e_z'[2] * 'e_x'[3] - 'e_z'[3] * 'e_x'[2], 'e_z'[3] * 'e_x'[1] - 'e_z'[1] * 'e_x'[3], 'e_z'[1] * 'e_x'[2] - 'e_z'[2] * 'e_x'[1]}, 'e_z'};
  end 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy';

  function 'Modelica.Units.Conversions.to_unit1' "Change the unit of a Real number to unit=\"1\""
    input Real 'r';
    output Real 'result'(unit = "1");
  algorithm
    'result' := 'r';
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_unit1';

  type 'Modelica.Mechanics.MultiBody.Types.GravityTypes' = enumeration('NoGravity', 'UniformGravity', 'PointGravity');

  type 'Modelica.Mechanics.MultiBody.Types.ResolveInFrameAB' = enumeration('world', 'frame_a', 'frame_b', 'frame_resolve');

  type 'Modelica.Mechanics.MultiBody.Types.VectorQuantity' = enumeration('Force', 'Torque', 'Velocity', 'Acceleration', 'AngularVelocity', 'AngularAcceleration', 'RelativePosition');

  record 'Modelica.Mechanics.MultiBody.Frames.Orientation'
    Real[3, 3] 'T';
    Real[3] 'w'(unit = fill("rad/s", 3), quantity = fill("AngularVelocity", 3));
  end 'Modelica.Mechanics.MultiBody.Frames.Orientation';

  model 'MovingActuatedDrive' "Demonstrates usage of model Rotor1D mounted on a moving body"
    Real 'bodyCylinder.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bodyCylinder.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bodyCylinder.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bodyCylinder.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bodyCylinder.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bodyCylinder.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bodyCylinder.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bodyCylinder.frame_a.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bodyCylinder.frame_a.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bodyCylinder.frame_a.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bodyCylinder.frame_a.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bodyCylinder.frame_a.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bodyCylinder.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bodyCylinder.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bodyCylinder.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'bodyCylinder.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'bodyCylinder.frame_b.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bodyCylinder.frame_b.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bodyCylinder.frame_b.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'bodyCylinder.frame_b.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bodyCylinder.frame_b.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bodyCylinder.frame_b.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'bodyCylinder.frame_b.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bodyCylinder.frame_b.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'bodyCylinder.frame_b.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    parameter Boolean 'bodyCylinder.animation' = true "= true, if animation shall be enabled (show shape between frame_a and frame_b and optionally a sphere at the center of mass)";
    parameter Boolean 'bodyCylinder.animateSphere' = false "= true, if mass shall be animated as sphere provided animation=true";
    parameter Real 'bodyCylinder.r[1]'(start = 0.0, unit = "m", quantity = "Length") = 0.5 "Vector from frame_a to frame_b resolved in frame_a";
    parameter Real 'bodyCylinder.r[2]'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to frame_b resolved in frame_a";
    parameter Real 'bodyCylinder.r[3]'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to frame_b resolved in frame_a";
    parameter Real 'bodyCylinder.r_CM[1]'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to center of mass, resolved in frame_a";
    parameter Real 'bodyCylinder.r_CM[2]'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to center of mass, resolved in frame_a";
    parameter Real 'bodyCylinder.r_CM[3]'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to center of mass, resolved in frame_a";
    parameter Real 'bodyCylinder.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.0 "Mass of rigid body";
    parameter Real 'bodyCylinder.I_11'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 2.0 "Element (1,1) of inertia tensor";
    parameter Real 'bodyCylinder.I_22'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Element (2,2) of inertia tensor";
    parameter Real 'bodyCylinder.I_33'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Element (3,3) of inertia tensor";
    parameter Real 'bodyCylinder.I_21'(min = -1e60, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Element (2,1) of inertia tensor";
    parameter Real 'bodyCylinder.I_31'(min = -1e60, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Element (3,1) of inertia tensor";
    parameter Real 'bodyCylinder.I_32'(min = -1e60, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Element (3,2) of inertia tensor";
    Real 'bodyCylinder.r_0[1]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of frame_a";
    Real 'bodyCylinder.r_0[2]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of frame_a";
    Real 'bodyCylinder.r_0[3]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of frame_a";
    Real 'bodyCylinder.v_0[1]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
    Real 'bodyCylinder.v_0[2]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
    Real 'bodyCylinder.v_0[3]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
    Real 'bodyCylinder.a_0[1]'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of frame_a resolved in world frame (= der(v_0))";
    Real 'bodyCylinder.a_0[2]'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of frame_a resolved in world frame (= der(v_0))";
    Real 'bodyCylinder.a_0[3]'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of frame_a resolved in world frame (= der(v_0))";
    parameter Boolean 'bodyCylinder.angles_fixed' = false "= true, if angles_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.angles_start[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate world frame around 'sequence_start' axes into frame_a";
    parameter Real 'bodyCylinder.angles_start[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate world frame around 'sequence_start' axes into frame_a";
    parameter Real 'bodyCylinder.angles_start[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate world frame around 'sequence_start' axes into frame_a";
    parameter Integer 'bodyCylinder.sequence_start[1]'(max = 3, min = 1) = 1 "Sequence of rotations to rotate world frame into frame_a at initial time" annotation(Evaluate = true);
    parameter Integer 'bodyCylinder.sequence_start[2]'(max = 3, min = 1) = 2 "Sequence of rotations to rotate world frame into frame_a at initial time" annotation(Evaluate = true);
    parameter Integer 'bodyCylinder.sequence_start[3]'(max = 3, min = 1) = 3 "Sequence of rotations to rotate world frame into frame_a at initial time" annotation(Evaluate = true);
    parameter Boolean 'bodyCylinder.w_0_fixed' = false "= true, if w_0_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.w_0_start[1]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial or guess values of angular velocity of frame_a resolved in world frame";
    parameter Real 'bodyCylinder.w_0_start[2]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial or guess values of angular velocity of frame_a resolved in world frame";
    parameter Real 'bodyCylinder.w_0_start[3]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial or guess values of angular velocity of frame_a resolved in world frame";
    parameter Boolean 'bodyCylinder.z_0_fixed' = false "= true, if z_0_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.z_0_start[1]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_0 = der(w_0)";
    parameter Real 'bodyCylinder.z_0_start[2]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_0 = der(w_0)";
    parameter Real 'bodyCylinder.z_0_start[3]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_0 = der(w_0)";
    parameter String 'bodyCylinder.shapeType' = "cylinder" "Type of shape";
    parameter Real 'bodyCylinder.r_shape[1]'(unit = "m", quantity = "Length") = 0.1 "Vector from frame_a to shape origin, resolved in frame_a";
    parameter Real 'bodyCylinder.r_shape[2]'(unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to shape origin, resolved in frame_a";
    parameter Real 'bodyCylinder.r_shape[3]'(unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to shape origin, resolved in frame_a";
    parameter Real 'bodyCylinder.lengthDirection[1]'(unit = "1") = 0.4 "Vector in length direction of shape, resolved in frame_a" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.lengthDirection[2]'(unit = "1") = 0.0 "Vector in length direction of shape, resolved in frame_a" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.lengthDirection[3]'(unit = "1") = 0.0 "Vector in length direction of shape, resolved in frame_a" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.widthDirection[1]'(unit = "1") = 0.0 "Vector in width direction of shape, resolved in frame_a" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.widthDirection[2]'(unit = "1") = 1.0 "Vector in width direction of shape, resolved in frame_a" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.widthDirection[3]'(unit = "1") = 0.0 "Vector in width direction of shape, resolved in frame_a" annotation(Evaluate = true);
    parameter Real 'bodyCylinder.length'(unit = "m", quantity = "Length") = 0.4 "Length of shape";
    parameter Real 'bodyCylinder.width'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Width of shape";
    parameter Real 'bodyCylinder.height'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Height of shape";
    parameter Real 'bodyCylinder.extra' = 0.0 "Additional parameter depending on shapeType (see docu of Visualizers.Advanced.Shape)";
    Integer 'bodyCylinder.color[1]'(max = 255, min = 0) "Color of shape";
    Integer 'bodyCylinder.color[2]'(max = 255, min = 0) "Color of shape";
    Integer 'bodyCylinder.color[3]'(max = 255, min = 0) "Color of shape";
    parameter Real 'bodyCylinder.sphereDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.2 "Diameter of sphere";
