//! base 0.1.0
package 'Accelerate'
  model 'Accelerate' "Use of model accelerate"
    parameter Boolean 'accelerate.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'accelerate.s'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'accelerate.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'accelerate.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'accelerate.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'accelerate.v'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of flange";
    Real 'accelerate.a'(unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of flange";
    Real 'accelerate.a_ref'(unit = "m/s2") "Absolute acceleration of flange as input signal";
    parameter Real 'mass.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass of the sliding mass";
    parameter StateSelect 'mass.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'mass.s'(stateSelect = StateSelect.default, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'mass.L'(start = 0.0, unit = "m", quantity = "Length") = 1.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'mass.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass.v'(stateSelect = StateSelect.default, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter Real 'constantAcc.k'(start = 1.0) = 1.0 "Constant output value";
    Real 'constantAcc.y' "Connector of Real output signal";
  equation
    'accelerate.flange.s' = 'mass.flange_a.s';
    'constantAcc.y' = 'accelerate.a_ref';
    'mass.flange_a.f' + 'accelerate.flange.f' = 0.0;
    'mass.flange_b.f' = 0.0;
    'accelerate.v' = der('accelerate.s');
    'accelerate.a' = der('accelerate.v');
    'accelerate.a' = 'accelerate.a_ref';
    'accelerate.s' = 'accelerate.flange.s' - 'accelerate.s_support';
    'accelerate.s_support' = 0.0;
    'mass.v' = der('mass.s');
    'mass.a' = der('mass.v');
    'mass.a' = 'mass.flange_a.f' + 'mass.flange_b.f';
    'mass.flange_a.s' = 'mass.s' - 0.5;
    'mass.flange_b.s' = 'mass.s' + 0.5;
    'constantAcc.y' = 1.0;
    annotation(experiment(StopTime = 1.0, Interval = 0.001));
  end 'Accelerate';
end 'Accelerate';
