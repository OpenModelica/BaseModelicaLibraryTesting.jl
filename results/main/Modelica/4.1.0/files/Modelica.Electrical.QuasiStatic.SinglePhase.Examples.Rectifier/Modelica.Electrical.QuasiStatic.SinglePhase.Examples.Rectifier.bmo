    Real 'rectifierAC.idealDiode3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode3.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.idealDiode3.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'rectifierAC.idealDiode3.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'rectifierAC.idealDiode3.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'rectifierAC.idealDiode3.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'rectifierAC.idealDiode3.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'rectifierAC.idealDiode3.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'rectifierAC.idealDiode3.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'rectifierAC.idealDiode3.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'rectifierAC.idealDiode3.off'(start = true) "Switching state";
    Real 'rectifierAC.idealDiode3.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'rectifierAC.idealDiode3.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'rectifierAC.idealDiode3.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Real 'rectifierAC.idealDiode4.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'rectifierAC.idealDiode4.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.idealDiode4.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode4.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.idealDiode4.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode4.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'rectifierAC.idealDiode4.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'rectifierAC.idealDiode4.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'rectifierAC.idealDiode4.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'rectifierAC.idealDiode4.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'rectifierAC.idealDiode4.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'rectifierAC.idealDiode4.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'rectifierAC.idealDiode4.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'rectifierAC.idealDiode4.off'(start = true) "Switching state";
    Real 'rectifierAC.idealDiode4.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'rectifierAC.idealDiode4.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'rectifierAC.idealDiode4.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Real 'currentSensorDC2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensorDC2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensorDC2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensorDC2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensorDC2.i'(unit = "A") "Current in the branch from p to n as output signal";
    Real 'iDC2.u' "Connector of Real input signal";
    Real 'iDC2.y' "Connector of Real output signal";
    parameter Real 'iDC2.f'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Base frequency";
    parameter Real 'iDC2.x0' = 0.0 "Start value of integrator state";
    parameter Real 'iDC2.y0'(min = 0.0) = 0.0 "Start value of output";
    parameter Integer 'iDC2.product.significantDigits'(min = 1) = 3 "Number of significant digits to be shown in dynamic diagram layer for y";
    parameter Integer 'iDC2.product.nu'(min = 0) = 2 "Number of input connections";
    Real 'iDC2.product.u[1]';
    Real 'iDC2.product.u[2]';
    Real 'iDC2.product.y';
    Real 'iDC2.mean.u' "Connector of Real input signal";
    Real 'iDC2.mean.y' "Connector of Real output signal";
    parameter Real 'iDC2.mean.f'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Base frequency";
    parameter Real 'iDC2.mean.x0' = 0.0 "Start value of integrator state";
    parameter Real 'iDC2.mean.y0' = 0.0 "Start value of output";
    parameter Boolean 'iDC2.mean.yGreaterOrEqualZero' = true "= true, if output y is guaranteed to be >= 0 for the exact solution" annotation(Evaluate = true);
    parameter Real 'iDC2.mean.t0'(fixed = false, unit = "s", quantity = "Time") "Start time of simulation";
    Real 'iDC2.mean.x' "Integrator state";
    discrete Real 'iDC2.mean.y_last' "Last sampled mean value";
    Real 'iDC2.sqrt1.u' "Connector of Real input signal";
    Real 'iDC2.sqrt1.y' "Connector of Real output signal";
    parameter Real 'load2.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'load2.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of conductance (G_actual = G/(1 + alpha*(T_heatPort - T_ref))";
    Real 'load2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'load2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'load2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'load2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'load2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'load2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'load2.G_actual'(unit = "S", quantity = "Conductance") "Actual conductance = G/(1 + alpha*(T_heatPort - T_ref))";
    Real 'load2.G'(unit = "S");
    parameter Real 'ramp.height' = 1.0 "Height of ramp";
    parameter Real 'ramp.duration'(start = 2.0, min = 0.0, unit = "s", quantity = "Time") = 0.8 "Duration of ramp (= 0.0 gives a Step)";
    Real 'ramp.y' "Connector of Real output signal";
    parameter Real 'ramp.offset' = 0.0 "Offset of output signal y";
    parameter Real 'ramp.startTime'(unit = "s", quantity = "Time") = 0.1 "Output y = offset for time < startTime";
  initial equation
    'iAC.mean1.t0' = time;
    'iAC.mean1.x' = 0.0;
    'iAC.mean1.y_last' = 0.0;
    'iAC.mean2.t0' = time;
    'iAC.mean2.x' = 0.0;
    'iAC.mean2.y_last' = 0.0;
    'iDC2.mean.t0' = time;
    'iDC2.mean.x' = 0.0;
    'iDC2.mean.y_last' = 0.0;
  equation
    'Itr' = 'iAC.y_rms';
    'Iqs' = 'iQS.len';
    'voltageQS.abs_v' = sqrt('voltageQS.v.re' ^ 2.0 + 'voltageQS.v.im' ^ 2.0);
    'voltageQS.arg_v' = 'Modelica.Math.atan3'('voltageQS.v.im', 'voltageQS.v.re', 0.0);
    'voltageQS.abs_i' = sqrt('voltageQS.i.re' ^ 2.0 + 'voltageQS.i.im' ^ 2.0);
    'voltageQS.arg_i' = 'Modelica.Math.atan3'('voltageQS.i.im', 'voltageQS.i.re', 0.0);
    'voltageQS.P' = 'voltageQS.v.re' * 'voltageQS.i.re' - 'voltageQS.v.im' * (-'voltageQS.i.im');
    'voltageQS.Q' = 'voltageQS.v.re' * (-'voltageQS.i.im') + 'voltageQS.v.im' * 'voltageQS.i.re';
    'voltageQS.S' = sqrt(('voltageQS.v.re' * 'voltageQS.i.re' - 'voltageQS.v.im' * (-'voltageQS.i.im')) ^ 2.0 + ('voltageQS.v.re' * (-'voltageQS.i.im') + 'voltageQS.v.im' * 'voltageQS.i.re') ^ 2.0);
    'voltageQS.pf' = cos('Modelica.Math.atan3'('voltageQS.Q', 'voltageQS.P', 0.0));
    'voltageQS.gamma' = 'voltageQS.pin_p.reference.gamma';
    'resistorQS.abs_v' = sqrt('resistorQS.v.re' ^ 2.0 + 'resistorQS.v.im' ^ 2.0);
    'resistorQS.arg_v' = 'Modelica.Math.atan3'('resistorQS.v.im', 'resistorQS.v.re', 0.0);
    'resistorQS.abs_i' = sqrt('resistorQS.i.re' ^ 2.0 + 'resistorQS.i.im' ^ 2.0);
    'resistorQS.arg_i' = 'Modelica.Math.atan3'('resistorQS.i.im', 'resistorQS.i.re', 0.0);
    'resistorQS.P' = 'resistorQS.v.re' * 'resistorQS.i.re' - 'resistorQS.v.im' * (-'resistorQS.i.im');
    'resistorQS.Q' = 'resistorQS.v.re' * (-'resistorQS.i.im') + 'resistorQS.v.im' * 'resistorQS.i.re';
    'resistorQS.S' = sqrt(('resistorQS.v.re' * 'resistorQS.i.re' - 'resistorQS.v.im' * (-'resistorQS.i.im')) ^ 2.0 + ('resistorQS.v.re' * (-'resistorQS.i.im') + 'resistorQS.v.im' * 'resistorQS.i.re') ^ 2.0);
    'resistorQS.pf' = cos('Modelica.Math.atan3'('resistorQS.Q', 'resistorQS.P', 0.0));
    'currentSensorQS.abs_i' = sqrt('currentSensorQS.i.re' ^ 2.0 + 'currentSensorQS.i.im' ^ 2.0);
    'currentSensorQS.arg_i' = 'Modelica.Math.atan3'('currentSensorQS.i.im', 'currentSensorQS.i.re', 0.0);
    'rectifierQS.iQS.re' = 'rectifierQS.pin_pQS.i.re';
    'rectifierQS.iQS.im' = 'rectifierQS.pin_pQS.i.im';
    'rectifierQS.vQSabs' = sqrt('rectifierQS.vQS.re' ^ 2.0 + 'rectifierQS.vQS.im' ^ 2.0);
    'rectifierQS.iQSabs' = sqrt('rectifierQS.iQS.re' ^ 2.0 + 'rectifierQS.iQS.im' ^ 2.0);
    'rectifierQS.pQS' = 'rectifierQS.sQS.re';
    'rectifierQS.qQS' = 'rectifierQS.sQS.im';
    'rectifierQS.vDC' = 'rectifierQS.pin_pDC.v' - 'rectifierQS.pin_nDC.v';
    'rectifierQS.iDC' = 'rectifierQS.pin_pDC.i';
    'rectifierQS.pDC' = 'rectifierQS.vDC' * 'rectifierQS.iDC';
    'rectifierAC.vAC' = 'rectifierAC.pin_pAC.v' - 'rectifierAC.pin_nAC.v';
    'rectifierAC.iAC' = 'rectifierAC.pin_pAC.i';
    'rectifierAC.pAC' = 'rectifierAC.vAC' * 'rectifierAC.iAC';
    'rectifierAC.vDC' = 'rectifierAC.pin_pDC.v' - 'rectifierAC.pin_nDC.v';
    'rectifierAC.iDC' = 'rectifierAC.pin_pDC.i';
    'rectifierAC.pDC' = 'rectifierAC.vDC' * 'rectifierAC.iDC';
    'iAC.product2.y' = 'iAC.mean2.u';
    'iAC.product1.y' = 'iAC.mean1.u';
    'iAC.mean1.y' = 'iAC.rectangularToPolar.u_re';
    'iAC.mean2.y' = 'iAC.rectangularToPolar.u_im';
    'iAC.rectangularToPolar.y_abs' = 'iAC.y_rms';
    'iAC.sin1.y' = 'iAC.product1.u[1]';
    'iAC.u' = 'iAC.product2.u[1]';
    'iAC.u' = 'iAC.product1.u[2]';
    'iAC.sin2.y' = 'iAC.product2.u[2]';
    'iAC.rectangularToPolar.y_arg' = 'iAC.gain.u';
    'iAC.gain.y' = 'iAC.y_arg';
    'rectifierAC.pin_pAC.v' = 'rectifierAC.idealDiode1.p.v';
    'rectifierAC.pin_pAC.v' = 'rectifierAC.idealDiode3.n.v';
    'rectifierAC.pin_nAC.v' = 'rectifierAC.idealDiode4.n.v';
    'rectifierAC.pin_nAC.v' = 'rectifierAC.idealDiode2.p.v';
    'rectifierAC.idealDiode4.p.v' = 'rectifierAC.pin_nDC.v';
    'rectifierAC.idealDiode4.p.v' = 'rectifierAC.idealDiode3.p.v';
    'rectifierAC.idealDiode2.n.v' = 'rectifierAC.pin_pDC.v';
    'rectifierAC.idealDiode2.n.v' = 'rectifierAC.idealDiode1.n.v';
    'iDC2.product.y' = 'iDC2.mean.u';
    'iDC2.mean.y' = 'iDC2.sqrt1.u';
    'iDC2.sqrt1.y' = 'iDC2.y';
    'iDC2.u' = 'iDC2.product.u[2]';
    'iDC2.u' = 'iDC2.product.u[1]';
    'voltageQS.pin_p.v.re' = 'resistorQS.pin_p.v.re';
    'voltageQS.pin_p.v.im' = 'resistorQS.pin_p.v.im';
    'rectifierQS.pin_nQS.reference.gamma' = 'groundQS.pin.reference.gamma';
    'rectifierQS.pin_nQS.reference.gamma' = 'voltageQS.pin_n.reference.gamma';
    'rectifierQS.pin_nQS.v.re' = 'groundQS.pin.v.re';
    'rectifierQS.pin_nQS.v.re' = 'voltageQS.pin_n.v.re';
    'rectifierQS.pin_nQS.v.im' = 'groundQS.pin.v.im';
    'rectifierQS.pin_nQS.v.im' = 'voltageQS.pin_n.v.im';
    'load1.n.v' = 'rectifierQS.pin_nDC.v';
    'load1.n.v' = 'groundDC1.p.v';
    'voltageAC.p.v' = 'resistorAC.p.v';
    'rectifierAC.pin_nAC.v' = 'groundAC.p.v';
    'rectifierAC.pin_nAC.v' = 'voltageAC.n.v';
    'rectifierAC.pin_nDC.v' = 'load2.n.v';
    'ramp.y' = 'load2.G';
    'ramp.y' = 'load1.G';
    'resistorQS.pin_n.reference.gamma' = 'currentSensorQS.pin_p.reference.gamma';
    'resistorQS.pin_n.v.re' = 'currentSensorQS.pin_p.v.re';
    'resistorQS.pin_n.v.im' = 'currentSensorQS.pin_p.v.im';
    'currentSensorQS.pin_n.reference.gamma' = 'rectifierQS.pin_pQS.reference.gamma';
    'currentSensorQS.pin_n.v.re' = 'rectifierQS.pin_pQS.v.re';
    'currentSensorQS.pin_n.v.im' = 'rectifierQS.pin_pQS.v.im';
    'currentSensorQS.i.re' = 'iQS.u.re';
    'currentSensorQS.i.im' = 'iQS.u.im';
    'rectifierQS.pin_pDC.v' = 'iDC1.p.v';
    'iDC1.n.v' = 'load1.p.v';
    'resistorAC.n.v' = 'currentSensorAC.p.v';
    'currentSensorAC.n.v' = 'rectifierAC.pin_pAC.v';
    'currentSensorAC.i' = 'iAC.u';
    'currentSensorDC2.i' = 'iDC2.u';
    'currentSensorDC2.p.v' = 'rectifierAC.pin_pDC.v';
    'currentSensorDC2.n.v' = 'load2.p.v';
    'resistorQS.pin_p.i.re' + 'voltageQS.pin_p.i.re' = 0.0;
    'resistorQS.pin_p.i.im' + 'voltageQS.pin_p.i.im' = 0.0;
    'rectifierQS.pin_nQS.i.re' + 'groundQS.pin.i.re' + 'voltageQS.pin_n.i.re' = 0.0;
    'rectifierQS.pin_nQS.i.im' + 'groundQS.pin.i.im' + 'voltageQS.pin_n.i.im' = 0.0;
    'currentSensorQS.pin_p.i.re' + 'resistorQS.pin_n.i.re' = 0.0;
    'currentSensorQS.pin_p.i.im' + 'resistorQS.pin_n.i.im' = 0.0;
    'rectifierQS.pin_pQS.i.re' + 'currentSensorQS.pin_n.i.re' = 0.0;
    'rectifierQS.pin_pQS.i.im' + 'currentSensorQS.pin_n.i.im' = 0.0;
    'iDC1.p.i' + 'rectifierQS.pin_pDC.i' = 0.0;
    'load1.n.i' + 'groundDC1.p.i' + 'rectifierQS.pin_nDC.i' = 0.0;
    'load1.p.i' + 'iDC1.n.i' = 0.0;
    'resistorAC.p.i' + 'voltageAC.p.i' = 0.0;
    'rectifierAC.pin_nAC.i' + 'groundAC.p.i' + 'voltageAC.n.i' = 0.0;
    'currentSensorAC.p.i' + 'resistorAC.n.i' = 0.0;
    'rectifierAC.pin_pAC.i' + 'currentSensorAC.n.i' = 0.0;
    'load2.n.i' + 'rectifierAC.pin_nDC.i' = 0.0;
    'rectifierAC.idealDiode2.n.i' + 'rectifierAC.idealDiode1.n.i' - 'rectifierAC.pin_pDC.i' = 0.0;
    'rectifierAC.idealDiode4.n.i' + 'rectifierAC.idealDiode2.p.i' - 'rectifierAC.pin_nAC.i' = 0.0;
    'rectifierAC.idealDiode4.p.i' + 'rectifierAC.idealDiode3.p.i' - 'rectifierAC.pin_nDC.i' = 0.0;
    'rectifierAC.idealDiode3.n.i' + 'rectifierAC.idealDiode1.p.i' - 'rectifierAC.pin_pAC.i' = 0.0;
    'currentSensorDC2.p.i' + 'rectifierAC.pin_pDC.i' = 0.0;
    'load2.p.i' + 'currentSensorDC2.n.i' = 0.0;
    'voltageQS.omega' = 314.1592653589793;
    'voltageQS.v.re' = 100.0;
    'voltageQS.v.im' = 0.0;
    'voltageQS.pin_p.i.re' + 'voltageQS.pin_n.i.re' = 0.0;
    'voltageQS.pin_p.i.im' + 'voltageQS.pin_n.i.im' = 0.0;
    'voltageQS.v.re' = 'voltageQS.pin_p.v.re' - 'voltageQS.pin_n.v.re';
    'voltageQS.v.im' = 'voltageQS.pin_p.v.im' - 'voltageQS.pin_n.v.im';
    'voltageQS.i.re' = 'voltageQS.pin_p.i.re';
    'voltageQS.i.im' = 'voltageQS.pin_p.i.im';
    'voltageQS.pin_p.reference.gamma' = 'voltageQS.pin_n.reference.gamma';
    'voltageQS.omega' = der('voltageQS.pin_p.reference.gamma');
    'resistorQS.R_actual' = 0.05;
    'resistorQS.v.re' = 'resistorQS.R_actual' * 'resistorQS.i.re' - 0.0 * 'resistorQS.i.im';
    'resistorQS.v.im' = 'resistorQS.R_actual' * 'resistorQS.i.im' + 0.0 * 'resistorQS.i.re';
    'resistorQS.LossPower' = 'resistorQS.v.re' * 'resistorQS.i.re' - 'resistorQS.v.im' * (-'resistorQS.i.im');
    'resistorQS.T_heatPort' = 293.15;
    'resistorQS.pin_p.i.re' + 'resistorQS.pin_n.i.re' = 0.0;
    'resistorQS.pin_p.i.im' + 'resistorQS.pin_n.i.im' = 0.0;
    'resistorQS.v.re' = 'resistorQS.pin_p.v.re' - 'resistorQS.pin_n.v.re';
    'resistorQS.v.im' = 'resistorQS.pin_p.v.im' - 'resistorQS.pin_n.v.im';
    'resistorQS.i.re' = 'resistorQS.pin_p.i.re';
    'resistorQS.i.im' = 'resistorQS.pin_p.i.im';
    'resistorQS.pin_p.reference.gamma' = 'resistorQS.pin_n.reference.gamma';
    'resistorQS.omega' = der('resistorQS.pin_p.reference.gamma');
    'currentSensorQS.i.re' = 'currentSensorQS.pin_p.i.re';
    'currentSensorQS.i.im' = 'currentSensorQS.pin_p.i.im';
    'currentSensorQS.v.re' = 'currentSensorQS.pin_p.v.re' - 'currentSensorQS.pin_n.v.re';
    'currentSensorQS.v.im' = 'currentSensorQS.pin_p.v.im' - 'currentSensorQS.pin_n.v.im';
    'currentSensorQS.v.re' = 0.0;
    'currentSensorQS.v.im' = 0.0;
    0.0 = 'currentSensorQS.pin_p.i.re' + 'currentSensorQS.pin_n.i.re' "Current balance";
    0.0 = 'currentSensorQS.pin_p.i.im' + 'currentSensorQS.pin_n.i.im' "Current balance";
    'currentSensorQS.pin_p.reference.gamma' = 'currentSensorQS.pin_n.reference.gamma';
    'currentSensorQS.omega' = der('currentSensorQS.pin_p.reference.gamma');
    'iQS.len' = sqrt('iQS.u.re' ^ 2.0 + 'iQS.u.im' ^ 2.0);
    'iQS.phi' = atan2('iQS.u.im', 'iQS.u.re');
    'groundQS.pin.v.re' = 0.0;
    'groundQS.pin.v.im' = 0.0;
    'rectifierQS.vQS.re' = 'rectifierQS.pin_pQS.v.re' - 'rectifierQS.pin_nQS.v.re';
    'rectifierQS.vQS.im' = 'rectifierQS.pin_pQS.v.im' - 'rectifierQS.pin_nQS.v.im';
    'rectifierQS.sQS.re' = 'rectifierQS.vQS.re' * 'rectifierQS.iQS.re' - 'rectifierQS.vQS.im' * (-'rectifierQS.iQS.im');
    'rectifierQS.sQS.im' = 'rectifierQS.vQS.re' * (-'rectifierQS.iQS.im') + 'rectifierQS.vQS.im' * 'rectifierQS.iQS.re';
    'rectifierQS.pin_pQS.reference.gamma' = 'rectifierQS.pin_nQS.reference.gamma';
    'rectifierQS.pin_pQS.i.re' + 'rectifierQS.pin_nQS.i.re' = 0.0;
    'rectifierQS.pin_pQS.i.im' + 'rectifierQS.pin_nQS.i.im' = 0.0;
    'rectifierQS.pin_pDC.i' + 'rectifierQS.pin_nDC.i' = 0.0;
    'rectifierQS.vDC' = sqrt('rectifierQS.vQS.re' ^ 2.0 + 'rectifierQS.vQS.im' ^ 2.0);
    'rectifierQS.pQS' + 'rectifierQS.pDC' = 0.0;
    'rectifierQS.qQS' = 0.0;
    'groundDC1.p.v' = 0.0;
    'iDC1.p.v' = 'iDC1.n.v';
    'iDC1.p.i' = 'iDC1.i';
    'iDC1.n.i' = -'iDC1.i';
    'load1.G_actual' = 'load1.G';
    'load1.i' = 'load1.G_actual' * 'load1.v';
    'load1.LossPower' = 'load1.v' * 'load1.i';
    'load1.T_heatPort' = 300.15;
    0.0 = 'load1.p.i' + 'load1.n.i';
    'load1.i' = 'load1.p.i';
    'load1.v' = 'load1.p.v' - 'load1.n.v';
    'voltageAC.signalSource.y' = if time < 0.0 then 0.0 else 141.4213562373095 * sin(314.1592653589793 * time + 1.5707963267948966);
    'voltageAC.v' = 'voltageAC.signalSource.y';
    0.0 = 'voltageAC.p.i' + 'voltageAC.n.i';
    'voltageAC.i' = 'voltageAC.p.i';
    'voltageAC.v' = 'voltageAC.p.v' - 'voltageAC.n.v';
    'resistorAC.R_actual' = 0.05;
    'resistorAC.v' = 'resistorAC.R_actual' * 'resistorAC.i';
    'resistorAC.LossPower' = 'resistorAC.v' * 'resistorAC.i';
    'resistorAC.T_heatPort' = 300.15;
    0.0 = 'resistorAC.p.i' + 'resistorAC.n.i';
    'resistorAC.i' = 'resistorAC.p.i';
    'resistorAC.v' = 'resistorAC.p.v' - 'resistorAC.n.v';
    'currentSensorAC.p.v' = 'currentSensorAC.n.v';
    'currentSensorAC.p.i' = 'currentSensorAC.i';
    'currentSensorAC.n.i' = -'currentSensorAC.i';
    'iAC.sin1.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * cos(314.1592653589793 * time);
    'iAC.sin2.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * sin(314.1592653589793 * time);
    'iAC.product1.y' = 'iAC.product1.u[1]' * 'iAC.product1.u[2]';
    'iAC.product2.y' = 'iAC.product2.u[1]' * 'iAC.product2.u[2]';
    der('iAC.mean1.x') = 'iAC.mean1.u';

    when sample('iAC.mean1.t0' + 0.02, 0.02) then
      'iAC.mean1.y_last' = 50.0 * pre('iAC.mean1.x');
      reinit('iAC.mean1.x', 0.0);
    end when;

    'iAC.mean1.y' = 'iAC.mean1.y_last';
    der('iAC.mean2.x') = 'iAC.mean2.u';

    when sample('iAC.mean2.t0' + 0.02, 0.02) then
      'iAC.mean2.y_last' = 50.0 * pre('iAC.mean2.x');
      reinit('iAC.mean2.x', 0.0);
    end when;

    'iAC.mean2.y' = 'iAC.mean2.y_last';
    'iAC.rectangularToPolar.y_abs' = sqrt('iAC.rectangularToPolar.u_re' * 'iAC.rectangularToPolar.u_re' + 'iAC.rectangularToPolar.u_im' * 'iAC.rectangularToPolar.u_im');
    'iAC.rectangularToPolar.y_arg' = atan2('iAC.rectangularToPolar.u_im', 'iAC.rectangularToPolar.u_re');
    'iAC.gain.y' = 'iAC.gain.u';
    'groundAC.p.v' = 0.0;
    'rectifierAC.idealDiode1.off' = 'rectifierAC.idealDiode1.s' < 0.0;
    'rectifierAC.idealDiode1.v' = 'rectifierAC.idealDiode1.s' * (if 'rectifierAC.idealDiode1.off' then 1.0 else 1e-5);
    'rectifierAC.idealDiode1.i' = 'rectifierAC.idealDiode1.s' * (if 'rectifierAC.idealDiode1.off' then 1e-5 else 1.0);
    'rectifierAC.idealDiode1.LossPower' = 'rectifierAC.idealDiode1.v' * 'rectifierAC.idealDiode1.i';
    'rectifierAC.idealDiode1.T_heatPort' = 293.15;
    0.0 = 'rectifierAC.idealDiode1.p.i' + 'rectifierAC.idealDiode1.n.i';
    'rectifierAC.idealDiode1.i' = 'rectifierAC.idealDiode1.p.i';
    'rectifierAC.idealDiode1.v' = 'rectifierAC.idealDiode1.p.v' - 'rectifierAC.idealDiode1.n.v';
    'rectifierAC.idealDiode2.off' = 'rectifierAC.idealDiode2.s' < 0.0;
    'rectifierAC.idealDiode2.v' = 'rectifierAC.idealDiode2.s' * (if 'rectifierAC.idealDiode2.off' then 1.0 else 1e-5);
    'rectifierAC.idealDiode2.i' = 'rectifierAC.idealDiode2.s' * (if 'rectifierAC.idealDiode2.off' then 1e-5 else 1.0);
    'rectifierAC.idealDiode2.LossPower' = 'rectifierAC.idealDiode2.v' * 'rectifierAC.idealDiode2.i';
    'rectifierAC.idealDiode2.T_heatPort' = 293.15;
    0.0 = 'rectifierAC.idealDiode2.p.i' + 'rectifierAC.idealDiode2.n.i';
    'rectifierAC.idealDiode2.i' = 'rectifierAC.idealDiode2.p.i';
    'rectifierAC.idealDiode2.v' = 'rectifierAC.idealDiode2.p.v' - 'rectifierAC.idealDiode2.n.v';
    'rectifierAC.idealDiode3.off' = 'rectifierAC.idealDiode3.s' < 0.0;
    'rectifierAC.idealDiode3.v' = 'rectifierAC.idealDiode3.s' * (if 'rectifierAC.idealDiode3.off' then 1.0 else 1e-5);
    'rectifierAC.idealDiode3.i' = 'rectifierAC.idealDiode3.s' * (if 'rectifierAC.idealDiode3.off' then 1e-5 else 1.0);
    'rectifierAC.idealDiode3.LossPower' = 'rectifierAC.idealDiode3.v' * 'rectifierAC.idealDiode3.i';
    'rectifierAC.idealDiode3.T_heatPort' = 293.15;
    0.0 = 'rectifierAC.idealDiode3.p.i' + 'rectifierAC.idealDiode3.n.i';
    'rectifierAC.idealDiode3.i' = 'rectifierAC.idealDiode3.p.i';
    'rectifierAC.idealDiode3.v' = 'rectifierAC.idealDiode3.p.v' - 'rectifierAC.idealDiode3.n.v';
    'rectifierAC.idealDiode4.off' = 'rectifierAC.idealDiode4.s' < 0.0;
    'rectifierAC.idealDiode4.v' = 'rectifierAC.idealDiode4.s' * (if 'rectifierAC.idealDiode4.off' then 1.0 else 1e-5);
    'rectifierAC.idealDiode4.i' = 'rectifierAC.idealDiode4.s' * (if 'rectifierAC.idealDiode4.off' then 1e-5 else 1.0);
    'rectifierAC.idealDiode4.LossPower' = 'rectifierAC.idealDiode4.v' * 'rectifierAC.idealDiode4.i';
    'rectifierAC.idealDiode4.T_heatPort' = 293.15;
    0.0 = 'rectifierAC.idealDiode4.p.i' + 'rectifierAC.idealDiode4.n.i';
    'rectifierAC.idealDiode4.i' = 'rectifierAC.idealDiode4.p.i';
    'rectifierAC.idealDiode4.v' = 'rectifierAC.idealDiode4.p.v' - 'rectifierAC.idealDiode4.n.v';
    'currentSensorDC2.p.v' = 'currentSensorDC2.n.v';
    'currentSensorDC2.p.i' = 'currentSensorDC2.i';
    'currentSensorDC2.n.i' = -'currentSensorDC2.i';
    'iDC2.product.y' = 'iDC2.product.u[1]' * 'iDC2.product.u[2]';
    der('iDC2.mean.x') = 'iDC2.mean.u';

    when sample('iDC2.mean.t0' + 0.02, 0.02) then
      'iDC2.mean.y_last' = max(0.0, 50.0 * pre('iDC2.mean.x'));
      reinit('iDC2.mean.x', 0.0);
    end when;

    'iDC2.mean.y' = 'iDC2.mean.y_last';
    'iDC2.sqrt1.y' = sqrt('iDC2.sqrt1.u');
    'load2.G_actual' = 'load2.G';
    'load2.i' = 'load2.G_actual' * 'load2.v';
    'load2.LossPower' = 'load2.v' * 'load2.i';
    'load2.T_heatPort' = 300.15;
    0.0 = 'load2.p.i' + 'load2.n.i';
    'load2.i' = 'load2.p.i';
    'load2.v' = 'load2.p.v' - 'load2.n.v';
    'ramp.y' = if time < 0.1 then 0.0 else if time < 0.9 then (time - 0.1) / 0.8 else 1.0;
    annotation(experiment(StopTime = 1.0, Interval = 0.0001));
  end 'Rectifier';
end 'Rectifier';
