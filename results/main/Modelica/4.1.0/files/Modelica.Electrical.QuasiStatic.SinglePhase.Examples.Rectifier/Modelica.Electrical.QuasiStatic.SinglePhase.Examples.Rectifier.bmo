    Real 'rectifierAC.pin_nAC.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.pin_nAC.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.pin_pDC.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.pin_pDC.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.pin_nDC.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.pin_nDC.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'rectifierAC.idealDiode1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.idealDiode1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.idealDiode1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'rectifierAC.idealDiode1.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'rectifierAC.idealDiode1.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'rectifierAC.idealDiode1.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'rectifierAC.idealDiode1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'rectifierAC.idealDiode1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'rectifierAC.idealDiode1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'rectifierAC.idealDiode1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'rectifierAC.idealDiode1.off'(start = true) "Switching state";
    Real 'rectifierAC.idealDiode1.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'rectifierAC.idealDiode1.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'rectifierAC.idealDiode1.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Real 'rectifierAC.idealDiode2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'rectifierAC.idealDiode2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.idealDiode2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rectifierAC.idealDiode2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rectifierAC.idealDiode2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'rectifierAC.idealDiode2.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'rectifierAC.idealDiode2.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'rectifierAC.idealDiode2.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'rectifierAC.idealDiode2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'rectifierAC.idealDiode2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'rectifierAC.idealDiode2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'rectifierAC.idealDiode2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'rectifierAC.idealDiode2.off'(start = true) "Switching state";
    Real 'rectifierAC.idealDiode2.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'rectifierAC.idealDiode2.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'rectifierAC.idealDiode2.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Real 'rectifierAC.idealDiode3.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
