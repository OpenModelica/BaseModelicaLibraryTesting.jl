//! base 0.1.0
package 'PlanarLoops_analytic'
  type 'Modelica.Mechanics.MultiBody.Types.GravityTypes' = enumeration('NoGravity', 'UniformGravity', 'PointGravity');

  type 'Modelica.Mechanics.MultiBody.Types.ResolveInFrameAB' = enumeration('world', 'frame_a', 'frame_b', 'frame_resolve');

  record 'Modelica.Mechanics.MultiBody.Frames.Orientation'
    Real[3, 3] 'T';
    Real[3] 'w'(unit = fill("rad/s", 3), quantity = fill("AngularVelocity", 3));
  end 'Modelica.Mechanics.MultiBody.Frames.Orientation';

  model 'PlanarLoops_analytic' "Mechanism with three planar kinematic loops and one degree-of-freedom with analytic loop handling (with JointRRR joints)"
    parameter Real 'rh[1]'(unit = "m", quantity = "Length") = 0.5 "Position vector from 'lower left' revolute to 'lower right' revolute joint for all the 3 loops";
    parameter Real 'rh[2]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'lower left' revolute to 'lower right' revolute joint for all the 3 loops";
    parameter Real 'rh[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'lower left' revolute to 'lower right' revolute joint for all the 3 loops";
    parameter Real 'rv[1]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'lower left' revolute to 'upper left' revolute joint in the first loop";
    parameter Real 'rv[2]'(unit = "m", quantity = "Length") = 0.5 "Position vector from 'lower left' revolute to 'upper left' revolute joint in the first loop";
    parameter Real 'rv[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'lower left' revolute to 'upper left' revolute joint in the first loop";
    parameter Real 'r1b[1]'(unit = "m", quantity = "Length") = 0.1 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the first loop";
    parameter Real 'r1b[2]'(unit = "m", quantity = "Length") = 0.5 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the first loop";
    parameter Real 'r1b[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the first loop";
    parameter Real 'r1a[1]'(unit = "m", quantity = "Length") = 0.6 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the first loop";
    parameter Real 'r1a[2]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the first loop";
    parameter Real 'r1a[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the first loop";
    parameter Real 'r2b[1]'(unit = "m", quantity = "Length") = 0.1 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the second loop";
    parameter Real 'r2b[2]'(unit = "m", quantity = "Length") = 0.6 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the second loop";
    parameter Real 'r2b[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the second loop";
    parameter Real 'r2a[1]'(unit = "m", quantity = "Length") = 0.5 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the second loop";
    parameter Real 'r2a[2]'(unit = "m", quantity = "Length") = 0.09999999999999998 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the second loop";
    parameter Real 'r2a[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the second loop";
    parameter Real 'r3b[1]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the third loop";
    parameter Real 'r3b[2]'(unit = "m", quantity = "Length") = 0.55 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the third loop";
    parameter Real 'r3b[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'lower right' revolute to 'upper right' revolute joint in the third loop";
    parameter Real 'r3a[1]'(unit = "m", quantity = "Length") = 0.4 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the third loop";
    parameter Real 'r3a[2]'(unit = "m", quantity = "Length") = -0.04999999999999993 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the third loop";
    parameter Real 'r3a[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from 'upper left' revolute to 'upper right' revolute joint in the third loop";
    Real 'world.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[2,2]' "Transformation matrix from world frame to local frame";
