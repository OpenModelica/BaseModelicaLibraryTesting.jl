    Real 'speedSource.phi'(stateSelect = StateSelect.prefer, fixed = false, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotation angle of flange with respect to support";
    Real 'speedSource.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange with respect to support";
    Real 'speedSource.a'(unit = "rad/s2", quantity = "AngularAcceleration") "If exact=false, angular acceleration of flange with respect to support else dummy";
