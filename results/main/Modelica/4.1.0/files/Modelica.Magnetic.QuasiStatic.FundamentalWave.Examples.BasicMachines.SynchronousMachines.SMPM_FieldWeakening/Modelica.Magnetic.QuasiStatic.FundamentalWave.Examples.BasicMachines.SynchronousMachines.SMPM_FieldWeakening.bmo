    'fieldWeakeningController.PID.I.local_set' = 0.0;
    der('fieldWeakeningController.PID.I.y') = 1e6 * 'fieldWeakeningController.PID.I.u';
    'fieldWeakeningController.PID.gainPID.y' = 'fieldWeakeningController.PID.gainPID.u';
    'fieldWeakeningController.PID.addPID.y' = 'fieldWeakeningController.PID.addPID.u1' + 'fieldWeakeningController.PID.addPID.u2' + 'fieldWeakeningController.PID.addPID.u3';
    'fieldWeakeningController.PID.addI.y' = 'fieldWeakeningController.PID.addI.u1' + (-1.0) * 'fieldWeakeningController.PID.addI.u2' + 'fieldWeakeningController.PID.addI.u3';
    'fieldWeakeningController.PID.addSat.y' = 'fieldWeakeningController.PID.addSat.u1' + (-1.0) * 'fieldWeakeningController.PID.addSat.u2';
    'fieldWeakeningController.PID.gainTrack.y' = 1.1111111111111112 * 'fieldWeakeningController.PID.gainTrack.u';
    'fieldWeakeningController.PID.limiter.simplifiedExpr' = 'fieldWeakeningController.PID.limiter.u';
    'fieldWeakeningController.PID.limiter.y' = homotopy(smooth(0, if 'fieldWeakeningController.PID.limiter.u' > 0.0 then 0.0 else if 'fieldWeakeningController.PID.limiter.u' < (-150.0) then -150.0 else 'fieldWeakeningController.PID.limiter.u'), 'fieldWeakeningController.PID.limiter.simplifiedExpr');
    'fieldWeakeningController.PID.Dzero.y' = 0.0;
    'fieldWeakeningController.PID.FFzero.y' = 0.0;
    'fieldWeakeningController.PID.addFF.y' = 'fieldWeakeningController.PID.addFF.u1' + 'fieldWeakeningController.PID.addFF.u2';
    'fieldWeakeningController.rectangularToPolar.y_abs' = sqrt('fieldWeakeningController.rectangularToPolar.u_re' * 'fieldWeakeningController.rectangularToPolar.u_re' + 'fieldWeakeningController.rectangularToPolar.u_im' * 'fieldWeakeningController.rectangularToPolar.u_im');
    'fieldWeakeningController.rectangularToPolar.y_arg' = atan2('fieldWeakeningController.rectangularToPolar.u_im', 'fieldWeakeningController.rectangularToPolar.u_re');
    'fieldWeakeningController.spacePhasorLimiter.y' = sign('fieldWeakeningController.spacePhasorLimiter.u2') * min(abs('fieldWeakeningController.spacePhasorLimiter.u2'), sqrt(22500.0 - min(150.0, abs('fieldWeakeningController.spacePhasorLimiter.u1')) ^ 2.0));
    'gainCurrent.y' = 150.0 * 'gainCurrent.u';
    'gainSpeed.y' = 157.07963267948966 * 'gainSpeed.u';
    'iqRef.y' = if time < 0.0 then 0.0 else if time < 0.5 then time / 0.5 else 1.0;
    'speed.y' = if time < 0.5 then 0.0 else if time < 2.5 then (time - 0.5) * 4.0 / 2.0 else 4.0;
  initial algorithm
    assert(true, "3 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
    annotation(experiment(StopTime = 2.5, Interval = 0.0001, Tolerance = 1e-06));
  end 'SMPM_FieldWeakening';
end 'SMPM_FieldWeakening';
