//! base 0.1.0
package 'SMPM_FieldWeakening'
  function 'Modelica.Electrical.QuasiStatic.Polyphase.Functions.quasiRMS' "Overall quasi-RMS value of complex input (current or voltage)"
    input 'Complex'[:] 'u';
    output Real 'y';
    Integer 'm' = size('u', 1);
  algorithm
    'y' := sum(sqrt('u['k']'.'re' ^ 2.0 + 'u['k']'.'im' ^ 2.0) for 'k' in 1:'m') / 'm';
    annotation(Inline = true);
  end 'Modelica.Electrical.QuasiStatic.Polyphase.Functions.quasiRMS';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  type 'Modelica.Blocks.Types.SimpleController' = enumeration('P', 'PI', 'PD', 'PID');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  record 'Modelica.Units.SI.ComplexVoltage'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexVoltage';

  record 'Modelica.Units.SI.ComplexCurrent'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexCurrent';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexInput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexInput';

  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  model 'SMPM_FieldWeakening' "Test example: Investigate field weakening of a PermanentMagnetSynchronousMachine"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'INominal'(unit = "A", quantity = "ElectricCurrent") = 150.0 "Nominal RMS current per phase";
    parameter Real 'wNominal'(unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Nominal speed";
    parameter Integer 'smpmData.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'smpmData.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Real 'smpmData.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Integer 'smpmData.p'(min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'smpmData.fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'smpmData.Rs'(unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'smpmData.TsRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'smpmData.alpha20s'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'smpmData.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'smpmData.Lszero'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator zero sequence inductance";
    parameter Real 'smpmData.Lssigma'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'smpmData.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'smpmData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smpmData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smpmData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smpmData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smpmData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smpmData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smpmData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'smpmData.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'smpmData.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'smpmData.statorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'smpmData.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'smpmData.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'smpmData.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'smpmData.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'smpmData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'smpmData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'smpmData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpmData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'smpmData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'smpmData.Lmd'(unit = "H", quantity = "Inductance") = 9.549296585513719e-4 "Stator main field inductance per phase in d-axis";
    parameter Real 'smpmData.Lmq'(unit = "H", quantity = "Inductance") = 9.549296585513719e-4 "Stator main field inductance per phase in q-axis";
    parameter Boolean 'smpmData.useDamperCage' = false "Enable / disable damper cage" annotation(Evaluate = true);
    parameter Real 'smpmData.Lrsigmad'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance in d-axis";
    parameter Real 'smpmData.Lrsigmaq'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance in q-axis";
    parameter Real 'smpmData.Rrd'(unit = "Ohm", quantity = "Resistance") = 0.04 "Damper resistance in d-axis at TRef";
    parameter Real 'smpmData.Rrq'(unit = "Ohm", quantity = "Resistance") = 0.04 "Damper resistance in q-axis at TRef";
    parameter Real 'smpmData.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of damper resistances in d- and q-axis";
    parameter Real 'smpmData.alpha20r'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of damper resistances in d- and q-axis";
    parameter Real 'smpmData.VsOpenCircuit'(unit = "V", quantity = "ElectricPotential") = 80.0 "Open circuit RMS voltage per phase @ fsNominal";
    parameter Real 'smpmData.permanentMagnetLossParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference permanent magnet losses at IRef and wRef";
    parameter Real 'smpmData.permanentMagnetLossParameters.c'(max = 1.0, min = 0.0) = 0.0 "Part of permanent magnet losses at current = 0, i.e. independent of current";
    parameter Real 'smpmData.permanentMagnetLossParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference stator RMS current that PRef refers to";
    parameter Real 'smpmData.permanentMagnetLossParameters.power_I'(min = 2.2250738585072014e-308) = 2.0 "Exponent of permanent magnet loss torque w.r.t. stator current";
    parameter Real 'smpmData.permanentMagnetLossParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpmData.permanentMagnetLossParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of permanent magnet loss torque w.r.t. angular velocity";
    parameter Real 'smpmData.permanentMagnetLossParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference permanent magnet loss torque at reference angular velocity and reference current";
    constant Real 'smpm.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    parameter Integer 'smpm.m'(min = 3) = 3 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'smpm.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Rotor inertia";
    parameter Boolean 'smpm.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'smpm.Js'(start = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator inertia";
    parameter Boolean 'smpm.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Integer 'smpm.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'smpm.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'smpm.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
    parameter Real 'smpm.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'smpm.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'smpm.alpha20s'(start = 0.0, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'smpm.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'smpm.Lssigma'(start = 3.183098861837907e-4, unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'smpm.L0.d'(start = 1.0, unit = "H", quantity = "Inductance") = 6.366197723675813e-4 "Component of d (direct) axis, aligned to real part";
    parameter Real 'smpm.L0.q'(start = 1.0, unit = "H", quantity = "Inductance") = 6.366197723675813e-4 "Component of q (quadrature) axis, aligned to imaginary part";
    parameter Real 'smpm.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smpm.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smpm.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smpm.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smpm.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smpm.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smpm.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'smpm.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'smpm.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'smpm.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'smpm.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'smpm.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'smpm.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'smpm.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'smpm.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'smpm.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'smpm.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpm.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'smpm.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    Real 'smpm.gammas'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of stator reference frame";
    Real 'smpm.gammar'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of stator reference frame";
    Real 'smpm.gamma'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Electrical angle between stator and rotor";
    Real 'smpm.phiMechanical'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Mechanical angle of rotor against stator";
    Real 'smpm.wMechanical'(fixed = false, start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") "Mechanical angular velocity of rotor against stator";
    Real 'smpm.tauElectrical'(unit = "N.m", quantity = "Torque") "Electromagnetic torque";
    Real 'smpm.tauShaft'(unit = "N.m", quantity = "Torque") "Shaft torque";
    Real 'smpm.powerBalance.powerStator'(unit = "W", quantity = "Power") "Electrical power (stator)";
    Real 'smpm.powerBalance.powerMechanical'(unit = "W", quantity = "Power") "Mechanical power";
    Real 'smpm.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") "Stator inertia power";
    Real 'smpm.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") "Rotor inertia power";
    Real 'smpm.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") "Total loss power";
    Real 'smpm.powerBalance.lossPowerStatorWinding'(unit = "W", quantity = "Power") "Stator copper losses";
    Real 'smpm.powerBalance.lossPowerStatorCore'(unit = "W", quantity = "Power") "Stator core losses";
    Real 'smpm.powerBalance.lossPowerRotorCore'(unit = "W", quantity = "Power") "Rotor core losses";
    Real 'smpm.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") "Stray load losses";
    Real 'smpm.powerBalance.lossPowerFriction'(unit = "W", quantity = "Power") "Friction losses";
    Real 'smpm.powerBalance.lossPowerRotorWinding'(unit = "W", quantity = "Power") "Rotor copper losses";
    Real 'smpm.powerBalance.lossPowerPermanentMagnet'(unit = "W", quantity = "Power") "Permanent magnet losses";
    Real 'smpm.vs[1].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'smpm.vs[1].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'smpm.vs[2].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'smpm.vs[2].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'smpm.vs[3].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'smpm.vs[3].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'smpm.abs_vs[1]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'smpm.abs_vs[2]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'smpm.abs_vs[3]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'smpm.arg_vs[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'smpm.arg_vs[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'smpm.arg_vs[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'smpm.is[1].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'smpm.is[1].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'smpm.is[2].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'smpm.is[2].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'smpm.is[3].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'smpm.is[3].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'smpm.abs_is[1]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'smpm.abs_is[2]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'smpm.abs_is[3]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'smpm.arg_is[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'smpm.arg_is[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'smpm.arg_is[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'smpm.Ps[1]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'smpm.Ps[2]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'smpm.Ps[3]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'smpm.Ps_total'(unit = "W", quantity = "Power") "Total active stator power";
    Real 'smpm.Qs[1]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'smpm.Qs[2]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'smpm.Qs[3]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'smpm.Qs_total'(unit = "var", quantity = "Power") "Total reactive stator power";
    Real 'smpm.Ss[1]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'smpm.Ss[2]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'smpm.Ss[3]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'smpm.Ss_total'(unit = "V.A", quantity = "Power") "Magnitude of total complex stator apparent power";
    Real 'smpm.pfs[1]' "Stator power factor";
    Real 'smpm.pfs[2]' "Stator power factor";
    Real 'smpm.pfs[3]' "Stator power factor";
    Real 'smpm.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpm.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smpm.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpm.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smpm.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpm.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'smpm.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Moment of inertia";
    parameter StateSelect 'smpm.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'smpm.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'smpm.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'smpm.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'smpm.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpm.inertiaStator.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smpm.inertiaStator.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpm.inertiaStator.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'smpm.inertiaStator.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'smpm.inertiaStator.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'smpm.inertiaStator.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'smpm.inertiaStator.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'smpm.inertiaStator.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'smpm.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'smpm.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpm.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Integer 'smpm.plug_sp.m' = 3 "Number of phases" annotation(Evaluate = true);
