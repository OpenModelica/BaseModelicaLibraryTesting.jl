  equation
    'smpm.gammas' = 'smpm.airGap.gammas';
    'smpm.gammar' = 'smpm.airGap.gammar';
    'smpm.gamma' = 'smpm.airGap.gamma';
    'smpm.phiMechanical' = 'smpm.flange.phi' - 'smpm.internalSupport.phi';
    'smpm.wMechanical' = der('smpm.phiMechanical');
    'smpm.tauElectrical' = 'smpm.inertiaRotor.flange_a.tau';
    'smpm.tauShaft' = -'smpm.flange.tau';
    'smpm.powerBalance.powerStator' = sum('smpm.vs[(1:size('smpm.vs', 1))['$i1896']].re' * 'smpm.is[(1:size('smpm.vs', 1))['$i1896']].re' - 'smpm.vs[(1:size('smpm.vs', 1))['$i1896']].im' * (-'smpm.is[(1:size('smpm.vs', 1))['$i1896']].im') for '$i1896' in 1:size('smpm.vs', 1));
    'smpm.powerBalance.powerMechanical' = 'smpm.wMechanical' * 'smpm.tauShaft';
    'smpm.powerBalance.powerInertiaStator' = 0.29 * 'smpm.inertiaStator.a' * 'smpm.inertiaStator.w';
    'smpm.powerBalance.powerInertiaRotor' = 0.0;
    'smpm.powerBalance.lossPowerTotal' = 'smpm.powerBalance.lossPowerStatorWinding' + 'smpm.powerBalance.lossPowerStatorCore' + 'smpm.powerBalance.lossPowerRotorCore' + 'smpm.powerBalance.lossPowerStrayLoad' + 'smpm.powerBalance.lossPowerFriction' + 'smpm.powerBalance.lossPowerRotorWinding' + 'smpm.powerBalance.lossPowerPermanentMagnet';
    'smpm.powerBalance.lossPowerStatorWinding' = 'smpm.stator.resistor.resistor[1].LossPower' + 'smpm.stator.resistor.resistor[2].LossPower' + 'smpm.stator.resistor.resistor[3].LossPower';
    'smpm.powerBalance.lossPowerStatorCore' = 'smpm.stator.core.lossPower';
    'smpm.powerBalance.lossPowerRotorCore' = 0.0;
    'smpm.powerBalance.lossPowerStrayLoad' = 'smpm.strayLoad.lossPower';
    'smpm.powerBalance.lossPowerFriction' = 'smpm.friction.lossPower';
    'smpm.powerBalance.lossPowerRotorWinding' = 'smpm.damperCageLossPower';
    'smpm.powerBalance.lossPowerPermanentMagnet' = 'smpm.permanentMagnet.lossPower';
    'smpm.is[1].re' = 'smpm.plug_sp.pin[1].i.re';
    'smpm.is[1].im' = 'smpm.plug_sp.pin[1].i.im';
    'smpm.is[2].re' = 'smpm.plug_sp.pin[2].i.re';
    'smpm.is[2].im' = 'smpm.plug_sp.pin[2].i.im';
    'smpm.is[3].re' = 'smpm.plug_sp.pin[3].i.re';
    'smpm.is[3].im' = 'smpm.plug_sp.pin[3].i.im';
    'smpm.Ps_total' = 'smpm.Ps[1]' + 'smpm.Ps[2]' + 'smpm.Ps[3]';
    'smpm.Qs_total' = 'smpm.Qs[1]' + 'smpm.Qs[2]' + 'smpm.Qs[3]';
    'smpm.Ss_total' = sqrt('smpm.Ps_total' ^ 2.0 + 'smpm.Qs_total' ^ 2.0);
    'smpm.stator.i[1].re' = 'smpm.stator.plug_p.pin[1].i.re';
    'smpm.stator.i[1].im' = 'smpm.stator.plug_p.pin[1].i.im';
    'smpm.stator.i[2].re' = 'smpm.stator.plug_p.pin[2].i.re';
    'smpm.stator.i[2].im' = 'smpm.stator.plug_p.pin[2].i.im';
    'smpm.stator.i[3].re' = 'smpm.stator.plug_p.pin[3].i.re';
    'smpm.stator.i[3].im' = 'smpm.stator.plug_p.pin[3].i.im';
    'smpm.stator.P_total' = 'smpm.stator.P[1]' + 'smpm.stator.P[2]' + 'smpm.stator.P[3]';
    'smpm.stator.Q_total' = 'smpm.stator.Q[1]' + 'smpm.stator.Q[2]' + 'smpm.stator.Q[3]';
    'smpm.stator.S_total' = sqrt('smpm.stator.P_total' ^ 2.0 + 'smpm.stator.Q_total' ^ 2.0);
    'smpm.stator.abs_V_m' = sqrt('smpm.stator.V_m.re' ^ 2.0 + 'smpm.stator.V_m.im' ^ 2.0);
    'smpm.stator.arg_V_m' = 'Modelica.Math.atan3'('smpm.stator.V_m.im', 'smpm.stator.V_m.re', 0.0);
    'smpm.stator.Phi.re' = 'smpm.stator.port_p.Phi.re';
    'smpm.stator.Phi.im' = 'smpm.stator.port_p.Phi.im';
    'smpm.stator.abs_Phi' = sqrt('smpm.stator.Phi.re' ^ 2.0 + 'smpm.stator.Phi.im' ^ 2.0);
    'smpm.stator.arg_Phi' = 'Modelica.Math.atan3'('smpm.stator.Phi.im', 'smpm.stator.Phi.re', 0.0);
    'smpm.stator.electroMagneticConverter.P_total' = 'smpm.stator.electroMagneticConverter.P[1]' + 'smpm.stator.electroMagneticConverter.P[2]' + 'smpm.stator.electroMagneticConverter.P[3]';
    'smpm.stator.electroMagneticConverter.Q_total' = 'smpm.stator.electroMagneticConverter.Q[1]' + 'smpm.stator.electroMagneticConverter.Q[2]' + 'smpm.stator.electroMagneticConverter.Q[3]';
    'smpm.stator.electroMagneticConverter.S_total' = sqrt('smpm.stator.electroMagneticConverter.P_total' ^ 2.0 + 'smpm.stator.electroMagneticConverter.Q_total' ^ 2.0);
    'smpm.stator.electroMagneticConverter.abs_V_m' = sqrt('smpm.stator.electroMagneticConverter.V_m.re' ^ 2.0 + 'smpm.stator.electroMagneticConverter.V_m.im' ^ 2.0);
    'smpm.stator.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('smpm.stator.electroMagneticConverter.V_m.im', 'smpm.stator.electroMagneticConverter.V_m.re', 0.0);
    'smpm.stator.electroMagneticConverter.abs_Phi' = sqrt('smpm.stator.electroMagneticConverter.Phi.re' ^ 2.0 + 'smpm.stator.electroMagneticConverter.Phi.im' ^ 2.0);
    'smpm.stator.electroMagneticConverter.arg_Phi' = 'Modelica.Math.atan3'('smpm.stator.electroMagneticConverter.Phi.im', 'smpm.stator.electroMagneticConverter.Phi.re', 0.0);
    'smpm.stator.electroMagneticConverter.omega' = der('smpm.stator.electroMagneticConverter.port_p.reference.gamma');
    'smpm.stator.resistor.P_total' = 'smpm.stator.resistor.P[1]' + 'smpm.stator.resistor.P[2]' + 'smpm.stator.resistor.P[3]';
    'smpm.stator.resistor.Q_total' = 'smpm.stator.resistor.Q[1]' + 'smpm.stator.resistor.Q[2]' + 'smpm.stator.resistor.Q[3]';
    'smpm.stator.resistor.S_total' = sqrt('smpm.stator.resistor.P_total' ^ 2.0 + 'smpm.stator.resistor.Q_total' ^ 2.0);
    'smpm.stator.resistor.resistor[1].abs_v' = sqrt('smpm.stator.resistor.resistor[1].v.re' ^ 2.0 + 'smpm.stator.resistor.resistor[1].v.im' ^ 2.0);
    'smpm.stator.resistor.resistor[1].arg_v' = 'Modelica.Math.atan3'('smpm.stator.resistor.resistor[1].v.im', 'smpm.stator.resistor.resistor[1].v.re', 0.0);
    'smpm.stator.resistor.resistor[1].abs_i' = sqrt('smpm.stator.resistor.resistor[1].i.re' ^ 2.0 + 'smpm.stator.resistor.resistor[1].i.im' ^ 2.0);
    'smpm.stator.resistor.resistor[1].arg_i' = 'Modelica.Math.atan3'('smpm.stator.resistor.resistor[1].i.im', 'smpm.stator.resistor.resistor[1].i.re', 0.0);
    'smpm.stator.resistor.resistor[1].P' = 'smpm.stator.resistor.resistor[1].v.re' * 'smpm.stator.resistor.resistor[1].i.re' - 'smpm.stator.resistor.resistor[1].v.im' * (-'smpm.stator.resistor.resistor[1].i.im');
    'smpm.stator.resistor.resistor[1].Q' = 'smpm.stator.resistor.resistor[1].v.re' * (-'smpm.stator.resistor.resistor[1].i.im') + 'smpm.stator.resistor.resistor[1].v.im' * 'smpm.stator.resistor.resistor[1].i.re';
    'smpm.stator.resistor.resistor[1].S' = sqrt(('smpm.stator.resistor.resistor[1].v.re' * 'smpm.stator.resistor.resistor[1].i.re' - 'smpm.stator.resistor.resistor[1].v.im' * (-'smpm.stator.resistor.resistor[1].i.im')) ^ 2.0 + ('smpm.stator.resistor.resistor[1].v.re' * (-'smpm.stator.resistor.resistor[1].i.im') + 'smpm.stator.resistor.resistor[1].v.im' * 'smpm.stator.resistor.resistor[1].i.re') ^ 2.0);
    'smpm.stator.resistor.resistor[1].pf' = cos('Modelica.Math.atan3'('smpm.stator.resistor.resistor[1].Q', 'smpm.stator.resistor.resistor[1].P', 0.0));
    'smpm.stator.resistor.resistor[1].heatPort.T' = 'smpm.stator.resistor.resistor[1].T_heatPort';
    'smpm.stator.resistor.resistor[1].heatPort.Q_flow' = -'smpm.stator.resistor.resistor[1].LossPower';
    'smpm.stator.resistor.resistor[2].abs_v' = sqrt('smpm.stator.resistor.resistor[2].v.re' ^ 2.0 + 'smpm.stator.resistor.resistor[2].v.im' ^ 2.0);
    'smpm.stator.resistor.resistor[2].arg_v' = 'Modelica.Math.atan3'('smpm.stator.resistor.resistor[2].v.im', 'smpm.stator.resistor.resistor[2].v.re', 0.0);
    'smpm.stator.resistor.resistor[2].abs_i' = sqrt('smpm.stator.resistor.resistor[2].i.re' ^ 2.0 + 'smpm.stator.resistor.resistor[2].i.im' ^ 2.0);
    'smpm.stator.resistor.resistor[2].arg_i' = 'Modelica.Math.atan3'('smpm.stator.resistor.resistor[2].i.im', 'smpm.stator.resistor.resistor[2].i.re', 0.0);
    'smpm.stator.resistor.resistor[2].P' = 'smpm.stator.resistor.resistor[2].v.re' * 'smpm.stator.resistor.resistor[2].i.re' - 'smpm.stator.resistor.resistor[2].v.im' * (-'smpm.stator.resistor.resistor[2].i.im');
    'smpm.stator.resistor.resistor[2].Q' = 'smpm.stator.resistor.resistor[2].v.re' * (-'smpm.stator.resistor.resistor[2].i.im') + 'smpm.stator.resistor.resistor[2].v.im' * 'smpm.stator.resistor.resistor[2].i.re';
