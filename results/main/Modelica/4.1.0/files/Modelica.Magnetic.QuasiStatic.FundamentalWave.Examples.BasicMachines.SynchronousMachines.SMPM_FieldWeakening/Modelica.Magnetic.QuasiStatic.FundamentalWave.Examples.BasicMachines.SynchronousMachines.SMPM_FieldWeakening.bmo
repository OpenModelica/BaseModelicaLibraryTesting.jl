    parameter Real 'speedSource.w_crit'(unit = "rad/s", quantity = "AngularFrequency") = 314.1592653589793 "Critical frequency";
    parameter Real 'fieldWeakeningController.VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal rms voltage per phase";
