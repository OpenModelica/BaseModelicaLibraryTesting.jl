    parameter Real 'fieldWeakeningController.PID.Nd'(min = 2.220446049250313e-14) = 10.0 "The higher Nd, the more ideal the derivative block";
    parameter Boolean 'fieldWeakeningController.PID.withFeedForward' = false "Use feed-forward input?" annotation(Evaluate = true);
    parameter Real 'fieldWeakeningController.PID.kFF' = 1.0 "Gain of feed-forward input";
