//! base 0.1.0
package 'SphericalConstraint'
  type 'Modelica.Mechanics.MultiBody.Types.ResolveInFrameAB' = enumeration('world', 'frame_a', 'frame_b', 'frame_resolve');

  type 'Modelica.Mechanics.MultiBody.Types.VectorQuantity' = enumeration('Force', 'Torque', 'Velocity', 'Acceleration', 'AngularVelocity', 'AngularAcceleration', 'RelativePosition');

  type 'Modelica.Mechanics.MultiBody.Types.GravityTypes' = enumeration('NoGravity', 'UniformGravity', 'PointGravity');

  type 'Modelica.Mechanics.MultiBody.Types.RotationTypes' = enumeration('RotationAxis', 'TwoAxesVectors', 'PlanarRotationSequence');

  record 'Modelica.Mechanics.MultiBody.Frames.Orientation'
    Real[3, 3] 'T';
    Real[3] 'w'(unit = fill("rad/s", 3), quantity = fill("AngularVelocity", 3));
  end 'Modelica.Mechanics.MultiBody.Frames.Orientation';

  model 'SphericalConstraint' "Body attached by one spring and spherical joint or constrained to environment"
    parameter Boolean 'animation' = true "= true, if animation shall be enabled";
    Real 'joint.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'joint.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'joint.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'joint.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'joint.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'joint.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'joint.frame_a.R.T[2,1]' "Transformation matrix from world frame to local frame";
