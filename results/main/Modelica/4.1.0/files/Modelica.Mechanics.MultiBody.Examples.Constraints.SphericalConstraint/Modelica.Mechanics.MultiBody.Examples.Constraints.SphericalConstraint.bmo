    Real 'joint.frame_a.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'joint.frame_a.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'joint.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'joint.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'joint.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'joint.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'joint.frame_a.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'joint.frame_a.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'joint.frame_a.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'joint.frame_a.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'joint.frame_a.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'joint.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'joint.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'joint.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
