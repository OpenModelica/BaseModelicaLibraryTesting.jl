    Real 'joint.frame_b.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'joint.frame_b.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'joint.frame_b.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'joint.frame_b.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'joint.frame_b.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'joint.frame_b.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'joint.frame_b.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'joint.frame_b.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'joint.frame_b.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'joint.frame_b.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'joint.frame_b.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'joint.frame_b.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    parameter Boolean 'joint.animation' = true "= true, if animation shall be enabled (show sphere)";
    parameter Real 'joint.sphereDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Diameter of sphere representing the spherical joint";
    Integer 'joint.sphereColor[1]'(max = 255, min = 0) "Color of sphere representing the spherical joint";
    Integer 'joint.sphereColor[2]'(max = 255, min = 0) "Color of sphere representing the spherical joint";
    Integer 'joint.sphereColor[3]'(max = 255, min = 0) "Color of sphere representing the spherical joint";
    Real 'joint.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter Boolean 'joint.angles_fixed' = true "= true, if angles_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'joint.angles_start[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate frame_a around 'sequence_start' axes into frame_b";
    parameter Real 'joint.angles_start[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate frame_a around 'sequence_start' axes into frame_b";
    parameter Real 'joint.angles_start[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate frame_a around 'sequence_start' axes into frame_b";
    parameter Integer 'joint.sequence_start[1]'(max = 3, min = 1) = 1 "Sequence of rotations to rotate frame_a into frame_b at initial time" annotation(Evaluate = true);
    parameter Integer 'joint.sequence_start[2]'(max = 3, min = 1) = 2 "Sequence of rotations to rotate frame_a into frame_b at initial time" annotation(Evaluate = true);
    parameter Integer 'joint.sequence_start[3]'(max = 3, min = 1) = 3 "Sequence of rotations to rotate frame_a into frame_b at initial time" annotation(Evaluate = true);
    parameter Boolean 'joint.w_rel_a_fixed' = true "= true, if w_rel_a_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'joint.w_rel_a_start[1]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial values of angular velocity of frame_b with respect to frame_a, resolved in frame_a";
    parameter Real 'joint.w_rel_a_start[2]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial values of angular velocity of frame_b with respect to frame_a, resolved in frame_a";
    parameter Real 'joint.w_rel_a_start[3]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial values of angular velocity of frame_b with respect to frame_a, resolved in frame_a";
    parameter Boolean 'joint.z_rel_a_fixed' = false "= true, if z_rel_a_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'joint.z_rel_a_start[1]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_rel_a = der(w_rel_a)";
    parameter Real 'joint.z_rel_a_start[2]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_rel_a = der(w_rel_a)";
    parameter Real 'joint.z_rel_a_start[3]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_rel_a = der(w_rel_a)";
    parameter Boolean 'joint.enforceStates' = true "= true, if relative variables of spherical joint shall be used as states (StateSelect.always)" annotation(Evaluate = true);
    parameter Boolean 'joint.useQuaternions' = true "= true, if quaternions shall be used as states otherwise use 3 angles as states (provided enforceStates=true)" annotation(Evaluate = true);
    parameter Integer 'joint.sequence_angleStates[1]'(max = 3, min = 1) = 1 "Sequence of rotations to rotate frame_a into frame_b around the 3 angles used as states" annotation(Evaluate = true);
    parameter Integer 'joint.sequence_angleStates[2]'(max = 3, min = 1) = 2 "Sequence of rotations to rotate frame_a into frame_b around the 3 angles used as states" annotation(Evaluate = true);
    parameter Integer 'joint.sequence_angleStates[3]'(max = 3, min = 1) = 3 "Sequence of rotations to rotate frame_a into frame_b around the 3 angles used as states" annotation(Evaluate = true);
    parameter Real 'joint.R_rel_start.T[1,1]' = 1.0 "Transformation matrix from world frame to local frame";
    parameter Real 'joint.R_rel_start.T[1,2]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'joint.R_rel_start.T[1,3]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'joint.R_rel_start.T[2,1]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'joint.R_rel_start.T[2,2]' = 1.0 "Transformation matrix from world frame to local frame";
    parameter Real 'joint.R_rel_start.T[2,3]' = 0.0 "Transformation matrix from world frame to local frame";
