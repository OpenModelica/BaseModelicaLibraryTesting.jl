//! base 0.1.0
package 'Friction'
  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  class 'Modelica.Blocks.Types.ExternalCombiTable1D'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table defined by matrix"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" 'externalCombiTable1D' = ModelicaStandardTables_CombiTable1D_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table defined by matrix"
      input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" ModelicaStandardTables_CombiTable1D_close('externalCombiTable1D') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTable1D';

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  model 'Friction' "Use of model Stop"
    parameter Real 'stop1.smax'(start = 25.0, unit = "m", quantity = "Length") = 25.0 "Right stop for (right end of) sliding mass";
    parameter Real 'stop1.smin'(start = -25.0, unit = "m", quantity = "Length") = -25.0 "Left stop for (left end of) sliding mass";
    parameter Real 'stop1.v_small'(unit = "m/s", quantity = "Velocity") = 0.001 "Relative velocity near to zero (see model info text)";
    Real 'stop1.v_relfric'(unit = "m/s", quantity = "Velocity") "Relative velocity between frictional surfaces";
    Real 'stop1.a_relfric'(unit = "m/s2", quantity = "Acceleration") "Relative acceleration between frictional surfaces";
    Real 'stop1.f'(unit = "N", quantity = "Force") "Friction force (positive, if directed in opposite direction of v_rel)";
    Real 'stop1.f0'(unit = "N", quantity = "Force") "Friction force for v=0 and forward sliding";
    Real 'stop1.f0_max'(unit = "N", quantity = "Force") "Maximum friction force for v=0 and locked";
    Boolean 'stop1.free' "= true, if frictional element is not active";
    Real 'stop1.sa'(unit = "1") "Path parameter of friction characteristic f = f(a_relfric)";
    Boolean 'stop1.startForward'(fixed = true, start = false) "= true, if v_rel=0 and start of forward sliding or v_rel > v_small";
    Boolean 'stop1.startBackward'(fixed = true, start = false) "= true, if v_rel=0 and start of backward sliding or v_rel < -v_small";
    Boolean 'stop1.locked'(start = false) "= true, if v_rel=0 and not sliding";
    Real 'stop1.s'(stateSelect = StateSelect.always, fixed = true, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'stop1.L'(start = 0.0, unit = "m", quantity = "Length") = 1.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'stop1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'stop1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'stop1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'stop1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    constant Integer 'stop1.Unknown' = 3 "Value of mode is not known";
    constant Integer 'stop1.Free' = 2 "Element is not active";
    constant Integer 'stop1.Forward' = 1 "v_rel > 0 (forward sliding)";
    constant Integer 'stop1.Stuck' = 0 "v_rel = 0 (forward sliding, locked or backward sliding)";
    constant Integer 'stop1.Backward' = -1 "v_rel < 0 (backward sliding)";
    Integer 'stop1.mode'(fixed = true, start = 3, max = 3, min = -1) "Mode of friction (-1: backward sliding, 0: stuck, 1: forward sliding, 2: inactive, 3: unknown)";
    constant Real 'stop1.unitAcceleration'(unit = "m/s2", quantity = "Acceleration") = 1.0;
    constant Real 'stop1.unitForce'(unit = "N", quantity = "Force") = 1.0;
    Real 'stop1.v'(stateSelect = StateSelect.always, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of flange_a and flange_b";
    Real 'stop1.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of flange_a and flange_b";
    parameter Real 'stop1.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass";
    parameter Real 'stop1.F_prop'(start = 1.0, min = 0.0, unit = "N.s/m") = 1.0 "Velocity dependent friction";
    parameter Real 'stop1.F_Coulomb'(start = 5.0, unit = "N", quantity = "Force") = 5.0 "Constant friction: Coulomb force";
    parameter Real 'stop1.F_Stribeck'(start = 10.0, unit = "N", quantity = "Force") = 10.0 "Stribeck effect";
    parameter Real 'stop1.fexp'(start = 2.0, min = 0.0, unit = "s/m") = 2.0 "Exponential decay";
    parameter Boolean 'stop1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'stop1.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Integer 'stop1.stopped' "Mode of stop (-1: hard stop at flange_a, 0: no stop, +1: hard stop at flange_b";
    parameter Boolean 'force.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'force.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'force.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'force.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'force.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'force.f'(unit = "N") "Driving force as input signal";
    parameter Real 'sineForce.amplitude' = 25.0 "Amplitude of sine wave";
    parameter Real 'sineForce.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 0.25 "Frequency of sine wave";
    parameter Real 'sineForce.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sineForce.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineForce.y' "Connector of Real output signal";
    parameter Real 'sineForce.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineForce.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'stop2.smax'(start = 25.0, unit = "m", quantity = "Length") = 0.9 "Right stop for (right end of) sliding mass";
    parameter Real 'stop2.smin'(start = -25.0, unit = "m", quantity = "Length") = -0.9 "Left stop for (left end of) sliding mass";
