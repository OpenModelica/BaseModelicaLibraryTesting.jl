    Real 'supportFriction.a'(unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of flange_a and flange_b";
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'supportFriction.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 15.0}, {0.24489795918367346, 11.372412286561172}, {0.4897959183673469, 9.244439101588995}, {0.7346938775510204, 8.03535686748911}, {0.9795918367346939, 7.389326380065974}, {1.2244897959183674, 7.088306657124507}, {1.469387755102041, 6.998692774429128}, {1.7142857142857142, 7.03861812323367}, {1.9591836734693877, 7.157918821735533}, {2.204081632653061, 7.325856879488491}, {2.4489795918367347, 7.523597548807137}, {2.693877551020408, 7.739599811061987}, {2.938775510204082, 7.9667918905525665}, {3.183673469387755, 8.200840546586416}, {3.4285714285714284, 8.439090579720828}, {3.673469387755102, 8.67991501269308}, {3.9183673469387754, 8.922316912854413}, {4.163265306122449, 9.165685408295948}, {4.408163265306122, 9.409646186380305}, {4.653061224489796, 9.653969886502638}, {4.8979591836734695, 9.898515967623712}, {5.142857142857143, 10.14319831302038}, {5.387755102040816, 10.387964154547149}, {5.63265306122449, 10.632781158447262}, {5.877551020408164, 10.877629512164946}, {6.122448979591836, 11.122497075528264}, {6.36734693877551, 11.367376409629465}, {6.612244897959184, 11.612262956267168}, {6.857142857142857, 11.857153922396948}, {7.1020408163265305, 12.102047596576828}, {7.346938775510204, 12.346942930118287}, {7.591836734693878, 12.591839280435934}, {7.836734693877551, 12.836736253784643}, {8.081632653061224, 13.08163360889653}, {8.326530612244898, 13.32653119793435}, {8.571428571428571, 13.571428930310622}, {8.816326530612244, 13.816326750517735}, {9.061224489795919, 14.061224624543323}, {9.306122448979592, 14.306122531546256}, {9.551020408163266, 14.551020458756108}, {9.795918367346939, 14.795918398347776}, {10.040816326530612, 15.04081634552642}, {10.285714285714286, 15.285714297353994}, {10.53061224489796, 15.530612252030208}, {10.775510204081632, 15.775510208451927}, {11.020408163265307, 16.020408165943213}, {11.26530612244898, 16.265306124089868}, {11.510204081632653, 16.510204082638108}, {11.755102040816327, 16.75510204143242}, {12.0, 17.000000000377515}}, {2}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object for sliding friction coefficient";
    Real 'supportFriction.table_signs[1]' "Signs for sliding friction coefficient table interpolation: [sign for v, sign for f]";
    Real 'supportFriction.table_signs[2]' "Signs for sliding friction coefficient table interpolation: [sign for v, sign for f]";
  equation
    'spring.flange_b.s' = 'stop2.flange_a.s';
    'sineForce.y' = 'force2.f';
    'sineForce.y' = 'force.f';
    'spring.flange_a.s' = 'fixed2.flange.s';
    'force.flange.s' = 'stop1.flange_a.s';
    'force2.flange.s' = 'mass.flange_a.s';
    'mass.flange_b.s' = 'supportFriction.flange_a.s';
    'stop1.flange_b.f' = 0.0;
    'force.flange.f' + 'stop1.flange_a.f' = 0.0;
    'stop2.flange_b.f' = 0.0;
    'fixed2.flange.f' + 'spring.flange_a.f' = 0.0;
    'spring.flange_b.f' + 'stop2.flange_a.f' = 0.0;
    'mass.flange_a.f' + 'force2.flange.f' = 0.0;
    'supportFriction.flange_a.f' + 'mass.flange_b.f' = 0.0;
    'supportFriction.flange_b.f' = 0.0;
    'stop1.f0' = 15.0;
    'stop1.f0_max' = 'stop1.f0' * 1.001;
    'stop1.free' = false;
    'stop1.v' = der('stop1.s');
    'stop1.a' = der('stop1.v');
    'stop1.v_relfric' = 'stop1.v';
    'stop1.a_relfric' = 'stop1.a';
    0.0 = 'stop1.flange_a.f' + 'stop1.flange_b.f' - 'stop1.f' - der('stop1.v');
    'stop1.f' = if 'stop1.locked' then 'stop1.sa' else if 'stop1.free' then 0.0 else if 'stop1.startForward' then 'stop1.v' + 5.0 + 10.0 else if 'stop1.startBackward' then 'stop1.v' - 5.0 - 10.0 else if pre('stop1.mode') == 1 then 'stop1.v' + 5.0 + 10.0 * exp(-2.0 * abs('stop1.v')) else 'stop1.v' - 5.0 - 10.0 * exp(-2.0 * abs('stop1.v'));
    'stop1.lossPower' = 'stop1.f' * 'stop1.v_relfric';

    when initial() then
      assert('stop1.s' > (-24.5) or 'stop1.s' >= (-24.5) and 'stop1.v' >= 0.0, "Error in initialization of hard stop. (s - L/2) must be >= smin\n" + "(s=" + String('stop1.s') + ", L=" + String(1.0) + ", smin=" + String(-25.0) + ")", AssertionLevel.error);
      assert('stop1.s' < 24.5 or 'stop1.s' <= 24.5 and 'stop1.v' <= 0.0, "Error in initialization of hard stop. (s + L/2) must be <= smax\n" + "(s=" + String('stop1.s') + ", L=" + String(1.0) + ", smax=" + String(25.0) + ")", AssertionLevel.error);
    end when;

    'stop1.stopped' = if 'stop1.s' <= (-24.5) then -1 else if 'stop1.s' >= 24.5 then 1 else 0;

    when 'stop1.stopped' <> 0 then
      reinit('stop1.s', if 'stop1.stopped' < 0 then -24.5 else 24.5);
      reinit('stop1.v', 0.0);
    end when;

    'stop1.startForward' = (pre('stop1.mode') == 0 and ('stop1.sa' > 'stop1.f0_max' and 'stop1.s' < 24.5 or (pre('stop1.startForward') and 'stop1.sa' > 'stop1.f0') and 'stop1.s' < 24.5) or pre('stop1.mode') == (-1) and 'stop1.v_relfric' > 0.001) or initial() and 'stop1.v_relfric' > 0.0;
    'stop1.startBackward' = (pre('stop1.mode') == 0 and ('stop1.sa' < (-'stop1.f0_max') and 'stop1.s' > (-24.5) or (pre('stop1.startBackward') and 'stop1.sa' < (-'stop1.f0')) and 'stop1.s' > (-24.5)) or pre('stop1.mode') == 1 and 'stop1.v_relfric' < (-0.001)) or initial() and 'stop1.v_relfric' < 0.0;
    'stop1.locked' = not 'stop1.free' and not (((pre('stop1.mode') == 1 or 'stop1.startForward') or pre('stop1.mode') == (-1)) or 'stop1.startBackward');
    'stop1.a_relfric' = if 'stop1.locked' then 0.0 else if 'stop1.free' then 'stop1.sa' else if 'stop1.startForward' then 'stop1.sa' - 'stop1.f0_max' else if 'stop1.startBackward' then 'stop1.sa' + 'stop1.f0_max' else if pre('stop1.mode') == 1 then 'stop1.sa' - 'stop1.f0_max' else 'stop1.sa' + 'stop1.f0_max';
    'stop1.mode' = if 'stop1.free' then 2 else if (((pre('stop1.mode') == 1 or pre('stop1.mode') == 2) or 'stop1.startForward') and 'stop1.v_relfric' > 0.0) and 'stop1.s' < 24.5 then 1 else if (((pre('stop1.mode') == (-1) or pre('stop1.mode') == 2) or 'stop1.startBackward') and 'stop1.v_relfric' < 0.0) and 'stop1.s' > (-24.5) then -1 else 0;
    'stop1.flange_a.s' = 'stop1.s' - 0.5;
    'stop1.flange_b.s' = 'stop1.s' + 0.5;
    'force.flange.f' = -'force.f';
    'force.s' = 'force.flange.s' - 'force.s_support';
    'force.s_support' = 0.0;
    'sineForce.y' = if time < 0.0 then 0.0 else 25.0 * sin(1.5707963267948966 * time);
    'stop2.f0' = 8.0;
    'stop2.f0_max' = 'stop2.f0' * 1.001;
    'stop2.free' = false;
    'stop2.v' = der('stop2.s');
    'stop2.a' = der('stop2.v');
    'stop2.v_relfric' = 'stop2.v';
    'stop2.a_relfric' = 'stop2.a';
    0.0 = 'stop2.flange_a.f' + 'stop2.flange_b.f' - 'stop2.f' - der('stop2.v');
    'stop2.f' = if 'stop2.locked' then 'stop2.sa' else if 'stop2.free' then 0.0 else if 'stop2.startForward' then 'stop2.v' + 3.0 + 5.0 else if 'stop2.startBackward' then 'stop2.v' - 3.0 - 5.0 else if pre('stop2.mode') == 1 then 'stop2.v' + 3.0 + 5.0 * exp(-2.0 * abs('stop2.v')) else 'stop2.v' - 3.0 - 5.0 * exp(-2.0 * abs('stop2.v'));
    'stop2.lossPower' = 'stop2.f' * 'stop2.v_relfric';

    when initial() then
      assert('stop2.s' > (-0.4) or 'stop2.s' >= (-0.4) and 'stop2.v' >= 0.0, "Error in initialization of hard stop. (s - L/2) must be >= smin\n" + "(s=" + String('stop2.s') + ", L=" + String(1.0) + ", smin=" + String(-0.9) + ")", AssertionLevel.error);
      assert('stop2.s' < 0.4 or 'stop2.s' <= 0.4 and 'stop2.v' <= 0.0, "Error in initialization of hard stop. (s + L/2) must be <= smax\n" + "(s=" + String('stop2.s') + ", L=" + String(1.0) + ", smax=" + String(0.9) + ")", AssertionLevel.error);
    end when;

    'stop2.stopped' = if 'stop2.s' <= (-0.4) then -1 else if 'stop2.s' >= 0.4 then 1 else 0;

    when 'stop2.stopped' <> 0 then
      reinit('stop2.s', if 'stop2.stopped' < 0 then -0.4 else 0.4);
      reinit('stop2.v', 0.0);
    end when;

    'stop2.startForward' = (pre('stop2.mode') == 0 and ('stop2.sa' > 'stop2.f0_max' and 'stop2.s' < 0.4 or (pre('stop2.startForward') and 'stop2.sa' > 'stop2.f0') and 'stop2.s' < 0.4) or pre('stop2.mode') == (-1) and 'stop2.v_relfric' > 0.001) or initial() and 'stop2.v_relfric' > 0.0;
    'stop2.startBackward' = (pre('stop2.mode') == 0 and ('stop2.sa' < (-'stop2.f0_max') and 'stop2.s' > (-0.4) or (pre('stop2.startBackward') and 'stop2.sa' < (-'stop2.f0')) and 'stop2.s' > (-0.4)) or pre('stop2.mode') == 1 and 'stop2.v_relfric' < (-0.001)) or initial() and 'stop2.v_relfric' < 0.0;
    'stop2.locked' = not 'stop2.free' and not (((pre('stop2.mode') == 1 or 'stop2.startForward') or pre('stop2.mode') == (-1)) or 'stop2.startBackward');
    'stop2.a_relfric' = if 'stop2.locked' then 0.0 else if 'stop2.free' then 'stop2.sa' else if 'stop2.startForward' then 'stop2.sa' - 'stop2.f0_max' else if 'stop2.startBackward' then 'stop2.sa' + 'stop2.f0_max' else if pre('stop2.mode') == 1 then 'stop2.sa' - 'stop2.f0_max' else 'stop2.sa' + 'stop2.f0_max';
    'stop2.mode' = if 'stop2.free' then 2 else if (((pre('stop2.mode') == 1 or pre('stop2.mode') == 2) or 'stop2.startForward') and 'stop2.v_relfric' > 0.0) and 'stop2.s' < 0.4 then 1 else if (((pre('stop2.mode') == (-1) or pre('stop2.mode') == 2) or 'stop2.startBackward') and 'stop2.v_relfric' < 0.0) and 'stop2.s' > (-0.4) then -1 else 0;
    'stop2.flange_a.s' = 'stop2.s' - 0.5;
    'stop2.flange_b.s' = 'stop2.s' + 0.5;
    'spring.f' = 500.0 * ('spring.s_rel' - 1.0);
    'spring.s_rel' = 'spring.flange_b.s' - 'spring.flange_a.s';
    'spring.flange_b.f' = 'spring.f';
    'spring.flange_a.f' = -'spring.f';
    'fixed2.flange.s' = -1.75;
    'force2.flange.f' = -'force2.f';
    'force2.s' = 'force2.flange.s' - 'force2.s_support';
    'force2.s_support' = 0.0;
    'mass.v' = der('mass.s');
    'mass.a' = der('mass.v');
    'mass.a' = 'mass.flange_a.f' + 'mass.flange_b.f';
    'mass.flange_a.s' = 'mass.s' - 0.5;
    'mass.flange_b.s' = 'mass.s' + 0.5;
    'supportFriction.f0' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('supportFriction.tableID', 1, 0.0);
    'supportFriction.f0_max' = 'supportFriction.f0';
    'supportFriction.free' = false;
    'supportFriction.s' = 'supportFriction.flange_a.s' - 'supportFriction.s_support';
    'supportFriction.flange_a.s' = 'supportFriction.flange_b.s';
    'supportFriction.v' = der('supportFriction.s');
    'supportFriction.a' = der('supportFriction.v');
    'supportFriction.v_relfric' = 'supportFriction.v';
    'supportFriction.a_relfric' = 'supportFriction.a';
    'supportFriction.flange_a.f' + 'supportFriction.flange_b.f' - 'supportFriction.f' = 0.0;
    'supportFriction.table_signs[1]' = if 'supportFriction.startForward' then 1.0 else if 'supportFriction.startBackward' then -1.0 else if pre('supportFriction.mode') == 1 then 1.0 else -1.0;
    'supportFriction.table_signs[2]' = if 'supportFriction.startForward' then 1.0 else if 'supportFriction.startBackward' then -1.0 else if pre('supportFriction.mode') == 1 then 1.0 else -1.0;
    'supportFriction.f' = if 'supportFriction.locked' then 'supportFriction.sa' else 'supportFriction.table_signs[2]' * 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('supportFriction.tableID', 1, 'supportFriction.table_signs[1]' * 'supportFriction.v');
    'supportFriction.lossPower' = 'supportFriction.f' * 'supportFriction.v_relfric';
    'supportFriction.startForward' = (pre('supportFriction.mode') == 0 and ('supportFriction.sa' > 'supportFriction.f0_max' or pre('supportFriction.startForward') and 'supportFriction.sa' > 'supportFriction.f0') or pre('supportFriction.mode') == (-1) and 'supportFriction.v_relfric' > 0.001) or initial() and 'supportFriction.v_relfric' > 0.0;
    'supportFriction.startBackward' = (pre('supportFriction.mode') == 0 and ('supportFriction.sa' < (-'supportFriction.f0_max') or pre('supportFriction.startBackward') and 'supportFriction.sa' < (-'supportFriction.f0')) or pre('supportFriction.mode') == 1 and 'supportFriction.v_relfric' < (-0.001)) or initial() and 'supportFriction.v_relfric' < 0.0;
    'supportFriction.locked' = not 'supportFriction.free' and not (((pre('supportFriction.mode') == 1 or 'supportFriction.startForward') or pre('supportFriction.mode') == (-1)) or 'supportFriction.startBackward');
    'supportFriction.a_relfric' = if 'supportFriction.locked' then 0.0 else if 'supportFriction.free' then 'supportFriction.sa' else if 'supportFriction.startForward' then 'supportFriction.sa' - 'supportFriction.f0_max' else if 'supportFriction.startBackward' then 'supportFriction.sa' + 'supportFriction.f0_max' else if pre('supportFriction.mode') == 1 then 'supportFriction.sa' - 'supportFriction.f0_max' else if pre('supportFriction.mode') == (-1) then 'supportFriction.sa' + 'supportFriction.f0_max' else 'supportFriction.sa' - sign('supportFriction.v_relfric') * 'supportFriction.f0_max';
    'supportFriction.mode' = if 'supportFriction.free' then 2 else if ((pre('supportFriction.mode') == 1 or pre('supportFriction.mode') == 2) or 'supportFriction.startForward') and 'supportFriction.v_relfric' > 0.0 then 1 else if ((pre('supportFriction.mode') == (-1) or pre('supportFriction.mode') == 2) or 'supportFriction.startBackward') and 'supportFriction.v_relfric' < 0.0 then -1 else 0;
    'supportFriction.s_a' = 'supportFriction.flange_a.s' - 'supportFriction.s_support';
    'supportFriction.s_b' = 'supportFriction.flange_b.s' - 'supportFriction.s_support';
    'supportFriction.s_support' = 0.0;
    annotation(experiment(StopTime = 5.0, Interval = 0.001));
  end 'Friction';
end 'Friction';
