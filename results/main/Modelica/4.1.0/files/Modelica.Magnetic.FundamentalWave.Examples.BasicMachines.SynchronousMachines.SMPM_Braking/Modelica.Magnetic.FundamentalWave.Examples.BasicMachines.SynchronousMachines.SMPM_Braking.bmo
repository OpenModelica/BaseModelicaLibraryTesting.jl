    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[1].n.i' = 0.0;
    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[1].v' = 'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[1].p.v' - 'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[1].n.v';
    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[2].p.i' = 0.0;
    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[2].n.i' = 0.0;
    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[2].v' = 'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[2].p.v' - 'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[2].n.v';
    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[3].p.i' = 0.0;
    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[3].n.i' = 0.0;
    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[3].v' = 'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[3].p.v' - 'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[3].n.v';
    'voltageQuasiRMSSensor.Gain1.y' = 0.7071067811865475 * 'voltageQuasiRMSSensor.Gain1.u';
    3.0 * 'voltageQuasiRMSSensor.ToSpacePhasor1.zero' = 'voltageQuasiRMSSensor.ToSpacePhasor1.u[1]' + 'voltageQuasiRMSSensor.ToSpacePhasor1.u[2]' + 'voltageQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'voltageQuasiRMSSensor.ToSpacePhasor1.y[1]' = 0.6666666666666666 * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[1]' + (-0.33333333333333315) * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[2]' + (-0.3333333333333336) * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'voltageQuasiRMSSensor.ToSpacePhasor1.y[2]' = 0.5773502691896257 * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[2]' + (-0.5773502691896255) * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'voltageQuasiRMSSensor.ToPolar1.y[1]' = sqrt('voltageQuasiRMSSensor.ToPolar1.u[1]' ^ 2.0 + 'voltageQuasiRMSSensor.ToPolar1.u[2]' ^ 2.0);
    'voltageQuasiRMSSensor.ToPolar1.y[2]' = if noEvent('voltageQuasiRMSSensor.ToPolar1.y[1]' <= 2.2250738585072014e-308) then 0.0 else 'Modelica.Math.atan2'('voltageQuasiRMSSensor.ToPolar1.u[2]', 'voltageQuasiRMSSensor.ToPolar1.u[1]');
    'grounding.R_actual' = 1e6;
    'grounding.v' = 'grounding.R_actual' * 'grounding.i';
    'grounding.LossPower' = 'grounding.v' * 'grounding.i';
    'grounding.T_heatPort' = 300.15;
    0.0 = 'grounding.p.i' + 'grounding.n.i';
    'grounding.i' = 'grounding.p.i';
    'grounding.v' = 'grounding.p.v' - 'grounding.n.v';
  initial algorithm
    assert(true, "3 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
    annotation(experiment(StopTime = 0.8, Interval = 1E-4, Tolerance = 1e-06));
  end 'SMPM_Braking';
end 'SMPM_Braking';
