//! base 0.1.0
package 'Inverse_sh_TX'
  record 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'
    Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[2] 'X'(nominal = fill(0.1, 2), start = {0.01, 0.99}, max = fill(1.0, 2), min = fill(0.0, 2), unit = fill("kg/kg", 2), quantity = fill("MassFraction", 2));
  end 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState';

  model 'Inverse_sh_TX' "Solve h = h_pTX(p, T, X), s = s_pTX(p, T, X) for T, if h or s is given"
    parameter Real 'T_min'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.0 "Vary temperature linearly from T_min (time=0) up to T_max (time=1)";
    parameter Real 'T_max'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 500.0 "Vary temperature linearly from T_min (time=0) up to T_max (time=1)";
    parameter Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Fixed pressure in model";
    parameter Real 'X[1]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.01 "Mass fraction vector";
    parameter Real 'X[2]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.99 "Mass fraction vector";
    parameter Real 'h_min'(unit = "J/kg", quantity = "SpecificEnergy") = 52261.144481212395 "Specific enthalpy at T_min";
    parameter Real 'h_max'(unit = "J/kg", quantity = "SpecificEnergy") = 257184.95627511968 "Specific enthalpy at T_max";
    parameter Real 's_min'(unit = "J/(kg.K)", quantity = "SpecificEntropy") = 350.79196547721216 "Specific entropy at T_min";
    parameter Real 's_max'(unit = "J/(kg.K)", quantity = "SpecificEntropy") = 873.679734248472 "Specific entropy at T_max";
    Real 'h1'(unit = "J/kg", quantity = "SpecificEnergy") "Pre-defined specific enthalpy";
    Real 'h2'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy computed from T (= h1 required)";
    Real 's1'(unit = "J/(kg.K)", quantity = "SpecificEntropy") "Pre-defined specific entropy";
    Real 's2'(unit = "J/(kg.K)", quantity = "SpecificEntropy") "Specific entropy computed from T (= h1 required)";
    Real 'Th'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature computed from h1";
    Real 'Ts'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature computed from s1";
    constant Real 'timeUnit'(unit = "s", quantity = "Time") = 1.0;
  equation
    'h1' = if time < 0.0 then 52261.144481212395 else if time >= 1.0 then 257184.95627511968 else 52261.144481212395 + time * 204923.81179390728;
    's1' = if time < 0.0 then 350.79196547721216 else if time >= 1.0 then 873.679734248472 else 350.79196547721216 + time * 522.8877687712597;
    'Th' = (if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX'(1e5, 'h1', {0.01, 0.99}), {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_phX'(1e5, 'h1', {0.01, 0.99}), cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).T;
    'Ts' = (if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_psX'(1e5, 's1', {0.01, 0.99}), {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Inverses.T_psX'(1e5, 's1', {0.01, 0.99}), cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).T;
    'h2' = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX'((if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Th', {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Th', cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).p, (if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Th', {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Th', cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).T, {((if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Th', {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Th', cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).X)[1], ((if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Th', {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Th', cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).X)[2]});
    's2' = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.s_pTX'((if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Ts', {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Ts', cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).p, (if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Ts', {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Ts', cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).T, {((if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Ts', {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Ts', cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).X)[1], ((if size({0.01, 0.99}, 1) == 2 then 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Ts', {0.01, 0.99}) else 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState'(1e5, 'Ts', cat(1, {0.01, 0.99}, {1.0 - sum({0.01, 0.99})}))).X)[2]});
    assert(abs('h1' - 'h2') < 0.001, "Inverse for h not correctly computed", AssertionLevel.error);
    assert(abs('s1' - 's2') < 0.001, "Inverse for s not correctly computed", AssertionLevel.error);
    annotation(experiment(StopTime = 1));
  end 'Inverse_sh_TX';
end 'Inverse_sh_TX';
