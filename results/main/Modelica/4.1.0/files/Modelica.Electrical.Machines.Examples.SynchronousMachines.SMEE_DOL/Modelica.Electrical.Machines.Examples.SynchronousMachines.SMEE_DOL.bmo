    Real 'smee.idq_ss[1]'(unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / stator fixed frame";
    Real 'smee.idq_ss[2]'(unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / stator fixed frame";
    Real 'smee.idq_sr[1]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / rotor fixed frame";
    Real 'smee.idq_sr[2]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / rotor fixed frame";
