    parameter Real 'resistor.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 20.0 "Resistance at temperature T_ref";
    parameter Real 'resistor.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'inductor.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inductor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.i'(fixed = true, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inductor.L'(start = 1.0, unit = "H", quantity = "Inductance") = 1.0 "Inductance";
    parameter Real 'constantVoltage.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = -120.0 "Value of constant voltage";
    Real 'constantVoltage.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'constantVoltage.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'constantVoltage.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'constantVoltage.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'constantVoltage.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'constantVoltage.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
  initial equation
    'meanVoltage.t0' = time;
    'meanVoltage.x' = 0.0;
    'meanVoltage.y_last' = 0.0;
    'rootMeanSquareVoltage.mean.t0' = time;
    'rootMeanSquareVoltage.mean.x' = 0.0;
    'rootMeanSquareVoltage.mean.y_last' = 0.0;
    'meanCurrent.t0' = time;
    'meanCurrent.x' = 0.0;
    'meanCurrent.y_last' = 0.0;
    pre('pulse2.twoPulse.timerPositive[1].entryTime') = 0.0;
    pre('pulse2.twoPulse.timerNegative[1].entryTime') = 0.0;
  equation
    'rectifier.vAC' = 'rectifier.ac_p.v' - 'rectifier.ac_n.v';
    'rectifier.iAC' = 'rectifier.ac_p.i';
    'rectifier.powerAC' = 'rectifier.vAC' * 'rectifier.iAC';
    'rectifier.vDC' = 'rectifier.dc_p.v';
    'rectifier.iDC' = 'rectifier.dc_p.i';
    'rectifier.powerDC' = 'rectifier.vDC' * 'rectifier.iDC';
    'rectifier.enableLogic.internalEnable[1]' = 'rectifier.enableLogic.booleanReplicator.y[1]';
    'rectifier.enableLogic.enableConstantSource.y' = 'rectifier.enableLogic.booleanReplicator.u';
    'rectifier.ac_p.v' = 'rectifier.thyristor_p.p.v';
    'rectifier.thyristor_p.p.i' - 'rectifier.ac_p.i' = 0.0;
    'rectifier.ac_n.v' = 'rectifier.thyristor_n.p.v';
    'rectifier.thyristor_n.p.i' - 'rectifier.ac_n.i' = 0.0;
    'rectifier.thyristor_n.n.v' = 'rectifier.dc_p.v';
    'rectifier.thyristor_n.n.v' = 'rectifier.thyristor_p.n.v';
    'rectifier.andCondition_p.y' = 'rectifier.thyristor_p.fire';
    'rectifier.andCondition_n.y' = 'rectifier.thyristor_n.fire';
    'rectifier.fire_n' = 'rectifier.andCondition_n.u1';
    'rectifier.enableLogic.internalEnable[1]' = 'rectifier.andCondition_p.u2';
    'rectifier.enableLogic.internalEnable[1]' = 'rectifier.andCondition_n.u2';
    'rectifier.andCondition_p.u1' = 'rectifier.fire_p';
    'rootMeanSquareVoltage.product.y' = 'rootMeanSquareVoltage.mean.u';
    'rootMeanSquareVoltage.mean.y' = 'rootMeanSquareVoltage.sqrt1.u';
    'rootMeanSquareVoltage.sqrt1.y' = 'rootMeanSquareVoltage.y';
    'rootMeanSquareVoltage.u' = 'rootMeanSquareVoltage.product.u[2]';
    'rootMeanSquareVoltage.u' = 'rootMeanSquareVoltage.product.u[1]';
