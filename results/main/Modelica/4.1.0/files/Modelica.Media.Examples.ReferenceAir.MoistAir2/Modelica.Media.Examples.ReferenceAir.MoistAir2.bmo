//! base 0.1.0
package 'MoistAir2'
  function 'Modelica.Media.Air.ReferenceMoistAir.xsaturation' "Return absolute humidity per unit mass of dry air at saturation as a function of the thermodynamic state record"
    input 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState' 'state';
    output Real 'x_sat'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction");
  algorithm
    'x_sat' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.xws_pT'('state'.'p', 'state'.'T');
    assert('x_sat' > (-1.0), "Calculation of absolute humidity is meaningless\nfor input pressure p = " + String('state'.'p') + " Pa and temperature T = " + String('state'.'T') + " K.", AssertionLevel.error);
  end 'Modelica.Media.Air.ReferenceMoistAir.xsaturation';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir2.ambient.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'ambient.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'ambient.Medium.ThermodynamicState'('p', 'T', 'X') else 'ambient.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir2.ambient.Medium.setState_pTX';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pds_pT_der' "Derivative of saturation partial pressure of steam"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'p_der';
    input Real 'T_der';
    output Real 'pds_der';
    Real 'Tlim';
  algorithm
    if 'T' >= 273.16 then
      'pds_der' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.psat_der'('T', 'T_der');
      'Tlim' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.Tsat'('p');
    else
      'pds_der' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub_der'('T', 'T_der');
      'Tlim' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Tsub'('p');
    end if;

    if 'T' <= 'Tlim' then
      'pds_der' := 'pds_der';
    else
      'pds_der' := 'p_der';
    end if;
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pds_pT_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX' "Specific enthalpy of moist air"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'xw';
    Real 'xws';
    Real 'pd';
    Real 'pl';
  algorithm
    if 'X'[1] == 0.0 then
      'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('p', 'T');
    else
      'pd' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pd_pTX'('p', 'T', 'X');
      'pl' := 'p' - 'pd';
      'xw' := 'X'[1] / (1.0 - 'X'[1]);
      'xws' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.xws_pT'('p', 'T');

      if 'xw' <= 'xws' or 'xws' == (-1.0) then
        if 'T' >= 773.15 then
          'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('pl', 'T') + 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + (1.0 + 'xw') * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_dis_pTX'('p', 'T', 'X');
        else
          'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('pl', 'T') + 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0);
        end if;
      else
        if 'T' < 273.16 then
          'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('pl', 'T') + 'xws' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + ('xw' - 'xws') * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT'('p', 'T');
        else
          'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('pl', 'T') + 'xws' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + ('xw' - 'xws') * 'Modelica.Media.Water.IF97_Utilities.h_pT'('p', 'T', 0);
        end if;
      end if;

      'h' := 'h' / (1.0 + 'xw');
    end if;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.rho_pTX_der' "Derivative of density as a function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    input Real 'p_der';
    input Real 'T_der';
    input Real[:] 'X_der';
    output Real 'd_der';
    Real 'pd';
    Real 'pd_der';
    Real 'pl';
    Real 'pl_der';
    Real 'xw';
    Real 'xw_der';
    Real 'xws';
    Real 'xws_der';
    Real[5] 'o';
  algorithm
    if 'X'[1] == 0.0 then
      'd_der' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT_der'('p', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('p', 'T'), 'p_der', 'T_der');
    else
      'xw' := 'X'[1] / (1.0 - 'X'[1]);
      'xw_der' := 'X_der'[1] / (1.0 - 'X'[1]) ^ 2.0;
      'xws' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.xws_pT'('p', 'T');
      'xws_der' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.xws_pT_der'('p', 'T', 'p_der', 'T_der');
      'pd' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pd_pTX'('p', 'T', 'X');
      'pd_der' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pd_pTX_der'('p', 'T', 'X', 'p_der', 'T_der', 'X_der');
      'pl' := 'p' - 'pd';
      'pl_der' := 'p_der' - 'pd_der';

      if 'xw' <= 'xws' or 'xws' == (-1.0) then
        if 'T' < 273.16 then
          'd_der' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT_der'('pl', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('pl', 'T'), 'pl_der', 'T_der') + 461.51805 * ('pd_der' * 'T' - 'pd' * 'T_der') / (461.51805 * 'T') ^ 2.0;
        else
          'd_der' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT_der'('pl', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('pl', 'T'), 'pl_der', 'T_der') + 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT_der'('pd', 'T', 'pd_der', 'T_der');
        end if;
      else
        if 'T' < 273.16 then
          'o'[1] := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('pl', 'T');
          'o'[2] := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT'('p', 'T');
          'o'[3] := (1.0 + 'xws') / ('Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('pl', 'T') + 'pd' / (461.51805 * 'T')) + ('xw' - 'xws') / 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT'('p', 'T');
          'o'[4] := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT_der'('pl', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('p', 'T'), 'p_der', 'T_der');
          'o'[5] := ('xws_der' * 'o'[1] - (1.0 + 'xws') * 'o'[4]) / 'o'[1] ^ 2.0 + ('pd_der' * 'T' - 'pd' * 'T_der') / 461.51805 / 'T' ^ 2.0 + ('xw_der' * 'o'[2] - 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT_der'('p', 'T', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.ice09BaseProp_pT'('p', 'T'), 'p_der', 'T_der')) / 'o'[2] ^ 2.0 - ('xws_der' * 'o'[2] - 'xws' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT_der'('p', 'T', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.ice09BaseProp_pT'('p', 'T'), 'p_der', 'T_der')) / 'o'[2] ^ 2.0;
          'd_der' := ('xw_der' * 'o'[3] - (1.0 + 'xw') * 'o'[5]) / 'o'[3] ^ 2.0;
        else
          'o'[1] := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('pl', 'T') + 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT'('pd', 'T');
          'o'[2] := 'Modelica.Media.Water.IF97_Utilities.rho_pT'('p', 'T', 0);
          'o'[3] := (1.0 + 'xws') / ('Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('pl', 'T') + 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT'('pd', 'T')) + ('xw' - 'xws') / 'Modelica.Media.Water.IF97_Utilities.rho_pT'('p', 'T', 0);
          'o'[4] := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT_der'('pl', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('p', 'T'), 'p_der', 'T_der') + 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT_der'('pd', 'T', 'pd_der', 'T_der');
          'o'[5] := ('xws_der' * 'o'[1] - (1.0 + 'xws') * 'o'[4]) / 'o'[1] ^ 2.0 + ('xw_der' * 'o'[2] - 'xw' * 'Modelica.Media.Water.IF97_Utilities.rho_pT_der'('p', 'T', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT'('p', 'T', 0), 'p_der', 'T_der')) / 'o'[2] ^ 2.0 - ('xws_der' * 'o'[2] - 'xws' * 'Modelica.Media.Water.IF97_Utilities.rho_pT_der'('p', 'T', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT'('p', 'T', 0), 'p_der', 'T_der')) / 'o'[2] ^ 2.0;
          'd_der' := ('xw_der' * 'o'[3] - (1.0 + 'xw') * 'o'[5]) / 'o'[3] ^ 2.0;
        end if;
      end if;
    end if;
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.rho_pTX_der';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pds_pT' "Saturation partial pressure of steam"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'pds'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tlim';
  algorithm
    if 'T' >= 273.16 then
      'pds' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.psat'('T');
      'Tlim' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Water95_Utilities.Tsat'('p');
    else
      'pds' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub'('T');
      'Tlim' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.Tsub'('p');
    end if;

    if 'T' <= 'Tlim' then
      'pds' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.f_pT'('p', 'T') * 'pds';
    else
      'pds' := 'p';
    end if;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pds_pT_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pds_pT';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir2.volume1.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'volume1.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'volume1.Medium.ThermodynamicState'('p', 'T', 'X') else 'volume1.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir2.volume1.Medium.setState_pTX';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.rho_pTX' "Return density as a function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pd';
    Real 'pl';
    Real 'xw';
    Real 'xws';
  algorithm
    if 'X'[1] == 0.0 then
      'd' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('p', 'T');
    else
      'xw' := 'X'[1] / (1.0 - 'X'[1]);
      'xws' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.xws_pT'('p', 'T');
      'pd' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pd_pTX'('p', 'T', 'X');
      'pl' := 'p' - 'pd';

      if 'xw' <= 'xws' or 'xws' == (-1.0) then
        if 'T' < 273.16 then
          'd' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('pl', 'T') + 'pd' / (461.51805 * 'T');
        else
          'd' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('pl', 'T') + 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT'('pd', 'T');
        end if;
      else
        if 'T' < 273.16 then
          'd' := (1.0 + 'xw') / ((1.0 + 'xws') / ('Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('pl', 'T') + 'pd' / (461.51805 * 'T')) + ('xw' - 'xws') / 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.rho_pT'('p', 'T'));
        else
          'd' := (1.0 + 'xw') / ((1.0 + 'xws') / ('Modelica.Media.Air.ReferenceAir.Air_Utilities.rho_pT'('pl', 'T') + 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.rho_pT'('pd', 'T')) + ('xw' - 'xws') / 'Modelica.Media.Water.IF97_Utilities.rho_pT'('p', 'T', 0));
        end if;
      end if;
    end if;
    annotation(derivative(order = 1) = 'Modelica.Media.Air.ReferenceMoistAir.Utilities.rho_pTX_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.rho_pTX';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.phi_pTX' "Relative humidity"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'phi';
    Real 'xw';
    Real 'pd';
    Real 'pds';
  algorithm
    if 'X'[1] == 0.0 then
      'phi' := 0.0;
    else
      'xw' := 'X'[1] / (1.0 - 'X'[1]);

      if 'T' >= 273.16 then
        'pds' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat'('T');
      else
        'pds' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.Basic.psub'('T');
      end if;

      'pds' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.f_pT'('p', 'T') * 'pds';
      'pd' := 'xw' / (0.6221042453709779 + 'xw') * 'p';
      'phi' := 'pd' / max(2.220446049250313e-14, 'pds');
    end if;
    annotation(Inline = false, LateInline = true);
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.phi_pTX';

  function 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX_der' "Derivative of specific enthalpy of moist air"
    input Real 'p'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    input Real 'p_der';
    input Real 'T_der';
    input Real[:] 'X_der';
    output Real 'h_der';
    Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'xw';
    Real 'xw_der';
    Real 'xws';
    Real 'xws_der';
    Real 'pd';
    Real 'pd_der';
    Real 'pl';
    Real 'pl_der';
  algorithm
    if 'X'[1] == 0.0 then
      'h_der' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT_der'('p', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('p', 'T'), 'p_der', 'T_der');
    else
      'pd' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pd_pTX'('p', 'T', 'X');
      'pd_der' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.pd_pTX_der'('p', 'T', 'X', 'p_der', 'T_der', 'X_der');
      'pl' := 'p' - 'pd';
      'pl_der' := 'p_der' - 'pd_der';
      'xw' := 'X'[1] / (1.0 - 'X'[1]);
      'xw_der' := 'X_der'[1] / (1.0 - 'X'[1]) ^ 2.0;
      'xws' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.xws_pT'('p', 'T');
      'xws_der' := 'Modelica.Media.Air.ReferenceMoistAir.Utilities.xws_pT_der'('p', 'T', 'p_der', 'T_der');

      if 'xw' <= 'xws' or 'xws' == (-1.0) then
        if 'T' >= 773.15 then
          'h_der' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT_der'('pl', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('pl', 'T'), 'pl_der', 'T_der') + 'xw_der' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT_der'('pd', 'T', 0, 'pd_der', 'T_der') + 'xw_der' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_dis_pTX'('p', 'T', 'X') + 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_dis_pTX_der'('p', 'T', 'X', 'p_der', 'T_der', 'X_der');
        else
          'h_der' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT_der'('pl', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('pl', 'T'), 'pl_der', 'T_der') + 'xw_der' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT_der'('pd', 'T', 0, 'pd_der', 'T_der');
        end if;
      else
        if 'T' < 273.16 then
          'h_der' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT_der'('pl', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('pl', 'T'), 'pl_der', 'T_der') + 'xws_der' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + 'xws' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT_der'('pd', 'T', 0, 'pd_der', 'T_der') + 'xw_der' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT'('p', 'T') + 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT_der'('p', 'T', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.ice09BaseProp_pT'('p', 'T'), 'p_der', 'T_der') - 'xws_der' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT'('p', 'T') - 'xws' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT_der'('p', 'T', 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.ice09BaseProp_pT'('p', 'T'), 'p_der', 'T_der');
        else
          'h_der' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT_der'('pl', 'T', 'Modelica.Media.Air.ReferenceAir.Air_Utilities.airBaseProp_pT'('p', 'T'), 'pl_der', 'T_der') + 'xws_der' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + 'xws' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT_der'('pd', 'T', 0, 'pd_der', 'T_der') + 'xw_der' * 'Modelica.Media.Water.IF97_Utilities.h_pT'('p', 'T', 0) + 'xw' * 'Modelica.Media.Water.IF97_Utilities.h_pT_der'('p', 'T', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT'('p', 'T', 0), 'p_der', 'T_der') - 'xws_der' * 'Modelica.Media.Water.IF97_Utilities.h_pT'('p', 'T', 0) - 'xws' * 'Modelica.Media.Water.IF97_Utilities.h_pT_der'('p', 'T', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT'('p', 'T', 0), 'p_der', 'T_der');
        end if;
      end if;

      if 'xw' <= 'xws' or 'xws' == (-1.0) then
        if 'T' >= 773.15 then
          'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('pl', 'T') + 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + (1.0 + 'xw') * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_dis_pTX'('p', 'T', 'X');
        else
          'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('pl', 'T') + 'xw' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0);
        end if;
      else
        if 'T' < 273.16 then
          'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('pl', 'T') + 'xws' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + ('xw' - 'xws') * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.Ice09_Utilities.h_pT'('p', 'T');
        else
          'h' := 'Modelica.Media.Air.ReferenceAir.Air_Utilities.h_pT'('pl', 'T') + 'xws' * 'Modelica.Media.Air.ReferenceMoistAir.Utilities.IF97_new.h_pT'('pd', 'T', 0) + ('xw' - 'xws') * 'Modelica.Media.Water.IF97_Utilities.h_pT'('p', 'T', 0);
        end if;
      end if;

      'h_der' := ('h_der' * (1.0 + 'xw') - 'h' * 'xw_der') / (1.0 + 'xw') ^ 2.0;
    end if;
  end 'Modelica.Media.Air.ReferenceMoistAir.Utilities.h_pTX_der';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir2.fixedMassFlowRate.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'fixedMassFlowRate.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'fixedMassFlowRate.Medium.ThermodynamicState'('p', 'T', 'X') else 'fixedMassFlowRate.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir2.fixedMassFlowRate.Medium.setState_pTX';

  function 'Modelica.Media.Air.ReferenceMoistAir.Xsaturation' "Return absolute humidity per unit mass of moist air at saturation as a function of the thermodynamic state record"
    input 'Modelica.Media.Air.ReferenceMoistAir.ThermodynamicState' 'state';
    output Real 'X_sat'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction");
    Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
  algorithm
    'X' := 'Modelica.Media.Air.ReferenceMoistAir.massFractionSaturation'('state');
    'X_sat' := 'X'[1];
  end 'Modelica.Media.Air.ReferenceMoistAir.Xsaturation';

  function 'Modelica.Media.Examples.ReferenceAir.MoistAir2.volume.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'volume.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'volume.Medium.ThermodynamicState'('p', 'T', 'X') else 'volume.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
  end 'Modelica.Media.Examples.ReferenceAir.MoistAir2.volume.Medium.setState_pTX';

