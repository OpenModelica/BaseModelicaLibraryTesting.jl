//! base 0.1.0
package 'SMR_Inverter'
  model 'SMR_Inverter' "Test example: SynchronousMachineReluctanceRotor with inverter"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Actual frequency";
    parameter Real 'tRamp'(unit = "s", quantity = "Time") = 1.0 "Frequency ramp";
    parameter Real 'TLoad'(unit = "N.m", quantity = "Torque") = 46.0 "Nominal load torque";
    parameter Real 'tStep'(unit = "s", quantity = "Time") = 1.2 "Time of load torque step";
    parameter Real 'JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load's moment of inertia";
    parameter Integer 'smr.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'smr.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'smr.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'smr.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
    parameter Real 'smr.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'smr.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'smr.alpha20s'(start = 0.0, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'smr.Lszero'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator zero sequence inductance";
    parameter Real 'smr.Lssigma'(start = 3.183098861837907e-4, unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'smr.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Boolean 'smr.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'smr.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Boolean 'smr.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Real 'smr.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smr.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smr.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smr.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smr.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smr.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smr.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    Real 'smr.phiMechanical'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Mechanical angle of rotor against stator";
    Real 'smr.wMechanical'(fixed = true, start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") "Mechanical angular velocity of rotor against stator";
    Real 'smr.tauElectrical'(unit = "N.m", quantity = "Torque") "Electromagnetic torque";
    Real 'smr.tauShaft'(unit = "N.m", quantity = "Torque") "Shaft torque";
    Real 'smr.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smr.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smr.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'smr.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'smr.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'smr.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'smr.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'smr.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'smr.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.inertiaStator.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smr.inertiaStator.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.inertiaStator.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'smr.inertiaStator.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'smr.inertiaStator.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'smr.inertiaStator.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'smr.inertiaStator.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'smr.inertiaStator.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'smr.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'smr.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smr.friction.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.friction.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smr.friction.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.friction.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smr.friction.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between shaft and support";
    Real 'smr.friction.tau'(unit = "N.m", quantity = "Torque") "Torque";
    Real 'smr.friction.w'(unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity of flange and support";
    parameter Real 'smr.friction.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smr.friction.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smr.friction.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smr.friction.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smr.friction.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smr.friction.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smr.friction.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Boolean 'smr.friction.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'smr.friction.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'smr.friction.heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'smr.friction.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'smr.internalSupport.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smr.internalSupport.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Integer 'smr.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'smr.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'smr.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'smr.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'smr.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'smr.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'smr.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'smr.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'smr.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'smr.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smr.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'smr.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    Real 'smr.powerBalance.powerStator'(unit = "W", quantity = "Power") "Electrical power (stator)";
    Real 'smr.powerBalance.powerMechanical'(unit = "W", quantity = "Power") "Mechanical power";
    Real 'smr.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") "Stator inertia power";
    Real 'smr.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") "Rotor inertia power";
    Real 'smr.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") "Total loss power";
    Real 'smr.powerBalance.lossPowerStatorWinding'(unit = "W", quantity = "Power") "Stator copper losses";
    Real 'smr.powerBalance.lossPowerStatorCore'(unit = "W", quantity = "Power") "Stator core losses";
    Real 'smr.powerBalance.lossPowerRotorCore'(unit = "W", quantity = "Power") "Rotor core losses";
    Real 'smr.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") "Stray load losses";
    Real 'smr.powerBalance.lossPowerFriction'(unit = "W", quantity = "Power") "Friction losses";
    Real 'smr.powerBalance.lossPowerRotorWinding'(unit = "W", quantity = "Power") "Rotor copper losses";
    Real 'smr.vs[1]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'smr.vs[2]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'smr.vs[3]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'smr.is[1]'(unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'smr.is[2]'(unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'smr.is[3]'(unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'smr.i_0_s'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Stator zero-sequence current";
    Real 'smr.idq_ss[1]'(unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / stator fixed frame";
    Real 'smr.idq_ss[2]'(unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / stator fixed frame";
    Real 'smr.idq_sr[1]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / rotor fixed frame";
    Real 'smr.idq_sr[2]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / rotor fixed frame";
    Real 'smr.idq_rs[1]'(unit = "A", quantity = "ElectricCurrent") "Rotor space phasor current / stator fixed frame";
    Real 'smr.idq_rs[2]'(unit = "A", quantity = "ElectricCurrent") "Rotor space phasor current / stator fixed frame";
    Real 'smr.idq_rr[1]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Rotor space phasor current / rotor fixed frame";
    Real 'smr.idq_rr[2]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Rotor space phasor current / rotor fixed frame";
    parameter Integer 'smr.plug_sp.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smr.plug_sp.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.plug_sp.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.plug_sp.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.plug_sp.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.plug_sp.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.plug_sp.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smr.plug_sn.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smr.plug_sn.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.plug_sn.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.plug_sn.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.plug_sn.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.plug_sn.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.plug_sn.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smr.rs.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smr.rs.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'smr.rs.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'smr.rs.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'smr.rs.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'smr.rs.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'smr.rs.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    parameter Integer 'smr.rs.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smr.rs.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.rs.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.rs.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.rs.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.rs.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.rs.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smr.rs.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smr.rs.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.rs.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.rs.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.rs.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.rs.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.rs.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'smr.rs.R[1]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.03 "Resistances R_ref at temperatures T_ref";
    parameter Real 'smr.rs.R[2]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.03 "Resistances R_ref at temperatures T_ref";
    parameter Real 'smr.rs.R[3]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.03 "Resistances R_ref at temperatures T_ref";
    parameter Real 'smr.rs.T_ref[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'smr.rs.T_ref[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'smr.rs.T_ref[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'smr.rs.alpha[1]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Real 'smr.rs.alpha[2]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Real 'smr.rs.alpha[3]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Integer 'smr.rs.mh'(min = 1) = 3 "Number of heatPorts=number of phases";
    parameter Boolean 'smr.rs.useHeatPort' = true "= true, if all heat ports are enabled" annotation(Evaluate = true);
    parameter Real 'smr.rs.T[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'smr.rs.T[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'smr.rs.T[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    Real 'smr.rs.heatPort[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'smr.rs.heatPort[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'smr.rs.heatPort[2].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'smr.rs.heatPort[2].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'smr.rs.heatPort[3].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'smr.rs.heatPort[3].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'smr.rs.resistor[1].R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.03 "Resistance at temperature T_ref";
    parameter Real 'smr.rs.resistor[1].T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'smr.rs.resistor[1].alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'smr.rs.resistor[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'smr.rs.resistor[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.rs.resistor[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.rs.resistor[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smr.rs.resistor[1].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smr.rs.resistor[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'smr.rs.resistor[1].useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'smr.rs.resistor[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'smr.rs.resistor[1].heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'smr.rs.resistor[1].heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'smr.rs.resistor[1].LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'smr.rs.resistor[1].T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'smr.rs.resistor[1].R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
