    Real 'signalVoltage.signalVoltage[3].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalVoltage.signalVoltage[3].v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'signalVoltage.signalVoltage[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Integer 'star.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'loadInertia.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadInertia.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'loadInertia.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadInertia.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'loadInertia.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'loadInertia.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'loadInertia.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'loadInertia.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'loadInertia.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Boolean 'loadTorqueStep.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'loadTorqueStep.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadTorqueStep.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'loadTorqueStep.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'loadTorqueStep.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of flange with respect to support (= flange.phi - support.phi)";
    parameter Real 'loadTorqueStep.stepTorque'(start = 1.0, unit = "N.m", quantity = "Torque") = -46.0 "Height of torque step (if negative, torque is acting as load)";
    parameter Real 'loadTorqueStep.offsetTorque'(start = 0.0, unit = "N.m", quantity = "Torque") = 0.0 "Offset of torque";
    parameter Real 'loadTorqueStep.startTime'(unit = "s", quantity = "Time") = 1.2 "Torque = offset for time < startTime";
    Real 'loadTorqueStep.tau'(unit = "N.m", quantity = "Torque") "Accelerating torque acting at flange (= -flange.tau)";
    parameter Integer 'terminalBox.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter String 'terminalBox.terminalConnection'(start = "Y") = "Y" "Choose \"Y\" for star or \"D\" for delta connection";
    parameter Integer 'terminalBox.plug_sp.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBox.plug_sp.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plug_sp.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.plug_sp.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plug_sp.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.plug_sp.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plug_sp.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'terminalBox.plug_sn.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBox.plug_sn.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plug_sn.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.plug_sn.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plug_sn.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.plug_sn.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plug_sn.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'terminalBox.star.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'terminalBox.star.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBox.star.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.star.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.star.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.star.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.star.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.star.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.star.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.star.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'terminalBox.plugSupply.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'terminalBox.plugSupply.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plugSupply.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.plugSupply.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plugSupply.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.plugSupply.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.plugSupply.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'terminalBox.starpoint.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'terminalBox.starpoint.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smrData.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'smrData.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Real 'smrData.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Integer 'smrData.p'(min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'smrData.fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'smrData.Rs'(unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'smrData.TsRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'smrData.alpha20s'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'smrData.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'smrData.Lszero'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator zero sequence inductance";
    parameter Real 'smrData.Lssigma'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'smrData.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'smrData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smrData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smrData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smrData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smrData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smrData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smrData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'smrData.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'smrData.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'smrData.statorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'smrData.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'smrData.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'smrData.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'smrData.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'smrData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'smrData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'smrData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smrData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'smrData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'smrData.Lmd'(unit = "H", quantity = "Inductance") = 0.009230986699329929 "Stator main field inductance per phase in d-axis";
    parameter Real 'smrData.Lmq'(unit = "H", quantity = "Inductance") = 0.002864788975654116 "Stator main field inductance per phase in q-axis";
    parameter Boolean 'smrData.useDamperCage' = true "Enable / disable damper cage" annotation(Evaluate = true);
    parameter Real 'smrData.Lrsigmad'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance in d-axis";
    parameter Real 'smrData.Lrsigmaq'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance in q-axis";
    parameter Real 'smrData.Rrd'(unit = "Ohm", quantity = "Resistance") = 0.04 "Damper resistance in d-axis at TRef";
    parameter Real 'smrData.Rrq'(unit = "Ohm", quantity = "Resistance") = 0.04 "Damper resistance in q-axis at TRef";
    parameter Real 'smrData.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of damper resistances in d- and q-axis";
    parameter Real 'smrData.alpha20r'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of damper resistances in d- and q-axis";
  initial equation
    'smr.is[1]' = 0.0;
    'smr.is[2]' = 0.0;
  equation
    'smr.phiMechanical' = 'smr.flange.phi' - 'smr.internalSupport.phi';
    'smr.wMechanical' = der('smr.phiMechanical');
    'smr.tauElectrical' = 'smr.inertiaRotor.flange_a.tau';
    'smr.tauShaft' = -'smr.flange.tau';
    'smr.friction.heatPort.Q_flow' = -'smr.friction.lossPower';
    'smr.powerBalance.powerStator' = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'('smr.vs', 'smr.is');
    'smr.powerBalance.powerMechanical' = 'smr.wMechanical' * 'smr.tauShaft';
    'smr.powerBalance.powerInertiaStator' = 0.29 * 'smr.inertiaStator.a' * 'smr.inertiaStator.w';
    'smr.powerBalance.powerInertiaRotor' = 0.29 * 'smr.inertiaRotor.a' * 'smr.inertiaRotor.w';
    'smr.powerBalance.lossPowerTotal' = 'smr.powerBalance.lossPowerStatorWinding' + 'smr.powerBalance.lossPowerStatorCore' + 'smr.powerBalance.lossPowerRotorCore' + 'smr.powerBalance.lossPowerStrayLoad' + 'smr.powerBalance.lossPowerFriction' + 'smr.powerBalance.lossPowerRotorWinding';
    'smr.powerBalance.lossPowerStatorWinding' = 'smr.rs.resistor[1].LossPower' + 'smr.rs.resistor[2].LossPower' + 'smr.rs.resistor[3].LossPower';
    'smr.powerBalance.lossPowerStatorCore' = 'smr.statorCore.lossPower';
    'smr.powerBalance.lossPowerRotorCore' = 0.0;
    'smr.powerBalance.lossPowerStrayLoad' = 'smr.strayLoad.lossPower';
    'smr.powerBalance.lossPowerFriction' = 'smr.friction.lossPower';
    'smr.powerBalance.lossPowerRotorWinding' = 'smr.damperCageLossPower';
    'smr.i_0_s' = 'smr.spacePhasorS.zero.i';
    'smr.rs.resistor[1].heatPort.T' = 'smr.rs.resistor[1].T_heatPort';
    'smr.rs.resistor[1].heatPort.Q_flow' = -'smr.rs.resistor[1].LossPower';
    'smr.rs.resistor[2].heatPort.T' = 'smr.rs.resistor[2].T_heatPort';
    'smr.rs.resistor[2].heatPort.Q_flow' = -'smr.rs.resistor[2].LossPower';
    'smr.rs.resistor[3].heatPort.T' = 'smr.rs.resistor[3].T_heatPort';
    'smr.rs.resistor[3].heatPort.Q_flow' = -'smr.rs.resistor[3].LossPower';
    'smr.statorCore.heatPort.Q_flow' = -'smr.statorCore.lossPower';
    'smr.statorCore.w' = 'smr.statorCoreParameters.wRef';
    'smr.statorCore.wLimit' = noEvent(max(noEvent(abs('smr.statorCore.w')), 'smr.statorCore.coreParameters.wMin'));
    'smr.strayLoad.heatPort.Q_flow' = -'smr.strayLoad.lossPower';
    'smr.strayLoad.iRMS' = sqrt(sum('smr.strayLoad.i' .^ 2.0 / size('smr.strayLoad.i', 1)));
    'smr.thermalAmbient.Q_flowStatorWinding' = 'smr.thermalAmbient.temperatureStatorWinding.port.Q_flow';
    'smr.thermalAmbient.Q_flowStatorCore' = 'smr.thermalAmbient.temperatureStatorCore.port.Q_flow';
    'smr.thermalAmbient.Q_flowRotorCore' = 'smr.thermalAmbient.temperatureRotorCore.port.Q_flow';
    'smr.thermalAmbient.Q_flowStrayLoad' = 'smr.thermalAmbient.temperatureStrayLoad.port.Q_flow';
    'smr.thermalAmbient.Q_flowFriction' = 'smr.thermalAmbient.temperatureFriction.port.Q_flow';
    'smr.thermalAmbient.Q_flowRotorWinding' = 'smr.thermalAmbient.temperatureRotorWinding.port.Q_flow';
    'smr.thermalAmbient.Q_flowTotal' = 'smr.thermalAmbient.Q_flowStatorWinding' + 'smr.thermalAmbient.Q_flowRotorWinding' + 'smr.thermalAmbient.Q_flowStatorCore' + 'smr.thermalAmbient.Q_flowRotorCore' + 'smr.thermalAmbient.Q_flowStrayLoad' + 'smr.thermalAmbient.Q_flowFriction';
    'smr.damperCage.heatPort.T' = 'smr.damperCage.T_heatPort';
    'smr.damperCage.heatPort.Q_flow' = -'smr.damperCage.LossPower';
    'smr.damperCage.lossPower' = 'smr.damperCage.LossPower';
    'smr.rs.resistor[1].p.v' = 'smr.rs.plug_p.pin[1].v';
    'smr.rs.resistor[2].p.v' = 'smr.rs.plug_p.pin[2].v';
    'smr.rs.resistor[3].p.v' = 'smr.rs.plug_p.pin[3].v';
    'smr.rs.resistor[1].n.v' = 'smr.rs.plug_n.pin[1].v';
    'smr.rs.resistor[2].n.v' = 'smr.rs.plug_n.pin[2].v';
    'smr.rs.resistor[3].n.v' = 'smr.rs.plug_n.pin[3].v';
    'smr.rs.resistor[1].heatPort.T' = 'smr.rs.heatPort[1].T';
    'smr.rs.resistor[2].heatPort.T' = 'smr.rs.heatPort[2].T';
    'smr.rs.resistor[3].heatPort.T' = 'smr.rs.heatPort[3].T';
    'smr.thermalAmbient.constTr.y' = 'smr.thermalAmbient.temperatureRotorWinding.T';
    'smr.thermalAmbient.temperatureRotorWinding.port.T' = 'smr.thermalAmbient.thermalPort.heatPortRotorWinding.T';
    'smr.thermalAmbient.constTs.y' = 'smr.thermalAmbient.temperatureStatorWinding.T';
    'smr.thermalAmbient.temperatureStrayLoad.port.T' = 'smr.thermalAmbient.thermalPort.heatPortStrayLoad.T';
    'smr.thermalAmbient.temperatureFriction.port.T' = 'smr.thermalAmbient.thermalPort.heatPortFriction.T';
    'smr.thermalAmbient.thermalCollectorStator.port_b.T' = 'smr.thermalAmbient.temperatureStatorWinding.port.T';
    'smr.thermalAmbient.thermalCollectorStator.port_a[1].T' = 'smr.thermalAmbient.thermalPort.heatPortStatorWinding[1].T';
    'smr.thermalAmbient.thermalCollectorStator.port_a[2].T' = 'smr.thermalAmbient.thermalPort.heatPortStatorWinding[2].T';
    'smr.thermalAmbient.thermalCollectorStator.port_a[3].T' = 'smr.thermalAmbient.thermalPort.heatPortStatorWinding[3].T';
    'smr.thermalAmbient.temperatureStatorCore.port.T' = 'smr.thermalAmbient.thermalPort.heatPortStatorCore.T';
    'smr.thermalAmbient.temperatureRotorCore.port.T' = 'smr.thermalAmbient.thermalPort.heatPortRotorCore.T';
    'smr.idq_dr[1]' = 'smr.damperCage.i[1]';
    'smr.idq_dr[1]' = 'smr.ir[1]';
    'smr.idq_dr[2]' = 'smr.damperCage.i[2]';
    'smr.idq_dr[2]' = 'smr.ir[2]';
    'smr.damperCageLossPower' = 'smr.damperCage.lossPower';
    'smr.airGap.spacePhasor_r.v_[1]' = 'smr.damperCage.spacePhasor_r.v_[1]';
    'smr.airGap.spacePhasor_r.v_[2]' = 'smr.damperCage.spacePhasor_r.v_[2]';
    'smr.friction.support.phi' = 'smr.internalSupport.phi';
    'smr.friction.support.phi' = 'smr.inertiaStator.flange_a.phi';
    'smr.friction.support.phi' = 'smr.fixed.flange.phi';
    'smr.friction.support.phi' = 'smr.strayLoad.support.phi';
    'smr.friction.support.phi' = 'smr.airGap.support.phi';
    'smr.lssigma.spacePhasor_b.v_[1]' = 'smr.airGap.spacePhasor_s.v_[1]';
    'smr.lssigma.spacePhasor_b.v_[2]' = 'smr.airGap.spacePhasor_s.v_[2]';
    'smr.airGap.flange.phi' = 'smr.inertiaRotor.flange_a.phi';
    'smr.thermalAmbient.thermalPort.heatPortRotorWinding.T' = 'smr.internalThermalPort.heatPortRotorWinding.T';
    'smr.thermalAmbient.thermalPort.heatPortRotorWinding.T' = 'smr.damperCage.heatPort.T';
    'smr.spacePhasorS.plug_n.pin[1].v' = 'smr.plug_sn.pin[1].v';
    'smr.spacePhasorS.plug_n.pin[2].v' = 'smr.plug_sn.pin[2].v';
    'smr.spacePhasorS.plug_n.pin[3].v' = 'smr.plug_sn.pin[3].v';
    'smr.strayLoad.plug_n.pin[1].v' = 'smr.rs.plug_p.pin[1].v';
    'smr.strayLoad.plug_n.pin[2].v' = 'smr.rs.plug_p.pin[2].v';
    'smr.strayLoad.plug_n.pin[3].v' = 'smr.rs.plug_p.pin[3].v';
    'smr.strayLoad.plug_p.pin[1].v' = 'smr.plug_sp.pin[1].v';
    'smr.strayLoad.plug_p.pin[2].v' = 'smr.plug_sp.pin[2].v';
    'smr.strayLoad.plug_p.pin[3].v' = 'smr.plug_sp.pin[3].v';
    'smr.spacePhasorS.plug_p.pin[1].v' = 'smr.rs.plug_n.pin[1].v';
    'smr.spacePhasorS.plug_p.pin[2].v' = 'smr.rs.plug_n.pin[2].v';
    'smr.spacePhasorS.plug_p.pin[3].v' = 'smr.rs.plug_n.pin[3].v';
    'smr.spacePhasorS.zero.v' = 'smr.lszero.p.v';
    'smr.lszero.n.v' = 'smr.spacePhasorS.ground.v';
    'smr.statorCore.spacePhasor.v_[1]' = 'smr.lssigma.spacePhasor_a.v_[1]';
    'smr.statorCore.spacePhasor.v_[1]' = 'smr.spacePhasorS.spacePhasor.v_[1]';
    'smr.statorCore.spacePhasor.v_[2]' = 'smr.lssigma.spacePhasor_a.v_[2]';
    'smr.statorCore.spacePhasor.v_[2]' = 'smr.spacePhasorS.spacePhasor.v_[2]';
    'smr.thermalAmbient.thermalPort.heatPortStatorCore.T' = 'smr.internalThermalPort.heatPortStatorCore.T';
    'smr.thermalAmbient.thermalPort.heatPortStatorCore.T' = 'smr.statorCore.heatPort.T';
    'smr.thermalAmbient.thermalPort.heatPortStrayLoad.T' = 'smr.internalThermalPort.heatPortStrayLoad.T';
