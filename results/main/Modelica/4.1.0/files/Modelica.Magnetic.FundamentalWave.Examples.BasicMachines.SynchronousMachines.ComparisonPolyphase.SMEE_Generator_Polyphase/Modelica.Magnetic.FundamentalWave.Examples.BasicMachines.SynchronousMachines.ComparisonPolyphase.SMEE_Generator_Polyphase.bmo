    'currentRMSsensorM.i[4]' = 'currentRMSsensorM.plug_p.pin[4].i';
    'currentRMSsensorM.i[5]' = 'currentRMSsensorM.plug_p.pin[5].i';
    'currentRMSsensor3.CurrentSensor1.currentSensor[1].p.v' = 'currentRMSsensor3.CurrentSensor1.currentSensor[1].n.v';
    'currentRMSsensor3.CurrentSensor1.currentSensor[1].p.i' = 'currentRMSsensor3.CurrentSensor1.currentSensor[1].i';
    'currentRMSsensor3.CurrentSensor1.currentSensor[1].n.i' = -'currentRMSsensor3.CurrentSensor1.currentSensor[1].i';
    'currentRMSsensor3.CurrentSensor1.currentSensor[2].p.v' = 'currentRMSsensor3.CurrentSensor1.currentSensor[2].n.v';
    'currentRMSsensor3.CurrentSensor1.currentSensor[2].p.i' = 'currentRMSsensor3.CurrentSensor1.currentSensor[2].i';
    'currentRMSsensor3.CurrentSensor1.currentSensor[2].n.i' = -'currentRMSsensor3.CurrentSensor1.currentSensor[2].i';
    'currentRMSsensor3.CurrentSensor1.currentSensor[3].p.v' = 'currentRMSsensor3.CurrentSensor1.currentSensor[3].n.v';
    'currentRMSsensor3.CurrentSensor1.currentSensor[3].p.i' = 'currentRMSsensor3.CurrentSensor1.currentSensor[3].i';
    'currentRMSsensor3.CurrentSensor1.currentSensor[3].n.i' = -'currentRMSsensor3.CurrentSensor1.currentSensor[3].i';
    'currentRMSsensor3.Gain1.y' = 0.7071067811865475 * 'currentRMSsensor3.Gain1.u';
    3.0 * 'currentRMSsensor3.ToSpacePhasor1.zero' = 'currentRMSsensor3.ToSpacePhasor1.u[1]' + 'currentRMSsensor3.ToSpacePhasor1.u[2]' + 'currentRMSsensor3.ToSpacePhasor1.u[3]';
    'currentRMSsensor3.ToSpacePhasor1.y[1]' = 0.6666666666666666 * 'currentRMSsensor3.ToSpacePhasor1.u[1]' + (-0.33333333333333315) * 'currentRMSsensor3.ToSpacePhasor1.u[2]' + (-0.3333333333333336) * 'currentRMSsensor3.ToSpacePhasor1.u[3]';
    'currentRMSsensor3.ToSpacePhasor1.y[2]' = 0.5773502691896257 * 'currentRMSsensor3.ToSpacePhasor1.u[2]' + (-0.5773502691896255) * 'currentRMSsensor3.ToSpacePhasor1.u[3]';
    'currentRMSsensor3.ToPolar1.y[1]' = sqrt('currentRMSsensor3.ToPolar1.u[1]' ^ 2.0 + 'currentRMSsensor3.ToPolar1.u[2]' ^ 2.0);
    'currentRMSsensor3.ToPolar1.y[2]' = if noEvent('currentRMSsensor3.ToPolar1.y[1]' <= 2.2250738585072014e-308) then 0.0 else atan2('currentRMSsensor3.ToPolar1.u[2]', 'currentRMSsensor3.ToPolar1.u[1]');
    'gain.y' = 1.6666666666666667 * 'gain.u';
    'feedback.y' = 'feedback.u1' - 'feedback.u2';
    'groundM.p.v' = 0.0;
    'sineVoltageM.sineVoltage[1].signalSource.y' = if time < 0.0 then 0.0 else 141.4213562373095 * sin(314.1592653589793 * time);
    'sineVoltageM.sineVoltage[1].v' = 'sineVoltageM.sineVoltage[1].signalSource.y';
    0.0 = 'sineVoltageM.sineVoltage[1].p.i' + 'sineVoltageM.sineVoltage[1].n.i';
    'sineVoltageM.sineVoltage[1].i' = 'sineVoltageM.sineVoltage[1].p.i';
    'sineVoltageM.sineVoltage[1].v' = 'sineVoltageM.sineVoltage[1].p.v' - 'sineVoltageM.sineVoltage[1].n.v';
