    'sineVoltageM.sineVoltage[5].v' = 'sineVoltageM.sineVoltage[5].p.v' - 'sineVoltageM.sineVoltage[5].n.v';
    'sineVoltageM.v[1]' = 'sineVoltageM.plug_p.pin[1].v' - 'sineVoltageM.plug_n.pin[1].v';
    'sineVoltageM.v[2]' = 'sineVoltageM.plug_p.pin[2].v' - 'sineVoltageM.plug_n.pin[2].v';
    'sineVoltageM.v[3]' = 'sineVoltageM.plug_p.pin[3].v' - 'sineVoltageM.plug_n.pin[3].v';
