    'currentRMSsensorM.v[5]' = 'currentRMSsensorM.plug_p.pin[5].v' - 'currentRMSsensorM.plug_n.pin[5].v';
    'currentRMSsensorM.i[1]' = 'currentRMSsensorM.plug_p.pin[1].i';
    'currentRMSsensorM.i[2]' = 'currentRMSsensorM.plug_p.pin[2].i';
