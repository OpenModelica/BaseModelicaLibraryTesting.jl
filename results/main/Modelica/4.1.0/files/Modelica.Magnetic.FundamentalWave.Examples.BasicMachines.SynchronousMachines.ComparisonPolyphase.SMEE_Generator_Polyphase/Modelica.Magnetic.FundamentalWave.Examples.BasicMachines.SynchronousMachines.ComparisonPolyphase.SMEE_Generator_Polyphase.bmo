    'smeeM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].abs_Phi' = sqrt('smeeM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.re' ^ 2.0 + 'smeeM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.im' ^ 2.0);
    'smeeM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].arg_Phi' = 'Modelica.Math.atan3'('smeeM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.im', 'smeeM.stator.electroMagneticConverter.singlePhaseElectroMagneticConverter[2].Phi.re', 0.0);
