//! base 0.1.0
package 'SMEE_Generator_Polyphase'
  function 'Modelica.Math.wrapAngle' "Wrap angle to interval ]-pi,pi] or [0,2*pi["
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    input Boolean 'positiveRange' = false;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := mod('u', 6.283185307179586);

    if 'y' > 3.141592653589793 and not 'positiveRange' then
      'y' := 'y' - 6.283185307179586;
    end if;
  end 'Modelica.Math.wrapAngle';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  function 'Modelica.Electrical.Machines.SpacePhasors.Functions.ToSpacePhasor' "Conversion from polyphase input to space phasor and zero sequence component"
    input Real[:] 'x';
    output Real[2] 'y';
    output Real 'y0';
    Integer 'm' = size('x', 1);
    Real['m'] 'phi'(displayUnit = fill("deg", 'm'), unit = fill("rad", 'm'), quantity = fill("Angle", 'm')) = 'Modelica.Electrical.Polyphase.Functions.symmetricOrientation'('m');
    Real[2, 'm'] 'TransformationMatrix' = 2.0 / 'm' * {cos('phi'[1:'m']), sin('phi'[1:'m'])};
  algorithm
    'y' := 'TransformationMatrix' * 'x';
    'y0' := 1.0 / 'm' * sum('x');
    annotation(Inline = true);
  end 'Modelica.Electrical.Machines.SpacePhasors.Functions.ToSpacePhasor';

  model 'SMEE_Generator_Polyphase' "Electrical excited polyphase synchronous machine operating as generator"
    constant Integer 'm3' = 3 "Number of stator phases of three-phase system";
    parameter Integer 'm' = 5 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'w'(unit = "rad/s", quantity = "AngularVelocity") = 156.97491292437 "Nominal speed";
    parameter Real 'Ie'(unit = "A", quantity = "ElectricCurrent") = 19.0 "Excitation current";
    parameter Real 'Ie0'(unit = "A", quantity = "ElectricCurrent") = 10.0 "Initial excitation current";
    parameter Real 'gamma0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial rotor displacement angle";
    parameter Integer 'p' = 2 "Number of pole pairs";
    parameter Real 'Rs'(unit = "Ohm", quantity = "Resistance") = 0.03 "Warm stator resistance per phase";
    parameter Real 'Lssigma'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'Lmd'(unit = "H", quantity = "Inductance") = 0.00477464829275686 "Main field inductance in d-axis";
    parameter Real 'Lmq'(unit = "H", quantity = "Inductance") = 0.00477464829275686 "Main field inductance in q-axis";
    parameter Real 'Lrsigmad'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance (equivalent three-phase winding) d-axis";
    parameter Real 'Lrsigmaq'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance (equivalent three-phase winding) q-axis";
    parameter Real 'Rrd'(unit = "Ohm", quantity = "Resistance") = 0.04 "Warm damper resistance (equivalent three-phase winding) d-axis";
    parameter Real 'Rrq'(unit = "Ohm", quantity = "Resistance") = 0.04 "Warm damper resistance (equivalent three-phase winding) q-axis";
    parameter Integer 'star3.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star3.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star3.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star3.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star3.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
