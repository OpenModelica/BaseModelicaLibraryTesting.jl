    'sineVoltageM.sineVoltage[2].v' = 'sineVoltageM.sineVoltage[2].p.v' - 'sineVoltageM.sineVoltage[2].n.v';
    'sineVoltageM.sineVoltage[3].signalSource.y' = if time < 0.0 then 0.0 else 141.4213562373095 * sin(314.1592653589793 * time - 2.5132741228718345);
    'sineVoltageM.sineVoltage[3].v' = 'sineVoltageM.sineVoltage[3].signalSource.y';
