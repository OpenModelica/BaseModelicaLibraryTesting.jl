    'sineVoltageM.sineVoltage[4].signalSource.y' = if time < 0.0 then 0.0 else 141.4213562373095 * sin(314.1592653589793 * time - 3.7699111843077517);
    'sineVoltageM.sineVoltage[4].v' = 'sineVoltageM.sineVoltage[4].signalSource.y';
    0.0 = 'sineVoltageM.sineVoltage[4].p.i' + 'sineVoltageM.sineVoltage[4].n.i';
    'sineVoltageM.sineVoltage[4].i' = 'sineVoltageM.sineVoltage[4].p.i';
    'sineVoltageM.sineVoltage[4].v' = 'sineVoltageM.sineVoltage[4].p.v' - 'sineVoltageM.sineVoltage[4].n.v';
    'sineVoltageM.sineVoltage[5].signalSource.y' = if time < 0.0 then 0.0 else 141.4213562373095 * sin(314.1592653589793 * time - 5.026548245743669);
    'sineVoltageM.sineVoltage[5].v' = 'sineVoltageM.sineVoltage[5].signalSource.y';
