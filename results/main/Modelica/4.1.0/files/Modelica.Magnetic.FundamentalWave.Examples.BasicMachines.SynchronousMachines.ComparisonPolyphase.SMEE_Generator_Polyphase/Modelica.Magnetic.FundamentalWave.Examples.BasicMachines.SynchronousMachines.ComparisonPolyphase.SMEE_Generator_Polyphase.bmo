    'sineVoltageM.i[2]' = 'sineVoltageM.plug_p.pin[2].i';
    'sineVoltageM.i[3]' = 'sineVoltageM.plug_p.pin[3].i';
    'sineVoltageM.i[4]' = 'sineVoltageM.plug_p.pin[4].i';
    'sineVoltageM.i[5]' = 'sineVoltageM.plug_p.pin[5].i';
