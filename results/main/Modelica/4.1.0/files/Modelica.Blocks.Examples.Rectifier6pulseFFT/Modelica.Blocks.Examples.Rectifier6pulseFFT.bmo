    Real 'groundAC.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'currentSensor.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'currentSensor.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'currentSensor.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
