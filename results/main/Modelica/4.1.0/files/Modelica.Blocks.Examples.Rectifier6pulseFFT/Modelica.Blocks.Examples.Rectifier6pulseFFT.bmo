    Real 'source.sineVoltage[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'source.sineVoltage[3].signalSource.amplitude' = 81.6496580927726 "Amplitude of sine wave";
