    Real 'currentSensor.currentSensor[2].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensor.currentSensor[2].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensor.currentSensor[2].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
