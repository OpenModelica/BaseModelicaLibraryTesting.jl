    parameter Real 'source.sineVoltage[2].startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'source.sineVoltage[3].V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 81.6496580927726 "Amplitude of sine wave";
    parameter Real 'source.sineVoltage[3].phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -4.1887902047863905 "Phase of sine wave";
