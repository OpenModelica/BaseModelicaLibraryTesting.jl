    Real 'source.sineVoltage[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'source.sineVoltage[1].signalSource.amplitude' = 81.6496580927726 "Amplitude of sine wave";
    parameter Real 'source.sineVoltage[1].signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'source.sineVoltage[1].signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase of sine wave";
    parameter Boolean 'source.sineVoltage[1].signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
