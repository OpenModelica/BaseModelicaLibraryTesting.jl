//! base 0.1.0
package 'Rectifier6pulseFFT'
  function 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower' "Calculate active power of voltage and current input"
    input Real[3] 'v'(unit = {"V", "V", "V"}, quantity = {"ElectricPotential", "ElectricPotential", "ElectricPotential"});
    input Real[3] 'i'(unit = {"A", "A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent", "ElectricCurrent"});
    output Real 'p'(unit = "W", quantity = "Power");
    constant Integer 'm' = 3;
    Real[2] 'v_'(unit = {"V", "V"}, quantity = {"ElectricPotential", "ElectricPotential"});
    Real[2] 'i_'(unit = {"A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent"});
  algorithm
    'v_' := {0.0, 0.0};
    'i_' := {0.0, 0.0};

    for 'k' in 1:'m' loop
      'v_' := {'v_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k'], 'v_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k']};
      'i_' := {'i_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k'], 'i_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k']};
    end for;

    'p' := 'm' / 2.0 * ('v_'[1] * 'i_'[1] + 'v_'[2] * 'i_'[2]);
    annotation(Inline = true);
  end 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower';

  function 'Modelica.Math.FastFourierTransform.realFFTwriteToFile' "Write real FFT computation to file"
    input Real 't_computed';
    input String 'fileName';
    input Real 'f_max'(unit = "Hz", quantity = "Frequency");
    input Real[:] 'amplitudes';
    input Real[:] 'phases' = fill(0.0, 0);
    input String 'format' = "4";
    output Boolean 'success';
    Integer 'nA' = size('amplitudes', 1);
    Real[3 * size('amplitudes', 1), if size('phases', 1) == 0 then 2 else 3] 'fA';
    Real 'f';
  algorithm
    assert(size('phases', 1) == 0 or size('phases', 1) == size('amplitudes', 1), "Input vector phases has the wrong size", AssertionLevel.error);
    'Modelica.Utilities.Files.removeFile'('fileName');

    if size('phases', 1) == size('amplitudes', 1) then
      for 'i' in 1:'nA' loop
        'f' := 'f_max' * ('i' - 1) / ('nA' - 1);
        'fA'[1 + 3 * ('i' - 1):1 + 3 * ('i' - 1) + 2,:] := {{'f', 0.0, 0.0}, {'f', 'amplitudes'['i'], 'phases'['i']}, {'f', 0.0, 0.0}};
      end for;
    else
      for 'i' in 1:'nA' loop
        'f' := 'f_max' * ('i' - 1) / ('nA' - 1);
        'fA'[1 + 3 * ('i' - 1):1 + 3 * ('i' - 1) + 2,:] := {{'f', 0.0}, {'f', 'amplitudes'['i']}, {'f', 0.0}};
      end for;
    end if;

    'success' := 'Modelica.Utilities.Streams.writeRealMatrix'('fileName', "FFT", 'fA', false, 'format');

    if 'success' then
      'Modelica.Utilities.Streams.print'("... FFT result computed at time = " + String('t_computed') + " s stored on file: " + 'Modelica.Utilities.Files.fullPathName'('fileName'), "");
    end if;
  end 'Modelica.Math.FastFourierTransform.realFFTwriteToFile';

  function 'Modelica.Math.FastFourierTransform.realFFT' "Return amplitude and phase vectors for a real FFT"
    input Real[:] 'u';
    input Integer 'nfi';
    output Integer 'info';
    output Real['nfi'] 'amplitudes';
    output Real['nfi'] 'phases';
    Integer 'nu' = size('u', 1);
    Integer 'nf' = div(size('u', 1), 2) + 1;
    Real 'u_DC';
    Real[size('u', 1)] 'u2';
    Real[div(size('u', 1), 2) + 1] 'A';
    Real[div(size('u', 1), 2) + 1] 'Phi';
    Real 'Aeps';
  algorithm
    assert('nfi' > 0 and 'nfi' <= div(size('u', 1), 2) + 1, "Argument nfi is out of range", AssertionLevel.error);
    'u_DC' := sum('u') / 'nu';
    'u2' := 'u' - fill('u_DC', 'nu');
    ('info', 'A', 'Phi') := 'Modelica.Math.FastFourierTransform.Internal.rawRealFFT'('u2');
    'amplitudes' := 'A'[1:'nfi'];
    'phases' := 'Modelica.Units.Conversions.to_deg'('Phi'[(1:'nfi')[1:'nfi']]);
    'Aeps' := 1e-4 * max('amplitudes');
    'amplitudes'[1] := 'u_DC';
    'phases'[1] := 0.0;

    for 'i' in 2:'nfi' loop
      if 'amplitudes'['i'] < 'Aeps' then
        'phases'['i'] := 0.0;
      end if;
    end for;
  end 'Modelica.Math.FastFourierTransform.realFFT';

  model 'Rectifier6pulseFFT' "Example of FFT block"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'V'(unit = "V", quantity = "ElectricPotential") = 81.6496580927726 "Amplitude of star-voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Frequency";
    parameter Real 'RL'(unit = "Ohm", quantity = "Resistance") = 0.4 "Load resistance";
    parameter Real 'C'(min = 0.0, unit = "F", quantity = "Capacitance") = 0.005 "Total DC-capacitance";
    parameter Real 'VC0'(unit = "V", quantity = "ElectricPotential") = 141.42135623730948 "Initial voltage of capacitance";
    parameter Integer 'source.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'source.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'source.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'source.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'source.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'source.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'source.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    parameter Integer 'source.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'source.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'source.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'source.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'source.V[1]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 81.6496580927726 "Amplitudes of sine waves";
    parameter Real 'source.V[2]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 81.6496580927726 "Amplitudes of sine waves";
    parameter Real 'source.V[3]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 81.6496580927726 "Amplitudes of sine waves";
    parameter Real 'source.phase[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phases of sine waves";
    parameter Real 'source.phase[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.0943951023931953 "Phases of sine waves";
    parameter Real 'source.phase[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -4.1887902047863905 "Phases of sine waves";
    parameter Real 'source.f[1]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'source.f[2]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'source.f[3]'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequencies of sine waves";
    parameter Real 'source.offset[1]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'source.offset[2]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'source.offset[3]'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offsets";
    parameter Real 'source.startTime[1]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'source.startTime[2]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'source.startTime[3]'(unit = "s", quantity = "Time") = 0.0 "Time offsets";
    parameter Real 'source.sineVoltage[1].V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 81.6496580927726 "Amplitude of sine wave";
    parameter Real 'source.sineVoltage[1].phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase of sine wave";
    parameter Real 'source.sineVoltage[1].f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
