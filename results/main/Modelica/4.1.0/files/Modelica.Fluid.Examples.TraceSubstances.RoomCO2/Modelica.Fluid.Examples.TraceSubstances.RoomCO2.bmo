    Real 'volume.portAreas[1]'(unit = "m2", quantity = "Area");
    Real 'volume.portAreas[2]'(unit = "m2", quantity = "Area");
    Real 'volume.vessel_ps_static[1]'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Static pressures inside the vessel at the height of the corresponding ports, zero flow velocity";
    Real 'volume.vessel_ps_static[2]'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Static pressures inside the vessel at the height of the corresponding ports, zero flow velocity";
    constant Real 'volume.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 100.0 "cf. suddenExpansion";
    Real 'volume.m_flow_turbulent[1]'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'volume.m_flow_turbulent[2]'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'volume.fluidLevel'(min = 0.0, unit = "m", quantity = "Length") "Level of fluid in the vessel for treating heights of ports";
    parameter Real 'volume.fluidLevel_max'(min = 0.0, unit = "m", quantity = "Length") = 1.0 "Maximum level of fluid in the vessel";
    parameter Real 'volume.vesselArea'(unit = "m2", quantity = "Area") = 55.87154937494352 "Area of the vessel used to relate to cross flow area of ports";
    Real 'volume.portsData_diameter[1]';
    Real 'volume.portsData_diameter[2]';
    Real 'volume.portsData_height[1]';
    Real 'volume.portsData_height[2]';
    Real 'volume.portsData_zeta_in[1]';
    Real 'volume.portsData_zeta_in[2]';
    Real 'volume.portsData_zeta_out[1]';
    Real 'volume.portsData_zeta_out[2]';
    Boolean 'volume.regularFlow[1]'(start = true);
    Boolean 'volume.regularFlow[2]'(start = true);
    Boolean 'volume.inFlow[1]'(start = false);
    Boolean 'volume.inFlow[2]'(start = false);
    parameter Real 'volume.V'(unit = "m3", quantity = "Volume") = 100.0 "Volume";
    parameter Boolean 'pipe.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'pipe.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rate from the connection point into the component";
    Real 'pipe.port_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe.port_a.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'pipe.port_a.Xi_outflow[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
    Real 'pipe.port_a.C_outflow[1]'(start = 1.0, min = 0.0) "Properties c_i/m close to the connection point if m_flow < 0";
    Real 'pipe.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rate from the connection point into the component";
    Real 'pipe.port_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe.port_b.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'pipe.port_b.Xi_outflow[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
    Real 'pipe.port_b.C_outflow[1]'(start = 1.0, min = 0.0) "Properties c_i/m close to the connection point if m_flow < 0";
    parameter Boolean 'pipe.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'pipe.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'pipe.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'pipe.nParallel'(min = 1.0) = 1.0 "Number of identical parallel pipes";
    parameter Real 'pipe.length'(unit = "m", quantity = "Length") = 1.0 "Length";
    parameter Boolean 'pipe.isCircular' = true "= true, if cross sectional area is circular" annotation(Evaluate = true);
    parameter Real 'pipe.diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.15 "Diameter of circular pipe";
    parameter Real 'pipe.crossArea'(unit = "m2", quantity = "Area") = 0.017671458676442587 "Inner cross section area";
    parameter Real 'pipe.perimeter'(min = 0.0, unit = "m", quantity = "Length") = 0.47123889803846897 "Inner perimeter";
    parameter Real 'pipe.roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average height of surface asperities (default: smooth steel pipe)";
    parameter Real 'pipe.V'(unit = "m3", quantity = "Volume") = 0.017671458676442587 "Volume size";
    parameter Real 'pipe.height_ab'(unit = "m", quantity = "Length") = 0.0 "Height(port_b) - Height(port_a)";
    parameter Real 'pipe.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port a";
    parameter Real 'pipe.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port b";
    parameter Real 'pipe.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Moist air") = 0.0 "Start value for mass flow rate" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.from_dp' = true "= true, use m_flow = f(dp), otherwise dp = f(m_flow)" annotation(Evaluate = true);
    parameter Integer 'pipe.flowModel.n' = 2 "Number of discrete flow volumes";
    Real 'pipe.flowModel.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.flowModel.states[1].T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.flowModel.states[1].X[1]'(nominal = 0.1, start = 0.01, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'pipe.flowModel.states[1].X[2]'(nominal = 0.1, start = 0.99, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'pipe.flowModel.states[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.flowModel.states[2].T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.flowModel.states[2].X[1]'(nominal = 0.1, start = 0.01, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'pipe.flowModel.states[2].X[2]'(nominal = 0.1, start = 0.99, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'pipe.flowModel.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    Real 'pipe.flowModel.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    parameter Real 'pipe.flowModel.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'pipe.flowModel.crossAreas[1]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe.flowModel.crossAreas[2]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe.flowModel.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe.flowModel.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe.flowModel.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe.flowModel.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe.flowModel.dheights[1]'(unit = "m", quantity = "Length") "Height(states[2:n]) - Height(states[1:n-1])";
    parameter Real 'pipe.flowModel.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'pipe.flowModel.allowFlowReversal' = true "= true, if flow reversal is enabled, otherwise restrict flow to design direction (states[1] -> states[n+1])" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe.flowModel.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Moist air") = 0.0 "Start value of mass flow rates";
    parameter Real 'pipe.flowModel.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[1] at design inflow";
    parameter Real 'pipe.flowModel.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[n+1] at design outflow";
    parameter Integer 'pipe.flowModel.m' = 1 "Number of flow segments";
    Real 'pipe.flowModel.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe.flowModel.m_flows[1]'(stateSelect = StateSelect.default, start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rates between states";
    Real 'pipe.flowModel.Is[1]'(unit = "kg.m/s", quantity = "Momentum") "Momenta of flow segments";
    Real 'pipe.flowModel.Ib_flows[1]'(unit = "N", quantity = "Force") "Flow of momentum across boundaries";
    Real 'pipe.flowModel.Fs_p[1]'(unit = "N", quantity = "Force") "Pressure forces";
    Real 'pipe.flowModel.Fs_fg[1]'(unit = "N", quantity = "Force") "Friction and gravity forces";
    parameter Boolean 'pipe.flowModel.useUpstreamScheme' = true "= false to average upstream and downstream properties across flow segments" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.use_Ib_flows' = false "= true to consider differences in flow of momentum through boundaries" annotation(Evaluate = true);
    Real 'pipe.flowModel.rhos[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe.flowModel.rhos[2]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe.flowModel.rhos_act[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
    Real 'pipe.flowModel.mus[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe.flowModel.mus[2]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe.flowModel.mus_act[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") "Actual viscosity per segment";
    Real 'pipe.flowModel.dps_fg[1]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    parameter Real 'pipe.flowModel.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0 "Start of turbulent regime, depending on type of flow device";
    parameter Boolean 'pipe.flowModel.show_Res' = true "= true, if Reynolds numbers are included for plotting" annotation(Evaluate = true);
    Real 'pipe.flowModel.Res[1]'(unit = "1", quantity = "ReynoldsNumber") "Reynolds numbers";
    Real 'pipe.flowModel.Res[2]'(unit = "1", quantity = "ReynoldsNumber") "Reynolds numbers";
    Real 'pipe.flowModel.m_flows_turbulent[1]'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Start of turbulent flow";
    parameter Boolean 'pipe.flowModel.use_rho_nominal' = false "= true, if rho_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.rho_nominal'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.1968332236411492 "Nominal density (e.g., rho_liquidWater = 995, rho_air = 1.2)";
    parameter Boolean 'pipe.flowModel.use_mu_nominal' = false "= true, if mu_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.mu_nominal'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") = 1.823286547365138e-5 "Nominal dynamic viscosity (e.g., mu_liquidWater = 1e-3, mu_air = 1.8e-5)";
    Real 'pipe.flowModel.pathLengths_internal[1]'(unit = "m", quantity = "Length") "pathLengths used internally; to be defined by extending class";
    Real 'pipe.flowModel.Res_turbulent_internal[1]'(unit = "1", quantity = "ReynoldsNumber") "Re_turbulent used internally; to be defined by extending class";
    parameter Real 'pipe.flowModel.dp_nominal'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Nominal pressure loss (only for nominal models)";
    parameter Real 'pipe.flowModel.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 100.0 * 'pipe.flowModel.m_flow_small' "Nominal mass flow rate";
    parameter Real 'pipe.flowModel.m_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Within regularization if |m_flows| < m_flow_small (may be wider for large discontinuities in static head)";
    parameter Real 'pipe.flowModel.dp_small'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Within regularization if |dp| < dp_small (may be wider for large discontinuities in static head)";
    parameter Boolean 'pipe.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'pipe.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'pipe.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure loss for nominal conditions";
    Real 'traceSource.port.m_flow'(max = 1e5, min = 0.0, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rate from the connection point into the component";
    Real 'traceSource.port.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'traceSource.port.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'traceSource.port.Xi_outflow[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
    Real 'traceSource.port.C_outflow[1]'(start = 1.0, min = 0.0) "Properties c_i/m close to the connection point if m_flow < 0";
    parameter String 'traceSource.substanceName' = "CO2" "Name of trace substance";
    Real 'traceSource.C' "Trace substance in port medium";
    parameter Integer 'traceSource.ind'(fixed = false) "Index of species in vector of auxiliary substances";
    Real 'traceSource.CVec[1]'(start = 1.0, min = 0.0, quantity = "CO2") "Trace substances vector, needed because indexed argument for the operator inStream is not supported";
  initial equation
    'volume.medium.T' = 'volume.T_start';
    'volume.medium.p' = 101325.0;
    'volume.medium.Xi[1]' = 0.015;
    'volume.mC_scaled[1]' = 'volume.m' * 0.001519 / 0.001519;
    'pipe.flowModel.dp_nominal' = 1000.0 * 'pipe.flowModel.dp_small';
    'pipe.flowModel.dp_small' = 1.0;
  equation
    'boundary4.medium.T_degC' = 'boundary4.medium.T' - 273.15;
    'boundary4.medium.p_bar' = 'boundary4.medium.p' / 1e5;
    'boundary1.medium.T_degC' = 'boundary1.medium.T' - 273.15;
    'boundary1.medium.p_bar' = 'boundary1.medium.p' / 1e5;
    'volume.fluidVolume' = 100.0;
    'volume.medium.T_degC' = 'volume.medium.T' - 273.15;
    'volume.medium.p_bar' = 'volume.medium.p' / 1e5;
    'volume.heatTransfer.states[1].p' = 'volume.medium.state.p';
    'volume.heatTransfer.states[1].T' = 'volume.medium.state.T';
    'volume.fluidLevel' = 0.0;
    'pipe.flowModel.dp_fric_nominal' = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.pressureLoss_m_flow'('pipe.flowModel.m_flow_nominal', 1.1968332236411492, 1.1968332236411492, 1.823286547365138e-5, 1.823286547365138e-5, 'pipe.flowModel.pathLengths_internal[1]', 'pipe.flowModel.diameters[1]', ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') / 2.0, ('pipe.flowModel.roughnesses[1]' + 'pipe.flowModel.roughnesses[2]') / 2.0, 'pipe.flowModel.m_flow_small', 'pipe.flowModel.Res_turbulent_internal[1]');
    'boundary1.C_in[1]' = 'boundary1.C_in_internal[1]';
    'C.y' = 'boundary1.C_in[1]';
    'pipe.port_b.p' = 'boundary4.ports[1].p';
    'traceVolume.port.p' = 'pipe.port_a.p';
    'traceVolume.port.p' = 'volume.ports[2].p';
    'boundary1.ports[2].p' = 'volume.ports[1].p';
    'boundary1.ports[1].p' = 'traceSource.port.p';
    'traceSource.port.m_flow' + 'boundary1.ports[1].m_flow' = 0.0;
    'volume.ports[1].m_flow' + 'boundary1.ports[2].m_flow' = 0.0;
    'pipe.port_a.m_flow' + 'volume.ports[2].m_flow' + 'traceVolume.port.m_flow' = 0.0;
    'volume.heatTransfer.heatPorts[1].Q_flow' = 0.0;
    'pipe.port_b.m_flow' + 'boundary4.ports[1].m_flow' = 0.0;
    'C.y' = 4.5569999999999996e-4;
    assert('boundary4.medium.T' >= 190.0 and 'boundary4.medium.T' <= 647.0, "\nTemperature T is not in the allowed range\n190.0 K <= (T =" + String('boundary4.medium.T') + " K) <= 647.0 K\nrequired from medium model \"" + "Moist air" + "\".", AssertionLevel.error);
    'boundary4.medium.MM' = 1.0 / ('boundary4.medium.Xi[1]' / 0.01801528 + (1.0 - 'boundary4.medium.Xi[1]') / 0.0289651159);
    'boundary4.medium.p_steam_sat' = min('Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.Utilities.spliceFunction'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.saturationPressureLiquid'('boundary4.medium.T'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.sublimationPressureIce'('boundary4.medium.T'), 'boundary4.medium.T' - 273.16, 1.0), 0.999 * 'boundary4.medium.p');
    'boundary4.medium.X_sat' = min('boundary4.medium.p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'boundary4.medium.p' - 'boundary4.medium.p_steam_sat') * (1.0 - 'boundary4.medium.Xi[1]'), 1.0) "Water content at saturation with respect to actual water content";
    'boundary4.medium.X_liquid' = max('boundary4.medium.Xi[1]' - 'boundary4.medium.X_sat', 0.0);
    'boundary4.medium.X_steam' = 'boundary4.medium.Xi[1]' - 'boundary4.medium.X_liquid';
    'boundary4.medium.X_air' = 1.0 - 'boundary4.medium.Xi[1]';
    'boundary4.medium.h' = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.h_pTX'(('Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.setState_pTX'('boundary4.medium.p', 'boundary4.medium.T', 'boundary4.medium.Xi')).p, ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.setState_pTX'('boundary4.medium.p', 'boundary4.medium.T', 'boundary4.medium.Xi')).T, {(('Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.setState_pTX'('boundary4.medium.p', 'boundary4.medium.T', 'boundary4.medium.Xi')).X)[1], (('Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.setState_pTX'('boundary4.medium.p', 'boundary4.medium.T', 'boundary4.medium.Xi')).X)[2]});
    'boundary4.medium.R_s' = 287.0525368759184 * ('boundary4.medium.X_air' / (1.0 - 'boundary4.medium.X_liquid')) + 461.5254384056201 * 'boundary4.medium.X_steam' / (1.0 - 'boundary4.medium.X_liquid');
    'boundary4.medium.u' = 'boundary4.medium.h' - 'boundary4.medium.R_s' * 'boundary4.medium.T';
    'boundary4.medium.d' = 'boundary4.medium.p' / ('boundary4.medium.R_s' * 'boundary4.medium.T');
    'boundary4.medium.state.p' = 'boundary4.medium.p';
    'boundary4.medium.state.T' = 'boundary4.medium.T';
    'boundary4.medium.state.X[1]' = 'boundary4.medium.X[1]';
    'boundary4.medium.state.X[2]' = 'boundary4.medium.X[2]';
    'boundary4.medium.x_sat' = 0.6219647130774989 * 'boundary4.medium.p_steam_sat' / max(2.220446049250313e-14, 'boundary4.medium.p' - 'boundary4.medium.p_steam_sat');
    'boundary4.medium.x_water' = 'boundary4.medium.Xi[1]' / max('boundary4.medium.X_air', 2.220446049250313e-14);
    'boundary4.medium.phi' = 'boundary4.medium.p' / 'boundary4.medium.p_steam_sat' * 'boundary4.medium.Xi[1]' / ('boundary4.medium.Xi[1]' + 0.6219647130774989 * 'boundary4.medium.X_air');
    'boundary4.medium.Xi[1]' = 'boundary4.medium.X[1]';
    'boundary4.medium.X[2]' = 1.0 - 'boundary4.medium.Xi[1]';
    assert('boundary4.medium.X[1]' >= (-1e-5) and 'boundary4.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('boundary4.medium.X[1]') + "of substance " + "water" + "\nof medium " + "Moist air" + " is not in the range 0..1", AssertionLevel.error);
    assert('boundary4.medium.X[2]' >= (-1e-5) and 'boundary4.medium.X[2]' <= 1.00001, "Mass fraction X[" + String(2) + "] = " + String('boundary4.medium.X[2]') + "of substance " + "air" + "\nof medium " + "Moist air" + " is not in the range 0..1", AssertionLevel.error);
    assert('boundary4.medium.p' >= 0.0, "Pressure (= " + String('boundary4.medium.p') + " Pa) of medium \"" + "Moist air" + "\" is negative\n(Temperature = " + String('boundary4.medium.T') + " K)", AssertionLevel.error);
    'boundary4.state.p' = 101325.0;
