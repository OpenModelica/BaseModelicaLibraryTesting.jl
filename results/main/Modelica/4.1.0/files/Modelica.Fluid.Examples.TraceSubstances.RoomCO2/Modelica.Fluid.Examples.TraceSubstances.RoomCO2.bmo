    'pipe.flowModel.vs[2]' = -'pipe.port_b.m_flow' / ('pipe.flowModel.states[2].p' / ((287.0525368759184 * (1.0 - 'pipe.flowModel.states[2].X[1]') + 461.5254384056201 * 'pipe.flowModel.states[2].X[1]') * 'pipe.flowModel.states[2].T')) / 'pipe.flowModel.crossAreas[2]';
    'pipe.flowModel.crossAreas[1]' = 0.017671458676442587;
    'pipe.flowModel.crossAreas[2]' = 0.017671458676442587;
    'pipe.flowModel.dimensions[1]' = 0.15;
    'pipe.flowModel.dimensions[2]' = 0.15;
    'pipe.flowModel.roughnesses[1]' = 2.5e-5;
    'pipe.flowModel.roughnesses[2]' = 2.5e-5;
    'pipe.flowModel.dheights[1]' = 0.0;
    'pipe.flowModel.pathLengths[1]' = 1.0;
    'pipe.flowModel.rhos[1]' = 'pipe.flowModel.states[1].p' / ((287.0525368759184 * (1.0 - 'pipe.flowModel.states[1].X[1]') + 461.5254384056201 * 'pipe.flowModel.states[1].X[1]') * 'pipe.flowModel.states[1].T');
    'pipe.flowModel.rhos[2]' = 'pipe.flowModel.states[2].p' / ((287.0525368759184 * (1.0 - 'pipe.flowModel.states[2].X[1]') + 461.5254384056201 * 'pipe.flowModel.states[2].X[1]') * 'pipe.flowModel.states[2].T');
    'pipe.flowModel.mus[1]' = 1e-6 * 'Modelica.Math.Polynomials.evaluateWithRange'({9.739110288630587e-15, -3.1353724870333906e-11, 4.3004876595642225e-8, -3.822801629175824e-5, 0.05042787436718076, 17.23926013924253}, -149.99999999999997, 1000.0000000000001, 'pipe.flowModel.states[1].T' - 273.15);
    'pipe.flowModel.mus[2]' = 1e-6 * 'Modelica.Math.Polynomials.evaluateWithRange'({9.739110288630587e-15, -3.1353724870333906e-11, 4.3004876595642225e-8, -3.822801629175824e-5, 0.05042787436718076, 17.23926013924253}, -149.99999999999997, 1000.0000000000001, 'pipe.flowModel.states[2].T' - 273.15);
    'pipe.flowModel.Res[1]' = abs('pipe.flowModel.vs[1]') * 'pipe.flowModel.rhos[1]' * 'pipe.flowModel.dimensions[1]' / 'pipe.flowModel.mus[1]';
    'pipe.flowModel.Res[2]' = abs('pipe.flowModel.vs[2]') * 'pipe.flowModel.rhos[2]' * 'pipe.flowModel.dimensions[2]' / 'pipe.flowModel.mus[2]';
    'pipe.flowModel.m_flows_turbulent[1]' = ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') / ('pipe.flowModel.dimensions[1]' + 'pipe.flowModel.dimensions[2]') * 'pipe.flowModel.mus_act[1]' * 4000.0;
    'pipe.flowModel.pathLengths_internal[1]' = 'pipe.flowModel.pathLengths[1]';
    'pipe.flowModel.Res_turbulent_internal[1]' = 4000.0;
    'pipe.flowModel.diameters[1]' = 0.5 * ('pipe.flowModel.dimensions[1]' + 'pipe.flowModel.dimensions[2]');
    'pipe.flowModel.m_flows[1]' = homotopy('Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead'('pipe.flowModel.dps_fg[1]', 'pipe.flowModel.rhos[1]', 'pipe.flowModel.rhos[2]', 'pipe.flowModel.mus[1]', 'pipe.flowModel.mus[2]', 'pipe.flowModel.pathLengths_internal[1]', 'pipe.flowModel.diameters[1]', 9.80665 * 'pipe.flowModel.dheights[1]', ('pipe.flowModel.crossAreas[1]' + 'pipe.flowModel.crossAreas[2]') / 2.0, ('pipe.flowModel.roughnesses[1]' + 'pipe.flowModel.roughnesses[2]') / 2.0, 'pipe.flowModel.dp_small', 'pipe.flowModel.Res_turbulent_internal[1]'), 'pipe.flowModel.m_flow_nominal' / 'pipe.flowModel.dp_nominal' * ('pipe.flowModel.dps_fg[1]' - 9.80665 * 'pipe.flowModel.dheights[1]' * 1.1968332236411492));
    'pipe.flowModel.rhos_act[1]' = noEvent(if 'pipe.flowModel.m_flows[1]' > 0.0 then 'pipe.flowModel.rhos[1]' else 'pipe.flowModel.rhos[2]');
    'pipe.flowModel.mus_act[1]' = noEvent(if 'pipe.flowModel.m_flows[1]' > 0.0 then 'pipe.flowModel.mus[1]' else 'pipe.flowModel.mus[2]');
    'pipe.flowModel.Ib_flows[1]' = 0.0;
