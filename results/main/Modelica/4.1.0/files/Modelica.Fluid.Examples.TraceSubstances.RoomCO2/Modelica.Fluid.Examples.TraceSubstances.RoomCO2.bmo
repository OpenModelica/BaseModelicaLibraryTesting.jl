  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'boundary1.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'boundary1.Medium.ThermodynamicState'('p', 'T', 'X') else 'boundary1.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.saturationPressureLiquid';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'volume.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'volume.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.T_phX'('p', 'h', 'X'), 'X') else 'volume.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'pipe.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'pipe.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.Medium.T_phX'('p', 'h', 'X'), 'X') else 'pipe.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.Medium.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := 'Modelica.Math.tan'('scaledXp');
      'y' := 0.5 * 'Modelica.Math.tanh'('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.sublimationPressureIce' "Return sublimation pressure of water as a function of temperature T between 190 and 273.16 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
  algorithm
    'psat' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.sublimationPressureIce_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.sublimationPressureIce';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'volume.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'volume.Medium.ThermodynamicState'('p', 'T', 'X') else 'volume.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.saturationPressureLiquid_der' "Derivative function for 'saturationPressureLiquid'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
    Real 'r1_der' = -1.0 / 'Tcritical' * 'dTsat';
    Real 'r2' = 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6];
  algorithm
    'psat_der' := exp('r2' * 'Tcritical' / 'Tsat') * 'pcritical' * (('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der') + 'a'[3] * ('r1' ^ ('n'[3] - 1.0) * 'n'[3] * 'r1_der') + 'a'[4] * ('r1' ^ ('n'[4] - 1.0) * 'n'[4] * 'r1_der') + 'a'[5] * ('r1' ^ ('n'[5] - 1.0) * 'n'[5] * 'r1_der') + 'a'[6] * ('r1' ^ ('n'[6] - 1.0) * 'n'[6] * 'r1_der')) * 'Tcritical' / 'Tsat' - 'r2' * 'Tcritical' * 'dTsat' / 'Tsat' ^ 2.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.saturationPressureLiquid_der';

  function 'Modelica.Math.Polynomials.evaluateWithRange_der' "Evaluate derivative of polynomial at a given abscissa value with extrapolation outside of the defined range"
    input Real[:] 'p';
    input Real 'uMin';
    input Real 'uMax';
    input Real 'u';
    input Real 'du';
    output Real 'dy';
  algorithm
    if 'u' < 'uMin' then
      'dy' := 'Modelica.Math.Polynomials.evaluate_der'('p', 'uMin', 'du');
    elseif 'u' > 'uMax' then
      'dy' := 'Modelica.Math.Polynomials.evaluate_der'('p', 'uMax', 'du');
    elseif true then
      'dy' := 'Modelica.Math.Polynomials.evaluate_der'('p', 'u', 'du');
    end if;
  end 'Modelica.Math.Polynomials.evaluateWithRange_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.h_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := 'Modelica.Math.tan'('scaledXp');
      'y' := 0.5 * 'Modelica.Math.tanh'('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.Utilities.spliceFunction_der' "Derivative of spliceFunction"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    input Real 'dpos';
    input Real 'dneg';
    input Real 'dx';
    input Real 'ddeltax' = 0.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'dscaledX1';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := 'Modelica.Math.tan'('scaledXp');
      'y' := 0.5 * 'Modelica.Math.tanh'('scaledXt') + 0.5;
    end if;

    'out' := 'dpos' * 'y' + (1.0 - 'y') * 'dneg';

    if abs('scaledX1') < 'lim' then
      'dscaledX1' := ('dx' - 'scaledX1' * 'ddeltax') / 'deltax';
      'out' := 'out' + ('pos' - 'neg') * 'dscaledX1' * 0.25 * 3.141592653589793 * (1.0 - 'Modelica.Math.tanh'('scaledXt') ^ 2.0) * ('scaledXt' ^ 2.0 + 1.0);
    end if;
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.Utilities.spliceFunction_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.saturationPressureLiquid';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'boundary4.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'boundary4.Medium.ThermodynamicState'('p', 'T', 'X') else 'boundary4.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.Utilities.spliceFunction_der' "Derivative of spliceFunction"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    input Real 'dpos';
    input Real 'dneg';
    input Real 'dx';
    input Real 'ddeltax' = 0.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'dscaledX1';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := 'Modelica.Math.tan'('scaledXp');
      'y' := 0.5 * 'Modelica.Math.tanh'('scaledXt') + 0.5;
    end if;

    'out' := 'dpos' * 'y' + (1.0 - 'y') * 'dneg';

    if abs('scaledX1') < 'lim' then
      'dscaledX1' := ('dx' - 'scaledX1' * 'ddeltax') / 'deltax';
      'out' := 'out' + ('pos' - 'neg') * 'dscaledX1' * 0.25 * 3.141592653589793 * (1.0 - 'Modelica.Math.tanh'('scaledXt') ^ 2.0) * ('scaledXt' ^ 2.0 + 1.0);
    end if;
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.Utilities.spliceFunction_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := 'Modelica.Math.tan'('scaledXp');
      'y' := 0.5 * 'Modelica.Math.tanh'('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary4.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.h_pTX_der' "Derivative function of h_pTX"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real 'dp'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    input Real 'dT'(unit = "K/s", quantity = "TemperatureSlope");
    input Real[:] 'dX'(each unit = "1/s");
    output Real 'h_der'(unit = "J/(kg.s)");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'x_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'dX_steam'(unit = "1/s");
    Real 'dX_air'(unit = "1/s");
    Real 'dX_liq'(unit = "1/s");
    Real 'dps'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dx_sat'(unit = "1/s");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.saturationPressure'('T');
    'x_sat' := 'p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat');
    'X_sat' := min('x_sat' * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.Utilities.smoothMax'('X'[1] - 'X_sat', 0.0, 1e-5);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'dX_air' := -'dX'[1];
    'dps' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.saturationPressure_der'('T', 'dT');
    'dx_sat' := 0.6219647130774989 * ('dps' * ('p' - 'p_steam_sat') - 'p_steam_sat' * ('dp' - 'dps')) / ('p' - 'p_steam_sat') / ('p' - 'p_steam_sat');
    'dX_liq' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.Utilities.smoothMax_der'('X'[1] - 'X_sat', 0.0, 1e-5, (1.0 + 'x_sat') * 'dX'[1] - (1.0 - 'X'[1]) * 'dx_sat', 0.0, 0.0);
    'dX_steam' := 'dX'[1] - 'dX_liq';
    'h_der' := 'X_steam' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow_der'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6, 'dT') + 'dX_steam' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) + 'X_air' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow_der'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684, 'dT') + 'dX_air' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) + 'X_liquid' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.enthalpyOfWater_der'('T', 'dT') + 'dX_liq' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.enthalpyOfWater'('T');
    annotation(Inline = false, smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.h_pTX_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.volume.Medium.h_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.h_pTX';

  function 'Modelica.Fluid.Utilities.checkBoundary' "Check whether boundary definition is correct"
    input String 'mediumName';
    input String[:] 'substanceNames';
    input Boolean 'singleState';
    input Boolean 'define_p';
    input Real[:] 'X_boundary';
    input String 'modelName' = "??? boundary ???";
    Integer 'nX' = size('X_boundary', 1);
    String 'X_str';
  algorithm
    assert(not 'singleState' or 'singleState' and 'define_p', "\nWrong value of parameter define_p (= false) in model \"" + 'modelName' + "\":\nThe selected medium \"" + 'mediumName' + "\" has Medium.singleState=true.\nTherefore, an boundary density cannot be defined and\ndefine_p = true is required.\n", AssertionLevel.error);

    for 'i' in 1:'nX' loop
      assert('X_boundary'['i'] >= 0.0, "\nWrong boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\":\nThe boundary value X_boundary(" + String('i') + ") = " + String('X_boundary'['i']) + "\nis negative. It must be positive.\n", AssertionLevel.error);
    end for;

    if 'nX' > 0 and abs(sum('X_boundary') - 1.0) > 1e-10 then
      'X_str' := "";

      for 'i' in 1:'nX' loop
        'X_str' := 'X_str' + "   X_boundary[" + String('i') + "] = " + String('X_boundary'['i']) + " \"" + 'substanceNames'['i'] + "\"\n";
      end for;

      'Modelica.Utilities.Streams.error'("The boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\"\n" + "do not sum up to 1. Instead, sum(X_boundary) = " + String(sum('X_boundary')) + ":\n" + 'X_str');
    end if;
  end 'Modelica.Fluid.Utilities.checkBoundary';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / 'Modelica.Math.log10'('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * 'Modelica.Math.exp'(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.pipe.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.sublimationPressureIce' "Return sublimation pressure of water as a function of temperature T between 190 and 273.16 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
  algorithm
    'psat' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.sublimationPressureIce_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.sublimationPressureIce';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.sublimationPressureIce_der' "Derivative function for 'sublimationPressureIce'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
    Real 'r1_der' = 'dTsat' / 'Ttriple';
  algorithm
    'psat_der' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple' * (-('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der')));
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.sublimationPressureIce_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2.boundary1.Medium.saturationPressureLiquid';

  type 'Modelica.Fluid.Types.PortFlowDirection' = enumeration('Entering', 'Leaving', 'Bidirectional');

  type 'Modelica.Fluid.Types.Dynamics' = enumeration('DynamicFreeInitial', 'FixedInitial', 'SteadyStateInitial', 'SteadyState');

  record 'volume.Medium.ThermodynamicState'
    Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[2] 'X'(nominal = fill(0.1, 2), start = {0.01, 0.99}, max = fill(1.0, 2), min = fill(0.0, 2), unit = fill("kg/kg", 2), quantity = fill("MassFraction", 2));
  end 'volume.Medium.ThermodynamicState';

  record 'boundary4.Medium.ThermodynamicState'
    Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[2] 'X'(nominal = fill(0.1, 2), start = {0.01, 0.99}, max = fill(1.0, 2), min = fill(0.0, 2), unit = fill("kg/kg", 2), quantity = fill("MassFraction", 2));
  end 'boundary4.Medium.ThermodynamicState';

  record 'boundary1.Medium.ThermodynamicState'
    Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[2] 'X'(nominal = fill(0.1, 2), start = {0.01, 0.99}, max = fill(1.0, 2), min = fill(0.0, 2), unit = fill("kg/kg", 2), quantity = fill("MassFraction", 2));
  end 'boundary1.Medium.ThermodynamicState';

  record 'pipe.Medium.ThermodynamicState'
    Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[2] 'X'(nominal = fill(0.1, 2), start = {0.01, 0.99}, max = fill(1.0, 2), min = fill(0.0, 2), unit = fill("kg/kg", 2), quantity = fill("MassFraction", 2));
  end 'pipe.Medium.ThermodynamicState';

  record 'Modelica.Media.IdealGases.Common.DataRecord'
    String 'name';
    Real 'MM'(min = 0.0, unit = "kg/mol", quantity = "MolarMass");
    Real 'Hf'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'H0'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'Tlimit'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[7] 'alow';
    Real[2] 'blow';
    Real[7] 'ahigh';
    Real[2] 'bhigh';
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  end 'Modelica.Media.IdealGases.Common.DataRecord';

  type 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' = enumeration('ZeroAt0K', 'ZeroAt25C', 'UserDefined');

  model 'RoomCO2' "Demonstrates a room volume with CO2 accumulation"
    parameter Real 'C.k'(start = 1.0) = 4.5569999999999996e-4 "Constant output value";
    Real 'C.y' "Connector of Real output signal";
    parameter Integer 'boundary4.nPorts' = 1 "Number of ports";
    Real 'boundary4.medium.p'(stateSelect = StateSelect.default, nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'boundary4.medium.Xi[1]'(stateSelect = StateSelect.default, start = 0.01, max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") "Structurally independent mass fractions";
    Real 'boundary4.medium.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'boundary4.medium.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'boundary4.medium.T'(stateSelect = StateSelect.default, nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'boundary4.medium.X[1]'(nominal = 0.1, start = 0.01, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'boundary4.medium.X[2]'(nominal = 0.1, start = 0.99, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'boundary4.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'boundary4.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'boundary4.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'boundary4.medium.state.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'boundary4.medium.state.T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'boundary4.medium.state.X[1]'(nominal = 0.1, start = 0.01, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'boundary4.medium.state.X[2]'(nominal = 0.1, start = 0.99, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    parameter Boolean 'boundary4.medium.preferredMediumStates' = false "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'boundary4.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'boundary4.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'boundary4.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'boundary4.medium.x_water'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass of total water/mass of dry air";
    Real 'boundary4.medium.phi' "Relative humidity";
    Real 'boundary4.medium.X_liquid'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fraction of liquid or solid water";
    Real 'boundary4.medium.X_steam'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fraction of steam water";
    Real 'boundary4.medium.X_air'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fraction of air";
    Real 'boundary4.medium.X_sat'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Steam water mass fraction of saturation boundary in kg_water/kg_moistair";
    Real 'boundary4.medium.x_sat'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Steam water mass content of saturation boundary in kg_water/kg_dryair";
    Real 'boundary4.medium.p_steam_sat'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Partial saturation pressure of steam";
    Real 'boundary4.ports[1].m_flow'(max = 1e60, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rate from the connection point into the component";
    Real 'boundary4.ports[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'boundary4.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'boundary4.ports[1].Xi_outflow[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
    Real 'boundary4.ports[1].C_outflow[1]'(start = 1.0, min = 0.0) "Properties c_i/m close to the connection point if m_flow < 0";
    parameter 'Modelica.Fluid.Types.PortFlowDirection' 'boundary4.flowDirection' = 'Modelica.Fluid.Types.PortFlowDirection'.'Bidirectional' "Allowed flow direction" annotation(Evaluate = true);
    parameter Boolean 'boundary4.use_p' = true "Select p or d" annotation(Evaluate = true);
    parameter Real 'boundary4.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Boundary pressure";
    parameter Real 'boundary4.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.1968332236411492 "Boundary density";
    parameter Boolean 'boundary4.use_T' = true "Select T or h" annotation(Evaluate = true);
    parameter Real 'boundary4.T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Boundary temperature";
    parameter Real 'boundary4.h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 45262.582490480156 "Boundary specific enthalpy";
    parameter Real 'boundary4.X[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 0.01 "Boundary mass fractions m_i/m";
    parameter Real 'boundary4.X[2]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 0.99 "Boundary mass fractions m_i/m";
    parameter Real 'boundary4.C[1]'(start = 1.0, min = 0.0, quantity = "CO2") = 0.0 "Boundary trace substances";
    Real 'boundary4.state.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'boundary4.state.T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'boundary4.state.X[1]'(nominal = 0.1, start = 0.01, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'boundary4.state.X[2]'(nominal = 0.1, start = 0.99, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'traceVolume.port.m_flow'(max = 1e5, min = 0.0, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rate from the connection point into the component";
    Real 'traceVolume.port.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'traceVolume.port.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'traceVolume.port.Xi_outflow[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
    Real 'traceVolume.port.C_outflow[1]'(start = 1.0, min = 0.0) "Properties c_i/m close to the connection point if m_flow < 0";
    parameter String 'traceVolume.substanceName' = "CO2" "Name of trace substance";
    Real 'traceVolume.C' "Trace substance in port medium";
    parameter Integer 'traceVolume.ind'(fixed = false) "Index of species in vector of auxiliary substances";
    Real 'traceVolume.CVec[1]'(start = 1.0, min = 0.0, quantity = "CO2") "Trace substances vector, needed because indexed argument for the operator inStream is not supported";
    parameter Real 'system.p_ambient'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default ambient pressure";
    parameter Real 'system.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default ambient temperature";
    parameter Real 'system.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'system.allowFlowReversal' = true "= false to restrict to design flow direction (port_a -> port_b)" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of energy balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of mass balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of trace substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Default formulation of momentum balances, if options available" annotation(Evaluate = true);
    parameter Real 'system.m_flow_start'(unit = "kg/s", quantity = "MassFlowRate") = 0.0 "Default start value for mass flow rates";
    parameter Real 'system.p_start'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default start value for pressures";
