    assert('traceSource.ind' > 0, "Trace substance 'CO2' is not present in medium 'Moist air'.\nCheck sensor parameter and medium model.", AssertionLevel.error);
    annotation(experiment(StopTime = 3600));
  end 'RoomCO2';
end 'RoomCO2';
