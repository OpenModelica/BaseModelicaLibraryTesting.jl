    'transformer1.i2[1]' = 0.0;
    'transformer1.i2[2]' = 0.0;
  equation
    'transformer1.powerBalance.power1' = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'({'transformer1.v1[1]', 'transformer1.v1[2]', 'transformer1.v1[3]'}, {'transformer1.i1[1]', 'transformer1.i1[2]', 'transformer1.i1[3]'});
    'transformer1.powerBalance.power2' = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'({'transformer1.v2[1]', 'transformer1.v2[2]', 'transformer1.v2[3]'}, {'transformer1.i2[1]', 'transformer1.i2[2]', 'transformer1.i2[3]'});
    'transformer1.powerBalance.lossPowerTotal' = 'transformer1.powerBalance.lossPower1' + 'transformer1.powerBalance.lossPower2' + 'transformer1.powerBalance.lossPowerCore';
    'transformer1.powerBalance.lossPower1' = 'transformer1.r1.resistor[1].LossPower' + 'transformer1.r1.resistor[2].LossPower' + 'transformer1.r1.resistor[3].LossPower';
    'transformer1.powerBalance.lossPower2' = 'transformer1.r2.resistor[1].LossPower' + 'transformer1.r2.resistor[2].LossPower' + 'transformer1.r2.resistor[3].LossPower';
    'transformer1.powerBalance.lossPowerCore' = 0.0;
    'transformer1.r1.resistor[1].heatPort.T' = 'transformer1.r1.resistor[1].T_heatPort';
    'transformer1.r1.resistor[1].heatPort.Q_flow' = -'transformer1.r1.resistor[1].LossPower';
    'transformer1.r1.resistor[2].heatPort.T' = 'transformer1.r1.resistor[2].T_heatPort';
    'transformer1.r1.resistor[2].heatPort.Q_flow' = -'transformer1.r1.resistor[2].LossPower';
    'transformer1.r1.resistor[3].heatPort.T' = 'transformer1.r1.resistor[3].T_heatPort';
