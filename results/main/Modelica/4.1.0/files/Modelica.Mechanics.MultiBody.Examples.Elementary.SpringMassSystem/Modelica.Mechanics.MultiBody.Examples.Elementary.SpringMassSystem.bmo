    'spring2.lineForce.frame_b.f[3]' = -('spring2.lineForce.frame_b.R.T[3,1]' * ('spring2.lineForce.e_rel_0[1]' * 'spring2.lineForce.fb') + 'spring2.lineForce.frame_b.R.T[3,2]' * ('spring2.lineForce.e_rel_0[2]' * 'spring2.lineForce.fb') + 'spring2.lineForce.frame_b.R.T[3,3]' * ('spring2.lineForce.e_rel_0[3]' * 'spring2.lineForce.fb'));
    assert(noEvent('spring2.lineForce.length' > 1e-10), "\nThe distance between the origin of frame_a and the origin of frame_b\nof a line force component became smaller as parameter s_small\n(= a small number, defined in the \"Advanced\" menu). The distance is\nset to s_small, although it is smaller, to avoid a division by zero\nwhen computing the direction of the line force. Possible reasons\nfor this situation:\n- At initial time the distance may already be zero: Change the initial\n  positions of the bodies connected by this element.\n- Hardware stops are not modeled or are modeled not stiff enough.\n  Include stops, e.g., stiff springs, or increase the stiffness\n  if already present.\n- Another error in your model may lead to unrealistically large forces\n  and torques that would in reality destroy the stops.\n- The flange_b connector might be defined by a pre-defined motion,\n  e.g., with Modelica.Mechanics.Translational.Position and the\n  predefined flange_b.s is zero or negative.\n", AssertionLevel.error);
    'spring2.lineForce.r_rel_0[1]' = 'spring2.lineForce.frame_b.r_0[1]' - 'spring2.lineForce.frame_a.r_0[1]';
    'spring2.lineForce.r_rel_0[2]' = 'spring2.lineForce.frame_b.r_0[2]' - 'spring2.lineForce.frame_a.r_0[2]';
    'spring2.lineForce.r_rel_0[3]' = 'spring2.lineForce.frame_b.r_0[3]' - 'spring2.lineForce.frame_a.r_0[3]';
    'spring2.lineForce.length' = sqrt('spring2.lineForce.r_rel_0[1]' * 'spring2.lineForce.r_rel_0[1]' + 'spring2.lineForce.r_rel_0[2]' * 'spring2.lineForce.r_rel_0[2]' + 'spring2.lineForce.r_rel_0[3]' * 'spring2.lineForce.r_rel_0[3]');
    'spring2.lineForce.s' = if 'spring2.lineForce.length' > 1e-10 then 'spring2.lineForce.length' else 1e-10;
    'spring2.lineForce.e_rel_0[1]' = 'spring2.lineForce.r_rel_0[1]' / 'spring2.lineForce.s';
    'spring2.lineForce.e_rel_0[2]' = 'spring2.lineForce.r_rel_0[2]' / 'spring2.lineForce.s';
    'spring2.lineForce.e_rel_0[3]' = 'spring2.lineForce.r_rel_0[3]' / 'spring2.lineForce.s';
    'spring2.lineForce.frame_a.t[1]' = 0.0;
    'spring2.lineForce.frame_a.t[2]' = 0.0;
    'spring2.lineForce.frame_a.t[3]' = 0.0;
    'spring2.lineForce.frame_b.t[1]' = 0.0;
    'spring2.lineForce.frame_b.t[2]' = 0.0;
    'spring2.lineForce.frame_b.t[3]' = 0.0;
    'spring2.spring.f' = 30.0 * ('spring2.spring.s_rel' - 0.1);
    'spring2.spring.s_rel' = 'spring2.spring.flange_b.s' - 'spring2.spring.flange_a.s';
    'spring2.spring.flange_b.f' = 'spring2.spring.f';
    'spring2.spring.flange_a.f' = -'spring2.spring.f';
    'spring2.r_rel_a[1]' = 'spring2.frame_a.R.T[1,1]' * 'spring2.r_rel_0[1]' + 'spring2.frame_a.R.T[1,2]' * 'spring2.r_rel_0[2]' + 'spring2.frame_a.R.T[1,3]' * 'spring2.r_rel_0[3]';
    'spring2.r_rel_a[2]' = 'spring2.frame_a.R.T[2,1]' * 'spring2.r_rel_0[1]' + 'spring2.frame_a.R.T[2,2]' * 'spring2.r_rel_0[2]' + 'spring2.frame_a.R.T[2,3]' * 'spring2.r_rel_0[3]';
    'spring2.r_rel_a[3]' = 'spring2.frame_a.R.T[3,1]' * 'spring2.r_rel_0[1]' + 'spring2.frame_a.R.T[3,2]' * 'spring2.r_rel_0[2]' + 'spring2.frame_a.R.T[3,3]' * 'spring2.r_rel_0[3]';
    'spring2.e_a[1]' = 'spring2.r_rel_a[1]' / 'spring2.s';
    'spring2.e_a[2]' = 'spring2.r_rel_a[2]' / 'spring2.s';
    'spring2.e_a[3]' = 'spring2.r_rel_a[3]' / 'spring2.s';
    'spring2.f' = 'spring2.spring.f';
    'spring2.length' = 'spring2.lineForce.length';
    'spring2.s' = 'spring2.lineForce.s';
    'spring2.r_rel_0[1]' = 'spring2.lineForce.r_rel_0[1]';
    'spring2.r_rel_0[2]' = 'spring2.lineForce.r_rel_0[2]';
    'spring2.r_rel_0[3]' = 'spring2.lineForce.r_rel_0[3]';
    'spring2.e_rel_0[1]' = 'spring2.lineForce.e_rel_0[1]';
    'spring2.e_rel_0[2]' = 'spring2.lineForce.e_rel_0[2]';
    'spring2.e_rel_0[3]' = 'spring2.lineForce.e_rel_0[3]';
    annotation(experiment(StopTime = 5));
  end 'SpringMassSystem';
end 'SpringMassSystem';
