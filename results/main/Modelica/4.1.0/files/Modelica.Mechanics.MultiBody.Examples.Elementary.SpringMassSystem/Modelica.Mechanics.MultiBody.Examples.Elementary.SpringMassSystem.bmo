    Real 'world.x_label.n_y[3]'(unit = "1") "Vector in direction of y-axis of 'lines' frame, resolved in object frame";
    Real 'world.x_label.lines[1,1,1]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
    Real 'world.x_label.lines[1,1,2]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
    Real 'world.x_label.lines[1,2,1]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
    Real 'world.x_label.lines[1,2,2]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
    Real 'world.x_label.lines[2,1,1]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
    Real 'world.x_label.lines[2,1,2]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
    Real 'world.x_label.lines[2,2,1]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
    Real 'world.x_label.lines[2,2,2]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
    Real 'world.x_label.diameter'(min = 0.0, unit = "m", quantity = "Length") "Diameter of the cylinders defined by lines";
    Integer 'world.x_label.color[1]'(max = 255, min = 0) "Color of cylinders";
    Integer 'world.x_label.color[2]'(max = 255, min = 0) "Color of cylinders";
    Integer 'world.x_label.color[3]'(max = 255, min = 0) "Color of cylinders";
