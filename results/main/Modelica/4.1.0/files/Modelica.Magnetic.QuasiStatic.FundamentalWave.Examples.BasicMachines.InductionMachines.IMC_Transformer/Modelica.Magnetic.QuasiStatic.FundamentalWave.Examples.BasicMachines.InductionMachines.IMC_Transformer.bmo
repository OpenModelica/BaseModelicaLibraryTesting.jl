//! base 0.1.0
package 'IMC_Transformer'
  function 'Modelica.Electrical.QuasiStatic.Polyphase.Functions.quasiRMS' "Overall quasi-RMS value of complex input (current or voltage)"
    input 'Complex'[:] 'u';
    output Real 'y';
    Integer 'm' = size('u', 1);
  algorithm
    'y' := sum(sqrt('u['k']'.'re' ^ 2.0 + 'u['k']'.'im' ^ 2.0) for 'k' in 1:'m') / 'm';
    annotation(Inline = true);
  end 'Modelica.Electrical.QuasiStatic.Polyphase.Functions.quasiRMS';

  function 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower' "Calculate active power of voltage and current input"
    input Real[3] 'v'(unit = {"V", "V", "V"}, quantity = {"ElectricPotential", "ElectricPotential", "ElectricPotential"});
    input Real[3] 'i'(unit = {"A", "A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent", "ElectricCurrent"});
    output Real 'p'(unit = "W", quantity = "Power");
    constant Integer 'm' = 3;
    Real[2] 'v_'(unit = {"V", "V"}, quantity = {"ElectricPotential", "ElectricPotential"});
    Real[2] 'i_'(unit = {"A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent"});
  algorithm
    'v_' := {0.0, 0.0};
    'i_' := {0.0, 0.0};

    for 'k' in 1:'m' loop
      'v_' := {'v_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k'], 'v_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k']};
      'i_' := {'i_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k'], 'i_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k']};
    end for;

    'p' := 'm' / 2.0 * ('v_'[1] * 'i_'[1] + 'v_'[2] * 'i_'[2]);
    annotation(Inline = true);
  end 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    elseif true then
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  record 'Modelica.Units.SI.ComplexVoltage'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexVoltage';

  record 'Modelica.Units.SI.ComplexCurrent'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexCurrent';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexInput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexInput';

  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  model 'IMC_Transformer' "Induction machine with squirrel cage starting with transformer"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'tStart1'(unit = "s", quantity = "Time") = 0.1 "Start time";
    parameter Real 'tStart2'(unit = "s", quantity = "Time") = 2.0 "Start time of bypass transformer";
    parameter Real 'TLoad'(unit = "N.m", quantity = "Torque") = 161.4 "Nominal load torque";
    parameter Real 'wLoad'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal load speed";
    parameter Real 'JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load's moment of inertia";
    constant Real 'imcQS.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    parameter Integer 'imcQS.m'(min = 3) = 3 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'imcQS.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor inertia";
    parameter Boolean 'imcQS.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'imcQS.Js'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator inertia";
    parameter Boolean 'imcQS.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Integer 'imcQS.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'imcQS.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'imcQS.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
    parameter Real 'imcQS.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'imcQS.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'imcQS.alpha20s'(start = 0.0, displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'imcQS.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'imcQS.Lssigma'(start = 3.239643625499069e-4, unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator stray inductance per phase";
    parameter Real 'imcQS.L0.d'(start = 1.0, unit = "H", quantity = "Inductance") = 0.006150221481975876 "Component of d (direct) axis, aligned to real part";
    parameter Real 'imcQS.L0.q'(start = 1.0, unit = "H", quantity = "Inductance") = 0.006150221481975876 "Component of q (quadrature) axis, aligned to imaginary part";
    parameter Real 'imcQS.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'imcQS.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'imcQS.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'imcQS.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'imcQS.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'imcQS.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'imcQS.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'imcQS.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'imcQS.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'imcQS.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'imcQS.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'imcQS.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'imcQS.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'imcQS.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'imcQS.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'imcQS.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'imcQS.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'imcQS.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'imcQS.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    Real 'imcQS.gammas'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of stator reference frame";
    Real 'imcQS.gammar'(fixed = true, start = 1.5707963267948966, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of stator reference frame";
    Real 'imcQS.gamma'(fixed = true, start = -1.5707963267948966, displayUnit = "deg", unit = "rad", quantity = "Angle") "Electrical angle between stator and rotor";
    Real 'imcQS.phiMechanical'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Mechanical angle of rotor against stator";
    Real 'imcQS.wMechanical'(fixed = true, start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") "Mechanical angular velocity of rotor against stator";
    Real 'imcQS.tauElectrical'(unit = "N.m", quantity = "Torque") "Electromagnetic torque";
    Real 'imcQS.tauShaft'(unit = "N.m", quantity = "Torque") "Shaft torque";
    Real 'imcQS.powerBalance.powerStator'(unit = "W", quantity = "Power") "Electrical power (stator)";
    Real 'imcQS.powerBalance.powerMechanical'(unit = "W", quantity = "Power") "Mechanical power";
    Real 'imcQS.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") "Stator inertia power";
    Real 'imcQS.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") "Rotor inertia power";
    Real 'imcQS.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") "Total loss power";
    Real 'imcQS.powerBalance.lossPowerStatorWinding'(unit = "W", quantity = "Power") "Stator copper losses";
    Real 'imcQS.powerBalance.lossPowerStatorCore'(unit = "W", quantity = "Power") "Stator core losses";
    Real 'imcQS.powerBalance.lossPowerRotorCore'(unit = "W", quantity = "Power") "Rotor core losses";
    Real 'imcQS.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") "Stray load losses";
    Real 'imcQS.powerBalance.lossPowerFriction'(unit = "W", quantity = "Power") "Friction losses";
    Real 'imcQS.powerBalance.lossPowerRotorWinding'(unit = "W", quantity = "Power") "Rotor copper losses";
    Real 'imcQS.vs[1].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.vs[1].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.vs[2].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.vs[2].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.vs[3].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.vs[3].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.abs_vs[1]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'imcQS.abs_vs[2]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'imcQS.abs_vs[3]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'imcQS.arg_vs[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'imcQS.arg_vs[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'imcQS.arg_vs[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'imcQS.is[1].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.is[1].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.is[2].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.is[2].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.is[3].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.is[3].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.abs_is[1]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'imcQS.abs_is[2]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'imcQS.abs_is[3]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'imcQS.arg_is[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'imcQS.arg_is[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'imcQS.arg_is[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'imcQS.Ps[1]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'imcQS.Ps[2]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'imcQS.Ps[3]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'imcQS.Ps_total'(unit = "W", quantity = "Power") "Total active stator power";
    Real 'imcQS.Qs[1]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'imcQS.Qs[2]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'imcQS.Qs[3]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'imcQS.Qs_total'(unit = "var", quantity = "Power") "Total reactive stator power";
    Real 'imcQS.Ss[1]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'imcQS.Ss[2]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'imcQS.Ss[3]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'imcQS.Ss_total'(unit = "V.A", quantity = "Power") "Magnitude of total complex stator apparent power";
    Real 'imcQS.pfs[1]' "Stator power factor";
    Real 'imcQS.pfs[2]' "Stator power factor";
    Real 'imcQS.pfs[3]' "Stator power factor";
    Real 'imcQS.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'imcQS.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'imcQS.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'imcQS.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'imcQS.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'imcQS.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'imcQS.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'imcQS.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'imcQS.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'imcQS.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'imcQS.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'imcQS.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'imcQS.inertiaStator.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'imcQS.inertiaStator.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'imcQS.inertiaStator.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'imcQS.inertiaStator.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'imcQS.inertiaStator.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'imcQS.inertiaStator.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'imcQS.inertiaStator.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'imcQS.inertiaStator.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'imcQS.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'imcQS.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'imcQS.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Integer 'imcQS.plug_sp.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'imcQS.plug_sp.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.plug_sp.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.plug_sp.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.plug_sp.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.plug_sp.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.plug_sp.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.plug_sp.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.plug_sp.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.plug_sp.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.plug_sp.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.plug_sp.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.plug_sp.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.plug_sp.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'imcQS.plug_sn.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'imcQS.plug_sn.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.plug_sn.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.plug_sn.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.plug_sn.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.plug_sn.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.plug_sn.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.plug_sn.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.plug_sn.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.plug_sn.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.plug_sn.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.plug_sn.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.plug_sn.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.plug_sn.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'imcQS.stator.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'imcQS.stator.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.stator.plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.stator.plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.stator.plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.stator.plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.stator.plug_p.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.stator.plug_p.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.stator.plug_p.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.stator.plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.stator.plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.stator.plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'imcQS.stator.plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'imcQS.stator.plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'imcQS.stator.plug_n.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'imcQS.stator.plug_n.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'imcQS.stator.plug_n.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'imcQS.stator.plug_n.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
