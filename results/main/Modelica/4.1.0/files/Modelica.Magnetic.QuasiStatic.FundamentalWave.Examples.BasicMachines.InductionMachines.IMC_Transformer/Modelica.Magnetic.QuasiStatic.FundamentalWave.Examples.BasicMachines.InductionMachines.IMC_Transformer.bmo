  initial equation
    'imc.is[1]' + 'imc.is[2]' + 'imc.is[3]' = 0.0;
    'imc.is[1]' = 0.0;
    'imc.is[2]' = 0.0;
    'imc.rotorCage.electroMagneticConverter.V_m.re' = 0.0;
    'imc.rotorCage.electroMagneticConverter.V_m.im' = 0.0;
    'transformer.i2[1]' = 0.0;
    'transformer.i2[2]' = 0.0;
  equation
    'imcQS.gammas' = 'imcQS.airGap.gammas';
    'imcQS.gammar' = 'imcQS.airGap.gammar';
    'imcQS.gamma' = 'imcQS.airGap.gamma';
    'imcQS.phiMechanical' = 'imcQS.flange.phi' - 'imcQS.internalSupport.phi';
    'imcQS.wMechanical' = der('imcQS.phiMechanical');
    'imcQS.tauElectrical' = 'imcQS.inertiaRotor.flange_a.tau';
    'imcQS.tauShaft' = -'imcQS.flange.tau';
    'imcQS.powerBalance.powerStator' = sum('imcQS.vs[(1:size('imcQS.vs', 1))['$i1077']].re' * 'imcQS.is[(1:size('imcQS.vs', 1))['$i1077']].re' - 'imcQS.vs[(1:size('imcQS.vs', 1))['$i1077']].im' * (-'imcQS.is[(1:size('imcQS.vs', 1))['$i1077']].im') for '$i1077' in 1:size('imcQS.vs', 1));
    'imcQS.powerBalance.powerMechanical' = 'imcQS.wMechanical' * 'imcQS.tauShaft';
    'imcQS.powerBalance.powerInertiaStator' = 0.29 * 'imcQS.inertiaStator.a' * 'imcQS.inertiaStator.w';
    'imcQS.powerBalance.powerInertiaRotor' = 0.29 * 'imcQS.inertiaRotor.a' * 'imcQS.inertiaRotor.w';
    'imcQS.powerBalance.lossPowerTotal' = 'imcQS.powerBalance.lossPowerStatorWinding' + 'imcQS.powerBalance.lossPowerStatorCore' + 'imcQS.powerBalance.lossPowerRotorCore' + 'imcQS.powerBalance.lossPowerStrayLoad' + 'imcQS.powerBalance.lossPowerFriction' + 'imcQS.powerBalance.lossPowerRotorWinding';
    'imcQS.powerBalance.lossPowerStatorWinding' = 'imcQS.stator.resistor.resistor[1].LossPower' + 'imcQS.stator.resistor.resistor[2].LossPower' + 'imcQS.stator.resistor.resistor[3].LossPower';
    'imcQS.powerBalance.lossPowerStatorCore' = 'imcQS.stator.core.lossPower';
    'imcQS.powerBalance.lossPowerRotorCore' = 0.0;
    'imcQS.powerBalance.lossPowerStrayLoad' = 'imcQS.strayLoad.lossPower';
    'imcQS.powerBalance.lossPowerFriction' = 'imcQS.friction.lossPower';
    'imcQS.powerBalance.lossPowerRotorWinding' = 'imcQS.rotorCage.resistor.resistor[1].LossPower' + 'imcQS.rotorCage.resistor.resistor[2].LossPower' + 'imcQS.rotorCage.resistor.resistor[3].LossPower';
    'imcQS.is[1].re' = 'imcQS.plug_sp.pin[1].i.re';
    'imcQS.is[1].im' = 'imcQS.plug_sp.pin[1].i.im';
    'imcQS.is[2].re' = 'imcQS.plug_sp.pin[2].i.re';
    'imcQS.is[2].im' = 'imcQS.plug_sp.pin[2].i.im';
    'imcQS.is[3].re' = 'imcQS.plug_sp.pin[3].i.re';
    'imcQS.is[3].im' = 'imcQS.plug_sp.pin[3].i.im';
    'imcQS.Ps_total' = 'imcQS.Ps[1]' + 'imcQS.Ps[2]' + 'imcQS.Ps[3]';
    'imcQS.Qs_total' = 'imcQS.Qs[1]' + 'imcQS.Qs[2]' + 'imcQS.Qs[3]';
    'imcQS.Ss_total' = sqrt('imcQS.Ps_total' ^ 2.0 + 'imcQS.Qs_total' ^ 2.0);
    'imcQS.stator.i[1].re' = 'imcQS.stator.plug_p.pin[1].i.re';
    'imcQS.stator.i[1].im' = 'imcQS.stator.plug_p.pin[1].i.im';
    'imcQS.stator.i[2].re' = 'imcQS.stator.plug_p.pin[2].i.re';
    'imcQS.stator.i[2].im' = 'imcQS.stator.plug_p.pin[2].i.im';
    'imcQS.stator.i[3].re' = 'imcQS.stator.plug_p.pin[3].i.re';
    'imcQS.stator.i[3].im' = 'imcQS.stator.plug_p.pin[3].i.im';
    'imcQS.stator.P_total' = 'imcQS.stator.P[1]' + 'imcQS.stator.P[2]' + 'imcQS.stator.P[3]';
    'imcQS.stator.Q_total' = 'imcQS.stator.Q[1]' + 'imcQS.stator.Q[2]' + 'imcQS.stator.Q[3]';
    'imcQS.stator.S_total' = sqrt('imcQS.stator.P_total' ^ 2.0 + 'imcQS.stator.Q_total' ^ 2.0);
    'imcQS.stator.abs_V_m' = sqrt('imcQS.stator.V_m.re' ^ 2.0 + 'imcQS.stator.V_m.im' ^ 2.0);
    'imcQS.stator.arg_V_m' = 'Modelica.Math.atan3'('imcQS.stator.V_m.im', 'imcQS.stator.V_m.re', 0.0);
    'imcQS.stator.Phi.re' = 'imcQS.stator.port_p.Phi.re';
    'imcQS.stator.Phi.im' = 'imcQS.stator.port_p.Phi.im';
    'imcQS.stator.abs_Phi' = sqrt('imcQS.stator.Phi.re' ^ 2.0 + 'imcQS.stator.Phi.im' ^ 2.0);
    'imcQS.stator.arg_Phi' = 'Modelica.Math.atan3'('imcQS.stator.Phi.im', 'imcQS.stator.Phi.re', 0.0);
    'imcQS.stator.electroMagneticConverter.P_total' = 'imcQS.stator.electroMagneticConverter.P[1]' + 'imcQS.stator.electroMagneticConverter.P[2]' + 'imcQS.stator.electroMagneticConverter.P[3]';
    'imcQS.stator.electroMagneticConverter.Q_total' = 'imcQS.stator.electroMagneticConverter.Q[1]' + 'imcQS.stator.electroMagneticConverter.Q[2]' + 'imcQS.stator.electroMagneticConverter.Q[3]';
    'imcQS.stator.electroMagneticConverter.S_total' = sqrt('imcQS.stator.electroMagneticConverter.P_total' ^ 2.0 + 'imcQS.stator.electroMagneticConverter.Q_total' ^ 2.0);
    'imcQS.stator.electroMagneticConverter.abs_V_m' = sqrt('imcQS.stator.electroMagneticConverter.V_m.re' ^ 2.0 + 'imcQS.stator.electroMagneticConverter.V_m.im' ^ 2.0);
    'imcQS.stator.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('imcQS.stator.electroMagneticConverter.V_m.im', 'imcQS.stator.electroMagneticConverter.V_m.re', 0.0);
    'imcQS.stator.electroMagneticConverter.abs_Phi' = sqrt('imcQS.stator.electroMagneticConverter.Phi.re' ^ 2.0 + 'imcQS.stator.electroMagneticConverter.Phi.im' ^ 2.0);
    'imcQS.stator.electroMagneticConverter.arg_Phi' = 'Modelica.Math.atan3'('imcQS.stator.electroMagneticConverter.Phi.im', 'imcQS.stator.electroMagneticConverter.Phi.re', 0.0);
    'imcQS.stator.electroMagneticConverter.omega' = der('imcQS.stator.electroMagneticConverter.port_p.reference.gamma');
    'imcQS.stator.resistor.P_total' = 'imcQS.stator.resistor.P[1]' + 'imcQS.stator.resistor.P[2]' + 'imcQS.stator.resistor.P[3]';
