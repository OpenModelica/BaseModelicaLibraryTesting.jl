    'signalCurrent2.v' = 'signalCurrent2.p.v' - 'signalCurrent2.n.v';
    0.0 = 'signalCurrent2.p.i' + 'signalCurrent2.n.i';
    'signalCurrent2.i' = 'signalCurrent2.p.i';
    'powerSensor2.voltageSensor.p.i' = 0.0;
    'powerSensor2.voltageSensor.n.i' = 0.0;
    'powerSensor2.voltageSensor.v' = 'powerSensor2.voltageSensor.p.v' - 'powerSensor2.voltageSensor.n.v';
    'powerSensor2.currentSensor.p.v' = 'powerSensor2.currentSensor.n.v';
    'powerSensor2.currentSensor.p.i' = 'powerSensor2.currentSensor.i';
    'powerSensor2.currentSensor.n.i' = -'powerSensor2.currentSensor.i';
    'powerSensor2.product.y' = 'powerSensor2.product.u1' * 'powerSensor2.product.u2';
    'energy2.local_reset' = false;
    'energy2.local_set' = 0.0;
    der('energy2.y') = 'energy2.u';
    'gain.y' = 75.0 * 'gain.u';
    annotation(experiment(StopTime = 3600, Interval = 0.1, Tolerance = 1e-06));
  end 'BatteryDischargeCharge';
end 'BatteryDischargeCharge';
