//! base 0.1.0
package 'BatteryDischargeCharge'
  function 'Modelica.Blocks.Tables.Internal.getDer2Table1DValue' "Second derivative of interpolated 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    input Real 'der_u';
    input Real 'der2_u';
    output Real 'der2_y';
  external "C" 'der2_y' = ModelicaStandardTables_CombiTable1D_getDer2Value('tableID', 'icol', 'u', 'der_u', 'der2_u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getDer2Table1DValue';

  function 'Modelica.Blocks.Tables.Internal.getDerTable1DValue' "Derivative of interpolated 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    input Real 'der_u';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTable1D_getDerValue('tableID', 'icol', 'u', 'der_u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 2) = 'Modelica.Blocks.Tables.Internal.getDer2Table1DValue');
  end 'Modelica.Blocks.Tables.Internal.getDerTable1DValue';

  function 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer' "Derivative of interpolated 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    input Real 'der_u';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTable1D_getDerValue('tableID', 'icol', 'u', 'der_u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer';

  function 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmax' "Return maximum abscissa value of 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    output Real 'uMax';
  external "C" 'uMax' = ModelicaStandardTables_CombiTable1D_maximumAbscissa('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmax';

  function 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmin' "Return minimum abscissa value of 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    output Real 'uMin';
  external "C" 'uMin' = ModelicaStandardTables_CombiTable1D_minimumAbscissa('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmin';

  function 'Modelica.Blocks.Tables.Internal.getTable1DValue' "Interpolate 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTable1D_getValue('tableID', 'icol', 'u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1) = 'Modelica.Blocks.Tables.Internal.getDerTable1DValue');
  end 'Modelica.Blocks.Tables.Internal.getTable1DValue';

  function 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer' "Interpolate 1-dim. table defined by matrix (but do not provide a derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTable1D_getValue('tableID', 'icol', 'u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer';

  function 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2' "Interpolate 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTable1D_getValue('tableID', 'icol', 'u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1) = 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer');
  end 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2';

  function 'Modelica.Math.BooleanVectors.oneTrue' "Returns true, if exactly one element of the Boolean input vector is true (\"xor\")"
    input Boolean[:] 'b';
    output Boolean 'result';
  algorithm
    'result' := sum(if 'b'['i'] then 1 else 0 for 'i' in 1:size('b', 1)) == 1;
  end 'Modelica.Math.BooleanVectors.oneTrue';

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  class 'Modelica.Blocks.Types.ExternalCombiTable1D'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table defined by matrix"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" 'externalCombiTable1D' = ModelicaStandardTables_CombiTable1D_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table defined by matrix"
      input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" ModelicaStandardTables_CombiTable1D_close('externalCombiTable1D') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTable1D';

  model 'BatteryDischargeCharge' "Discharge and charge idealized battery"
    parameter Real 'pulseSeries.amplitude1' = 1.0 "Amplitude of 1st pulse series";
    parameter Integer 'pulseSeries.n1'(min = 0) = 7 "Number of pulses of 1st series";
    parameter Real 'pulseSeries.T1'(unit = "s", quantity = "Time") = 60.0 "Length of pulses of 1st series";
    parameter Real 'pulseSeries.Tp1'(unit = "s", quantity = "Time") = 60.0 "Pause between pulses of 1st series";
    parameter Real 'pulseSeries.amplitude2' = -1.0 "Amplitude of 2nd pulse series";
    parameter Integer 'pulseSeries.n2'(min = 0) = 7 "Number of pulses of 2nd series";
    parameter Real 'pulseSeries.T2'(unit = "s", quantity = "Time") = 60.0 "Length of pulses of 2nd series";
    parameter Real 'pulseSeries.Tp2'(unit = "s", quantity = "Time") = 60.0 "Pause between pulses of 2nd series";
    parameter Real 'pulseSeries.Tp'(unit = "s", quantity = "Time") = 60.0 "Pause (in addition to TP1) between the two series";
    Real 'pulseSeries.y' "Connector of Real output signal";
    parameter Real 'pulseSeries.offset' = 0.0 "Offset of output signal y";
    parameter Real 'pulseSeries.startTime'(unit = "s", quantity = "Time") = 60.0 "Output y = offset for time < startTime";
    parameter Real 'pulseSeries.Tstart1[1]'(unit = "s", quantity = "Time") = 60.0;
    parameter Real 'pulseSeries.Tstart1[2]'(unit = "s", quantity = "Time") = 180.0;
    parameter Real 'pulseSeries.Tstart1[3]'(unit = "s", quantity = "Time") = 300.0;
    parameter Real 'pulseSeries.Tstart1[4]'(unit = "s", quantity = "Time") = 420.0;
    parameter Real 'pulseSeries.Tstart1[5]'(unit = "s", quantity = "Time") = 540.0;
    parameter Real 'pulseSeries.Tstart1[6]'(unit = "s", quantity = "Time") = 660.0;
    parameter Real 'pulseSeries.Tstart1[7]'(unit = "s", quantity = "Time") = 780.0;
    parameter Real 'pulseSeries.Tstart2[1]'(unit = "s", quantity = "Time") = 960.0;
    parameter Real 'pulseSeries.Tstart2[2]'(unit = "s", quantity = "Time") = 1080.0;
    parameter Real 'pulseSeries.Tstart2[3]'(unit = "s", quantity = "Time") = 1200.0;
    parameter Real 'pulseSeries.Tstart2[4]'(unit = "s", quantity = "Time") = 1320.0;
    parameter Real 'pulseSeries.Tstart2[5]'(unit = "s", quantity = "Time") = 1440.0;
    parameter Real 'pulseSeries.Tstart2[6]'(unit = "s", quantity = "Time") = 1560.0;
    parameter Real 'pulseSeries.Tstart2[7]'(unit = "s", quantity = "Time") = 1680.0;
    Boolean 'pulseSeries.on1';
    Boolean 'pulseSeries.on2';
    parameter Real 'Isc'(unit = "A", quantity = "ElectricCurrent") = 1200.0 "Short-circuit current of cell at OCVmax";
    constant String 'cellData1.CellType' = "Cell Data" "Indicates cell type";
    parameter Real 'cellData1.Qnom'(displayUnit = "A.h", unit = "C", quantity = "ElectricCharge") = 18000.0 "Nominal (maximum) charge";
    parameter Boolean 'cellData1.useLinearSOCDependency' = true "Use a linear SOC dependent OCV, otherwise table based";
    parameter Real 'cellData1.OCVmax'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 4.2 "OCV at SOC = SOCmax";
    parameter Real 'cellData1.OCVmin'(start = 0.0, min = 0.0, unit = "V", quantity = "ElectricPotential") = 2.5 "OCV at SOC = SOCmin";
    parameter Real 'cellData1.SOCmax'(max = 1.0) = 1.0 "Maximum state of charge";
    parameter Real 'cellData1.SOCmin'(min = 0.0) = 0.0 "Minimum state of charge";
    parameter Real 'cellData1.OCV_SOC[1,1]' = 0.0 "OCV/OCVmax versus SOC table";
    parameter Real 'cellData1.OCV_SOC[1,2]' = 0.5952380952380952 "OCV/OCVmax versus SOC table";
    parameter Real 'cellData1.OCV_SOC[2,1]' = 1.0 "OCV/OCVmax versus SOC table";
    parameter Real 'cellData1.OCV_SOC[2,2]' = 1.0 "OCV/OCVmax versus SOC table";
    parameter 'Modelica.Blocks.Types.Smoothness' 'cellData1.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' "Smoothness of table interpolation";
    parameter Real 'cellData1.OCV_SOC_internal[1,1]' = 0.0 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData1.OCV_SOC_internal[1,2]' = 0.5952380952380952 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData1.OCV_SOC_internal[2,1]' = 1.0 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData1.OCV_SOC_internal[2,2]' = 1.0 "OCV/OCVmax versus SOC used internal";
    parameter Real 'cellData1.Ri'(unit = "Ohm", quantity = "Resistance") = 0.0035 "Total inner resistance (= OCVmax/Isc)";
    parameter Real 'cellData1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'cellData1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance at T_ref";
    parameter Real 'cellData1.Idis'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Self-discharge current at SOC = SOCmax" annotation(Evaluate = true);
    parameter Real 'cellData1.R0'(unit = "Ohm", quantity = "Resistance") = 0.0035 "Inner resistance without parallel C";
    Real 'battery1.displaySOC' "SOC for display";
    parameter Integer 'battery1.Ns'(min = 1) = 10 "Number of serial connected cells";
    parameter Integer 'battery1.Np'(min = 1) = 2 "Number of parallel connected cells";
    constant String 'battery1.cellData.CellType' = "Cell Data" "Indicates cell type";
    parameter Real 'battery1.cellData.Qnom'(displayUnit = "A.h", unit = "C", quantity = "ElectricCharge") = 18000.0 "Nominal (maximum) charge";
    parameter Boolean 'battery1.cellData.useLinearSOCDependency' = true "Use a linear SOC dependent OCV, otherwise table based";
    parameter Real 'battery1.cellData.OCVmax'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 4.2 "OCV at SOC = SOCmax";
    parameter Real 'battery1.cellData.OCVmin'(start = 0.0, min = 0.0, unit = "V", quantity = "ElectricPotential") = 2.5 "OCV at SOC = SOCmin";
    parameter Real 'battery1.cellData.SOCmax'(max = 1.0) = 1.0 "Maximum state of charge";
    parameter Real 'battery1.cellData.SOCmin'(min = 0.0) = 0.0 "Minimum state of charge";
    parameter Real 'battery1.cellData.OCV_SOC[1,1]' = 0.0 "OCV/OCVmax versus SOC table";
    parameter Real 'battery1.cellData.OCV_SOC[1,2]' = 0.5952380952380952 "OCV/OCVmax versus SOC table";
    parameter Real 'battery1.cellData.OCV_SOC[2,1]' = 1.0 "OCV/OCVmax versus SOC table";
    parameter Real 'battery1.cellData.OCV_SOC[2,2]' = 1.0 "OCV/OCVmax versus SOC table";
    parameter 'Modelica.Blocks.Types.Smoothness' 'battery1.cellData.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' "Smoothness of table interpolation";
    parameter Real 'battery1.cellData.OCV_SOC_internal[1,1]' = 0.0 "OCV/OCVmax versus SOC used internal";
    parameter Real 'battery1.cellData.OCV_SOC_internal[1,2]' = 0.5952380952380952 "OCV/OCVmax versus SOC used internal";
    parameter Real 'battery1.cellData.OCV_SOC_internal[2,1]' = 1.0 "OCV/OCVmax versus SOC used internal";
    parameter Real 'battery1.cellData.OCV_SOC_internal[2,2]' = 1.0 "OCV/OCVmax versus SOC used internal";
    parameter Real 'battery1.cellData.Ri'(unit = "Ohm", quantity = "Resistance") = 0.0035 "Total inner resistance (= OCVmax/Isc)";
    parameter Real 'battery1.cellData.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'battery1.cellData.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance at T_ref";
    parameter Real 'battery1.cellData.Idis'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Self-discharge current at SOC = SOCmax" annotation(Evaluate = true);
    parameter Real 'battery1.cellData.R0'(unit = "Ohm", quantity = "Resistance") = 0.0035 "Inner resistance without parallel C";
    parameter Real 'battery1.SOCtolerance' = 1e-9 "Tolerance to detect depleted of overcharged battery";
    Real 'battery1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'battery1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery1.i'(unit = "A", quantity = "ElectricCurrent") "Current into the battery";
    Real 'battery1.power'(unit = "W", quantity = "Power") "Power to the battery";
    Real 'battery1.SOC'(fixed = true, start = 0.95) "State of charge";
    Real 'battery1.currentSensor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery1.currentSensor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery1.currentSensor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery1.currentSensor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery1.currentSensor.i'(unit = "A") "Current in the branch from p to n as output signal";
    parameter Real 'battery1.limIntegrator.k' = 2.777777777777778e-5 "Integrator gain";
    parameter Real 'battery1.limIntegrator.outMax'(start = 1.0) = 0.999999999 "Upper limit of output";
    parameter Real 'battery1.limIntegrator.outMin' = 1e-9 "Lower limit of output";
    parameter Boolean 'battery1.limIntegrator.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'battery1.limIntegrator.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'battery1.limIntegrator.initType' = 'Modelica.Blocks.Types.Init'.'NoInit' "Type of initialization (1: no init, 2: steady state, 3/4: initial output)" annotation(Evaluate = true);
    parameter Boolean 'battery1.limIntegrator.limitsAtInit' = true "= false, if limits are ignored during initialization (i.e., der(y)=k*u)" annotation(Evaluate = true);
    parameter Real 'battery1.limIntegrator.y_start' = 0.0 "Initial or guess value of output (must be in the limits outMin .. outMax)";
    parameter Boolean 'battery1.limIntegrator.strict' = false "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    Real 'battery1.limIntegrator.u' "Connector of Real input signal";
    Real 'battery1.limIntegrator.y' "Connector of Real output signal";
    Boolean 'battery1.limIntegrator.local_reset';
    Real 'battery1.limIntegrator.local_set';
    parameter Integer 'battery1.ocv_soc.nout' = 1 "Number of outputs";
    Real 'battery1.ocv_soc.u' "Connector of Real input signal";
    Real 'battery1.ocv_soc.y[1]' "Connector of Real output signals";
    parameter Boolean 'battery1.ocv_soc.tableOnFile' = false "= true, if table is defined on file or in function usertab";
    parameter Real 'battery1.ocv_soc.table[1,1]' = 0.0 "Table matrix (grid = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'battery1.ocv_soc.table[1,2]' = 0.5952380952380952 "Table matrix (grid = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'battery1.ocv_soc.table[2,1]' = 1.0 "Table matrix (grid = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'battery1.ocv_soc.table[2,2]' = 1.0 "Table matrix (grid = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter String 'battery1.ocv_soc.tableName' = "NoName" "Table name on file or in function usertab (see docu)";
    parameter String 'battery1.ocv_soc.fileName' = "NoName" "File where matrix is stored";
    parameter String 'battery1.ocv_soc.delimiter' = "," "Column delimiter character for CSV file";
    parameter Integer 'battery1.ocv_soc.nHeaderLines' = 0 "Number of header lines to ignore for CSV file";
    parameter Boolean 'battery1.ocv_soc.verboseRead' = true "= true, if info message that file is loading is to be printed";
    parameter Integer 'battery1.ocv_soc.columns[1]' = 2 "Columns of table to be interpolated";
    parameter 'Modelica.Blocks.Types.Smoothness' 'battery1.ocv_soc.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' "Smoothness of table interpolation";
    parameter 'Modelica.Blocks.Types.Extrapolation' 'battery1.ocv_soc.extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'HoldLastPoint' "Extrapolation of data outside the definition range";
    parameter Boolean 'battery1.ocv_soc.verboseExtrapolation' = false "= true, if warning messages are to be printed if table input is outside the definition range";
    parameter Real 'battery1.ocv_soc.u_min' = 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmin'('battery1.ocv_soc.tableID') "Minimum abscissa value defined in table";
    parameter Real 'battery1.ocv_soc.u_max' = 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmax'('battery1.ocv_soc.tableID') "Maximum abscissa value defined in table";
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'battery1.ocv_soc.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 0.5952380952380952}, {1.0, 1.0}}, {2}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'HoldLastPoint', false, ",", 0) "External table object";
    parameter Boolean 'battery1.ocv_soc.isCsvExt' = false;
    parameter Real 'battery1.gainV.k'(start = 1.0) = 42.0 "Gain value multiplied with input signal";
    Real 'battery1.gainV.u' "Input signal connector";
    Real 'battery1.gainV.y' "Output signal connector";
    Real 'battery1.ocv.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery1.ocv.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery1.ocv.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery1.ocv.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery1.ocv.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'battery1.ocv.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'battery1.selfDischarge.G'(start = 1.0, unit = "S", quantity = "Conductance") = 0.0 "Conductance at temperature T_ref";
    parameter Real 'battery1.selfDischarge.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'battery1.selfDischarge.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of conductance (G_actual = G_ref/(1 + alpha*(T_heatPort - T_ref))";
    Real 'battery1.selfDischarge.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'battery1.selfDischarge.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery1.selfDischarge.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery1.selfDischarge.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'battery1.selfDischarge.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'battery1.selfDischarge.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'battery1.selfDischarge.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'battery1.selfDischarge.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'battery1.selfDischarge.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'battery1.selfDischarge.heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'battery1.selfDischarge.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'battery1.selfDischarge.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'battery1.selfDischarge.G_actual'(unit = "S", quantity = "Conductance") "Actual conductance = G_ref/(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'battery1.r0.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.0175 "Resistance at temperature T_ref";
    parameter Real 'battery1.r0.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'battery1.r0.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
