    Real 'filter.u' "Connector of Real input signal";
    Real 'filter.y' "Connector of Real output signal";
    parameter 'Modelica.Blocks.Types.AnalogFilter' 'filter.analogFilter' = 'Modelica.Blocks.Types.AnalogFilter'.'CriticalDamping' "Analog filter characteristics (CriticalDamping/Bessel/Butterworth/ChebyshevI)";
    parameter 'Modelica.Blocks.Types.FilterType' 'filter.filterType' = 'Modelica.Blocks.Types.FilterType'.'LowPass' "Type of filter (LowPass/HighPass/BandPass/BandStop)";
    parameter Integer 'filter.order'(min = 1) = 2 "Order of filter";
    parameter Real 'filter.f_cut'(unit = "Hz", quantity = "Frequency") = 20.0 "Cut-off frequency";
    parameter Real 'filter.gain' = 0.4082482904638631 "Gain (= amplitude of frequency response at zero frequency)";
    parameter Real 'filter.A_ripple'(unit = "dB") = 0.5 "Pass band ripple for Chebyshev filter (otherwise not used); > 0 required";
    parameter Real 'filter.f_min'(unit = "Hz", quantity = "Frequency") = 0.0 "Band of band pass/stop filter is f_min (A=-3db*gain) .. f_cut (A=-3db*gain)";
    parameter Boolean 'filter.normalized' = true "= true, if amplitude at f_cut = -3db, otherwise unmodified filter";
    parameter 'Modelica.Blocks.Types.Init' 'filter.init' = 'Modelica.Blocks.Types.Init'.'SteadyState' "Type of initialization (no init/steady state/initial state/initial output)" annotation(Evaluate = true);
    parameter Integer 'filter.nx' = 2;
