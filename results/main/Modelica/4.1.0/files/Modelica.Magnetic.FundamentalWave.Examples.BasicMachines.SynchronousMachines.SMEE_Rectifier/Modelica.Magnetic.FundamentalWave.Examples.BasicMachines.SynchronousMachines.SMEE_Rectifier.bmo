//! base 0.1.0
package 'SMEE_Rectifier'
  function 'Modelica.Blocks.Continuous.Internal.Filter.roots.lowPass' "Return low pass filter roots as needed for block for given cut-off frequency"
    input Real[:] 'cr_in';
    input Real[:] 'c0_in';
    input Real[size('c0_in', 1)] 'c1_in';
    input Real 'f_cut'(unit = "Hz", quantity = "Frequency");
    output Real[size('cr_in', 1)] 'r';
    output Real[size('c0_in', 1)] 'a';
    output Real[size('c0_in', 1)] 'b';
    output Real[size('c0_in', 1)] 'ku';
    Real[size('c0_in', 1)] 'c0';
    Real[size('c0_in', 1)] 'c1';
    Real[size('cr_in', 1)] 'cr';
  algorithm
    ('cr', 'c0', 'c1') := 'Modelica.Blocks.Continuous.Internal.Filter.coefficients.lowPass'('cr_in', 'c0_in', 'c1_in', 'f_cut');

    for 'i' in 1:size('cr_in', 1) loop
      'r'['i'] := -'cr'['i'];
    end for;

    for 'i' in 1:size('c0_in', 1) loop
      'a'['i'] := -'c1'['i'] / 2.0;
      'b'['i'] := sqrt('c0'['i'] - 'a'['i'] * 'a'['i']);
      'ku'['i'] := 'c0'['i'] / 'b'['i'];
    end for;
  end 'Modelica.Blocks.Continuous.Internal.Filter.roots.lowPass';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  type 'Modelica.Blocks.Types.SimpleController' = enumeration('P', 'PI', 'PD', 'PID');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  type 'Modelica.Blocks.Types.AnalogFilter' = enumeration('CriticalDamping', 'Bessel', 'Butterworth', 'ChebyshevI');

  type 'Modelica.Blocks.Types.FilterType' = enumeration('LowPass', 'HighPass', 'BandPass', 'BandStop');

  model 'SMEE_Rectifier' "Test example: ElectricalExcitedSynchronousMachine with rectifier"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'wNominal'(unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Nominal speed";
    parameter Real 'VDC0'(unit = "V", quantity = "ElectricPotential") = 244.9489742783178 "No-load DC voltage";
    parameter Real 'RLoad'(unit = "Ohm", quantity = "Resistance") = 1.9999999999999998 "Load resistance";
    parameter Real 'Ve0'(unit = "V", quantity = "ElectricPotential") = 24.99999995307565 "No load excitation voltage";
    parameter Real 'k' = 0.49999999906151305 "Voltage controller: gain";
    parameter Real 'Ti'(unit = "s", quantity = "Time") = 0.1305886715 "Voltage controller: integral time constant";
    constant Real 'smee.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    parameter Integer 'smee.m'(min = 3) = 3 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'smee.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor inertia";
    parameter Boolean 'smee.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'smee.Js'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator inertia";
    parameter Boolean 'smee.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Integer 'smee.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'smee.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'smee.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
    parameter Real 'smee.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.030000000995873476 "Stator resistance per phase at TRef";
    parameter Real 'smee.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'smee.alpha20s'(start = 0.0, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'smee.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'smee.Lssigma'(start = 3.183098861837907e-4, unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance";
    parameter Real 'smee.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'smee.Lszero'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator zero inductance";
    parameter Real 'smee.L0.d'(start = 1.0, unit = "H", quantity = "Inductance") = 0.0031830988618379067 "Component of d (direct) axis, aligned to real part";
    parameter Real 'smee.L0.q'(start = 1.0, unit = "H", quantity = "Inductance") = 0.0031830988618379067 "Component of q (quadrature) axis, aligned to imaginary part";
    parameter Real 'smee.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smee.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smee.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smee.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smee.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smee.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smee.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'smee.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'smee.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'smee.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'smee.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'smee.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'smee.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'smee.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 1.5707963267948965e-4 "Angular velocity limit";
    parameter Real 'smee.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'smee.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'smee.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smee.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'smee.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    Real 'smee.phiMechanical'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Mechanical angle of rotor against stator";
    Real 'smee.wMechanical'(start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") "Mechanical angular velocity of rotor against stator";
    Real 'smee.tauElectrical'(unit = "N.m", quantity = "Torque") "Electromagnetic torque";
    Real 'smee.tauShaft'(unit = "N.m", quantity = "Torque") "Shaft torque";
    Real 'smee.powerBalance.powerStator'(unit = "W", quantity = "Power") "Electrical power (stator)";
    Real 'smee.powerBalance.powerMechanical'(unit = "W", quantity = "Power") "Mechanical power";
    Real 'smee.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") "Stator inertia power";
    Real 'smee.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") "Rotor inertia power";
    Real 'smee.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") "Total loss power";
    Real 'smee.powerBalance.lossPowerStatorWinding'(unit = "W", quantity = "Power") "Stator copper losses";
    Real 'smee.powerBalance.lossPowerStatorCore'(unit = "W", quantity = "Power") "Stator core losses";
    Real 'smee.powerBalance.lossPowerRotorCore'(unit = "W", quantity = "Power") "Rotor core losses";
    Real 'smee.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") "Stray load losses";
    Real 'smee.powerBalance.lossPowerFriction'(unit = "W", quantity = "Power") "Friction losses";
    Real 'smee.powerBalance.lossPowerRotorWinding'(unit = "W", quantity = "Power") "Rotor copper losses";
    Real 'smee.powerBalance.powerExcitation'(unit = "W", quantity = "Power") "Electrical excitation power";
    Real 'smee.powerBalance.lossPowerExcitation'(unit = "W", quantity = "Power") "Excitation losses";
    Real 'smee.powerBalance.lossPowerBrush'(unit = "W", quantity = "Power") "Brush losses";
    Real 'smee.vs[1]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'smee.vs[2]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'smee.vs[3]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'smee.is[1]'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'smee.is[2]'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'smee.is[3]'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'smee.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smee.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smee.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smee.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smee.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smee.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'smee.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'smee.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'smee.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'smee.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'smee.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'smee.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smee.inertiaStator.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smee.inertiaStator.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smee.inertiaStator.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'smee.inertiaStator.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'smee.inertiaStator.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'smee.inertiaStator.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'smee.inertiaStator.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'smee.inertiaStator.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'smee.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'smee.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smee.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Integer 'smee.plug_sp.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smee.plug_sp.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.plug_sp.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.plug_sp.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.plug_sp.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.plug_sp.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.plug_sp.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smee.plug_sn.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smee.plug_sn.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.plug_sn.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.plug_sn.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.plug_sn.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.plug_sn.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.plug_sn.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smee.stator.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smee.stator.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.stator.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.stator.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.stator.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.stator.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.stator.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smee.stator.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smee.stator.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.stator.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.stator.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.stator.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.stator.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.stator.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smee.stator.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smee.stator.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smee.stator.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smee.stator.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'smee.stator.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smee.stator.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smee.stator.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smee.stator.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    parameter Integer 'smee.stator.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Boolean 'smee.stator.useHeatPort' = true "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Real 'smee.stator.RRef'(unit = "Ohm", quantity = "Resistance") = 0.030000000995873476 "Winding resistance per phase at TRef";
    parameter Real 'smee.stator.TRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of winding";
    parameter Real 'smee.stator.alpha20'(start = 0.0, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of winding at 20 degC";
    parameter Real 'smee.stator.alphaRef'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of winding at reference temperature";
    parameter Real 'smee.stator.TOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of winding";
    parameter Real 'smee.stator.Lsigma'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Winding stray inductance per phase";
    parameter Real 'smee.stator.ratioCommonLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance";
    parameter Real 'smee.stator.Lzero'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Zero sequence inductance of winding";
    parameter Real 'smee.stator.effectiveTurns' = 1.0 "Effective number of turns per phase";
    parameter Real 'smee.stator.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Electrical reference core loss reluctance";
    parameter Integer 'smee.stator.nBase' = 1 "Number of base systems";
    parameter Integer 'smee.stator.mBase' = 3 "Number of phase of the base systems";
    Real 'smee.stator.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smee.stator.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smee.stator.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smee.stator.i[1]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smee.stator.i[2]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smee.stator.i[3]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smee.stator.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smee.stator.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smee.stator.abs_V_m'(unit = "A", quantity = "MagneticPotential") "Magnitude of complex magnetic potential difference";
    Real 'smee.stator.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic potential difference";
    Real 'smee.stator.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smee.stator.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'smee.stator.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnitude of complex magnetic flux";
    Real 'smee.stator.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux";
    Real 'smee.stator.electroMagneticConverter.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smee.stator.electroMagneticConverter.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smee.stator.electroMagneticConverter.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smee.stator.electroMagneticConverter.i[1]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smee.stator.electroMagneticConverter.i[2]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smee.stator.electroMagneticConverter.i[3]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smee.stator.electroMagneticConverter.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smee.stator.electroMagneticConverter.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smee.stator.electroMagneticConverter.abs_V_m'(unit = "A", quantity = "MagneticPotential") "Magnitude of complex magnetic potential difference";
    Real 'smee.stator.electroMagneticConverter.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic potential difference";
    Real 'smee.stator.electroMagneticConverter.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smee.stator.electroMagneticConverter.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'smee.stator.electroMagneticConverter.abs_Phi'(unit = "A", quantity = "MagneticPotential") "Magnitude of complex magnetic flux";
    Real 'smee.stator.electroMagneticConverter.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux";
    parameter Integer 'smee.stator.electroMagneticConverter.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smee.stator.electroMagneticConverter.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
