    'smee.thermalAmbient.Q_flowStatorWinding' = 'smee.thermalAmbient.temperatureStatorWinding.port.Q_flow';
    'smee.thermalAmbient.Q_flowStatorCore' = 'smee.thermalAmbient.temperatureStatorCore.port.Q_flow';
    'smee.thermalAmbient.Q_flowRotorCore' = 'smee.thermalAmbient.temperatureRotorCore.port.Q_flow';
    'smee.thermalAmbient.Q_flowStrayLoad' = 'smee.thermalAmbient.temperatureStrayLoad.port.Q_flow';
    'smee.thermalAmbient.Q_flowFriction' = 'smee.thermalAmbient.temperatureFriction.port.Q_flow';
    'smee.thermalAmbient.Q_flowRotorWinding' = 'smee.thermalAmbient.temperatureRotorWinding.port.Q_flow';
    'smee.thermalAmbient.Q_flowExcitation' = 'smee.thermalAmbient.temperatureExcitation.port.Q_flow';
    'smee.thermalAmbient.Q_flowTotal' = 'smee.thermalAmbient.Q_flowStatorWinding' + 'smee.thermalAmbient.Q_flowRotorWinding' + 'smee.thermalAmbient.Q_flowExcitation' + 'smee.thermalAmbient.Q_flowStatorCore' + 'smee.thermalAmbient.Q_flowRotorCore' + 'smee.thermalAmbient.Q_flowStrayLoad' + 'smee.thermalAmbient.Q_flowFriction';
    'smee.strayLoad.heatPort.Q_flow' = -'smee.strayLoad.lossPower';
    'smee.strayLoad.iRMS' = sqrt(sum('smee.strayLoad.i' .^ 2.0 / size('smee.strayLoad.i', 1)));
