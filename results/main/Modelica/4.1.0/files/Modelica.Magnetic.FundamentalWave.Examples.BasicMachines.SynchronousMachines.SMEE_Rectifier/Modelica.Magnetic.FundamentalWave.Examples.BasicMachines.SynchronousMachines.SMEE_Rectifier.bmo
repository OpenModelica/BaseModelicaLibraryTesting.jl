    'smee.rotorCage.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('smee.rotorCage.electroMagneticConverter.V_m.im', 'smee.rotorCage.electroMagneticConverter.V_m.re', 0.0);
