    'smee.stator.core.heatPort.T' = 'smee.stator.core.TheatPort';
    'smee.stator.core.heatPort.Q_flow' = -'smee.stator.core.lossPower';
    'smee.stator.stray.abs_V_m' = sqrt('smee.stator.stray.V_m.re' ^ 2.0 + 'smee.stator.stray.V_m.im' ^ 2.0);
    'smee.stator.stray.arg_V_m' = 'Modelica.Math.atan3'('smee.stator.stray.V_m.im', 'smee.stator.stray.V_m.re', 0.0);
    'smee.stator.stray.Phi.re' = 'smee.stator.stray.port_p.Phi.re';
    'smee.stator.stray.Phi.im' = 'smee.stator.stray.port_p.Phi.im';
    'smee.stator.stray.abs_Phi' = sqrt('smee.stator.stray.Phi.re' ^ 2.0 + 'smee.stator.stray.Phi.im' ^ 2.0);
