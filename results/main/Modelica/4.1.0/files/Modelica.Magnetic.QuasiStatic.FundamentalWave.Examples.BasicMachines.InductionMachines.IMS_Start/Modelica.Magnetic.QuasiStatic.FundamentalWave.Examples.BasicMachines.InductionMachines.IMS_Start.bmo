    Real 'groundMachine.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
  initial equation
    'ims.is[1]' + 'ims.is[2]' + 'ims.is[3]' = 0.0;
    'ims.is[1]' = 0.0;
    'ims.is[2]' = 0.0;
    'ims.ir[1]' + 'ims.ir[2]' + 'ims.ir[3]' = 0.0;
    'ims.ir[1]' = 0.0;
    'ims.ir[2]' = 0.0;
  equation
    'Itr' = 'currentQuasiRMSSensor.I';
    'Iqs' = 'currentQuasiRMSSensorQS.I';
    'ims.phiMechanical' = 'ims.flange.phi' - 'ims.internalSupport.phi';
    'ims.wMechanical' = der('ims.phiMechanical');
    'ims.tauElectrical' = 'ims.inertiaRotor.flange_a.tau';
    'ims.tauShaft' = -'ims.flange.tau';
    'ims.powerBalance.powerStator' = 'ims.vs[1]' * 'ims.is[1]' + 'ims.vs[2]' * 'ims.is[2]' + 'ims.vs[3]' * 'ims.is[3]';
    'ims.powerBalance.powerMechanical' = 'ims.wMechanical' * 'ims.tauShaft';
    'ims.powerBalance.powerInertiaStator' = 0.29 * 'ims.inertiaStator.a' * 'ims.inertiaStator.w';
    'ims.powerBalance.powerInertiaRotor' = 0.29 * 'ims.inertiaRotor.a' * 'ims.inertiaRotor.w';
    'ims.powerBalance.lossPowerTotal' = 'ims.powerBalance.lossPowerStatorWinding' + 'ims.powerBalance.lossPowerStatorCore' + 'ims.powerBalance.lossPowerRotorCore' + 'ims.powerBalance.lossPowerStrayLoad' + 'ims.powerBalance.lossPowerFriction' + 'ims.powerBalance.lossPowerRotorWinding' + 'ims.powerBalance.lossPowerBrush';
    'ims.powerBalance.lossPowerStatorWinding' = 'ims.stator.resistor.resistor[1].LossPower' + 'ims.stator.resistor.resistor[2].LossPower' + 'ims.stator.resistor.resistor[3].LossPower';
    'ims.powerBalance.lossPowerStatorCore' = 'ims.stator.core.lossPower';
    'ims.powerBalance.lossPowerRotorCore' = 'ims.rotor.core.lossPower';
    'ims.powerBalance.lossPowerStrayLoad' = 'ims.strayLoad.lossPower';
    'ims.powerBalance.lossPowerFriction' = 'ims.friction.lossPower';
    'ims.powerBalance.lossPowerRotorWinding' = 'ims.rotor.resistor.resistor[1].LossPower' + 'ims.rotor.resistor.resistor[2].LossPower' + 'ims.rotor.resistor.resistor[3].LossPower';
    'ims.powerBalance.lossPowerBrush' = 0.0;
