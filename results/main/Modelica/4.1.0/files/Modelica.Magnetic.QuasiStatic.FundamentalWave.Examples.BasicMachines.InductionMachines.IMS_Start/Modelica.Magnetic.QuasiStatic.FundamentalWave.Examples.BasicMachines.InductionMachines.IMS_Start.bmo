    parameter Real 'sineVoltage.sineVoltage[3].startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Integer 'idealCloser.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'idealCloser.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'idealCloser.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
