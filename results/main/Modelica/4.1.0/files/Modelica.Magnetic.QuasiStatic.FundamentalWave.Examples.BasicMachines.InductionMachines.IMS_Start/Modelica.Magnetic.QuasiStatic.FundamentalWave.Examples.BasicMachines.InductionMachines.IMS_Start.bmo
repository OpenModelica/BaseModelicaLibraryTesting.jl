    Real 'idealCloser.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'idealCloser.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'idealCloser.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'idealCloser.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'idealCloser.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'idealCloser.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'idealCloser.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'idealCloser.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'idealCloser.Ron[1]'(start = 1e-5, min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Closed switch resistance";
    parameter Real 'idealCloser.Ron[2]'(start = 1e-5, min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Closed switch resistance";
