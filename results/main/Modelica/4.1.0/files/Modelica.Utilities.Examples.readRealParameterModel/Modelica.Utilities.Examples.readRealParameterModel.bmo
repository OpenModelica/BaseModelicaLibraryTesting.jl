//! base 0.1.0
package 'readRealParameterModel'
  function 'Modelica.Utilities.Streams.close' "Close file"
    input String 'fileName';
  external "C" ModelicaStreams_closeFile('fileName') annotation(Library = "ModelicaExternalC", LibraryDirectory = "modelica://Modelica/Resources/Library", Include = "#include \"ModelicaInternal.h\"", IncludeDirectory = "modelica://Modelica/Resources/C-Sources");
  end 'Modelica.Utilities.Streams.close';

  model 'readRealParameterModel' "Demonstrate usage of Examples.readRealParameter/.expression"
    parameter String 'file' = "/home/runner/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Examples_readRealParameters.txt" "File on which data is present";
    parameter Real 'J'(unit = "kg.m2", quantity = "MomentOfInertia") = 2.3 "Inertia";
    parameter Real 'phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.0471975511965976 "Relative angle";
    parameter Real 'w_rel0'(unit = "rad/s", quantity = "AngularVelocity") = 3.0 "Relative angular velocity";
  equation
    when terminal() then
      'Modelica.Utilities.Streams.close'("/home/runner/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Data/Utilities/Examples_readRealParameters.txt");
    end when;
    annotation(experiment(StopTime = 1.01));
  end 'readRealParameterModel';
end 'readRealParameterModel';
