    Real 'signalVoltage.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalVoltage.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalVoltage.v[1]'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'signalVoltage.v[2]'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
