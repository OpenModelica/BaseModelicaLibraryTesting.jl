    Real 'ramp.y' "Connector of Real output signal";
    parameter Real 'ramp.offset' = 0.0 "Offset of output signal y";
    parameter Real 'ramp.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Integer 'vfController.nout' = 3 "Number of outputs";
    Real 'vfController.u'(unit = "Hz") "Connector of Real input signal";
    Real 'vfController.y[1]' "Connector of Real output signals";
    Real 'vfController.y[2]' "Connector of Real output signals";
    Real 'vfController.y[3]' "Connector of Real output signals";
