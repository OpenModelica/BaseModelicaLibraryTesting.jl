    parameter Real 'vfController.fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'vfController.BasePhase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Common phase shift";
    parameter Boolean 'vfController.EconomyMode' = false "Economy mode: voltage quadratic dependent on frequency" annotation(Evaluate = true);
    Real 'vfController.x'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Integrator state";
    Real 'vfController.amplitude'(unit = "V", quantity = "ElectricPotential");
    parameter Integer 'vfController.pow' = 1 annotation(Evaluate = true);
    parameter Integer 'currentRMSsensorM.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'currentRMSsensorM.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'currentRMSsensorM.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'currentRMSsensorM.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'currentRMSsensorM.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'currentRMSsensorM.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'currentRMSsensorM.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    parameter Integer 'currentRMSsensorM.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'currentRMSsensorM.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentRMSsensorM.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
