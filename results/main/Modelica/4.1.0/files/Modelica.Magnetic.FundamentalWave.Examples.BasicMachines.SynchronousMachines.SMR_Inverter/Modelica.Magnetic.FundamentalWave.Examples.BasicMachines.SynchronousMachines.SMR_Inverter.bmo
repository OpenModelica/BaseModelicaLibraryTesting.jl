    Real 'currentRMSsensorM.currentSensor.currentSensor[3].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentRMSsensorM.currentSensor.currentSensor[3].i'(unit = "A") "Current in the branch from p to n as output signal";
    Real 'currentRMSsensorM.quasiRMS.y' "Connector of Real output signal";
    parameter Integer 'currentRMSsensorM.quasiRMS.m'(min = 2) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'currentRMSsensorM.quasiRMS.u[1]';
    Real 'currentRMSsensorM.quasiRMS.u[2]';
    Real 'currentRMSsensorM.quasiRMS.u[3]';
    constant Integer 'currentRMSsensorE.m'(min = 1) = 3 "Number of phases";
    Real 'currentRMSsensorE.I'(unit = "A", quantity = "ElectricCurrent");
    parameter Integer 'currentRMSsensorE.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'currentRMSsensorE.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
