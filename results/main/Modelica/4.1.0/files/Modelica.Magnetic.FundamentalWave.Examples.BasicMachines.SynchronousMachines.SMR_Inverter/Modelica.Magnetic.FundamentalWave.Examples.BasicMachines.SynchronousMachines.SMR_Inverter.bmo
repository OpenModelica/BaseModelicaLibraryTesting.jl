  model 'SMR_Inverter' "Starting of synchronous reluctance machine with inverter"
    constant Integer 'm' = 3 "Number of stator phases";
    parameter Real 'VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'fKnee'(unit = "Hz", quantity = "Frequency") = 50.0 "Knee frequency of V/f curve";
    parameter Real 'tRamp'(unit = "s", quantity = "Time") = 1.0 "Frequency ramp";
    parameter Real 'T_Load'(unit = "N.m", quantity = "Torque") = 46.0 "Nominal load torque";
    parameter Real 'tStep'(unit = "s", quantity = "Time") = 1.2 "Time of load torque step";
    parameter Real 'J_Load'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load inertia";
    Real 'thetaM'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotor displacement angle, FundamentalWave machine";
    Real 'thetaE'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotor displacement angle, Electrical machine";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'star.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'star.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'star.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'signalVoltage.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'signalVoltage.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive plugs";
    Real 'signalVoltage.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive plugs";
    Real 'signalVoltage.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive plugs";
    parameter Integer 'signalVoltage.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'signalVoltage.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalVoltage.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalVoltage.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalVoltage.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalVoltage.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalVoltage.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'signalVoltage.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'signalVoltage.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalVoltage.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'signalVoltage.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
