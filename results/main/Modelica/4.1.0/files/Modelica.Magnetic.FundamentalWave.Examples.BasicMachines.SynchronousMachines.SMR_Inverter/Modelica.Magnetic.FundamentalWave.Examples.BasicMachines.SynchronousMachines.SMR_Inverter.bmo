    'torqueStepE.tau' = if time < 1.2 then 0.0 else -46.0;
    'torqueStepE.phi' = 'torqueStepE.flange.phi' - 'torqueStepE.phi_support';
    'torqueStepE.phi_support' = 0.0;
  initial algorithm
    assert(true, "3 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
    annotation(experiment(StopTime = 1.5, Interval = 1E-4, Tolerance = 1e-06));
  end 'SMR_Inverter';
end 'SMR_Inverter';
