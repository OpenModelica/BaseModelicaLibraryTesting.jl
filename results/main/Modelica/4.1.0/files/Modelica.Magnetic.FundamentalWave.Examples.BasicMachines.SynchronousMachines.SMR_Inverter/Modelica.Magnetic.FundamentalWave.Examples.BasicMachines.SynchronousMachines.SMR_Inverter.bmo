    Real 'signalVoltage.signalVoltage[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'signalVoltage.signalVoltage[2].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'signalVoltage.signalVoltage[2].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
