    Real 'currentRMSsensorE.CurrentSensor1.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'currentRMSsensorE.CurrentSensor1.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'currentRMSsensorE.CurrentSensor1.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentRMSsensorE.CurrentSensor1.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentRMSsensorE.CurrentSensor1.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentRMSsensorE.CurrentSensor1.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentRMSsensorE.CurrentSensor1.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
