    Real 'currentRMSsensorM.currentSensor.i[1]'(unit = "A") "Current in the branch from p to n as output signal";
    Real 'currentRMSsensorM.currentSensor.i[2]'(unit = "A") "Current in the branch from p to n as output signal";
    Real 'currentRMSsensorM.currentSensor.i[3]'(unit = "A") "Current in the branch from p to n as output signal";
    Real 'currentRMSsensorM.currentSensor.currentSensor[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentRMSsensorM.currentSensor.currentSensor[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentRMSsensorM.currentSensor.currentSensor[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
