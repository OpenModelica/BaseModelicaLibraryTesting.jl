    'forceToPosition3b.u' = 'forceToPosition3b.flange.f' "input = flow = force";
    'forceToPosition3b.y' = 'forceToPosition3b.p';
    'forceToPosition3b.y1' = 0.0;
    'forceToPosition3b.y2' = 0.0;
    'forceToPosition3b.u1' = 0.0;
    'forceToPosition3b.u2' = 0.0;
    'forceToPosition3b.u' = 'forceToPosition3b.f';
    annotation(experiment(StopTime = 1, Interval = 0.001));
  end 'GenerationOfFMUs';
end 'GenerationOfFMUs';
