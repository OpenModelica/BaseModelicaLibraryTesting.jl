    parameter Boolean 'springDamper.positionToForce2.use_fder2' = false "Use output for 2nd derivative of flow (only if 1st derivative is used, too)" annotation(Evaluate = true);
    Real 'springDamper.positionToForce2.p'(unit = "m") "Input for potential";
    Real 'springDamper.positionToForce2.pder'(unit = "m/s") "Optional input for der(potential)";
    Real 'springDamper.positionToForce2.f'(unit = "N") "Output for flow";
    parameter String 'springDamper.positionToForce2.Name_p' = "s" "Name of potential variable";
    parameter String 'springDamper.positionToForce2.Name_pder' = "v" "Name of 1st derivative of potential variable";
    parameter String 'springDamper.positionToForce2.Name_pder2' = "a" "Name of 2nd derivative of potential variable";
