//! base 0.1.0
package 'GenerationOfFMUs'
  model 'GenerationOfFMUs' "Example to demonstrate variants to generate FMUs (Functional Mock-up Units)"
    parameter Real 'sine1.amplitude' = 10.0 "Amplitude of sine wave";
    parameter Real 'sine1.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of sine wave";
    parameter Real 'sine1.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine1.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine1.y' "Connector of Real output signal";
    parameter Real 'sine1.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine1.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'directMass.m'(min = 0.0, unit = "kg", quantity = "Mass") = 1.1 "Mass";
    parameter Real 'directMass.mass.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.1 "Mass of the sliding mass";
    parameter StateSelect 'directMass.mass.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'directMass.mass.s'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'directMass.mass.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'directMass.mass.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'directMass.mass.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'directMass.mass.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'directMass.mass.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'directMass.mass.v'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'directMass.mass.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter Boolean 'directMass.forceSource.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'directMass.forceSource.s'(unit = "m", quantity = "Length") "Distance between flange and support (= flange.s - support.s)";
    Real 'directMass.forceSource.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'directMass.forceSource.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'directMass.forceSource.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'directMass.forceSource.f'(unit = "N") "Driving force as input signal";
    Real 'directMass.fDrive'(unit = "N") "Accelerating force acting at flange (= -flange.f)";
    parameter Boolean 'directMass.forceToPosition.use_pder' = true "Use output for 1st derivative of potential" annotation(Evaluate = true);
    parameter Boolean 'directMass.forceToPosition.use_pder2' = true "Use output for 2nd derivative of potential (only if 1st derivative is used, too)" annotation(Evaluate = true);
    parameter Boolean 'directMass.forceToPosition.use_fder' = false "Use input for 1st derivative of flow" annotation(Evaluate = true);
    parameter Boolean 'directMass.forceToPosition.use_fder2' = false "Use input for 2nd derivative of flow (only if 1st derivative is used, too)" annotation(Evaluate = true);
    Real 'directMass.forceToPosition.p'(unit = "m") "Output for potential";
    Real 'directMass.forceToPosition.pder'(unit = "m/s") "Optional output for der(potential)";
    Real 'directMass.forceToPosition.pder2'(unit = "m/s2") "Optional output for der2(potential)";
    Real 'directMass.forceToPosition.f'(unit = "N") "Input for flow";
    parameter String 'directMass.forceToPosition.Name_p' = "s" "Name of potential variable";
    parameter String 'directMass.forceToPosition.Name_pder' = "v" "Name of 1st derivative of potential variable";
    parameter String 'directMass.forceToPosition.Name_pder2' = "a" "Name of 2nd derivative of potential variable";
    parameter String 'directMass.forceToPosition.Name_f' = "f" "Name of flow variable";
    parameter String 'directMass.forceToPosition.Name_fder' = "der(f)" "Name of 1st derivative of flow variable";
    parameter String 'directMass.forceToPosition.Name_fder2' = "der2(f)" "Name of 2nd derivative of flow variable";
    Real 'directMass.forceToPosition.y' "Output signal";
    Real 'directMass.forceToPosition.y1' "Optional 1st derivative of output";
    Real 'directMass.forceToPosition.y2' "Optional 2nd derivative of output";
    Real 'directMass.forceToPosition.u' "Input signal";
    Real 'directMass.forceToPosition.u1' "Optional 1st derivative of input";
    Real 'directMass.forceToPosition.u2' "Optional 2nd derivative of input";
    Real 'directMass.forceToPosition.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'directMass.forceToPosition.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'directMass.s'(unit = "m") "Mass moves with position s due to force f";
    Real 'directMass.v'(unit = "m/s") "Mass moves with speed v due to force f";
    Real 'directMass.a'(unit = "m/s2") "Mass moves with acceleration a due to force f";
    Real 'directMass.f'(unit = "N") "Force to drive the mass";
    parameter Real 'inverseMass.m'(min = 0.0, unit = "kg", quantity = "Mass") = 2.2 "Mass";
    parameter Real 'inverseMass.mass.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 2.2 "Mass of the sliding mass";
    parameter StateSelect 'inverseMass.mass.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'inverseMass.mass.s'(stateSelect = StateSelect.default, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'inverseMass.mass.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'inverseMass.mass.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'inverseMass.mass.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'inverseMass.mass.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'inverseMass.mass.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'inverseMass.mass.v'(stateSelect = StateSelect.default, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'inverseMass.mass.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter Boolean 'inverseMass.positionToForce.use_pder' = true "Use input for 1st derivative of potential" annotation(Evaluate = true);
    parameter Boolean 'inverseMass.positionToForce.use_pder2' = true "Use input for 2nd derivative of potential (only if 1st derivative is used, too)" annotation(Evaluate = true);
    parameter Boolean 'inverseMass.positionToForce.use_fder' = false "Use output for 1st derivative of flow" annotation(Evaluate = true);
    parameter Boolean 'inverseMass.positionToForce.use_fder2' = false "Use output for 2nd derivative of flow (only if 1st derivative is used, too)" annotation(Evaluate = true);
    Real 'inverseMass.positionToForce.p'(unit = "m") "Input for potential";
    Real 'inverseMass.positionToForce.pder'(unit = "m/s") "Optional input for der(potential)";
    Real 'inverseMass.positionToForce.pder2'(unit = "m/s2") "Optional input for der2(potential)";
    Real 'inverseMass.positionToForce.f'(unit = "N") "Output for flow";
    parameter String 'inverseMass.positionToForce.Name_p' = "s" "Name of potential variable";
    parameter String 'inverseMass.positionToForce.Name_pder' = "v" "Name of 1st derivative of potential variable";
    parameter String 'inverseMass.positionToForce.Name_pder2' = "a" "Name of 2nd derivative of potential variable";
    parameter String 'inverseMass.positionToForce.Name_f' = "f" "Name of flow variable";
    parameter String 'inverseMass.positionToForce.Name_fder' = "der(f)" "Name of 1st derivative of flow variable";
    parameter String 'inverseMass.positionToForce.Name_fder2' = "der2(f)" "Name of 2nd derivative of flow variable";
    Real 'inverseMass.positionToForce.y' "Output signal";
    Real 'inverseMass.positionToForce.y1' "Optional 1st derivative of output";
    Real 'inverseMass.positionToForce.y2' "Optional 2nd derivative of output";
    Real 'inverseMass.positionToForce.u' "Input signal";
    Real 'inverseMass.positionToForce.u1' "Optional 1st derivative of input";
    Real 'inverseMass.positionToForce.u2' "Optional 2nd derivative of input";
    Real 'inverseMass.positionToForce.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'inverseMass.positionToForce.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'inverseMass.s'(unit = "m") "Position to drive the mass";
    Real 'inverseMass.v'(unit = "m/s") "Speed to drive the mass";
    Real 'inverseMass.a'(unit = "m/s2") "Acceleration to drive the mass";
    Real 'inverseMass.f'(unit = "N") "Force needed to drive the flange according to s, v, a";
    parameter Real 'springDamper.c'(unit = "N/m", quantity = "TranslationalSpringConstant") = 1e4 "Spring constant";
    parameter Real 'springDamper.d'(unit = "N.s/m", quantity = "TranslationalDampingConstant") = 100.0 "Damping constant";
    parameter Real 'springDamper.s_rel0'(unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
    parameter Boolean 'springDamper.positionToForce1.use_pder' = true "Use input for 1st derivative of potential" annotation(Evaluate = true);
    parameter Boolean 'springDamper.positionToForce1.use_pder2' = false "Use input for 2nd derivative of potential (only if 1st derivative is used, too)" annotation(Evaluate = true);
    parameter Boolean 'springDamper.positionToForce1.use_fder' = false "Use output for 1st derivative of flow" annotation(Evaluate = true);
    parameter Boolean 'springDamper.positionToForce1.use_fder2' = false "Use output for 2nd derivative of flow (only if 1st derivative is used, too)" annotation(Evaluate = true);
    Real 'springDamper.positionToForce1.p'(unit = "m") "Input for potential";
    Real 'springDamper.positionToForce1.pder'(unit = "m/s") "Optional input for der(potential)";
    Real 'springDamper.positionToForce1.f'(unit = "N") "Output for flow";
    parameter String 'springDamper.positionToForce1.Name_p' = "s" "Name of potential variable";
    parameter String 'springDamper.positionToForce1.Name_pder' = "v" "Name of 1st derivative of potential variable";
    parameter String 'springDamper.positionToForce1.Name_pder2' = "a" "Name of 2nd derivative of potential variable";
    parameter String 'springDamper.positionToForce1.Name_f' = "f" "Name of flow variable";
    parameter String 'springDamper.positionToForce1.Name_fder' = "der(f)" "Name of 1st derivative of flow variable";
    parameter String 'springDamper.positionToForce1.Name_fder2' = "der2(f)" "Name of 2nd derivative of flow variable";
    Real 'springDamper.positionToForce1.y' "Output signal";
    Real 'springDamper.positionToForce1.y1' "Optional 1st derivative of output";
