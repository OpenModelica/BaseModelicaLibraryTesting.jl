    parameter Real 'mass2a.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.1 "Mass of the sliding mass";
    parameter StateSelect 'mass2a.stateSelect' = StateSelect.default "Priority to use s and v as states";
