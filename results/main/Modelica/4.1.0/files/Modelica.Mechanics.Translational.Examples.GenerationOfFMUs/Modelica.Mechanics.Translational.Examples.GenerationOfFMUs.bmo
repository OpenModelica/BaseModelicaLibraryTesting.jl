    Real 'springDamper.positionToForce1.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'springDamper.s1'(unit = "m") "Position of left flange of force element";
    Real 'springDamper.v1'(unit = "m/s") "Speed to left flange of force element";
    Real 'springDamper.f1'(unit = "N") "Force generated by the force element";
    parameter Real 'springDamper.springDamper.c'(start = 1e5, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e4 "Spring constant";
    parameter Real 'springDamper.springDamper.d'(start = 0.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 100.0 "Damping constant";
    parameter Real 'springDamper.springDamper.s_rel0'(unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
    Real 'springDamper.springDamper.v_rel'(start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'springDamper.springDamper.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'springDamper.springDamper.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'springDamper.springDamper.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'springDamper.springDamper.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'springDamper.springDamper.s_rel'(start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'springDamper.springDamper.f'(unit = "N", quantity = "Force") "Force between flanges (positive in direction of flange axis R)";
    parameter Boolean 'springDamper.springDamper.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'springDamper.springDamper.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'springDamper.springDamper.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'springDamper.springDamper.f_d'(unit = "N", quantity = "Force") "Damping force";
    Real 'springDamper.s2'(unit = "m") "Position of right flange of force element";
    Real 'springDamper.v2'(unit = "m/s") "Speed to right flange of force element";
    Real 'springDamper.f2'(unit = "N") "Force generated by the force element";
    parameter Boolean 'springDamper.positionToForce2.use_pder' = true "Use input for 1st derivative of potential" annotation(Evaluate = true);
    parameter Boolean 'springDamper.positionToForce2.use_pder2' = false "Use input for 2nd derivative of potential (only if 1st derivative is used, too)" annotation(Evaluate = true);
