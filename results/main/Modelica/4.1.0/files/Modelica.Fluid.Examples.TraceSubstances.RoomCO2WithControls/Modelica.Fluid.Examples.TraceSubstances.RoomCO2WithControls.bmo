//! base 0.1.0
package 'RoomCO2WithControls'
  function '$OMC$PositiveMax'
    input Real 'flowValue';
    input Real 'eps';
    output Real 'positiveMax';
  algorithm
    'positiveMax' := max('flowValue', 'eps');
  end '$OMC$PositiveMax';

  function 'Modelica.Blocks.Tables.Internal.getNextTimeEvent' "Return next time event value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Real 'timeIn';
    output Real 'nextTimeEvent';
  external "C" 'nextTimeEvent' = ModelicaStandardTables_CombiTimeTable_nextTimeEvent('tableID', 'timeIn') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getNextTimeEvent';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmax' "Return maximum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMax';
  external "C" 'timeMax' = ModelicaStandardTables_CombiTimeTable_maximumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmax';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmin' "Return minimum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMin';
  external "C" 'timeMin' = ModelicaStandardTables_CombiTimeTable_minimumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmin';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer' "Interpolate 1-dim. table where first column is time (but do not provide a derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Integer 'icol';
    input Real 'timeIn';
    input Real 'nextTimeEvent';
    input Real 'pre_nextTimeEvent';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTimeTable_getValue('tableID', 'icol', 'timeIn', 'nextTimeEvent', 'pre_nextTimeEvent') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.T_phX' "Return temperature as a function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.T_phX.f_nonlinear'(p = 'p', h = 'h', X = 'X'[1:1]), 190.0, 647.0, 2.220446049250313e-14);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.T_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.enthalpyOfWater' "Computes specific enthalpy of water (solid/liquid) near atmospheric pressure from temperature T"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.enthalpyOfWater_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.enthalpyOfWater';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.enthalpyOfWater_der' "Derivative function of enthalpyOfWater"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT'(unit = "K/s");
    output Real 'dh'(unit = "J/(kg.s)");
  algorithm
    'dh' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction_der'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1, 4200.0 * 'dT', 2050.0 * 'dT', 'dT', 0.0);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.enthalpyOfWater_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.h_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.h_pTX_der' "Derivative function of h_pTX"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real 'dp'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    input Real 'dT'(unit = "K/s", quantity = "TemperatureSlope");
    input Real[:] 'dX'(each unit = "1/s");
    output Real 'h_der'(unit = "J/(kg.s)");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'x_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'dX_steam'(unit = "1/s");
    Real 'dX_air'(unit = "1/s");
    Real 'dX_liq'(unit = "1/s");
    Real 'dps'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dx_sat'(unit = "1/s");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressure'('T');
    'x_sat' := 'p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat');
    'X_sat' := min('x_sat' * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.smoothMax'('X'[1] - 'X_sat', 0.0, 1e-5);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'dX_air' := -'dX'[1];
    'dps' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressure_der'('T', 'dT');
    'dx_sat' := 0.6219647130774989 * ('dps' * ('p' - 'p_steam_sat') - 'p_steam_sat' * ('dp' - 'dps')) / ('p' - 'p_steam_sat') / ('p' - 'p_steam_sat');
    'dX_liq' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.smoothMax_der'('X'[1] - 'X_sat', 0.0, 1e-5, (1.0 + 'x_sat') * 'dX'[1] - (1.0 - 'X'[1]) * 'dx_sat', 0.0, 0.0);
    'dX_steam' := 'dX'[1] - 'dX_liq';
    'h_der' := 'X_steam' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T')) + 'dX_steam' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) + 'X_air' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T')) + 'dX_air' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) + 'X_liquid' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.enthalpyOfWater_der'('T', 'dT') + 'dX_liq' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.enthalpyOfWater'('T');
    annotation(Inline = false, smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.h_pTX_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.pressure' "Returns pressure of ideal gas as a function of the thermodynamic state record"
    input 'boundary4.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.pressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressure' "Return saturation pressure of water as a function of temperature T between 190 and 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'psat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressure_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressureLiquid';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressureLiquid_der' "Derivative function for 'saturationPressureLiquid'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
    Real 'r1_der' = -1.0 / 'Tcritical' * 'dTsat';
    Real 'r2' = 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6];
  algorithm
    'psat_der' := exp('r2' * 'Tcritical' / 'Tsat') * 'pcritical' * (('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der') + 'a'[3] * ('r1' ^ ('n'[3] - 1.0) * 'n'[3] * 'r1_der') + 'a'[4] * ('r1' ^ ('n'[4] - 1.0) * 'n'[4] * 'r1_der') + 'a'[5] * ('r1' ^ ('n'[5] - 1.0) * 'n'[5] * 'r1_der') + 'a'[6] * ('r1' ^ ('n'[6] - 1.0) * 'n'[6] * 'r1_der')) * 'Tcritical' / 'Tsat' - 'r2' * 'Tcritical' * 'dTsat' / 'Tsat' ^ 2.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressureLiquid_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressure_der' "Derivative function for 'saturationPressure'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
  algorithm
    'psat_der' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction_der'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0, 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressureLiquid_der'('Tsat', 'dTsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.sublimationPressureIce_der'('Tsat', 'dTsat'), 'dTsat', 0.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.saturationPressure_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'boundary4.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'boundary4.Medium.ThermodynamicState'('p', 'T', 'X') else 'boundary4.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'boundary4.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'boundary4.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.T_phX'('p', 'h', 'X'), 'X') else 'boundary4.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.specificEnthalpy' "Return specific enthalpy of moist air as a function of the thermodynamic state record"
    input 'boundary4.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.h_pTX'('state'.'p', 'state'.'T', 'state'.'X');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.specificEnthalpy'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.sublimationPressureIce' "Return sublimation pressure of water as a function of temperature T between 190 and 273.16 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
  algorithm
    'psat' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.sublimationPressureIce_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.sublimationPressureIce';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.sublimationPressureIce_der' "Derivative function for 'sublimationPressureIce'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
    Real 'r1_der' = 'dTsat' / 'Ttriple';
  algorithm
    'psat_der' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple' * (-('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der')));
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.sublimationPressureIce_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'boundary4.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.temperature';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.temperature'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.T_phX.f_nonlinear' "Solve h_pTX(p,T,X) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.h_pTX'('p', 'u', 'X') - 'h';
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.T_phX.f_nonlinear';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.smoothMax'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    output Real 'y';
  algorithm
    'y' := max('x1', 'x2') + log(exp(4.0 / 'dx' * ('x1' - max('x1', 'x2'))) + exp(4.0 / 'dx' * ('x2' - max('x1', 'x2')))) / (4.0 / 'dx');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.smoothMax';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.smoothMax_der'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    input Real 'dx1';
    input Real 'dx2';
    input Real 'ddx';
    output Real 'dy';
  algorithm
    'dy' := (if 'x1' > 'x2' then 'dx1' else 'dx2') + 0.25 * (((4.0 * ('dx1' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x1' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + (4.0 * ('dx2' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x2' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'dx' / (exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) + log(exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'ddx');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.smoothMax_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction_der' "Derivative of spliceFunction"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    input Real 'dpos';
    input Real 'dneg';
    input Real 'dx';
    input Real 'ddeltax' = 0.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'dscaledX1';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'dpos' * 'y' + (1.0 - 'y') * 'dneg';

    if abs('scaledX1') < 'lim' then
      'dscaledX1' := ('dx' - 'scaledX1' * 'ddeltax') / 'deltax';
      'out' := 'out' + ('pos' - 'neg') * 'dscaledX1' * 0.25 * 3.141592653589793 * (1.0 - tanh('scaledXt') ^ 2.0) * ('scaledXt' ^ 2.0 + 1.0);
    end if;
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.boundary4.Medium.Utilities.spliceFunction_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.T_phX' "Return temperature as a function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.T_phX.f_nonlinear'(p = 'p', h = 'h', X = 'X'[1:1]), 190.0, 647.0, 2.220446049250313e-14);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.T_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.density' "Returns density of ideal gas as a function of the thermodynamic state record"
    input 'ductIn.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'state'.'p' / ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.gasConstant'('state') * 'state'.'T');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.density';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.enthalpyOfWater' "Computes specific enthalpy of water (solid/liquid) near atmospheric pressure from temperature T"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.enthalpyOfWater_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.enthalpyOfWater';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.enthalpyOfWater_der' "Derivative function of enthalpyOfWater"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT'(unit = "K/s");
    output Real 'dh'(unit = "J/(kg.s)");
  algorithm
    'dh' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction_der'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1, 4200.0 * 'dT', 2050.0 * 'dT', 'dT', 0.0);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.enthalpyOfWater_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.gasConstant' "Return ideal gas constant as a function from thermodynamic state, only valid for phi<1"
    input 'ductIn.Medium.ThermodynamicState' 'state';
    output Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'R_s' := 287.0525368759184 * (1.0 - 'state'.'X'[1]) + 461.5254384056201 * 'state'.'X'[1];
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.gasConstant';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.h_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.h_pTX_der' "Derivative function of h_pTX"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real 'dp'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    input Real 'dT'(unit = "K/s", quantity = "TemperatureSlope");
    input Real[:] 'dX'(each unit = "1/s");
    output Real 'h_der'(unit = "J/(kg.s)");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'x_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'dX_steam'(unit = "1/s");
    Real 'dX_air'(unit = "1/s");
    Real 'dX_liq'(unit = "1/s");
    Real 'dps'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dx_sat'(unit = "1/s");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressure'('T');
    'x_sat' := 'p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat');
    'X_sat' := min('x_sat' * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.smoothMax'('X'[1] - 'X_sat', 0.0, 1e-5);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'dX_air' := -'dX'[1];
    'dps' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressure_der'('T', 'dT');
    'dx_sat' := 0.6219647130774989 * ('dps' * ('p' - 'p_steam_sat') - 'p_steam_sat' * ('dp' - 'dps')) / ('p' - 'p_steam_sat') / ('p' - 'p_steam_sat');
    'dX_liq' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.smoothMax_der'('X'[1] - 'X_sat', 0.0, 1e-5, (1.0 + 'x_sat') * 'dX'[1] - (1.0 - 'X'[1]) * 'dx_sat', 0.0, 0.0);
    'dX_steam' := 'dX'[1] - 'dX_liq';
    'h_der' := 'X_steam' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T')) + 'dX_steam' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) + 'X_air' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T')) + 'dX_air' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) + 'X_liquid' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.enthalpyOfWater_der'('T', 'dT') + 'dX_liq' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.enthalpyOfWater'('T');
    annotation(Inline = false, smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.h_pTX_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressure' "Return saturation pressure of water as a function of temperature T between 190 and 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'psat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressure_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressureLiquid';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressureLiquid_der' "Derivative function for 'saturationPressureLiquid'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
    Real 'r1_der' = -1.0 / 'Tcritical' * 'dTsat';
    Real 'r2' = 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6];
  algorithm
    'psat_der' := exp('r2' * 'Tcritical' / 'Tsat') * 'pcritical' * (('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der') + 'a'[3] * ('r1' ^ ('n'[3] - 1.0) * 'n'[3] * 'r1_der') + 'a'[4] * ('r1' ^ ('n'[4] - 1.0) * 'n'[4] * 'r1_der') + 'a'[5] * ('r1' ^ ('n'[5] - 1.0) * 'n'[5] * 'r1_der') + 'a'[6] * ('r1' ^ ('n'[6] - 1.0) * 'n'[6] * 'r1_der')) * 'Tcritical' / 'Tsat' - 'r2' * 'Tcritical' * 'dTsat' / 'Tsat' ^ 2.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressureLiquid_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressure_der' "Derivative function for 'saturationPressure'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
  algorithm
    'psat_der' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction_der'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0, 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressureLiquid_der'('Tsat', 'dTsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.sublimationPressureIce_der'('Tsat', 'dTsat'), 'dTsat', 0.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.saturationPressure_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'ductIn.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'ductIn.Medium.ThermodynamicState'('p', 'T', 'X') else 'ductIn.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'ductIn.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'ductIn.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.T_phX'('p', 'h', 'X'), 'X') else 'ductIn.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.specificEnthalpy' "Return specific enthalpy of moist air as a function of the thermodynamic state record"
    input 'ductIn.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.h_pTX'('state'.'p', 'state'.'T', 'state'.'X');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.specificEnthalpy'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.sublimationPressureIce' "Return sublimation pressure of water as a function of temperature T between 190 and 273.16 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
  algorithm
    'psat' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.sublimationPressureIce_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.sublimationPressureIce';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.sublimationPressureIce_der' "Derivative function for 'sublimationPressureIce'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
    Real 'r1_der' = 'dTsat' / 'Ttriple';
  algorithm
    'psat_der' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple' * (-('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der')));
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.sublimationPressureIce_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'ductIn.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.temperature';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.temperature'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.T_phX.f_nonlinear' "Solve h_pTX(p,T,X) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.h_pTX'('p', 'u', 'X') - 'h';
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.T_phX.f_nonlinear';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.smoothMax'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    output Real 'y';
  algorithm
    'y' := max('x1', 'x2') + log(exp(4.0 / 'dx' * ('x1' - max('x1', 'x2'))) + exp(4.0 / 'dx' * ('x2' - max('x1', 'x2')))) / (4.0 / 'dx');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.smoothMax';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.smoothMax_der'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    input Real 'dx1';
    input Real 'dx2';
    input Real 'ddx';
    output Real 'dy';
  algorithm
    'dy' := (if 'x1' > 'x2' then 'dx1' else 'dx2') + 0.25 * (((4.0 * ('dx1' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x1' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + (4.0 * ('dx2' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x2' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'dx' / (exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) + log(exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'ddx');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.smoothMax_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction_der' "Derivative of spliceFunction"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    input Real 'dpos';
    input Real 'dneg';
    input Real 'dx';
    input Real 'ddeltax' = 0.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'dscaledX1';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'dpos' * 'y' + (1.0 - 'y') * 'dneg';

    if abs('scaledX1') < 'lim' then
      'dscaledX1' := ('dx' - 'scaledX1' * 'ddeltax') / 'deltax';
      'out' := 'out' + ('pos' - 'neg') * 'dscaledX1' * 0.25 * 3.141592653589793 * (1.0 - tanh('scaledXt') ^ 2.0) * ('scaledXt' ^ 2.0 + 1.0);
    end if;
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.Utilities.spliceFunction_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.density' "Returns density of ideal gas as a function of the thermodynamic state record"
    input 'ductIn.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'state'.'p' / ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.gasConstant'('state') * 'state'.'T');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.dynamicViscosity' "Return dynamic viscosity as a function of the thermodynamic state record, valid from 123.15 K to 1273.15 K"
    input 'ductIn.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'eta'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
  algorithm
    'eta' := 1e-6 * 'Modelica.Math.Polynomials.evaluateWithRange'({9.739110288630587e-15, -3.1353724870333906e-11, 4.3004876595642225e-8, -3.822801629175824e-5, 0.05042787436718076, 17.23926013924253}, -149.99999999999997, 1000.0000000000001, 'state'.'T' - 273.15);
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.dynamicViscosity';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.gasConstant' "Return ideal gas constant as a function from thermodynamic state, only valid for phi<1"
    input 'ductIn.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'R_s' := 287.0525368759184 * (1.0 - 'state'.'X'[1]) + 461.5254384056201 * 'state'.'X'[1];
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.gasConstant';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.pressure' "Returns pressure of ideal gas as a function of the thermodynamic state record"
    input 'ductIn.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / log10('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'lambda2';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'dRe_ddp';
    Real 'aux1';
    Real 'aux2';
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'lambda2' := abs('dp_fric') * 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' * 'mu') "Known as lambda2=f(dp)";
    'aux1' := 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' ^ 2.0);
    'Re' := 'lambda2' / 64.0 "Hagen-Poiseuille";
    'dRe_ddp' := 'aux1' / 64.0 "Hagen-Poiseuille";

    if 'Re' > 'Re1' then
      'Re' := -2.0 * sqrt('lambda2') * log10(2.51 / sqrt('lambda2') + 0.27 * 'Delta') "Colebrook-White";
      'aux2' := sqrt('aux1' * abs('dp_fric'));
      'dRe_ddp' := 0.43429448190325176 * (5.02 / (2.0 * abs('dp_fric') * (2.51 / 'aux2' + 0.27 * 'Delta')) - 2.0 * log(2.51 / 'aux2' + 0.27 * 'Delta') * 'aux1' / (2.0 * 'aux2'));

      if 'Re' < 'Re2' then
        ('Re', 'dRe_ddp') := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative'('lambda2', 'Re1', 'Re2', 'Delta', 'dp_fric');
      end if;
    end if;

    'm_flow' := 'crossArea' / 'diameter' * 'mu' * (if 'dp_fric' >= 0.0 then 'Re' else -'Re');
    'dm_flow_ddp_fric' := 'crossArea' / 'diameter' * 'mu' * 'dRe_ddp';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative' "Interpolation in log-log space using a cubic Hermite polynomial, where x=log10(lambda2), y=log10(Re)"
    input Real 'lambda2';
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    output Real 'dRe_ddp';
    Real 'x1' = log10(64.0 * 'Re1');
    Real 'y1' = log10('Re1');
    Real 'y1d' = 1.0;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x' = log10('lambda2');
    Real 'y';
    Real 'dy_dx';
    Real 'aux3' = log10('aux2');
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'x2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'y2' = log10('aux5');
    Real 'y2d' = 0.5 + 1.0900791495771618 / ('aux5' * 'aux4');
  algorithm
    ('y', 'dy_dx') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('x', 'x1', 'x2', 'y1', 'y2', 'y1d', 'y2d');
    'Re' := 10.0 ^ 'y';
    'dRe_ddp' := 'Re' / abs('dp_fric') * 'dy_dx';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2' "Cubic Hermite spline interpolation in transition region"
    input Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta';
    output Real 'lambda2';
    Real 'x1' = log10('Re1');
    Real 'y1' = log10(64.0 * 'Re1');
    Real 'yd1' = 1.0;
    Real 'aux1' = 1.1217826467560994;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x2' = log10('Re2');
    Real 'dx' = log10('Re' / 'Re1');
    Real 'aux3' = log10('aux2');
    Real 'diff_x' = 'x2' - 'x1';
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'yd2' = 2.0 + 4.0 * 'aux1' / ('aux2' * 'aux3' * 'Re2' ^ 0.9);
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'y2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'm' = ('y2' - 'y1') / 'diff_x';
    Real 'c2' = (3.0 * 'm' - 2.0 * 'yd1' - 'yd2') / 'diff_x';
    Real 'c3' = ('yd1' + 'yd2' - 2.0 * 'm') / ('diff_x' * 'diff_x');
  algorithm
    'lambda2' := 64.0 * 'Re1' * ('Re' / 'Re1') ^ ('yd1' + 'dx' * ('c2' + 'dx' * 'c3'));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.heatTransfer.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'ductIn.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.T_phX' "Return temperature as a function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.T_phX.f_nonlinear'(p = 'p', h = 'h', X = 'X'[1:1]), 190.0, 647.0, 2.220446049250313e-14);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.T_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.density' "Returns density of ideal gas as a function of the thermodynamic state record"
    input 'ductOut.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'state'.'p' / ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.gasConstant'('state') * 'state'.'T');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.density';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.enthalpyOfWater' "Computes specific enthalpy of water (solid/liquid) near atmospheric pressure from temperature T"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.enthalpyOfWater_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.enthalpyOfWater';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.enthalpyOfWater_der' "Derivative function of enthalpyOfWater"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT'(unit = "K/s");
    output Real 'dh'(unit = "J/(kg.s)");
  algorithm
    'dh' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction_der'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1, 4200.0 * 'dT', 2050.0 * 'dT', 'dT', 0.0);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.enthalpyOfWater_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.gasConstant' "Return ideal gas constant as a function from thermodynamic state, only valid for phi<1"
    input 'ductOut.Medium.ThermodynamicState' 'state';
    output Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'R_s' := 287.0525368759184 * (1.0 - 'state'.'X'[1]) + 461.5254384056201 * 'state'.'X'[1];
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.gasConstant';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.h_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.h_pTX_der' "Derivative function of h_pTX"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real 'dp'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    input Real 'dT'(unit = "K/s", quantity = "TemperatureSlope");
    input Real[:] 'dX'(each unit = "1/s");
    output Real 'h_der'(unit = "J/(kg.s)");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'x_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'dX_steam'(unit = "1/s");
    Real 'dX_air'(unit = "1/s");
    Real 'dX_liq'(unit = "1/s");
    Real 'dps'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dx_sat'(unit = "1/s");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressure'('T');
    'x_sat' := 'p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat');
    'X_sat' := min('x_sat' * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.smoothMax'('X'[1] - 'X_sat', 0.0, 1e-5);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'dX_air' := -'dX'[1];
    'dps' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressure_der'('T', 'dT');
    'dx_sat' := 0.6219647130774989 * ('dps' * ('p' - 'p_steam_sat') - 'p_steam_sat' * ('dp' - 'dps')) / ('p' - 'p_steam_sat') / ('p' - 'p_steam_sat');
    'dX_liq' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.smoothMax_der'('X'[1] - 'X_sat', 0.0, 1e-5, (1.0 + 'x_sat') * 'dX'[1] - (1.0 - 'X'[1]) * 'dx_sat', 0.0, 0.0);
    'dX_steam' := 'dX'[1] - 'dX_liq';
    'h_der' := 'X_steam' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T')) + 'dX_steam' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) + 'X_air' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T')) + 'dX_air' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) + 'X_liquid' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.enthalpyOfWater_der'('T', 'dT') + 'dX_liq' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.enthalpyOfWater'('T');
    annotation(Inline = false, smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.h_pTX_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressure' "Return saturation pressure of water as a function of temperature T between 190 and 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'psat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressure_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressureLiquid';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressureLiquid_der' "Derivative function for 'saturationPressureLiquid'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
    Real 'r1_der' = -1.0 / 'Tcritical' * 'dTsat';
    Real 'r2' = 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6];
  algorithm
    'psat_der' := exp('r2' * 'Tcritical' / 'Tsat') * 'pcritical' * (('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der') + 'a'[3] * ('r1' ^ ('n'[3] - 1.0) * 'n'[3] * 'r1_der') + 'a'[4] * ('r1' ^ ('n'[4] - 1.0) * 'n'[4] * 'r1_der') + 'a'[5] * ('r1' ^ ('n'[5] - 1.0) * 'n'[5] * 'r1_der') + 'a'[6] * ('r1' ^ ('n'[6] - 1.0) * 'n'[6] * 'r1_der')) * 'Tcritical' / 'Tsat' - 'r2' * 'Tcritical' * 'dTsat' / 'Tsat' ^ 2.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressureLiquid_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressure_der' "Derivative function for 'saturationPressure'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
  algorithm
    'psat_der' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction_der'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0, 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressureLiquid_der'('Tsat', 'dTsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.sublimationPressureIce_der'('Tsat', 'dTsat'), 'dTsat', 0.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.saturationPressure_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'ductOut.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'ductOut.Medium.ThermodynamicState'('p', 'T', 'X') else 'ductOut.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'ductOut.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'ductOut.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.T_phX'('p', 'h', 'X'), 'X') else 'ductOut.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.specificEnthalpy' "Return specific enthalpy of moist air as a function of the thermodynamic state record"
    input 'ductOut.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.h_pTX'('state'.'p', 'state'.'T', 'state'.'X');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.specificEnthalpy'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.sublimationPressureIce' "Return sublimation pressure of water as a function of temperature T between 190 and 273.16 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
  algorithm
    'psat' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.sublimationPressureIce_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.sublimationPressureIce';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.sublimationPressureIce_der' "Derivative function for 'sublimationPressureIce'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
    Real 'r1_der' = 'dTsat' / 'Ttriple';
  algorithm
    'psat_der' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple' * (-('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der')));
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.sublimationPressureIce_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'ductOut.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.temperature';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.temperature'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.T_phX.f_nonlinear' "Solve h_pTX(p,T,X) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.h_pTX'('p', 'u', 'X') - 'h';
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.T_phX.f_nonlinear';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.smoothMax'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    output Real 'y';
  algorithm
    'y' := max('x1', 'x2') + log(exp(4.0 / 'dx' * ('x1' - max('x1', 'x2'))) + exp(4.0 / 'dx' * ('x2' - max('x1', 'x2')))) / (4.0 / 'dx');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.smoothMax';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.smoothMax_der'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    input Real 'dx1';
    input Real 'dx2';
    input Real 'ddx';
    output Real 'dy';
  algorithm
    'dy' := (if 'x1' > 'x2' then 'dx1' else 'dx2') + 0.25 * (((4.0 * ('dx1' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x1' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + (4.0 * ('dx2' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x2' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'dx' / (exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) + log(exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'ddx');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.smoothMax_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction_der' "Derivative of spliceFunction"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    input Real 'dpos';
    input Real 'dneg';
    input Real 'dx';
    input Real 'ddeltax' = 0.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'dscaledX1';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'dpos' * 'y' + (1.0 - 'y') * 'dneg';

    if abs('scaledX1') < 'lim' then
      'dscaledX1' := ('dx' - 'scaledX1' * 'ddeltax') / 'deltax';
      'out' := 'out' + ('pos' - 'neg') * 'dscaledX1' * 0.25 * 3.141592653589793 * (1.0 - tanh('scaledXt') ^ 2.0) * ('scaledXt' ^ 2.0 + 1.0);
    end if;
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.Medium.Utilities.spliceFunction_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.density' "Returns density of ideal gas as a function of the thermodynamic state record"
    input 'ductOut.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'state'.'p' / ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.gasConstant'('state') * 'state'.'T');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.density';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.dynamicViscosity' "Return dynamic viscosity as a function of the thermodynamic state record, valid from 123.15 K to 1273.15 K"
    input 'ductOut.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'eta'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
  algorithm
    'eta' := 1e-6 * 'Modelica.Math.Polynomials.evaluateWithRange'({9.739110288630587e-15, -3.1353724870333906e-11, 4.3004876595642225e-8, -3.822801629175824e-5, 0.05042787436718076, 17.23926013924253}, -149.99999999999997, 1000.0000000000001, 'state'.'T' - 273.15);
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.dynamicViscosity';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.gasConstant' "Return ideal gas constant as a function from thermodynamic state, only valid for phi<1"
    input 'ductOut.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'R_s' := 287.0525368759184 * (1.0 - 'state'.'X'[1]) + 461.5254384056201 * 'state'.'X'[1];
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.gasConstant';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.pressure' "Returns pressure of ideal gas as a function of the thermodynamic state record"
    input 'ductOut.flowModel.Medium.ThermodynamicState' 'state';
    output Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'state'.'p';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.Medium.pressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.massFlowRate_dp_staticHead' "Return mass flow rate m_flow as function of pressure loss dp, i.e., m_flow = f(dp), due to wall friction and static head"
    input Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'g_times_height_ab'(unit = "m2/s2");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'dp_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'dp_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'm_flow_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'm_flow_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_a'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dm_flow_ddp_fric_b'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'dp_grav_a'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_a';
    Real 'dp_grav_b'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 'g_times_height_ab' * 'rho_b';
    Real 'm_flow_zero'(unit = "kg/s", quantity = "MassFlowRate") = 0.0;
    Real 'dm_flow_ddp_fric_zero';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min((745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta')) ^ 0.97, 'Re_turbulent');
    Real 'dp_zero'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = ('dp_grav_a' + 'dp_grav_b') / 2.0;
  algorithm
    'dp_a' := max('dp_grav_a', 'dp_grav_b') + 'dp_small';
    'dp_b' := min('dp_grav_a', 'dp_grav_b') - 'dp_small';

    if 'dp' >= 'dp_a' then
      'm_flow' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif 'dp' <= 'dp_b' then
      'm_flow' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
    elseif true then
      ('m_flow_a', 'dm_flow_ddp_fric_a') := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_a' - 'dp_grav_a', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow_b', 'dm_flow_ddp_fric_b') := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric'('dp_b' - 'dp_grav_b', 'rho_a', 'rho_b', 'mu_a', 'mu_b', 'length', 'diameter', 'crossArea', 'Re1', 'Re2', 'Delta');
      ('m_flow', 'dm_flow_ddp_fric_zero') := 'Modelica.Fluid.Utilities.regFun3'('dp_zero', 'dp_b', 'dp_a', 'm_flow_b', 'm_flow_a', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_a');

      if 'dp' > 'dp_zero' then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_zero', 'dp_a', 'm_flow_zero', 'm_flow_a', 'dm_flow_ddp_fric_zero', 'dm_flow_ddp_fric_a');
      elseif true then
        'm_flow' := 'Modelica.Fluid.Utilities.regFun3'('dp', 'dp_b', 'dp_zero', 'm_flow_b', 'm_flow_zero', 'dm_flow_ddp_fric_b', 'dm_flow_ddp_fric_zero');
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.massFlowRate_dp_staticHead';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.pressureLoss_m_flow' "Return pressure loss dp as function of mass flow rate m_flow, i.e., dp = f(m_flow), due to wall friction"
    input Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area") = 3.141592653589793 * 'diameter' ^ 2.0 / 4.0;
    input Real 'roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5;
    input Real 'm_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 0.01;
    input Real 'Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0;
    output Real 'dp'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Delta'(min = 0.0) = 'roughness' / 'diameter';
    Real 'Re2'(unit = "1", quantity = "ReynoldsNumber") = 'Re_turbulent';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'lambda2';
    Real 'Re1'(unit = "1", quantity = "ReynoldsNumber") = min(745.0 * exp(if 'Delta' <= 0.0065 then 1.0 else 0.0065 / 'Delta'), 'Re_turbulent');
  algorithm
    'rho' := if 'm_flow' >= 0.0 then 'rho_a' else 'rho_b';
    'mu' := if 'm_flow' >= 0.0 then 'mu_a' else 'mu_b';
    'Re' := 'diameter' * abs('m_flow') / ('crossArea' * 'mu');
    'lambda2' := if 'Re' <= 'Re1' then 64.0 * 'Re' else if 'Re' >= 'Re2' then 0.25 * ('Re' / log10('Delta' / 3.7 + 5.74 / 'Re' ^ 0.9)) ^ 2.0 else 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2'('Re', 'Re1', 'Re2', 'Delta');
    'dp' := 'length' * 'mu' * 'mu' / (2.0 * 'rho' * 'diameter' * 'diameter' * 'diameter') * (if 'm_flow' >= 0.0 then 'lambda2' else -'lambda2');
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.pressureLoss_m_flow';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric' "Calculate mass flow rate as function of pressure drop due to friction"
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'rho_a'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'rho_b'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu_a'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'mu_b'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'length'(unit = "m", quantity = "Length");
    input Real 'diameter'(min = 0.0, unit = "m", quantity = "Length");
    input Real 'crossArea'(unit = "m2", quantity = "Area");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    output Real 'm_flow'(unit = "kg/s", quantity = "MassFlowRate");
    output Real 'dm_flow_ddp_fric';
    Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'lambda2';
    Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    Real 'dRe_ddp';
    Real 'aux1';
    Real 'aux2';
  algorithm
    if 'dp_fric' >= 0.0 then
      'rho' := 'rho_a';
      'mu' := 'mu_a';
    elseif true then
      'rho' := 'rho_b';
      'mu' := 'mu_b';
    end if;

    'lambda2' := abs('dp_fric') * 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' * 'mu') "Known as lambda2=f(dp)";
    'aux1' := 2.0 * 'diameter' ^ 3.0 * 'rho' / ('length' * 'mu' ^ 2.0);
    'Re' := 'lambda2' / 64.0 "Hagen-Poiseuille";
    'dRe_ddp' := 'aux1' / 64.0 "Hagen-Poiseuille";

    if 'Re' > 'Re1' then
      'Re' := -2.0 * sqrt('lambda2') * log10(2.51 / sqrt('lambda2') + 0.27 * 'Delta') "Colebrook-White";
      'aux2' := sqrt('aux1' * abs('dp_fric'));
      'dRe_ddp' := 0.43429448190325176 * (5.02 / (2.0 * abs('dp_fric') * (2.51 / 'aux2' + 0.27 * 'Delta')) - 2.0 * log(2.51 / 'aux2' + 0.27 * 'Delta') * 'aux1' / (2.0 * 'aux2'));

      if 'Re' < 'Re2' then
        ('Re', 'dRe_ddp') := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative'('lambda2', 'Re1', 'Re2', 'Delta', 'dp_fric');
      end if;
    end if;

    'm_flow' := 'crossArea' / 'diameter' * 'mu' * (if 'dp_fric' >= 0.0 then 'Re' else -'Re');
    'dm_flow_ddp_fric' := 'crossArea' / 'diameter' * 'mu' * 'dRe_ddp';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative' "Interpolation in log-log space using a cubic Hermite polynomial, where x=log10(lambda2), y=log10(Re)"
    input Real 'lambda2';
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta'(min = 0.0);
    input Real 'dp_fric'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    output Real 'dRe_ddp';
    Real 'x1' = log10(64.0 * 'Re1');
    Real 'y1' = log10('Re1');
    Real 'y1d' = 1.0;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x' = log10('lambda2');
    Real 'y';
    Real 'dy_dx';
    Real 'aux3' = log10('aux2');
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'x2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'y2' = log10('aux5');
    Real 'y2d' = 0.5 + 1.0900791495771618 / ('aux5' * 'aux4');
  algorithm
    ('y', 'dy_dx') := 'Modelica.Fluid.Utilities.cubicHermite_withDerivative'('x', 'x1', 'x2', 'y1', 'y2', 'y1d', 'y2d');
    'Re' := 10.0 ^ 'y';
    'dRe_ddp' := 'Re' / abs('dp_fric') * 'dy_dx';
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.Internal.m_flow_of_dp_fric.interpolateInRegion2_withDerivative';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2' "Cubic Hermite spline interpolation in transition region"
    input Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re1'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Re2'(unit = "1", quantity = "ReynoldsNumber");
    input Real 'Delta';
    output Real 'lambda2';
    Real 'x1' = log10('Re1');
    Real 'y1' = log10(64.0 * 'Re1');
    Real 'yd1' = 1.0;
    Real 'aux1' = 1.1217826467560994;
    Real 'aux2' = 'Delta' / 3.7 + 5.74 / 'Re2' ^ 0.9;
    Real 'x2' = log10('Re2');
    Real 'dx' = log10('Re' / 'Re1');
    Real 'aux3' = log10('aux2');
    Real 'diff_x' = 'x2' - 'x1';
    Real 'L2' = 0.25 * ('Re2' / 'aux3') ^ 2.0;
    Real 'yd2' = 2.0 + 4.0 * 'aux1' / ('aux2' * 'aux3' * 'Re2' ^ 0.9);
    Real 'aux4' = 2.51 / sqrt('L2') + 0.27 * 'Delta';
    Real 'y2' = log10('L2');
    Real 'aux5' = -2.0 * sqrt('L2') * log10('aux4');
    Real 'm' = ('y2' - 'y1') / 'diff_x';
    Real 'c2' = (3.0 * 'm' - 2.0 * 'yd1' - 'yd2') / 'diff_x';
    Real 'c3' = ('yd1' + 'yd2' - 2.0 * 'm') / ('diff_x' * 'diff_x');
  algorithm
    'lambda2' := 64.0 * 'Re1' * ('Re' / 'Re1') ^ ('yd1' + 'dx' * ('c2' + 'dx' * 'c3'));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.flowModel.WallFriction.pressureLoss_m_flow.interpolateInRegion2';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.heatTransfer.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'ductOut.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductOut.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.T_phX' "Return temperature as a function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.T_phX.f_nonlinear'(p = 'p', h = 'h', X = 'X'[1:1]), 190.0, 647.0, 2.220446049250313e-14);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.T_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.enthalpyOfWater' "Computes specific enthalpy of water (solid/liquid) near atmospheric pressure from temperature T"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.enthalpyOfWater_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.enthalpyOfWater';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.enthalpyOfWater_der' "Derivative function of enthalpyOfWater"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT'(unit = "K/s");
    output Real 'dh'(unit = "J/(kg.s)");
  algorithm
    'dh' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction_der'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1, 4200.0 * 'dT', 2050.0 * 'dT', 'dT', 0.0);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.enthalpyOfWater_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.h_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.h_pTX_der' "Derivative function of h_pTX"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real 'dp'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    input Real 'dT'(unit = "K/s", quantity = "TemperatureSlope");
    input Real[:] 'dX'(each unit = "1/s");
    output Real 'h_der'(unit = "J/(kg.s)");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'x_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'dX_steam'(unit = "1/s");
    Real 'dX_air'(unit = "1/s");
    Real 'dX_liq'(unit = "1/s");
    Real 'dps'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dx_sat'(unit = "1/s");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressure'('T');
    'x_sat' := 'p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat');
    'X_sat' := min('x_sat' * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.smoothMax'('X'[1] - 'X_sat', 0.0, 1e-5);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'dX_air' := -'dX'[1];
    'dps' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressure_der'('T', 'dT');
    'dx_sat' := 0.6219647130774989 * ('dps' * ('p' - 'p_steam_sat') - 'p_steam_sat' * ('dp' - 'dps')) / ('p' - 'p_steam_sat') / ('p' - 'p_steam_sat');
    'dX_liq' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.smoothMax_der'('X'[1] - 'X_sat', 0.0, 1e-5, (1.0 + 'x_sat') * 'dX'[1] - (1.0 - 'X'[1]) * 'dx_sat', 0.0, 0.0);
    'dX_steam' := 'dX'[1] - 'dX_liq';
    'h_der' := 'X_steam' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T')) + 'dX_steam' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) + 'X_air' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T')) + 'dX_air' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) + 'X_liquid' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.enthalpyOfWater_der'('T', 'dT') + 'dX_liq' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.enthalpyOfWater'('T');
    annotation(Inline = false, smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.h_pTX_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressure' "Return saturation pressure of water as a function of temperature T between 190 and 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'psat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressure_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressureLiquid';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressureLiquid_der' "Derivative function for 'saturationPressureLiquid'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
    Real 'r1_der' = -1.0 / 'Tcritical' * 'dTsat';
    Real 'r2' = 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6];
  algorithm
    'psat_der' := exp('r2' * 'Tcritical' / 'Tsat') * 'pcritical' * (('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der') + 'a'[3] * ('r1' ^ ('n'[3] - 1.0) * 'n'[3] * 'r1_der') + 'a'[4] * ('r1' ^ ('n'[4] - 1.0) * 'n'[4] * 'r1_der') + 'a'[5] * ('r1' ^ ('n'[5] - 1.0) * 'n'[5] * 'r1_der') + 'a'[6] * ('r1' ^ ('n'[6] - 1.0) * 'n'[6] * 'r1_der')) * 'Tcritical' / 'Tsat' - 'r2' * 'Tcritical' * 'dTsat' / 'Tsat' ^ 2.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressureLiquid_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressure_der' "Derivative function for 'saturationPressure'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
  algorithm
    'psat_der' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction_der'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0, 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressureLiquid_der'('Tsat', 'dTsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.sublimationPressureIce_der'('Tsat', 'dTsat'), 'dTsat', 0.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.saturationPressure_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'freshAir.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'freshAir.Medium.ThermodynamicState'('p', 'T', 'X') else 'freshAir.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'freshAir.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'freshAir.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.T_phX'('p', 'h', 'X'), 'X') else 'freshAir.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.specificEnthalpy' "Return specific enthalpy of moist air as a function of the thermodynamic state record"
    input 'freshAir.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.h_pTX'('state'.'p', 'state'.'T', 'state'.'X');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.specificEnthalpy'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.sublimationPressureIce' "Return sublimation pressure of water as a function of temperature T between 190 and 273.16 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
  algorithm
    'psat' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.sublimationPressureIce_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.sublimationPressureIce';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.sublimationPressureIce_der' "Derivative function for 'sublimationPressureIce'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
    Real 'r1_der' = 'dTsat' / 'Ttriple';
  algorithm
    'psat_der' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple' * (-('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der')));
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.sublimationPressureIce_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'freshAir.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.temperature';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.temperature'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.T_phX.f_nonlinear' "Solve h_pTX(p,T,X) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.h_pTX'('p', 'u', 'X') - 'h';
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.T_phX.f_nonlinear';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.smoothMax'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    output Real 'y';
  algorithm
    'y' := max('x1', 'x2') + log(exp(4.0 / 'dx' * ('x1' - max('x1', 'x2'))) + exp(4.0 / 'dx' * ('x2' - max('x1', 'x2')))) / (4.0 / 'dx');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.smoothMax';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.smoothMax_der'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    input Real 'dx1';
    input Real 'dx2';
    input Real 'ddx';
    output Real 'dy';
  algorithm
    'dy' := (if 'x1' > 'x2' then 'dx1' else 'dx2') + 0.25 * (((4.0 * ('dx1' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x1' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + (4.0 * ('dx2' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x2' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'dx' / (exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) + log(exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'ddx');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.smoothMax_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction_der' "Derivative of spliceFunction"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    input Real 'dpos';
    input Real 'dneg';
    input Real 'dx';
    input Real 'ddeltax' = 0.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'dscaledX1';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'dpos' * 'y' + (1.0 - 'y') * 'dneg';

    if abs('scaledX1') < 'lim' then
      'dscaledX1' := ('dx' - 'scaledX1' * 'ddeltax') / 'deltax';
      'out' := 'out' + ('pos' - 'neg') * 'dscaledX1' * 0.25 * 3.141592653589793 * (1.0 - tanh('scaledXt') ^ 2.0) * ('scaledXt' ^ 2.0 + 1.0);
    end if;
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.freshAir.Medium.Utilities.spliceFunction_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.T_phX' "Return temperature as a function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.T_phX.f_nonlinear'(p = 'p', h = 'h', X = 'X'[1:1]), 190.0, 647.0, 2.220446049250313e-14);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.T_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.enthalpyOfWater' "Computes specific enthalpy of water (solid/liquid) near atmospheric pressure from temperature T"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.enthalpyOfWater_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.enthalpyOfWater';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.enthalpyOfWater_der' "Derivative function of enthalpyOfWater"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT'(unit = "K/s");
    output Real 'dh'(unit = "J/(kg.s)");
  algorithm
    'dh' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction_der'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1, 4200.0 * 'dT', 2050.0 * 'dT', 'dT', 0.0);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.enthalpyOfWater_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.h_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.h_pTX_der' "Derivative function of h_pTX"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real 'dp'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    input Real 'dT'(unit = "K/s", quantity = "TemperatureSlope");
    input Real[:] 'dX'(each unit = "1/s");
    output Real 'h_der'(unit = "J/(kg.s)");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'x_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'dX_steam'(unit = "1/s");
    Real 'dX_air'(unit = "1/s");
    Real 'dX_liq'(unit = "1/s");
    Real 'dps'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dx_sat'(unit = "1/s");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressure'('T');
    'x_sat' := 'p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat');
    'X_sat' := min('x_sat' * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.smoothMax'('X'[1] - 'X_sat', 0.0, 1e-5);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'dX_air' := -'dX'[1];
    'dps' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressure_der'('T', 'dT');
    'dx_sat' := 0.6219647130774989 * ('dps' * ('p' - 'p_steam_sat') - 'p_steam_sat' * ('dp' - 'dps')) / ('p' - 'p_steam_sat') / ('p' - 'p_steam_sat');
    'dX_liq' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.smoothMax_der'('X'[1] - 'X_sat', 0.0, 1e-5, (1.0 + 'x_sat') * 'dX'[1] - (1.0 - 'X'[1]) * 'dx_sat', 0.0, 0.0);
    'dX_steam' := 'dX'[1] - 'dX_liq';
    'h_der' := 'X_steam' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T')) + 'dX_steam' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) + 'X_air' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T')) + 'dX_air' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) + 'X_liquid' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.enthalpyOfWater_der'('T', 'dT') + 'dX_liq' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.enthalpyOfWater'('T');
    annotation(Inline = false, smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.h_pTX_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressure' "Return saturation pressure of water as a function of temperature T between 190 and 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'psat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressure_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressureLiquid';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressureLiquid_der' "Derivative function for 'saturationPressureLiquid'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
    Real 'r1_der' = -1.0 / 'Tcritical' * 'dTsat';
    Real 'r2' = 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6];
  algorithm
    'psat_der' := exp('r2' * 'Tcritical' / 'Tsat') * 'pcritical' * (('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der') + 'a'[3] * ('r1' ^ ('n'[3] - 1.0) * 'n'[3] * 'r1_der') + 'a'[4] * ('r1' ^ ('n'[4] - 1.0) * 'n'[4] * 'r1_der') + 'a'[5] * ('r1' ^ ('n'[5] - 1.0) * 'n'[5] * 'r1_der') + 'a'[6] * ('r1' ^ ('n'[6] - 1.0) * 'n'[6] * 'r1_der')) * 'Tcritical' / 'Tsat' - 'r2' * 'Tcritical' * 'dTsat' / 'Tsat' ^ 2.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressureLiquid_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressure_der' "Derivative function for 'saturationPressure'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
  algorithm
    'psat_der' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction_der'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0, 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressureLiquid_der'('Tsat', 'dTsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.sublimationPressureIce_der'('Tsat', 'dTsat'), 'dTsat', 0.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.saturationPressure_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'peopleSource.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'peopleSource.Medium.ThermodynamicState'('p', 'T', 'X') else 'peopleSource.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'peopleSource.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'peopleSource.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.T_phX'('p', 'h', 'X'), 'X') else 'peopleSource.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.specificEnthalpy' "Return specific enthalpy of moist air as a function of the thermodynamic state record"
    input 'peopleSource.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.h_pTX'('state'.'p', 'state'.'T', 'state'.'X');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.specificEnthalpy'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.sublimationPressureIce' "Return sublimation pressure of water as a function of temperature T between 190 and 273.16 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
  algorithm
    'psat' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.sublimationPressureIce_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.sublimationPressureIce';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.sublimationPressureIce_der' "Derivative function for 'sublimationPressureIce'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
    Real 'r1_der' = 'dTsat' / 'Ttriple';
  algorithm
    'psat_der' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple' * (-('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der')));
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.sublimationPressureIce_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'peopleSource.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.temperature';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.temperature'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.T_phX.f_nonlinear' "Solve h_pTX(p,T,X) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.h_pTX'('p', 'u', 'X') - 'h';
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.T_phX.f_nonlinear';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.smoothMax'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    output Real 'y';
  algorithm
    'y' := max('x1', 'x2') + log(exp(4.0 / 'dx' * ('x1' - max('x1', 'x2'))) + exp(4.0 / 'dx' * ('x2' - max('x1', 'x2')))) / (4.0 / 'dx');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.smoothMax';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.smoothMax_der'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    input Real 'dx1';
    input Real 'dx2';
    input Real 'ddx';
    output Real 'dy';
  algorithm
    'dy' := (if 'x1' > 'x2' then 'dx1' else 'dx2') + 0.25 * (((4.0 * ('dx1' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x1' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + (4.0 * ('dx2' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x2' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'dx' / (exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) + log(exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'ddx');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.smoothMax_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction_der' "Derivative of spliceFunction"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    input Real 'dpos';
    input Real 'dneg';
    input Real 'dx';
    input Real 'ddeltax' = 0.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'dscaledX1';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'dpos' * 'y' + (1.0 - 'y') * 'dneg';

    if abs('scaledX1') < 'lim' then
      'dscaledX1' := ('dx' - 'scaledX1' * 'ddeltax') / 'deltax';
      'out' := 'out' + ('pos' - 'neg') * 'dscaledX1' * 0.25 * 3.141592653589793 * (1.0 - tanh('scaledXt') ^ 2.0) * ('scaledXt' ^ 2.0 + 1.0);
    end if;
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.peopleSource.Medium.Utilities.spliceFunction_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.T_phX' "Return temperature as a function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Math.Nonlinear.solveOneNonlinearEquation'(function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.T_phX.f_nonlinear'(p = 'p', h = 'h', X = 'X'[1:1]), 190.0, 647.0, 2.220446049250313e-14);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.T_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.density' "Returns density of ideal gas as a function of the thermodynamic state record"
    input 'volume.Medium.ThermodynamicState' 'state';
    output Real 'd'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
  algorithm
    'd' := 'state'.'p' / ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.gasConstant'('state') * 'state'.'T');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.density';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.enthalpyOfWater' "Computes specific enthalpy of water (solid/liquid) near atmospheric pressure from temperature T"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.enthalpyOfWater_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.enthalpyOfWater';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.enthalpyOfWater_der' "Derivative function of enthalpyOfWater"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT'(unit = "K/s");
    output Real 'dh'(unit = "J/(kg.s)");
  algorithm
    'dh' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction_der'(4200.0 * ('T' - 273.15), 2050.0 * ('T' - 273.15) - 333000.0, 'T' - 273.16, 0.1, 4200.0 * 'dT', 2050.0 * 'dT', 'dT', 0.0);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.enthalpyOfWater_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.gasConstant' "Return ideal gas constant as a function from thermodynamic state, only valid for phi<1"
    input 'volume.Medium.ThermodynamicState' 'state';
    output Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'R_s' := 287.0525368759184 * (1.0 - 'state'.'X'[1]) + 461.5254384056201 * 'state'.'X'[1];
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.gasConstant';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.h_pTX' "Return specific enthalpy of moist air as a function of pressure p, temperature T and composition X"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressure'('T');
    'X_sat' := min('p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat') * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := max('X'[1] - 'X_sat', 0.0);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'h' := 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) * 'X_steam' + 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) * 'X_air' + 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.enthalpyOfWater'('T') * 'X_liquid';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.h_pTX_der', Inline = false);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.h_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.h_pTX_der' "Derivative function of h_pTX"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("1", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    input Real 'dp'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    input Real 'dT'(unit = "K/s", quantity = "TemperatureSlope");
    input Real[:] 'dX'(each unit = "1/s");
    output Real 'h_der'(unit = "J/(kg.s)");
    Real 'p_steam_sat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'X_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_liquid'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_steam'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'X_air'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'x_sat'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction");
    Real 'dX_steam'(unit = "1/s");
    Real 'dX_air'(unit = "1/s");
    Real 'dX_liq'(unit = "1/s");
    Real 'dps'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'dx_sat'(unit = "1/s");
  algorithm
    'p_steam_sat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressure'('T');
    'x_sat' := 'p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'p' - 'p_steam_sat');
    'X_sat' := min('x_sat' * (1.0 - 'X'[1]), 1.0);
    'X_liquid' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.smoothMax'('X'[1] - 'X_sat', 0.0, 1e-5);
    'X_steam' := 'X'[1] - 'X_liquid';
    'X_air' := 1.0 - 'X'[1];
    'dX_air' := -'dX'[1];
    'dps' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressure_der'('T', 'dT');
    'dx_sat' := 0.6219647130774989 * ('dps' * ('p' - 'p_steam_sat') - 'p_steam_sat' * ('dp' - 'dps')) / ('p' - 'p_steam_sat') / ('p' - 'p_steam_sat');
    'dX_liq' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.smoothMax_der'('X'[1] - 'X_sat', 0.0, 1e-5, (1.0 + 'x_sat') * 'dX'[1] - (1.0 - 'X'[1]) * 'dx_sat', 0.0, 0.0);
    'dX_steam' := 'dX'[1] - 'dX_liq';
    'h_der' := 'X_steam' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T')) + 'dX_steam' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("H2O", 0.01801528, -1.342338281725291e7, 549760.6476280135, 1000.0, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {-33039.7431, 17.24205775}, {1.034972096e6, -2412.698562, 4.64611078, 0.002291998307, -6.836830479999999e-7, 9.426468930000001e-11, -4.82238053e-15}, {-13842.86509, -7.97814851}, 461.5254384056201), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 2.547494319e6) + 'X_air' * ('dT' * 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T')) + 'dX_air' * 'Modelica.Media.IdealGases.Common.Functions.h_Tlow'('Modelica.Media.IdealGases.Common.DataRecord'("Air", 0.0289651159, -4333.833858403446, 298609.6803431054, 1000.0, {10099.5016, -196.827561, 5.00915511, -0.00576101373, 1.06685993e-5, -7.94029797e-9, 2.18523191e-12}, {-176.796731, -3.921504225}, {241521.443, -1257.8746, 5.14455867, -2.13854179e-4, 7.06522784e-8, -1.07148349e-11, 6.57780015e-16}, {6462.26319, -8.147411905}, 287.0525368759184), 'T', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined', 25104.684) + 'X_liquid' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.enthalpyOfWater_der'('T', 'dT') + 'dX_liq' * 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.enthalpyOfWater'('T');
    annotation(Inline = false, smoothOrder = 1);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.h_pTX_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressure' "Return saturation pressure of water as a function of temperature T between 190 and 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'psat' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0);
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressure_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressure';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressureLiquid' "Return saturation pressure of water as a function of temperature T in the range of 273.16 to 647.096 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
  algorithm
    'psat' := exp(('a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6]) * 'Tcritical' / 'Tsat') * 'pcritical';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressureLiquid_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressureLiquid';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressureLiquid_der' "Derivative function for 'saturationPressureLiquid'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Tcritical'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 647.096;
    Real 'pcritical'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2.2064e7;
    Real[:] 'a' = {-7.85951783, 1.84408259, -11.7866497, 22.6807411, -15.9618719, 1.80122502};
    Real[:] 'n' = {1.0, 1.5, 3.0, 3.5, 4.0, 7.5};
    Real 'r1' = 1.0 - 'Tsat' / 'Tcritical';
    Real 'r1_der' = -1.0 / 'Tcritical' * 'dTsat';
    Real 'r2' = 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] * 'r1' ^ 'n'[2] + 'a'[3] * 'r1' ^ 'n'[3] + 'a'[4] * 'r1' ^ 'n'[4] + 'a'[5] * 'r1' ^ 'n'[5] + 'a'[6] * 'r1' ^ 'n'[6];
  algorithm
    'psat_der' := exp('r2' * 'Tcritical' / 'Tsat') * 'pcritical' * (('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der') + 'a'[3] * ('r1' ^ ('n'[3] - 1.0) * 'n'[3] * 'r1_der') + 'a'[4] * ('r1' ^ ('n'[4] - 1.0) * 'n'[4] * 'r1_der') + 'a'[5] * ('r1' ^ ('n'[5] - 1.0) * 'n'[5] * 'r1_der') + 'a'[6] * ('r1' ^ ('n'[6] - 1.0) * 'n'[6] * 'r1_der')) * 'Tcritical' / 'Tsat' - 'r2' * 'Tcritical' * 'dTsat' / 'Tsat' ^ 2.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressureLiquid_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressure_der' "Derivative function for 'saturationPressure'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
  algorithm
    'psat_der' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction_der'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressureLiquid'('Tsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.sublimationPressureIce'('Tsat'), 'Tsat' - 273.16, 1.0, 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressureLiquid_der'('Tsat', 'dTsat'), 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.sublimationPressureIce_der'('Tsat', 'dTsat'), 'dTsat', 0.0);
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.saturationPressure_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.setState_pTX' "Return thermodynamic state as function of pressure p, temperature T and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'volume.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'volume.Medium.ThermodynamicState'('p', 'T', 'X') else 'volume.Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.setState_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.setState_phX' "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output 'volume.Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 2 then 'volume.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.T_phX'('p', 'h', 'X'), 'X') else 'volume.Medium.ThermodynamicState'('p', 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.T_phX'('p', 'h', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.setState_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.specificEnthalpy' "Return specific enthalpy of moist air as a function of the thermodynamic state record"
    input 'volume.Medium.ThermodynamicState' 'state';
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.h_pTX'('state'.'p', 'state'.'T', 'state'.'X');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.specificEnthalpy';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.specificEnthalpy_pTX' "Return specific enthalpy from p, T, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.specificEnthalpy'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.setState_pTX'('p', 'T', 'X'));
    annotation(inverse(T = Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.temperature_phX('p', 'h', 'X')));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.specificEnthalpy_pTX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.sublimationPressureIce' "Return sublimation pressure of water as a function of temperature T between 190 and 273.16 K"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'psat'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
  algorithm
    'psat' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.sublimationPressureIce_der', Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.sublimationPressureIce';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.sublimationPressureIce_der' "Derivative function for 'sublimationPressureIce'"
    input Real 'Tsat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dTsat'(unit = "K/s", quantity = "TemperatureSlope");
    output Real 'psat_der'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    Real 'Ttriple'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.16;
    Real 'ptriple'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 611.657;
    Real[:] 'a' = {-13.928169, 34.7078238};
    Real[:] 'n' = {-1.5, -1.25};
    Real 'r1' = 'Tsat' / 'Ttriple';
    Real 'r1_der' = 'dTsat' / 'Ttriple';
  algorithm
    'psat_der' := exp('a'[1] - 'a'[1] * 'r1' ^ 'n'[1] + 'a'[2] - 'a'[2] * 'r1' ^ 'n'[2]) * 'ptriple' * (-('a'[1] * ('r1' ^ ('n'[1] - 1.0) * 'n'[1] * 'r1_der') + 'a'[2] * ('r1' ^ ('n'[2] - 1.0) * 'n'[2] * 'r1_der')));
    annotation(Inline = false, smoothOrder = 5);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.sublimationPressureIce_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'volume.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.temperature';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.temperature_phX' "Return temperature from p, h, and X or Xi"
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.01, 0.99};
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.temperature'('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.setState_phX'('p', 'h', 'X'));
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.temperature_phX';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.T_phX.f_nonlinear' "Solve h_pTX(p,T,X) for T with given h"
    input Real 'u';
    input Real 'p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1)));
    output Real 'y';
  algorithm
    'y' := 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.h_pTX'('p', 'u', 'X') - 'h';
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.T_phX.f_nonlinear';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.smoothMax'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    output Real 'y';
  algorithm
    'y' := max('x1', 'x2') + log(exp(4.0 / 'dx' * ('x1' - max('x1', 'x2'))) + exp(4.0 / 'dx' * ('x2' - max('x1', 'x2')))) / (4.0 / 'dx');
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.smoothMax';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.smoothMax_der'
    input Real 'x1';
    input Real 'x2';
    input Real 'dx';
    input Real 'dx1';
    input Real 'dx2';
    input Real 'ddx';
    output Real 'dy';
  algorithm
    'dy' := (if 'x1' > 'x2' then 'dx1' else 'dx2') + 0.25 * (((4.0 * ('dx1' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x1' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + (4.0 * ('dx2' - (if 'x1' > 'x2' then 'dx1' else 'dx2')) / 'dx' - 4.0 * ('x2' - max('x1', 'x2')) * 'ddx' / 'dx' ^ 2.0) * exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'dx' / (exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) + log(exp(4.0 * ('x1' - max('x1', 'x2')) / 'dx') + exp(4.0 * ('x2' - max('x1', 'x2')) / 'dx')) * 'ddx');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.smoothMax_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction' "Spline interpolation of two functions"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'pos' * 'y' + (1.0 - 'y') * 'neg';
    annotation(derivative(order = 1) = 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction_der');
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction_der' "Derivative of spliceFunction"
    input Real 'pos';
    input Real 'neg';
    input Real 'x';
    input Real 'deltax' = 1.0;
    input Real 'dpos';
    input Real 'dneg';
    input Real 'dx';
    input Real 'ddeltax' = 0.0;
    output Real 'out';
    constant Real 'lim' = 0.9999999999;
    Real 'scaledX1';
    Real 'scaledXp';
    Real 'scaledXt';
    Real 'dscaledX1';
    Real 'y';
  algorithm
    'scaledX1' := 'x' / 'deltax';

    if 'scaledX1' <= (-'lim') then
      'y' := 0.0;
    elseif 'scaledX1' >= 'lim' then
      'y' := 1.0;
    elseif true then
      'scaledXp' := 'scaledX1' * 0.5 * 3.141592653589793;
      'scaledXt' := tan('scaledXp');
      'y' := 0.5 * tanh('scaledXt') + 0.5;
    end if;

    'out' := 'dpos' * 'y' + (1.0 - 'y') * 'dneg';

    if abs('scaledX1') < 'lim' then
      'dscaledX1' := ('dx' - 'scaledX1' * 'ddeltax') / 'deltax';
      'out' := 'out' + ('pos' - 'neg') * 'dscaledX1' * 0.25 * 3.141592653589793 * (1.0 - tanh('scaledXt') ^ 2.0) * ('scaledXt' ^ 2.0 + 1.0);
    end if;
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.Medium.Utilities.spliceFunction_der';

  function 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.heatTransfer.Medium.temperature' "Return temperature of ideal gas as a function of the thermodynamic state record"
    input 'volume.heatTransfer.Medium.ThermodynamicState' 'state';
    output Real 'T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'T' := 'state'.'T';
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.volume.heatTransfer.Medium.temperature';

  function 'Modelica.Fluid.Pipes.BaseClasses.CharacteristicNumbers.ReynoldsNumber' "Return Reynolds number from v, rho, mu, D"
    input Real 'v'(unit = "m/s", quantity = "Velocity");
    input Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    input Real 'mu'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    input Real 'D'(unit = "m", quantity = "Length");
    output Real 'Re'(unit = "1", quantity = "ReynoldsNumber");
  algorithm
    'Re' := abs('v') * 'rho' * 'D' / 'mu';
  end 'Modelica.Fluid.Pipes.BaseClasses.CharacteristicNumbers.ReynoldsNumber';

  function 'Modelica.Fluid.Utilities.checkBoundary' "Check whether boundary definition is correct"
    input String 'mediumName';
    input String[:] 'substanceNames';
    input Boolean 'singleState';
    input Boolean 'define_p';
    input Real[:] 'X_boundary';
    input String 'modelName' = "??? boundary ???";
    Integer 'nX' = size('X_boundary', 1);
    String 'X_str';
  algorithm
    assert(not 'singleState' or 'singleState' and 'define_p', "\nWrong value of parameter define_p (= false) in model \"" + 'modelName' + "\":\nThe selected medium \"" + 'mediumName' + "\" has Medium.singleState=true.\nTherefore, an boundary density cannot be defined and\ndefine_p = true is required.\n", AssertionLevel.error);

    for 'i' in 1:'nX' loop
      assert('X_boundary'['i'] >= 0.0, "\nWrong boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\":\nThe boundary value X_boundary(" + String('i') + ") = " + String('X_boundary'['i']) + "\nis negative. It must be positive.\n", AssertionLevel.error);
    end for;

    if 'nX' > 0 and abs(sum('X_boundary') - 1.0) > 1e-10 then
      'X_str' := "";

      for 'i' in 1:'nX' loop
        'X_str' := 'X_str' + "   X_boundary[" + String('i') + "] = " + String('X_boundary'['i']) + " \"" + 'substanceNames'['i'] + "\"\n";
      end for;

      'Modelica.Utilities.Streams.error'("The boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\"\n" + "do not sum up to 1. Instead, sum(X_boundary) = " + String(sum('X_boundary')) + ":\n" + 'X_str');
    end if;
  end 'Modelica.Fluid.Utilities.checkBoundary';

  function 'Modelica.Fluid.Utilities.cubicHermite_withDerivative' "Evaluate a cubic Hermite spline, return value and derivative"
    input Real 'x';
    input Real 'x1';
    input Real 'x2';
    input Real 'y1';
    input Real 'y2';
    input Real 'y1d';
    input Real 'y2d';
    output Real 'y';
    output Real 'dy_dx';
    Real 'h';
    Real 't';
    Real 'h00';
    Real 'h10';
    Real 'h01';
    Real 'h11';
    Real 'h00d';
    Real 'h10d';
    Real 'h01d';
    Real 'h11d';
    Real 'aux3';
    Real 'aux2';
  algorithm
    'h' := 'x2' - 'x1';

    if abs('h') > 0.0 then
      't' := ('x' - 'x1') / 'h';
      'aux3' := 't' ^ 3.0;
      'aux2' := 't' ^ 2.0;
      'h00' := 2.0 * 'aux3' - 3.0 * 'aux2' + 1.0;
      'h10' := 'aux3' - 2.0 * 'aux2' + 't';
      'h01' := 3.0 * 'aux2' - 2.0 * 'aux3';
      'h11' := 'aux3' - 'aux2';
      'h00d' := 6.0 * ('aux2' - 't');
      'h10d' := 3.0 * 'aux2' - 4.0 * 't' + 1.0;
      'h01d' := 6.0 * ('t' - 'aux2');
      'h11d' := 3.0 * 'aux2' - 2.0 * 't';
      'y' := 'y1' * 'h00' + 'h' * 'y1d' * 'h10' + 'y2' * 'h01' + 'h' * 'y2d' * 'h11';
      'dy_dx' := 'y1' * 'h00d' / 'h' + 'y1d' * 'h10d' + 'y2' * 'h01d' / 'h' + 'y2d' * 'h11d';
    elseif true then
      'y' := ('y1' + 'y2') / 2.0;
      'dy_dx' := sign('y2' - 'y1') * 1e60;
    end if;
    annotation(smoothOrder = 3);
  end 'Modelica.Fluid.Utilities.cubicHermite_withDerivative';

  function 'Modelica.Fluid.Utilities.regFun3' "Co-monotonic and C1 smooth regularization function"
    input Real 'x';
    input Real 'x0';
    input Real 'x1';
    input Real 'y0';
    input Real 'y1';
    input Real 'y0d';
    input Real 'y1d';
    output Real 'y';
    output Real 'c';
    Real 'h0';
    Real 'Delta0';
    Real 'xstar';
    Real 'mu';
    Real 'eta';
    Real 'omega';
    Real 'rho';
    Real 'theta0';
    Real 'mu_tilde';
    Real 'eta_tilde';
    Real 'xi1';
    Real 'xi2';
    Real 'a1';
    Real 'a2';
    Real 'const12';
    Real 'const3';
    Real 'aux01';
    Real 'aux02';
    Boolean 'useSingleCubicPolynomial' = false;
  algorithm
    assert('x0' < 'x1', "regFun3(): Data points not sorted appropriately (x0 = " + String('x0') + " > x1 = " + String('x1') + "). Please flip arguments.", AssertionLevel.error);

    if 'y0d' * 'y1d' >= 0.0 then
    elseif true then
      assert(abs('y0d') < 2.220446049250313e-16 or abs('y1d') < 2.220446049250313e-16, "regFun3(): Derivatives at data points do not allow co-monotone interpolation, as both are non-zero, of opposite sign and have an absolute value larger than machine eps (y0d = " + String('y0d') + ", y1d = " + String('y1d') + "). Please correct arguments.", AssertionLevel.error);
    end if;

    'h0' := 'x1' - 'x0';
    'Delta0' := ('y1' - 'y0') / 'h0';

    if abs('Delta0') <= 0.0 then
      'y' := 'y0' + 'Delta0' * ('x' - 'x0');
      'c' := 0.0;
    elseif abs('y1d' + 'y0d' - 2.0 * 'Delta0') < 2.220446049250313e-14 then
      'y' := 'y0' + ('x' - 'x0') * ('y0d' + ('x' - 'x0') / 'h0' * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d') + ('x' - 'x0') * ('y0d' + 'y1d' - 2.0 * 'Delta0') / 'h0'));
      'aux01' := ('x0' + 'x1') / 2.0;
      'c' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('aux01' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('aux01' - 'x0') / 'h0' + 'y0d';
    elseif true then
      'xstar' := 0.3333333333333333 * (6.0 * 'x0' * 'Delta0' - (3.0 * 'x0' * 'y0d' + 3.0 * 'x0' * 'y1d') - 2.0 * 'h0' * 'y0d' - 'h0' * 'y1d' + 3.0 * 'h0' * 'Delta0') / (2.0 * 'Delta0' - ('y0d' + 'y1d'));
      'mu' := 'xstar' - 'x0';
      'eta' := 'x1' - 'xstar';
      'omega' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('xstar' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('xstar' - 'x0') / 'h0' + 'y0d';
      'aux01' := 0.25 * sign('Delta0') * min(abs('omega'), abs('Delta0')) "Slope c if not using plain cubic S0";

      if abs('y0d' - 'y1d') <= 2.220446049250313e-14 then
        'aux02' := 'y0d';

        if 'y1' > 'y0' + 'y0d' * ('x1' - 'x0') then
          'useSingleCubicPolynomial' := true;
        end if;
      elseif abs('y1d' + 'y0d' - 2.0 * 'Delta0') < 2.220446049250313e-14 then
        'aux02' := (6.0 * 'Delta0' * ('y1d' + 'y0d' - 1.5 * 'Delta0') - 'y1d' * 'y0d' - 'y1d' ^ 2.0 - 'y0d' ^ 2.0) * (if 'y1d' + 'y0d' - 2.0 * 'Delta0' >= 0.0 then 1.0 else -1.0) * 1e60;
      elseif true then
        'aux02' := (6.0 * 'Delta0' * ('y1d' + 'y0d' - 1.5 * 'Delta0') - 'y1d' * 'y0d' - 'y1d' ^ 2.0 - 'y0d' ^ 2.0) / (3.0 * ('y1d' + 'y0d' - 2.0 * 'Delta0'));
      end if;

      if ((('mu' > 0.0 and 'eta' < 'h0') and 'Delta0' * 'omega' <= 0.0 or abs('aux01') < abs('aux02') and 'aux02' * 'Delta0' >= 0.0) or abs('aux01') < abs(0.1 * 'Delta0')) and not 'useSingleCubicPolynomial' then
        'c' := 'aux01';

        if abs('c') < abs('aux02') and 'aux02' * 'Delta0' >= 0.0 then
          'c' := 'aux02';
        end if;

        if abs('c') < abs(0.1 * 'Delta0') then
          'c' := 0.1 * 'Delta0';
        end if;

        'theta0' := ('y0d' * 'mu' + 'y1d' * 'eta') / 'h0';

        if abs('theta0' - 'c') < 1e-6 * abs('c') then
          'c' := 0.999999 * 'theta0';
        end if;

        'rho' := 3.0 * ('Delta0' - 'c') / ('theta0' - 'c');
        'mu_tilde' := 'rho' * 'mu';
        'eta_tilde' := 'rho' * 'eta';
        'xi1' := 'x0' + 'mu_tilde';
        'xi2' := 'x1' - 'eta_tilde';
        'a1' := ('y0d' - 'c') / max('mu_tilde' ^ 2.0, 2.220446049250313e-14);
        'a2' := ('y1d' - 'c') / max('eta_tilde' ^ 2.0, 2.220446049250313e-14);
        'const12' := 'y0' - 'a1' / 3.0 * ('x0' - 'xi1') ^ 3.0 - 'c' * 'x0';
        'const3' := 'y1' - 'a2' / 3.0 * ('x1' - 'xi2') ^ 3.0 - 'c' * 'x1';

        if 'x' < 'xi1' then
          'y' := 'a1' / 3.0 * ('x' - 'xi1') ^ 3.0 + 'c' * 'x' + 'const12';
        elseif 'x' < 'xi2' then
          'y' := 'c' * 'x' + 'const12';
        elseif true then
          'y' := 'a2' / 3.0 * ('x' - 'xi2') ^ 3.0 + 'c' * 'x' + 'const3';
        end if;
      elseif true then
        'y' := 'y0' + ('x' - 'x0') * ('y0d' + ('x' - 'x0') / 'h0' * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d') + ('x' - 'x0') * ('y0d' + 'y1d' - 2.0 * 'Delta0') / 'h0'));
        'aux01' := ('x0' + 'x1') / 2.0;
        'c' := 3.0 * ('y0d' + 'y1d' - 2.0 * 'Delta0') * ('aux01' - 'x0') ^ 2.0 / 'h0' ^ 2.0 + 2.0 * (3.0 * 'Delta0' - (2.0 * 'y0d' + 'y1d')) * ('aux01' - 'x0') / 'h0' + 'y0d';
      end if;
    end if;
    annotation(smoothOrder = 1);
  end 'Modelica.Fluid.Utilities.regFun3';

  function 'Modelica.Math.Nonlinear.solveOneNonlinearEquation' "Solve f(u) = 0 in a very reliable and efficient way (f(u_min) and f(u_max) must have different signs)"
    input 'Modelica.Math.Nonlinear.Interfaces.partialScalarFunction' 'f';
    input Real 'u_min';
    input Real 'u_max';
    input Real 'tolerance' = 2.220446049250313e-14;
    output Real 'u';
    constant Real 'eps' = 2.220446049250313e-16;
    Real 'a' = 'u_min';
    Real 'b' = 'u_max';
    Real 'c';
    Real 'd';
    Real 'e';
    Real 'm';
    Real 's';
    Real 'p';
    Real 'q';
    Real 'r';
    Real 'tol';
    Real 'fa';
    Real 'fb';
    Real 'fc';
    Boolean 'found' = false;
  algorithm
    'fa' := 'f'('u_min');
    'fb' := 'f'('u_max');
    'fc' := 'fb';

    if 'fa' > 0.0 and 'fb' > 0.0 or 'fa' < 0.0 and 'fb' < 0.0 then
      'Modelica.Utilities.Streams.error'("The arguments u_min and u_max provided in the function call\n    solveOneNonlinearEquation(f,u_min,u_max)\ndo not bracket the root of the single non-linear equation 0=f(u):\n  u_min  = " + String('u_min') + "\n" + "  u_max  = " + String('u_max') + "\n" + "  fa = f(u_min) = " + String('fa') + "\n" + "  fb = f(u_max) = " + String('fb') + "\n" + "fa and fb must have opposite sign which is not the case");
    end if;

    'c' := 'a';
    'fc' := 'fa';
    'e' := 'b' - 'a';
    'd' := 'e';

    while not 'found' loop
      if abs('fc') < abs('fb') then
        'a' := 'b';
        'b' := 'c';
        'c' := 'a';
        'fa' := 'fb';
        'fb' := 'fc';
        'fc' := 'fa';
      end if;

      'tol' := 2.0 * 'eps' * abs('b') + 'tolerance';
      'm' := ('c' - 'b') / 2.0;

      if abs('m') <= 'tol' or 'fb' == 0.0 then
        'found' := true;
        'u' := 'b';
      elseif true then
        if abs('e') < 'tol' or abs('fa') <= abs('fb') then
          'e' := 'm';
          'd' := 'e';
        elseif true then
          's' := 'fb' / 'fa';

          if 'a' == 'c' then
            'p' := 2.0 * 'm' * 's';
            'q' := 1.0 - 's';
          elseif true then
            'q' := 'fa' / 'fc';
            'r' := 'fb' / 'fc';
            'p' := 's' * (2.0 * 'm' * 'q' * ('q' - 'r') - ('b' - 'a') * ('r' - 1.0));
            'q' := ('q' - 1.0) * ('r' - 1.0) * ('s' - 1.0);
          end if;

          if 'p' > 0.0 then
            'q' := -'q';
          elseif true then
            'p' := -'p';
          end if;

          's' := 'e';
          'e' := 'd';

          if 2.0 * 'p' < 3.0 * 'm' * 'q' - abs('tol' * 'q') and 'p' < abs(0.5 * 's' * 'q') then
            'd' := 'p' / 'q';
          elseif true then
            'e' := 'm';
            'd' := 'e';
          end if;
        end if;

        'a' := 'b';
        'fa' := 'fb';
        'b' := 'b' + (if abs('d') > 'tol' then 'd' else if 'm' > 0.0 then 'tol' else -'tol');
        'fb' := 'f'('b');

        if 'fb' > 0.0 and 'fc' > 0.0 or 'fb' < 0.0 and 'fc' < 0.0 then
          'c' := 'a';
          'fc' := 'fa';
          'e' := 'b' - 'a';
          'd' := 'e';
        end if;
      end if;
    end while;
  end 'Modelica.Math.Nonlinear.solveOneNonlinearEquation';

  function 'Modelica.Math.Polynomials.evaluate' "Evaluate polynomial at a given abscissa value"
    input Real[:] 'p';
    input Real 'u';
    output Real 'y';
  algorithm
    'y' := 'p'[1];

    for 'j' in 2:size('p', 1) loop
      'y' := 'p'['j'] + 'u' * 'y';
    end for;
    annotation(derivative(order = 1, zeroDerivative = 'p') = 'Modelica.Math.Polynomials.evaluate_der');
  end 'Modelica.Math.Polynomials.evaluate';

  function 'Modelica.Math.Polynomials.evaluateWithRange' "Evaluate polynomial at a given abscissa value with linear extrapolation outside of the defined range"
    input Real[:] 'p';
    input Real 'uMin';
    input Real 'uMax';
    input Real 'u';
    output Real 'y';
  algorithm
    if 'u' < 'uMin' then
      'y' := 'Modelica.Math.Polynomials.evaluate'('p', 'uMin') - 'Modelica.Math.Polynomials.evaluate_der'('p', 'uMin', 'uMin' - 'u');
    elseif 'u' > 'uMax' then
      'y' := 'Modelica.Math.Polynomials.evaluate'('p', 'uMax') + 'Modelica.Math.Polynomials.evaluate_der'('p', 'uMax', 'u' - 'uMax');
    elseif true then
      'y' := 'Modelica.Math.Polynomials.evaluate'('p', 'u');
    end if;
    annotation(derivative(order = 1, zeroDerivative = 'p', zeroDerivative = 'uMin', zeroDerivative = 'uMax') = 'Modelica.Math.Polynomials.evaluateWithRange_der');
  end 'Modelica.Math.Polynomials.evaluateWithRange';

  function 'Modelica.Math.Polynomials.evaluateWithRange_der' "Evaluate derivative of polynomial at a given abscissa value with extrapolation outside of the defined range"
    input Real[:] 'p';
    input Real 'uMin';
    input Real 'uMax';
    input Real 'u';
    input Real 'du';
    output Real 'dy';
  algorithm
    if 'u' < 'uMin' then
      'dy' := 'Modelica.Math.Polynomials.evaluate_der'('p', 'uMin', 'du');
    elseif 'u' > 'uMax' then
      'dy' := 'Modelica.Math.Polynomials.evaluate_der'('p', 'uMax', 'du');
    elseif true then
      'dy' := 'Modelica.Math.Polynomials.evaluate_der'('p', 'u', 'du');
    end if;
  end 'Modelica.Math.Polynomials.evaluateWithRange_der';

  function 'Modelica.Math.Polynomials.evaluate_der' "Evaluate derivative of polynomial at a given abscissa value"
    input Real[:] 'p';
    input Real 'u';
    input Real 'du';
    output Real 'dy';
    Integer 'n' = size('p', 1);
  algorithm
    'dy' := 'p'[1] * ('n' - 1);

    for 'j' in 2:size('p', 1) - 1 loop
      'dy' := 'p'['j'] * ('n' - 'j') + 'u' * 'dy';
    end for;

    'dy' := 'dy' * 'du';
  end 'Modelica.Math.Polynomials.evaluate_der';

  function 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow' "Compute specific heat capacity at constant pressure, low T region"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
  algorithm
    'cp' := 'data'.'R_s' * (1.0 / ('T' * 'T') * ('data'.'alow'[1] + 'T' * ('data'.'alow'[2] + 'T' * ('data'.'alow'[3] + 'T' * ('data'.'alow'[4] + 'T' * ('data'.'alow'[5] + 'T' * ('data'.'alow'[6] + 'data'.'alow'[7] * 'T')))))));
    annotation(derivative(order = 1, zeroDerivative = 'data') = 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow_der', Inline = false);
  end 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow';

  function 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow_der' "Compute derivative of specific heat capacity at constant pressure, low T region"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'dT'(unit = "K/s");
    output Real 'cp_der'(unit = "J/(kg.K.s)");
  algorithm
    'cp_der' := 'dT' * 'data'.'R_s' / ('T' * 'T' * 'T') * ('T' * ('T' * 'T' * ('data'.'alow'[4] + 'T' * (2.0 * 'data'.'alow'[5] + 'T' * (3.0 * 'data'.'alow'[6] + 4.0 * 'data'.'alow'[7] * 'T'))) - 'data'.'alow'[2]) - 2.0 * 'data'.'alow'[1]);
    annotation(smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.cp_Tlow_der';

  function 'Modelica.Media.IdealGases.Common.Functions.h_Tlow' "Compute specific enthalpy, low T region; reference is decided by the
    refChoice input, or by the referenceChoice package constant by default"
    input 'Modelica.Media.IdealGases.Common.DataRecord' 'data';
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'exclEnthForm' = true;
    input 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' 'refChoice' = 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K';
    input Real 'h_off'(unit = "J/kg", quantity = "SpecificEnergy") = 0.0;
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'data'.'R_s' * (('T' * ('data'.'blow'[1] + 'data'.'alow'[2] * log('T') + 'T' * ('data'.'alow'[3] + 'T' * (0.5 * 'data'.'alow'[4] + 'T' * (0.3333333333333333 * 'data'.'alow'[5] + 'T' * (0.25 * 'data'.'alow'[6] + 0.2 * 'data'.'alow'[7] * 'T'))))) - 'data'.'alow'[1]) / 'T') + (if 'exclEnthForm' then -'data'.'Hf' else 0.0) + (if 'refChoice' == 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K' then 'data'.'H0' else 0.0) + (if 'refChoice' == 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'UserDefined' then 'h_off' else 0.0);
    annotation(Inline = false, smoothOrder = 2);
  end 'Modelica.Media.IdealGases.Common.Functions.h_Tlow';

  function 'Modelica.Utilities.Streams.error' "Print error message and cancel all actions - in case of an unrecoverable error"
    input String 'string';
  algorithm
    assert(false, 'string', AssertionLevel.error);
  end 'Modelica.Utilities.Streams.error';

