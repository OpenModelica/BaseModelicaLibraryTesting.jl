    der('ductIn.mXis[2,1]') = 'ductIn.mbXi_flows[2,1]';
    der('ductIn.mCs_scaled[1,1]') = 'ductIn.mbC_flows[1,1]' / 0.1519;
    'ductIn.mCs[1,1]' = 'ductIn.mCs_scaled[1,1]' * 0.1519;
    der('ductIn.mCs_scaled[2,1]') = 'ductIn.mbC_flows[2,1]' / 0.1519;
    'ductIn.mCs[2,1]' = 'ductIn.mCs_scaled[2,1]' * 0.1519;
    'traceDuctOut.CVec[1]' = ('$OMC$PositiveMax'(-'volume.ports[1].m_flow', 1e-7) * 'volume.ports[1].C_outflow[1]' + '$OMC$PositiveMax'(-'ductIn.port_b.m_flow', 1e-7) * 'ductIn.port_b.C_outflow[1]') / ('$OMC$PositiveMax'(-'volume.ports[1].m_flow', 1e-7) + '$OMC$PositiveMax'(-'ductIn.port_b.m_flow', 1e-7));
    'traceDuctOut.C' = 'traceDuctOut.CVec['traceDuctOut.ind']';
    'traceDuctOut.port.m_flow' = 0.0;
    'traceDuctOut.port.h_outflow' = 45262.582490480156;
    'traceDuctOut.port.Xi_outflow[1]' = 0.01;
    'traceDuctOut.port.C_outflow[1]' = 0.0;
  initial algorithm
    'traceVolume.ind' := -1;
    'traceVolume.ind' := 1;
    assert('traceVolume.ind' > 0, "Trace substance 'CO2' is not present in medium 'Moist air'.\nCheck sensor parameter and medium model.", AssertionLevel.error);
  initial algorithm
    'traceDuctIn.ind' := -1;
    'traceDuctIn.ind' := 1;
    assert('traceDuctIn.ind' > 0, "Trace substance 'CO2' is not present in medium 'Moist air'.\nCheck sensor parameter and medium model.", AssertionLevel.error);
  initial algorithm
    'traceDuctOut.ind' := -1;
    'traceDuctOut.ind' := 1;
    assert('traceDuctOut.ind' > 0, "Trace substance 'CO2' is not present in medium 'Moist air'.\nCheck sensor parameter and medium model.", AssertionLevel.error);
    annotation(experiment(StopTime = 86400, Tolerance = 1e-006));
  end 'RoomCO2WithControls';
