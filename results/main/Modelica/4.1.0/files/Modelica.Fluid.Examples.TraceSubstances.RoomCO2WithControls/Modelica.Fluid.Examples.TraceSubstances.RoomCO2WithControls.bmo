    'ductIn.vsFM[4]' = 'ductIn.m_flows[3]' / 'Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.density'('ductIn.state_b') / 0.017671458676442587;
    'ductIn.ms[1]' = 'ductIn.fluidVolumes[1]' * 'ductIn.mediums[1].d';
    'ductIn.mXis[1,1]' = 'ductIn.ms[1]' * 'ductIn.mediums[1].Xi[1]';
    'ductIn.mCs[1,1]' = 'ductIn.ms[1]' * 'ductIn.Cs[1,1]';
    'ductIn.Us[1]' = 'ductIn.ms[1]' * 'ductIn.mediums[1].u';
    'ductIn.ms[2]' = 'ductIn.fluidVolumes[2]' * 'ductIn.mediums[2].d';
    'ductIn.mXis[2,1]' = 'ductIn.ms[2]' * 'ductIn.mediums[2].Xi[1]';
    'ductIn.mCs[2,1]' = 'ductIn.ms[2]' * 'ductIn.Cs[2,1]';
    'ductIn.Us[2]' = 'ductIn.ms[2]' * 'ductIn.mediums[2].u';
    der('ductIn.Us[1]') = 'ductIn.Hb_flows[1]' + 'ductIn.Wb_flows[1]' + 'ductIn.Qb_flows[1]';
    der('ductIn.Us[2]') = 'ductIn.Hb_flows[2]' + 'ductIn.Wb_flows[2]' + 'ductIn.Qb_flows[2]';
    der('ductIn.ms[1]') = 'ductIn.mb_flows[1]';
    der('ductIn.ms[2]') = 'ductIn.mb_flows[2]';
