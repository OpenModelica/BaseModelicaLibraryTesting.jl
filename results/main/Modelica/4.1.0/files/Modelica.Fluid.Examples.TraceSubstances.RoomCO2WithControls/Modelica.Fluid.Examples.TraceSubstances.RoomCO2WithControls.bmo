    'ductIn.mC_flows[2,1]' = semiLinear('ductIn.m_flows[2]', 'ductIn.Cs[1,1]', 'ductIn.Cs[2,1]');
    'ductIn.H_flows[1]' = semiLinear('ductIn.port_a.m_flow', 'freshAir.ports[2].h_outflow', 'ductIn.mediums[1].h');
    'ductIn.H_flows[3]' = -semiLinear('ductIn.port_b.m_flow', 'volume.ports[1].h_outflow', 'ductIn.mediums[2].h');
    'ductIn.mXi_flows[1,1]' = semiLinear('ductIn.port_a.m_flow', 'freshAir.ports[2].Xi_outflow[1]', 'ductIn.mediums[1].Xi[1]');
    'ductIn.mXi_flows[3,1]' = -semiLinear('ductIn.port_b.m_flow', 'volume.ports[1].Xi_outflow[1]', 'ductIn.mediums[2].Xi[1]');
    'ductIn.mC_flows[1,1]' = semiLinear('ductIn.port_a.m_flow', 'freshAir.ports[2].C_outflow[1]', 'ductIn.Cs[1,1]');
    'ductIn.mC_flows[3,1]' = -semiLinear('ductIn.port_b.m_flow', 'volume.ports[1].C_outflow[1]', 'ductIn.Cs[2,1]');
    'ductIn.port_a.m_flow' = 'ductIn.m_flows[1]';
    'ductIn.port_b.m_flow' = -'ductIn.m_flows[3]';
    'ductIn.port_a.h_outflow' = 'ductIn.mediums[1].h';
    'ductIn.port_b.h_outflow' = 'ductIn.mediums[2].h';
    'ductIn.port_a.Xi_outflow[1]' = 'ductIn.mediums[1].Xi[1]';
    'ductIn.port_b.Xi_outflow[1]' = 'ductIn.mediums[2].Xi[1]';
    'ductIn.port_a.C_outflow[1]' = 'ductIn.Cs[1,1]';
    'ductIn.port_b.C_outflow[1]' = 'ductIn.Cs[2,1]';
    'ductIn.state_a.p' = ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('ductIn.port_a.p', 'freshAir.ports[2].h_outflow', {'freshAir.ports[2].Xi_outflow[1]'})).p;
    'ductIn.state_a.T' = ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('ductIn.port_a.p', 'freshAir.ports[2].h_outflow', {'freshAir.ports[2].Xi_outflow[1]'})).T;
    'ductIn.state_a.X[1]' = (('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('ductIn.port_a.p', 'freshAir.ports[2].h_outflow', {'freshAir.ports[2].Xi_outflow[1]'})).X)[1];
    'ductIn.state_a.X[2]' = (('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('ductIn.port_a.p', 'freshAir.ports[2].h_outflow', {'freshAir.ports[2].Xi_outflow[1]'})).X)[2];
    'ductIn.state_b.p' = ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('ductIn.port_b.p', 'volume.ports[1].h_outflow', {'volume.ports[1].Xi_outflow[1]'})).p;
    'ductIn.state_b.T' = ('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('ductIn.port_b.p', 'volume.ports[1].h_outflow', {'volume.ports[1].Xi_outflow[1]'})).T;
    'ductIn.state_b.X[1]' = (('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('ductIn.port_b.p', 'volume.ports[1].h_outflow', {'volume.ports[1].Xi_outflow[1]'})).X)[1];
    'ductIn.state_b.X[2]' = (('Modelica.Fluid.Examples.TraceSubstances.RoomCO2WithControls.ductIn.Medium.setState_phX'('ductIn.port_b.p', 'volume.ports[1].h_outflow', {'volume.ports[1].Xi_outflow[1]'})).X)[2];
    'ductIn.statesFM[1].p' = 'ductIn.state_a.p';
    'ductIn.statesFM[1].T' = 'ductIn.state_a.T';
    'ductIn.statesFM[1].X[1]' = 'ductIn.state_a.X[1]';
    'ductIn.statesFM[1].X[2]' = 'ductIn.state_a.X[2]';
