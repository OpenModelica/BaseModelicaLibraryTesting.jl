    'preisachEverett.H' = 'preisachEverett.V_m';
    'preisachEverett.Phi' = 'preisachEverett.B' * 1e-4;
    'preisachEverett.Heddy' = 0.0;
    'preisachEverett.LossPowerStat' = 'preisachEverett.Hstat' * der('preisachEverett.B') * 1e-4;
    'preisachEverett.LossPowerEddy' = 'preisachEverett.Heddy' * der('preisachEverett.B') * 1e-4;
    'preisachEverett.LossPower' = 'preisachEverett.LossPowerStat' + 'preisachEverett.LossPowerEddy';
    'preisachEverett.T_heatPort' = 293.15;
    0.0 = 'preisachEverett.port_p.Phi' + 'preisachEverett.port_n.Phi';
    'preisachEverett.V_m' = 'preisachEverett.port_p.V_m' - 'preisachEverett.port_n.V_m';
    'preisachEverett.Phi' = 'preisachEverett.port_p.Phi';
    'magGnd3.port.V_m' = 0.0;
    'resistor3.R_actual' = 1.0;
    'resistor3.v' = 'resistor3.R_actual' * 'resistor3.i';
    'resistor3.LossPower' = 'resistor3.v' * 'resistor3.i';
    'resistor3.T_heatPort' = 300.15;
    0.0 = 'resistor3.p.i' + 'resistor3.n.i';
    'resistor3.i' = 'resistor3.p.i';
    'resistor3.v' = 'resistor3.p.v' - 'resistor3.n.v';
    'vSource3.v' = 'vSource3.p.v' - 'vSource3.n.v';
    0.0 = 'vSource3.p.i' + 'vSource3.n.i';
    'vSource3.i' = 'vSource3.p.i';
    'gain.y' = 'gain.u';
    'tellinenSoft.hystR' = 1.35 * tanh(0.023802968158184314 * 'tellinenSoft.Hstat' - 0.9521187263273725) + 1.25663706212e-4 * 'tellinenSoft.Hstat' - 6.75e-4;
    'tellinenSoft.hystF' = 1.35 * tanh(0.023802968158184314 * 'tellinenSoft.Hstat' + 0.9521187263273725) + 1.25663706212e-4 * 'tellinenSoft.Hstat' + 6.75e-4;
    'tellinenSoft.asc' = der('tellinenSoft.Hstat') > 0.0;
    der('tellinenSoft.B') = 'tellinenSoft.k' * 'tellinenSoft.dHyst' + 1.25663706212e-4 * der('tellinenSoft.Hstat');
    'tellinenSoft.diffHyst' = 'tellinenSoft.hystF' - 'tellinenSoft.hystR';

    if initial() then
      'tellinenSoft.k' = 0.01;
      'tellinenSoft.dHyst' = 0.0;
    elseif 'tellinenSoft.asc' then
      'tellinenSoft.dHyst' = der('tellinenSoft.hystR' - 1.25663706212e-4 * 'tellinenSoft.Hstat');
      'tellinenSoft.k' = max(0.01, ('tellinenSoft.hystF' - 'tellinenSoft.B') / 'tellinenSoft.diffHyst');
    else
      'tellinenSoft.dHyst' = der('tellinenSoft.hystF' - 1.25663706212e-4 * 'tellinenSoft.Hstat');
      'tellinenSoft.k' = max(0.01, ('tellinenSoft.B' - 'tellinenSoft.hystR') / 'tellinenSoft.diffHyst');
    end if;

    der('tellinenSoft.MagRel') = 0.0;
    'tellinenSoft.H' = 'tellinenSoft.Hstat' + 'tellinenSoft.Heddy';
    'tellinenSoft.H' = 'tellinenSoft.V_m';
    'tellinenSoft.Phi' = 'tellinenSoft.B' * 1e-4;
    'tellinenSoft.Heddy' = 0.0;
    'tellinenSoft.LossPowerStat' = 'tellinenSoft.Hstat' * der('tellinenSoft.B') * 1e-4;
    'tellinenSoft.LossPowerEddy' = 'tellinenSoft.Heddy' * der('tellinenSoft.B') * 1e-4;
    'tellinenSoft.LossPower' = 'tellinenSoft.LossPowerStat' + 'tellinenSoft.LossPowerEddy';
    'tellinenSoft.T_heatPort' = 293.15;
    0.0 = 'tellinenSoft.port_p.Phi' + 'tellinenSoft.port_n.Phi';
    'tellinenSoft.V_m' = 'tellinenSoft.port_p.V_m' - 'tellinenSoft.port_n.V_m';
    'tellinenSoft.Phi' = 'tellinenSoft.port_p.Phi';
  algorithm
    assert(true, "The first point in time has to be set to 0, but is table[1,1] = 0", AssertionLevel.error);

    when {time >= pre('timeTable.nextEvent'), initial()} then
      ('timeTable.a', 'timeTable.b', 'timeTable.nextEventScaled', 'timeTable.last') := 'Modelica.Magnetic.FluxTubes.Examples.Hysteresis.HysteresisModelComparison.timeTable.getInterpolationCoefficients'({{0.0, 0.0}, {1.0, 500.0}, {3.0, -500.0}, {5.0, 500.0}, {6.0, -24.0}, {7.0, 24.0}, {8.0, -24.0}, {9.0, 24.0}, {10.0, -24.0}, {11.0, 24.0}, {12.0, -24.0}, {13.0, 24.0}, {14.0, -24.0}, {15.0, 24.0}}, 0.0, 0.0, 'timeTable.timeScaled', 'timeTable.last', 2.220446049250313e-14, 0.0);
      'timeTable.nextEvent' := 'timeTable.nextEventScaled';
    end when;
    annotation(experiment(StartTime = 0, StopTime = 14, Interval = 3e-3, Tolerance = 1e-005));
  end 'HysteresisModelComparison';
end 'HysteresisModelComparison';
