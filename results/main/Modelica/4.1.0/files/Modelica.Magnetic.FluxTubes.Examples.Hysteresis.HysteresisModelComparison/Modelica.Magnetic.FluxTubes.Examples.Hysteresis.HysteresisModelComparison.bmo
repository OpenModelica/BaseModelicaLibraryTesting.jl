    parameter Real 'resistor3.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1.0 "Resistance at temperature T_ref";
    parameter Real 'resistor3.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor3.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor3.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor3.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor3.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor3.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor3.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor3.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor3.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor3.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'vSource3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSource3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSource3.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSource3.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSource3.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'vSource3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'gain.k'(start = 1.0) = 1.0 "Gain value multiplied with input signal";
    Real 'gain.u' "Input signal connector";
    Real 'gain.y' "Output signal connector";
    parameter Real 'tellinenSoft.Js'(unit = "T", quantity = "MagneticFluxDensity") = 1.35 "Saturation polarization";
    parameter Real 'tellinenSoft.Br'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Remanence";
    parameter Real 'tellinenSoft.Hc'(unit = "A/m", quantity = "MagneticFieldStrength") = 40.0 "Coercitivity";
    parameter Real 'tellinenSoft.K' = 100.0 "Slope of hysteresis in the saturation region (K*mu_0)";
    Real 'tellinenSoft.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'tellinenSoft.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'tellinenSoft.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'tellinenSoft.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'tellinenSoft.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'tellinenSoft.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'tellinenSoft.l'(unit = "m", quantity = "Length") = 1.0 "Length in direction of flux";
    parameter Real 'tellinenSoft.A'(unit = "m2", quantity = "Area") = 1e-4 "Area of cross section";
    parameter Real 'tellinenSoft.V'(unit = "m3", quantity = "Volume") = 1e-4 "Volume of FluxTube";
    parameter Boolean 'tellinenSoft.useHeatPort' = false "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'tellinenSoft.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'tellinenSoft.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via HeatPort";
    Real 'tellinenSoft.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of HeatPort";
    parameter Boolean 'tellinenSoft.includeEddyCurrents' = false "= true, if eddy current losses are enabled" annotation(Evaluate = true);
    parameter Real 'tellinenSoft.sigma'(unit = "S/m", quantity = "Conductivity") = 1e7 "Conductivity of core material";
    parameter Real 'tellinenSoft.d'(unit = "m", quantity = "Length") = 5e-4 "Thickness of lamination";
    Real 'tellinenSoft.H'(start = 0.0, unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'tellinenSoft.Hstat'(unit = "A/m", quantity = "MagneticFieldStrength") "Static (ferromagnetic) portion of the magnetic field strength";
    Real 'tellinenSoft.Heddy'(unit = "A/m", quantity = "MagneticFieldStrength") "Dynamic (eddy currents) portion of the magnetic field strength";
    Real 'tellinenSoft.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'tellinenSoft.MagRel'(fixed = true, start = 0.0, max = 1.0, min = -1.0, unit = "1", quantity = "Relative magnetization") "Relative magnetization at initialization (-1..1)";
    Real 'tellinenSoft.LossPowerStat'(unit = "W", quantity = "Power") "Ferromagnetic (static) hysteresis losses";
    Real 'tellinenSoft.LossPowerEddy'(unit = "W", quantity = "Power") "Eddy current losses (dynamic hysteresis losses)";
    Real 'tellinenSoft.derHstat'(start = 0.0, unit = "A/(m.s)");
    parameter Real 'tellinenSoft.eddyCurrentFactor'(unit = "S.m") = 0.20833333333333334;
    Boolean 'tellinenSoft.asc'(start = true) "True when der(Hstat)>0";
    Real 'tellinenSoft.hystR'(unit = "T", quantity = "MagneticFluxDensity") "Rising branch of limiting hysteresis loop";
    Real 'tellinenSoft.hystF'(unit = "T", quantity = "MagneticFluxDensity") "Falling branch of limiting hysteresis loop";
    Real 'tellinenSoft.diffHyst'(unit = "T", quantity = "MagneticFluxDensity") "Distance between rising and falling limiting hysteresis branch at the current operating point";
    Real 'tellinenSoft.dHyst'(unit = "T/s", quantity = "MagneticFluxDensitySlope") "Slope of the Rising (when der(H)>0) or Falling (when der(H)<0) limiting hysteresis branch at the current operating point";
    Real 'tellinenSoft.k';
    parameter Real 'tellinenSoft.mu0'(unit = "N/A2") = 1.25663706212e-4;
    parameter Real 'tellinenSoft.eps'(unit = "T", quantity = "MagneticFluxDensity") = 0.00135;
    parameter Real 'tellinenSoft.H0' = 0.9521187263273725;
    parameter Real 'tellinenSoft.M' = 0.023802968158184314;
