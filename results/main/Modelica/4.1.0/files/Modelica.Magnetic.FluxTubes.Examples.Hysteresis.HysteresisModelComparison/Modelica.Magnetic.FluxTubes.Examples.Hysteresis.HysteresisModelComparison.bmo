    Real 'winding3.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'winding3.Phi'(stateSelect = StateSelect.never, unit = "Wb", quantity = "MagneticFlux") "Total Magnetic flux coupled into magnetic circuit (= Phi_ind + Phi_leak)";
    Real 'winding3.Phi_ind'(stateSelect = StateSelect.never, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux of converter";
    Real 'winding3.Phi_leak'(stateSelect = StateSelect.never, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux of leakage inductance";
    parameter Real 'winding3.N'(start = 1.0, min = 2.220446049250313e-16) = 1.0 "Number of turns";
    parameter Real 'winding3.L'(unit = "m", quantity = "Length") = 0.01 "Length in direction of flux";
    parameter Real 'winding3.A'(unit = "m2", quantity = "Area") = 1e-5 "Area of cross-section";
    parameter Real 'winding3.mu_rel'(min = 2.220446049250313e-16, unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability of leakage inductance (> 0 required)";
    parameter Real 'winding3.G_m'(unit = "H", quantity = "Permeance") = 1.25663706212e-9 "Magnetic permeance of leakage inductance";
    Real 'winding3.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'winding3.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    constant Real 'winding3.eps' = 2.220446049250313e-14;
    Real 'elGnd3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'elGnd3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'preisachEverett.mat.Hsat'(unit = "A/m", quantity = "MagneticFieldStrength") = 650.0 "Hysteresis region between -Hsat .. Hsat";
    parameter Real 'preisachEverett.mat.M'(unit = "1") = 0.967 "Related to saturation value of magnetization";
    parameter Real 'preisachEverett.mat.r'(unit = "1") = 0.50256 "Proportion of the straight region in the vicinity of Hc";
    parameter Real 'preisachEverett.mat.q'(unit = "m/A") = 0.039964 "Slope of the straight region in the vicinity of Hc";
    parameter Real 'preisachEverett.mat.p1'(unit = "m/A") = 0.18807 "Sharpness of major loop";
    parameter Real 'preisachEverett.mat.p2'(unit = "m/A") = 7.81e-4 "Sharpness of major loop";
    parameter Real 'preisachEverett.mat.Hc'(unit = "A/m", quantity = "MagneticFieldStrength") = 42.2283 "Major loop coercivity";
    parameter Real 'preisachEverett.mat.K'(unit = "1") = 50.0 "Slope in saturation region mu_0*K";
    parameter Real 'preisachEverett.mat.sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6 "Electrical conductivity of material";
    parameter Integer 'preisachEverett.Count' = 100 "Length of history array";
    parameter Real 'preisachEverett.eps'(unit = "A/m", quantity = "MagneticFieldStrength") = 1e-5 "Tolerance in Preisach history";
    parameter Real 'preisachEverett.t1'(unit = "s", quantity = "Time") = 1e-6 "Initialization time";
    Real 'preisachEverett.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'preisachEverett.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'preisachEverett.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'preisachEverett.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'preisachEverett.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'preisachEverett.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'preisachEverett.l'(unit = "m", quantity = "Length") = 1.0 "Length in direction of flux";
    parameter Real 'preisachEverett.A'(unit = "m2", quantity = "Area") = 1e-4 "Area of cross section";
    parameter Real 'preisachEverett.V'(unit = "m3", quantity = "Volume") = 1e-4 "Volume of FluxTube";
    parameter Boolean 'preisachEverett.useHeatPort' = false "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'preisachEverett.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'preisachEverett.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via HeatPort";
