//! base 0.1.0
package 'HysteresisModelComparison'
  function 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmax' "Return maximum abscissa value of 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    output Real 'uMax';
  external "C" 'uMax' = ModelicaStandardTables_CombiTable1D_maximumAbscissa('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmax';

  function 'Modelica.Magnetic.FluxTubes.Utilities.everett' "Everett function, see [YUY89]"
    input Real 'a_'(unit = "A/m", quantity = "MagneticFieldStrength");
    input Real 'b_'(unit = "A/m", quantity = "MagneticFieldStrength");
    input 'Modelica.Magnetic.FluxTubes.Material.HysteresisEverettParameter.BaseData' 'p';
    input Boolean 'mirror';
    output Real 'J'(unit = "T", quantity = "MagneticFluxDensity");
    Real 'a'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'b'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'h1'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'h2'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'h3'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'h4'(unit = "A/m", quantity = "MagneticFieldStrength");
    constant Real 'unitT'(unit = "T", quantity = "MagneticFluxDensity") = 1.0;
  algorithm
    if 'a_' >= 'b_' or 'mirror' then
      'a' := if 'a_' > 'p'.'Hsat' then 'p'.'Hsat' else if 'a_' < (-'p'.'Hsat') then -'p'.'Hsat' else 'a_';
      'b' := if 'b_' > 'p'.'Hsat' then 'p'.'Hsat' else if 'b_' < (-'p'.'Hsat') then -'p'.'Hsat' else 'b_';
      'h1' := -('b' + 'p'.'Hc');
      'h2' := 'a' - 'p'.'Hc';
      'h3' := -('a' + 'p'.'Hc');
      'h4' := 'b' - 'p'.'Hc';
      'J' := 'unitT' * (('p'.'M' * 'p'.'r' * (0.6366197723675814 * atan('p'.'q' * 'h1') + 1.0) + 2.0 * 'p'.'M' * (1.0 - 'p'.'r') / (1.0 + 0.5 * (exp(-'p'.'p1' * 'h1') + exp(-'p'.'p2' * 'h1')))) * ('p'.'M' * 'p'.'r' * (0.6366197723675814 * atan('p'.'q' * 'h2') + 1.0) + 2.0 * 'p'.'M' * (1.0 - 'p'.'r') / (1.0 + 0.5 * (exp(-'p'.'p1' * 'h2') + exp(-'p'.'p2' * 'h2')))) - ('p'.'M' * 'p'.'r' * (0.6366197723675814 * atan('p'.'q' * 'h3') + 1.0) + 2.0 * 'p'.'M' * (1.0 - 'p'.'r') / (1.0 + 0.5 * (exp(-'p'.'p1' * 'h3') + exp(-'p'.'p2' * 'h3')))) * ('p'.'M' * 'p'.'r' * (0.6366197723675814 * atan('p'.'q' * 'h4') + 1.0) + 2.0 * 'p'.'M' * (1.0 - 'p'.'r') / (1.0 + 0.5 * (exp(-'p'.'p1' * 'h4') + exp(-'p'.'p2' * 'h4')))));
    else
      'J' := 0.0;
    end if;
  end 'Modelica.Magnetic.FluxTubes.Utilities.everett';

  function 'Modelica.Magnetic.FluxTubes.Utilities.initPreisach' "Function used for the initialization of the Preisach hysteresis model GenericHystPreisachEverett"
    input Real 'x'(unit = "A/m", quantity = "MagneticFieldStrength");
    input Real 'H'(unit = "A/m", quantity = "MagneticFieldStrength");
    input 'Modelica.Magnetic.FluxTubes.Material.HysteresisEverettParameter.BaseData' 'p';
    output Real 'B'(unit = "T", quantity = "MagneticFluxDensity");
    Real 'hmax'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'H_l'(unit = "A/m", quantity = "MagneticFieldStrength");
  algorithm
    'H_l' := if 'H' <= (-'p'.'Hsat') then -'p'.'Hsat' else if 'H' >= 'p'.'Hsat' then 'p'.'Hsat' else 'H';
    'hmax' := abs('H') + abs('x');
    'B' := if 'x' < 0.0 then 'Modelica.Magnetic.FluxTubes.Utilities.everett'('H_l', -'hmax', 'p', false) - 0.5 * 'Modelica.Magnetic.FluxTubes.Utilities.everett'('hmax', -'hmax', 'p', false) + 'p'.'K' * 1.25663706212e-6 * 'H' else 0.5 * 'Modelica.Magnetic.FluxTubes.Utilities.everett'('hmax', -'hmax', 'p', false) - 'Modelica.Magnetic.FluxTubes.Utilities.everett'('hmax', 'H_l', 'p', false) + 'p'.'K' * 1.25663706212e-6 * 'H';
  end 'Modelica.Magnetic.FluxTubes.Utilities.initPreisach';

  function 'Modelica.Magnetic.FluxTubes.Examples.Hysteresis.HysteresisModelComparison.timeTable.getInterpolationCoefficients' "Determine interpolation coefficients and next time event"
    input Real[:, 2] 'table';
    input Real 'offset';
    input Real 'startTimeScaled';
    input Real 'timeScaled';
    input Integer 'last';
    input Real 'TimeEps';
    input Real 'shiftTimeScaled';
    output Real 'a';
    output Real 'b';
    output Real 'nextEventScaled';
    output Integer 'next';
    Integer 'columns' = 2;
    Integer 'ncol' = 2;
    Integer 'nrow' = size('table', 1);
    Integer 'next0';
    Real 'tp';
    Real 'dt';
  algorithm
    'next' := 'last';
    'nextEventScaled' := 'timeScaled' - 'TimeEps' * abs('timeScaled');
    'tp' := 'timeScaled' + 'TimeEps' * abs('timeScaled');

    if 'tp' < 'startTimeScaled' then
      'nextEventScaled' := 'startTimeScaled';
      'a' := 0.0;
      'b' := 'offset';
    elseif 'nrow' < 2 then
      'a' := 0.0;
      'b' := 'offset' + 'table'[1,'columns'];
    else
      'tp' := 'tp' - 'shiftTimeScaled';

      while 'next' < 'nrow' and 'tp' >= 'table'['next',1] loop
        'next' := 'next' + 1;
      end while;

      if 'next' < 'nrow' then
        'nextEventScaled' := 'shiftTimeScaled' + 'table'['next',1];
      end if;

      if 'next' == 1 then
        'next' := 2;
      end if;

      'next0' := 'next' - 1;
      'dt' := 'table'['next',1] - 'table'['next0',1];

      if 'dt' <= 'TimeEps' * abs('table'['next',1]) then
        'a' := 0.0;
        'b' := 'offset' + 'table'['next','columns'];
      else
        'a' := ('table'['next','columns'] - 'table'['next0','columns']) / 'dt';
        'b' := 'offset' + 'table'['next0','columns'] - 'a' * 'table'['next0',1];
      end if;
    end if;

    'b' := 'b' - 'a' * 'shiftTimeScaled';
  end 'Modelica.Magnetic.FluxTubes.Examples.Hysteresis.HysteresisModelComparison.timeTable.getInterpolationCoefficients';

  function 'Modelica.Blocks.Tables.Internal.getTable1DValue' "Interpolate 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTable1D_getValue('tableID', 'icol', 'u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1) = 'Modelica.Blocks.Tables.Internal.getDerTable1DValue');
  end 'Modelica.Blocks.Tables.Internal.getTable1DValue';

  function 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmin' "Return minimum abscissa value of 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    output Real 'uMin';
  external "C" 'uMin' = ModelicaStandardTables_CombiTable1D_minimumAbscissa('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmin';

  function 'Modelica.Blocks.Tables.Internal.getDerTable1DValue' "Derivative of interpolated 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    input Real 'der_u';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTable1D_getDerValue('tableID', 'icol', 'u', 'der_u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 2) = 'Modelica.Blocks.Tables.Internal.getDer2Table1DValue');
  end 'Modelica.Blocks.Tables.Internal.getDerTable1DValue';

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  class 'Modelica.Blocks.Types.ExternalCombiTable1D'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table defined by matrix"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" 'externalCombiTable1D' = ModelicaStandardTables_CombiTable1D_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table defined by matrix"
      input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" ModelicaStandardTables_CombiTable1D_close('externalCombiTable1D') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTable1D';

  record 'Modelica.Magnetic.FluxTubes.Material.HysteresisEverettParameter.M330_50A'
    parameter Real 'Hsat'(unit = "A/m", quantity = "MagneticFieldStrength") = 650.0;
    parameter Real 'M'(unit = "1") = 0.967;
    parameter Real 'r'(unit = "1") = 0.50256;
    parameter Real 'q'(unit = "m/A") = 0.039964;
    parameter Real 'p1'(unit = "m/A") = 0.18807;
    parameter Real 'p2'(unit = "m/A") = 7.81e-4;
    parameter Real 'Hc'(unit = "A/m", quantity = "MagneticFieldStrength") = 42.2283;
    parameter Real 'K'(unit = "1") = 50.0;
    parameter Real 'sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6;
  end 'Modelica.Magnetic.FluxTubes.Material.HysteresisEverettParameter.M330_50A';

  record 'Modelica.Magnetic.FluxTubes.Material.HysteresisEverettParameter.BaseData'
    parameter Real 'Hsat'(unit = "A/m", quantity = "MagneticFieldStrength") = 100.0;
    parameter Real 'M'(unit = "1") = 0.95;
    parameter Real 'r'(unit = "1") = 0.55;
    parameter Real 'q'(unit = "m/A") = 0.24;
    parameter Real 'p1'(unit = "m/A") = 0.12;
    parameter Real 'p2'(unit = "m/A") = 0.8;
    parameter Real 'Hc'(unit = "A/m", quantity = "MagneticFieldStrength") = 7.4;
    parameter Real 'K'(unit = "1") = 1.0;
    parameter Real 'sigma'(unit = "S/m", quantity = "Conductivity") = 1.0;
  end 'Modelica.Magnetic.FluxTubes.Material.HysteresisEverettParameter.BaseData';

  model 'HysteresisModelComparison' "Comparison of the different hysteresis models"
    parameter Real 'timeTable.table[1,1]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[1,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[2,1]' = 1.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[2,2]' = 500.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[3,1]' = 3.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[3,2]' = -500.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[4,1]' = 5.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[4,2]' = 500.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[5,1]' = 6.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[5,2]' = -24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[6,1]' = 7.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[6,2]' = 24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[7,1]' = 8.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[7,2]' = -24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[8,1]' = 9.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[8,2]' = 24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[9,1]' = 10.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[9,2]' = -24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[10,1]' = 11.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[10,2]' = 24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[11,1]' = 12.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[11,2]' = -24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[12,1]' = 13.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[12,2]' = 24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[13,1]' = 14.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[13,2]' = -24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[14,1]' = 15.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.table[14,2]' = 24.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'timeTable.timeScale'(min = 2.220446049250313e-16, unit = "s", quantity = "Time") = 1.0 "Time scale of first table column" annotation(Evaluate = true);
    Real 'timeTable.y' "Connector of Real output signal";
    parameter Real 'timeTable.offset' = 0.0 "Offset of output signal y";
    parameter Real 'timeTable.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'timeTable.shiftTime'(unit = "s", quantity = "Time") = 0.0 "Shift time of first table column";
    discrete Real 'timeTable.a' "Interpolation coefficient a of actual interval (y=a*x+b)";
    discrete Real 'timeTable.b' "Interpolation coefficient b of actual interval (y=a*x+b)";
    Integer 'timeTable.last'(start = 1) "Last used lower grid index";
    discrete Real 'timeTable.nextEvent'(fixed = true, start = 0.0, unit = "s", quantity = "Time") "Next event instant";
    discrete Real 'timeTable.nextEventScaled'(fixed = true, start = 0.0) "Next scaled event instant";
    Real 'timeTable.timeScaled' "Scaled time";
    Real 'winding1.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'winding1.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'winding1.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'winding1.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'winding1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'winding1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'winding1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'winding1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'winding1.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'winding1.i'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'winding1.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'winding1.Phi'(stateSelect = StateSelect.never, unit = "Wb", quantity = "MagneticFlux") "Total Magnetic flux coupled into magnetic circuit (= Phi_ind + Phi_leak)";
    Real 'winding1.Phi_ind'(stateSelect = StateSelect.never, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux of converter";
    Real 'winding1.Phi_leak'(stateSelect = StateSelect.never, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux of leakage inductance";
    parameter Real 'winding1.N'(start = 1.0, min = 2.220446049250313e-16) = 1.0 "Number of turns";
    parameter Real 'winding1.L'(unit = "m", quantity = "Length") = 0.01 "Length in direction of flux";
    parameter Real 'winding1.A'(unit = "m2", quantity = "Area") = 1e-5 "Area of cross-section";
    parameter Real 'winding1.mu_rel'(min = 2.220446049250313e-16, unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability of leakage inductance (> 0 required)";
    parameter Real 'winding1.G_m'(unit = "H", quantity = "Permeance") = 1.25663706212e-9 "Magnetic permeance of leakage inductance";
    Real 'winding1.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'winding1.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    constant Real 'winding1.eps' = 2.220446049250313e-14;
    Real 'elGnd1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'elGnd1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'magGnd1.port.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'magGnd1.port.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    parameter Real 'resistor1.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1.0 "Resistance at temperature T_ref";
    parameter Real 'resistor1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor1.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'vSource1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSource1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSource1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSource1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSource1.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'vSource1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'winding2.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'winding2.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'winding2.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'winding2.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'winding2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'winding2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'winding2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'winding2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'winding2.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'winding2.i'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'winding2.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'winding2.Phi'(stateSelect = StateSelect.never, unit = "Wb", quantity = "MagneticFlux") "Total Magnetic flux coupled into magnetic circuit (= Phi_ind + Phi_leak)";
    Real 'winding2.Phi_ind'(stateSelect = StateSelect.never, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux of converter";
