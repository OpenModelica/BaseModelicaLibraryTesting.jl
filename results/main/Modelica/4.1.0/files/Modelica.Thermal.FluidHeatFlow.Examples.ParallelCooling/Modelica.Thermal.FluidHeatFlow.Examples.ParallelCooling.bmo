    Real 'pipe3.T_b'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_b";
    Real 'pipe3.dT'(unit = "K", quantity = "ThermodynamicTemperature");
    Real 'pipe3.T_q'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature relevant for heat exchange with ambient";
    Real 'pipe3.h'(start = 'pipe3.medium.cp' * 293.15, unit = "J/kg", quantity = "SpecificEnergy") "Medium's specific enthalpy";
    parameter Real 'pipe3.flowPort_a.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'pipe3.flowPort_a.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'pipe3.flowPort_a.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'pipe3.flowPort_a.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'pipe3.flowPort_a.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'pipe3.flowPort_a.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'pipe3.flowPort_a.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'pipe3.flowPort_a.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pipe3.flowPort_a.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'pipe3.flowPort_b.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'pipe3.flowPort_b.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'pipe3.flowPort_b.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'pipe3.flowPort_b.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'pipe3.flowPort_b.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'pipe3.flowPort_b.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'pipe3.flowPort_b.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'pipe3.flowPort_b.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pipe3.flowPort_b.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'pipe3.V_flowLaminar'(start = 0.1, min = 2.2250738585072014e-308, unit = "m3/s", quantity = "VolumeFlowRate") = 0.1 "Laminar volume flow";
    parameter Real 'pipe3.dpLaminar'(start = 0.1, displayUnit = "Pa", unit = "Pa", quantity = "Pressure") = 0.1 "Laminar pressure drop";
    parameter Real 'pipe3.V_flowNominal'(start = 1.0, unit = "m3/s", quantity = "VolumeFlowRate") = 1.0 "Nominal volume flow";
    parameter Real 'pipe3.dpNominal'(start = 1.0, displayUnit = "Pa", unit = "Pa", quantity = "Pressure") = 1.0 "Nominal pressure drop";
    parameter Real 'pipe3.frictionLoss'(max = 1.0, min = 0.0) = 0.0 "Part of friction losses fed to medium";
    Real 'pipe3.pressureDrop'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'pipe3.volumeFlow'(unit = "m3/s", quantity = "VolumeFlowRate");
    Real 'pipe3.Q_friction'(unit = "W", quantity = "Power");
    parameter Real 'pipe3.dpNomMin'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0;
    parameter Real 'pipe3.k'(fixed = false, unit = "Pa.s2/m6");
    parameter Boolean 'pipe3.useHeatPort' = false "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'pipe3.h_g'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Geodetic height (height difference from flowPort_a to flowPort_b)";
    parameter Real 'pipe3.g'(min = 0.0, unit = "m/s2", quantity = "Acceleration") = 9.80665 "Gravitation";
    Real 'pipe3.Q_flowHeatPort'(unit = "W", quantity = "Power") "Heat flow at conditional heatPort";
    parameter Real 'ambient2.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'ambient2.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'ambient2.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'ambient2.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'ambient2.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    parameter Real 'ambient2.T0'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Initial temperature of medium";
    parameter Boolean 'ambient2.T0fixed' = false "Initial temperature guess value or fixed";
    Real 'ambient2.T_port'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature at flowPort_a";
    Real 'ambient2.T'(nominal = 300.0, fixed = false, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Outlet temperature of medium";
    parameter Real 'ambient2.flowPort.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'ambient2.flowPort.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'ambient2.flowPort.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'ambient2.flowPort.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'ambient2.flowPort.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'ambient2.flowPort.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'ambient2.flowPort.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'ambient2.flowPort.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'ambient2.flowPort.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    constant Boolean 'ambient2.Exchange' = true "Exchange of medium via flowport";
    Real 'ambient2.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy in the volume";
    parameter Boolean 'ambient2.usePressureInput' = false "Enable / disable pressure input" annotation(Evaluate = true);
    parameter Real 'ambient2.constantAmbientPressure'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 0.0 "Ambient pressure";
    parameter Boolean 'ambient2.useTemperatureInput' = false "Enable / disable temperature input" annotation(Evaluate = true);
    parameter Real 'ambient2.constantAmbientTemperature'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'ambient2.pAmbient'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'ambient2.TAmbient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    parameter Real 'heatCapacitor1.C'(unit = "J/K", quantity = "HeatCapacity") = 0.1 "Heat capacity of element (= cp*m)";
    Real 'heatCapacitor1.T'(nominal = 300.0, fixed = true, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of element";
    Real 'heatCapacitor1.der_T'(start = 0.0, unit = "K/s", quantity = "TemperatureSlope") "Time derivative of temperature (= der(T))";
    Real 'heatCapacitor1.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'heatCapacitor1.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'prescribedHeatFlow1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'prescribedHeatFlow1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of heat flow rate";
    Real 'prescribedHeatFlow1.Q_flow'(unit = "W");
    Real 'prescribedHeatFlow1.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'prescribedHeatFlow1.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'convection1.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate from solid -> fluid";
    Real 'convection1.dT'(unit = "K", quantity = "ThermodynamicTemperature");
    Real 'convection1.Gc'(unit = "W/K") "Signal representing the convective thermal conductance in [W/K]";
    Real 'convection1.solid.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'convection1.solid.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'convection1.fluid.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'convection1.fluid.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'heatCapacitor2.C'(unit = "J/K", quantity = "HeatCapacity") = 0.1 "Heat capacity of element (= cp*m)";
    Real 'heatCapacitor2.T'(nominal = 300.0, fixed = true, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of element";
    Real 'heatCapacitor2.der_T'(start = 0.0, unit = "K/s", quantity = "TemperatureSlope") "Time derivative of temperature (= der(T))";
    Real 'heatCapacitor2.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'heatCapacitor2.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'prescribedHeatFlow2.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'prescribedHeatFlow2.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of heat flow rate";
    Real 'prescribedHeatFlow2.Q_flow'(unit = "W");
    Real 'prescribedHeatFlow2.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'prescribedHeatFlow2.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'convection2.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate from solid -> fluid";
    Real 'convection2.dT'(unit = "K", quantity = "ThermodynamicTemperature");
    Real 'convection2.Gc'(unit = "W/K") "Signal representing the convective thermal conductance in [W/K]";
    Real 'convection2.solid.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'convection2.solid.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'convection2.fluid.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'convection2.fluid.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'volumeFlow.k'(start = 1.0) = 1.0 "Constant output value";
    Real 'volumeFlow.y' "Connector of Real output signal";
    parameter Real 'heatFlow1.k'(start = 1.0) = 5.0 "Constant output value";
    Real 'heatFlow1.y' "Connector of Real output signal";
    parameter Real 'heatFlow2.k'(start = 1.0) = 10.0 "Constant output value";
    Real 'heatFlow2.y' "Connector of Real output signal";
    parameter Real 'thermalConductance1.k'(start = 1.0) = 1.0 "Constant output value";
    Real 'thermalConductance1.y' "Connector of Real output signal";
    parameter Real 'thermalConductance2.k'(start = 1.0) = 1.0 "Constant output value";
    Real 'thermalConductance2.y' "Connector of Real output signal";
  equation
    'dTSource1' = 'prescribedHeatFlow1.port.T' - 293.15;
    'dTtoPipe1' = 'prescribedHeatFlow1.port.T' - 'pipe1.T_q';
    'dTCoolant1' = 'pipe1.dT';
    'dTSource2' = 'prescribedHeatFlow2.port.T' - 293.15;
    'dTtoPipe2' = 'prescribedHeatFlow2.port.T' - 'pipe2.T_q';
    'dTCoolant2' = 'pipe2.dT';
    'dTmixedCoolant' = 'ambient2.T_port' - 'ambient1.T_port';
    'pump.volumeFlow' = 'pump.internalVolumeFlow';
    'pipe1.heatPort.T' = 'pipe1.T_q';
    'pipe1.heatPort.Q_flow' = 'pipe1.Q_flowHeatPort';
    'pipe2.heatPort.T' = 'pipe2.T_q';
    'pipe2.heatPort.Q_flow' = 'pipe2.Q_flowHeatPort';
    'ambient1.flowPort.h' = 'pump.flowPort_a.h';
    assert(abs('ambient1.flowPort.medium.rho' - 'pump.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient1.flowPort.medium.cp' - 'pump.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient1.flowPort.medium.cv' - 'pump.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient1.flowPort.medium.lambda' - 'pump.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient1.flowPort.medium.nu' - 'pump.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'ambient1.flowPort.p' = 'pump.flowPort_a.p';
    'pump.flowPort_b.h' = 'pipe2.flowPort_a.h';
    'pump.flowPort_b.h' = 'pipe1.flowPort_a.h';
    assert(abs('pump.flowPort_b.medium.rho' - 'pipe2.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.rho' - 'pipe1.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.cp' - 'pipe2.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.cp' - 'pipe1.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.cv' - 'pipe2.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.cv' - 'pipe1.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.lambda' - 'pipe2.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.lambda' - 'pipe1.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.nu' - 'pipe2.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pump.flowPort_b.medium.nu' - 'pipe1.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'pump.flowPort_b.p' = 'pipe2.flowPort_a.p';
    'pump.flowPort_b.p' = 'pipe1.flowPort_a.p';
    'heatFlow2.y' = 'prescribedHeatFlow2.Q_flow';
    'heatFlow1.y' = 'prescribedHeatFlow1.Q_flow';
    'thermalConductance2.y' = 'convection2.Gc';
    'thermalConductance1.y' = 'convection1.Gc';
    'pipe1.heatPort.T' = 'convection1.fluid.T';
    'convection2.fluid.T' = 'pipe2.heatPort.T';
    'convection2.solid.T' = 'heatCapacitor2.port.T';
    'convection2.solid.T' = 'prescribedHeatFlow2.port.T';
    'convection1.solid.T' = 'heatCapacitor1.port.T';
    'convection1.solid.T' = 'prescribedHeatFlow1.port.T';
    'pipe1.flowPort_b.h' = 'pipe3.flowPort_a.h';
    'pipe1.flowPort_b.h' = 'pipe2.flowPort_b.h';
    assert(abs('pipe1.flowPort_b.medium.rho' - 'pipe3.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.rho' - 'pipe2.flowPort_b.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.cp' - 'pipe3.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.cp' - 'pipe2.flowPort_b.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.cv' - 'pipe3.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.cv' - 'pipe2.flowPort_b.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.lambda' - 'pipe3.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.lambda' - 'pipe2.flowPort_b.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.nu' - 'pipe3.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.nu' - 'pipe2.flowPort_b.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'pipe1.flowPort_b.p' = 'pipe3.flowPort_a.p';
    'pipe1.flowPort_b.p' = 'pipe2.flowPort_b.p';
    'pipe3.flowPort_b.h' = 'ambient2.flowPort.h';
    assert(abs('pipe3.flowPort_b.medium.rho' - 'ambient2.flowPort.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe3.flowPort_b.medium.cp' - 'ambient2.flowPort.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe3.flowPort_b.medium.cv' - 'ambient2.flowPort.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe3.flowPort_b.medium.lambda' - 'ambient2.flowPort.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe3.flowPort_b.medium.nu' - 'ambient2.flowPort.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'pipe3.flowPort_b.p' = 'ambient2.flowPort.p';
    'volumeFlow.y' = 'pump.volumeFlow';
    'pump.flowPort_a.m_flow' + 'ambient1.flowPort.m_flow' = 0.0;
    'pump.flowPort_a.H_flow' + 'ambient1.flowPort.H_flow' = 0.0;
    'pipe2.flowPort_a.m_flow' + 'pipe1.flowPort_a.m_flow' + 'pump.flowPort_b.m_flow' = 0.0;
    'pipe2.flowPort_a.H_flow' + 'pipe1.flowPort_a.H_flow' + 'pump.flowPort_b.H_flow' = 0.0;
    'convection1.fluid.Q_flow' + 'pipe1.heatPort.Q_flow' = 0.0;
    'pipe3.flowPort_a.m_flow' + 'pipe2.flowPort_b.m_flow' + 'pipe1.flowPort_b.m_flow' = 0.0;
    'pipe3.flowPort_a.H_flow' + 'pipe2.flowPort_b.H_flow' + 'pipe1.flowPort_b.H_flow' = 0.0;
    'ambient2.flowPort.m_flow' + 'pipe3.flowPort_b.m_flow' = 0.0;
    'ambient2.flowPort.H_flow' + 'pipe3.flowPort_b.H_flow' = 0.0;
    'convection1.solid.Q_flow' + 'prescribedHeatFlow1.port.Q_flow' + 'heatCapacitor1.port.Q_flow' = 0.0;
    'convection2.solid.Q_flow' + 'prescribedHeatFlow2.port.Q_flow' + 'heatCapacitor2.port.Q_flow' = 0.0;
    'convection2.fluid.Q_flow' + 'pipe2.heatPort.Q_flow' = 0.0;
    'ambient1.pAmbient' = 0.0;
    'ambient1.TAmbient' = 293.15;
    'ambient1.flowPort.p' = 'ambient1.pAmbient';
    'ambient1.T' = 'ambient1.TAmbient';
    'ambient1.T_port' = 'ambient1.flowPort.h' / 'ambient1.medium.cp';
    'ambient1.T' = 'ambient1.h' / 'ambient1.medium.cp';
    'ambient1.flowPort.H_flow' = semiLinear('ambient1.flowPort.m_flow', 'ambient1.flowPort.h', 'ambient1.h');
    'pump.Q_flow' = 0.0;
    'pump.V_flow' = 'pump.internalVolumeFlow';
    'pump.dp' = 'pump.flowPort_a.p' - 'pump.flowPort_b.p';
    'pump.V_flow' = 'pump.flowPort_a.m_flow' / 'pump.medium.rho';
    'pump.T_a' = 'pump.flowPort_a.h' / 'pump.medium.cp';
    'pump.T_b' = 'pump.flowPort_b.h' / 'pump.medium.cp';
    'pump.dT' = if noEvent('pump.V_flow' >= 0.0) then 'pump.T' - 'pump.T_a' else 'pump.T_b' - 'pump.T';
    'pump.h' = 'pump.medium.cp' * 'pump.T';
    'pump.T_q' = 'pump.T';
    'pump.flowPort_a.m_flow' + 'pump.flowPort_b.m_flow' = 0.0;
    'pump.flowPort_a.H_flow' + 'pump.flowPort_b.H_flow' + 'pump.Q_flow' = 0.0;
    'pump.flowPort_a.H_flow' = semiLinear('pump.flowPort_a.m_flow', 'pump.flowPort_a.h', 'pump.h');
    'pump.flowPort_b.H_flow' = semiLinear('pump.flowPort_b.m_flow', 'pump.flowPort_b.h', 'pump.h');
    'pipe1.volumeFlow' = 'pipe1.V_flow';
    'pipe1.dp' = 'pipe1.pressureDrop';
    'pipe1.Q_flow' = 'pipe1.Q_flowHeatPort' + 'pipe1.Q_friction';

    if 'pipe1.volumeFlow' > 0.1 then
      'pipe1.pressureDrop' = 'pipe1.volumeFlow' + 'pipe1.k' * ('pipe1.volumeFlow' - 0.1) ^ 2.0;
    elseif 'pipe1.volumeFlow' < (-0.1) then
      'pipe1.pressureDrop' = 'pipe1.volumeFlow' - 'pipe1.k' * ('pipe1.volumeFlow' + 0.1) ^ 2.0;
    elseif true then
      'pipe1.pressureDrop' = 'pipe1.volumeFlow';
    end if;

    'pipe1.Q_friction' = 0.0;
    'pipe1.dp' = 'pipe1.flowPort_a.p' - 'pipe1.flowPort_b.p';
    'pipe1.V_flow' = 'pipe1.flowPort_a.m_flow' / 'pipe1.medium.rho';
    'pipe1.T_a' = 'pipe1.flowPort_a.h' / 'pipe1.medium.cp';
    'pipe1.T_b' = 'pipe1.flowPort_b.h' / 'pipe1.medium.cp';
    'pipe1.dT' = if noEvent('pipe1.V_flow' >= 0.0) then 'pipe1.T' - 'pipe1.T_a' else 'pipe1.T_b' - 'pipe1.T';
    'pipe1.h' = 'pipe1.medium.cp' * 'pipe1.T';
    'pipe1.T_q' = 'pipe1.T';
    'pipe1.flowPort_a.m_flow' + 'pipe1.flowPort_b.m_flow' = 0.0;
    'pipe1.flowPort_a.H_flow' + 'pipe1.flowPort_b.H_flow' + 'pipe1.Q_flow' = 0.1 * 'pipe1.medium.cv' * der('pipe1.T');
    'pipe1.flowPort_a.H_flow' = semiLinear('pipe1.flowPort_a.m_flow', 'pipe1.flowPort_a.h', 'pipe1.h');
    'pipe1.flowPort_b.H_flow' = semiLinear('pipe1.flowPort_b.m_flow', 'pipe1.flowPort_b.h', 'pipe1.h');
    'pipe2.volumeFlow' = 'pipe2.V_flow';
    'pipe2.dp' = 'pipe2.pressureDrop';
    'pipe2.Q_flow' = 'pipe2.Q_flowHeatPort' + 'pipe2.Q_friction';

    if 'pipe2.volumeFlow' > 0.1 then
      'pipe2.pressureDrop' = 'pipe2.volumeFlow' + 'pipe2.k' * ('pipe2.volumeFlow' - 0.1) ^ 2.0;
    elseif 'pipe2.volumeFlow' < (-0.1) then
      'pipe2.pressureDrop' = 'pipe2.volumeFlow' - 'pipe2.k' * ('pipe2.volumeFlow' + 0.1) ^ 2.0;
    elseif true then
      'pipe2.pressureDrop' = 'pipe2.volumeFlow';
    end if;

    'pipe2.Q_friction' = 0.0;
    'pipe2.dp' = 'pipe2.flowPort_a.p' - 'pipe2.flowPort_b.p';
    'pipe2.V_flow' = 'pipe2.flowPort_a.m_flow' / 'pipe2.medium.rho';
    'pipe2.T_a' = 'pipe2.flowPort_a.h' / 'pipe2.medium.cp';
    'pipe2.T_b' = 'pipe2.flowPort_b.h' / 'pipe2.medium.cp';
    'pipe2.dT' = if noEvent('pipe2.V_flow' >= 0.0) then 'pipe2.T' - 'pipe2.T_a' else 'pipe2.T_b' - 'pipe2.T';
    'pipe2.h' = 'pipe2.medium.cp' * 'pipe2.T';
    'pipe2.T_q' = 'pipe2.T';
    'pipe2.flowPort_a.m_flow' + 'pipe2.flowPort_b.m_flow' = 0.0;
    'pipe2.flowPort_a.H_flow' + 'pipe2.flowPort_b.H_flow' + 'pipe2.Q_flow' = 0.1 * 'pipe2.medium.cv' * der('pipe2.T');
    'pipe2.flowPort_a.H_flow' = semiLinear('pipe2.flowPort_a.m_flow', 'pipe2.flowPort_a.h', 'pipe2.h');
    'pipe2.flowPort_b.H_flow' = semiLinear('pipe2.flowPort_b.m_flow', 'pipe2.flowPort_b.h', 'pipe2.h');
    'pipe3.Q_flowHeatPort' = 0.0;
    'pipe3.volumeFlow' = 'pipe3.V_flow';
    'pipe3.dp' = 'pipe3.pressureDrop';
    'pipe3.Q_flow' = 'pipe3.Q_flowHeatPort' + 'pipe3.Q_friction';

    if 'pipe3.volumeFlow' > 0.1 then
      'pipe3.pressureDrop' = 'pipe3.volumeFlow' + 'pipe3.k' * ('pipe3.volumeFlow' - 0.1) ^ 2.0;
    elseif 'pipe3.volumeFlow' < (-0.1) then
      'pipe3.pressureDrop' = 'pipe3.volumeFlow' - 'pipe3.k' * ('pipe3.volumeFlow' + 0.1) ^ 2.0;
    elseif true then
      'pipe3.pressureDrop' = 'pipe3.volumeFlow';
    end if;

    'pipe3.Q_friction' = 0.0;
    'pipe3.dp' = 'pipe3.flowPort_a.p' - 'pipe3.flowPort_b.p';
    'pipe3.V_flow' = 'pipe3.flowPort_a.m_flow' / 'pipe3.medium.rho';
    'pipe3.T_a' = 'pipe3.flowPort_a.h' / 'pipe3.medium.cp';
    'pipe3.T_b' = 'pipe3.flowPort_b.h' / 'pipe3.medium.cp';
    'pipe3.dT' = if noEvent('pipe3.V_flow' >= 0.0) then 'pipe3.T' - 'pipe3.T_a' else 'pipe3.T_b' - 'pipe3.T';
    'pipe3.h' = 'pipe3.medium.cp' * 'pipe3.T';
    'pipe3.T_q' = 'pipe3.T';
    'pipe3.flowPort_a.m_flow' + 'pipe3.flowPort_b.m_flow' = 0.0;
    'pipe3.flowPort_a.H_flow' + 'pipe3.flowPort_b.H_flow' + 'pipe3.Q_flow' = 0.1 * 'pipe3.medium.cv' * der('pipe3.T');
    'pipe3.flowPort_a.H_flow' = semiLinear('pipe3.flowPort_a.m_flow', 'pipe3.flowPort_a.h', 'pipe3.h');
    'pipe3.flowPort_b.H_flow' = semiLinear('pipe3.flowPort_b.m_flow', 'pipe3.flowPort_b.h', 'pipe3.h');
    'ambient2.pAmbient' = 0.0;
    'ambient2.TAmbient' = 293.15;
    'ambient2.flowPort.p' = 'ambient2.pAmbient';
    'ambient2.T' = 'ambient2.TAmbient';
    'ambient2.T_port' = 'ambient2.flowPort.h' / 'ambient2.medium.cp';
    'ambient2.T' = 'ambient2.h' / 'ambient2.medium.cp';
    'ambient2.flowPort.H_flow' = semiLinear('ambient2.flowPort.m_flow', 'ambient2.flowPort.h', 'ambient2.h');
    'heatCapacitor1.T' = 'heatCapacitor1.port.T';
    'heatCapacitor1.der_T' = der('heatCapacitor1.T');
    0.1 * der('heatCapacitor1.T') = 'heatCapacitor1.port.Q_flow';
    'prescribedHeatFlow1.port.Q_flow' = -'prescribedHeatFlow1.Q_flow';
    'convection1.dT' = 'convection1.solid.T' - 'convection1.fluid.T';
    'convection1.solid.Q_flow' = 'convection1.Q_flow';
    'convection1.fluid.Q_flow' = -'convection1.Q_flow';
    'convection1.Q_flow' = 'convection1.Gc' * 'convection1.dT';
    'heatCapacitor2.T' = 'heatCapacitor2.port.T';
    'heatCapacitor2.der_T' = der('heatCapacitor2.T');
    0.1 * der('heatCapacitor2.T') = 'heatCapacitor2.port.Q_flow';
    'prescribedHeatFlow2.port.Q_flow' = -'prescribedHeatFlow2.Q_flow';
    'convection2.dT' = 'convection2.solid.T' - 'convection2.fluid.T';
    'convection2.solid.Q_flow' = 'convection2.Q_flow';
    'convection2.fluid.Q_flow' = -'convection2.Q_flow';
    'convection2.Q_flow' = 'convection2.Gc' * 'convection2.dT';
    'volumeFlow.y' = 1.0;
    'heatFlow1.y' = 5.0;
    'heatFlow2.y' = 10.0;
    'thermalConductance1.y' = 1.0;
    'thermalConductance2.y' = 1.0;
  initial algorithm
    assert(true, "SimpleFriction: V_flowNominal has to be > V_flowLaminar!", AssertionLevel.error);
    assert(true, "SimpleFriction: dpNominal has to be > dpLaminar/V_flowLaminar*V_flowNominal!", AssertionLevel.error);
    'pipe1.k' := 0.0;
  initial algorithm
    assert(true, "SimpleFriction: V_flowNominal has to be > V_flowLaminar!", AssertionLevel.error);
    assert(true, "SimpleFriction: dpNominal has to be > dpLaminar/V_flowLaminar*V_flowNominal!", AssertionLevel.error);
    'pipe2.k' := 0.0;
  initial algorithm
    assert(true, "SimpleFriction: V_flowNominal has to be > V_flowLaminar!", AssertionLevel.error);
    assert(true, "SimpleFriction: dpNominal has to be > dpLaminar/V_flowLaminar*V_flowNominal!", AssertionLevel.error);
    'pipe3.k' := 0.0;
    annotation(experiment(StopTime = 1.0, Interval = 0.001));
  end 'ParallelCooling';
end 'ParallelCooling';
