    'imc.ir[1]' = 'imc.squirrelCageR.i[1]';
    'imc.ir[2]' = 'imc.squirrelCageR.i[2]';
    'imc.airGap.i_ms[1]' = 'imc.airGap.i_ss[1]' + 'imc.airGap.i_rs[1]';
    'imc.airGap.i_ms[2]' = 'imc.airGap.i_ss[2]' + 'imc.airGap.i_rs[2]';
    'imc.airGap.psi_ms[1]' = 0.009225332222963813 * 'imc.airGap.i_ms[1]';
    'imc.airGap.psi_ms[2]' = 0.009225332222963813 * 'imc.airGap.i_ms[2]';
    'imc.airGap.psi_mr[1]' = 'imc.airGap.RotationMatrix[1,1]' * 'imc.airGap.psi_ms[1]' + 'imc.airGap.RotationMatrix[2,1]' * 'imc.airGap.psi_ms[2]';
    'imc.airGap.psi_mr[2]' = 'imc.airGap.RotationMatrix[1,2]' * 'imc.airGap.psi_ms[1]' + 'imc.airGap.RotationMatrix[2,2]' * 'imc.airGap.psi_ms[2]';
    'imc.airGap.gamma' = 2.0 * ('imc.airGap.flange.phi' - 'imc.airGap.support.phi');
    'imc.airGap.RotationMatrix[1,1]' = cos('imc.airGap.gamma');
    'imc.airGap.RotationMatrix[1,2]' = -sin('imc.airGap.gamma');
    'imc.airGap.RotationMatrix[2,1]' = sin('imc.airGap.gamma');
    'imc.airGap.RotationMatrix[2,2]' = cos('imc.airGap.gamma');
    'imc.airGap.i_ss[1]' = 'imc.airGap.spacePhasor_s.i_[1]';
    'imc.airGap.i_ss[2]' = 'imc.airGap.spacePhasor_s.i_[2]';
    'imc.airGap.i_ss[1]' = 'imc.airGap.RotationMatrix[1,1]' * 'imc.airGap.i_sr[1]' + 'imc.airGap.RotationMatrix[1,2]' * 'imc.airGap.i_sr[2]';
    'imc.airGap.i_ss[2]' = 'imc.airGap.RotationMatrix[2,1]' * 'imc.airGap.i_sr[1]' + 'imc.airGap.RotationMatrix[2,2]' * 'imc.airGap.i_sr[2]';
    'imc.airGap.i_rr[1]' = 'imc.airGap.spacePhasor_r.i_[1]';
    'imc.airGap.i_rr[2]' = 'imc.airGap.spacePhasor_r.i_[2]';
    'imc.airGap.i_rs[1]' = 'imc.airGap.RotationMatrix[1,1]' * 'imc.airGap.i_rr[1]' + 'imc.airGap.RotationMatrix[1,2]' * 'imc.airGap.i_rr[2]';
    'imc.airGap.i_rs[2]' = 'imc.airGap.RotationMatrix[2,1]' * 'imc.airGap.i_rr[1]' + 'imc.airGap.RotationMatrix[2,2]' * 'imc.airGap.i_rr[2]';
    'imc.airGap.spacePhasor_s.v_[1]' = der('imc.airGap.psi_ms[1]');
    'imc.airGap.spacePhasor_s.v_[2]' = der('imc.airGap.psi_ms[2]');
    'imc.airGap.spacePhasor_r.v_[1]' = der('imc.airGap.psi_mr[1]');
    'imc.airGap.spacePhasor_r.v_[2]' = der('imc.airGap.psi_mr[2]');
    'imc.airGap.tauElectrical' = 3.0 * ('imc.airGap.spacePhasor_s.i_[2]' * 'imc.airGap.psi_ms[1]' - 'imc.airGap.spacePhasor_s.i_[1]' * 'imc.airGap.psi_ms[2]');
    'imc.airGap.flange.tau' = -'imc.airGap.tauElectrical';
    'imc.airGap.support.tau' = 'imc.airGap.tauElectrical';
    'imc.squirrelCageR.i[1]' = -'imc.squirrelCageR.spacePhasor_r.i_[1]';
    'imc.squirrelCageR.i[2]' = -'imc.squirrelCageR.spacePhasor_r.i_[2]';
    'imc.squirrelCageR.Rr_actual' = 0.04;
    'imc.squirrelCageR.spacePhasor_r.v_[1]' = 'imc.squirrelCageR.Rr_actual' * 'imc.squirrelCageR.spacePhasor_r.i_[1]' + 3.239643625499069e-4 * der('imc.squirrelCageR.spacePhasor_r.i_[1]');
    'imc.squirrelCageR.spacePhasor_r.v_[2]' = 'imc.squirrelCageR.Rr_actual' * 'imc.squirrelCageR.spacePhasor_r.i_[2]' + 3.239643625499069e-4 * der('imc.squirrelCageR.spacePhasor_r.i_[2]');
    0.6666666666666666 * 'imc.squirrelCageR.LossPower' = 'imc.squirrelCageR.Rr_actual' * ('imc.squirrelCageR.spacePhasor_r.i_[1]' * 'imc.squirrelCageR.spacePhasor_r.i_[1]' + 'imc.squirrelCageR.spacePhasor_r.i_[2]' * 'imc.squirrelCageR.spacePhasor_r.i_[2]');
    'loadInertia.phi' = 'loadInertia.flange_a.phi';
    'loadInertia.phi' = 'loadInertia.flange_b.phi';
    'loadInertia.w' = der('loadInertia.phi');
    'loadInertia.a' = der('loadInertia.w');
    1.16 * 'loadInertia.a' = 'loadInertia.flange_a.tau' + 'loadInertia.flange_b.tau';
    'plugToPin1.pin_p.v' = 'plugToPin1.plug_p.pin[1].v';
    'plugToPin1.plug_p.pin[1].i' = -'plugToPin1.pin_p.i';
    'plugToPin1.plug_p.pin[2].i' = 0.0;
    'plugToPin1.plug_p.pin[3].i' = 0.0;
    'plugToPin2.pin_p.v' = 'plugToPin2.plug_p.pin[2].v';
    'plugToPin2.plug_p.pin[1].i' = 0.0;
    'plugToPin2.plug_p.pin[2].i' = -'plugToPin2.pin_p.i';
    'plugToPin2.plug_p.pin[3].i' = 0.0;
    'plugToPin3.pin_p.v' = 'plugToPin3.plug_p.pin[3].v';
    'plugToPin3.plug_p.pin[1].i' = 0.0;
    'plugToPin3.plug_p.pin[2].i' = 0.0;
    'plugToPin3.plug_p.pin[3].i' = -'plugToPin3.pin_p.i';
    'constantCurrent.i' = 244.9489742783178;
    0.0 = 'constantCurrent.p.i' + 'constantCurrent.n.i';
    'constantCurrent.i' = 'constantCurrent.p.i';
    'constantCurrent.v' = 'constantCurrent.p.v' - 'constantCurrent.n.v';
    'ground.p.v' = 0.0;
    annotation(experiment(StopTime = 25, Interval = 0.001, Tolerance = 1e-06));
  end 'IMC_DCBraking';
end 'IMC_DCBraking';
