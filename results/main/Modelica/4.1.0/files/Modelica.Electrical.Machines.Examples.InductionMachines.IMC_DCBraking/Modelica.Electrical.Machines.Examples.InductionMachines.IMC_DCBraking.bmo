    parameter Real 'imc.Lssigma'(start = 3.239643625499069e-4, unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator stray inductance per phase";
    parameter Real 'imc.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
