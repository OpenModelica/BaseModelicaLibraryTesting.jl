//! base 0.1.0
package 'IMC_DCBraking'
  model 'IMC_DCBraking' "Induction machine with DC current braking"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'w0'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Initial mechanical speed";
    parameter Real 'JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 1.16 "Load's moment of inertia";
    Real 'tauElectrical'(unit = "N.m", quantity = "Torque") "Electrical torque";
    Real 'tauShaft'(unit = "N.m", quantity = "Torque") "Shaft torque";
    Real 'wMechanical'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") "Shaft speed";
    parameter Real 'settings.INominal'(unit = "A", quantity = "ElectricCurrent") = 100.0 "Nominal RMS current per phase";
    parameter String 'settings.layout' = "D3" "Braking connection layout";
    parameter String 'settings.terminalConnection' = "D" "Terminal connection";
    parameter Boolean 'settings.connect3' = true "Connect 3rd terminal";
    parameter Real 'settings.Idc'(unit = "A", quantity = "ElectricCurrent") = 244.9489742783178 "DC braking current";
    parameter Real 'settings.is[1]'(unit = "A", quantity = "ElectricCurrent") = 122.4744871391589 "Phase currents";
    parameter Real 'settings.is[2]'(unit = "A", quantity = "ElectricCurrent") = -122.4744871391589 "Phase currents";
    parameter Real 'settings.is[3]'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Phase currents";
    parameter Integer 'imcData.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'imcData.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Real 'imcData.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Integer 'imcData.p'(min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'imcData.fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'imcData.Rs'(unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'imcData.TsRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'imcData.alpha20s'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'imcData.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'imcData.Lszero'(unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator zero sequence inductance";
    parameter Real 'imcData.Lssigma'(unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator stray inductance per phase";
    parameter Real 'imcData.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'imcData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'imcData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'imcData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'imcData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'imcData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'imcData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'imcData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'imcData.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'imcData.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'imcData.statorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'imcData.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'imcData.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'imcData.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'imcData.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'imcData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'imcData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'imcData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'imcData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'imcData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'imcData.Lm'(unit = "H", quantity = "Inductance") = 0.009225332222963813 "Stator main field inductance per phase";
    parameter Real 'imcData.Lrsigma'(unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Rotor stray inductance per phase (equivalent three-phase winding)";
    parameter Real 'imcData.Rr'(unit = "Ohm", quantity = "Resistance") = 0.04 "Rotor resistance per phase (equivalent three-phase winding) at TRef";
    parameter Real 'imcData.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of rotor resistance";
    parameter Real 'imcData.alpha20r'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of rotor resistance at 20 degC";
    parameter Integer 'imc.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'imc.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'imc.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'imc.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
