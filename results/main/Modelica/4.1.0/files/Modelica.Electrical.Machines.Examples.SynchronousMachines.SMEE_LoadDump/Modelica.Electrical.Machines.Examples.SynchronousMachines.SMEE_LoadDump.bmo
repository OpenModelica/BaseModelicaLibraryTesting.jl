    Real 'smee.rs.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.rs.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smee.rs.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smee.rs.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smee.rs.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
