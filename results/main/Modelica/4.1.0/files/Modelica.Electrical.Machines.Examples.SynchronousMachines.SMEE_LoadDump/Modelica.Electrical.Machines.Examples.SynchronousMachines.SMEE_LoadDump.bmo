    parameter Integer 'smee.rs.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smee.rs.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
