    Real 'smee.rs.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'smee.rs.R[1]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.030000000995873476 "Resistances R_ref at temperatures T_ref";
    parameter Real 'smee.rs.R[2]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.030000000995873476 "Resistances R_ref at temperatures T_ref";
    parameter Real 'smee.rs.R[3]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.030000000995873476 "Resistances R_ref at temperatures T_ref";
    parameter Real 'smee.rs.T_ref[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'smee.rs.T_ref[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'smee.rs.T_ref[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'smee.rs.alpha[1]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Real 'smee.rs.alpha[2]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Real 'smee.rs.alpha[3]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Integer 'smee.rs.mh'(min = 1) = 3 "Number of heatPorts=number of phases";
    parameter Boolean 'smee.rs.useHeatPort' = true "= true, if all heat ports are enabled" annotation(Evaluate = true);
    parameter Real 'smee.rs.T[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'smee.rs.T[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'smee.rs.T[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    Real 'smee.rs.heatPort[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'smee.rs.heatPort[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'smee.rs.heatPort[2].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
