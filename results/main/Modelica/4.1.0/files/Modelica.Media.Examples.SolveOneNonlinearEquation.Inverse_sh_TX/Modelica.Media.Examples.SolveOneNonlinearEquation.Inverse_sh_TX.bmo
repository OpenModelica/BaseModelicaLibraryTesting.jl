//! base 0.1.0
package 'Inverse_sh_TX'
  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_psX' "Return thermodynamic state as function of p, s and composition X"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output 'Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 0 then 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX'('p', 's', {0.768, 0.232, 0.0, 0.0}), {0.768, 0.232, 0.0, 0.0}) else if size('X', 1) == 4 then 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX'('p', 's', 'X'), 'X') else 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_psX'('p', 's', 'X'), cat(1, 'X', {1.0 - sum('X')}));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_psX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_phX' "Return thermodynamic state as function of p, h and composition X"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(nominal = 1e5, start = 3e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output 'Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 0 then 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX'('h', {0.768, 0.232, 0.0, 0.0}, true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0), {0.768, 0.232, 0.0, 0.0}) else if size('X', 1) == 4 then 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX'('h', 'X', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0), 'X') else 'Medium.ThermodynamicState'('p', 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.T_hX'('h', 'X', true, 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy'.'ZeroAt0K', 0.0), cat(1, 'X', {1.0 - sum('X')}));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_phX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX' "Return thermodynamic state as function of p, T and composition X"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[:] 'X'(nominal = fill(0.1, size('X', 1)), max = fill(1.0, size('X', 1)), min = fill(0.0, size('X', 1)), unit = fill("kg/kg", size('X', 1)), quantity = fill("MassFraction", size('X', 1))) = {0.768, 0.232, 0.0, 0.0};
    output 'Medium.ThermodynamicState' 'state';
  algorithm
    'state' := if size('X', 1) == 0 then 'Medium.ThermodynamicState'('p', 'T', {0.768, 0.232, 0.0, 0.0}) else if size('X', 1) == 4 then 'Medium.ThermodynamicState'('p', 'T', 'X') else 'Medium.ThermodynamicState'('p', 'T', cat(1, 'X', {1.0 - sum('X')}));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX';

  function 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropyOfpTX' "Return specific entropy from pressure, temperature and mass fractions"
    input Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real[4] 'X'(nominal = {0.1, 0.1, 0.1, 0.1}, max = {1.0, 1.0, 1.0, 1.0}, min = {0.0, 0.0, 0.0, 0.0}, unit = {"kg/kg", "kg/kg", "kg/kg", "kg/kg"}, quantity = {"MassFraction", "MassFraction", "MassFraction", "MassFraction"});
    output Real 's'(nominal = 1000.0, max = 1e7, min = -1e7, unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real[4] 'Y'(each unit = "mol/mol") = 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.massToMoleFractions'('X', {0.0280134, 0.0319988, 0.01801528, 0.0440095});
  algorithm
    's' := 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.s_TX'('T', 'X') - ('X'[1] * 8.31446261815324 / 0.0280134 * (if 'X'[1] < 2.220446049250313e-16 then 'Y'[1] else 'Modelica.Math.log'('Y'[1] * 'p' / 101325.0)) + 'X'[2] * 8.31446261815324 / 0.0319988 * (if 'X'[2] < 2.220446049250313e-16 then 'Y'[2] else 'Modelica.Math.log'('Y'[2] * 'p' / 101325.0)) + 'X'[3] * 8.31446261815324 / 0.01801528 * (if 'X'[3] < 2.220446049250313e-16 then 'Y'[3] else 'Modelica.Math.log'('Y'[3] * 'p' / 101325.0)) + 'X'[4] * 8.31446261815324 / 0.0440095 * (if 'X'[4] < 2.220446049250313e-16 then 'Y'[4] else 'Modelica.Math.log'('Y'[4] * 'p' / 101325.0)));
    annotation(Inline = true, smoothOrder = 2);
  end 'Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.specificEntropyOfpTX';

  record 'Medium.ThermodynamicState'
    Real 'p'(nominal = 1e6, start = 1e6, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 500.0, start = 500.0, max = 6000.0, min = 200.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real[4] 'X'(nominal = fill(0.1, 4), start = {0.768, 0.232, 0.0, 0.0}, max = fill(1.0, 4), min = fill(0.0, 4), unit = fill("kg/kg", 4), quantity = fill("MassFraction", 4));
  end 'Medium.ThermodynamicState';

  type 'Modelica.Media.Interfaces.Choices.ReferenceEnthalpy' = enumeration('ZeroAt0K', 'ZeroAt25C', 'UserDefined');

  model 'Inverse_sh_TX' "Solve h = h_TX(TX) for T, if h is given for ideal gas NASA"
    parameter Real 'T_min'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.0 "Vary temperature linearly from T_min (time=0) up to T_max (time=1)";
    parameter Real 'T_max'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 500.0 "Vary temperature linearly from T_min (time=0) up to T_max (time=1)";
    parameter Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Fixed pressure in model";
    parameter Real 'h_min'(unit = "J/kg", quantity = "SpecificEnergy") = 302499.2070626019 "Specific enthalpy at T_min";
    parameter Real 'h_max'(unit = "J/kg", quantity = "SpecificEnergy") = 506796.354985627 "Specific enthalpy at T_max";
    parameter Real 's_min'(unit = "J/(kg.K)", quantity = "SpecificEntropy") = 6898.317128785827 "Specific entropy at T_min";
    parameter Real 's_max'(unit = "J/(kg.K)", quantity = "SpecificEntropy") = 7419.588064899617 "Specific entropy at T_max";
    Real 'h1'(fixed = true, start = 302499.2070626019, unit = "J/kg", quantity = "SpecificEnergy") "Pre-defined specific enthalpy";
    Real 'h2'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy computed from Th (= h1 required)";
    Real 's1'(fixed = true, start = 6898.317128785827, unit = "J/(kg.K)", quantity = "SpecificEntropy") "Pre-defined specific entropy";
    Real 's2'(unit = "J/(kg.K)", quantity = "SpecificEntropy") "Specific entropy computed from Ts (= s1 required)";
    Real 'Th'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature computed from h1";
    Real 'Ts'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature computed from s1";
    parameter Real 'X[1]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.768 "Mass fraction vector";
    parameter Real 'X[2]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.232 "Mass fraction vector";
    parameter Real 'X[3]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.0 "Mass fraction vector";
    parameter Real 'X[4]'(max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") = 0.0 "Mass fraction vector";
    constant Real 'timeUnit'(unit = "s", quantity = "Time") = 1.0;
  equation
    der('h1') = if time < 1.0 then 204297.14792302507 else 0.0;
    der('s1') = if time < 1.0 then 521.2709361137904 else 0.0;
    'Th' = ('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_phX'(1e5, 'h1', {0.768, 0.232, 0.0, 0.0})).T;
    'Ts' = ('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_psX'(1e5, 's1', {0.768, 0.232, 0.0, 0.0})).T;
    'h2' = ('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'(1e5, 'Th', {0.768, 0.232, 0.0, 0.0})).X * {smooth(0, (if ('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'(1e5, 'Th', {0.768, 0.232, 0.0, 0.0})).T < ({1000.0, 1000.0, 1000.0, 1000.0})['i'] then ({296.80474344420884, 259.8381814318037, 461.5254384056201, 188.92534566400437})['i'] * ((('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'(1e5, 'Th', {0.768, 0.232, 0.0, 0.0})).T * (({{710.846086, -10.76003744}, {-3391.45487, 18.4969947}, {-33039.7431, 17.24205775}, {-45281.9846, -7.04827944}})['i',1] + ({{22103.71497, -381.846182, 6.08273836, -0.00853091441, 1.384646189e-5, -9.62579362e-9, 2.519705809e-12}, {-34255.6342, 484.700097, 1.119010961, 0.00429388924, -6.83630052e-7, -2.0233727e-9, 1.039040018e-12}, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {49436.5054, -626.411601, 5.30172524, 0.002503813816, -2.127308728e-7, -7.68998878e-10, 2.849677801e-13}})['i',2] * log(('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'(1e5, 'Th', {0.768, 0.232, 0.0, 0.0})).T) + ('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'(1e5, 'Th', {0.768, 0.232, 0.0, 0.0})).T * (({{22103.71497, -381.846182, 6.08273836, -0.00853091441, 1.384646189e-5, -9.62579362e-9, 2.519705809e-12}, {-34255.6342, 484.700097, 1.119010961, 0.00429388924, -6.83630052e-7, -2.0233727e-9, 1.039040018e-12}, {-39479.6083, 575.573102, 0.931782653, 0.00722271286, -7.34255737e-6, 4.95504349e-9, -1.336933246e-12}, {49436.5054, -626.411601, 5.30172524, 0.002503813816, -2.127308728e-7, -7.68998878e-10, 2.849677801e-13}})['i',3] + ('Modelica.Media.Examples.SolveOneNonlinearEquation.Inverse_sh_TX.Medium.setState_pTX'(1e5, 'Th', {0.768, 0.232, 0.0, 0.0})).T * (0.5 * ({{22103.71497, -381.846182, 6.08273836, -0.00853091441, 1.384646189