    Real 'R2.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'IdealGTOThyristor2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'IdealGTOThyristor2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'IdealGTOThyristor2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'IdealGTOThyristor2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'IdealGTOThyristor2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'IdealGTOThyristor2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'IdealGTOThyristor2.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'IdealGTOThyristor2.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'IdealGTOThyristor2.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 1.0 "Forward threshold voltage";
    parameter Boolean 'IdealGTOThyristor2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'IdealGTOThyristor2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'IdealGTOThyristor2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'IdealGTOThyristor2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'IdealGTOThyristor2.off'(fixed = true, start = true) "Switching state";
    Real 'IdealGTOThyristor2.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'IdealGTOThyristor2.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'IdealGTOThyristor2.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Boolean 'IdealGTOThyristor2.fire';
    parameter Real 'R4.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.001 "Resistance at temperature T_ref";
    parameter Real 'R4.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'R4.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'R4.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'R4.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'R4.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'R4.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'R4.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'R4.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'R4.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'R4.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'R4.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'R4.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'R4.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'booleanPulse.width'(max = 100.0, min = 2.2250738585072014e-308) = 20.0 "Width of pulse in % of period";
    parameter Real 'booleanPulse.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 1.0 "Time for one period";
    parameter Real 'booleanPulse.startTime'(unit = "s", quantity = "Time") = 0.15 "Time instant of first pulse";
    Boolean 'booleanPulse.y' "Connector of Boolean output signal";
    parameter Real 'booleanPulse.Twidth'(unit = "s", quantity = "Time") = 0.2 "Width of one pulse";
    discrete Real 'booleanPulse.pulseStart'(unit = "s", quantity = "Time") "Start time of pulse";
  initial equation
    'booleanPulse.pulseStart' = 0.15;
  equation
    'booleanStep1.combiTimeTable.y[1]' = 'booleanStep1.realToBoolean.u';
    'booleanStep1.realToBoolean.y' = 'booleanStep1.y';
    'IdealThyristor1.n.v' = 'R3.p.v';
    'IdealGTOThyristor1.n.v' = 'R1.p.v';
    'R2.n.v' = 'R1.n.v';
    'R2.n.v' = 'R4.n.v';
    'R2.n.v' = 'Ground1.p.v';
    'R2.n.v' = 'R3.n.v';
    'R2.n.v' = 'SineVoltage1.n.v';
    'IdealThyristor1.fire' = 'booleanStep1.y';
    'IdealThyristor1.fire' = 'IdealGTOThyristor1.fire';
    'IdealThyristor2.n.v' = 'R2.p.v';
    'IdealGTOThyristor2.n.v' = 'R4.p.v';
    'SineVoltage1.p.v' = 'IdealThyristor2.p.v';
    'SineVoltage1.p.v' = 'IdealGTOThyristor2.p.v';
    'SineVoltage1.p.v' = 'IdealGTOThyristor1.p.v';
    'SineVoltage1.p.v' = 'IdealThyristor1.p.v';
    'booleanPulse.y' = 'IdealThyristor2.fire';
    'booleanPulse.y' = 'IdealGTOThyristor2.fire';
    'R3.p.i' + 'IdealThyristor1.n.i' = 0.0;
    'R4.n.i' + 'R2.n.i' + 'R1.n.i' + 'R3.n.i' + 'Ground1.p.i' + 'SineVoltage1.n.i' = 0.0;
    'R1.p.i' + 'IdealGTOThyristor1.n.i' = 0.0;
    'R2.p.i' + 'IdealThyristor2.n.i' = 0.0;
    'IdealGTOThyristor2.p.i' + 'IdealThyristor2.p.i' + 'IdealGTOThyristor1.p.i' + 'SineVoltage1.p.i' + 'IdealThyristor1.p.i' = 0.0;
    'R4.p.i' + 'IdealGTOThyristor2.n.i' = 0.0;
    'IdealThyristor1.off' = 'IdealThyristor1.s' < 0.0 or pre('IdealThyristor1.off') and not 'IdealThyristor1.fire';
    'IdealThyristor1.v' = 'IdealThyristor1.s' * (if 'IdealThyristor1.off' then 1.0 else 1e-5) + 1.0;
    'IdealThyristor1.i' = 'IdealThyristor1.s' * (if 'IdealThyristor1.off' then 1e-5 else 1.0) + 1e-5;
    'IdealThyristor1.LossPower' = 'IdealThyristor1.v' * 'IdealThyristor1.i';
    'IdealThyristor1.T_heatPort' = 293.15;
    0.0 = 'IdealThyristor1.p.i' + 'IdealThyristor1.n.i';
    'IdealThyristor1.i' = 'IdealThyristor1.p.i';
    'IdealThyristor1.v' = 'IdealThyristor1.p.v' - 'IdealThyristor1.n.v';
    'SineVoltage1.signalSource.y' = if time < 0.0 then 0.0 else 10.0 * 'Modelica.Math.sin'(6.283185307179586 * time);
    'SineVoltage1.v' = 'SineVoltage1.signalSource.y';
    0.0 = 'SineVoltage1.p.i' + 'SineVoltage1.n.i';
    'SineVoltage1.i' = 'SineVoltage1.p.i';
    'SineVoltage1.v' = 'SineVoltage1.p.v' - 'SineVoltage1.n.v';
    'Ground1.p.v' = 0.0;
    'R3.R_actual' = 0.001;
    'R3.v' = 'R3.R_actual' * 'R3.i';
    'R3.LossPower' = 'R3.v' * 'R3.i';
    'R3.T_heatPort' = 300.15;
    0.0 = 'R3.p.i' + 'R3.n.i';
    'R3.i' = 'R3.p.i';
    'R3.v' = 'R3.p.v' - 'R3.n.v';
    'IdealGTOThyristor1.off' = 'IdealGTOThyristor1.s' < 0.0 or not 'IdealGTOThyristor1.fire';
    'IdealGTOThyristor1.v' = 'IdealGTOThyristor1.s' * (if 'IdealGTOThyristor1.off' then 1.0 else 1e-5) + 1.0;
    'IdealGTOThyristor1.i' = 'IdealGTOThyristor1.s' * (if 'IdealGTOThyristor1.off' then 1e-5 else 1.0) + 1e-5;
    'IdealGTOThyristor1.LossPower' = 'IdealGTOThyristor1.v' * 'IdealGTOThyristor1.i';
    'IdealGTOThyristor1.T_heatPort' = 293.15;
    0.0 = 'IdealGTOThyristor1.p.i' + 'IdealGTOThyristor1.n.i';
    'IdealGTOThyristor1.i' = 'IdealGTOThyristor1.p.i';
    'IdealGTOThyristor1.v' = 'IdealGTOThyristor1.p.v' - 'IdealGTOThyristor1.n.v';
    'R1.R_actual' = 0.001;
    'R1.v' = 'R1.R_actual' * 'R1.i';
    'R1.LossPower' = 'R1.v' * 'R1.i';
    'R1.T_heatPort' = 300.15;
    0.0 = 'R1.p.i' + 'R1.n.i';
    'R1.i' = 'R1.p.i';
    'R1.v' = 'R1.p.v' - 'R1.n.v';
    'booleanStep1.combiTimeTable.timeScaled' = time;

    when {time >= pre('booleanStep1.combiTimeTable.nextTimeEvent'), initial()} then
      'booleanStep1.combiTimeTable.nextTimeEventScaled' = 'Modelica.Blocks.Tables.Internal.getNextTimeEvent'('booleanStep1.combiTimeTable.tableID', 'booleanStep1.combiTimeTable.timeScaled');
      'booleanStep1.combiTimeTable.nextTimeEvent' = if 'booleanStep1.combiTimeTable.nextTimeEventScaled' < 1e60 then 'booleanStep1.combiTimeTable.nextTimeEventScaled' else 1e60;
    end when;

    'booleanStep1.combiTimeTable.y[1]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer'('booleanStep1.combiTimeTable.tableID', 1, 'booleanStep1.combiTimeTable.timeScaled', 'booleanStep1.combiTimeTable.nextTimeEventScaled', pre('booleanStep1.combiTimeTable.nextTimeEventScaled'));
    'booleanStep1.realToBoolean.y' = 'booleanStep1.realToBoolean.u' >= 0.5;
    'IdealThyristor2.off' = 'IdealThyristor2.s' < 0.0 or pre('IdealThyristor2.off') and not 'IdealThyristor2.fire';
    'IdealThyristor2.v' = 'IdealThyristor2.s' * (if 'IdealThyristor2.off' then 1.0 else 1e-5) + 1.0;
    'IdealThyristor2.i' = 'IdealThyristor2.s' * (if 'IdealThyristor2.off' then 1e-5 else 1.0) + 1e-5;
    'IdealThyristor2.LossPower' = 'IdealThyristor2.v' * 'IdealThyristor2.i';
    'IdealThyristor2.T_heatPort' = 293.15;
    0.0 = 'IdealThyristor2.p.i' + 'IdealThyristor2.n.i';
    'IdealThyristor2.i' = 'IdealThyristor2.p.i';
    'IdealThyristor2.v' = 'IdealThyristor2.p.v' - 'IdealThyristor2.n.v';
    'R2.R_actual' = 0.001;
    'R2.v' = 'R2.R_actual' * 'R2.i';
    'R2.LossPower' = 'R2.v' * 'R2.i';
    'R2.T_heatPort' = 300.15;
    0.0 = 'R2.p.i' + 'R2.n.i';
    'R2.i' = 'R2.p.i';
    'R2.v' = 'R2.p.v' - 'R2.n.v';
    'IdealGTOThyristor2.off' = 'IdealGTOThyristor2.s' < 0.0 or not 'IdealGTOThyristor2.fire';
    'IdealGTOThyristor2.v' = 'IdealGTOThyristor2.s' * (if 'IdealGTOThyristor2.off' then 1.0 else 1e-5) + 1.0;
    'IdealGTOThyristor2.i' = 'IdealGTOThyristor2.s' * (if 'IdealGTOThyristor2.off' then 1e-5 else 1.0) + 1e-5;
    'IdealGTOThyristor2.LossPower' = 'IdealGTOThyristor2.v' * 'IdealGTOThyristor2.i';
    'IdealGTOThyristor2.T_heatPort' = 293.15;
    0.0 = 'IdealGTOThyristor2.p.i' + 'IdealGTOThyristor2.n.i';
    'IdealGTOThyristor2.i' = 'IdealGTOThyristor2.p.i';
    'IdealGTOThyristor2.v' = 'IdealGTOThyristor2.p.v' - 'IdealGTOThyristor2.n.v';
    'R4.R_actual' = 0.001;
    'R4.v' = 'R4.R_actual' * 'R4.i';
    'R4.LossPower' = 'R4.v' * 'R4.i';
    'R4.T_heatPort' = 300.15;
    0.0 = 'R4.p.i' + 'R4.n.i';
    'R4.i' = 'R4.p.i';
    'R4.v' = 'R4.p.v' - 'R4.n.v';

    when sample(0.15, 1.0) then
      'booleanPulse.pulseStart' = time;
    end when;

    'booleanPulse.y' = time >= 'booleanPulse.pulseStart' and time < 'booleanPulse.pulseStart' + 0.2;
    annotation(experiment(StopTime = 6));
  end 'CharacteristicThyristors';
end 'CharacteristicThyristors';
