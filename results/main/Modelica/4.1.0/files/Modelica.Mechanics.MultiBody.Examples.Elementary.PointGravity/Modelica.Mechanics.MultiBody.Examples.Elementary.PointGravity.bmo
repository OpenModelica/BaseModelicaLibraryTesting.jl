    Real 'world.x_label.diameter'(min = 0.0, unit = "m", quantity = "Length") "Diameter of the cylinders defined by lines";
    Integer 'world.x_label.color[1]'(max = 255, min = 0) "Color of cylinders";
    Integer 'world.x_label.color[2]'(max = 255, min = 0) "Color of cylinders";
    Integer 'world.x_label.color[3]'(max = 255, min = 0) "Color of cylinders";
    Real 'world.x_label.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter Integer 'world.x_label.n' = 2 "Number of cylinders";
