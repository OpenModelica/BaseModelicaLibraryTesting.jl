    Real 'cell.cell.internalHeatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'cell.cell.internalHeatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'cell.multiSensor.pc.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'cell.multiSensor.pc.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'cell.multiSensor.nc.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'cell.multiSensor.nc.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'cell.multiSensor.pv.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'cell.multiSensor.pv.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'cell.multiSensor.nv.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'cell.multiSensor.nv.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'cell.multiSensor.i'(unit = "A", quantity = "ElectricCurrent") "Current as output signal";
    Real 'cell.multiSensor.v'(unit = "V", quantity = "ElectricPotential") "Voltage as output signal";
    Real 'cell.multiSensor.power'(unit = "W", quantity = "Power") "Instantaneous power as output signal";
    parameter Real 'cell.limIntegrator.k' = 5.555555555555556e-5 "Integrator gain";
    parameter Real 'cell.limIntegrator.outMax'(start = 1.0) = 0.999999999 "Upper limit of output";
    parameter Real 'cell.limIntegrator.outMin' = 1e-9 "Lower limit of output";
    parameter Boolean 'cell.limIntegrator.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'cell.limIntegrator.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'cell.limIntegrator.initType' = 'Modelica.Blocks.Types.Init'.'InitialOutput' "Type of initialization (1: no init, 2: steady state, 3/4: initial output)" annotation(Evaluate = true);
    parameter Boolean 'cell.limIntegrator.limitsAtInit' = true "= false, if limits are ignored during initialization (i.e., der(y)=k*u)" annotation(Evaluate = true);
    parameter Real 'cell.limIntegrator.y_start' = 0.1 "Initial or guess value of output (must be in the limits outMin .. outMax)";
    parameter Boolean 'cell.limIntegrator.strict' = false "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    Real 'cell.limIntegrator.u' "Connector of Real input signal";
    Real 'cell.limIntegrator.y' "Connector of Real output signal";
    Boolean 'cell.limIntegrator.local_reset';
    Real 'cell.limIntegrator.local_set';
    Real 'cell.temperatureSensor.T'(unit = "K") "Absolute temperature as output signal";
    Real 'cell.temperatureSensor.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'cell.temperatureSensor.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'cell.heatFlowSensor.Q_flow'(unit = "W") "Heat flow from port_a to port_b as output signal";
    Real 'cell.heatFlowSensor.port_a.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'cell.heatFlowSensor.port_a.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'cell.heatFlowSensor.port_b.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'cell.heatFlowSensor.port_b.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'cell.cellBus.v'(unit = "V", quantity = "ElectricPotential") "Cell voltage";
    Real 'cell.cellBus.i'(unit = "A", quantity = "ElectricCurrent") "Cell current";
    Real 'cell.cellBus.soc' "State of charge of cell";
    Real 'cell.cellBus.power'(unit = "W", quantity = "Power") "Cell power";
    Real 'cell.cellBus.lossPower'(unit = "W", quantity = "Power") "Cell losses";
    Real 'cell.cellBus.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Cell temperature";
    Real 'multiSensor.pc.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'multiSensor.pc.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'multiSensor.nc.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'multiSensor.nc.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'multiSensor.pv.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'multiSensor.pv.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'multiSensor.nv.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'multiSensor.nv.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'multiSensor.i'(unit = "A", quantity = "ElectricCurrent") "Current as output signal";
    Real 'multiSensor.v'(unit = "V", quantity = "ElectricPotential") "Voltage as output signal";
    Real 'multiSensor.power'(unit = "W", quantity = "Power") "Instantaneous power as output signal";
    parameter Real 'energy.k' = 1.0 "Integrator gain";
    parameter Boolean 'energy.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'energy.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'energy.initType' = 'Modelica.Blocks.Types.Init'.'InitialState' "Type of initialization (1: no init, 2: steady state, 3,4: initial output)" annotation(Evaluate = true);
    parameter Real 'energy.y_start' = 0.0 "Initial or guess value of output (= state)";
    Real 'energy.u'(unit = "W") "Connector of Real input signal";
    Real 'energy.y'(unit = "J") "Connector of Real output signal";
    Boolean 'energy.local_reset';
    Real 'energy.local_set';
  initial equation
    'cell.limIntegrator.y' = 0.1;
    'energy.y' = 0.0;
  equation
    'cell.displaySOC' = 'cell.SOC';
    'cell.i' = 'cell.p.i';
    'cell.power' = 'cell.v' * 'cell.i';
    'cell.SOC' = 'cell.limIntegrator.y';
    'cell.cell.displaySOC' = 'cell.cell.SOC';
    'cell.cell.i' = 'cell.cell.p.i';
    'cell.cell.power' = 'cell.cell.v' * 'cell.cell.i';
    'cell.cell.SOC' = 'cell.cell.limIntegrator.y';
    'cell.cell.selfDischarge.heatPort.T' = 'cell.cell.selfDischarge.T_heatPort';
    'cell.cell.selfDischarge.heatPort.Q_flow' = -'cell.cell.selfDischarge.LossPower';
    'cell.cell.r0.heatPort.T' = 'cell.cell.r0.T_heatPort';
    'cell.cell.r0.heatPort.Q_flow' = -'cell.cell.r0.LossPower';
    'cell.cell.r0.n.v' = 'cell.cell.n.v';
    'cell.cell.gainV.y' = 'cell.cell.ocv.v';
    'cell.cell.ocv_soc.y[1]' = 'cell.cell.gainV.u';
    'cell.cell.limIntegrator.y' = 'cell.cell.ocv_soc.u';
    'cell.cell.currentSensor.n.v' = 'cell.cell.ocv.p.v';
    'cell.cell.limIntegrator.u' = 'cell.cell.currentSensor.i';
    'cell.cell.currentSensor.p.v' = 'cell.cell.selfDischarge.p.v';
    'cell.cell.currentSensor.p.v' = 'cell.cell.p.v';
    'cell.cell.selfDischarge.p.i' + 'cell.cell.currentSensor.p.i' - 'cell.cell.p.i' = 0.0;
    'cell.cell.ocv.n.v' = 'cell.cell.selfDischarge.n.v';
    'cell.cell.ocv.n.v' = 'cell.cell.r0.p.v';
    'cell.cell.heatPort.T' = 'cell.cell.internalHeatPort.T';
    'cell.cell.heatPort.T' = 'cell.cell.r0.heatPort.T';
    'cell.cell.heatPort.T' = 'cell.cell.selfDischarge.heatPort.T';
    'cell.multiSensor.pc.v' = 'cell.multiSensor.pv.v';
    'cell.multiSensor.pc.v' = 'cell.p.v';
    'cell.multiSensor.pv.i' + 'cell.multiSensor.pc.i' - 'cell.p.i' = 0.0;
    'cell.multiSensor.nc.v' = 'cell.cell.p.v';
    'cell.n.v' = 'cell.multiSensor.nv.v';
    'cell.n.v' = 'cell.cell.n.v';
    'cell.multiSensor.i' = 'cell.cellBus.i';
    'cell.multiSensor.i' = 'cell.limIntegrator.u';
    'cell.fixedTemperature.port.T' = 'cell.internalHeatPort.T';
    'cell.fixedTemperature.port.T' = 'cell.heatFlowSensor.port_b.T';
    'cell.heatFlowSensor.port_a.T' = 'cell.temperatureSensor.port.T';
    'cell.heatFlowSensor.port_a.T' = 'cell.cell.heatPort.T';
    'ground.p.v' = 'multiSensor.nv.v';
    'ground.p.v' = 'cccvCharger.n.v';
    'ground.p.v' = 'cell.n.v';
    'multiSensor.pc.v' = 'multiSensor.pv.v';
    'multiSensor.pc.v' = 'cccvCharger.p.v';
    'multiSensor.nc.v' = 'cell.p.v';
    'multiSensor.power' = 'energy.u';
    'cell.limIntegrator.y' = 'cell.cellBus.soc';
    'cell.multiSensor.v' = 'cell.cellBus.v';
    'cell.multiSensor.power' = 'cell.cellBus.power';
    'cell.heatFlowSensor.Q_flow' = 'cell.cellBus.lossPower';
    'cell.temperatureSensor.T' = 'cell.cellBus.T';
    'multiSensor.pv.i' + 'multiSensor.pc.i' + 'cccvCharger.p.i' = 0.0;
    'multiSensor.nv.i' + 'cell.n.i' + 'ground.p.i' + 'cccvCharger.n.i' = 0.0;
    'cell.internalHeatPort.Q_flow' = 0.0;
    'cell.multiSensor.nv.i' + 'cell.cell.n.i' - 'cell.n.i' = 0.0;
    'cell.cell.ocv.p.i' + 'cell.cell.currentSensor.n.i' = 0.0;
    'cell.cell.r0.heatPort.Q_flow' + 'cell.cell.selfDischarge.heatPort.Q_flow' - 'cell.cell.heatPort.Q_flow' - 'cell.cell.internalHeatPort.Q_flow' = 0.0;
    'cell.cell.r0.p.i' + 'cell.cell.selfDischarge.n.i' + 'cell.cell.ocv.n.i' = 0.0;
    'cell.cell.r0.n.i' - 'cell.cell.n.i' = 0.0;
    'cell.heatFlowSensor.port_a.Q_flow' + 'cell.temperatureSensor.port.Q_flow' + 'cell.cell.heatPort.Q_flow' = 0.0;
    'cell.cell.internalHeatPort.Q_flow' = 0.0;
    'cell.multiSensor.nc.i' + 'cell.cell.p.i' = 0.0;
    'cell.heatFlowSensor.port_b.Q_flow' + 'cell.fixedTemperature.port.Q_flow' - 'cell.internalHeatPort.Q_flow' = 0.0;
    'multiSensor.nc.i' + 'cell.p.i' = 0.0;
    'cccvCharger.CV' = 'cccvCharger.v' >= 4.2;

    if 'cccvCharger.CV' then
      'cccvCharger.v' = 4.2;
    elseif true then
      'cccvCharger.i' = -25.0 * (if time < 0.0 then 0.0 else min(1.0, time / 60.0));
    end if;

    0.0 = 'cccvCharger.p.i' + 'cccvCharger.n.i';
    'cccvCharger.i' = 'cccvCharger.p.i';
    'cccvCharger.v' = 'cccvCharger.p.v' - 'cccvCharger.n.v';
    'ground.p.v' = 0.0;
    'cell.fixedTemperature.port.T' = 293.15;
    'cell.cell.currentSensor.p.v' = 'cell.cell.currentSensor.n.v';
    'cell.cell.currentSensor.p.i' = 'cell.cell.currentSensor.i';
    'cell.cell.currentSensor.n.i' = -'cell.cell.currentSensor.i';
    'cell.cell.limIntegrator.local_reset' = false;
    'cell.cell.limIntegrator.local_set' = 0.0;
    der('cell.cell.limIntegrator.y') = if 'cell.cell.limIntegrator.y' < 1e-9 and 5.555555555555556e-5 * 'cell.cell.limIntegrator.u' < 0.0 or 'cell.cell.limIntegrator.y' > 0.999999999 and 5.555555555555556e-5 * 'cell.cell.limIntegrator.u' > 0.0 then 0.0 else 5.555555555555556e-5 * 'cell.cell.limIntegrator.u';
    'cell.cell.ocv_soc.y[1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValue'('cell.cell.ocv_soc.tableID', 1, 'cell.cell.ocv_soc.u');
    'cell.cell.gainV.y' = 4.2 * 'cell.cell.gainV.u';
    'cell.cell.ocv.v' = 'cell.cell.ocv.p.v' - 'cell.cell.ocv.n.v';
    0.0 = 'cell.cell.ocv.p.i' + 'cell.cell.ocv.n.i';
    'cell.cell.ocv.i' = 'cell.cell.ocv.p.i';
    'cell.cell.selfDischarge.G_actual' = 2.380952380952381e-4;
    'cell.cell.selfDischarge.i' = 'cell.cell.selfDischarge.G_actual' * 'cell.cell.selfDischarge.v';
    'cell.cell.selfDischarge.LossPower' = 'cell.cell.selfDischarge.v' * 'cell.cell.selfDischarge.i';
    0.0 = 'cell.cell.selfDischarge.p.i' + 'cell.cell.selfDischarge.n.i';
    'cell.cell.selfDischarge.i' = 'cell.cell.selfDischarge.p.i';
    'cell.cell.selfDischarge.v' = 'cell.cell.selfDischarge.p.v' - 'cell.cell.selfDischarge.n.v';
    'cell.cell.r0.R_actual' = 0.0035;
    'cell.cell.r0.v' = 'cell.cell.r0.R_actual' * 'cell.cell.r0.i';
    'cell.cell.r0.LossPower' = 'cell.cell.r0.v' * 'cell.cell.r0.i';
    0.0 = 'cell.cell.r0.p.i' + 'cell.cell.r0.n.i';
    'cell.cell.r0.i' = 'cell.cell.r0.p.i';
    'cell.cell.r0.v' = 'cell.cell.r0.p.v' - 'cell.cell.r0.n.v';
    assert('cell.cell.cellData.SOCmax' > 'cell.cell.cellData.SOCmin', "Specify 0 <= SOCmin < SOCmax <= 1", AssertionLevel.error);
    assert('cell.cell.cellData.OCV_SOC[1,1]' >= 0.0, "Specify OCV(SOC) table with minimum SOC >= 0", AssertionLevel.error);
    assert('cell.cell.cellData.OCV_SOC[29,1]' <= 1.0, "Specify OCV(SOC) table with maximum SOC <= 1", AssertionLevel.error);
    assert('cell.cell.cellData.OCV_SOC[1,2]' >= 0.0, "Specify OCV(SOC) table with minimum OCV/OCVmax >= 0", AssertionLevel.error);
    assert('cell.cell.cellData.OCV_SOC[29,2]' <= 1.0, "Specify OCV(SOC) table with maximum OCV/OCVmax <= 1", AssertionLevel.error);
    assert('cell.cell.SOC' < 'cell.cell.cellData.SOCmax' + 1e-9, "Battery overcharged!", AssertionLevel.error);
    assert('cell.cell.SOC' > 'cell.cell.cellData.SOCmin' - 1e-9, "Battery exhausted!", AssertionLevel.error);
    'cell.cell.v' = 'cell.cell.p.v' - 'cell.cell.n.v';
    'cell.multiSensor.pc.i' + 'cell.multiSensor.nc.i' = 0.0;
    'cell.multiSensor.pc.v' - 'cell.multiSensor.nc.v' = 0.0;
    'cell.multiSensor.pv.i' = 0.0;
    'cell.multiSensor.nv.i' = 0.0;
    'cell.multiSensor.i' = 'cell.multiSensor.pc.i';
    'cell.multiSensor.v' = 'cell.multiSensor.pv.v' - 'cell.multiSensor.nv.v';
    'cell.multiSensor.power' = 'cell.multiSensor.v' * 'cell.multiSensor.i';
    'cell.limIntegrator.local_reset' = false;
    'cell.limIntegrator.local_set' = 0.0;
    der('cell.limIntegrator.y') = if 'cell.limIntegrator.y' < 1e-9 and 5.555555555555556e-5 * 'cell.limIntegrator.u' < 0.0 or 'cell.limIntegrator.y' > 0.999999999 and 5.555555555555556e-5 * 'cell.limIntegrator.u' > 0.0 then 0.0 else 5.555555555555556e-5 * 'cell.limIntegrator.u';
    'cell.temperatureSensor.T' = 'cell.temperatureSensor.port.T';
    'cell.temperatureSensor.port.Q_flow' = 0.0;
    'cell.heatFlowSensor.port_a.T' = 'cell.heatFlowSensor.port_b.T';
    'cell.heatFlowSensor.port_a.Q_flow' + 'cell.heatFlowSensor.port_b.Q_flow' = 0.0;
    'cell.heatFlowSensor.Q_flow' = 'cell.heatFlowSensor.port_a.Q_flow';
    'cell.v' = 'cell.p.v' - 'cell.n.v';
    'multiSensor.pc.i' + 'multiSensor.nc.i' = 0.0;
    'multiSensor.pc.v' - 'multiSensor.nc.v' = 0.0;
    'multiSensor.pv.i' = 0.0;
    'multiSensor.nv.i' = 0.0;
    'multiSensor.i' = 'multiSensor.pc.i';
    'multiSensor.v' = 'multiSensor.pv.v' - 'multiSensor.nv.v';
    'multiSensor.power' = 'multiSensor.v' * 'multiSensor.i';
    'energy.local_reset' = false;
    'energy.local_set' = 0.0;
    der('energy.y') = 'energy.u';
    annotation(experiment(StopTime = 1200, Interval = 0.1, Tolerance = 1e-06));
  end 'CCCV_Cell';
end 'CCCV_Cell';
