//! base 0.1.0
package 'ThyristorBridge2mPulse_DC_Drive'
  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'ThyristorBridge2mPulse_DC_Drive' "2*m pulse thyristor bridge feeding a DC drive"
    parameter Integer 'm'(min = 3) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'Vrms'(unit = "V", quantity = "ElectricPotential") = 42.75166100539547 "RMS supply voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Frequency";
    parameter Real 'SMains'(unit = "V.A", quantity = "Power") = 2.5e5 "Mains short circuit apparent power";
    parameter Real 'lamdaMains' = 0.1 "Mains short circuit power factor";
    parameter Real 'ZMains'(unit = "Ohm", quantity = "Resistance") = 0.021932454224643017 "Mains short circuit impedance";
    parameter Real 'RMains'(unit = "Ohm", quantity = "Resistance") = 0.0021932454224643017 "Mains resistance" annotation(Evaluate = true);
    parameter Real 'LMains'(unit = "H", quantity = "Inductance") = 6.946322717396206e-5 "Mains inductance" annotation(Evaluate = true);
    parameter Real 'Ld'(unit = "H", quantity = "Inductance") = 0.0045000000000000005 "Smoothing inductance" annotation(Evaluate = true);
    parameter Real 'tauNominal'(unit = "N.m", quantity = "Torque") = 63.66197723675815 "Nominal torque";
    output Real 'w'(displayUnit = "rpm", unit = "rad/s", quantity = "AngularVelocity") = 'dcpm.wMechanical';
    output Real 'tau'(unit = "N.m", quantity = "Torque") = 'dcpm.tauShaft';
