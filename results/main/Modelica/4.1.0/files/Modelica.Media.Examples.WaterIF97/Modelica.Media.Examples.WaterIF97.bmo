  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g2' "Gibbs function for region 2: g(p,T)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Boolean 'checkLimits' = true;
    output 'Modelica.Media.Common.GibbsDerivs' 'g';
    Real 'tau2';
    Real[55] 'o';
  algorithm
    'g'.'p' := 'p';
    'g'.'T' := 'T';
    'g'.'R_s' := 461.526;

    if 'checkLimits' then
      assert('p' > 0.0, "IF97 medium function g2 called with too low pressure\np = " + String('p') + " Pa <= 0.0 Pa", AssertionLevel.error);
      assert('p' <= 1e8, "IF97 medium function g2: the input pressure (= " + String('p') + " Pa) is higher than 100 MPa", AssertionLevel.error);
      assert('T' >= 273.15, "IF97 medium function g2: the temperature (= " + String('T') + " K) is lower than 273.15 K!", AssertionLevel.error);
      assert('T' <= 1073.15, "IF97 medium function g2: the input temperature (= " + String('T') + " K) is higher than the limit of 1073.15 K", AssertionLevel.error);
    end if;

    'g'.'pi' := 'p' / 1e6;
    'g'.'tau' := 540.0 / 'T';
    'tau2' := 'g'.'tau' - 0.5;
    'o'[1] := 'tau2' * 'tau2';
    'o'[2] := 'o'[1] * 'tau2';
    'o'[3] := -0.05032527872793 * 'o'[2];
    'o'[4] := 'o'[3] - 0.057581259083432;
    'o'[5] := 'o'[4] * 'tau2';
    'o'[6] := 'o'[5] - 0.045996013696365;
    'o'[7] := 'o'[6] * 'tau2';
    'o'[8] := 'o'[7] - 0.017834862292358;
    'o'[9] := 'o'[8] * 'tau2';
    'o'[10] := 'o'[1] * 'o'[1];
    'o'[11] := 'o'[10] * 'o'[10];
    'o'[12] := 'o'[11] * 'o'[11];
    'o'[13] := 'o'[10] * 'o'[11] * 'o'[12] * 'tau2';
    'o'[14] := 'o'[1] * 'o'[10] * 'tau2';
    'o'[15] := 'o'[10] * 'o'[11] * 'tau2';
    'o'[16] := 'o'[1] * 'o'[12] * 'tau2';
    'o'[17] := 'o'[1] * 'o'[11] * 'tau2';
    'o'[18] := 'o'[1] * 'o'[10] * 'o'[11];
    'o'[19] := 'o'[10] * 'o'[11] * 'o'[12];
    'o'[20] := 'o'[1] * 'o'[10];
    'o'[21] := 'g'.'pi' * 'g'.'pi';
    'o'[22] := 'o'[21] * 'o'[21];
    'o'[23] := 'o'[21] * 'o'[22];
    'o'[24] := 'o'[10] * 'o'[12] * 'tau2';
