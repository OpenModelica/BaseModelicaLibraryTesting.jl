11 * 'o'[10] * 'o'[13] * 'o'[6] * 'o'[7] * 'q2'))) / 'o'[1];
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hlowerofp2';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hlowerofp5' "Explicit lower specific enthalpy limit of region 5 as function of pressure"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pi';
  algorithm
    'pi' := 'p' / 1e6;
    assert('p' > 611.657, "IF97 medium function hlowerofp5 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'h' := 461526.0 * (9.01505286876203 + 'pi' * ((3.36540214679088e-7 * 'pi' - 2.03245575263501e-5) * 'pi' - 0.00979043490246092));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hlowerofp5';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp1' "Explicit upper specific enthalpy limit of region 1 as function of pressure (meets region 4 saturation pressure curve at 623.15 K)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pi1';
    Real[3] 'o';
  algorithm
    'pi1' := 7.1 - 'p' / 1.653e7;
    assert('p' > 611.657, "IF97 medium function hupperofp1 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'o'[1] := 'pi1' * 'pi1';
    'o'[2] := 'o'[1] * 'o'[1];
    'o'[3] := 'o'[2] * 'o'[2];
    'h' := 639675.036 * (2.42896927729349 + 'pi1' * ('pi1' * (0.00143759406818289 + 'pi1' * (1.25338925082983e-4 + 'pi1' * (1.23617764767172e-5 + 'pi1' * (3.17834967400818e-6 + 'o'[1] * 'pi1' * (1.46754947271665e-8 + 'o'[2] * 'o'[3] * 'pi1' * (1.86779322717506e-17 + 'o'[1] * ('o'[1] * 'o'[2] * ('pi1' * (4.27026404402408e-22 + (3.49930466305574e-24 * 'pi1' - 6.66749357417962e-23) * 'pi1') - 9.19148577641497e-22) - 4.18568363667416e-19))))))) - 0.00141131225285294));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp1';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp2' "Explicit upper specific enthalpy limit of region 2 as function of pressure"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pi';
    Real[2] 'o';
  algorithm
    'pi' := 'p' / 1e6;
    assert('p' > 611.657, "IF97 medium function hupperofp2 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'o'[1] := 'pi' * 'pi';
    'o'[2] := 'o'[1] * 'o'[1] * 'o'[1];
    'h' := 4.16066337647071e6 + 'pi' * ('pi' * ('pi' * (0.109090430596056 + 'pi' * ('pi' * (4.2261295097284e-15 + 'pi' * ('pi' * ('pi' * (7.56960433802525e-23 + 'pi' * (7.16825117265975e-32 + 'pi' * (3.37267475986401e-21 + ('o'[1] * ((1.6746290980312e-65 + 'pi' * ('pi' * (8.06630589170884e-129 + (1.88543121025106e-84 * 'pi' - 1.76117969553159e-103) * 'pi') - 3.71600586812966e-69)) * 'o'[1] - 8.00969737237617e-134) - 7.5656940729795e-74) * 'o'[2]))) - 3.79407294691742e-25) - 1.27295130636232e-10)) - 1.72486052272327e-4)) - 8.53409968320258) - 4518.48617188327);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp2';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp5' "Explicit upper specific enthalpy limit of region 5 as function of pressure"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pi';
  algorithm
    'pi' := 'p' / 1e6;
    assert('p' > 611.657, "IF97 medium function hupperofp5 called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'h' := 461526.0 * (15.9838891400332 + 'pi' * ((7.5006972718273e-8 * 'pi' - 5.01510211858761e-8) * 'pi' - 4.89898813722568e-4));
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp5';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hv_p_R4b' "Explicit approximation of vapour specific enthalpy on the boundary between regions 4 and 3"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'x';
  algorithm
    'x' := acos('p' / 2.2064e7);
    'h' := (1.0 + 'x' * (0.4880153718655694 + 'x' * (0.2079670746250689 + 'x' * ('x' * (25.08887602293532 + 'x' * ('x' * (45.66489164833212 + (6.616936460057692e-4 * 'x' - 16.98555442961553) * 'x') - 48.38215180269516)) - 6.084122698421623)))) * 2.08754684511715e6;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hv_p_R4b';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p'
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input 'Modelica.Media.Common.IF97PhaseBoundaryProperties' 'bpro';
    output Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    'h' := 'bpro'.'h';
    annotation(derivative(order = 1, noDerivative = 'bpro') = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p_der', Inline = false, LateInline = true);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p_der' "Derivative function for the specific enthalpy along the phase boundary"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input 'Modelica.Media.Common.IF97PhaseBoundaryProperties' 'bpro';
    input Real 'p_der';
    output Real 'h_der';
  algorithm
    if 'bpro'.'region3boundary' then
      'h_der' := (('bpro'.'d' * 'bpro'.'pd' - 'bpro'.'T' * 'bpro'.'pt') * 'p_der' + ('bpro'.'T' * 'bpro'.'pt' * 'bpro'.'pt' + 'bpro'.'d' * 'bpro'.'d' * 'bpro'.'pd' * 'bpro'.'cv') / 'bpro'.'dpT' * 'p_der') / ('bpro'.'pd' * 'bpro'.'d' * 'bpro'.'d');
    elseif true then
      'h_der' := (1.0 / 'bpro'.'d' - 'bpro'.'T' * 'bpro'.'vt') * 'p_der' + 'bpro'.'cp' / 'bpro'.'dpT' * 'p_der';
    end if;
    annotation(Inline = true);
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p_der';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_pT' "Return the current region (valid values: 1,2,3,5) in IF97, given pressure and temperature"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Integer 'mode' = 0;
    output Integer 'region';
  algorithm
    if 'mode' <> 0 then
      'region' := 'mode';
    elseif true then
      if 'p' < 1.65292e7 then
        if 'T' > 1073.15 then
          'region' := 5;
        elseif 'T' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('p') then
          'region' := 2;
        elseif true then
          'region' := 1;
        end if;
      elseif true then
        if 'T' < 623.15 then
          'region' := 1;
        elseif 'T' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boundary23ofp'('p') then
          'region' := 3;
        elseif true then
          'region' := 2;
        end if;
      end if;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_pT';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_ph' "Return the current region (valid values: 1,2,3,4,5) in IF97 for given pressure and specific enthalpy"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase' = 0;
    input Integer 'mode' = 0;
    output Integer 'region';
    Boolean 'hsubcrit';
    Real 'Ttest'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    constant Real[5] 'n' = {348.05185628969, -1.1671859879975, 0.0010192970039326, 572.54459862746, 13.91883977887};
    Real 'hl'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'hv'(unit = "J/kg", quantity = "SpecificEnergy");
  algorithm
    if 'mode' <> 0 then
      'region' := 'mode';
    elseif true then
      'hl' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p'('p', 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boilingcurve_p'('p'));
      'hv' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p'('p', 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p'('p'));

      if 'phase' == 2 then
        'region' := 4;
      elseif true then
        if ((('p' < 611.657 or 'p' > 1e8) or 'h' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hlowerofp1'('p')) or 'p' < 1e7 and 'h' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp5'('p')) or 'p' >= 1e7 and 'h' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp2'('p') then
          'region' := -1;
        elseif true then
          'hsubcrit' := 'h' < 2.08754684511715e6;

          if 'p' < 1.65292e7 then
            if 'hsubcrit' then
              if 'phase' == 1 then
                'region' := 1;
              elseif true then
                if 'h' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Isentropic.hofpT1'('p', 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('p')) then
                  'region' := 1;
                elseif true then
                  'region' := 4;
                end if;
              end if;
            elseif true then
              if 'h' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hlowerofp5'('p') then
                if 'p' < 1e7 and 'h' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp5'('p') then
                  'region' := 5;
                elseif true then
                  'region' := -2;
                end if;
              elseif true then
                if 'phase' == 1 then
                  'region' := 2;
                elseif true then
                  if 'h' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Isentropic.hofpT2'('p', 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('p')) then
                    'region' := 2;
                  elseif true then
                    'region' := 4;
                  end if;
                end if;
              end if;
            end if;
          elseif true then
            if 'hsubcrit' then
              if 'h' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hupperofp1'('p') then
                'region' := 1;
              elseif true then
                if 'h' < 'hl' or 'p' > 2.2064e7 then
                  'region' := 3;
                elseif true then
                  'region' := 4;
                end if;
              end if;
            elseif true then
              if 'h' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hlowerofp2'('p') then
                'region' := 2;
              elseif true then
                if 'h' > 'hv' or 'p' > 2.2064e7 then
                  'region' := 3;
                elseif true then
                  'region' := 4;
                end if;
              end if;
            end if;
          end if;
        end if;
      end if;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_ph';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_T' "Density of saturated water"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat'('T');

    if 'T' < 623.15 then
      'd' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.d1n'('p', 'T');
    elseif 'T' < 647.096 then
      'd' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b'('p');
    elseif true then
      'd' := 322.0;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_T';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b' "Explicit approximation of liquid density on the boundary between regions 4 and 3"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'dl'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'x';
  algorithm
    if 'p' < 2.2064e7 then
      'x' := acos('p' / 2.2064e7);
      'dl' := (1.0 + 'x' * (1.903224079094824 + 'x' * ('x' * ('x' * (94.34196116778385 + 'x' * ('x' * (796.6627910598293 + 'x' * ('x' * (673.2581177021598 + (5.2536560808895e-4 * 'x' - 191.43077336405156) * 'x') - 994.5385383600702)) - 369.3676833623383)) - 8.191449323843552) - 2.5314861802401123))) * 322.0;
    elseif true then
      'dl' := 322.0;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_T' "Density of saturated vapour"
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  algorithm
    'p' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.psat'('T');

    if 'T' < 623.15 then
      'd' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.d2n'('p', 'T');
    elseif 'T' < 647.096 then
      'd' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b'('p');
    elseif true then
      'd' := 322.0;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_T';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b' "Explicit approximation of vapour density on the boundary between regions 4 and 2"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 'dv'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'x';
  algorithm
    if 'p' < 2.2064e7 then
      'x' := acos('p' / 2.2064e7);
      'dv' := (1.0 + 'x' * ('x' * ('x' * (59.18702203076563 + 'x' * ('x' * (1437.2007245332388 + 'x' * ('x' * (3740.5790348670057 + 'x' * ((725.8761975803782 - 0.0011151111658332337 * 'x') * 'x' - 2537.375817253895)) - 3015.853540307519)) - 403.5391431811611)) - 1.1447872718878493) - 1.8463850803362596)) * 322.0;
    elseif true then
      'dv' := 322.0;
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b';

  record 'Modelica.Media.Common.IF97PhaseBoundaryProperties'
    Boolean 'region3boundary';
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 's'(unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real 'cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'dpT'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'pt'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'pd'(unit = "Pa.m3/kg", quantity = "DerPressureByDensity");
    Real 'vt'(unit = "m3/(kg.K)");
    Real 'vp'(unit = "m3/(kg.Pa)");
  end 'Modelica.Media.Common.IF97PhaseBoundaryProperties';

  record 'Modelica.Media.Common.IF97BaseTwoPhase'
    Integer 'phase'(start = 0);
    Integer 'region'(max = 5, min = 1);
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 's'(unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real 'pt'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'pd'(unit = "Pa.m3/kg", quantity = "DerPressureByDensity");
    Real 'vt';
    Real 'vp';
    Real 'x';
    Real 'dpT';
  end 'Modelica.Media.Common.IF97BaseTwoPhase';

  record 'Medium.ThermodynamicState'
    Integer 'phase'(max = 2, min = 0);
    Real 'h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy");
    Real 'd'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure");
  end 'Medium.ThermodynamicState';

  record 'Modelica.Media.Common.GibbsDerivs'
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'pi'(unit = "1");
    Real 'tau'(unit = "1");
    Real 'g'(unit = "1");
    Real 'gpi'(unit = "1");
    Real 'gpipi'(unit = "1");
    Real 'gtau'(unit = "1");
    Real 'gtautau'(unit = "1");
    Real 'gtaupi'(unit = "1");
  end 'Modelica.Media.Common.GibbsDerivs';

  record 'Modelica.Media.Common.HelmholtzDerivs'
    Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'delta'(unit = "1");
    Real 'tau'(unit = "1");
    Real 'f'(unit = "1");
    Real 'fdelta'(unit = "1");
    Real 'fdeltadelta'(unit = "1");
    Real 'ftau'(unit = "1");
    Real 'ftautau'(unit = "1");
    Real 'fdeltatau'(unit = "1");
  end 'Modelica.Media.Common.HelmholtzDerivs';

  record 'Modelica.Media.Common.NewtonDerivatives_pT'
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'pd'(unit = "Pa.m3/kg", quantity = "DerPressureByDensity");
  end 'Modelica.Media.Common.NewtonDerivatives_pT';

  record 'Modelica.Media.Common.NewtonDerivatives_ph'
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'pd'(unit = "Pa.m3/kg", quantity = "DerPressureByDensity");
    Real 'pt'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'hd';
    Real 'ht';
  end 'Modelica.Media.Common.NewtonDerivatives_ph';

  record 'Modelica.Media.Common.PhaseBoundaryProperties'
    Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'u'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 's'(unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real 'cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'pt'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'pd'(unit = "Pa.m3/kg", quantity = "DerPressureByDensity");
  end 'Modelica.Media.Common.PhaseBoundaryProperties';

  model 'WaterIF97' "WaterIF97 medium model"
    Real 'medium.p'(stateSelect = StateSelect.prefer, nominal = 1e5, fixed = true, start = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'medium.h'(stateSelect = StateSelect.prefer, fixed = true, start = 1e5, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'medium.d'(stateSelect = StateSelect.default, nominal = 500.0, start = 999.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'medium.T'(stateSelect = StateSelect.default, nominal = 500.0, start = 275.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Integer 'medium.state.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'medium.state.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'medium.state.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'medium.state.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'medium.state.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'medium.preferredMediumStates' = false "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") = 'medium.T' - 273.15 "Temperature of medium in [degC]";
    Real 'medium.p_bar'(unit = "bar", quantity = "Pressure") = 'medium.p' / 1e5 "Absolute pressure of medium in [bar]";
    Real 'medium.sat.psat'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Saturation pressure";
    Real 'medium.sat.Tsat'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Saturation temperature";
    Integer 'medium.phase'(fixed = false, start = 1, max = 2, min = 0) "2 for two-phase, 1 for one-phase, 0 if not known";
    Real 'V'(fixed = true, start = 0.1, unit = "m3", quantity = "Volume");
    parameter Real 'dV'(unit = "m3/s", quantity = "VolumeFlowRate") = 0.0 "Fixed time derivative of volume";
    parameter Real 'm_flow_ext'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 0.0 "Fixed mass flow rate into volume";
    parameter Real 'H_flow_ext'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") = 1e4 "Fixed enthalpy flow rate into volume";
    Real 'm'(min = 0.0, unit = "kg", quantity = "Mass") "Mass of volume";
    Real 'U'(unit = "J", quantity = "Energy") "Internal energy of volume";
    Integer 'state2.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'state2.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'state2.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'state2.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'state2.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Integer 'state.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'state.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'state.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'state.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'state.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Real 'm_flow_ext2';
    Real 'der_p';
    Real 'der_T';
  equation
    'medium.MM' = 0.018015268;
    'medium.phase' = if ('medium.h' < 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p'('medium.sat.psat', 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boilingcurve_p'('medium.sat.psat')) or 'medium.h' > 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hvl_p'('medium.sat.psat', 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p'('medium.sat.psat'))) or 'medium.p' > 2.2064e7 then 1 else 2;
    'medium.d' = 'Modelica.Media.Water.IF97_Utilities.rho_props_ph'('medium.p', 'medium.h', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.p', 'medium.h', 'medium.phase', 0));
    'medium.T' = 'Modelica.Media.Water.IF97_Utilities.T_props_ph'('medium.p', 'medium.h', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.p', 'medium.h', 'medium.phase', 0));
    'medium.sat.Tsat' = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('medium.p');
    'medium.sat.psat' = 'medium.p';
    'medium.u' = 'medium.h' - 'medium.p' / 'medium.d';
    'medium.R_s' = 461.5231157345669;
    'medium.h' = 'medium.state.h';
    'medium.p' = 'medium.state.p';
    'medium.T' = 'medium.state.T';
    'medium.d' = 'medium.state.d';
    'medium.phase' = 'medium.state.phase';
    'medium.X[1]' = 1.0;
    assert('medium.X[1]' >= (-1e-5) and 'medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('medium.X[1]') + "of substance " + "water" + "\nof medium " + "WaterIF97" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium.p' >= 0.0, "Pressure (= " + String('medium.p') + " Pa) of medium \"" + "WaterIF97" + "\" is negative\n(Temperature = " + String('medium.T') + " K)", AssertionLevel.error);
    der('V') = 0.0;
    'm' = 'medium.d' * 'V';
    'U' = 'm' * 'medium.u';
    der('m') = 0.0;
    der('U') = 1e4;
    'm_flow_ext2' = time - 0.5;
    'state2.phase' = ('Modelica.Media.Examples.WaterIF97.Medium.setState_pT'(1e5 * (1.0 + time), 300.0 + 200.0 * time, 0)).phase;
    'state2.h' = ('Modelica.Media.Examples.WaterIF97.Medium.setState_pT'(1e5 * (1.0 + time), 300.0 + 200.0 * time, 0)).h;
    'state2.d' = ('Modelica.Media.Examples.WaterIF97.Medium.setState_pT'(1e5 * (1.0 + time), 300.0 + 200.0 * time, 0)).d;
    'state2.T' = ('Modelica.Media.Examples.WaterIF97.Medium.setState_pT'(1e5 * (1.0 + time), 300.0 + 200.0 * time, 0)).T;
    'state2.p' = ('Modelica.Media.Examples.WaterIF97.Medium.setState_pT'(1e5 * (1.0 + time), 300.0 + 200.0 * time, 0)).p;
    'state.phase' = 0;
    'state.h' = smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.h' else if 'm_flow_ext2' < (-0.05) then 'state2.h' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.h' - 'medium.state.h') / 4.0 + ('medium.state.h' + 'state2.h') / 2.0);
    'state.d' = 'Modelica.Media.Water.IF97_Utilities.rho_props_ph'(smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.p' else if 'm_flow_ext2' < (-0.05) then 'state2.p' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.p' - 'medium.state.p') / 4.0 + ('medium.state.p' + 'state2.p') / 2.0), smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.h' else if 'm_flow_ext2' < (-0.05) then 'state2.h' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.h' - 'medium.state.h') / 4.0 + ('medium.state.h' + 'state2.h') / 2.0), 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'(smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.p' else if 'm_flow_ext2' < (-0.05) then 'state2.p' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.p' - 'medium.state.p') / 4.0 + ('medium.state.p' + 'state2.p') / 2.0), smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.h' else if 'm_flow_ext2' < (-0.05) then 'state2.h' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.h' - 'medium.state.h') / 4.0 + ('medium.state.h' + 'state2.h') / 2.0), 0, 0));
    'state.T' = 'Modelica.Media.Water.IF97_Utilities.T_props_ph'(smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.p' else if 'm_flow_ext2' < (-0.05) then 'state2.p' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.p' - 'medium.state.p') / 4.0 + ('medium.state.p' + 'state2.p') / 2.0), smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.h' else if 'm_flow_ext2' < (-0.05) then 'state2.h' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.h' - 'medium.state.h') / 4.0 + ('medium.state.h' + 'state2.h') / 2.0), 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'(smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.p' else if 'm_flow_ext2' < (-0.05) then 'state2.p' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.p' - 'medium.state.p') / 4.0 + ('medium.state.p' + 'state2.p') / 2.0), smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.h' else if 'm_flow_ext2' < (-0.05) then 'state2.h' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.h' - 'medium.state.h') / 4.0 + ('medium.state.h' + 'state2.h') / 2.0), 0, 0));
    'state.p' = smooth(1, if 'm_flow_ext2' > 0.05 then 'medium.state.p' else if 'm_flow_ext2' < (-0.05) then 'state2.p' else 'm_flow_ext2' / 0.05 * (('m_flow_ext2' / 0.05) ^ 2.0 - 3.0) * ('state2.p' - 'medium.state.p') / 4.0 + ('medium.state.p' + 'state2.p') / 2.0);
    'der_p' = der('state.p');
    'der_T' = der('state.T');
    annotation(experiment(StopTime = 1));
  end 'WaterIF97';
end 'WaterIF97';
