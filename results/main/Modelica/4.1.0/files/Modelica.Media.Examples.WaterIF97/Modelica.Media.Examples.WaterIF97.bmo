    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    output 'Modelica.Media.Common.GibbsDerivs' 'g';
    Real[11] 'o';
  algorithm
    assert('p' > 0.0, "IF97 medium function g5 called with too low pressure\np = " + String('p') + " Pa <=  0.0 Pa", AssertionLevel.error);
    assert('p' <= 1e7, "IF97 medium function g5: input pressure (= " + String('p') + " Pa) is higher than 10 MPa in region 5", AssertionLevel.error);
    assert('T' <= 2273.15, "IF97 medium function g5: input temperature (= " + String('T') + " K) is higher than limit of 2273.15K in region 5", AssertionLevel.error);
