    Real 'smpm.stator.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smpm.stator.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smpm.stator.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'smpm.stator.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'smpm.stator.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smpm.stator.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smpm.stator.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smpm.stator.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smpm.stator.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'smpm.stator.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'smpm.stator.port_n.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smpm.stator.port_n.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smpm.stator.port_n.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smpm.stator.port_n.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'smpm.stator.port_p.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smpm.stator.port_p.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smpm.stator.port_p.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smpm.stator.port_p.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    parameter Integer 'smpm.stator.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Boolean 'smpm.stator.useHeatPort' = true "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Real 'smpm.stator.RRef'(unit = "Ohm", quantity = "Resistance") = 0.03 "Winding resistance per phase at TRef";
    parameter Real 'smpm.stator.TRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of winding";
    parameter Real 'smpm.stator.alpha20'(start = 0.0, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of winding at 20 degC";
    parameter Real 'smpm.stator.alphaRef'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of winding at reference temperature";
    parameter Real 'smpm.stator.TOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of winding";
    parameter Real 'smpm.stator.Lsigma'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Winding stray inductance per phase";
    parameter Real 'smpm.stator.ratioCommonLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance";
    parameter Real 'smpm.stator.Lzero'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Zero sequence inductance of winding";
    parameter Real 'smpm.stator.effectiveTurns' = 1.0 "Effective number of turns per phase";
    parameter Real 'smpm.stator.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Electrical reference core loss reluctance";
    parameter Integer 'smpm.stator.nBase' = 1 "Number of base systems";
    parameter Integer 'smpm.stator.mBase' = 3 "Number of phase of the base systems";
    Real 'smpm.stator.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smpm.stator.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smpm.stator.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smpm.stator.i[1]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smpm.stator.i[2]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smpm.stator.i[3]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smpm.stator.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smpm.stator.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smpm.stator.abs_V_m'(unit = "A", quantity = "MagneticPotential") "Magnitude of complex magnetic potential difference";
    Real 'smpm.stator.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic potential difference";
    Real 'smpm.stator.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smpm.stator.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'smpm.stator.abs_Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnitude of complex magnetic flux";
    Real 'smpm.stator.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux";
    Real 'smpm.stator.electroMagneticConverter.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smpm.stator.electroMagneticConverter.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smpm.stator.electroMagneticConverter.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'smpm.stator.electroMagneticConverter.i[1]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smpm.stator.electroMagneticConverter.i[2]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smpm.stator.electroMagneticConverter.i[3]'(unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'smpm.stator.electroMagneticConverter.V_m.re'(unit = "A", quantity = "MagneticPotential") "Real part of complex number";
    Real 'smpm.stator.electroMagneticConverter.V_m.im'(unit = "A", quantity = "MagneticPotential") "Imaginary part of complex number";
    Real 'smpm.stator.electroMagneticConverter.abs_V_m'(unit = "A", quantity = "MagneticPotential") "Magnitude of complex magnetic potential difference";
    Real 'smpm.stator.electroMagneticConverter.arg_V_m'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic potential difference";
    Real 'smpm.stator.electroMagneticConverter.Phi.re'(unit = "Wb", quantity = "MagneticFlux") "Real part of complex number";
    Real 'smpm.stator.electroMagneticConverter.Phi.im'(unit = "Wb", quantity = "MagneticFlux") "Imaginary part of complex number";
    Real 'smpm.stator.electroMagneticConverter.abs_Phi'(unit = "A", quantity = "MagneticPotential") "Magnitude of complex magnetic flux";
    Real 'smpm.stator.electroMagneticConverter.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex magnetic flux";
    parameter Integer 'smpm.stator.electroMagneticConverter.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
