    Real 'currentQuasiRMSSensor.ToSpacePhasor1.u[2]' "Connector of Real input signals";
    Real 'currentQuasiRMSSensor.ToSpacePhasor1.u[3]' "Connector of Real input signals";
    Real 'currentQuasiRMSSensor.ToSpacePhasor1.y[1]' "Connector of Real output signals";
    Real 'currentQuasiRMSSensor.ToSpacePhasor1.y[2]' "Connector of Real output signals";
    parameter Integer 'currentQuasiRMSSensor.ToSpacePhasor1.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.phi[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.phi[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 2.0943951023931953;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.phi[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 4.1887902047863905;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.TransformationMatrix[1,1]' = 0.6666666666666666;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.TransformationMatrix[1,2]' = -0.33333333333333315;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.TransformationMatrix[1,3]' = -0.3333333333333336;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.TransformationMatrix[2,1]' = 0.0;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.TransformationMatrix[2,2]' = 0.5773502691896257;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.TransformationMatrix[2,3]' = -0.5773502691896255;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.InverseTransformation[1,1]' = 1.0;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.InverseTransformation[1,2]' = 0.0;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.InverseTransformation[2,1]' = -0.4999999999999998;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.InverseTransformation[2,2]' = 0.8660254037844387;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.InverseTransformation[3,1]' = -0.5000000000000004;
    parameter Real 'currentQuasiRMSSensor.ToSpacePhasor1.InverseTransformation[3,2]' = -0.8660254037844384;
    Real 'currentQuasiRMSSensor.ToSpacePhasor1.zero' "Zero sequence component";
    parameter Integer 'currentQuasiRMSSensor.ToPolar1.n' = 2 "Number of inputs (= number of outputs)";
    Real 'currentQuasiRMSSensor.ToPolar1.u[1]' "Connector of Real input signals";
    Real 'currentQuasiRMSSensor.ToPolar1.u[2]' "Connector of Real input signals";
    Real 'currentQuasiRMSSensor.ToPolar1.y[1]' "Connector of Real output signals";
