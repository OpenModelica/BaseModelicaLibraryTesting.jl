//! base 0.1.0
package 'MeasuringTemperature'
  function 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph' "Intermediate property record for water"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    input Integer 'phase' = 0;
    input Integer 'region' = 0;
    output 'Modelica.Media.Common.IF97BaseTwoPhase' 'aux';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Integer 'error';
    Real 'h_liq'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'd_liq'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'h_vap'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'd_vap'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    'Modelica.Media.Common.PhaseBoundaryProperties' 'liq';
    'Modelica.Media.Common.PhaseBoundaryProperties' 'vap';
    'Modelica.Media.Common.GibbsDerivs' 'gl';
    'Modelica.Media.Common.GibbsDerivs' 'gv';
    'Modelica.Media.Common.HelmholtzDerivs' 'fl';
    'Modelica.Media.Common.HelmholtzDerivs' 'fv';
    Real 't1'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 't2'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  algorithm
    'aux'.'region' := if 'region' == 0 then if 'phase' == 2 then 4 else 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_ph'('p', 'h', 'phase', 0) else 'region';
    'aux'.'phase' := if 'phase' <> 0 then 'phase' else if 'aux'.'region' == 4 then 2 else 1;
    'aux'.'p' := max('p', 611.657);
    'aux'.'h' := max('h', 1000.0);
    'aux'.'R_s' := 461.526;
    'aux'.'vt' := 0.0 "Initialized in case it is not needed";
    'aux'.'vp' := 0.0 "Initialized in case it is not needed";

    if 'aux'.'region' == 1 then
      'aux'.'T' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tph1'('aux'.'p', 'aux'.'h');
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g1'('p', 'aux'.'T');
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'aux'.'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
      'aux'.'vp' := 'aux'.'R_s' * 'aux'.'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'x' := 0.0;
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
    elseif 'aux'.'region' == 2 then
      'aux'.'T' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tph2'('aux'.'p', 'aux'.'h');
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g2'('p', 'aux'.'T', true);
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'aux'.'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'vp' := 'aux'.'R_s' * 'aux'.'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'x' := 1.0;
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
    elseif 'aux'.'region' == 3 then
      ('aux'.'rho', 'aux'.'T', 'error') := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dtofph3'('aux'.'p', 'aux'.'h', 1e-7, 1e-6);
      'f' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('aux'.'rho', 'aux'.'T');
      'aux'.'h' := 'aux'.'R_s' * 'aux'.'T' * ('f'.'tau' * 'f'.'ftau' + 'f'.'delta' * 'f'.'fdelta');
      'aux'.'s' := 'aux'.'R_s' * ('f'.'tau' * 'f'.'ftau' - 'f'.'f');
      'aux'.'pd' := 'aux'.'R_s' * 'aux'.'T' * 'f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta');
      'aux'.'pt' := 'aux'.'R_s' * 'aux'.'rho' * 'f'.'delta' * ('f'.'fdelta' - 'f'.'tau' * 'f'.'fdeltatau');
      'aux'.'cv' := abs('aux'.'R_s' * (-'f'.'tau' * 'f'.'tau' * 'f'.'ftautau')) "Can be close to neg. infinity near critical point";
      'aux'.'cp' := ('aux'.'rho' * 'aux'.'rho' * 'aux'.'pd' * 'aux'.'cv' + 'aux'.'T' * 'aux'.'pt' * 'aux'.'pt') / ('aux'.'rho' * 'aux'.'rho' * 'aux'.'pd');
      'aux'.'x' := 0.0;
      'aux'.'dpT' := 'aux'.'pt';
    elseif 'aux'.'region' == 4 then
      'h_liq' := 'Modelica.Media.Water.IF97_Utilities.hl_p'('p');
      'h_vap' := 'Modelica.Media.Water.IF97_Utilities.hv_p'('p');
      'aux'.'x' := if 'h_vap' <> 'h_liq' then ('h' - 'h_liq') / ('h_vap' - 'h_liq') else 1.0;

      if 'p' < 1.65292e7 then
        't1' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tph1'('aux'.'p', 'h_liq');
        't2' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tph2'('aux'.'p', 'h_vap');
        'gl' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g1'('aux'.'p', 't1');
        'gv' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g2'('aux'.'p', 't2', true);
        'liq' := 'Modelica.Media.Common.gibbsToBoundaryProps'('gl');
        'vap' := 'Modelica.Media.Common.gibbsToBoundaryProps'('gv');
        'aux'.'T' := 't1' + 'aux'.'x' * ('t2' - 't1');
      elseif true then
        'aux'.'T' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('aux'.'p');
        'd_liq' := 'Modelica.Media.Water.IF97_Utilities.rhol_T'('aux'.'T');
        'd_vap' := 'Modelica.Media.Water.IF97_Utilities.rhov_T'('aux'.'T');
        'fl' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('d_liq', 'aux'.'T');
        'fv' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('d_vap', 'aux'.'T');
        'liq' := 'Modelica.Media.Common.helmholtzToBoundaryProps'('fl');
        'vap' := 'Modelica.Media.Common.helmholtzToBoundaryProps'('fv');
      end if;

      'aux'.'dpT' := if 'liq'.'d' <> 'vap'.'d' then ('vap'.'s' - 'liq'.'s') * 'liq'.'d' * 'vap'.'d' / ('liq'.'d' - 'vap'.'d') else 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dptofT'('aux'.'T');
      'aux'.'s' := 'liq'.'s' + 'aux'.'x' * ('vap'.'s' - 'liq'.'s');
      'aux'.'rho' := 'liq'.'d' * 'vap'.'d' / ('vap'.'d' + 'aux'.'x' * ('liq'.'d' - 'vap'.'d'));
      'aux'.'cv' := 'Modelica.Media.Common.cv2Phase'('liq', 'vap', 'aux'.'x', 'aux'.'T', 'p');
      'aux'.'cp' := 'liq'.'cp' + 'aux'.'x' * ('vap'.'cp' - 'liq'.'cp');
      'aux'.'pt' := 'liq'.'pt' + 'aux'.'x' * ('vap'.'pt' - 'liq'.'pt');
      'aux'.'pd' := 'liq'.'pd' + 'aux'.'x' * ('vap'.'pd' - 'liq'.'pd');
    elseif 'aux'.'region' == 5 then
      ('aux'.'T', 'error') := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.tofph5'('aux'.'p', 'aux'.'h', 1e-7);
      assert('error' == 0, "Error in inverse iteration of steam tables", AssertionLevel.error);
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g5'('aux'.'p', 'aux'.'T');
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'aux'.'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'vp' := 'aux'.'R_s' * 'aux'.'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
    elseif true then
      assert(false, "Error in region computation of IF97 steam tables(p = " + String('p') + ", h = " + String('h') + ")", AssertionLevel.error);
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p' "Properties on the dew curve"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output 'Modelica.Media.Common.IF97PhaseBoundaryProperties' 'bpro';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Real 'plim'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = min('p', 2.20639999999999e7);
  algorithm
    'bpro'.'R_s' := 461.526;
    'bpro'.'T' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('plim');
    'bpro'.'dpT' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dptofT'('bpro'.'T');
    'bpro'.'region3boundary' := 'bpro'.'T' > 623.15;

    if not 'bpro'.'region3boundary' then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g2'('p', 'bpro'.'T', true);
      'bpro'.'d' := 'p' / ('bpro'.'R_s' * 'bpro'.'T' * 'g'.'pi' * 'g'.'gpi');
      'bpro'.'h' := if 'p' > 'plim' then 2.08754684511715e6 else 'bpro'.'R_s' * 'bpro'.'T' * 'g'.'tau' * 'g'.'gtau';
      'bpro'.'s' := 'g'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'bpro'.'cp' := -'bpro'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'bpro'.'vt' := 'bpro'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'bpro'.'vp' := 'bpro'.'R_s' * 'bpro'.'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'bpro'.'pt' := -'p' / 'bpro'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'bpro'.'pd' := -'bpro'.'R_s' * 'bpro'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
    elseif true then
      'bpro'.'d' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhov_p_R4b'('plim');
      'f' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('bpro'.'d', 'bpro'.'T');
      'bpro'.'h' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hv_p_R4b'('plim');
      'bpro'.'s' := 'f'.'R_s' * ('f'.'tau' * 'f'.'ftau' - 'f'.'f');
      'bpro'.'cv' := 'bpro'.'R_s' * (-'f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
      'bpro'.'pt' := 'bpro'.'R_s' * 'bpro'.'d' * 'f'.'delta' * ('f'.'fdelta' - 'f'.'tau' * 'f'.'fdeltatau');
      'bpro'.'pd' := 'bpro'.'R_s' * 'bpro'.'T' * 'f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta');
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat' "Region 4 saturation temperature as a function of pressure"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output Real 't_sat'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'pi';
    Real[20] 'o';
  algorithm
    assert('p' > 611.657, "IF97 medium function tsat called with too low pressure\np = " + String('p') + " Pa <= " + "611.657" + " Pa (triple point pressure)", AssertionLevel.error);
    'pi' := min('p', 2.2064e7) * 1e-6;
    'o'[1] := 'pi' ^ 0.25;
    'o'[2] := -3.2325550322333e6 * 'o'[1];
    'o'[3] := 'pi' ^ 0.5;
    'o'[4] := -724213.16703206 * 'o'[3];
    'o'[5] := 405113.40542057 + 'o'[2] + 'o'[4];
    'o'[6] := -17.073846940092 * 'o'[1];
    'o'[7] := 14.91510861353 + 'o'[3] + 'o'[6];
    'o'[8] := -4.0 * 'o'[5] * 'o'[7];
    'o'[9] := 12020.82470247 * 'o'[1];
    'o'[10] := 1167.0521452767 * 'o'[3];
    'o'[11] := 'o'[10] - 4823.2657361591 + 'o'[9];
    'o'[12] := 'o'[11] * 'o'[11];
    'o'[13] := 'o'[12] + 'o'[8];
    'o'[14] := 'o'[13] ^ 0.5;
    'o'[15] := -'o'[14];
    'o'[16] := -12020.82470247 * 'o'[1];
    'o'[17] := -1167.0521452767 * 'o'[3];
    'o'[18] := 4823.2657361591 + 'o'[15] + 'o'[16] + 'o'[17];
    'o'[19] := 1.0 / 'o'[18];
    'o'[20] := 2.0 * 'o'[19] * 'o'[5];
    't_sat' := 0.5 * (650.17534844798 + 'o'[20] - ((650.17534844798 + 'o'[20]) ^ 2.0 - 4.0 * (1300.35069689596 * 'o'[19] * 'o'[5] - 0.23855557567849)) ^ 0.5);
    annotation(derivative(order = 1) = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der');
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boilingcurve_p' "Properties on the boiling curve"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    output 'Modelica.Media.Common.IF97PhaseBoundaryProperties' 'bpro';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Real 'plim'(displayUnit = "bar", unit = "Pa", quantity = "Pressure") = min('p', 2.20639999999999e7);
  algorithm
    'bpro'.'R_s' := 461.526;
    'bpro'.'T' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('plim');
    'bpro'.'dpT' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dptofT'('bpro'.'T');
    'bpro'.'region3boundary' := 'bpro'.'T' > 623.15;

    if not 'bpro'.'region3boundary' then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g1'('p', 'bpro'.'T');
      'bpro'.'d' := 'p' / ('bpro'.'R_s' * 'bpro'.'T' * 'g'.'pi' * 'g'.'gpi');
      'bpro'.'h' := if 'p' > 'plim' then 2.08754684511715e6 else 'bpro'.'R_s' * 'bpro'.'T' * 'g'.'tau' * 'g'.'gtau';
      'bpro'.'s' := 'g'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'bpro'.'cp' := -'bpro'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'bpro'.'vt' := 'bpro'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'bpro'.'vp' := 'bpro'.'R_s' * 'bpro'.'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'bpro'.'pt' := -'p' / 'bpro'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'bpro'.'pd' := -'bpro'.'R_s' * 'bpro'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
    elseif true then
      'bpro'.'d' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.rhol_p_R4b'('plim');
      'f' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('bpro'.'d', 'bpro'.'T');
      'bpro'.'h' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.hl_p_R4b'('plim');
      'bpro'.'s' := 'f'.'R_s' * ('f'.'tau' * 'f'.'ftau' - 'f'.'f');
      'bpro'.'cv' := 'bpro'.'R_s' * (-'f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
      'bpro'.'pt' := 'bpro'.'R_s' * 'bpro'.'d' * 'f'.'delta' * ('f'.'fdelta' - 'f'.'tau' * 'f'.'fdeltatau');
      'bpro'.'pd' := 'bpro'.'R_s' * 'bpro'.'T' * 'f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta');
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boilingcurve_p';

  function 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility' "Interpolating with two 3-order polynomials with a prescribed derivative at x=0"
    input Real 'x';
    input Real 'x1';
    input Real 'k1';
    input Real 'k2';
    input Boolean 'use_yd0' = false;
    input Real 'yd0'(min = 0.0) = 1.0;
    output Real 'y';
    Real 'x2';
    Real 'y1';
    Real 'y2';
    Real 'y1d';
    Real 'y2d';
    Real 'w';
    Real 'w1';
    Real 'w2';
    Real 'y0d';
    Real 'ww';
  algorithm
    'x2' := -'x1';

    if 'x' <= 'x2' then
      'y' := -'k2' * 'x' ^ 2.0;
    elseif true then
      'y1' := 'k1' * 'x1' ^ 2.0;
      'y2' := -'k2' * 'x2' ^ 2.0;
      'y1d' := 'k1' * 2.0 * 'x1';
      'y2d' := -'k2' * 2.0 * 'x2';

      if 'use_yd0' then
        'y0d' := 'yd0';
      elseif true then
        'w' := 'x2' / 'x1';
        'y0d' := ((3.0 * 'y2' - 'x2' * 'y2d') / 'w' - (3.0 * 'y1' - 'x1' * 'y1d') * 'w') / (2.0 * 'x1' * (1.0 - 'w'));
      end if;

      'w1' := 2.23606797749979 * 'k1' * 'x1';
      'w2' := 2.23606797749979 * 'k2' * abs('x2');
      'ww' := 0.9 * (if 'w1' < 'w2' then 'w1' else 'w2');

      if 'ww' < 'y0d' then
        'y0d' := 'ww';
      end if;

      'y' := if 'x' >= 0.0 then 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x', 'x1', 'y1', 'y1d', 'y0d') else 'Modelica.Fluid.Utilities.evaluatePoly3_derivativeAtZero'('x', 'x2', 'y2', 'y2d', 'y0d');
    end if;
    annotation(smoothOrder = 2);
  end 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility';

  function 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT' "Intermediate property record for water (p and T preferred states)"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Integer 'region' = 0;
    output 'Modelica.Media.Common.IF97BaseTwoPhase' 'aux';
    'Modelica.Media.Common.GibbsDerivs' 'g';
    'Modelica.Media.Common.HelmholtzDerivs' 'f';
    Integer 'error';
  algorithm
    'aux'.'phase' := 1;
    'aux'.'region' := if 'region' == 0 then 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.region_pT'('p', 'T', 0) else 'region';
    'aux'.'R_s' := 461.526;
    'aux'.'p' := 'p';
    'aux'.'T' := 'T';
    'aux'.'vt' := 0.0 "Initialized in case it is not needed";
    'aux'.'vp' := 0.0 "Initialized in case it is not needed";

    if 'aux'.'region' == 1 then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g1'('p', 'T');
      'aux'.'h' := 'aux'.'R_s' * 'aux'.'T' * 'g'.'tau' * 'g'.'gtau';
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'vp' := 'aux'.'R_s' * 'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'x' := 0.0;
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
    elseif 'aux'.'region' == 2 then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g2'('p', 'T', true);
      'aux'.'h' := 'aux'.'R_s' * 'aux'.'T' * 'g'.'tau' * 'g'.'gtau';
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'vp' := 'aux'.'R_s' * 'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'x' := 1.0;
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
    elseif 'aux'.'region' == 3 then
      ('aux'.'rho', 'error') := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Inverses.dofpt3'('p', 'T', 1e-7);
      'f' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.f3'('aux'.'rho', 'T');
      'aux'.'h' := 'aux'.'R_s' * 'T' * ('f'.'tau' * 'f'.'ftau' + 'f'.'delta' * 'f'.'fdelta');
      'aux'.'s' := 'aux'.'R_s' * ('f'.'tau' * 'f'.'ftau' - 'f'.'f');
      'aux'.'pd' := 'aux'.'R_s' * 'T' * 'f'.'delta' * (2.0 * 'f'.'fdelta' + 'f'.'delta' * 'f'.'fdeltadelta');
      'aux'.'pt' := 'aux'.'R_s' * 'aux'.'rho' * 'f'.'delta' * ('f'.'fdelta' - 'f'.'tau' * 'f'.'fdeltatau');
      'aux'.'cv' := 'aux'.'R_s' * (-'f'.'tau' * 'f'.'tau' * 'f'.'ftautau');
      'aux'.'x' := 0.0;
      'aux'.'dpT' := 'aux'.'pt';
    elseif 'aux'.'region' == 5 then
      'g' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.g5'('p', 'T');
      'aux'.'h' := 'aux'.'R_s' * 'aux'.'T' * 'g'.'tau' * 'g'.'gtau';
      'aux'.'s' := 'aux'.'R_s' * ('g'.'tau' * 'g'.'gtau' - 'g'.'g');
      'aux'.'rho' := 'p' / ('aux'.'R_s' * 'T' * 'g'.'pi' * 'g'.'gpi');
      'aux'.'vt' := 'aux'.'R_s' / 'p' * ('g'.'pi' * 'g'.'gpi' - 'g'.'tau' * 'g'.'pi' * 'g'.'gtaupi');
      'aux'.'vp' := 'aux'.'R_s' * 'T' / ('p' * 'p') * 'g'.'pi' * 'g'.'pi' * 'g'.'gpipi';
      'aux'.'pt' := -'g'.'p' / 'g'.'T' * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / ('g'.'gpipi' * 'g'.'pi');
      'aux'.'pd' := -'g'.'R_s' * 'g'.'T' * 'g'.'gpi' * 'g'.'gpi' / 'g'.'gpipi';
      'aux'.'cp' := -'aux'.'R_s' * 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau';
      'aux'.'cv' := 'aux'.'R_s' * (('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') * ('g'.'gpi' - 'g'.'tau' * 'g'.'gtaupi') / 'g'.'gpipi' - 'g'.'tau' * 'g'.'tau' * 'g'.'gtautau');
      'aux'.'x' := 1.0;
      'aux'.'dpT' := -'aux'.'vt' / 'aux'.'vp';
    elseif true then
      assert(false, "Error in region computation of IF97 steam tables(p = " + String('p') + ", T = " + String('T') + ")", AssertionLevel.error);
    end if;
  end 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT';

  function 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der' "Derivative function for tsat"
    input Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    input Real 'der_p'(displayUnit = "bar/s", unit = "Pa/s", quantity = "PressureSlope");
    output Real 'der_tsat'(unit = "K/s", quantity = "TemperatureSlope");
    Real 'dtp';
  algorithm
    'dtp' := 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dtsatofp'('p');
    'der_tsat' := 'dtp' * 'der_p';
  end 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat_der';

  function 'Modelica.Fluid.Utilities.checkBoundary' "Check whether boundary definition is correct"
    input String 'mediumName';
    input String[:] 'substanceNames';
    input Boolean 'singleState';
    input Boolean 'define_p';
    input Real[:] 'X_boundary';
    input String 'modelName' = "??? boundary ???";
    Integer 'nX' = size('X_boundary', 1);
    String 'X_str';
  algorithm
    assert(not 'singleState' or 'singleState' and 'define_p', "\nWrong value of parameter define_p (= false) in model \"" + 'modelName' + "\":\nThe selected medium \"" + 'mediumName' + "\" has Medium.singleState=true.\nTherefore, an boundary density cannot be defined and\ndefine_p = true is required.\n", AssertionLevel.error);

    for 'i' in 1:'nX' loop
      assert('X_boundary'['i'] >= 0.0, "\nWrong boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\":\nThe boundary value X_boundary(" + String('i') + ") = " + String('X_boundary'['i']) + "\nis negative. It must be positive.\n", AssertionLevel.error);
    end for;

    if 'nX' > 0 and abs(sum('X_boundary') - 1.0) > 1e-10 then
      'X_str' := "";

      for 'i' in 1:'nX' loop
        'X_str' := 'X_str' + "   X_boundary[" + String('i') + "] = " + String('X_boundary'['i']) + " \"" + 'substanceNames'['i'] + "\"\n";
      end for;

      'Modelica.Utilities.Streams.error'("The boundary mass fractions in medium \"" + 'mediumName' + "\" in model \"" + 'modelName' + "\"\n" + "do not sum up to 1. Instead, sum(X_boundary) = " + String(sum('X_boundary')) + ":\n" + 'X_str');
    end if;
  end 'Modelica.Fluid.Utilities.checkBoundary';

  type 'Modelica.Fluid.Types.Dynamics' = enumeration('DynamicFreeInitial', 'FixedInitial', 'SteadyStateInitial', 'SteadyState');

  type 'Modelica.Fluid.Types.PortFlowDirection' = enumeration('Entering', 'Leaving', 'Bidirectional');

  record 'Modelica.Media.Common.IF97BaseTwoPhase'
    Integer 'phase'(start = 0);
    Integer 'region'(max = 5, min = 1);
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 's'(unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real 'pt'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'pd'(unit = "Pa.m3/kg", quantity = "DerPressureByDensity");
    Real 'vt';
    Real 'vp';
    Real 'x';
    Real 'dpT';
  end 'Modelica.Media.Common.IF97BaseTwoPhase';

  record 'Modelica.Media.Common.IF97PhaseBoundaryProperties'
    Boolean 'region3boundary';
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 's'(unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real 'cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'dpT'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'pt'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'pd'(unit = "Pa.m3/kg", quantity = "DerPressureByDensity");
    Real 'vt'(unit = "m3/(kg.K)");
    Real 'vp'(unit = "m3/(kg.Pa)");
  end 'Modelica.Media.Common.IF97PhaseBoundaryProperties';

  record 'Modelica.Media.Common.GibbsDerivs'
    Real 'p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'pi'(unit = "1");
    Real 'tau'(unit = "1");
    Real 'g'(unit = "1");
    Real 'gpi'(unit = "1");
    Real 'gpipi'(unit = "1");
    Real 'gtau'(unit = "1");
    Real 'gtautau'(unit = "1");
    Real 'gtaupi'(unit = "1");
  end 'Modelica.Media.Common.GibbsDerivs';

  record 'Modelica.Media.Common.HelmholtzDerivs'
    Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'R_s'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'delta'(unit = "1");
    Real 'tau'(unit = "1");
    Real 'f'(unit = "1");
    Real 'fdelta'(unit = "1");
    Real 'fdeltadelta'(unit = "1");
    Real 'ftau'(unit = "1");
    Real 'ftautau'(unit = "1");
    Real 'fdeltatau'(unit = "1");
  end 'Modelica.Media.Common.HelmholtzDerivs';

  record 'Modelica.Media.Common.PhaseBoundaryProperties'
    Real 'd'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'u'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 's'(unit = "J/(kg.K)", quantity = "SpecificEntropy");
    Real 'cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity");
    Real 'pt'(unit = "Pa/K", quantity = "DerPressureByTemperature");
    Real 'pd'(unit = "Pa.m3/kg", quantity = "DerPressureByDensity");
  end 'Modelica.Media.Common.PhaseBoundaryProperties';

  model 'MeasuringTemperature' "Differences between using one port with and without explicit junction model and two port sensors for fluid temperature measuring"
    Real 'T_onePort.port.m_flow'(max = 1e5, min = 0.0, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'T_onePort.port.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'T_onePort.port.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'T_onePort.T'(min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature in port medium";
    parameter Boolean 'T_twoPort.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'T_twoPort.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'T_twoPort.port_a.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'T_twoPort.port_a.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'T_twoPort.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'T_twoPort.port_b.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'T_twoPort.port_b.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'T_twoPort.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'T_twoPort.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'T_twoPort.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'T_twoPort.m_flow_nominal'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 1.0 "Nominal value of m_flow = port_a.m_flow";
    parameter Real 'T_twoPort.m_flow_small'(max = 1e5, min = 0.0, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 0.01 "Regularization for bi-directional flow in the region |m_flow| < m_flow_small (m_flow_small > 0 required)";
    Real 'T_twoPort.T'(min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of the passing fluid";
    Real 'T_twoPort.T_a_inflow'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of inflowing fluid at port_a";
    Real 'T_twoPort.T_b_inflow'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of inflowing fluid at port_b or T_a_inflow, if uni-directional flow";
    parameter Real 'system.p_ambient'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default ambient pressure";
    parameter Real 'system.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default ambient temperature";
    parameter Real 'system.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'system.allowFlowReversal' = true "= false to restrict to design flow direction (port_a -> port_b)" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of energy balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of mass balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Default formulation of trace substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Default formulation of momentum balances, if options available" annotation(Evaluate = true);
    parameter Real 'system.m_flow_start'(unit = "kg/s", quantity = "MassFlowRate") = 0.0 "Default start value for mass flow rates";
    parameter Real 'system.p_start'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default start value for pressures";
    parameter Real 'system.T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default start value for temperatures";
    parameter Boolean 'system.use_eps_Re' = false "= true to determine turbulent region automatically using Reynolds number" annotation(Evaluate = true);
    parameter Real 'system.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 1.0 "Default nominal mass flow rate";
    parameter Real 'system.eps_m_flow'(min = 0.0) = 1e-4 "Regularization of zero flow for |m_flow| < eps_m_flow*m_flow_nominal";
    parameter Real 'system.dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0 "Default small pressure drop for regularization of laminar and zero flow";
    parameter Real 'system.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Default small mass flow rate for regularization of laminar and zero flow";
    Real 'openTankCold2.level'(stateSelect = StateSelect.prefer, start = 0.975, min = 0.0, unit = "m", quantity = "Length") "Level height of tank";
    Real 'openTankCold2.V'(stateSelect = StateSelect.never, unit = "m3", quantity = "Volume") "Actual tank volume";
    parameter Real 'openTankCold2.height'(min = 0.0, unit = "m", quantity = "Length") = 2.0 "Height of tank";
    parameter Real 'openTankCold2.crossArea'(unit = "m2", quantity = "Area") = 2.0 "Area of tank";
    parameter Real 'openTankCold2.p_ambient'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Tank surface pressure";
    parameter Real 'openTankCold2.T_ambient'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Tank surface Temperature";
    parameter Real 'openTankCold2.level_start'(min = 0.0, unit = "m", quantity = "Length") = 0.975 "Start value of tank level";
    Real 'openTankCold2.fluidVolume'(unit = "m3", quantity = "Volume") "Volume";
    parameter 'Modelica.Fluid.Types.Dynamics' 'openTankCold2.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'openTankCold2.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'openTankCold2.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of substance balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'openTankCold2.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'FixedInitial' "Formulation of trace substance balance" annotation(Evaluate = true);
    parameter Real 'openTankCold2.p_start'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Boolean 'openTankCold2.use_T_start' = true "= true, use T_start, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'openTankCold2.T_start'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Start value of temperature";
    parameter Real 'openTankCold2.h_start'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 84013.0581525969 "Start value of specific enthalpy";
    parameter Real 'openTankCold2.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
    Real 'openTankCold2.medium.p'(stateSelect = StateSelect.prefer, nominal = 1e5, start = 101325.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'openTankCold2.medium.h'(stateSelect = StateSelect.prefer, start = 84013.0581525969, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'openTankCold2.medium.d'(stateSelect = StateSelect.default, nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'openTankCold2.medium.T'(stateSelect = StateSelect.default, nominal = 500.0, start = 293.15, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
