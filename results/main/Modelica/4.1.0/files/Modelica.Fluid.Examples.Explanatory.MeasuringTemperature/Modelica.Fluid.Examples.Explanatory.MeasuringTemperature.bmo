      'openTankHot3.ports[1].p' = 'openTankHot3.vessel_ps_static[1]' + 0.5 / 'openTankHot3.portAreas[1]' ^ 2.0 * smooth(2, if 'openTankHot3.ports[1].m_flow' >= 'openTankHot3.m_flow_turbulent[1]' then ('openTankHot3.portsData_zeta_in[1]' - 1.0 + 'openTankHot3.portAreas[1]' ^ 2.0 / 4.0) / 'openTankHot3.portInDensities[1]' * 'openTankHot3.ports_penetration[1]' * 'openTankHot3.ports[1].m_flow' ^ 2.0 else if 'openTankHot3.ports[1].m_flow' <= (-'openTankHot3.m_flow_turbulent[1]') then -('openTankHot3.portsData_zeta_out[1]' + 1.0 - 'openTankHot3.portAreas[1]' ^ 2.0 / 4.0) / 'openTankHot3.medium.d' / 'openTankHot3.ports_penetration[1]' * 'openTankHot3.ports[1].m_flow' ^ 2.0 else if ('openTankHot3.portsData_zeta_in[1]' - 1.0 + 'openTankHot3.portAreas[1]' ^ 2.0 / 4.0) / 'openTankHot3.portInDensities[1]' * 'openTankHot3.ports_penetration[1]' >= ('openTankHot3.portsData_zeta_out[1]' + 1.0 - 'openTankHot3.portAreas[1]' ^ 2.0 / 4.0) / 'openTankHot3.medium.d' / 'openTankHot3.ports_penetration[1]' then 'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility'('openTankHot3.ports[1].m_flow', 'openTankHot3.m_flow_turbulent[1]', ('openTankHot3.portsData_zeta_in[1]' - 1.0 + 'openTankHot3.portAreas[1]' ^ 2.0 / 4.0) / 'openTankHot3.portInDensities[1]' * 'openTankHot3.ports_penetration[1]', ('openTankHot3.portsData_zeta_out[1]' + 1.0 - 'openTankHot3.portAreas[1]' ^ 2.0 / 4.0) / 'openTankHot3.medium.d' / 'openTankHot3.ports_penetration[1]', false, 1.0) else -'Modelica.Fluid.Utilities.regSquare2.regSquare2_utility'(-'openTankHot3.ports[1].m_flow', 'openTankHot3.m_flow_turbulent[1]', ('openTankHot3.portsData_zeta_out[1]' + 1.0 - 'openTankHot3.portAreas[1]' ^ 2.0 / 4.0) / 'openTankHot3.medium.d' / 'openTankHot3.ports_penetration[1]', ('openTankHot3.portsData_zeta_in[1]' - 1.0 + 'openTankHot3.portAreas[1]' ^ 2.0 / 4.0) / 'openTankHot3.portInDensities[1]' * 'openTankHot3.ports_penetration[1]', false, 1.0));
      'openTankHot3.s[1]' = 'openTankHot3.fluidLevel' - 'openTankHot3.portsData_height[1]';
    elseif 'openTankHot3.inFlow[1]' then
      'openTankHot3.ports[1].p' = 'openTankHot3.vessel_ps_static[1]';
      'openTankHot3.s[1]' = 'openTankHot3.ports[1].m_flow';
    elseif true then
      'openTankHot3.ports[1].m_flow' = 0.0;
      'openTankHot3.s[1]' = ('openTankHot3.ports[1].p' - 'openTankHot3.vessel_ps_static[1]') / 101325.0 * ('openTankHot3.portsData_height[1]' - 'openTankHot3.fluidLevel');
    end if;

    'openTankHot3.ports[1].h_outflow' = 'openTankHot3.medium.h';
    'openTankHot3.ports_H_flow[1]' = smooth(0, 'openTankHot3.ports[1].m_flow' * (if 'openTankHot3.ports[1].m_flow' > 0.0 then 'junctionIdeal.port_2.h_outflow' else 'openTankHot3.ports[1].h_outflow')) "Enthalpy flow";
    'openTankHot3.ports_E_flow[1]' = 'openTankHot3.ports[1].m_flow' * (0.5 * 'openTankHot3.portVelocities[1]' * 'openTankHot3.portVelocities[1]' + 9.80665 * 'openTankHot3.portsData_height[1]') "Flow of kinetic and potential energy";
    'openTankHot3.m' = 'openTankHot3.fluidVolume' * 'openTankHot3.medium.d';
    'openTankHot3.U' = 'openTankHot3.m' * 'openTankHot3.medium.u';
    der('openTankHot3.U') = 'openTankHot3.Hb_flow' + 'openTankHot3.Qb_flow' + 'openTankHot3.Wb_flow';
    der('openTankHot3.m') = 'openTankHot3.mb_flow';
    'mFlow3.medium.MM' = 0.018015268;
    'mFlow3.medium.phase' = if ('mFlow3.medium.h' < ('Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boilingcurve_p'('mFlow3.medium.sat.psat')).h or 'mFlow3.medium.h' > ('Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p'('mFlow3.medium.sat.psat')).h) or 'mFlow3.medium.p' > 2.2064e7 then 1 else 2;
    'mFlow3.medium.d' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('mFlow3.medium.p', 'mFlow3.medium.h', 'mFlow3.medium.phase', 0)).rho;
    'mFlow3.medium.T' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('mFlow3.medium.p', 'mFlow3.medium.h', 'mFlow3.medium.phase', 0)).T;
    'mFlow3.medium.sat.Tsat' = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('mFlow3.medium.p');
    'mFlow3.medium.sat.psat' = 'mFlow3.medium.p';
    'mFlow3.medium.u' = 'mFlow3.medium.h' - 'mFlow3.medium.p' / 'mFlow3.medium.d';
    'mFlow3.medium.R_s' = 461.5231157345669;
    'mFlow3.medium.h' = 'mFlow3.medium.state.h';
    'mFlow3.medium.p' = 'mFlow3.medium.state.p';
    'mFlow3.medium.T' = 'mFlow3.medium.state.T';
    'mFlow3.medium.d' = 'mFlow3.medium.state.d';
    'mFlow3.medium.phase' = 'mFlow3.medium.state.phase';
    'mFlow3.medium.X[1]' = 1.0;
    assert('mFlow3.medium.X[1]' >= (-1e-5) and 'mFlow3.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('mFlow3.medium.X[1]') + "of substance " + "water" + "\nof medium " + "WaterIF97" + " is not in the range 0..1", AssertionLevel.error);
    assert('mFlow3.medium.p' >= 0.0, "Pressure (= " + String('mFlow3.medium.p') + " Pa) of medium \"" + "WaterIF97" + "\" is negative\n(Temperature = " + String('mFlow3.medium.T') + " K)", AssertionLevel.error);
    'Modelica.Fluid.Utilities.checkBoundary'("WaterIF97", {"water"}, false, true, {'mFlow3.X_in_internal[1]'}, "MassFlowSource_T");
    'mFlow3.T_in_internal' = 323.15;
    'mFlow3.X_in_internal[1]' = 1.0;
    'mFlow3.medium.h' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT'('mFlow3.medium.p', 'mFlow3.T_in_internal', 0)).h;
    'mFlow3.ports[1].m_flow' = -'mFlow3.m_flow_in_internal';
    'mFlow3.ports[1].p' = 'mFlow3.medium.p';
    'mFlow3.ports[1].h_outflow' = 'mFlow3.medium.h';
    annotation(experiment(StopTime = 1.1));
  end 'MeasuringTemperature';
end 'MeasuringTemperature';
