//! base 0.1.0
package 'TickBasedSine'
  model 'TickBasedSine' "Example of using the clocked tick based Sine source block"
    Real 'assignClock1.u' "Connector of clocked, Real input signal";
    Real 'assignClock1.y' "Connector of clocked, Real output signal";
    Clock 'assignClock1.clock';
    parameter Real 'periodicClock1.period'(unit = "s", quantity = "Time") = 0.1 "Period of clock (defined as Real number)" annotation(Evaluate = true);
    parameter Boolean 'periodicClock1.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'periodicClock1.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'periodicClock1.y';
    Real 'sine.y' "Connector of clocked, Real output signal";
    parameter Real 'sine.amplitude' = 1.0 "Amplitude of sine wave";
    parameter Real 'sine.offset' = 0.0 "Offset of output signal";
    parameter Integer 'sine.periodTicks' = 10 "Number of clock ticks for one period";
    parameter Integer 'sine.periodOffset' = 2 "Number of periods the sine signal is offset";
    parameter Integer 'sine.startTick'(min = 1) = 4 "Output = offset for clock tick < startTick";
    constant Real 'sine.pi' = 3.141592653589793;
    Real 'sine.Ts' "Sample time (periodic or non-periodic)";
    Integer 'sine.counter'(start = 0);
    Boolean 'sine.startOutput'(start = false) "Flag whether counter >= startTick reached once";
    parameter Real 'sineRef.amplitude' = 1.0 "Amplitude of sine wave";
    parameter Real 'sineRef.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1.0 "Frequency of sine wave";
    parameter Real 'sineRef.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.2566370614359172 "Phase of sine wave";
    parameter Boolean 'sineRef.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineRef.y' "Connector of Real output signal";
    parameter Real 'sineRef.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineRef.startTime'(unit = "s", quantity = "Time") = 0.3 "Output y = offset for time < startTime";
  equation
    'sine.Ts' = interval('sine.y');
    'periodicClock1.y' = 'assignClock1.clock';
    'sine.y' = 'assignClock1.u';

    when 'assignClock1.clock' then
      'assignClock1.y' = 'assignClock1.u';
    end when;

    'periodicClock1.y' = Clock('periodicClock1.period');

    if previous('sine.startOutput') then
      'sine.counter' = if previous('sine.counter') == 9 then 0 else previous('sine.counter') + 1;
      'sine.startOutput' = previous('sine.startOutput');
    elseif true then
      'sine.startOutput' = previous('sine.counter') >= 3;
      'sine.counter' = if 'sine.startOutput' then 0 else previous('sine.counter') + 1;
    end if;

    'sine.y' = if 'sine.startOutput' then sin(0.6283185307179586 * ('sine.counter' + 2)) else 0.0;
    'sineRef.y' = if time < 0.3 then 0.0 else sin(6.283185307179586 * (time - 0.3) + 1.2566370614359172);
    annotation(experiment(StopTime = 1.0));
  end 'TickBasedSine';
end 'TickBasedSine';
