//! base 0.1.0
package 'Graetz'
  function 'Modelica.Electrical.Spice3.Internal.Diode.diodeNoBypassCode' "Calculation of currents"
    input 'Modelica.Electrical.Spice3.Internal.Diode.DiodeModelLineParams' 'in_p';
    input 'Modelica.Electrical.Spice3.Internal.Diode.DiodeParams' 'in_dp';
    input 'Modelica.Electrical.Spice3.Internal.Diode.DiodeCalc' 'in_c';
    input 'Modelica.Electrical.Spice3.Internal.Model.Model' 'in_m';
    input Boolean 'in_m_mbInit';
    input Real 'in_m_pVoltageValues'[2](unit = {"V", "V"}, quantity = {"ElectricPotential", "ElectricPotential"});
    output 'Modelica.Electrical.Spice3.Internal.Diode.CurrentsCapacitances' 'out_cc';
    output Real 'm_dCap'(min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_dPNVoltage'(unit = "V", quantity = "ElectricPotential");
    Real 'm_dCurrent'(unit = "A", quantity = "ElectricCurrent");
    Real 'm_dCond'(unit = "S", quantity = "Conductance");
    Real 'm_dCharge'(unit = "C", quantity = "ElectricCharge");
    Real 'm_dCapCurrent'(unit = "A", quantity = "ElectricCurrent");
  algorithm
    'm_dPNVoltage' := 'in_m_pVoltageValues'[1] - 'in_m_pVoltageValues'[2];

    if 'in_p'.'m_pBvIsGiven' > 0.5 then
      ('out_cc'.'m_dCurrent', 'm_dCond') := 'Modelica.Electrical.Spice3.Internal.Functions.junction3'('m_dPNVoltage', 'in_m'.'m_dTemp', 'in_p'.'m_emissionCoeff', 'in_c'.'m_tSatCur', 'in_c'.'m_tBrkdwnV');
    else
      ('out_cc'.'m_dCurrent', 'm_dCond') := 'Modelica.Electrical.Spice3.Internal.Functions.junction2'('m_dPNVoltage', 'in_m'.'m_dTemp', 'in_p'.'m_emissionCoeff', 'in_c'.'m_tSatCur');
    end if;

    'm_dCurrent' := 'out_cc'.'m_dCurrent';
    ('m_dCap', 'm_dCharge') := 'Modelica.Electrical.Spice3.Internal.Functions.junctionCapTransTime'('in_c'.'m_tJctCap', 'm_dPNVoltage', 'in_c'.'m_tJctPot' * 'in_p'.'m_depletionCapCoeff', 'in_p'.'m_gradingCoeff', 'in_p'.'m_junctionPot', 'in_c'.'m_tF1', 'in_c'.'m_f2', 'in_c'.'m_f3', 'in_p'.'m_transitTime', 'm_dCond', 'm_dCurrent');
  end 'Modelica.Electrical.Spice3.Internal.Diode.diodeNoBypassCode';

  function 'Modelica.Electrical.Spice3.Internal.Functions.resDepTemp' "Temperature dependent conductance"
    input Real 'resist'(unit = "Ohm", quantity = "Resistance");
    input Real 'temp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'tnom'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    input Real 'tc1';
    input Real 'tc2';
    output Real 'conduct'(unit = "S", quantity = "Conductance");
    output Real 'dCond_dTemp';
    Real 'difference';
    Real 'factor';
  algorithm
    'difference' := 'temp' - 'tnom';
    'factor' := 1.0 + 'tc1' * 'difference' + 'tc2' * 'difference' * 'difference';
    'conduct' := 1.0 / ('resist' * 'factor');
    'dCond_dTemp' := ('tc1' + 2.0 * 'tc2' * 'difference') * 'conduct' * 'conduct';
  end 'Modelica.Electrical.Spice3.Internal.Functions.resDepTemp';

  record 'Modelica.Electrical.Spice3.Internal.Diode.CurrentsCapacitances'
    Real 'm_dCurrent'(unit = "A", quantity = "ElectricCurrent");
  end 'Modelica.Electrical.Spice3.Internal.Diode.CurrentsCapacitances';

  record 'Modelica.Electrical.Spice3.Internal.Diode.DiodeModelLineParams'
    Real 'm_satCur'(start = 1e-14, unit = "A", quantity = "ElectricCurrent");
    Real 'm_resist'(start = 0.0, unit = "Ohm", quantity = "Resistance");
    Real 'm_emissionCoeff'(start = 1.0);
    Real 'm_transitTime'(start = 0.0, unit = "s", quantity = "Time");
    Real 'm_junctionCap'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_junctionPot'(start = 1.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_gradingCoeff'(start = 0.5, unit = "1/K", quantity = "LinearTemperatureCoefficient");
    Real 'm_activationEnergy'(start = 1.11, unit = "eV", quantity = "Energy");
    Real 'm_saturationCurrentExp'(start = 3.0);
    Real 'm_depletionCapCoeff'(start = 0.5);
    Real 'm_breakdownVoltage'(unit = "V", quantity = "ElectricPotential");
    Real 'm_pBvIsGiven';
    Real 'm_breakdownCurrent'(start = 0.001, unit = "A", quantity = "ElectricCurrent");
    Real 'm_nomTemp'(nominal = 300.0, start = 300.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
    Real 'm_fNcoef'(start = 0.0);
    Real 'm_fNexp'(start = 1.0);
    Real 'm_conductance'(unit = "S", quantity = "Conductance");
  end 'Modelica.Electrical.Spice3.Internal.Diode.DiodeModelLineParams';

  record 'Modelica.Electrical.Spice3.Internal.Diode.DiodeParams'
    Real 'm_area'(start = 1.0);
    Boolean 'm_bOff'(start = false);
    Real 'm_dIC'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'm_pIcIsGiven';
    Boolean 'm_bSensArea'(start = false);
  end 'Modelica.Electrical.Spice3.Internal.Diode.DiodeParams';

  record 'Modelica.Electrical.Spice3.Internal.Diode.DiodeCalc'
    Real 'm_tJctPot'(unit = "V", quantity = "ElectricPotential");
    Real 'm_tJctCap'(min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'm_tF1';
    Real 'm_f2';
    Real 'm_f3';
    Real 'm_tSatCur'(unit = "A", quantity = "ElectricCurrent");
    Real 'm_tVcrit'(unit = "V", quantity = "ElectricPotential");
    Real 'm_dVte';
    Real 'm_tBrkdwnV'(unit = "V", quantity = "ElectricPotential");
  end 'Modelica.Electrical.Spice3.Internal.Diode.DiodeCalc';

  record 'Modelica.Electrical.Spice3.Internal.Model.Model'
    Real 'm_dTemp'(nominal = 300.0, start = 300.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature");
  end 'Modelica.Electrical.Spice3.Internal.Model.Model';

  record 'Modelica.Electrical.Spice3.Internal.Rsemiconductor.ResistorVariables'
    Real 'm_dWidth'(unit = "m", quantity = "Length");
    Real 'm_dLength'(unit = "m", quantity = "Length");
    Real 'm_dResist'(unit = "Ohm", quantity = "Resistance");
    Real 'm_dConduct'(unit = "S", quantity = "Conductance");
    Real 'm_dCond_dTemp'(unit = "degC", quantity = "ThermodynamicTemperature");
  end 'Modelica.Electrical.Spice3.Internal.Rsemiconductor.ResistorVariables';

  model 'Graetz' "Graetz rectifier circuit"
    Real 'D1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'D1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'D1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'D1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'D1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'D1.AREA' = 1.0 "Area factor";
    parameter Boolean 'D1.OFF' = false "Optional initial condition: false - IC not used, true - IC used, not implemented yet";
    parameter Real 'D1.IC'(start = -1e40, unit = "V", quantity = "ElectricPotential") = -1e40 "Initial condition value (VD, not implemented yet";
    parameter Real 'D1.TEMP'(unit = "degC", quantity = "ThermodynamicTemperature") = 27.0 "Operating temperature of the device";
    parameter Boolean 'D1.SENS_AREA'(start = false) = false "Flag to request sensitivity WRT area, not implemented yet";
    parameter Real 'D1.modelcarddiode.IS'(unit = "A", quantity = "ElectricCurrent") = 1e-14 "Saturation Current";
    parameter Real 'D1.modelcarddiode.RS'(unit = "Ohm", quantity = "Resistance") = 0.0 "Ohmic resistance";
    parameter Real 'D1.modelcarddiode.N' = 1.0 "Emission coefficient";
    parameter Real 'D1.modelcarddiode.TT'(unit = "s", quantity = "Time") = 0.0 "Transit time";
    parameter Real 'D1.modelcarddiode.CJO'(min = -1e60, unit = "F", quantity = "Capacitance") = 1e-7 "Junction capacitance";
    parameter Real 'D1.modelcarddiode.VJ'(unit = "V", quantity = "ElectricPotential") = 1.0 "Junction Potential";
    parameter Real 'D1.modelcarddiode.M' = 0.5 "Grading coefficient";
    parameter Real 'D1.modelcarddiode.EG'(unit = "eV", quantity = "Energy") = 1.11 "Activation Energy";
    parameter Real 'D1.modelcarddiode.XTI' = 3.0 "Saturation current temperature exponent";
    parameter Real 'D1.modelcarddiode.FC' = 0.5 "Forward bias junction fit parameter";
    parameter Real 'D1.modelcarddiode.BV'(unit = "V", quantity = "ElectricPotential") = -1e40 "Reverse breakdown voltage, default infinity";
    parameter Real 'D1.modelcarddiode.IBV'(unit = "A", quantity = "ElectricCurrent") = 0.001 "Current at reverse breakdown voltage";
    parameter Real 'D1.modelcarddiode.TNOM'(unit = "degC", quantity = "ThermodynamicTemperature") = 27.0 "Parameter measurement temperature";
    parameter Real 'D1.modelcarddiode.KF' = 0.0 "Flicker noise coefficient";
    parameter Real 'D1.modelcarddiode.AF' = 1.0 "Flicker noise exponent";
    parameter Real 'D1.modelcarddiode.G'(unit = "S", quantity = "Conductance") = 0.0 "Ohmic conductance";
    constant Real 'D1.C.EPSSIL' = 1.0359431399069999e-10;
    constant Real 'D1.C.EPSOX' = 3.453133e-11;
    constant Real 'D1.C.CHARGE'(unit = "C", quantity = "ElectricCharge") = 1.6021918e-19;
    constant Real 'D1.C.CONSTCtoK'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.15;
    constant Real 'D1.C.CONSTboltz'(unit = "J/K", quantity = "HeatCapacity") = 1.3806226e-23;
    constant Real 'D1.C.REFTEMP'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'D1.C.CONSTroot2' = 1.4142135623730951;
    constant Real 'D1.C.CONSTvt0'(unit = "(J)/(A.s)") = 0.025864680954552383;
    constant Real 'D1.C.CONSTKoverQ'(unit = "(J/K)/(A.s)") = 8.617251692337959e-5;
    constant Real 'D1.C.CONSTe' = 2.718281828459045;
    constant Real 'D1.C.CKTgmin'(unit = "S", quantity = "Conductance") = 1e-12;
    constant Real 'D1.C.CKTnomTemp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'D1.C.CKTtemp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'D1.C.CKTdefaultMosAD'(unit = "m2", quantity = "Area") = 0.0;
    constant Real 'D1.C.CKTdefaultMosAS'(unit = "m2", quantity = "Area") = 0.0;
    constant Real 'D1.C.CKTdefaultMosL'(unit = "m", quantity = "Length") = 1e-4;
    constant Real 'D1.C.CKTdefaultMosW'(unit = "m", quantity = "Length") = 1e-4;
    constant Real 'D1.C.CKTreltol' = 1e-10;
    constant Real 'D1.C.CKTabstol' = 1e-15;
    constant Real 'D1.C.CKTvolttol' = 1e-10;
    constant Real 'D1.C.CKTtemptol' = 0.001;
    parameter Real 'D1.param.m_satCur'(start = 1e-14, unit = "A", quantity = "ElectricCurrent") = 1e-14 "IS, Saturation current";
    parameter Real 'D1.param.m_resist'(start = 0.0, unit = "Ohm", quantity = "Resistance") = 0.0 "RS, Ohmic resistance";
    parameter Real 'D1.param.m_emissionCoeff'(start = 1.0) = 1.0 "N, Emission Coefficient";
    parameter Real 'D1.param.m_transitTime'(start = 0.0, unit = "s", quantity = "Time") = 0.0 "TT, Transit Time";
    parameter Real 'D1.param.m_junctionCap'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance") = 1e-7 "CJO, Junction capacitance";
    parameter Real 'D1.param.m_junctionPot'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 1.0 "VJ, Junction potential";
    parameter Real 'D1.param.m_gradingCoeff'(start = 0.5, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.5 "M, Grading coefficient";
    parameter Real 'D1.param.m_activationEnergy'(start = 1.11, unit = "eV", quantity = "Energy") = 1.11 "EG, Activation energy";
    parameter Real 'D1.param.m_saturationCurrentExp'(start = 3.0) = 3.0 "XTI, Saturation current temperature exp.";
    parameter Real 'D1.param.m_depletionCapCoeff'(start = 0.5) = 0.5 "FC, Forward bias junction fit parameter";
    parameter Real 'D1.param.m_breakdownVoltage'(unit = "V", quantity = "ElectricPotential") = 0.0 "BV, Reverse breakdown voltage";
    parameter Real 'D1.param.m_pBvIsGiven' = 0.0 "BV is given value";
    parameter Real 'D1.param.m_breakdownCurrent'(start = 0.001, unit = "A", quantity = "ElectricCurrent") = 0.001 "IBV, Current at reverse breakdown voltage";
    parameter Real 'D1.param.m_nomTemp'(nominal = 300.0, start = 300.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "TNOM, Parameter measurement temperature";
    parameter Real 'D1.param.m_fNcoef'(start = 0.0) = 0.0 "KF, flicker noise coefficient";
    parameter Real 'D1.param.m_fNexp'(start = 1.0) = 1.0 "AF, flicker noise exponent";
    parameter Real 'D1.param.m_conductance'(unit = "S", quantity = "Conductance") = 0.0 "G, Ohmic conductance";
    parameter Real 'D1.dp.m_area'(start = 1.0) = 1.0 "AREA, Area factor";
    parameter Boolean 'D1.dp.m_bOff'(start = false) = false "OFF, Initially off";
    parameter Real 'D1.dp.m_dIC'(start = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "IC, Initial device voltage";
    parameter Real 'D1.dp.m_pIcIsGiven' = 0.0 "IC is given value";
    parameter Boolean 'D1.dp.m_bSensArea'(start = false) = false "SENS_AREA, flag to request sensitivity WRT area";
    parameter Real 'D1.m.m_dTemp'(nominal = 300.0, start = 300.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "TEMP, Device Temperature";
    parameter Real 'D1.c1.m_pBvIsGiven' = 0.0 "Additional BV is given variable";
    parameter Real 'D1.c2.m_tJctPot'(unit = "V", quantity = "ElectricPotential") = 1.0;
    parameter Real 'D1.c2.m_tJctCap'(min = -1e60, unit = "F", quantity = "Capacitance") = 1e-7;
    parameter Real 'D1.c2.m_tF1' = 0.5857864376269049;
    parameter Real 'D1.c2.m_f2' = 0.3535533905932738;
    parameter Real 'D1.c2.m_f3' = 0.25;
    parameter Real 'D1.c2.m_tSatCur'(unit = "A", quantity = "ElectricCurrent") = 1e-14;
    parameter Real 'D1.c2.m_tVcrit'(unit = "V", quantity = "ElectricPotential") = 0.7302825626525529;
    parameter Real 'D1.c2.m_dVte' = 0.025864680954552383;
    parameter Real 'D1.c2.m_tBrkdwnV'(unit = "V", quantity = "ElectricPotential", fixed = false);
    constant Boolean 'D1.m_mbInit' = false;
    Real 'D1.cc.m_dCurrent'(unit = "A", quantity = "ElectricCurrent");
    Real 'D1.icap';
    Real 'D1.m_dCap';
    Real 'D1.pin'(fixed = true, start = 0.0);
    Real 'D1.ir';
    Real 'D1.igmin';
    Real 'D3.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'D3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'D3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'D3.n.v'(fixed = true, start = 0.0, unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'D3.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'D3.AREA' = 1.0 "Area factor";
    parameter Boolean 'D3.OFF' = false "Optional initial condition: false - IC not used, true - IC used, not implemented yet";
    parameter Real 'D3.IC'(start = -1e40, unit = "V", quantity = "ElectricPotential") = -1e40 "Initial condition value (VD, not implemented yet";
    parameter Real 'D3.TEMP'(unit = "degC", quantity = "ThermodynamicTemperature") = 27.0 "Operating temperature of the device";
    parameter Boolean 'D3.SENS_AREA'(start = false) = false "Flag to request sensitivity WRT area, not implemented yet";
    parameter Real 'D3.modelcarddiode.IS'(unit = "A", quantity = "ElectricCurrent") = 1e-14 "Saturation Current";
    parameter Real 'D3.modelcarddiode.RS'(unit = "Ohm", quantity = "Resistance") = 0.0 "Ohmic resistance";
    parameter Real 'D3.modelcarddiode.N' = 1.0 "Emission coefficient";
    parameter Real 'D3.modelcarddiode.TT'(unit = "s", quantity = "Time") = 0.0 "Transit time";
    parameter Real 'D3.modelcarddiode.CJO'(min = -1e60, unit = "F", quantity = "Capacitance") = 1e-7 "Junction capacitance";
    parameter Real 'D3.modelcarddiode.VJ'(unit = "V", quantity = "ElectricPotential") = 1.0 "Junction Potential";
    parameter Real 'D3.modelcarddiode.M' = 0.5 "Grading coefficient";
    parameter Real 'D3.modelcarddiode.EG'(unit = "eV", quantity = "Energy") = 1.11 "Activation Energy";
    parameter Real 'D3.modelcarddiode.XTI' = 3.0 "Saturation current temperature exponent";
    parameter Real 'D3.modelcarddiode.FC' = 0.5 "Forward bias junction fit parameter";
    parameter Real 'D3.modelcarddiode.BV'(unit = "V", quantity = "ElectricPotential") = -1e40 "Reverse breakdown voltage, default infinity";
    parameter Real 'D3.modelcarddiode.IBV'(unit = "A", quantity = "ElectricCurrent") = 0.001 "Current at reverse breakdown voltage";
    parameter Real 'D3.modelcarddiode.TNOM'(unit = "degC", quantity = "ThermodynamicTemperature") = 27.0 "Parameter measurement temperature";
    parameter Real 'D3.modelcarddiode.KF' = 0.0 "Flicker noise coefficient";
    parameter Real 'D3.modelcarddiode.AF' = 1.0 "Flicker noise exponent";
    parameter Real 'D3.modelcarddiode.G'(unit = "S", quantity = "Conductance") = 0.0 "Ohmic conductance";
    constant Real 'D3.C.EPSSIL' = 1.0359431399069999e-10;
    constant Real 'D3.C.EPSOX' = 3.453133e-11;
    constant Real 'D3.C.CHARGE'(unit = "C", quantity = "ElectricCharge") = 1.6021918e-19;
    constant Real 'D3.C.CONSTCtoK'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 273.15;
    constant Real 'D3.C.CONSTboltz'(unit = "J/K", quantity = "HeatCapacity") = 1.3806226e-23;
    constant Real 'D3.C.REFTEMP'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'D3.C.CONSTroot2' = 1.4142135623730951;
    constant Real 'D3.C.CONSTvt0'(unit = "(J)/(A.s)") = 0.025864680954552383;
    constant Real 'D3.C.CONSTKoverQ'(unit = "(J/K)/(A.s)") = 8.617251692337959e-5;
    constant Real 'D3.C.CONSTe' = 2.718281828459045;
    constant Real 'D3.C.CKTgmin'(unit = "S", quantity = "Conductance") = 1e-12;
    constant Real 'D3.C.CKTnomTemp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'D3.C.CKTtemp'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15;
    constant Real 'D3.C.CKTdefaultMosAD'(unit = "m2", quantity = "Area") = 0.0;
    constant Real 'D3.C.CKTdefaultMosAS'(unit = "m2", quantity = "Area") = 0.0;
    constant Real 'D3.C.CKTdefaultMosL'(unit = "m", quantity = "Length") = 1e-4;
    constant Real 'D3.C.CKTdefaultMosW'(unit = "m", quantity = "Length") = 1e-4;
    constant Real 'D3.C.CKTreltol' = 1e-10;
    constant Real 'D3.C.CKTabstol' = 1e-15;
    constant Real 'D3.C.CKTvolttol' = 1e-10;
    constant Real 'D3.C.CKTtemptol' = 0.001;
    parameter Real 'D3.param.m_satCur'(start = 1e-14, unit = "A", quantity = "ElectricCurrent") = 1e-14 "IS, Saturation current";
    parameter Real 'D3.param.m_resist'(start = 0.0, unit = "Ohm", quantity = "Resistance") = 0.0 "RS, Ohmic resistance";
    parameter Real 'D3.param.m_emissionCoeff'(start = 1.0) = 1.0 "N, Emission Coefficient";
    parameter Real 'D3.param.m_transitTime'(start = 0.0, unit = "s", quantity = "Time") = 0.0 "TT, Transit Time";
    parameter Real 'D3.param.m_junctionCap'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance") = 1e-7 "CJO, Junction capacitance";
    parameter Real 'D3.param.m_junctionPot'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 1.0 "VJ, Junction potential";
    parameter Real 'D3.param.m_gradingCoeff'(start = 0.5, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.5 "M, Grading coefficient";
    parameter Real 'D3.param.m_activationEnergy'(start = 1.11, unit = "eV", quantity = "Energy") = 1.11 "EG, Activation energy";
    parameter Real 'D3.param.m_saturationCurrentExp'(start = 3.0) = 3.0 "XTI, Saturation current temperature exp.";
    parameter Real 'D3.param.m_depletionCapCoeff'(start = 0.5) = 0.5 "FC, Forward bias junction fit parameter";
    parameter Real 'D3.param.m_breakdownVoltage'(unit = "V", quantity = "ElectricPotential") = 0.0 "BV, Reverse breakdown voltage";
    parameter Real 'D3.param.m_pBvIsGiven' = 0.0 "BV is given value";
    parameter Real 'D3.param.m_breakdownCurrent'(start = 0.001, unit = "A", quantity = "ElectricCurrent") = 0.001 "IBV, Current at reverse breakdown voltage";
    parameter Real 'D3.param.m_nomTemp'(nominal = 300.0, start = 300.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "TNOM, Parameter measurement temperature";
    parameter Real 'D3.param.m_fNcoef'(start = 0.0) = 0.0 "KF, flicker noise coefficient";
    parameter Real 'D3.param.m_fNexp'(start = 1.0) = 1.0 "AF, flicker noise exponent";
    parameter Real 'D3.param.m_conductance'(unit = "S", quantity = "Conductance") = 0.0 "G, Ohmic conductance";
    parameter Real 'D3.dp.m_area'(start = 1.0) = 1.0 "AREA, Area factor";
    parameter Boolean 'D3.dp.m_bOff'(start = false) = false "OFF, Initially off";
    parameter Real 'D3.dp.m_dIC'(start = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "IC, Initial device voltage";
    parameter Real 'D3.dp.m_pIcIsGiven' = 0.0 "IC is given value";
    parameter Boolean 'D3.dp.m_bSensArea'(start = false) = false "SENS_AREA, flag to request sensitivity WRT area";
