    parameter Real 'rout.lp.m_dNarrow'(unit = "m", quantity = "Length") = 0.0 "Narrowing of resistor";
    parameter Real 'rout.lp.m_dTnom'(unit = "degC", quantity = "ThermodynamicTemperature") = 300.15 "Parameter measurement temperature";
    parameter Real 'rout.rp.m_dResist'(start = 1000.0, unit = "Ohm", quantity = "Resistance") = 10.0 "Device is a resistor model";
    parameter Real 'rout.rp.m_dResIsGiven' = 1.0 "Resistance is given value";
    parameter Real 'rout.rp.m_dWidth'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Width";
    parameter Real 'rout.rp.m_dWidthIsGiven' = 0.0 "Width is given value";
    parameter Real 'rout.rp.m_dLength'(unit = "m", quantity = "Length") = 0.0 "Length";
    parameter Real 'rout.rp.m_dLengthIsGiven' = 0.0 "Length is given value";
    parameter Boolean 'rout.rp.m_bSensResist'(start = false) = false "Flag to request sensitivity WRT resistance";
    parameter Real 'rout.rp.m_dTemp'(start = 27.0, unit = "degC", quantity = "ThermodynamicTemperature") = 300.15 "Resistor device temperature";
    Real 'rout.vp.m_dWidth'(unit = "m", quantity = "Length");
    Real 'rout.vp.m_dLength'(unit = "m", quantity = "Length");
    Real 'rout.vp.m_dResist'(unit = "Ohm", quantity = "Resistance");
    Real 'rout.vp.m_dConduct'(unit = "S", quantity = "Conductance");
    Real 'rout.vp.m_dCond_dTemp'(unit = "degC", quantity = "ThermodynamicTemperature");
    Real 'vsin.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'vsin.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vsin.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vsin.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vsin.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vsin.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'vsin.VO'(unit = "V", quantity = "ElectricPotential") = 0.0 "Offset";
    parameter Real 'vsin.VA'(unit = "V", quantity = "ElectricPotential") = 10.0 "Amplitude";
    parameter Real 'vsin.FREQ'(start = 1.0, unit = "Hz", quantity = "Frequency") = 200.0 "Frequency";
    parameter Real 'vsin.TD'(unit = "s", quantity = "Time") = 0.0 "Delay";
    parameter Real 'vsin.THETA'(unit = "s-1", quantity = "DampingCoefficient") = 0.0 "Damping factor";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
  equation
    'D3.p.v' = 'vsin.p.v';
    'D3.p.v' = 'D1.n.v';
    'rout.n.v' = 'D1.p.v';
    'rout.n.v' = 'D2.p.v';
    'D4.n.v' = 'rout.p.v';
    'D4.n.v' = 'D3.n.v';
    'vsin.n.v' = 'ground.p.v';
    'vsin.n.v' = 'D4.p.v';
    'vsin.n.v' = 'D2.n.v';
    'vsin.p.i' + 'D3.p.i' + 'D1.n.i' = 0.0;
    'rout.p.i' + 'D4.n.i' + 'D3.n.i' = 0.0;
    'ground.p.i' + 'vsin.n.i' + 'D2.n.i' + 'D4.p.i' = 0.0;
    'rout.n.i' + 'D2.p.i' + 'D1.p.i' = 0.0;
    ('D1.cc', 'D1.m_dCap') = 'Modelica.Electrical.Spice3.Internal.Diode.diodeNoBypassCode'('Modelica.Electrical.Spice3.Internal.Diode.DiodeModelLineParams'(1e-14, 0.0, 1.0, 0.0, 1e-7, 1.0, 0.5, 1.11, 3.0, 0.5, 0.0, 0.0, 0.001, 300.15, 0.0, 1.0, 0.0), 'Modelica.Electrical.Spice3.Internal.Diode.DiodeParams'(1.0, false, 0.0, 0.0, false), 'Modelica.Electrical.Spice3.Internal.Diode.DiodeCalc'(1.0, 1e-7, 0.5857864376269049, 0.3535533905932738, 0.25, 1e-14, 0.7302825626525529, 0.025864680954552383, #EMPTY#), 'Modelica.Electrical.Spice3.Internal.Model.Model'(300.15), false, {'D1.pin', 'D1.n.v'});
    'D1.icap' = 'D1.m_dCap' * (der('D1.pin') - der('D1.n.v'));
    0.0 = 'D1.p.v' - 'D1.pin';
    'D1.igmin' = 1e-12 * ('D1.pin' - 'D1.n.v');
    'D1.p.i' = 'D1.ir';
    'D1.n.i' = -('D1.cc.m_dCurrent' + 'D1.igmin' + 'D1.icap');
    0.0 = 'D1.cc.m_dCurrent' - 'D1.ir' + 'D1.igmin' + 'D1.icap';
    'D1.v' = 'D1.p.v' - 'D1.n.v';
    ('D3.cc', 'D3.m_dCap') = 'Modelica.Electrical.Spice3.Internal.Diode.diodeNoBypassCode'('Modelica.Electrical.Spice3.Internal.Diode.DiodeModelLineParams'(1e-14, 0.0, 1.0, 0.0, 1e-7, 1.0, 0.5, 1.11, 3.0, 0.5, 0.0, 0.0, 0.001, 300.15, 0.0, 1.0, 0.0), 'Modelica.Electrical.Spice3.Internal.Diode.DiodeParams'(1.0, false, 0.0, 0.0, false), 'Modelica.Electrical.Spice3.Internal.Diode.DiodeCalc'(1.0, 1e-7, 0.5857864376269049, 0.3535533905932738, 0.25, 1e-14, 0.7302825626525529, 0.025864680954552383, #EMPTY#), 'Modelica.Electrical.Spice3.Internal.Model.Model'(300.15), false, {'D3.pin', 'D3.n.v'});
    'D3.icap' = 'D3.m_dCap' * (der('D3.pin') - der('D3.n.v'));
    0.0 = 'D3.p.v' - 'D3.pin';
    'D3.igmin' = 1e-12 * ('D3.pin' - 'D3.n.v');
    'D3.p.i' = 'D3.ir';
    'D3.n.i' = -('D3.cc.m_dCurrent' + 'D3.igmin' + 'D3.icap');
    0.0 = 'D3.cc.m_dCurrent' - 'D3.ir' + 'D3.igmin' + 'D3.icap';
    'D3.v' = 'D3.p.v' - 'D3.n.v';
    ('D4.cc', 'D4.m_dCap') = 'Modelica.Electrical.Spice3.Internal.Diode.diodeNoBypassCode'('Modelica.Electrical.Spice3.Internal.Diode.DiodeModelLineParams'(1e-14, 0.0, 1.0, 0.0, 1e-7, 1.0, 0.5, 1.11, 3.0, 0.5, 0.0, 0.0, 0.001, 300.15, 0.0, 1.0, 0.0), 'Modelica.Electrical.Spice3.Internal.Diode.DiodeParams'(1.0, false, 0.0, 0.0, false), 'Modelica.Electrical.Spice3.Internal.Diode.DiodeCalc'(1.0, 1e-7, 0.5857864376269049, 0.3535533905932738, 0.25, 1e-14, 0.7302825626525529, 0.025864680954552383, #EMPTY#), 'Modelica.Electrical.Spice3.Internal.Model.Model'(300.15), false, {'D4.pin', 'D4.n.v'});
    'D4.icap' = 'D4.m_dCap' * (der('D4.pin') - der('D4.n.v'));
    0.0 = 'D4.p.v' - 'D4.pin';
    'D4.igmin' = 1e-12 * ('D4.pin' - 'D4.n.v');
    'D4.p.i' = 'D4.ir';
    'D4.n.i' = -('D4.cc.m_dCurrent' + 'D4.igmin' + 'D4.icap');
    0.0 = 'D4.cc.m_dCurrent' - 'D4.ir' + 'D4.igmin' + 'D4.icap';
    'D4.v' = 'D4.p.v' - 'D4.n.v';
    ('D2.cc', 'D2.m_dCap') = 'Modelica.Electrical.Spice3.Internal.Diode.diodeNoBypassCode'('Modelica.Electrical.Spice3.Internal.Diode.DiodeModelLineParams'(1e-14, 0.0, 1.0, 0.0, 1e-7, 1.0, 0.5, 1.11, 3.0, 0.5, 0.0, 0.0, 0.001, 300.15, 0.0, 1.0, 0.0), 'Modelica.Electrical.Spice3.Internal.Diode.DiodeParams'(1.0, false, 0.0, 0.0, false), 'Modelica.Electrical.Spice3.Internal.Diode.DiodeCalc'(1.0, 1e-7, 0.5857864376269049, 0.3535533905932738, 0.25, 1e-14, 0.7302825626525529, 0.025864680954552383, #EMPTY#), 'Modelica.Electrical.Spice3.Internal.Model.Model'(300.15), false, {'D2.pin', 'D2.n.v'});
    'D2.icap' = 'D2.m_dCap' * (der('D2.pin') - der('D2.n.v'));
    0.0 = 'D2.p.v' - 'D2.pin';
    'D2.igmin' = 1e-12 * ('D2.pin' - 'D2.n.v');
    'D2.p.i' = 'D2.ir';
    'D2.n.i' = -('D2.cc.m_dCurrent' + 'D2.igmin' + 'D2.icap');
    0.0 = 'D2.cc.m_dCurrent' - 'D2.ir' + 'D2.igmin' + 'D2.icap';
    'D2.v' = 'D2.p.v' - 'D2.n.v';
    0.0 = 'rout.p.i' + 'rout.n.i';
    'rout.i' = 'rout.p.i';
    'rout.v' = 'rout.p.v' - 'rout.n.v';
    'vsin.v' = if time < 0.0 then 0.0 else 10.0 * sin(1256.6370614359173 * time);
    0.0 = 'vsin.p.i' + 'vsin.n.i';
    'vsin.i' = 'vsin.p.i';
    'vsin.v' = 'vsin.p.v' - 'vsin.n.v';
    'ground.p.v' = 0.0;
  algorithm
    'rout.vp' := 'Modelica.Electrical.Spice3.Internal.Rsemiconductor.ResistorVariables'(0.0, 0.0, 10.0, 0.0, 0.0);
    ('rout.vp.m_dConduct', 'rout.vp.m_dCond_dTemp') := 'Modelica.Electrical.Spice3.Internal.Functions.resDepTemp'('rout.vp.m_dResist', 300.15, 'rout.lp.m_dTnom', 'rout.lp.m_dTC1', 'rout.lp.m_dTC2');
    'rout.i' := 'rout.vp.m_dConduct' * 'rout.v';
    annotation(experiment(StopTime = 0.025));
  end 'Graetz';
end 'Graetz';
