//! base 0.1.0
package 'IMC_DOL'
  function 'Complex.\'*\'.scalarProduct' "Scalar product of two complex vectors c1 and c2"
    input 'Complex'[:] 'c1';
    input 'Complex'[size('c1', 1)] 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex'(0.0, 0.0);

    for 'i' in 1:size('c1', 1) loop
      'c3' := 'Complex'('c3'.'re' + 'c1['i']'.'re' * 'c2['i']'.'re' + 'c1['i']'.'im' * 'c2['i']'.'im', 'c3'.'im' + 'c1['i']'.'re' * 'c2['i']'.'im' - 'c1['i']'.'im' * 'c2['i']'.'re');
    end for;
    annotation(Inline = true, smoothOrder = 100);
  end 'Complex.\'*\'.scalarProduct';

  function 'Complex.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Complex.\'constructor\'.fromReal';

  function 'Modelica.ComplexMath.abs' "Absolute value of complex number"
    input 'Complex' 'c';
    output Real 'result';
  algorithm
    'result' := sqrt('c'.'re' ^ 2.0 + 'c'.'im' ^ 2.0);
    annotation(Inline = true);
  end 'Modelica.ComplexMath.abs';

  function 'Modelica.ComplexMath.arg' "Phase angle of complex number"
    input 'Complex' 'c';
    input Real 'phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'phi'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'phi' := 'Modelica.Math.atan3'('c'.'im', 'c'.'re', 'phi0');
    annotation(Inline = true);
  end 'Modelica.ComplexMath.arg';

  function 'Modelica.ComplexMath.real' "Real part of complex number"
    input 'Complex' 'c';
    output Real 'r';
  algorithm
    'r' := 'c'.'re';
    annotation(Inline = true);
  end 'Modelica.ComplexMath.real';

  function 'Modelica.Electrical.QuasiStatic.Polyphase.Functions.quasiRMS' "Overall quasi-RMS value of complex input (current or voltage)"
    input 'Complex'[:] 'u';
    output Real 'y';
    Integer 'm' = size('u', 1);
  algorithm
    'y' := sum(sqrt('u['k']'.'re' ^ 2.0 + 'u['k']'.'im' ^ 2.0) for 'k' in 1:'m') / 'm';
    annotation(Inline = true);
  end 'Modelica.Electrical.QuasiStatic.Polyphase.Functions.quasiRMS';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := atan2('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    elseif true then
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  function 'Modelica.Units.SI.ComplexCurrent.\'+\'' "Add two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex'('c1'.'re' + 'c2'.'re', 'c1'.'im' + 'c2'.'im');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexCurrent.\'+\'';

  function 'Modelica.Units.SI.ComplexCurrent.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexCurrent.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexElectricPotential.\'-\'.subtract' "Subtract two complex numbers"
    input 'Complex' 'c1';
    input 'Complex' 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex'('c1'.'re' - 'c2'.'re', 'c1'.'im' - 'c2'.'im');
    annotation(Inline = true, smoothOrder = 100);
  end 'Modelica.Units.SI.ComplexElectricPotential.\'-\'.subtract';

  function 'Modelica.Units.SI.ComplexElectricPotential.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexElectricPotential.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexMagneticFlux.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexMagneticFlux.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexMagneticPotential.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexMagneticPotential.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexMagneticPotentialDifference.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexMagneticPotentialDifference.\'constructor\'.fromReal';

  function 'Modelica.Units.SI.ComplexVoltage.\'constructor\'.fromReal' "Construct Complex from Real"
    input Real 're';
    input Real 'im' = 0.0;
    output 'Complex' 'result';
  algorithm
    annotation(Inline = true);
  end 'Modelica.Units.SI.ComplexVoltage.\'constructor\'.fromReal';

  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  record 'Modelica.Units.SI.ComplexCurrent'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexCurrent';

  record 'Modelica.Units.SI.ComplexVoltage'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexVoltage';

  record 'Modelica.Units.SI.ComplexElectricPotential'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexElectricPotential';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexInput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexInput';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexOutput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexOutput';

  record 'Modelica.Units.SI.ComplexMagneticFlux'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexMagneticFlux';

  record 'Modelica.Units.SI.ComplexMagneticPotential'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexMagneticPotential';

  record 'Modelica.Units.SI.ComplexMagneticPotentialDifference'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexMagneticPotentialDifference';

  model 'IMC_DOL' "Induction machine with squirrel cage started directly on line (DOL)"
    parameter Integer 'm' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'tOn'(unit = "s", quantity = "Time") = 0.1 "Start time of machine";
    parameter Real 'T_Load'(unit = "N.m", quantity = "Torque") = 161.4 "Nominal load torque";
    parameter Real 'w_Load'(displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 150.84357126211393 "Nominal load speed";
    parameter Real 'J_Load'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.5 "Load inertia";
    parameter Integer 'p' = 2 "Number of pole pairs";
    output Real 'Itr'(unit = "A", quantity = "ElectricCurrent") "Transient RMS current";
    output Real 'Iqs'(unit = "A", quantity = "ElectricCurrent") "QS RMS current";
    parameter Integer 'voltageSourceQS.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'voltageSourceQS.v[1].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.v[1].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.v[2].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.v[2].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.v[3].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.v[3].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.abs_v[1]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'voltageSourceQS.abs_v[2]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'voltageSourceQS.abs_v[3]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'voltageSourceQS.arg_v[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'voltageSourceQS.arg_v[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'voltageSourceQS.arg_v[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'voltageSourceQS.i[1].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.i[1].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.i[2].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.i[2].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.i[3].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.i[3].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.abs_i[1]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'voltageSourceQS.abs_i[2]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'voltageSourceQS.abs_i[3]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'voltageSourceQS.arg_i[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'voltageSourceQS.arg_i[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'voltageSourceQS.arg_i[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'voltageSourceQS.P[1]'(unit = "W", quantity = "Power") "Active power";
    Real 'voltageSourceQS.P[2]'(unit = "W", quantity = "Power") "Active power";
    Real 'voltageSourceQS.P[3]'(unit = "W", quantity = "Power") "Active power";
    Real 'voltageSourceQS.P_total'(unit = "W", quantity = "Power") "Total active power";
    Real 'voltageSourceQS.Q[1]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSourceQS.Q[2]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSourceQS.Q[3]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSourceQS.Q_total'(unit = "var", quantity = "Power") "Total reactive power";
    Real 'voltageSourceQS.S[1]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSourceQS.S[2]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSourceQS.S[3]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSourceQS.S_total'(unit = "V.A", quantity = "Power") "Magnitude of total complex apparent power";
    Real 'voltageSourceQS.pf[1]' "Power factor";
    Real 'voltageSourceQS.pf[2]' "Power factor";
    Real 'voltageSourceQS.pf[3]' "Power factor";
    Real 'voltageSourceQS.omega'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of reference frame";
    parameter Integer 'voltageSourceQS.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'voltageSourceQS.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.plug_p.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_p.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.plug_p.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'voltageSourceQS.plug_n.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'voltageSourceQS.plug_n.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.plug_n.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_n.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.plug_n.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_n.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.plug_n.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_n.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.plug_n.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_n.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSourceQS.plug_n.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_n.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSourceQS.plug_n.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSourceQS.plug_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'voltageSourceQS.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    Real 'voltageSourceQS.gamma'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Real 'voltageSourceQS.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of the source";
    parameter Real 'voltageSourceQS.V[1]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 100.0 "RMS voltage of the source";
    parameter Real 'voltageSourceQS.V[2]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 100.0 "RMS voltage of the source";
    parameter Real 'voltageSourceQS.V[3]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 100.0 "RMS voltage of the source";
    parameter Real 'voltageSourceQS.phi[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase shift of the source";
    parameter Real 'voltageSourceQS.phi[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.0943951023931953 "Phase shift of the source";
    parameter Real 'voltageSourceQS.phi[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -4.1887902047863905 "Phase shift of the source";
    parameter Integer 'starQS.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'starQS.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'starQS.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plug_p.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plug_p.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plug_p.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'starQS.pin_n.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.pin_n.v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.pin_n.i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.pin_n.i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.pin_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'starQS.plugToPins_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'starQS.plugToPins_p.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'starQS.plugToPins_p.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plugToPins_p.plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'starQS.plugToPins_p.pin_p[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plugToPins_p.pin_p[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.pin_p[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plugToPins_p.pin_p[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.pin_p[1].reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'starQS.plugToPins_p.pin_p[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plugToPins_p.pin_p[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.pin_p[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plugToPins_p.pin_p[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.pin_p[2].reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'starQS.plugToPins_p.pin_p[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plugToPins_p.pin_p[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.pin_p[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plugToPins_p.pin_p[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.pin_p[3].reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'starQS.plugToPins_p.plugToPin_p[1].m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'starQS.plugToPins_p.plugToPin_p[1].k'(max = 3, min = 1) = 1 "Phase index" annotation(Evaluate = true);
    parameter Integer 'starQS.plugToPins_p.plugToPin_p[1].plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
