    Real 'world.x_arrowHead.width'(unit = "m", quantity = "Length") "Width of visual object";
    Real 'world.x_arrowHead.height'(unit = "m", quantity = "Length") "Height of visual object";
    Real 'world.x_arrowHead.extra' "Additional size data for some of the shape types";
