//! base 0.1.0
package 'AutomaticSeed'
  function 'Modelica.Math.Random.Generators.Xorshift128plus.random' "Returns a uniform random number with the xorshift128+ algorithm"
    input Integer[4] 'stateIn';
    output Real 'result';
    output Integer[4] 'stateOut';
  external "C" ModelicaRandom_xorshift128plus('stateIn', 'stateOut', 'result') annotation(Library = "ModelicaExternalC", LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Math.Random.Generators.Xorshift128plus.random';

  function 'Modelica.Math.Random.Utilities.initialStateWithXorshift64star' "Return an initial state vector for a random number generator (based on xorshift64star algorithm)"
    input Integer 'localSeed';
    input Integer 'globalSeed';
    input Integer 'nState'(min = 1);
    output Integer['nState'] 'state';
    Real 'r';
    Integer[2] 'aux';
    Integer 'nStateEven';
  algorithm
    'aux' := 'Modelica.Math.Random.Generators.Xorshift64star.initialState'('localSeed', 'globalSeed');

    if 'nState' >= 2 then
      'state'[1:2] := 'aux';
    else
      'state'[1] := 'aux'[1];
    end if;

    'nStateEven' := 2 * div('nState', 2);

    for 'i' in 3:2:'nStateEven' loop
      ('r', 'aux') := 'Modelica.Math.Random.Generators.Xorshift64star.random'('state'['i' - 2:'i' - 1]);
      'state'['i':'i' + 1] := 'aux';
    end for;

    if 'nState' >= 3 and 'nState' <> 'nStateEven' then
      ('r', 'aux') := 'Modelica.Math.Random.Generators.Xorshift64star.random'('state'['nState' - 2:'nState' - 1]);
      'state'['nState'] := 'aux'[1];
    end if;
  end 'Modelica.Math.Random.Utilities.initialStateWithXorshift64star';

  function 'Modelica.Math.Random.Utilities.initializeImpureRandom' "Initializes the internal state of the impure random number generator"
    input Integer 'seed';
    output Integer 'id';
    constant Integer 'localSeed' = 715827883;
    Integer[33] 'rngState';
  algorithm
    'rngState' := 'Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('localSeed', 'seed', 33);
    'id' := 'localSeed';
    'Modelica.Math.Random.Utilities.initializeImpureRandom.setInternalState'('rngState', 'id');
  end 'Modelica.Math.Random.Utilities.initializeImpureRandom';

  model 'AutomaticSeed' "Demonstrates noise with startTime and automatic local seed for UniformNoise"
    parameter Real 'startTime'(unit = "s", quantity = "Time") = 0.5 "Start time of noise";
    parameter Real 'y_off' = -1.0 "Output of block before startTime";
    output Real 'manualSeed1_y';
    output Real 'manualSeed2_y';
    output Real 'manualSeed3_y';
    parameter Boolean 'globalSeed.enableNoise' = true "= true, if noise blocks generate noise as output; = false, if they generate a constant output";
    parameter Boolean 'globalSeed.useAutomaticSeed' = false "= true, choose a seed by system time and process id; = false, use fixedSeed";
    parameter Integer 'globalSeed.fixedSeed' = 67867967 "Fixed global seed for random number generators (if useAutomaticSeed = false)";
    parameter Integer 'globalSeed.seed'(fixed = false) "Actually used global seed";
    parameter Integer 'globalSeed.id_impure'(fixed = false) "ID for impure random number generators Modelica.Math.Random.Utilities.impureXXX";
    Real 'automaticSeed1.y' "Connector of Real output signal";
    parameter Real 'automaticSeed1.samplePeriod'(start = 0.01, unit = "s", quantity = "Time") = 0.01 "Period for sampling the raw random numbers";
    parameter Boolean 'automaticSeed1.enableNoise' = true "= true: y = noise, otherwise y = y_off";
    parameter Real 'automaticSeed1.y_off' = -1.0 "Sets y = y_off if enableNoise=false (or time<startTime, see below)";
    parameter Boolean 'automaticSeed1.useGlobalSeed' = true "= true: use global seed, otherwise ignore it";
    parameter Boolean 'automaticSeed1.useAutomaticLocalSeed' = true "= true: use automatic local seed, otherwise use fixedLocalSeed";
    parameter Integer 'automaticSeed1.fixedLocalSeed' = 1 "Local seed (any Integer number)";
    parameter Real 'automaticSeed1.startTime'(unit = "s", quantity = "Time") = 0.5 "Start time for sampling the raw random numbers";
    parameter Integer 'automaticSeed1.localSeed'(fixed = false) "The actual localSeed";
    parameter Integer 'automaticSeed1.actualGlobalSeed' = 'globalSeed.seed' "The global seed, which is actually used";
    parameter Boolean 'automaticSeed1.generateNoise' = true "= true, if noise shall be generated, otherwise no noise";
    Integer 'automaticSeed1.state[1]' "Internal state of random number generator";
    Integer 'automaticSeed1.state[2]' "Internal state of random number generator";
    Integer 'automaticSeed1.state[3]' "Internal state of random number generator";
    Integer 'automaticSeed1.state[4]' "Internal state of random number generator";
    discrete Real 'automaticSeed1.r' "Random number according to the desired distribution";
    discrete Real 'automaticSeed1.r_raw' "Uniform random number in the range (0,1]";
    parameter Real 'automaticSeed1.y_min'(start = 0.0) = -1.0 "Lower limit of y";
    parameter Real 'automaticSeed1.y_max'(start = 1.0) = 3.0 "Upper limit of y";
    Real 'automaticSeed2.y' "Connector of Real output signal";
    parameter Real 'automaticSeed2.samplePeriod'(start = 0.01, unit = "s", quantity = "Time") = 0.01 "Period for sampling the raw random numbers";
    parameter Boolean 'automaticSeed2.enableNoise' = true "= true: y = noise, otherwise y = y_off";
    parameter Real 'automaticSeed2.y_off' = -1.0 "Sets y = y_off if enableNoise=false (or time<startTime, see below)";
    parameter Boolean 'automaticSeed2.useGlobalSeed' = true "= true: use global seed, otherwise ignore it";
    parameter Boolean 'automaticSeed2.useAutomaticLocalSeed' = true "= true: use automatic local seed, otherwise use fixedLocalSeed";
    parameter Integer 'automaticSeed2.fixedLocalSeed' = 1 "Local seed (any Integer number)";
    parameter Real 'automaticSeed2.startTime'(unit = "s", quantity = "Time") = 0.5 "Start time for sampling the raw random numbers";
    parameter Integer 'automaticSeed2.localSeed'(fixed = false) "The actual localSeed";
    parameter Integer 'automaticSeed2.actualGlobalSeed' = 'globalSeed.seed' "The global seed, which is actually used";
    parameter Boolean 'automaticSeed2.generateNoise' = true "= true, if noise shall be generated, otherwise no noise";
    Integer 'automaticSeed2.state[1]' "Internal state of random number generator";
    Integer 'automaticSeed2.state[2]' "Internal state of random number generator";
    Integer 'automaticSeed2.state[3]' "Internal state of random number generator";
    Integer 'automaticSeed2.state[4]' "Internal state of random number generator";
    discrete Real 'automaticSeed2.r' "Random number according to the desired distribution";
    discrete Real 'automaticSeed2.r_raw' "Uniform random number in the range (0,1]";
    parameter Real 'automaticSeed2.y_min'(start = 0.0) = -1.0 "Lower limit of y";
    parameter Real 'automaticSeed2.y_max'(start = 1.0) = 3.0 "Upper limit of y";
    Real 'automaticSeed3.y' "Connector of Real output signal";
    parameter Real 'automaticSeed3.samplePeriod'(start = 0.01, unit = "s", quantity = "Time") = 0.01 "Period for sampling the raw random numbers";
    parameter Boolean 'automaticSeed3.enableNoise' = true "= true: y = noise, otherwise y = y_off";
    parameter Real 'automaticSeed3.y_off' = -1.0 "Sets y = y_off if enableNoise=false (or time<startTime, see below)";
    parameter Boolean 'automaticSeed3.useGlobalSeed' = true "= true: use global seed, otherwise ignore it";
    parameter Boolean 'automaticSeed3.useAutomaticLocalSeed' = true "= true: use automatic local seed, otherwise use fixedLocalSeed";
    parameter Integer 'automaticSeed3.fixedLocalSeed' = 1 "Local seed (any Integer number)";
    parameter Real 'automaticSeed3.startTime'(unit = "s", quantity = "Time") = 0.5 "Start time for sampling the raw random numbers";
    parameter Integer 'automaticSeed3.localSeed'(fixed = false) "The actual localSeed";
    parameter Integer 'automaticSeed3.actualGlobalSeed' = 'globalSeed.seed' "The global seed, which is actually used";
    parameter Boolean 'automaticSeed3.generateNoise' = true "= true, if noise shall be generated, otherwise no noise";
    Integer 'automaticSeed3.state[1]' "Internal state of random number generator";
    Integer 'automaticSeed3.state[2]' "Internal state of random number generator";
    Integer 'automaticSeed3.state[3]' "Internal state of random number generator";
    Integer 'automaticSeed3.state[4]' "Internal state of random number generator";
    discrete Real 'automaticSeed3.r' "Random number according to the desired distribution";
    discrete Real 'automaticSeed3.r_raw' "Uniform random number in the range (0,1]";
    parameter Real 'automaticSeed3.y_min'(start = 0.0) = -1.0 "Lower limit of y";
    parameter Real 'automaticSeed3.y_max'(start = 1.0) = 3.0 "Upper limit of y";
    Real 'manualSeed1.y' "Connector of Real output signal";
    parameter Real 'manualSeed1.samplePeriod'(start = 0.01, unit = "s", quantity = "Time") = 0.01 "Period for sampling the raw random numbers";
    parameter Boolean 'manualSeed1.enableNoise' = true "= true: y = noise, otherwise y = y_off";
    parameter Real 'manualSeed1.y_off' = -1.0 "Sets y = y_off if enableNoise=false (or time<startTime, see below)";
    parameter Boolean 'manualSeed1.useGlobalSeed' = true "= true: use global seed, otherwise ignore it";
    parameter Boolean 'manualSeed1.useAutomaticLocalSeed' = false "= true: use automatic local seed, otherwise use fixedLocalSeed";
    parameter Integer 'manualSeed1.fixedLocalSeed' = 1 "Local seed (any Integer number)";
    parameter Real 'manualSeed1.startTime'(unit = "s", quantity = "Time") = 0.5 "Start time for sampling the raw random numbers";
    parameter Integer 'manualSeed1.localSeed'(fixed = false) "The actual localSeed";
    parameter Integer 'manualSeed1.actualGlobalSeed' = 'globalSeed.seed' "The global seed, which is actually used";
    parameter Boolean 'manualSeed1.generateNoise' = true "= true, if noise shall be generated, otherwise no noise";
    Integer 'manualSeed1.state[1]' "Internal state of random number generator";
    Integer 'manualSeed1.state[2]' "Internal state of random number generator";
    Integer 'manualSeed1.state[3]' "Internal state of random number generator";
    Integer 'manualSeed1.state[4]' "Internal state of random number generator";
    discrete Real 'manualSeed1.r' "Random number according to the desired distribution";
    discrete Real 'manualSeed1.r_raw' "Uniform random number in the range (0,1]";
    parameter Real 'manualSeed1.y_min'(start = 0.0) = -1.0 "Lower limit of y";
    parameter Real 'manualSeed1.y_max'(start = 1.0) = 3.0 "Upper limit of y";
    Real 'manualSeed2.y' "Connector of Real output signal";
    parameter Real 'manualSeed2.samplePeriod'(start = 0.01, unit = "s", quantity = "Time") = 0.01 "Period for sampling the raw random numbers";
    parameter Boolean 'manualSeed2.enableNoise' = true "= true: y = noise, otherwise y = y_off";
    parameter Real 'manualSeed2.y_off' = -1.0 "Sets y = y_off if enableNoise=false (or time<startTime, see below)";
    parameter Boolean 'manualSeed2.useGlobalSeed' = true "= true: use global seed, otherwise ignore it";
    parameter Boolean 'manualSeed2.useAutomaticLocalSeed' = false "= true: use automatic local seed, otherwise use fixedLocalSeed";
    parameter Integer 'manualSeed2.fixedLocalSeed' = 2 "Local seed (any Integer number)";
    parameter Real 'manualSeed2.startTime'(unit = "s", quantity = "Time") = 0.5 "Start time for sampling the raw random numbers";
    parameter Integer 'manualSeed2.localSeed'(fixed = false) "The actual localSeed";
    parameter Integer 'manualSeed2.actualGlobalSeed' = 'globalSeed.seed' "The global seed, which is actually used";
    parameter Boolean 'manualSeed2.generateNoise' = true "= true, if noise shall be generated, otherwise no noise";
    Integer 'manualSeed2.state[1]' "Internal state of random number generator";
    Integer 'manualSeed2.state[2]' "Internal state of random number generator";
    Integer 'manualSeed2.state[3]' "Internal state of random number generator";
    Integer 'manualSeed2.state[4]' "Internal state of random number generator";
    discrete Real 'manualSeed2.r' "Random number according to the desired distribution";
    discrete Real 'manualSeed2.r_raw' "Uniform random number in the range (0,1]";
    parameter Real 'manualSeed2.y_min'(start = 0.0) = -1.0 "Lower limit of y";
    parameter Real 'manualSeed2.y_max'(start = 1.0) = 3.0 "Upper limit of y";
    Real 'manualSeed3.y' "Connector of Real output signal";
    parameter Real 'manualSeed3.samplePeriod'(start = 0.01, unit = "s", quantity = "Time") = 0.01 "Period for sampling the raw random numbers";
    parameter Boolean 'manualSeed3.enableNoise' = true "= true: y = noise, otherwise y = y_off";
    parameter Real 'manualSeed3.y_off' = -1.0 "Sets y = y_off if enableNoise=false (or time<startTime, see below)";
    parameter Boolean 'manualSeed3.useGlobalSeed' = true "= true: use global seed, otherwise ignore it";
    parameter Boolean 'manualSeed3.useAutomaticLocalSeed' = false "= true: use automatic local seed, otherwise use fixedLocalSeed";
    parameter Integer 'manualSeed3.fixedLocalSeed' = 3 "Local seed (any Integer number)";
    parameter Real 'manualSeed3.startTime'(unit = "s", quantity = "Time") = 0.5 "Start time for sampling the raw random numbers";
    parameter Integer 'manualSeed3.localSeed'(fixed = false) "The actual localSeed";
    parameter Integer 'manualSeed3.actualGlobalSeed' = 'globalSeed.seed' "The global seed, which is actually used";
    parameter Boolean 'manualSeed3.generateNoise' = true "= true, if noise shall be generated, otherwise no noise";
    Integer 'manualSeed3.state[1]' "Internal state of random number generator";
    Integer 'manualSeed3.state[2]' "Internal state of random number generator";
    Integer 'manualSeed3.state[3]' "Internal state of random number generator";
    Integer 'manualSeed3.state[4]' "Internal state of random number generator";
    discrete Real 'manualSeed3.r' "Random number according to the desired distribution";
    discrete Real 'manualSeed3.r_raw' "Uniform random number in the range (0,1]";
    parameter Real 'manualSeed3.y_min'(start = 0.0) = -1.0 "Lower limit of y";
    parameter Real 'manualSeed3.y_max'(start = 1.0) = 3.0 "Upper limit of y";
  initial equation
    'globalSeed.seed' = 67867967;
    'globalSeed.id_impure' = 'Modelica.Math.Random.Utilities.initializeImpureRandom'('globalSeed.seed');
    'automaticSeed1.r' = 'automaticSeed1.r_raw' * (3.0 - (-1.0)) + (-1.0);
    'automaticSeed1.localSeed' = 163662653;
    pre('automaticSeed1.state[1]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed1.localSeed', 'automaticSeed1.actualGlobalSeed', 4))[1];
    pre('automaticSeed1.state[2]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed1.localSeed', 'automaticSeed1.actualGlobalSeed', 4))[2];
    pre('automaticSeed1.state[3]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed1.localSeed', 'automaticSeed1.actualGlobalSeed', 4))[3];
    pre('automaticSeed1.state[4]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed1.localSeed', 'automaticSeed1.actualGlobalSeed', 4))[4];
    'automaticSeed1.r_raw' = 'Modelica.Math.Random.Generators.Xorshift128plus.random'(pre('automaticSeed1.state'));
    'automaticSeed2.r' = 'automaticSeed2.r_raw' * (3.0 - (-1.0)) + (-1.0);
    'automaticSeed2.localSeed' = 163662654;
    pre('automaticSeed2.state[1]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed2.localSeed', 'automaticSeed2.actualGlobalSeed', 4))[1];
    pre('automaticSeed2.state[2]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed2.localSeed', 'automaticSeed2.actualGlobalSeed', 4))[2];
    pre('automaticSeed2.state[3]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed2.localSeed', 'automaticSeed2.actualGlobalSeed', 4))[3];
    pre('automaticSeed2.state[4]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed2.localSeed', 'automaticSeed2.actualGlobalSeed', 4))[4];
    'automaticSeed2.r_raw' = 'Modelica.Math.Random.Generators.Xorshift128plus.random'(pre('automaticSeed2.state'));
    'automaticSeed3.r' = 'automaticSeed3.r_raw' * (3.0 - (-1.0)) + (-1.0);
    'automaticSeed3.localSeed' = 163662655;
    pre('automaticSeed3.state[1]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed3.localSeed', 'automaticSeed3.actualGlobalSeed', 4))[1];
    pre('automaticSeed3.state[2]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed3.localSeed', 'automaticSeed3.actualGlobalSeed', 4))[2];
    pre('automaticSeed3.state[3]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed3.localSeed', 'automaticSeed3.actualGlobalSeed', 4))[3];
    pre('automaticSeed3.state[4]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('automaticSeed3.localSeed', 'automaticSeed3.actualGlobalSeed', 4))[4];
    'automaticSeed3.r_raw' = 'Modelica.Math.Random.Generators.Xorshift128plus.random'(pre('automaticSeed3.state'));
    'manualSeed1.r' = 'manualSeed1.r_raw' * (3.0 - (-1.0)) + (-1.0);
    'manualSeed1.localSeed' = 1;
    pre('manualSeed1.state[1]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed1.localSeed', 'manualSeed1.actualGlobalSeed', 4))[1];
    pre('manualSeed1.state[2]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed1.localSeed', 'manualSeed1.actualGlobalSeed', 4))[2];
    pre('manualSeed1.state[3]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed1.localSeed', 'manualSeed1.actualGlobalSeed', 4))[3];
    pre('manualSeed1.state[4]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed1.localSeed', 'manualSeed1.actualGlobalSeed', 4))[4];
    'manualSeed1.r_raw' = 'Modelica.Math.Random.Generators.Xorshift128plus.random'(pre('manualSeed1.state'));
    'manualSeed2.r' = 'manualSeed2.r_raw' * (3.0 - (-1.0)) + (-1.0);
    'manualSeed2.localSeed' = 2;
    pre('manualSeed2.state[1]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed2.localSeed', 'manualSeed2.actualGlobalSeed', 4))[1];
    pre('manualSeed2.state[2]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed2.localSeed', 'manualSeed2.actualGlobalSeed', 4))[2];
    pre('manualSeed2.state[3]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed2.localSeed', 'manualSeed2.actualGlobalSeed', 4))[3];
    pre('manualSeed2.state[4]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed2.localSeed', 'manualSeed2.actualGlobalSeed', 4))[4];
    'manualSeed2.r_raw' = 'Modelica.Math.Random.Generators.Xorshift128plus.random'(pre('manualSeed2.state'));
    'manualSeed3.r' = 'manualSeed3.r_raw' * (3.0 - (-1.0)) + (-1.0);
    'manualSeed3.localSeed' = 3;
    pre('manualSeed3.state[1]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed3.localSeed', 'manualSeed3.actualGlobalSeed', 4))[1];
    pre('manualSeed3.state[2]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed3.localSeed', 'manualSeed3.actualGlobalSeed', 4))[2];
    pre('manualSeed3.state[3]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed3.localSeed', 'manualSeed3.actualGlobalSeed', 4))[3];
    pre('manualSeed3.state[4]') = ('Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('manualSeed3.localSeed', 'manualSeed3.actualGlobalSeed', 4))[4];
    'manualSeed3.r_raw' = 'Modelica.Math.Random.Generators.Xorshift128plus.random'(pre('manualSeed3.state'));
  equation
    'manualSeed1_y' = 'manualSeed1.y';
    'manualSeed2_y' = 'manualSeed2.y';
    'manualSeed3_y' = 'manualSeed3.y';

    when sample(0.5, 0.01) then
      'automaticSeed1.r' = 'automaticSeed1.r_raw' * (3.0 - (-1.0)) + (-1.0);
    end when;

    when sample(0.5, 0.01) then
      ('automaticSeed1.r_raw', 'automaticSeed1.state') = 'Modelica.Math.Random.Generators.Xorshift128plus.random'({pre('automaticSeed1.state[1]'), pre('automaticSeed1.state[2]'), pre('automaticSeed1.state[3]'), pre('automaticSeed1.state[4]')});
    end when;

    'automaticSeed1.y' = if time < 0.5 then -1.0 else 'automaticSeed1.r';

    when sample(0.5, 0.01) then
      'automaticSeed2.r' = 'automaticSeed2.r_raw' * (3.0 - (-1.0)) + (-1.0);
    end when;

    when sample(0.5, 0.01) then
      ('automaticSeed2.r_raw', 'automaticSeed2.state') = 'Modelica.Math.Random.Generators.Xorshift128plus.random'({pre('automaticSeed2.state[1]'), pre('automaticSeed2.state[2]'), pre('automaticSeed2.state[3]'), pre('automaticSeed2.state[4]')});
    end when;

    'automaticSeed2.y' = if time < 0.5 then -1.0 else 'automaticSeed2.r';

    when sample(0.5, 0.01) then
      'automaticSeed3.r' = 'automaticSeed3.r_raw' * (3.0 - (-1.0)) + (-1.0);
    end when;

    when sample(0.5, 0.01) then
      ('automaticSeed3.r_raw', 'automaticSeed3.state') = 'Modelica.Math.Random.Generators.Xorshift128plus.random'({pre('automaticSeed3.state[1]'), pre('automaticSeed3.state[2]'), pre('automaticSeed3.state[3]'), pre('automaticSeed3.state[4]')});
    end when;

    'automaticSeed3.y' = if time < 0.5 then -1.0 else 'automaticSeed3.r';

    when sample(0.5, 0.01) then
      'manualSeed1.r' = 'manualSeed1.r_raw' * (3.0 - (-1.0)) + (-1.0);
    end when;

    when sample(0.5, 0.01) then
      ('manualSeed1.r_raw', 'manualSeed1.state') = 'Modelica.Math.Random.Generators.Xorshift128plus.random'({pre('manualSeed1.state[1]'), pre('manualSeed1.state[2]'), pre('manualSeed1.state[3]'), pre('manualSeed1.state[4]')});
    end when;

    'manualSeed1.y' = if time < 0.5 then -1.0 else 'manualSeed1.r';

    when sample(0.5, 0.01) then
      'manualSeed2.r' = 'manualSeed2.r_raw' * (3.0 - (-1.0)) + (-1.0);
    end when;

    when sample(0.5, 0.01) then
      ('manualSeed2.r_raw', 'manualSeed2.state') = 'Modelica.Math.Random.Generators.Xorshift128plus.random'({pre('manualSeed2.state[1]'), pre('manualSeed2.state[2]'), pre('manualSeed2.state[3]'), pre('manualSeed2.state[4]')});
    end when;

    'manualSeed2.y' = if time < 0.5 then -1.0 else 'manualSeed2.r';

    when sample(0.5, 0.01) then
      'manualSeed3.r' = 'manualSeed3.r_raw' * (3.0 - (-1.0)) + (-1.0);
    end when;

    when sample(0.5, 0.01) then
      ('manualSeed3.r_raw', 'manualSeed3.state') = 'Modelica.Math.Random.Generators.Xorshift128plus.random'({pre('manualSeed3.state[1]'), pre('manualSeed3.state[2]'), pre('manualSeed3.state[3]'), pre('manualSeed3.state[4]')});
    end when;

    'manualSeed3.y' = if time < 0.5 then -1.0 else 'manualSeed3.r';
    annotation(experiment(StopTime = 2));
  end 'AutomaticSeed';
end 'AutomaticSeed';
