    Real 'pipe2.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'pipe2.port_b.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe2.port_b.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'pipe2.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'pipe2.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'pipe2.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'pipe2.nParallel'(min = 1.0) = 1.0 "Number of identical parallel pipes";
    parameter Real 'pipe2.length'(unit = "m", quantity = "Length") = 1000.0 "Length";
    parameter Boolean 'pipe2.isCircular' = true "= true, if cross sectional area is circular" annotation(Evaluate = true);
    parameter Real 'pipe2.diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.0254 "Diameter of circular pipe";
    parameter Real 'pipe2.crossArea'(unit = "m2", quantity = "Area") = 5.067074790974977e-4 "Inner cross section area";
    parameter Real 'pipe2.perimeter'(min = 0.0, unit = "m", quantity = "Length") = 0.07979645340118074 "Inner perimeter";
    parameter Real 'pipe2.roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average height of surface asperities (default: smooth steel pipe)";
    parameter Real 'pipe2.V'(unit = "m3", quantity = "Volume") = 0.5067074790974977 "Volume size";
    parameter Real 'pipe2.height_ab'(unit = "m", quantity = "Length") = 0.0 "Height(port_b) - Height(port_a)";
    parameter Real 'pipe2.p_a_start'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port a";
    parameter Real 'pipe2.p_b_start'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure at port b";
    parameter Real 'pipe2.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 0.4 "Start value for mass flow rate" annotation(Evaluate = true);
    parameter Integer 'pipe2.flowModel.n' = 2 "Number of discrete flow volumes";
    Integer 'pipe2.flowModel.states[1].phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'pipe2.flowModel.states[1].h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'pipe2.flowModel.states[1].d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'pipe2.flowModel.states[1].T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'pipe2.flowModel.states[1].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Integer 'pipe2.flowModel.states[2].phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'pipe2.flowModel.states[2].h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'pipe2.flowModel.states[2].d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'pipe2.flowModel.states[2].T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'pipe2.flowModel.states[2].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    Real 'pipe2.flowModel.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    Real 'pipe2.flowModel.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    parameter Real 'pipe2.flowModel.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'pipe2.flowModel.crossAreas[1]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe2.flowModel.crossAreas[2]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe2.flowModel.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe2.flowModel.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe2.flowModel.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe2.flowModel.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe2.flowModel.dheights[1]'(unit = "m", quantity = "Length") "Height(states[2:n]) - Height(states[1:n-1])";
    parameter Real 'pipe2.flowModel.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'pipe2.flowModel.allowFlowReversal' = true "= true, if flow reversal is enabled, otherwise restrict flow to design direction (states[1] -> states[n+1])" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe2.flowModel.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance" annotation(Evaluate = true);
    parameter Real 'pipe2.flowModel.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 0.4 "Start value of mass flow rates";
    parameter Real 'pipe2.flowModel.p_a_start'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[1] at design inflow";
    parameter Real 'pipe2.flowModel.p_b_start'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value for p[n+1] at design outflow";
    parameter Integer 'pipe2.flowModel.m' = 1 "Number of flow segments";
    Real 'pipe2.flowModel.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe2.flowModel.m_flows[1]'(stateSelect = StateSelect.default, start = 0.4, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rates between states";
    Real 'pipe2.flowModel.Is[1]'(unit = "kg.m/s", quantity = "Momentum") "Momenta of flow segments";
    Real 'pipe2.flowModel.Ib_flows[1]'(unit = "N", quantity = "Force") "Flow of momentum across boundaries";
    Real 'pipe2.flowModel.Fs_p[1]'(unit = "N", quantity = "Force") "Pressure forces";
    Real 'pipe2.flowModel.Fs_fg[1]'(unit = "N", quantity = "Force") "Friction and gravity forces";
    parameter Boolean 'pipe2.flowModel.useUpstreamScheme' = true "= false to average upstream and downstream properties across flow segments" annotation(Evaluate = true);
    parameter Boolean 'pipe2.flowModel.use_Ib_flows' = false "= true to consider differences in flow of momentum through boundaries" annotation(Evaluate = true);
    Real 'pipe2.flowModel.rhos[1]'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe2.flowModel.rhos[2]'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe2.flowModel.rhos_act[1]'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
    Real 'pipe2.flowModel.mus[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe2.flowModel.mus[2]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe2.flowModel.mus_act[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") "Actual viscosity per segment";
    Real 'pipe2.flowModel.dps_fg[1]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    parameter Real 'pipe2.flowModel.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0 "Start of turbulent regime, depending on type of flow device";
    parameter Boolean 'pipe2.flowModel.show_Res' = true "= true, if Reynolds numbers are included for plotting" annotation(Evaluate = true);
    Real 'pipe2.flowModel.Res[1]'(unit = "1", quantity = "ReynoldsNumber") "Reynolds numbers";
    Real 'pipe2.flowModel.Res[2]'(unit = "1", quantity = "ReynoldsNumber") "Reynolds numbers";
    Real 'pipe2.flowModel.m_flows_turbulent[1]'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Start of turbulent flow";
    parameter Boolean 'pipe2.flowModel.use_rho_nominal' = false "= true, if rho_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe2.flowModel.rho_nominal'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 998.2060924679472 "Nominal density (e.g., rho_liquidWater = 995, rho_air = 1.2)";
    parameter Boolean 'pipe2.flowModel.use_mu_nominal' = false "= true, if mu_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe2.flowModel.mu_nominal'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") = 0.0010016053256479086 "Nominal dynamic viscosity (e.g., mu_liquidWater = 1e-3, mu_air = 1.8e-5)";
    parameter Real 'pipe2.flowModel.dp_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Nominal pressure loss";
    parameter Real 'pipe2.flowModel.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 1.0 "Mass flow rate for dp_nominal";
    Real 'pipe2.flowModel.pathLengths_nominal[1]'(unit = "m", quantity = "Length") "Lengths resulting from given nominal values for circular tubes";
    parameter Integer 'sink2.nPorts' = 1 "Number of ports";
    Real 'sink2.medium.p'(stateSelect = StateSelect.default, nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'sink2.medium.h'(stateSelect = StateSelect.default, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'sink2.medium.d'(stateSelect = StateSelect.default, nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'sink2.medium.T'(stateSelect = StateSelect.default, nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'sink2.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'sink2.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'sink2.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'sink2.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Integer 'sink2.medium.state.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'sink2.medium.state.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'sink2.medium.state.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'sink2.medium.state.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'sink2.medium.state.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'sink2.medium.preferredMediumStates' = false "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'sink2.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'sink2.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'sink2.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'sink2.medium.sat.psat'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Saturation pressure";
    Real 'sink2.medium.sat.Tsat'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Saturation temperature";
    Integer 'sink2.medium.phase'(fixed = false, start = 1, max = 2, min = 0) "2 for two-phase, 1 for one-phase, 0 if not known";
    Real 'sink2.ports[1].m_flow'(max = 1e60, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'sink2.ports[1].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'sink2.ports[1].h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter 'Modelica.Fluid.Types.PortFlowDirection' 'sink2.flowDirection' = 'Modelica.Fluid.Types.PortFlowDirection'.'Bidirectional' "Allowed flow direction" annotation(Evaluate = true);
    parameter Boolean 'sink2.use_p_in' = false "Get the pressure from the input connector" annotation(Evaluate = true);
    parameter Boolean 'sink2.use_T_in' = false "Get the temperature from the input connector" annotation(Evaluate = true);
    parameter Boolean 'sink2.use_X_in' = false "Get the composition from the input connector" annotation(Evaluate = true);
    parameter Boolean 'sink2.use_C_in' = false "Get the trace substances from the input connector" annotation(Evaluate = true);
    parameter Real 'sink2.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 2e5 "Fixed value of pressure";
    parameter Real 'sink2.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed value of temperature";
    parameter Real 'sink2.X[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Fixed value of composition";
    Real 'sink2.p_in_internal'(unit = "Pa") "Needed to connect to conditional connector";
    Real 'sink2.T_in_internal'(unit = "K") "Needed to connect to conditional connector";
    Real 'sink2.X_in_internal[1]'(unit = "1") "Needed to connect to conditional connector";
  initial equation
    assert(abs('pipe1.flowModel.crossAreas[1]' - 0.7853981633974483 * 'pipe1.flowModel.dimensions[1]' ^ 2.0) < 1e-10 * 'pipe1.flowModel.crossAreas[1]', "NominalTurbulentPipeFlow model requires circular tubes", AssertionLevel.error);
    assert(abs('pipe1.flowModel.crossAreas[2]' - 0.7853981633974483 * 'pipe1.flowModel.dimensions[2]' ^ 2.0) < 1e-10 * 'pipe1.flowModel.crossAreas[2]', "NominalTurbulentPipeFlow model requires circular tubes", AssertionLevel.error);
    'pipe1.flowModel.dp_small' = 1.0;
  equation
    'source.medium.T_degC' = 'source.medium.T' - 273.15;
    'source.medium.p_bar' = 'source.medium.p' / 1e5;
    'pump.fluidVolume' = 0.0;
    'pump.medium.T_degC' = 'pump.medium.T' - 273.15;
    'pump.medium.p_bar' = 'pump.medium.p' / 1e5;
    'pump.heatTransfer.states[1].phase' = 'pump.medium.state.phase';
    'pump.heatTransfer.states[1].h' = 'pump.medium.state.h';
    'pump.heatTransfer.states[1].d' = 'pump.medium.state.d';
    'pump.heatTransfer.states[1].T' = 'pump.medium.state.T';
    'pump.heatTransfer.states[1].p' = 'pump.medium.state.p';
    'pump.rho' = 'pump.medium.d';
    'pump.dp_pump' = 'pump.port_b.p' - 'pump.port_a.p';
    'pump.head' = 'pump.dp_pump' / ('pump.rho' * 9.80665);
    'pump.m_flow' = 'pump.port_a.m_flow';
    'pump.m_flow_single' = 'pump.m_flow';
    'pump.W_total' = 'pump.W_single';
    'pump.monitoring.state_in.phase' = 0;
    'pump.monitoring.state_in.h' = 'source.ports[1].h_outflow';
    'pump.monitoring.state_in.d' = 'Modelica.Media.Water.IF97_Utilities.rho_props_ph'('pump.port_a.p', 'source.ports[1].h_outflow', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('pump.port_a.p', 'source.ports[1].h_outflow', 0, 0));
    'pump.monitoring.state_in.T' = 'Modelica.Media.Water.IF97_Utilities.T_props_ph'('pump.port_a.p', 'source.ports[1].h_outflow', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('pump.port_a.p', 'source.ports[1].h_outflow', 0, 0));
    'pump.monitoring.state_in.p' = 'pump.port_a.p';
    'pump.monitoring.state.phase' = 'pump.medium.state.phase';
    'pump.monitoring.state.h' = 'pump.medium.state.h';
    'pump.monitoring.state.d' = 'pump.medium.state.d';
    'pump.monitoring.state.T' = 'pump.medium.state.T';
    'pump.monitoring.state.p' = 'pump.medium.state.p';
    'orifice.V_flow' = 'orifice.m_flow' / 'Modelica.Fluid.Utilities.regStep'('orifice.m_flow', 'orifice.state_a.d', 'orifice.state_b.d', 0.01);
    'orifice.port_a_T' = 'Modelica.Fluid.Utilities.regStep'('orifice.port_a.m_flow', 'orifice.state_a.T', 'Modelica.Media.Water.IF97_Utilities.T_props_ph'('orifice.port_a.p', 'orifice.port_a.h_outflow', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('orifice.port_a.p', 'orifice.port_a.h_outflow', 0, 0)), 0.01);
    'orifice.port_b_T' = 'Modelica.Fluid.Utilities.regStep'('orifice.port_b.m_flow', 'orifice.state_b.T', 'Modelica.Media.Water.IF97_Utilities.T_props_ph'('orifice.port_b.p', 'orifice.port_b.h_outflow', 'Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('orifice.port_b.p', 'orifice.port_b.h_outflow', 0, 0)), 0.01);
    'orifice.pathLength' = 0.0;
    'orifice.d' = 0.5 * ('orifice.state_a.d' + 'orifice.state_b.d');
    'orifice.A_mean' = 5.067074790974977e-4;
    'orifice.m_flow_turbulent' = 0.01;
    'orifice.dp_turbulent' = 1.0;
    'sink.medium.T_degC' = 'sink.medium.T' - 273.15;
    'sink.medium.p_bar' = 'sink.medium.p' / 1e5;
    'pipe1.flowModel.states[1].phase' = 0;
