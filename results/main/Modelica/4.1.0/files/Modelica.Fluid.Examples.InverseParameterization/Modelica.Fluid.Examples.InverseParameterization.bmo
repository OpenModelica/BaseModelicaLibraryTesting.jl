    'pipe2.flowModel.states[1].T' = 'Modelica.Fluid.Examples.InverseParameterization.pipe2.Medium.temperature_ph'('pipe2.port_a.p', ('$OMC$PositiveMax'(-'orifice.port_a.m_flow', 1e-7) * 'orifice.port_a.h_outflow' + '$OMC$PositiveMax'(-'pipe1.port_a.m_flow', 1e-7) * 'pipe1.port_a.h_outflow' + '$OMC$PositiveMax'(-'pump.port_b.m_flow', 1e-7) * 'pump.port_b.h_outflow') / ('$OMC$PositiveMax'(-'orifice.port_a.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe1.port_a.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pump.port_b.m_flow', 1e-7)), 0, 0);
    'pipe2.flowModel.states[1].p' = 'pipe2.port_a.p';
    'pipe2.flowModel.states[2].phase' = if 0 == 0 then 0 else if 0 == 4 then 2 else 1;
    'pipe2.flowModel.states[2].h' = 'sink2.ports[1].h_outflow';
    'pipe2.flowModel.states[2].d' = 'Modelica.Fluid.Examples.InverseParameterization.pipe2.Medium.density_ph'('pipe2.port_b.p', 'sink2.ports[1].h_outflow', 0, 0);
    'pipe2.flowModel.states[2].T' = 'Modelica.Fluid.Examples.InverseParameterization.pipe2.Medium.temperature_ph'('pipe2.port_b.p', 'sink2.ports[1].h_outflow', 0, 0);
    'pipe2.flowModel.states[2].p' = 'pipe2.port_b.p';
    'pipe2.flowModel.vs[1]' = 'pipe2.port_a.m_flow' / 'Modelica.Fluid.Examples.InverseParameterization.pipe2.Medium.density'('pipe2.flowModel.states[1]') / 'pipe2.flowModel.crossAreas[1]';
    'pipe2.flowModel.vs[2]' = -'pipe2.port_b.m_flow' / 'Modelica.Fluid.Examples.InverseParameterization.pipe2.Medium.density'('pipe2.flowModel.states[2]') / 'pipe2.flowModel.crossAreas[2]';
    'pipe2.flowModel.crossAreas[1]' = 5.067074790974977e-4;
    'pipe2.flowModel.crossAreas[2]' = 5.067074790974977e-4;
    'pipe2.flowModel.dimensions[1]' = 0.0254;
    'pipe2.flowModel.dimensions[2]' = 0.0254;
    'pipe2.flowModel.roughnesses[1]' = 2.5e-5;
    'pipe2.flowModel.roughnesses[2]' = 2.5e-5;
    'pipe2.flowModel.dheights[1]' = 0.0;
    'pipe2.flowModel.pathLengths[1]' = 1000.0;
    'pipe2.flowModel.rhos[1]' = 'Modelica.Fluid.Examples.InverseParameterization.pipe2.flowModel.Medium.density'('pipe2.flowModel.states[1]');
    'pipe2.flowModel.rhos[2]' = 'Modelica.Fluid.Examples.InverseParameterization.pipe2.flowModel.Medium.density'('pipe2.flowModel.states[2]');
    'pipe2.flowModel.mus[1]' = 'Modelica.Fluid.Examples.InverseParameterization.pipe2.flowModel.Medium.dynamicViscosity'('pipe2.flowModel.states[1]');
    'pipe2.flowModel.mus[2]' = 'Modelica.Fluid.Examples.InverseParameterization.pipe2.flowModel.Medium.dynamicViscosity'('pipe2.flowModel.states[2]');
    'pipe2.flowModel.Res[1]' = 'Modelica.Fluid.Pipes.BaseClasses.CharacteristicNumbers.ReynoldsNumber'('pipe2.flowModel.vs[1]', 'pipe2.flowModel.rhos[1]', 'pipe2.flowModel.mus[1]', 'pipe2.flowModel.dimensions[1]');
    'pipe2.flowModel.Res[2]' = 'Modelica.Fluid.Pipes.BaseClasses.CharacteristicNumbers.ReynoldsNumber'('pipe2.flowModel.vs[2]', 'pipe2.flowModel.rhos[2]', 'pipe2.flowModel.mus[2]', 'pipe2.flowModel.dimensions[2]');
    'pipe2.flowModel.m_flows_turbulent[1]' = ('pipe2.flowModel.crossAreas[1]' + 'pipe2.flowModel.crossAreas[2]') / ('pipe2.flowModel.dimensions[1]' + 'pipe2.flowModel.dimensions[2]') * 'pipe2.flowModel.mus_act[1]' * 4000.0;
    'pipe2.flowModel.pathLengths_nominal[1]' = (1e5 - 9.80665 * 'pipe2.flowModel.dheights[1]') * 3.141592653589793 * (('pipe2.flowModel.dimensions[1]' + 'pipe2.flowModel.dimensions[2]') / 2.0) ^ 4.0 * 'pipe2.flowModel.rhos_act[1]' / (128.0 * 'pipe2.flowModel.mus_act[1]');
    'pipe2.flowModel.dps_fg[1]' = 9.80665 * 'pipe2.flowModel.dheights[1]' * (if 'pipe2.flowModel.m_flows[1]' > 0.0 then 'pipe2.flowModel.rhos[1]' else 'pipe2.flowModel.rhos[2]') + 1e5 * 'pipe2.flowModel.m_flows[1]';
    'pipe2.flowModel.rhos_act[1]' = noEvent(if 'pipe2.flowModel.m_flows[1]' > 0.0 then 'pipe2.flowModel.rhos[1]' else 'pipe2.flowModel.rhos[2]');
    'pipe2.flowModel.mus_act[1]' = noEvent(if 'pipe2.flowModel.m_flows[1]' > 0.0 then 'pipe2.flowModel.mus[1]' else 'pipe2.flowModel.mus[2]');
    'pipe2.flowModel.Ib_flows[1]' = 0.0;
    'pipe2.flowModel.Fs_p[1]' = 0.5 * ('pipe2.flowModel.crossAreas[1]' + 'pipe2.flowModel.crossAreas[2]') * ('Modelica.Fluid.Examples.InverseParameterization.pipe2.flowModel.Medium.pressure'('pipe2.flowModel.states[2]') - 'Modelica.Fluid.Examples.InverseParameterization.pipe2.flowModel.Medium.pressure'('pipe2.flowModel.states[1]'));
    'pipe2.flowModel.dps_fg[1]' = 'pipe2.flowModel.Fs_fg[1]' * 2.0 / ('pipe2.flowModel.crossAreas[1]' + 'pipe2.flowModel.crossAreas[2]');
    'pipe2.flowModel.Is[1]' = 'pipe2.flowModel.m_flows[1]' * 'pipe2.flowModel.pathLengths[1]';
    0.0 = 'pipe2.flowModel.Ib_flows[1]' - 'pipe2.flowModel.Fs_p[1]' - 'pipe2.flowModel.Fs_fg[1]';
    'pipe2.port_a.m_flow' = 'pipe2.flowModel.m_flows[1]';
    0.0 = 'pipe2.port_a.m_flow' + 'pipe2.port_b.m_flow';
    'pipe2.port_b.h_outflow' = ('$OMC$PositiveMax'(-'orifice.port_a.m_flow', 1e-7) * 'orifice.port_a.h_outflow' + '$OMC$PositiveMax'(-'pipe1.port_a.m_flow', 1e-7) * 'pipe1.port_a.h_outflow' + '$OMC$PositiveMax'(-'pump.port_b.m_flow', 1e-7) * 'pump.port_b.h_outflow') / ('$OMC$PositiveMax'(-'orifice.port_a.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pipe1.port_a.m_flow', 1e-7) + '$OMC$PositiveMax'(-'pump.port_b.m_flow', 1e-7));
    'pipe2.port_a.h_outflow' = 'sink2.ports[1].h_outflow';
    'sink2.medium.MM' = 0.018015268;
    'sink2.medium.phase' = if ('sink2.medium.h' < 'Modelica.Fluid.Examples.InverseParameterization.sink2.Medium.bubbleEnthalpy'('sink2.medium.sat') or 'sink2.medium.h' > 'Modelica.Fluid.Examples.InverseParameterization.sink2.Medium.dewEnthalpy'('sink2.medium.sat')) or 'sink2.medium.p' > 2.2064e7 then 1 else 2;
    'sink2.medium.d' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('sink2.medium.p', 'sink2.medium.h', 'sink2.medium.phase', 0)).rho;
    'sink2.medium.T' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('sink2.medium.p', 'sink2.medium.h', 'sink2.medium.phase', 0)).T;
    'sink2.medium.sat.Tsat' = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('sink2.medium.p');
    'sink2.medium.sat.psat' = 'sink2.medium.p';
    'sink2.medium.u' = 'sink2.medium.h' - 'sink2.medium.p' / 'sink2.medium.d';
    'sink2.medium.R_s' = 461.5231157345669;
    'sink2.medium.h' = 'sink2.medium.state.h';
    'sink2.medium.p' = 'sink2.medium.state.p';
    'sink2.medium.T' = 'sink2.medium.state.T';
    'sink2.medium.d' = 'sink2.medium.state.d';
    'sink2.medium.phase' = 'sink2.medium.state.phase';
    'sink2.medium.X[1]' = 1.0;
    assert('sink2.medium.X[1]' >= (-1e-5) and 'sink2.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('sink2.medium.X[1]') + "of substance " + "water" + "\nof medium " + "WaterIF97" + " is not in the range 0..1", AssertionLevel.error);
    assert('sink2.medium.p' >= 0.0, "Pressure (= " + String('sink2.medium.p') + " Pa) of medium \"" + "WaterIF97" + "\" is negative\n(Temperature = " + String('sink2.medium.T') + " K)", AssertionLevel.error);
    'Modelica.Fluid.Utilities.checkBoundary'("WaterIF97", {"water"}, false, true, {'sink2.X_in_internal[1]'}, "Boundary_pT");
    'sink2.p_in_internal' = 2e5;
    'sink2.T_in_internal' = 293.15;
    'sink2.X_in_internal[1]' = 1.0;
    'sink2.medium.p' = 'sink2.p_in_internal';
    'sink2.medium.h' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_pT'('sink2.p_in_internal', 'sink2.T_in_internal', 0)).h;
    'sink2.ports[1].p' = 'sink2.medium.p';
    'sink2.ports[1].h_outflow' = 'sink2.medium.h';
    annotation(experiment(StopTime = 10, Interval = 0.001));
  end 'InverseParameterization';
end 'InverseParameterization';
