  model 'InverseParameterization' "Demonstrates the parameterization of a pump and a pipe for given nominal values"
    parameter Real 'eps_m_flow_turbulent' = 0.1 "Turbulent flow |m_flow| >= eps_m_flow_nominal*m_flow_nominal";
    parameter Integer 'source.nPorts' = 1 "Number of ports";
    Real 'source.medium.p'(stateSelect = StateSelect.default, nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'source.medium.h'(stateSelect = StateSelect.default, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'source.medium.d'(stateSelect = StateSelect.default, nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'source.medium.T'(stateSelect = StateSelect.default, nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'source.medium.X[1]'(nominal = 0.1, start = 1.0, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'source.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'source.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'source.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Integer 'source.medium.state.phase'(max = 2, min = 0) "Phase of the fluid: 1 for 1-phase, 2 for two-phase, 0 for not known, e.g., interactive use";
    Real 'source.medium.state.h'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy";
    Real 'source.medium.state.d'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density";
    Real 'source.medium.state.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature";
    Real 'source.medium.state.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure";
    parameter Boolean 'source.medium.preferredMediumStates' = false "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'source.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'source.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'source.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'source.medium.sat.psat'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Saturation pressure";
    Real 'source.medium.sat.Tsat'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Saturation temperature";
    Integer 'source.medium.phase'(fixed = false, start = 1, max = 2, min = 0) "2 for two-phase, 1 for one-phase, 0 if not known";
    Real 'source.ports[1].m_flow'(max = 1e60, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'source.ports[1].p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'source.ports[1].h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter 'Modelica.Fluid.Types.PortFlowDirection' 'source.flowDirection' = 'Modelica.Fluid.Types.PortFlowDirection'.'Bidirectional' "Allowed flow direction" annotation(Evaluate = true);
    parameter Boolean 'source.use_p_in' = false "Get the pressure from the input connector" annotation(Evaluate = true);
    parameter Boolean 'source.use_T_in' = false "Get the temperature from the input connector" annotation(Evaluate = true);
    parameter Boolean 'source.use_X_in' = false "Get the composition from the input connector" annotation(Evaluate = true);
    parameter Boolean 'source.use_C_in' = false "Get the trace substances from the input connector" annotation(Evaluate = true);
    parameter Real 'source.p'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1e5 "Fixed value of pressure";
    parameter Real 'source.T'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed value of temperature";
    parameter Real 'source.X[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Fixed value of composition";
    Real 'source.p_in_internal'(unit = "Pa") "Needed to connect to conditional connector";
    Real 'source.T_in_internal'(unit = "K") "Needed to connect to conditional connector";
    Real 'source.X_in_internal[1]'(unit = "1") "Needed to connect to conditional connector";
    parameter Boolean 'pump.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'pump.port_a.m_flow'(start = 0.4, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'pump.port_a.p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pump.port_a.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'pump.port_b.m_flow'(start = -0.4, max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") "Mass flow rate from the connection point into the component";
    Real 'pump.port_b.p'(nominal = 1e6, start = 101325.0, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pump.port_b.h_outflow'(nominal = 5e5, start = 1e5, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'pump.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'pump.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'pump.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'pump.p_a_start'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Guess value for inlet pressure";
    parameter Real 'pump.p_b_start'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Guess value for outlet pressure";
    parameter Real 'pump.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.WaterIF97") = 0.4 "Guess value of m_flow = port_a.m_flow";
    parameter 'Modelica.Fluid.Types.CheckValveHomotopyType' 'pump.checkValveHomotopy' = 'Modelica.Fluid.Types.CheckValveHomotopyType'.'NoHomotopy' "= whether the valve is Closed, Open, or unknown at initialization";
    parameter Real 'pump.V_flow_single_init'(unit = "m3/s", quantity = "VolumeFlowRate") = 4.007188525678571e-4 "Used for simplified initialization model";
    parameter Real 'pump.delta_head_init'(unit = "m", quantity = "Length") = -0.3650334296563571 "Delta head for a 10% increase of flow at the initialization point";
    parameter Integer 'pump.nParallel'(min = 1) = 1 "Number of pumps in parallel";
    parameter Real 'pump.N_nominal'(unit = "rev/min", quantity = "AngularVelocity") = 1500.0 "Nominal rotational speed for flow characteristic";
    parameter Real 'pump.rho_nominal'(nominal = 500.0, start = 150.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 998.2060924679472 "Nominal fluid density for characteristic";
    parameter Boolean 'pump.use_powerCharacteristic' = false "Use powerCharacteristic (vs. efficiencyCharacteristic)" annotation(Evaluate = true);
    parameter Boolean 'pump.checkValve' = false "= true to prevent reverse flow" annotation(Evaluate = true);
    parameter Real 'pump.V'(unit = "m3", quantity = "Volume") = 0.0 "Volume inside the pump" annotation(Evaluate = true);
    Real 'pump.fluidVolume'(unit = "m3", quantity = "Volume") "Volume";
    parameter 'Modelica.Fluid.Types.Dynamics' 'pump.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of energy balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pump.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of mass balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pump.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of substance balance" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pump.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of trace substance balance" annotation(Evaluate = true);
    parameter Real 'pump.p_start'(nominal = 1e6, start = 5e6, max = 1e8, min = 611.657, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Start value of pressure";
    parameter Boolean 'pump.use_T_start' = true "= true, use T_start, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'pump.T_start'(nominal = 500.0, start = 500.0, max = 2273.15, min = 273.15, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Start value of temperature";
