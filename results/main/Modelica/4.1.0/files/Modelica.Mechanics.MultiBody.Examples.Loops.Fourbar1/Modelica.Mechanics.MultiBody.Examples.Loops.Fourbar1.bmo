    'j5.frame_b.R.T[2,1]' = 'j5.R_rel.T[2,1]' * 'j5.frame_a.R.T[1,1]' + 'j5.R_rel.T[2,2]' * 'j5.frame_a.R.T[2,1]' + 'j5.R_rel.T[2,3]' * 'j5.frame_a.R.T[3,1]';
    'j5.frame_b.R.T[2,2]' = 'j5.R_rel.T[2,1]' * 'j5.frame_a.R.T[1,2]' + 'j5.R_rel.T[2,2]' * 'j5.frame_a.R.T[2,2]' + 'j5.R_rel.T[2,3]' * 'j5.frame_a.R.T[3,2]';
    'j5.frame_b.R.T[2,3]' = 'j5.R_rel.T[2,1]' * 'j5.frame_a.R.T[1,3]' + 'j5.R_rel.T[2,2]' * 'j5.frame_a.R.T[2,3]' + 'j5.R_rel.T[2,3]' * 'j5.frame_a.R.T[3,3]';
    'j5.frame_b.R.T[3,1]' = 'j5.R_rel.T[3,1]' * 'j5.frame_a.R.T[1,1]' + 'j5.R_rel.T[3,2]' * 'j5.frame_a.R.T[2,1]' + 'j5.R_rel.T[3,3]' * 'j5.frame_a.R.T[3,1]';
    'j5.frame_b.R.T[3,2]' = 'j5.R_rel.T[3,1]' * 'j5.frame_a.R.T[1,2]' + 'j5.R_rel.T[3,2]' * 'j5.frame_a.R.T[2,2]' + 'j5.R_rel.T[3,3]' * 'j5.frame_a.R.T[3,2]';
    'j5.frame_b.R.T[3,3]' = 'j5.R_rel.T[3,1]' * 'j5.frame_a.R.T[1,3]' + 'j5.R_rel.T[3,2]' * 'j5.frame_a.R.T[2,3]' + 'j5.R_rel.T[3,3]' * 'j5.frame_a.R.T[3,3]';
    'j5.frame_b.R.w[1]' = ('Modelica.Mechanics.MultiBody.Frames.resolve2'('j5.R_rel', 'j5.frame_a.R.w'))[1] + 'j5.R_rel.w[1]';
    'j5.frame_b.R.w[2]' = ('Modelica.Mechanics.MultiBody.Frames.resolve2'('j5.R_rel', 'j5.frame_a.R.w'))[2] + 'j5.R_rel.w[2]';
    'j5.frame_b.R.w[3]' = ('Modelica.Mechanics.MultiBody.Frames.resolve2'('j5.R_rel', 'j5.frame_a.R.w'))[3] + 'j5.R_rel.w[3]';
    'j5.frame_a.f[1]' = -('j5.R_rel.T[1,1]' * 'j5.frame_b.f[1]' + 'j5.R_rel.T[2,1]' * 'j5.frame_b.f[2]' + 'j5.R_rel.T[3,1]' * 'j5.frame_b.f[3]');
    'j5.frame_a.f[2]' = -('j5.R_rel.T[1,2]' * 'j5.frame_b.f[1]' + 'j5.R_rel.T[2,2]' * 'j5.frame_b.f[2]' + 'j5.R_rel.T[3,2]' * 'j5.frame_b.f[3]');
    'j5.frame_a.f[3]' = -('j5.R_rel.T[1,3]' * 'j5.frame_b.f[1]' + 'j5.R_rel.T[2,3]' * 'j5.frame_b.f[2]' + 'j5.R_rel.T[3,3]' * 'j5.frame_b.f[3]');
    'j5.frame_a.t[1]' = -('j5.R_rel.T[1,1]' * 'j5.frame_b.t[1]' + 'j5.R_rel.T[2,1]' * 'j5.frame_b.t[2]' + 'j5.R_rel.T[3,1]' * 'j5.frame_b.t[3]');
    'j5.frame_a.t[2]' = -('j5.R_rel.T[1,2]' * 'j5.frame_b.t[1]' + 'j5.R_rel.T[2,2]' * 'j5.frame_b.t[2]' + 'j5.R_rel.T[3,2]' * 'j5.frame_b.t[3]');
    'j5.frame_a.t[3]' = -('j5.R_rel.T[1,3]' * 'j5.frame_b.t[1]' + 'j5.R_rel.T[2,3]' * 'j5.frame_b.t[2]' + 'j5.R_rel.T[3,3]' * 'j5.frame_b.t[3]');
    'j5.tau' = -'j5.frame_b.t[3]';
    'j5.phi' = 'j5.internalAxis.phi';
    'b0.color[1]' = 155;
    'b0.color[2]' = 155;
    'b0.color[3]' = 155;
    'b0.frame_b.r_0[1]' = 'b0.frame_a.r_0[1]' + 'b0.frame_a.R.T[1,1]' * 1.2 + 'b0.frame_a.R.T[2,1]' * 0.0 + 'b0.frame_a.R.T[3,1]' * 0.0;
    'b0.frame_b.r_0[2]' = 'b0.frame_a.r_0[2]' + 'b0.frame_a.R.T[1,2]' * 1.2 + 'b0.frame_a.R.T[2,2]' * 0.0 + 'b0.frame_a.R.T[3,2]' * 0.0;
    'b0.frame_b.r_0[3]' = 'b0.frame_a.r_0[3]' + 'b0.frame_a.R.T[1,3]' * 1.2 + 'b0.frame_a.R.T[2,3]' * 0.0 + 'b0.frame_a.R.T[3,3]' * 0.0;
    'b0.frame_b.R.T[1,1]' = 'b0.frame_a.R.T[1,1]';
    'b0.frame_b.R.T[1,2]' = 'b0.frame_a.R.T[1,2]';
    'b0.frame_b.R.T[1,3]' = 'b0.frame_a.R.T[1,3]';
    'b0.frame_b.R.T[2,1]' = 'b0.frame_a.R.T[2,1]';
    'b0.frame_b.R.T[2,2]' = 'b0.frame_a.R.T[2,2]';
    'b0.frame_b.R.T[2,3]' = 'b0.frame_a.R.T[2,3]';
    'b0.frame_b.R.T[3,1]' = 'b0.frame_a.R.T[3,1]';
    'b0.frame_b.R.T[3,2]' = 'b0.frame_a.R.T[3,2]';
    'b0.frame_b.R.T[3,3]' = 'b0.frame_a.R.T[3,3]';
    'b0.frame_b.R.w[1]' = 'b0.frame_a.R.w[1]';
    'b0.frame_b.R.w[2]' = 'b0.frame_a.R.w[2]';
    'b0.frame_b.R.w[3]' = 'b0.frame_a.R.w[3]';
    0.0 = 'b0.frame_a.f[1]' + 'b0.frame_b.f[1]';
    0.0 = 'b0.frame_a.f[2]' + 'b0.frame_b.f[2]';
    0.0 = 'b0.frame_a.f[3]' + 'b0.frame_b.f[3]';
    0.0 = 'b0.frame_a.t[1]' + 'b0.frame_b.t[1]';
    0.0 = 'b0.frame_a.t[2]' + 'b0.frame_b.t[2]' - 1.2 * 'b0.frame_b.f[3]';
    0.0 = 'b0.frame_a.t[3]' + 'b0.frame_b.t[3]' + 1.2 * 'b0.frame_b.f[2]';
    'j1_phi' = 'j1.phi';
    'j2_s' = 'j2.s';
    'j1_w' = 'j1.w';
    'j2_v' = 'j2.v';
    annotation(experiment(StopTime = 5));
  end 'Fourbar1';
end 'Fourbar1';
