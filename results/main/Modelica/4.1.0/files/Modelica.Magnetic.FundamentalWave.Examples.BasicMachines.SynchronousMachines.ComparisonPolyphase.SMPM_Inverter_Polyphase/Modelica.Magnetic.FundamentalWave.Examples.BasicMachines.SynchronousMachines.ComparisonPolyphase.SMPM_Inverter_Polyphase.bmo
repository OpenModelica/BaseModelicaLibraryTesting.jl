    parameter Integer 'vfController.nout' = 5 "Number of outputs";
    Real 'vfController.u'(unit = "Hz") "Connector of Real input signal";
    Real 'vfController.y[1]' "Connector of Real output signals";
    Real 'vfController.y[2]' "Connector of Real output signals";
    Real 'vfController.y[3]' "Connector of Real output signals";
    Real 'vfController.y[4]' "Connector of Real output signals";
    Real 'vfController.y[5]' "Connector of Real output signals";
    parameter Integer 'vfController.m' = 5 "Number of phases" annotation(Evaluate = true);
    parameter Real 'vfController.orientation[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Orientation of phases";
    parameter Real 'vfController.orientation[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -1.2566370614359172 "Orientation of phases";
    parameter Real 'vfController.orientation[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.5132741228718345 "Orientation of phases";
    parameter Real 'vfController.orientation[4]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -3.7699111843077517 "Orientation of phases";
    parameter Real 'vfController.orientation[5]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -5.026548245743669 "Orientation of phases";
    parameter Real 'vfController.VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'vfController.fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'vfController.BasePhase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267948966 "Common phase shift";
    parameter Boolean 'vfController.EconomyMode' = false "Economy mode: voltage quadratic dependent on frequency" annotation(Evaluate = true);
    Real 'vfController.x'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Integrator state";
    Real 'vfController.amplitude'(unit = "V", quantity = "ElectricPotential");
    parameter Integer 'vfController.pow' = 1 annotation(Evaluate = true);
    Real 'feedback.u1' "Commanded input";
    Real 'feedback.u2' "Feedback input";
    Real 'feedback.y';
    parameter Real 'gain.k'(start = 1.0) = 1.6666666666666667 "Gain value multiplied with input signal";
    Real 'gain.u' "Input signal connector";
    Real 'gain.y' "Output signal connector";
    parameter Integer 'smpmDataM.m' = 5 "Number of phases" annotation(Evaluate = true);
    parameter Real 'smpmDataM.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Real 'smpmDataM.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Integer 'smpmDataM.p'(min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'smpmDataM.fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'smpmDataM.Rs'(unit = "Ohm", quantity = "Resistance") = 0.049999999999999996 "Stator resistance per phase at TRef";
    parameter Real 'smpmDataM.TsRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'smpmDataM.alpha20s'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'smpmDataM.effectiveStatorTurns' = 1.0 "Effective number of stator turns";
    parameter Real 'smpmDataM.Lszero'(unit = "H", quantity = "Inductance") = 5.305164769729845e-4 "Stator zero sequence inductance";
    parameter Real 'smpmDataM.Lssigma'(unit = "H", quantity = "Inductance") = 5.305164769729845e-4 "Stator stray inductance per phase";
    parameter Real 'smpmDataM.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'smpmDataM.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smpmDataM.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smpmDataM.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smpmDataM.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smpmDataM.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smpmDataM.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smpmDataM.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'smpmDataM.statorCoreParameters.m' = 5 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'smpmDataM.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'smpmDataM.statorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'smpmDataM.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'smpmDataM.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'smpmDataM.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'smpmDataM.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'smpmDataM.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'smpmDataM.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'smpmDataM.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpmDataM.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'smpmDataM.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'smpmDataM.Lmd'(unit = "H", quantity = "Inductance") = 0.0015915494309189533 "Stator main field inductance per phase in d-axis";
    parameter Real 'smpmDataM.Lmq'(unit = "H", quantity = "Inductance") = 0.0015915494309189533 "Stator main field inductance per phase in q-axis";
    parameter Boolean 'smpmDataM.useDamperCage' = true "Enable / disable damper cage" annotation(Evaluate = true);
    parameter Real 'smpmDataM.Lrsigmad'(unit = "H", quantity = "Inductance") = 2.6525823848649226e-4 "Damper stray inductance in d-axis";
    parameter Real 'smpmDataM.Lrsigmaq'(unit = "H", quantity = "Inductance") = 2.6525823848649226e-4 "Damper stray inductance in q-axis";
    parameter Real 'smpmDataM.Rrd'(unit = "Ohm", quantity = "Resistance") = 0.06666666666666667 "Damper resistance in d-axis at TRef";
    parameter Real 'smpmDataM.Rrq'(unit = "Ohm", quantity = "Resistance") = 0.06666666666666667 "Damper resistance in q-axis at TRef";
    parameter Real 'smpmDataM.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of damper resistances in d- and q-axis";
    parameter Real 'smpmDataM.alpha20r'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of damper resistances in d- and q-axis";
    parameter Real 'smpmDataM.VsOpenCircuit'(unit = "V", quantity = "ElectricPotential") = 112.3 "Open circuit RMS voltage per phase @ fsNominal";
    parameter Real 'smpmDataM.permanentMagnetLossParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference permanent magnet losses at IRef and wRef";
    parameter Real 'smpmDataM.permanentMagnetLossParameters.c'(max = 1.0, min = 0.0) = 0.0 "Part of permanent magnet losses at current = 0, i.e. independent of current";
    parameter Real 'smpmDataM.permanentMagnetLossParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference stator RMS current that PRef refers to";
    parameter Real 'smpmDataM.permanentMagnetLossParameters.power_I'(min = 2.2250738585072014e-308) = 2.0 "Exponent of permanent magnet loss torque w.r.t. stator current";
    parameter Real 'smpmDataM.permanentMagnetLossParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpmDataM.permanentMagnetLossParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of permanent magnet loss torque w.r.t. angular velocity";
    parameter Real 'smpmDataM.permanentMagnetLossParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference permanent magnet loss torque at reference angular velocity and reference current";
  initial equation
    'smpm3.is[1]' = 0.0;
    'smpm3.is[2]' = 0.0;
    'smpmM.is[1]' = 0.0;
    'smpmM.is[2]' = 0.0;
  equation
    'smpmM.phiMechanical' = 'smpmM.flange.phi' - 'smpmM.internalSupport.phi';
    'smpmM.wMechanical' = der('smpmM.phiMechanical');
    'smpmM.tauElectrical' = 'smpmM.inertiaRotor.flange_a.tau';
    'smpmM.tauShaft' = -'smpmM.flange.tau';
    'smpmM.powerBalance.powerStator' = sum('smpmM.vs' * 'smpmM.is');
    'smpmM.powerBalance.powerMechanical' = 'smpmM.wMechanical' * 'smpmM.tauShaft';
    'smpmM.powerBalance.powerInertiaStator' = 0.29 * 'smpmM.inertiaStator.a' * 'smpmM.inertiaStator.w';
    'smpmM.powerBalance.powerInertiaRotor' = 0.29 * 'smpmM.inertiaRotor.a' * 'smpmM.inertiaRotor.w';
    'smpmM.powerBalance.lossPowerTotal' = 'smpmM.powerBalance.lossPowerStatorWinding' + 'smpmM.powerBalance.lossPowerStatorCore' + 'smpmM.powerBalance.lossPowerRotorCore' + 'smpmM.powerBalance.lossPowerStrayLoad' + 'smpmM.powerBalance.lossPowerFriction' + 'smpmM.powerBalance.lossPowerRotorWinding' + 'smpmM.powerBalance.lossPowerPermanentMagnet';
    'smpmM.powerBalance.lossPowerStatorWinding' = 'smpmM.stator.resistor.resistor[1].LossPower' + 'smpmM.stator.resistor.resistor[2].LossPower' + 'smpmM.stator.resistor.resistor[3].LossPower' + 'smpmM.stator.resistor.resistor[4].LossPower' + 'smpmM.stator.resistor.resistor[5].LossPower';
    'smpmM.powerBalance.lossPowerStatorCore' = 'smpmM.stator.core.lossPower';
    'smpmM.powerBalance.lossPowerRotorCore' = 0.0;
    'smpmM.powerBalance.lossPowerStrayLoad' = 'smpmM.strayLoad.lossPower';
    'smpmM.powerBalance.lossPowerFriction' = 'smpmM.friction.lossPower';
    'smpmM.powerBalance.lossPowerRotorWinding' = 'smpmM.damperCageLossPower';
    'smpmM.powerBalance.lossPowerPermanentMagnet' = 'smpmM.permanentMagnet.lossPower';
    'smpmM.stator.abs_V_m' = sqrt('smpmM.stator.V_m.re' ^ 2.0 + 'smpmM.stator.V_m.im' ^ 2.0);
    'smpmM.stator.arg_V_m' = 'Modelica.Math.atan3'('smpmM.stator.V_m.im', 'smpmM.stator.V_m.re', 0.0);
    'smpmM.stator.Phi.re' = 'smpmM.stator.port_p.Phi.re';
    'smpmM.stator.Phi.im' = 'smpmM.stator.port_p.Phi.im';
    'smpmM.stator.abs_Phi' = sqrt('smpmM.stator.Phi.re' ^ 2.0 + 'smpmM.stator.Phi.im' ^ 2.0);
    'smpmM.stator.arg_Phi' = 'Modelica.Math.atan3'('smpmM.stator.Phi.im', 'smpmM.stator.Phi.re', 0.0);
    'smpmM.stator.electroMagneticConverter.abs_V_m' = sqrt('smpmM.stator.electroMagneticConverter.V_m.re' ^ 2.0 + 'smpmM.stator.electroMagneticConverter.V_m.im' ^ 2.0);
    'smpmM.stator.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('smpmM.stator.electroMagneticConverter.V_m.im', 'smpmM.stator.electroMagneticConverter.V_m.re', 0.0);
    'smpmM.stator.electroMagneticConverter.Phi.re' = 'smpmM.stator.electroMagneticConverter.port_p.Phi.re';
    'smpmM.stator.electroMagneticConverter.Phi.im' = 'smpmM.stator.electroMagneticConverter.port_p.Phi.im';
    'smpmM.stator.electroMagneticConverter.abs_Phi' = sqrt('smpmM.stator.electroMagneticConverter.Phi.re' ^ 2.0 + 'smpmM.stator.electroMagneticConverter.Phi.im' ^ 2.0);
