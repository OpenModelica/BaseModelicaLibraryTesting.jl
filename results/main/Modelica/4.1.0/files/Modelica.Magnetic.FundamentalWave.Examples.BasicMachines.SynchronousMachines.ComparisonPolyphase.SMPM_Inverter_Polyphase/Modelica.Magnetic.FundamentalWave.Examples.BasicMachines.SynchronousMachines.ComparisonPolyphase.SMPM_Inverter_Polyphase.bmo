    'signalVoltageM.signalVoltage[1].i' = 'signalVoltageM.signalVoltage[1].p.i';
    'signalVoltageM.signalVoltage[2].v' = 'signalVoltageM.signalVoltage[2].p.v' - 'signalVoltageM.signalVoltage[2].n.v';
    0.0 = 'signalVoltageM.signalVoltage[2].p.i' + 'signalVoltageM.signalVoltage[2].n.i';
    'signalVoltageM.signalVoltage[2].i' = 'signalVoltageM.signalVoltage[2].p.i';
    'signalVoltageM.signalVoltage[3].v' = 'signalVoltageM.signalVoltage[3].p.v' - 'signalVoltageM.signalVoltage[3].n.v';
    0.0 = 'signalVoltageM.signalVoltage[3].p.i' + 'signalVoltageM.signalVoltage[3].n.i';
    'signalVoltageM.signalVoltage[3].i' = 'signalVoltageM.signalVoltage[3].p.i';
    'signalVoltageM.signalVoltage[4].v' = 'signalVoltageM.signalVoltage[4].p.v' - 'signalVoltageM.signalVoltage[4].n.v';
    0.0 = 'signalVoltageM.signalVoltage[4].p.i' + 'signalVoltageM.signalVoltage[4].n.i';
    'signalVoltageM.signalVoltage[4].i' = 'signalVoltageM.signalVoltage[4].p.i';
    'signalVoltageM.signalVoltage[5].v' = 'signalVoltageM.signalVoltage[5].p.v' - 'signalVoltageM.signalVoltage[5].n.v';
    0.0 = 'signalVoltageM.signalVoltage[5].p.i' + 'signalVoltageM.signalVoltage[5].n.i';
    'signalVoltageM.signalVoltage[5].i' = 'signalVoltageM.signalVoltage[5].p.i';
    'groundM.p.v' = 0.0;
    'vfController.amplitude' = 141.4213562373095 * (if abs('vfController.u') < 50.0 then abs('vfController.u') / 50.0 else 1.0);
    der('vfController.x') = 6.283185307179586 * 'vfController.u';
    'vfController.y[1]' = 'vfController.amplitude' * sin('vfController.x' + 1.5707963267948966);
    'vfController.y[2]' = 'vfController.amplitude' * sin('vfController.x' + 1.5707963267948966 - 1.2566370614359172);
    'vfController.y[3]' = 'vfController.amplitude' * sin('vfController.x' + 1.5707963267948966 - 2.5132741228718345);
    'vfController.y[4]' = 'vfController.amplitude' * sin('vfController.x' + 1.5707963267948966 - 3.7699111843077517);
    'vfController.y[5]' = 'vfController.amplitude' * sin('vfController.x' + 1.5707963267948966 - 5.026548245743669);
    'feedback.y' = 'feedback.u1' - 'feedback.u2';
    'gain.y' = 1.6666666666666667 * 'gain.u';
  initial algorithm
    assert(true, "5 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
  initial algorithm
    assert(true, "3 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
    annotation(experiment(StopTime = 1.5, Interval = 1E-4, Tolerance = 1e-006));
  end 'SMPM_Inverter_Polyphase';
end 'SMPM_Inverter_Polyphase';
