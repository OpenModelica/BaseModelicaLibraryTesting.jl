//! base 0.1.0
package 'SMPM_Inverter_Polyphase'
  function 'Modelica.Math.wrapAngle' "Wrap angle to interval ]-pi,pi] or [0,2*pi["
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    input Boolean 'positiveRange' = false;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := mod('u', 6.283185307179586);

    if 'y' > 3.141592653589793 and not 'positiveRange' then
      'y' := 'y' - 6.283185307179586;
    end if;
  end 'Modelica.Math.wrapAngle';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  model 'SMPM_Inverter_Polyphase' "Starting of polyphase permanent magnet synchronous machine with inverter"
    constant Integer 'm3' = 3 "Number of stator phases of three-phase system";
    parameter Integer 'm' = 5 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'VsNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'fKnee'(unit = "Hz", quantity = "Frequency") = 50.0 "Knee frequency of V/f curve";
    parameter Real 'tRamp'(unit = "s", quantity = "Time") = 1.0 "Frequency ramp";
    parameter Real 'T_Load'(unit = "N.m", quantity = "Torque") = 181.4 "Nominal load torque";
    parameter Real 'tStep'(unit = "s", quantity = "Time") = 1.2 "Time of load torque step";
    parameter Real 'J_Load'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load inertia";
    Real 'ground3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'star3.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star3.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star3.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
