    'switch3.idealClosingSwitch[2].v' = 'switch3.idealClosingSwitch[2].s' * (if 'switch3.idealClosingSwitch[2].off' then 1.0 else 1e-9);
    'switch3.idealClosingSwitch[2].i' = 'switch3.idealClosingSwitch[2].s' * (if 'switch3.idealClosingSwitch[2].off' then 1e-9 else 1.0);
    'switch3.idealClosingSwitch[2].LossPower' = 'switch3.idealClosingSwitch[2].v' * 'switch3.idealClosingSwitch[2].i';
    'switch3.idealClosingSwitch[2].T_heatPort' = 293.15;
    0.0 = 'switch3.idealClosingSwitch[2].p.i' + 'switch3.idealClosingSwitch[2].n.i';
    'switch3.idealClosingSwitch[2].i' = 'switch3.idealClosingSwitch[2].p.i';
    'switch3.idealClosingSwitch[2].v' = 'switch3.idealClosingSwitch[2].p.v' - 'switch3.idealClosingSwitch[2].n.v';
    'switch3.idealClosingSwitch[3].off' = not 'switch3.idealClosingSwitch[3].control';
    'switch3.idealClosingSwitch[3].v' = 'switch3.idealClosingSwitch[3].s' * (if 'switch3.idealClosingSwitch[3].off' then 1.0 else 1e-9);
    'switch3.idealClosingSwitch[3].i' = 'switch3.idealClosingSwitch[3].s' * (if 'switch3.idealClosingSwitch[3].off' then 1e-9 else 1.0);
    'switch3.idealClosingSwitch[3].LossPower' = 'switch3.idealClosingSwitch[3].v' * 'switch3.idealClosingSwitch[3].i';
    'switch3.idealClosingSwitch[3].T_heatPort' = 293.15;
    0.0 = 'switch3.idealClosingSwitch[3].p.i' + 'switch3.idealClosingSwitch[3].n.i';
    'switch3.idealClosingSwitch[3].i' = 'switch3.idealClosingSwitch[3].p.i';
    'switch3.idealClosingSwitch[3].v' = 'switch3.idealClosingSwitch[3].p.v' - 'switch3.idealClosingSwitch[3].n.v';
    'switch3.v[1]' = 'switch3.plug_p.pin[1].v' - 'switch3.plug_n.pin[1].v';
    'switch3.v[2]' = 'switch3.plug_p.pin[2].v' - 'switch3.plug_n.pin[2].v';
    'switch3.v[3]' = 'switch3.plug_p.pin[3].v' - 'switch3.plug_n.pin[3].v';
    'switch3.i[1]' = 'switch3.plug_p.pin[1].i';
    'switch3.i[2]' = 'switch3.plug_p.pin[2].i';
    'switch3.i[3]' = 'switch3.plug_p.pin[3].i';
    'booleanReplicator2.y[1]' = 'booleanReplicator2.u';
    'booleanReplicator2.y[2]' = 'booleanReplicator2.u';
    'booleanReplicator2.y[3]' = 'booleanReplicator2.u';
    'booleanReplicator3.y[1]' = 'booleanReplicator3.u';
    'booleanReplicator3.y[2]' = 'booleanReplicator3.u';
    'booleanReplicator3.y[3]' = 'booleanReplicator3.u';
    'booleanStep2.y' = time >= 0.65;
    'booleanStep3.y' = time >= 0.5;
    annotation(experiment(StopTime = 1.0, Interval = 0.001, Tolerance = 1e-06));
  end 'SMPM_ResistiveBraking';
end 'SMPM_ResistiveBraking';
