    'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[3].v' = 'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[3].p.v' - 'voltageQuasiRMSSensor.VoltageSensor1.voltageSensor[3].n.v';
    'voltageQuasiRMSSensor.Gain1.y' = 0.7071067811865475 * 'voltageQuasiRMSSensor.Gain1.u';
    3.0 * 'voltageQuasiRMSSensor.ToSpacePhasor1.zero' = 'voltageQuasiRMSSensor.ToSpacePhasor1.u[1]' + 'voltageQuasiRMSSensor.ToSpacePhasor1.u[2]' + 'voltageQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'voltageQuasiRMSSensor.ToSpacePhasor1.y[1]' = 0.6666666666666666 * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[1]' + (-0.33333333333333315) * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[2]' + (-0.3333333333333336) * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'voltageQuasiRMSSensor.ToSpacePhasor1.y[2]' = 0.5773502691896257 * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[2]' + (-0.5773502691896255) * 'voltageQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'voltageQuasiRMSSensor.ToPolar1.y[1]' = sqrt('voltageQuasiRMSSensor.ToPolar1.u[1]' ^ 2.0 + 'voltageQuasiRMSSensor.ToPolar1.u[2]' ^ 2.0);
    'voltageQuasiRMSSensor.ToPolar1.y[2]' = if noEvent('voltageQuasiRMSSensor.ToPolar1.y[1]' <= 2.2250738585072014e-308) then 0.0 else atan2('voltageQuasiRMSSensor.ToPolar1.u[2]', 'voltageQuasiRMSSensor.ToPolar1.u[1]');
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[1].p.v' = 'currentQuasiRMSSensor.CurrentSensor1.currentSensor[1].n.v';
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[1].p.i' = 'currentQuasiRMSSensor.CurrentSensor1.currentSensor[1].i';
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[1].n.i' = -'currentQuasiRMSSensor.CurrentSensor1.currentSensor[1].i';
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[2].p.v' = 'currentQuasiRMSSensor.CurrentSensor1.currentSensor[2].n.v';
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[2].p.i' = 'currentQuasiRMSSensor.CurrentSensor1.currentSensor[2].i';
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[2].n.i' = -'currentQuasiRMSSensor.CurrentSensor1.currentSensor[2].i';
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[3].p.v' = 'currentQuasiRMSSensor.CurrentSensor1.currentSensor[3].n.v';
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[3].p.i' = 'currentQuasiRMSSensor.CurrentSensor1.currentSensor[3].i';
    'currentQuasiRMSSensor.CurrentSensor1.currentSensor[3].n.i' = -'currentQuasiRMSSensor.CurrentSensor1.currentSensor[3].i';
    'currentQuasiRMSSensor.Gain1.y' = 0.7071067811865475 * 'currentQuasiRMSSensor.Gain1.u';
    3.0 * 'currentQuasiRMSSensor.ToSpacePhasor1.zero' = 'currentQuasiRMSSensor.ToSpacePhasor1.u[1]' + 'currentQuasiRMSSensor.ToSpacePhasor1.u[2]' + 'currentQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'currentQuasiRMSSensor.ToSpacePhasor1.y[1]' = 0.6666666666666666 * 'currentQuasiRMSSensor.ToSpacePhasor1.u[1]' + (-0.33333333333333315) * 'currentQuasiRMSSensor.ToSpacePhasor1.u[2]' + (-0.3333333333333336) * 'currentQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'currentQuasiRMSSensor.ToSpacePhasor1.y[2]' = 0.5773502691896257 * 'currentQuasiRMSSensor.ToSpacePhasor1.u[2]' + (-0.5773502691896255) * 'currentQuasiRMSSensor.ToSpacePhasor1.u[3]';
    'currentQuasiRMSSensor.ToPolar1.y[1]' = sqrt('currentQuasiRMSSensor.ToPolar1.u[1]' ^ 2.0 + 'currentQuasiRMSSensor.ToPolar1.u[2]' ^ 2.0);
    'currentQuasiRMSSensor.ToPolar1.y[2]' = if noEvent('currentQuasiRMSSensor.ToPolar1.y[1]' <= 2.2250738585072014e-308) then 0.0 else atan2('currentQuasiRMSSensor.ToPolar1.u[2]', 'currentQuasiRMSSensor.ToPolar1.u[1]');
    'sinCosResolver.flange.tau' = 0.0;
    'sinCosResolver.y[1]' = 1.5 + cos('sinCosResolver.flange.phi' - 'sinCosResolver.phi_support' + 3.141592653589793);
    'sinCosResolver.y[2]' = 1.5 - cos('sinCosResolver.flange.phi' - 'sinCosResolver.phi_support' + 3.141592653589793);
    'sinCosResolver.y[3]' = 1.5 + sin('sinCosResolver.flange.phi' - 'sinCosResolver.phi_support' + 3.141592653589793);
    'sinCosResolver.y[4]' = 1.5 - sin('sinCosResolver.flange.phi' - 'sinCosResolver.phi_support' + 3.141592653589793);
    'sinCosResolver.phi_support' = 0.0;
    'sinCosEvaluation.feedbackCos.y' = 'sinCosEvaluation.feedbackCos.u1' - 'sinCosEvaluation.feedbackCos.u2';
    'sinCosEvaluation.feedbackSin.y' = 'sinCosEvaluation.feedbackSin.u1' - 'sinCosEvaluation.feedbackSin.u2';
    'sinCosEvaluation.rotator.RotationMatrix[1,1]' = cos(-'sinCosEvaluation.rotator.angle');
    'sinCosEvaluation.rotator.RotationMatrix[1,2]' = -sin(-'sinCosEvaluation.rotator.angle');
    'sinCosEvaluation.rotator.RotationMatrix[2,1]' = sin(-'sinCosEvaluation.rotator.angle');
    'sinCosEvaluation.rotator.RotationMatrix[2,2]' = cos(-'sinCosEvaluation.rotator.angle');
    'sinCosEvaluation.rotator.y[1]' = 'sinCosEvaluation.rotator.RotationMatrix[1,1]' * 'sinCosEvaluation.rotator.u[1]' + 'sinCosEvaluation.rotator.RotationMatrix[1,2]' * 'sinCosEvaluation.rotator.u[2]';
    'sinCosEvaluation.rotator.y[2]' = 'sinCosEvaluation.rotator.RotationMatrix[2,1]' * 'sinCosEvaluation.rotator.u[1]' + 'sinCosEvaluation.rotator.RotationMatrix[2,2]' * 'sinCosEvaluation.rotator.u[2]';
    'sinCosEvaluation.integrator.local_reset' = false;
    'sinCosEvaluation.integrator.local_set' = 0.0;
    der('sinCosEvaluation.integrator.y') = 1e6 * 'sinCosEvaluation.integrator.u';
    'sinCosEvaluation.der1.y' = der('sinCosEvaluation.der1.u');
    annotation(experiment(StopTime = 2.0, Interval = 1E-4, Tolerance = 1e-06));
  end 'SMPM_VoltageSource';
