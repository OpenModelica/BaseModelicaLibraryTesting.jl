    'annulus_pipe.Wb_flows[2]' = 'annulus_pipe.vs[2]' * 1.5707963267948965e-4 * (('annulus_pipe.mediums[2].p' - 'annulus_pipe.mediums[1].p') / 2.0 + 'annulus_pipe.flowModel.dps_fg[1]' / 2.0);
