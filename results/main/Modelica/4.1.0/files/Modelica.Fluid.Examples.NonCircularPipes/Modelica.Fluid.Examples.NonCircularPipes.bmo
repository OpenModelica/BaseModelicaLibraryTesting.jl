    assert('annulus_pipe.mediums[2].p' >= 0.0, "Pressure (= " + String('annulus_pipe.mediums[2].p') + " Pa) of medium \"" + "WaterIF97" + "\" is negative\n(Temperature = " + String('annulus_pipe.mediums[2].T') + " K)", AssertionLevel.error);
