    'annulus_pipe.flowModel.rhos[2]' = 'annulus_pipe.flowModel.states[2].d';
    'annulus_pipe.flowModel.mus[1]' = 'Modelica.Media.Water.IF97_Utilities.dynamicViscosity'('annulus_pipe.flowModel.states[1].d', 'annulus_pipe.flowModel.states[1].T', 'annulus_pipe.flowModel.states[1].p', 'annulus_pipe.flowModel.states[1].phase', true);
    'annulus_pipe.flowModel.mus[2]' = 'Modelica.Media.Water.IF97_Utilities.dynamicViscosity'('annulus_pipe.flowModel.states[2].d', 'annulus_pipe.flowModel.states[2].T', 'annulus_pipe.flowModel.states[2].p', 'annulus_pipe.flowModel.states[2].phase', true);
