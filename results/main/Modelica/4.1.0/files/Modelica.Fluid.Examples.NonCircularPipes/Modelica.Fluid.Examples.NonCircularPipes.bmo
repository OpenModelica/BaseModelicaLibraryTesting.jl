    'annulus_pipe.flowModel.m_flows[1]' = homotopy('Modelica.Fluid.Examples.NonCircularPipes.annulus_pipe.flowModel.WallFriction.massFlowRate_dp_staticHead'('annulus_pipe.flowModel.dps_fg[1]', 'annulus_pipe.flowModel.rhos[1]', 'annulus_pipe.flowModel.rhos[2]', 'annulus_pipe.flowModel.mus[1]', 'annulus_pipe.flowModel.mus[2]', 'annulus_pipe.flowModel.pathLengths_internal[1]', 'annulus_pipe.flowModel.diameters[1]', 9.80665 * 'annulus_pipe.flowModel.dheights[1]', ('annulus_pipe.flowModel.crossAreas[1]' + 'annulus_pipe.flowModel.crossAreas[2]') / 2.0, ('annulus_pipe.flowModel.roughnesses[1]' + 'annulus_pipe.flowModel.roughnesses[2]') / 2.0, 'annulus_pipe.flowModel.dp_small', 'annulus_pipe.flowModel.Res_turbulent_internal[1]'), 'annulus_pipe.flowModel.m_flow_nominal' / 'annulus_pipe.flowModel.dp_nominal' * ('annulus_pipe.flowModel.dps_fg[1]' - 9.80665 * 'annulus_pipe.flowModel.dheights[1]' * 998.2060924679472));
    'annulus_pipe.flowModel.rhos_act[1]' = noEvent(if 'annulus_pipe.flowModel.m_flows[1]' > 0.0 then 'annulus_pipe.flowModel.rhos[1]' else 'annulus_pipe.flowModel.rhos[2]');
    'annulus_pipe.flowModel.mus_act[1]' = noEvent(if 'annulus_pipe.flowModel.m_flows[1]' > 0.0 then 'annulus_pipe.flowModel.mus[1]' else 'annulus_pipe.flowModel.mus[2]');
    'annulus_pipe.flowModel.Ib_flows[1]' = 0.0;
    'annulus_pipe.flowModel.Fs_p[1]' = 0.5 * ('annulus_pipe.flowModel.crossAreas[1]' + 'annulus_pipe.flowModel.crossAreas[2]') * ('annulus_pipe.flowModel.states[2].p' - 'annulus_pipe.flowModel.states[1].p');
    'annulus_pipe.flowModel.dps_fg[1]' = 'annulus_pipe.flowModel.Fs_fg[1]' * 2.0 / ('annulus_pipe.flowModel.crossAreas[1]' + 'annulus_pipe.flowModel.crossAreas[2]');
    'annulus_pipe.flowModel.Is[1]' = 'annulus_pipe.flowModel.m_flows[1]' * 'annulus_pipe.flowModel.pathLengths[1]';
    0.0 = 'annulus_pipe.flowModel.Ib_flows[1]' - 'annulus_pipe.flowModel.Fs_p[1]' - 'annulus_pipe.flowModel.Fs_fg[1]';
