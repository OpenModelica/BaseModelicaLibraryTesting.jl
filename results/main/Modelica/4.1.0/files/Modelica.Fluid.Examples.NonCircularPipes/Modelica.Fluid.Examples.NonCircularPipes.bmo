    parameter Boolean 'circular_pipe.port_a_exposesState' = true "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'circular_pipe.port_b_exposesState' = true "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'circular_pipe.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
