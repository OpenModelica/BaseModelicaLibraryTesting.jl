    'annulus_pipe.vs[2]' = 0.5 * ('annulus_pipe.m_flows[2]' + 'annulus_pipe.m_flows[3]') / 'annulus_pipe.mediums[2].d' / 1.5707963267948965e-4;
    'annulus_pipe.heatTransfer.surfaceAreas[1]' = 3.1415926535897936;
