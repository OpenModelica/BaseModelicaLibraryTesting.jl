    'annulus_pipe.flowModel.m_flows[1]' = homotopy('Modelica.Fluid.Examples.NonCircularPipes.annulus_pipe.flowModel.WallFriction.massFlowRate_dp_staticHead'('annulus_pipe.flowModel.dps_fg[1]', 'annulus_pipe.flowModel.rhos[1]', 'annulus_pipe.flowModel.rhos[2]', 'annulus_pipe.flowModel.mus[1]', 'annulus_pipe.flowModel.mus[2]', 'annulus_pipe.flowModel.pathLengths_internal[1]', 'annulus_pipe.flowModel.diameters[1]', 9.80665 * 'annulus_pipe.flowModel.dheights[1]', ('annulus_pipe.flowModel.crossAreas[1]' + 'annulus_pipe.flowModel.crossAreas[2]') / 2.0, ('annulus_pipe.flowModel.roughnesses[1]' + 'annulus_pipe.flowModel.roughnesses[2]') / 2.0, 'annulus_pipe.flowModel.dp_small', 'annulus_pipe.flowModel.Res_turbulent_internal[1]'), 'annulus_pipe.flowModel.m_flow_nominal' / 'annulus_pipe.flowModel.dp_nominal' * ('annulus_pipe.flowModel.dps_fg[1]' - 9.80665 * 'annulus_pipe.flowModel.dheights[1]' * 998.2060924679472));
    'annulus_pipe.flowModel.rhos_act[1]' = noEvent(if 'annulus_pipe.flowModel.m_flows[1]' > 0.0 then 'annulus_pipe.flowModel.rhos[1]' else 'annulus_pipe.flowModel.rhos[2]');
    'annulus_pipe.flowModel.mus_act[1]' = noEvent(if 'annulus_pipe.flowModel.m_flows[1]' > 0.0 then 'annulus_pipe.flowModel.mus[1]' else 'annulus_pipe.flowModel.mus[2]');
    'annulus_pipe.flowModel.Ib_flows[1]' = 0.0;
    'annulus_pipe.flowModel.Fs_p[1]' = 0.5 * ('annulus_pipe.flowModel.crossAreas[1]' + 'annulus_pipe.flowModel.crossAreas[2]') * ('annulus_pipe.flowModel.states[2].p' - 'annulus_pipe.flowModel.states[1].p');
    'annulus_pipe.flowModel.dps_fg[1]' = 'annulus_pipe.flowModel.Fs_fg[1]' * 2.0 / ('annulus_pipe.flowModel.crossAreas[1]' + 'annulus_pipe.flowModel.crossAreas[2]');
    'annulus_pipe.flowModel.Is[1]' = 'annulus_pipe.flowModel.m_flows[1]' * 'annulus_pipe.flowModel.pathLengths[1]';
    0.0 = 'annulus_pipe.flowModel.Ib_flows[1]' - 'annulus_pipe.flowModel.Fs_p[1]' - 'annulus_pipe.flowModel.Fs_fg[1]';
    'annulus_pipe.vs[1]' = 0.5 * ('annulus_pipe.m_flows[1]' + 'annulus_pipe.m_flows[2]') / 'annulus_pipe.mediums[1].d' / 1.5707963267948965e-4;
    'annulus_pipe.vs[2]' = 0.5 * ('annulus_pipe.m_flows[2]' + 'annulus_pipe.m_flows[3]') / 'annulus_pipe.mediums[2].d' / 1.5707963267948965e-4;
    'annulus_pipe.heatTransfer.surfaceAreas[1]' = 3.1415926535897936;
    'annulus_pipe.heatTransfer.surfaceAreas[2]' = 3.1415926535897936;
    'annulus_pipe.heatTransfer.Ts[1]' = 'annulus_pipe.heatTransfer.states[1].T';
    'annulus_pipe.heatTransfer.Ts[2]' = 'annulus_pipe.heatTransfer.states[2].T';
    'annulus_pipe.heatTransfer.vs[1]' = 'annulus_pipe.vs[1]';
    'annulus_pipe.heatTransfer.vs[2]' = 'annulus_pipe.vs[2]';
    'annulus_pipe.heatTransfer.lengths[1]' = 50.0;
    'annulus_pipe.heatTransfer.lengths[2]' = 50.0;
    'annulus_pipe.heatTransfer.dimensions[1]' = 0.009999999999999998;
    'annulus_pipe.heatTransfer.dimensions[2]' = 0.009999999999999998;
    'annulus_pipe.heatTransfer.roughnesses[1]' = 2.5e-5;
    'annulus_pipe.heatTransfer.roughnesses[2]' = 2.5e-5;
    'annulus_pipe.heatTransfer.Ts[1]' = 'annulus_pipe.heatTransfer.heatPorts[1].T';
    'annulus_pipe.heatTransfer.Ts[2]' = 'annulus_pipe.heatTransfer.heatPorts[2].T';
    'annulus_pipe.heatTransfer.Q_flows[1]' = 'annulus_pipe.heatTransfer.heatPorts[1].Q_flow';
    'annulus_pipe.heatTransfer.Q_flows[2]' = 'annulus_pipe.heatTransfer.heatPorts[2].Q_flow';
    'annulus_pipe.Qb_flows[1]' = 'annulus_pipe.heatTransfer.Q_flows[1]';
    'annulus_pipe.Qb_flows[2]' = 'annulus_pipe.heatTransfer.Q_flows[2]';
    'annulus_pipe.Wb_flows[1]' = 'annulus_pipe.vs[1]' * 1.5707963267948965e-4 * (('annulus_pipe.mediums[2].p' - 'annulus_pipe.mediums[1].p') / 2.0 + 'annulus_pipe.flowModel.dps_fg[1]' / 2.0);
    'annulus_pipe.Wb_flows[2]' = 'annulus_pipe.vs[2]' * 1.5707963267948965e-4 * (('annulus_pipe.mediums[2].p' - 'annulus_pipe.mediums[1].p') / 2.0 + 'annulus_pipe.flowModel.dps_fg[1]' / 2.0);
    'annulus_pipe.pathLengths[1]' = 100.0;
    'annulus_pipe.dheightsFM[1]' = 0.0;
    'annulus_pipe.crossAreasFM[1]' = 1.5707963267948965e-4;
    'annulus_pipe.crossAreasFM[2]' = 1.5707963267948965e-4;
    'annulus_pipe.dimensionsFM[1]' = 0.009999999999999998;
    'annulus_pipe.dimensionsFM[2]' = 0.009999999999999998;
    'annulus_pipe.roughnessesFM[1]' = 2.5e-5;
    'annulus_pipe.roughnessesFM[2]' = 2.5e-5;
    'annulus_pipe.mb_flows[1]' = 'annulus_pipe.m_flows[1]' - 'annulus_pipe.m_flows[2]';
    'annulus_pipe.Hb_flows[1]' = 'annulus_pipe.H_flows[1]' - 'annulus_pipe.H_flows[2]';
    'annulus_pipe.mb_flows[2]' = 'annulus_pipe.m_flows[2]' - 'annulus_pipe.m_flows[3]';
    'annulus_pipe.Hb_flows[2]' = 'annulus_pipe.H_flows[2]' - 'annulus_pipe.H_flows[3]';
    'annulus_pipe.H_flows[2]' = semiLinear('annulus_pipe.m_flows[2]', 'annulus_pipe.mediums[1].h', 'annulus_pipe.mediums[2].h');
    'annulus_pipe.H_flows[1]' = semiLinear('annulus_pipe.port_a.m_flow', 'boundary.ports[2].h_outflow', 'annulus_pipe.mediums[1].h');
    'annulus_pipe.H_flows[3]' = -semiLinear('annulus_pipe.port_b.m_flow', 'massflowsink2.ports[1].h_outflow', 'annulus_pipe.mediums[2].h');
    'annulus_pipe.port_a.m_flow' = 'annulus_pipe.m_flows[1]';
    'annulus_pipe.port_b.m_flow' = -'annulus_pipe.m_flows[3]';
    'annulus_pipe.port_a.h_outflow' = 'annulus_pipe.mediums[1].h';
    'annulus_pipe.port_b.h_outflow' = 'annulus_pipe.mediums[2].h';
    'annulus_pipe.state_a.phase' = if 0 == 0 then 0 else if 0 == 4 then 2 else 1;
    'annulus_pipe.state_a.h' = 'boundary.ports[2].h_outflow';
    'annulus_pipe.state_a.d' = 'Modelica.Fluid.Examples.NonCircularPipes.annulus_pipe.Medium.density_ph'('annulus_pipe.port_a.p', 'boundary.ports[2].h_outflow', 0, 0);
    'annulus_pipe.state_a.T' = 'Modelica.Fluid.Examples.NonCircularPipes.annulus_pipe.Medium.temperature_ph'('annulus_pipe.port_a.p', 'boundary.ports[2].h_outflow', 0, 0);
    'annulus_pipe.state_a.p' = 'annulus_pipe.port_a.p';
    'annulus_pipe.state_b.phase' = if 0 == 0 then 0 else if 0 == 4 then 2 else 1;
    'annulus_pipe.state_b.h' = 'massflowsink2.ports[1].h_outflow';
    'annulus_pipe.state_b.d' = 'Modelica.Fluid.Examples.NonCircularPipes.annulus_pipe.Medium.density_ph'('annulus_pipe.port_b.p', 'massflowsink2.ports[1].h_outflow', 0, 0);
    'annulus_pipe.state_b.T' = 'Modelica.Fluid.Examples.NonCircularPipes.annulus_pipe.Medium.temperature_ph'('annulus_pipe.port_b.p', 'massflowsink2.ports[1].h_outflow', 0, 0);
    'annulus_pipe.state_b.p' = 'annulus_pipe.port_b.p';
    'annulus_pipe.statesFM[1].phase' = 'annulus_pipe.mediums[1].state.phase';
    'annulus_pipe.statesFM[1].h' = 'annulus_pipe.mediums[1].state.h';
    'annulus_pipe.statesFM[1].d' = 'annulus_pipe.mediums[1].state.d';
    'annulus_pipe.statesFM[1].T' = 'annulus_pipe.mediums[1].state.T';
    'annulus_pipe.statesFM[1].p' = 'annulus_pipe.mediums[1].state.p';
    'annulus_pipe.statesFM[2].phase' = 'annulus_pipe.mediums[2].state.phase';
    'annulus_pipe.statesFM[2].h' = 'annulus_pipe.mediums[2].state.h';
    'annulus_pipe.statesFM[2].d' = 'annulus_pipe.mediums[2].state.d';
    'annulus_pipe.statesFM[2].T' = 'annulus_pipe.mediums[2].state.T';
    'annulus_pipe.statesFM[2].p' = 'annulus_pipe.mediums[2].state.p';
    'annulus_pipe.m_flows[2]' = 'annulus_pipe.flowModel.m_flows[1]';
    'annulus_pipe.vsFM[1]' = 'annulus_pipe.vs[1]';
    'annulus_pipe.vsFM[2]' = 'annulus_pipe.vs[2]';
    'annulus_pipe.port_a.p' = 'annulus_pipe.mediums[1].p';
    'annulus_pipe.port_b.p' = 'annulus_pipe.mediums[2].p';
    'annulus_pipe.ms[1]' = 'annulus_pipe.fluidVolumes[1]' * 'annulus_pipe.mediums[1].d';
    'annulus_pipe.Us[1]' = 'annulus_pipe.ms[1]' * 'annulus_pipe.mediums[1].u';
    'annulus_pipe.ms[2]' = 'annulus_pipe.fluidVolumes[2]' * 'annulus_pipe.mediums[2].d';
    'annulus_pipe.Us[2]' = 'annulus_pipe.ms[2]' * 'annulus_pipe.mediums[2].u';
    der('annulus_pipe.Us[1]') = 'annulus_pipe.Hb_flows[1]' + 'annulus_pipe.Wb_flows[1]' + 'annulus_pipe.Qb_flows[1]';
    der('annulus_pipe.Us[2]') = 'annulus_pipe.Hb_flows[2]' + 'annulus_pipe.Wb_flows[2]' + 'annulus_pipe.Qb_flows[2]';
    der('annulus_pipe.ms[1]') = 'annulus_pipe.mb_flows[1]';
    der('annulus_pipe.ms[2]') = 'annulus_pipe.mb_flows[2]';
    annotation(experiment(StopTime = 1));
  end 'NonCircularPipes';
end 'NonCircularPipes';
