    parameter Real 'imcQS.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 410.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'imcQS.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 387.9 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'imcQS.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'imcQS.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'imcQS.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 9.082868838743923e-4 "Reference conductance at reference frequency and voltage";
    parameter Real 'imcQS.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'imcQS.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 102.18857277543316 "Reference stray load losses at IRef and wRef";
