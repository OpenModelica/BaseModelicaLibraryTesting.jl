    parameter Real 'imcData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 1.1752980412939964e-6 "Torque corresponding with linear angular velocity range";
    parameter Integer 'imcData.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'imcData.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 410.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'imcData.statorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 387.9 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'imcData.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
