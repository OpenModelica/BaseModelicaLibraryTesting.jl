    parameter Real 'imcData.Lssigma'(unit = "H", quantity = "Inductance") = 0.004838310269993618 "Stator stray inductance per phase";
    parameter Real 'imcData.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'imcData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 180.0 "Reference friction losses at wRef";
    parameter Real 'imcData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 153.1526418625024 "Reference angular velocity that the PRef refer to";
