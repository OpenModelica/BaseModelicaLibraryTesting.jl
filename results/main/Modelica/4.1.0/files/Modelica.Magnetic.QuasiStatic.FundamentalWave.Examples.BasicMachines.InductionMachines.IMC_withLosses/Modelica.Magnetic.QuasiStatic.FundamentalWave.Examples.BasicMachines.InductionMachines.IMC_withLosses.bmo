    'pf_simQS' = if noEvent('SelQS' > 2.2250738585072014e-308) then 'PelQS' / 'SelQS' else 0.0;
    'pf_measQS' = 'combiTable1DsQS.y[3]';
    'eff_simQS' = if noEvent(abs('PelQS') > 2.2250738585072014e-308) then 'PmechQS' / 'PelQS' else 0.0;
    'eff_measQS' = 'combiTable1DsQS.y[4]';
    'imcQS.gammas' = 'imcQS.airGap.gammas';
