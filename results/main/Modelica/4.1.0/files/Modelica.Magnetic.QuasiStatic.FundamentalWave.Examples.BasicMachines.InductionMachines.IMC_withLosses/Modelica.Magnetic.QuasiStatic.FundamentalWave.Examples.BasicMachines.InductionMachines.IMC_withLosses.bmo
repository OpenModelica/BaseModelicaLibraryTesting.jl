    'imcQS.is[3].re' = 'imcQS.plug_sp.pin[3].i.re';
    'imcQS.is[3].im' = 'imcQS.plug_sp.pin[3].i.im';
    'imcQS.Ps_total' = 'imcQS.Ps[1]' + 'imcQS.Ps[2]' + 'imcQS.Ps[3]';
    'imcQS.Qs_total' = 'imcQS.Qs[1]' + 'imcQS.Qs[2]' + 'imcQS.Qs[3]';
    'imcQS.Ss_total' = sqrt('imcQS.Ps_total' ^ 2.0 + 'imcQS.Qs_total' ^ 2.0);
    'imcQS.stator.i[1].re' = 'imcQS.stator.plug_p.pin[1].i.re';
    'imcQS.stator.i[1].im' = 'imcQS.stator.plug_p.pin[1].i.im';
    'imcQS.stator.i[2].re' = 'imcQS.stator.plug_p.pin[2].i.re';
