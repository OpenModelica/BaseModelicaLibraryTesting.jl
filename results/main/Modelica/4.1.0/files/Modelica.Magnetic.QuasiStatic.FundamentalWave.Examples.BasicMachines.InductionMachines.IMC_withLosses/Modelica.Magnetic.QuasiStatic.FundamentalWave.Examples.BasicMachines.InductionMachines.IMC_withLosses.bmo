    'imcQS.phiMechanical' = 'imcQS.flange.phi' - 'imcQS.internalSupport.phi';
    'imcQS.wMechanical' = der('imcQS.phiMechanical');
    'imcQS.tauElectrical' = 'imcQS.inertiaRotor.flange_a.tau';
    'imcQS.tauShaft' = -'imcQS.flange.tau';
    'imcQS.powerBalance.powerStator' = sum('Modelica.ComplexMath.real'('Modelica.Units.SI.ComplexVoltage.\'*\'.multiply'('imcQS.vs[(1:size('imcQS.vs', 1))['$i1317']]', 'Modelica.ComplexMath.conj'('imcQS.is[(1:size('imcQS.vs', 1))['$i1317']]'))) for '$i1317' in 1:size('imcQS.vs', 1));
    'imcQS.powerBalance.powerMechanical' = 'imcQS.wMechanical' * 'imcQS.tauShaft';
    'imcQS.powerBalance.powerInertiaStator' = 0.12 * 'imcQS.inertiaStator.a' * 'imcQS.inertiaStator.w';
    'imcQS.powerBalance.powerInertiaRotor' = 0.12 * 'imcQS.inertiaRotor.a' * 'imcQS.inertiaRotor.w';
    'imcQS.powerBalance.lossPowerTotal' = 'imcQS.powerBalance.lossPowerStatorWinding' + 'imcQS.powerBalance.lossPowerStatorCore' + 'imcQS.powerBalance.lossPowerRotorCore' + 'imcQS.powerBalance.lossPowerStrayLoad' + 'imcQS.powerBalance.lossPowerFriction' + 'imcQS.powerBalance.lossPowerRotorWinding';
    'imcQS.powerBalance.lossPowerStatorWinding' = 'imcQS.stator.resistor.resistor[1].LossPower' + 'imcQS.stator.resistor.resistor[2].LossPower' + 'imcQS.stator.resistor.resistor[3].LossPower';
    'imcQS.powerBalance.lossPowerStatorCore' = 'imcQS.stator.core.lossPower';
    'imcQS.powerBalance.lossPowerRotorCore' = 0.0;
    'imcQS.powerBalance.lossPowerStrayLoad' = 'imcQS.strayLoad.lossPower';
    'imcQS.powerBalance.lossPowerFriction' = 'imcQS.friction.lossPower';
    'imcQS.powerBalance.lossPowerRotorWinding' = 'imcQS.rotorCage.resistor.resistor[1].LossPower' + 'imcQS.rotorCage.resistor.resistor[2].LossPower' + 'imcQS.rotorCage.resistor.resistor[3].LossPower';
    'imcQS.is[1].re' = 'imcQS.plug_sp.pin[1].i.re';
    'imcQS.is[1].im' = 'imcQS.plug_sp.pin[1].i.im';
    'imcQS.is[2].re' = 'imcQS.plug_sp.pin[2].i.re';
