  initial equation
    'PIQS.x' = 0.0;
  equation
    'PelQS' = 'electricalPowerSensorQS.apparentPower.re';
    'QelQS' = 'electricalPowerSensorQS.apparentPower.im';
    'SelQS' = sqrt('PelQS' ^ 2.0 + 'QelQS' ^ 2.0);
    'PmechQS' = 'powerSensorQS.power';
    'Ps_simQS' = 692.8203230275509 * 'I_simQS' * 'pf_simQS';
    'Ps_measQS' = 692.8203230275509 * 'I_measQS' * 'pf_measQS';
    'loss_simQS' = 'Ps_simQS' - 'PmechQS';
    'loss_measQS' = 'Ps_measQS' - 'PmechQS';
    'I_simQS' = 'currentQuasiRMSSensorQS.I';
    'I_measQS' = 'combiTable1DsQS.y[1]';
    'w_simQS' = 'imcQS.wMechanical';
