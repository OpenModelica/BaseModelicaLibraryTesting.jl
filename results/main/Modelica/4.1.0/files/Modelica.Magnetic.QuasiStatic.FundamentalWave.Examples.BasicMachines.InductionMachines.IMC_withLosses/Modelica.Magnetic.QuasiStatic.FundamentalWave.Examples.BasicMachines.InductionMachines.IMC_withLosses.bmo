    'sineVoltageQS.plug_p.pin[3].i.im' + 'sineVoltageQS.plug_n.pin[3].i.im' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[1].plug_p.reference.gamma' = 'starQS.plugToPins_p.plugToPin_p[1].pin_p.reference.gamma';
    'starQS.plugToPins_p.plugToPin_p[1].pin_p.v.re' = 'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[1].v.re';
    'starQS.plugToPins_p.plugToPin_p[1].pin_p.v.im' = 'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[1].v.im';
    'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[1].i.re' = -'starQS.plugToPins_p.plugToPin_p[1].pin_p.i.re';
    'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[1].i.im' = -'starQS.plugToPins_p.plugToPin_p[1].pin_p.i.im';
    'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[2].i.re' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[2].i.im' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[3].i.re' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[1].plug_p.pin[3].i.im' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[2].plug_p.reference.gamma' = 'starQS.plugToPins_p.plugToPin_p[2].pin_p.reference.gamma';
    'starQS.plugToPins_p.plugToPin_p[2].pin_p.v.re' = 'starQS.plugToPins_p.plugToPin_p[2].plug_p.pin[2].v.re';
    'starQS.plugToPins_p.plugToPin_p[2].pin_p.v.im' = 'starQS.plugToPins_p.plugToPin_p[2].plug_p.pin[2].v.im';
    'starQS.plugToPins_p.plugToPin_p[2].plug_p.pin[1].i.re' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[2].plug_p.pin[1].i.im' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[2].plug_p.pin[2].i.re' = -'starQS.plugToPins_p.plugToPin_p[2].pin_p.i.re';
    'starQS.plugToPins_p.plugToPin_p[2].plug_p.pin[2].i.im' = -'starQS.plugToPins_p.plugToPin_p[2].pin_p.i.im';
    'starQS.plugToPins_p.plugToPin_p[2].plug_p.pin[3].i.re' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[2].plug_p.pin[3].i.im' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[3].plug_p.reference.gamma' = 'starQS.plugToPins_p.plugToPin_p[3].pin_p.reference.gamma';
    'starQS.plugToPins_p.plugToPin_p[3].pin_p.v.re' = 'starQS.plugToPins_p.plugToPin_p[3].plug_p.pin[3].v.re';
    'starQS.plugToPins_p.plugToPin_p[3].pin_p.v.im' = 'starQS.plugToPins_p.plugToPin_p[3].plug_p.pin[3].v.im';
    'starQS.plugToPins_p.plugToPin_p[3].plug_p.pin[1].i.re' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[3].plug_p.pin[1].i.im' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[3].plug_p.pin[2].i.re' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[3].plug_p.pin[2].i.im' = 0.0;
    'starQS.plugToPins_p.plugToPin_p[3].plug_p.pin[3].i.re' = -'starQS.plugToPins_p.plugToPin_p[3].pin_p.i.re';
    'starQS.plugToPins_p.plugToPin_p[3].plug_p.pin[3].i.im' = -'starQS.plugToPins_p.plugToPin_p[3].pin_p.i.im';
    'groundQS.pin.v.re' = 0.0;
    'groundQS.pin.v.im' = 0.0;
    'powerSensorQS.flange_a.phi' = 'powerSensorQS.flange_b.phi';
    'powerSensorQS.power' = 'powerSensorQS.flange_a.tau' * der('powerSensorQS.flange_a.phi');
    0.0 = 'powerSensorQS.flange_a.tau' + 'powerSensorQS.flange_b.tau';
    'loadInertiaQS.phi' = 'loadInertiaQS.flange_a.phi';
    'loadInertiaQS.phi' = 'loadInertiaQS.flange_b.phi';
    'loadInertiaQS.w' = der('loadInertiaQS.phi');
    'loadInertiaQS.a' = der('loadInertiaQS.w');
    0.12 * 'loadInertiaQS.a' = 'loadInertiaQS.flange_a.tau' + 'loadInertiaQS.flange_b.tau';
    'torqueQS.flange.tau' = -'torqueQS.tau';
    'torqueQS.phi_support' = 0.0;
    'gainQS.y' = (-1.0) * 'gainQS.u';
    der('PIQS.x') = 'PIQS.u' / 0.01;
    'PIQS.y' = 0.01 * ('PIQS.x' + 'PIQS.u');
    'feedbackQS.y' = 'feedbackQS.u1' - 'feedbackQS.u2';
    'rampQS.y' = if time < 4.5 then 0.0 else if time < 10.0 then (time - 4.5) * 22200.0 / 5.5 else 22200.0;
    'combiTable1DsQS.y[1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValue'('combiTable1DsQS.tableID', 1, 'combiTable1DsQS.u');
    'combiTable1DsQS.y[2]' = 'Modelica.Blocks.Tables.Internal.getTable1DValue'('combiTable1DsQS.tableID', 2, 'combiTable1DsQS.u');
    'combiTable1DsQS.y[3]' = 'Modelica.Blocks.Tables.Internal.getTable1DValue'('combiTable1DsQS.tableID', 3, 'combiTable1DsQS.u');
    'combiTable1DsQS.y[4]' = 'Modelica.Blocks.Tables.Internal.getTable1DValue'('combiTable1DsQS.tableID', 4, 'combiTable1DsQS.u');
  initial algorithm
    assert(true, "3 phases are currently not supported in this version of FundametalWave", AssertionLevel.error);
    annotation(experiment(StopTime = 10, Interval = 0.0001, Tolerance = 1e-06));
  end 'IMC_withLosses';
end 'IMC_withLosses';
