    'imcQS.stator.resistor.resistor[2].P' = 'imcQS.stator.resistor.resistor[2].v.re' * 'imcQS.stator.resistor.resistor[2].i.re' - 'imcQS.stator.resistor.resistor[2].v.im' * (-'imcQS.stator.resistor.resistor[2].i.im');
    'imcQS.stator.resistor.resistor[2].Q' = 'imcQS.stator.resistor.resistor[2].v.re' * (-'imcQS.stator.resistor.resistor[2].i.im') + 'imcQS.stator.resistor.resistor[2].v.im' * 'imcQS.stator.resistor.resistor[2].i.re';
    'imcQS.stator.resistor.resistor[2].S' = sqrt(('imcQS.stator.resistor.resistor[2].v.re' * 'imcQS.stator.resistor.resistor[2].i.re' - 'imcQS.stator.resistor.resistor[2].v.im' * (-'imcQS.stator.resistor.resistor[2].i.im')) ^ 2.0 + ('imcQS.stator.resistor.resistor[2].v.re' * (-'imcQS.stator.resistor.resistor[2].i.im') + 'imcQS.stator.resistor.resistor[2].v.im' * 'imcQS.stator.resistor.resistor[2].i.re') ^ 2.0);
    'imcQS.stator.resistor.resistor[2].pf' = cos('Modelica.Math.atan3'('imcQS.stator.resistor.resistor[2].Q', 'imcQS.stator.resistor.resistor[2].P', 0.0));
