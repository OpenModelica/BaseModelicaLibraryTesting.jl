    'imcQS.stator.resistor.Q_total' = 'imcQS.stator.resistor.Q[1]' + 'imcQS.stator.resistor.Q[2]' + 'imcQS.stator.resistor.Q[3]';
    'imcQS.stator.resistor.S_total' = sqrt('imcQS.stator.resistor.P_total' ^ 2.0 + 'imcQS.stator.resistor.Q_total' ^ 2.0);
    'imcQS.stator.resistor.resistor[1].abs_v' = sqrt('imcQS.stator.resistor.resistor[1].v.re' ^ 2.0 + 'imcQS.stator.resistor.resistor[1].v.im' ^ 2.0);
    'imcQS.stator.resistor.resistor[1].arg_v' = 'Modelica.Math.atan3'('imcQS.stator.resistor.resistor[1].v.im', 'imcQS.stator.resistor.resistor[1].v.re', 0.0);
    'imcQS.stator.resistor.resistor[1].abs_i' = sqrt('imcQS.stator.resistor.resistor[1].i.re' ^ 2.0 + 'imcQS.stator.resistor.resistor[1].i.im' ^ 2.0);
    'imcQS.stator.resistor.resistor[1].arg_i' = 'Modelica.Math.atan3'('imcQS.stator.resistor.resistor[1].i.im', 'imcQS.stator.resistor.resistor[1].i.re', 0.0);
    'imcQS.stator.resistor.resistor[1].P' = 'imcQS.stator.resistor.resistor[1].v.re' * 'imcQS.stator.resistor.resistor[1].i.re' - 'imcQS.stator.resistor.resistor[1].v.im' * (-'imcQS.stator.resistor.resistor[1].i.im');
    'imcQS.stator.resistor.resistor[1].Q' = 'imcQS.stator.resistor.resistor[1].v.re' * (-'imcQS.stator.resistor.resistor[1].i.im') + 'imcQS.stator.resistor.resistor[1].v.im' * 'imcQS.stator.resistor.resistor[1].i.re';
    'imcQS.stator.resistor.resistor[1].S' = sqrt(('imcQS.stator.resistor.resistor[1].v.re' * 'imcQS.stator.resistor.resistor[1].i.re' - 'imcQS.stator.resistor.resistor[1].v.im' * (-'imcQS.stator.resistor.resistor[1].i.im')) ^ 2.0 + ('imcQS.stator.resistor.resistor[1].v.re' * (-'imcQS.stator.resistor.resistor[1].i.im') + 'imcQS.stator.resistor.resistor[1].v.im' * 'imcQS.stator.resistor.resistor[1].i.re') ^ 2.0);
    'imcQS.stator.resistor.resistor[1].pf' = cos('Modelica.Math.atan3'('imcQS.stator.resistor.resistor[1].Q', 'imcQS.stator.resistor.resistor[1].P', 0.0));
