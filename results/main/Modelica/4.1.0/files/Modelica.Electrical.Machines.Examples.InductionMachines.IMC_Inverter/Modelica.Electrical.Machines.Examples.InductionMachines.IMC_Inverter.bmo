//! base 0.1.0
package 'IMC_Inverter'
  function 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower' "Calculate active power of voltage and current input"
    input Real[3] 'v'(unit = {"V", "V", "V"}, quantity = {"ElectricPotential", "ElectricPotential", "ElectricPotential"});
    input Real[3] 'i'(unit = {"A", "A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent", "ElectricCurrent"});
    output Real 'p'(unit = "W", quantity = "Power");
    constant Integer 'm' = 3;
    Real[2] 'v_'(unit = {"V", "V"}, quantity = {"ElectricPotential", "ElectricPotential"});
    Real[2] 'i_'(unit = {"A", "A"}, quantity = {"ElectricCurrent", "ElectricCurrent"});
  algorithm
    'v_' := {0.0, 0.0};
    'i_' := {0.0, 0.0};

    for 'k' in 1:'m' loop
      'v_' := {'v_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k'], 'v_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'v'['k']};
      'i_' := {'i_'[1] + 2.0 / 'm' * cos(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k'], 'i_'[2] + 2.0 / 'm' * sin(('k' - 1) / 'm' * 2.0 * 3.141592653589793) * 'i'['k']};
    end for;

    'p' := 'm' / 2.0 * ('v_'[1] * 'i_'[1] + 'v_'[2] * 'i_'[2]);
    annotation(Inline = true);
  end 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower';

  model 'IMC_Inverter' "Test example: InductionMachineSquirrelCage with inverter"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Actual frequency";
    parameter Real 'tRamp'(unit = "s", quantity = "Time") = 1.0 "Frequency ramp";
    parameter Real 'TLoad'(unit = "N.m", quantity = "Torque") = 161.4 "Nominal load torque";
    parameter Real 'tStep'(unit = "s", quantity = "Time") = 1.2 "Time of load torque step";
    parameter Real 'JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load's moment of inertia";
    parameter Integer 'aimc.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'aimc.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'aimc.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'aimc.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operational temperature of stator resistance";
    parameter Real 'aimc.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'aimc.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of stator resistance";
    parameter Real 'aimc.alpha20s'(start = 0.0, displayUnit = "1/K", unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'aimc.Lszero'(unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator zero sequence inductance";
    parameter Real 'aimc.Lssigma'(start = 3.239643625499069e-4, unit = "H", quantity = "Inductance") = 3.239643625499069e-4 "Stator stray inductance per phase";
    parameter Real 'aimc.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Boolean 'aimc.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'aimc.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Boolean 'aimc.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Real 'aimc.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'aimc.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'aimc.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'aimc.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'aimc.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'aimc.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'aimc.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    Real 'aimc.phiMechanical'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") = 'aimc.flange.phi' - 'aimc.internalSupport.phi' "Mechanical angle of rotor against stator";
    Real 'aimc.wMechanical'(fixed = true, start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = der('aimc.phiMechanical') "Mechanical angular velocity of rotor against stator";
    Real 'aimc.tauElectrical'(unit = "N.m", quantity = "Torque") = 'aimc.inertiaRotor.flange_a.tau' "Electromagnetic torque";
    Real 'aimc.tauShaft'(unit = "N.m", quantity = "Torque") = -'aimc.flange.tau' "Shaft torque";
    Real 'aimc.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'aimc.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'aimc.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'aimc.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'aimc.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'aimc.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'aimc.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.inertiaStator.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.inertiaStator.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.inertiaStator.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'aimc.inertiaStator.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'aimc.inertiaStator.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'aimc.inertiaStator.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'aimc.inertiaStator.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'aimc.inertiaStator.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'aimc.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'aimc.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.friction.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.friction.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.friction.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.friction.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'aimc.friction.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between shaft and support";
    Real 'aimc.friction.tau'(unit = "N.m", quantity = "Torque") "Torque";
    Real 'aimc.friction.w'(unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity of flange and support";
    parameter Real 'aimc.friction.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'aimc.friction.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'aimc.friction.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'aimc.friction.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'aimc.friction.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'aimc.friction.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'aimc.friction.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Boolean 'aimc.friction.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'aimc.friction.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'aimc.friction.heatPort.Q_flow'(unit = "W", quantity = "Power") = -'aimc.friction.lossPower' "Heat flow rate (positive if flowing from outside into the component)";
    Real 'aimc.friction.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'aimc.internalSupport.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'aimc.internalSupport.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Integer 'aimc.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'aimc.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'aimc.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'aimc.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'aimc.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'aimc.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'aimc.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'aimc.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'aimc.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'aimc.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'aimc.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'aimc.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    Real 'aimc.powerBalance.powerStator'(unit = "W", quantity = "Power") = 'Modelica.Electrical.Machines.SpacePhasors.Functions.activePower'('aimc.vs', 'aimc.is') "Electrical power (stator)";
    Real 'aimc.powerBalance.powerMechanical'(unit = "W", quantity = "Power") = 'aimc.wMechanical' * 'aimc.tauShaft' "Mechanical power";
    Real 'aimc.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") = 0.29 * 'aimc.inertiaStator.a' * 'aimc.inertiaStator.w' "Stator inertia power";
    Real 'aimc.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") = 0.29 * 'aimc.inertiaRotor.a' * 'aimc.inertiaRotor.w' "Rotor inertia power";
    Real 'aimc.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") = 'aimc.powerBalance.lossPowerStatorWinding' + 'aimc.powerBalance.lossPowerStatorCore' + 'aimc.powerBalance.lossPowerRotorCore' + 'aimc.powerBalance.lossPowerStrayLoad' + 'aimc.powerBalance.lossPowerFriction' + 'aimc.powerBalance.lossPowerRotorWinding' "Total loss power";
    Real 'aimc.powerBalance.lossPowerStatorWinding'(unit = "W", quantity = "Power") = 'aimc.rs.resistor[1].LossPower' + 'aimc.rs.resistor[2].LossPower' + 'aimc.rs.resistor[3].LossPower' "Stator copper losses";
    Real 'aimc.powerBalance.lossPowerStatorCore'(unit = "W", quantity = "Power") = 'aimc.statorCore.lossPower' "Stator core losses";
    Real 'aimc.powerBalance.lossPowerRotorCore'(unit = "W", quantity = "Power") = 0.0 "Rotor core losses";
    Real 'aimc.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") = 'aimc.strayLoad.lossPower' "Stray load losses";
    Real 'aimc.powerBalance.lossPowerFriction'(unit = "W", quantity = "Power") = 'aimc.friction.lossPower' "Friction losses";
    Real 'aimc.powerBalance.lossPowerRotorWinding'(unit = "W", quantity = "Power") = 'aimc.squirrelCageR.LossPower' "Rotor copper losses";
    Real 'aimc.vs[1]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimc.vs[2]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimc.vs[3]'(unit = "V", quantity = "ElectricPotential") "Stator instantaneous voltages";
    Real 'aimc.is[1]'(unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'aimc.is[2]'(unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'aimc.is[3]'(unit = "A", quantity = "ElectricCurrent") "Stator instantaneous currents";
    Real 'aimc.i_0_s'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") = 'aimc.spacePhasorS.zero.i' "Stator zero-sequence current";
    Real 'aimc.idq_ss[1]'(unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / stator fixed frame";
    Real 'aimc.idq_ss[2]'(unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / stator fixed frame";
    Real 'aimc.idq_sr[1]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / rotor fixed frame";
    Real 'aimc.idq_sr[2]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Stator space phasor current / rotor fixed frame";
    Real 'aimc.idq_rs[1]'(unit = "A", quantity = "ElectricCurrent") "Rotor space phasor current / stator fixed frame";
    Real 'aimc.idq_rs[2]'(unit = "A", quantity = "ElectricCurrent") "Rotor space phasor current / stator fixed frame";
    Real 'aimc.idq_rr[1]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Rotor space phasor current / rotor fixed frame";
    Real 'aimc.idq_rr[2]'(stateSelect = StateSelect.prefer, unit = "A", quantity = "ElectricCurrent") "Rotor space phasor current / rotor fixed frame";
    parameter Integer 'aimc.plug_sp.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'aimc.plug_sp.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.plug_sp.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.plug_sp.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.plug_sp.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.plug_sp.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.plug_sp.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'aimc.plug_sn.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'aimc.plug_sn.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.plug_sn.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.plug_sn.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.plug_sn.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.plug_sn.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.plug_sn.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'aimc.rs.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'aimc.rs.v[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'aimc.rs.v[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'aimc.rs.v[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drops of the two polyphase plugs";
    Real 'aimc.rs.i[1]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'aimc.rs.i[2]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    Real 'aimc.rs.i[3]'(unit = "A", quantity = "ElectricCurrent") "Currents flowing into positive polyphase plugs";
    parameter Integer 'aimc.rs.plug_p.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'aimc.rs.plug_p.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.rs.plug_p.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.rs.plug_p.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.rs.plug_p.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.rs.plug_p.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.rs.plug_p.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Integer 'aimc.rs.plug_n.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'aimc.rs.plug_n.pin[1].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.rs.plug_n.pin[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.rs.plug_n.pin[2].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.rs.plug_n.pin[2].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'aimc.rs.plug_n.pin[3].v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'aimc.rs.plug_n.pin[3].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'aimc.rs.R[1]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.03 "Resistances R_ref at temperatures T_ref";
    parameter Real 'aimc.rs.R[2]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.03 "Resistances R_ref at temperatures T_ref";
    parameter Real 'aimc.rs.R[3]'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.03 "Resistances R_ref at temperatures T_ref";
    parameter Real 'aimc.rs.T_ref[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'aimc.rs.T_ref[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'aimc.rs.T_ref[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperatures";
    parameter Real 'aimc.rs.alpha[1]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Real 'aimc.rs.alpha[2]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Real 'aimc.rs.alpha[3]'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficients of resistances at reference temperatures";
    parameter Integer 'aimc.rs.mh'(min = 1) = 3 "Number of heatPorts=number of phases";
    parameter Boolean 'aimc.rs.useHeatPort' = true "= true, if all heat ports are enabled" annotation(Evaluate = true);
    parameter Real 'aimc.rs.T[1]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'aimc.rs.T[2]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    parameter Real 'aimc.rs.T[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    Real 'aimc.rs.heatPort[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'aimc.rs.heatPort[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'aimc.rs.heatPort[2].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'aimc.rs.heatPort[2].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'aimc.rs.heatPort[3].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'aimc.rs.heatPort[3].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
