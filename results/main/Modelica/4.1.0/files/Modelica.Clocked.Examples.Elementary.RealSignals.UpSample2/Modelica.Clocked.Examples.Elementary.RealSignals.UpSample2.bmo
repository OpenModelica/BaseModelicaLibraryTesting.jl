//! base 0.1.0
package 'UpSample2'
  type 'Modelica.Clocked.Types.Resolution' = enumeration('y', 'd', 'h', 'm', 's', 'ms', 'us', 'ns');

  model 'UpSample2' "Example of an UpSample block for Real signals combined with FIR filter blocks"
    parameter Integer 'periodicClock.factor'(min = 0) = 20 "Sample factor with respect to resolution" annotation(Evaluate = true);
    parameter 'Modelica.Clocked.Types.Resolution' 'periodicClock.resolution' = 'Modelica.Clocked.Types.Resolution'.'ms' "Clock resolution" annotation(Evaluate = true);
    parameter Boolean 'periodicClock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'periodicClock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'periodicClock.y';
    constant Integer 'periodicClock.conversionTable[1]' = 31536000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[2]' = 86400 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[3]' = 3600 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[4]' = 60 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[5]' = 1 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[6]' = 1000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[7]' = 1000000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[8]' = 1000000000 "Table to convert from Resolution to Integer clock resolution";
    parameter Integer 'periodicClock.resolutionFactor' = 1000 annotation(Evaluate = true);
    Clock 'periodicClock.c';
    parameter Real 'sine.amplitude' = 1.0 "Amplitude of sine wave";
    parameter Real 'sine.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of sine wave";
    parameter Real 'sine.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine.y' "Connector of Real output signal";
    parameter Real 'sine.offset' = 0.1 "Offset of output signal y";
    parameter Real 'sine.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    Real 'sample1.u' "Connector of continuous-time, Real input signal";
    Real 'sample1.y' "Connector of clocked, Real output signal";
    Clock 'sample1.clock' "Output signal y is associated with this clock input";
    parameter Boolean 'upSample.inferFactor' = false "= true, if upsampling factor is inferred" annotation(Evaluate = true);
    parameter Integer 'upSample.factor'(min = 1) = 3 "Upsampling factor >= 1 (if inferFactor=false)" annotation(Evaluate = true);
    Real 'upSample.u' "Connector of clocked, Real input signal";
    Real 'upSample.y' "Connector of clocked, Real output signal (clock of y is faster as clock of u)";
    Real 'upSample.dummy';
    Boolean 'upSample.b'(start = false);
    Boolean 'upSample.b_super'(start = false);
    Real 'upSample.u_super';
    parameter Boolean 'superSampleIpo.inferFactor' = false "= true, if super-sampling factor is inferred" annotation(Evaluate = true);
    parameter Integer 'superSampleIpo.factor'(min = 1) = 3 "Super-sampling factor >= 1 (if inferFactor=false)" annotation(Evaluate = true);
    Real 'superSampleIpo.u' "Connector of clocked, Real input signal";
    Real 'superSampleIpo.y' "Connector of clocked, Real output signal";
    Real 'superSampleIpo.uu'(start = 0.0);
    Real 'superSampleIpo.u_super';
    Real 'superSampleIpo.u_pre';
    Real 'superSampleIpo.u_preSuper';
    Integer 'superSampleIpo.usedFactor';
    Integer 'superSampleIpo.ticks'(start = 0);
    Boolean 'superSampleIpo.first'(start = true);
    Real 'FIR2.u' "Connector of clocked, Real input signal";
    Real 'FIR2.y' "Connector of clocked, Real output signal";
    Real 'FIR2.a[1]' "Coefficients of FIR filter";
    Real 'FIR2.a[2]' "Coefficients of FIR filter";
    Real 'FIR2.a[3]' "Coefficients of FIR filter";
    Real 'FIR2.a[4]' "Coefficients of FIR filter";
    Real 'FIR2.a[5]' "Coefficients of FIR filter";
    parameter Real 'FIR2.cBufStart[1]' = 0.0 "The u-buffer [u(i-1), u(i-2), ..., u(size(a,1)-1)] is initialized with u(i=1)*cBufStart";
    parameter Real 'FIR2.cBufStart[2]' = 0.0 "The u-buffer [u(i-1), u(i-2), ..., u(size(a,1)-1)] is initialized with u(i=1)*cBufStart";
    parameter Real 'FIR2.cBufStart[3]' = 0.0 "The u-buffer [u(i-1), u(i-2), ..., u(size(a,1)-1)] is initialized with u(i=1)*cBufStart";
    parameter Real 'FIR2.cBufStart[4]' = 0.0 "The u-buffer [u(i-1), u(i-2), ..., u(size(a,1)-1)] is initialized with u(i=1)*cBufStart";
    parameter Integer 'FIR2.n' = 4 "Order of filter";
    Real 'FIR2.u_buffer[1]'(start = 0.0) "The previous values of the inputs; u_buffer[1] = u, u_buffer[2] = previous(u_buffer[1]); u_buffer[3] = previous(u_buffer[2])";
    Real 'FIR2.u_buffer[2]'(start = 0.0) "The previous values of the inputs; u_buffer[1] = u, u_buffer[2] = previous(u_buffer[1]); u_buffer[3] = previous(u_buffer[2])";
    Real 'FIR2.u_buffer[3]'(start = 0.0) "The previous values of the inputs; u_buffer[1] = u, u_buffer[2] = previous(u_buffer[1]); u_buffer[3] = previous(u_buffer[2])";
    Real 'FIR2.u_buffer[4]'(start = 0.0) "The previous values of the inputs; u_buffer[1] = u, u_buffer[2] = previous(u_buffer[1]); u_buffer[3] = previous(u_buffer[2])";
    Real 'FIR2.u_buffer[5]'(start = 0.0) "The previous values of the inputs; u_buffer[1] = u, u_buffer[2] = previous(u_buffer[1]); u_buffer[3] = previous(u_buffer[2])";
    Boolean 'FIR2.first'(start = true) "Used to identify the first clock tick";
    Real 'FIR1.u' "Connector of clocked, Real input signal";
    Real 'FIR1.y' "Connector of clocked, Real output signal";
    Real 'FIR1.a[1]' "Coefficients of FIR filter";
    Real 'FIR1.a[2]' "Coefficients of FIR filter";
    Real 'FIR1.a[3]' "Coefficients of FIR filter";
    parameter Real 'FIR1.cBufStart[1]' = 0.0 "The u-buffer [u(i-1), u(i-2), ..., u(size(a,1)-1)] is initialized with u(i=1)*cBufStart";
    parameter Real 'FIR1.cBufStart[2]' = 0.0 "The u-buffer [u(i-1), u(i-2), ..., u(size(a,1)-1)] is initialized with u(i=1)*cBufStart";
    parameter Integer 'FIR1.n' = 2 "Order of filter";
    Real 'FIR1.u_buffer[1]'(start = 0.0) "The previous values of the inputs; u_buffer[1] = u, u_buffer[2] = previous(u_buffer[1]); u_buffer[3] = previous(u_buffer[2])";
    Real 'FIR1.u_buffer[2]'(start = 0.0) "The previous values of the inputs; u_buffer[1] = u, u_buffer[2] = previous(u_buffer[1]); u_buffer[3] = previous(u_buffer[2])";
    Real 'FIR1.u_buffer[3]'(start = 0.0) "The previous values of the inputs; u_buffer[1] = u, u_buffer[2] = previous(u_buffer[1]); u_buffer[3] = previous(u_buffer[2])";
    Boolean 'FIR1.first'(start = true) "Used to identify the first clock tick";
  equation
    'superSampleIpo.usedFactor' = 3;
    'sine.y' = 'sample1.u';
    'periodicClock.y' = 'sample1.clock';
    'sample1.y' = 'superSampleIpo.u';
    'sample1.y' = 'upSample.u';
    'FIR1.u' = 'upSample.y';
    'FIR1.u' = 'FIR2.u';
    'periodicClock.c' = Clock('periodicClock.factor', 1000);
    'periodicClock.y' = 'periodicClock.c';
    'sine.y' = 0.1 + (if time < 0.0 then 0.0 else 'Modelica.Math.sin'(12.566370614359172 * time));
    'sample1.y' = sample('sample1.u', 'sample1.clock');

    when Clock() then
      'upSample.dummy' = 'upSample.u';
      'upSample.b' = not previous('upSample.b');
    end when;

    when Clock() then
      'upSample.b_super' = superSample('upSample.b', 0);
      'upSample.u_super' = superSample('upSample.u', 3);
      'upSample.y' = if 'upSample.b_super' <> previous('upSample.b_super') then 'upSample.u_super' else 0.0;
    end when;

    when Clock() then
      'superSampleIpo.uu' = 'superSampleIpo.u';
      'superSampleIpo.first' = false;
      'superSampleIpo.u_pre' = if previous('superSampleIpo.first') then 'superSampleIpo.u' else previous('superSampleIpo.uu');
    end when;

    when Clock() then
      'superSampleIpo.u_super' = superSample('superSampleIpo.u', 3);
      'superSampleIpo.u_preSuper' = superSample('superSampleIpo.u_pre', 0);
      'superSampleIpo.ticks' = if previous('superSampleIpo.ticks') < 'superSampleIpo.usedFactor' then previous('superSampleIpo.ticks') + 1 else 1;
      'superSampleIpo.y' = 'superSampleIpo.u_preSuper' + 'superSampleIpo.ticks' / 'superSampleIpo.usedFactor' * ('superSampleIpo.u_super' - 'superSampleIpo.u_preSuper');
    end when;

    'FIR2.a[1]' = 0.3333333333333333;
    'FIR2.a[2]' = 0.6666666666666666;
    'FIR2.a[3]' = 1.0;
    'FIR2.a[4]' = 0.6666666666666666;
    'FIR2.a[5]' = 0.3333333333333333;

    when Clock() then
      'FIR2.first' = false;
      'FIR2.u_buffer[1]' = if previous('FIR2.first') then 'FIR2.u' else 'FIR2.u';
      'FIR2.u_buffer[2]' = if previous('FIR2.first') then 0.0 else previous('FIR2.u_buffer[1]');
      'FIR2.u_buffer[3]' = if previous('FIR2.first') then 0.0 else previous('FIR2.u_buffer[2]');
      'FIR2.u_buffer[4]' = if previous('FIR2.first') then 0.0 else previous('FIR2.u_buffer[3]');
      'FIR2.u_buffer[5]' = if previous('FIR2.first') then 0.0 else previous('FIR2.u_buffer[4]');
      'FIR2.y' = 'FIR2.a[1]' * 'FIR2.u_buffer[1]' + 'FIR2.a[2]' * 'FIR2.u_buffer[2]' + 'FIR2.a[3]' * 'FIR2.u_buffer[3]' + 'FIR2.a[4]' * 'FIR2.u_buffer[4]' + 'FIR2.a[5]' * 'FIR2.u_buffer[5]';
    end when;

    'FIR1.a[1]' = 1.0;
    'FIR1.a[2]' = 1.0;
    'FIR1.a[3]' = 1.0;

    when Clock() then
      'FIR1.first' = false;
      'FIR1.u_buffer[1]' = if previous('FIR1.first') then 'FIR1.u' else 'FIR1.u';
      'FIR1.u_buffer[2]' = if previous('FIR1.first') then 0.0 else previous('FIR1.u_buffer[1]');
      'FIR1.u_buffer[3]' = if previous('FIR1.first') then 0.0 else previous('FIR1.u_buffer[2]');
      'FIR1.y' = 'FIR1.a[1]' * 'FIR1.u_buffer[1]' + 'FIR1.a[2]' * 'FIR1.u_buffer[2]' + 'FIR1.a[3]' * 'FIR1.u_buffer[3]';
    end when;
    annotation(experiment(StopTime = 0.06));
  end 'UpSample2';
end 'UpSample2';
