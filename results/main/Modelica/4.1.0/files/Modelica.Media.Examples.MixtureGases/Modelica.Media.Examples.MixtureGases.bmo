      'lambdaX'['i'] := 'Modelica.Media.IdealGases.Common.Functions.thermalConductivityEstimate'('cp'['i'], 'eta'['i'], 'method', ({'Modelica.Media.IdealGases.Common.DataRecord'("CH4", 0.01604246, -4.65015963885838e6, 624355.7409524474, 1000.0, {-176685.0998, 2786.18102, -12.0257785, 0.0391761929, -3.61905443e-5, 2.026853043e-8, -4.976705489999999e-12}, {-23313.1436, 89.0432275}, {3.73004276e6, -13835.01485, 20.49107091, -0.001961974759, 4.72731304e-7, -3.72881469e-11, 1.623737207e-15}, {75320.6691, -121.9124889}, 518.2814855078335), 'Modelica.Media.IdealGases.Common.DataRecord'("C2H6", 0.03006904, -2.788633890539904e6, 395476.3437741943, 1000.0, {-186204.4161, 3406.19186, -19.51705092, 0.0756583559, -8.20417322e-5, 5.0611358e-8, -1.319281992e-11}, {-27029.3289, 129.8140496}, {5.02578213e6, -20330.22397, 33.2255293, -0.00383670341, 7.23840586e-7, -7.3191825e-11, 3.065468699e-15}, {111596.395, -203.9410584}, 276.51398248830026), 'Modelica.Media.IdealGases.Common.DataRecord'("C3H8", 0.04409562, -2.373931923397381e6, 334301.1845620949, 1000.0, {-243314.4337, 4656.27081, -29.39466091, 0.1188952745, -1.376308269e-4, 8.814823909999999e-8, -2.342987994e-11}, {-35403.3527, 184.1749277}, {6.420731680000001e6, -26597.91134, 45.3435684, -0.00502066392, 9.471216939999999e-7, -9.57540523e-11, 4.00967288e-15}, {145558.2459, -281.8374734}, 188.55636909062622), 'Modelica.Media.IdealGases.Common.DataRecord'("C4H10_n_butane", 0.0581222, -2.16423328779709e6, 330832.0228759407, 1000.0, {-317587.254, 6176.331819999999, -38.9156212, 0.1584654284, -1.860050159e-4, 1.199676349e-7, -3.20167055e-11}, {-45403.63390000001, 237.9488665}, {7.68232245e6, -32560.5151, 57.3673275, -0.00619791681, 1.180186048e-6, -1.221893698e-10, 5.250635250000001e-15}, {177452.656, -358.791876}, 143.05222445124238), 'Modelica.Media.IdealGases.Common.DataRecord'("N2", 0.0280134, 0.0, 309498.4543111511, 1000.0, {22103.71497, -381.846182, 6.08273836, -0.00853091441, 1.384646189e-5, -9.62579362e-9, 2.519705809e-12}, {710.846086, -10.76003744}, {587712.406, -2239.249073, 6.06694922, -6.1396855e-4, 1.491806679e-7, -1.923105485e-11, 1.061954386e-15}, {12832.10415, -15.86640027}, 296.80474344420884), 'Modelica.Media.IdealGases.Common.DataRecord'("CO2", 0.0440095, -8.941478544405185e6, 212805.6215135368, 1000.0, {49436.5054, -626.411601, 5.30172524, 0.002503813816, -2.127308728e-7, -7.68998878e-10, 2.849677801e-13}, {-45281.9846, -7.04827944}, {117696.2419, -1788.791477, 8.29152319, -9.22315678e-5, 4.86367688e-9, -1.891053312e-12, 6.330036589999999e-16}, {-39083.5059, -26.52669281}, 188.92534566400437)})['i']);
    end for;

    'lambda' := 'Modelica.Media.Examples.MixtureGases.Medium2.lowPressureThermalConductivity'('Modelica.Media.Examples.MixtureGases.Medium2.massToMoleFractions'('state'.'X', {0.01604246, 0.03006904, 0.04409562, 0.0581222, 0.0280134, 0.0440095}), 'state'.'T', {190.56, 305.32, 369.83, 425.12, 126.2, 304.12}, {4.599e6, 4.872e6, 4.248e6, 3.796e6, 3.398e6, 7.374e6}, {0.01604246, 0.03006904, 0.04409562, 0.0581222, 0.0280134, 0.0440095}, 'lambdaX');
