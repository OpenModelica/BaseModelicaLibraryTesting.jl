    'medium2.state.p' = 'medium2.p';
    'medium2.state.X[1]' = 'medium2.X[1]';
    'medium2.state.X[2]' = 'medium2.X[2]';
    'medium2.state.X[3]' = 'medium2.X[3]';
    'medium2.state.X[4]' = 'medium2.X[4]';
    'medium2.state.X[5]' = 'medium2.X[5]';
    'medium2.state.X[6]' = 'medium2.X[6]';
    'medium2.Xi[1]' = 'medium2.X[1]';
    'medium2.Xi[2]' = 'medium2.X[2]';
    'medium2.Xi[3]' = 'medium2.X[3]';
    'medium2.Xi[4]' = 'medium2.X[4]';
    'medium2.Xi[5]' = 'medium2.X[5]';
    'medium2.Xi[6]' = 'medium2.X[6]';
    assert('medium2.X[1]' >= (-1e-5) and 'medium2.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('medium2.X[1]') + "of substance " + "Methane" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[2]' >= (-1e-5) and 'medium2.X[2]' <= 1.00001, "Mass fraction X[" + String(2) + "] = " + String('medium2.X[2]') + "of substance " + "Ethane" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[3]' >= (-1e-5) and 'medium2.X[3]' <= 1.00001, "Mass fraction X[" + String(3) + "] = " + String('medium2.X[3]') + "of substance " + "Propane" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[4]' >= (-1e-5) and 'medium2.X[4]' <= 1.00001, "Mass fraction X[" + String(4) + "] = " + String('medium2.X[4]') + "of substance " + "N-Butane," + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[5]' >= (-1e-5) and 'medium2.X[5]' <= 1.00001, "Mass fraction X[" + String(5) + "] = " + String('medium2.X[5]') + "of substance " + "Nitrogen" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.X[6]' >= (-1e-5) and 'medium2.X[6]' <= 1.00001, "Mass fraction X[" + String(6) + "] = " + String('medium2.X[6]') + "of substance " + "Carbondioxide" + "\nof medium " + "SimpleNaturalGas" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium2.p' >= 0.0, "Pressure (= " + String('medium2.p') + " Pa) of medium \"" + "SimpleNaturalGas" + "\" is negative\n(Temperature = " + String('medium2.T') + " K)", AssertionLevel.error);
    'state2.X[1]' = 0.3;
    'state2.X[2]' = 0.2;
    'state2.X[3]' = 0.2;
    'state2.X[4]' = 0.1;
    'state2.X[5]' = 0.1;
    'state2.X[6]' = 0.1;
    'medium1.X[1]' = 0.8;
    'medium1.X[2]' = 0.2;
    'm1' = 'medium1.d';
    'U1' = 'm1' * 'medium1.u';
    der('m1') = 0.01;
    der('U1') = 5000.0;
    'medium2.X[1]' = 0.1;
    'medium2.X[2]' = 0.1;
    'medium2.X[3]' = 0.1;
    'medium2.X[4]' = 0.2;
    'medium2.X[5]' = 0.2;
    'medium2.X[6]' = 0.3;
    'm2' = 'medium2.d';
    'U2' = 'm2' * 'medium2.u';
    der('m2') = 0.01;
    der('U2') = 5000.0;
    'm_flow_ext2' = time - 0.5;
    'smoothState.p' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.p' else if 'm_flow_ext2' < (-0.2) then 'state2.p' else if abs(0.2) > 0.0 then 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.p' - 'medium2.state.p') / 4.0 + ('medium2.state.p' + 'state2.p') / 2.0 else ('medium2.state.p' + 'state2.p') / 2.0);
    'smoothState.T' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.T' else if 'm_flow_ext2' < (-0.2) then 'state2.T' else if abs(0.2) > 0.0 then 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.T' - 'medium2.state.T') / 4.0 + ('medium2.state.T' + 'state2.T') / 2.0 else ('medium2.state.T' + 'state2.T') / 2.0);
    'smoothState.X[1]' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.X[1]' else if 'm_flow_ext2' < (-0.2) then 'state2.X[1]' else 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.X[1]' - 'medium2.state.X[1]') / 4.0 + ('medium2.state.X[1]' + 'state2.X[1]') / 2.0);
    'smoothState.X[2]' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.X[2]' else if 'm_flow_ext2' < (-0.2) then 'state2.X[2]' else 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.X[2]' - 'medium2.state.X[2]') / 4.0 + ('medium2.state.X[2]' + 'state2.X[2]') / 2.0);
    'smoothState.X[3]' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.X[3]' else if 'm_flow_ext2' < (-0.2) then 'state2.X[3]' else 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.X[3]' - 'medium2.state.X[3]') / 4.0 + ('medium2.state.X[3]' + 'state2.X[3]') / 2.0);
    'smoothState.X[4]' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.X[4]' else if 'm_flow_ext2' < (-0.2) then 'state2.X[4]' else 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.X[4]' - 'medium2.state.X[4]') / 4.0 + ('medium2.state.X[4]' + 'state2.X[4]') / 2.0);
    'smoothState.X[5]' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.X[5]' else if 'm_flow_ext2' < (-0.2) then 'state2.X[5]' else 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.X[5]' - 'medium2.state.X[5]') / 4.0 + ('medium2.state.X[5]' + 'state2.X[5]') / 2.0);
    'smoothState.X[6]' = smooth(1, if 'm_flow_ext2' > 0.2 then 'medium2.state.X[6]' else if 'm_flow_ext2' < (-0.2) then 'state2.X[6]' else 'm_flow_ext2' / 0.2 * (('m_flow_ext2' / 0.2) ^ 2.0 - 3.0) * ('state2.X[6]' - 'medium2.state.X[6]') / 4.0 + ('medium2.state.X[6]' + 'state2.X[6]') / 2.0);
    'der_p' = der('smoothState.p');
    'der_T' = der('smoothState.T');
    annotation(experiment(StopTime = 1));
  end 'MixtureGases';
end 'MixtureGases';
