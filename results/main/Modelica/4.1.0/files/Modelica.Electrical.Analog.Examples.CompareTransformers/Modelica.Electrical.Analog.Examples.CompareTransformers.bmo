    Real 'idealTransformer.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'idealTransformer.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'idealTransformer.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'idealTransformer.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'idealTransformer.n'(start = 1.0) = 2.0 "Turns ratio primary:secondary voltage";
    parameter Boolean 'idealTransformer.considerMagnetization' = false "Choice of considering magnetization" annotation(Evaluate = true);
    parameter Real 'idealTransformer.Lm1'(start = 1.0, unit = "H", quantity = "Inductance") = 0.15915494309189535 "Magnetization inductance w.r.t. primary side";
    Real 'idealTransformer.im1'(unit = "A", quantity = "ElectricCurrent") "Magnetization current w.r.t. primary side";
    Real 'idealTransformer.psim1'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux w.r.t. primary side";
  initial equation
    'basicTransformer.i1' = 0.0;
    'basicTransformer.i2' = 0.0;
  equation
    'v1B' = 'resistor11.n.v';
    'i1B' = 'resistor11.i';
    'v2B' = 'resistor12.p.v';
    'i2B' = 'resistor12.i';
    'v1I' = 'resistor21.n.v';
    'i1I' = 'resistor21.i';
    'v2I' = 'resistor22.p.v';
    'i2I' = 'resistor22.i';
    'ground11.p.v' = 'basicTransformer.n1.v';
    'ground11.p.v' = 'sineVoltage1.n.v';
    'sineVoltage1.p.v' = 'resistor11.p.v';
    'basicTransformer.n2.v' = 'ground12.p.v';
    'basicTransformer.n2.v' = 'load1.n.v';
    'resistor12.n.v' = 'load1.p.v';
