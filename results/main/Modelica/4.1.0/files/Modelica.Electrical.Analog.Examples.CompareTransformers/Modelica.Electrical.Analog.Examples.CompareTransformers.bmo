    Real 'resistor22.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor22.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor22.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor22.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor22.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor22.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'load2.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.25 "Resistance at temperature T_ref";
    parameter Real 'load2.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'load2.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'load2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'load2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'load2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'load2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'load2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'load2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'load2.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ground22.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground22.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'basicTransformer.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'basicTransformer.v2'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'basicTransformer.i1'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'basicTransformer.i2'(start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'basicTransformer.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'basicTransformer.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'basicTransformer.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'basicTransformer.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'basicTransformer.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'basicTransformer.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'basicTransformer.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'basicTransformer.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'basicTransformer.L1'(start = 1.0, unit = "H", quantity = "Inductance") = 0.15995071780735481 "Primary inductance";
    parameter Real 'basicTransformer.L2'(start = 1.0, unit = "H", quantity = "Inductance") = 0.039987679451838704 "Secondary inductance";
    parameter Real 'basicTransformer.M'(start = 1.0, unit = "H", quantity = "Inductance") = 0.07957747154594767 "Coupling inductance";
    Real 'basicTransformer.dv' "Difference between voltage drop over primary inductor and voltage drop over secondary inductor";
    Real 'idealTransformer.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'idealTransformer.v2'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'idealTransformer.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'idealTransformer.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'idealTransformer.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'idealTransformer.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'idealTransformer.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
