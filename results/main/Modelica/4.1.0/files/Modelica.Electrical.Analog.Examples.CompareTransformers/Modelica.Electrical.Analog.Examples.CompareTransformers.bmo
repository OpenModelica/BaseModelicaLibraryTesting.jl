//! base 0.1.0
package 'CompareTransformers'
  model 'CompareTransformers' "Transformer circuit to show the magnetization facilities"
    parameter Real 'Vdc'(unit = "V", quantity = "ElectricPotential") = 0.1 "DC offset of voltage source";
    parameter Real 'Vpeak'(unit = "V", quantity = "ElectricPotential") = 0.1 "Peak voltage of voltage source";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of voltage source";
    parameter Real 'phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267948966 "Phase of voltage source";
    parameter Real 'n' = 2.0 "Turns ratio primary:secondary voltage";
    parameter Real 'R1'(unit = "Ohm", quantity = "Resistance") = 0.01 "Primary resistance w.r.t. primary side";
    parameter Real 'L1sigma'(unit = "H", quantity = "Inductance") = 7.957747154594768e-4 "Primary leakage inductance w.r.t. primary side";
    parameter Real 'Lm1'(unit = "H", quantity = "Inductance") = 0.15915494309189535 "Magnetizing inductance w.r.t. primary side";
    parameter Real 'L2sigma'(unit = "H", quantity = "Inductance") = 1.989436788648692e-4 "Secondary leakage inductance w.r.t. secondary side";
    parameter Real 'R2'(unit = "Ohm", quantity = "Resistance") = 0.0025 "Secondary resistance w.r.t. secondary side";
    parameter Real 'RL'(unit = "Ohm", quantity = "Resistance") = 0.25 "Load resistance";
    parameter Real 'L1'(unit = "H", quantity = "Inductance") = 0.15995071780735481 "Primary no-load inductance";
    parameter Real 'L2'(unit = "H", quantity = "Inductance") = 0.039987679451838704 "Secondary no-load inductance";
    parameter Real 'M'(unit = "H", quantity = "Inductance") = 0.07957747154594767 "Mutual inductance";
    output Real 'v1B'(unit = "V", quantity = "ElectricPotential") "Primary voltage, basic transformer";
    output Real 'i1B'(unit = "A", quantity = "ElectricCurrent") "Primary current, basic transformer";
    output Real 'v2B'(unit = "V", quantity = "ElectricPotential") "Secondary voltage, basic transformer";
    output Real 'i2B'(unit = "A", quantity = "ElectricCurrent") "Secondary current, basic transformer";
    output Real 'v1I'(unit = "V", quantity = "ElectricPotential") "Primary voltage, basic transformer";
    output Real 'i1I'(unit = "A", quantity = "ElectricCurrent") "Primary current, basic transformer";
    output Real 'v2I'(unit = "V", quantity = "ElectricPotential") "Secondary voltage, basic transformer";
    output Real 'i2I'(unit = "A", quantity = "ElectricCurrent") "Secondary current, basic transformer";
    parameter Real 'sineVoltage1.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 0.1 "Amplitude of sine wave";
    parameter Real 'sineVoltage1.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267948966 "Phase of sine wave";
    parameter Real 'sineVoltage1.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of sine wave";
    Real 'sineVoltage1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sineVoltage1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sineVoltage1.signalSource.amplitude' = 0.1 "Amplitude of sine wave";
    parameter Real 'sineVoltage1.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of sine wave";
    parameter Real 'sineVoltage1.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267948966 "Phase of sine wave";
    parameter Boolean 'sineVoltage1.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltage1.signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltage1.signalSource.offset' = 0.1 "Offset of output signal y";
    parameter Real 'sineVoltage1.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sineVoltage1.offset'(unit = "V", quantity = "ElectricPotential") = 0.1 "Voltage offset";
    parameter Real 'sineVoltage1.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    Real 'ground11.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground11.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'resistor11.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.01 "Resistance at temperature T_ref";
    parameter Real 'resistor11.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor11.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor11.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor11.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor11.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor11.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor11.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor11.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor11.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor11.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor11.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor11.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor11.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'resistor12.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.0025 "Resistance at temperature T_ref";
    parameter Real 'resistor12.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor12.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor12.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor12.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor12.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor12.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor12.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor12.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor12.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor12.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor12.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor12.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor12.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'load1.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.25 "Resistance at temperature T_ref";
    parameter Real 'load1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'load1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'load1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'load1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'load1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'load1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'load1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'load1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'load1.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ground12.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground12.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'sineVoltage2.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 0.1 "Amplitude of sine wave";
    parameter Real 'sineVoltage2.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267948966 "Phase of sine wave";
    parameter Real 'sineVoltage2.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of sine wave";
    Real 'sineVoltage2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sineVoltage2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sineVoltage2.signalSource.amplitude' = 0.1 "Amplitude of sine wave";
    parameter Real 'sineVoltage2.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of sine wave";
    parameter Real 'sineVoltage2.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.5707963267948966 "Phase of sine wave";
    parameter Boolean 'sineVoltage2.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltage2.signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltage2.signalSource.offset' = 0.1 "Offset of output signal y";
    parameter Real 'sineVoltage2.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sineVoltage2.offset'(unit = "V", quantity = "ElectricPotential") = 0.1 "Voltage offset";
    parameter Real 'sineVoltage2.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    Real 'ground21.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground21.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'resistor21.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 0.01 "Resistance at temperature T_ref";
    parameter Real 'resistor21.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor21.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor21.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor21.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor21.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
