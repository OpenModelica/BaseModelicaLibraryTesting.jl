//! base 0.1.0
package 'Motor'
  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmin' "Return minimum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMin';
  external "C" 'timeMin' = ModelicaStandardTables_CombiTimeTable_minimumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmin';

  function 'Modelica.Blocks.Tables.Internal.getNextTimeEvent' "Return next time event value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Real 'timeIn';
    output Real 'nextTimeEvent';
  external "C" 'nextTimeEvent' = ModelicaStandardTables_CombiTimeTable_nextTimeEvent('tableID', 'timeIn') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getNextTimeEvent';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmax' "Return maximum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMax';
  external "C" 'timeMax' = ModelicaStandardTables_CombiTimeTable_maximumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmax';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer' "Interpolate 1-dim. table where first column is time (but do not provide a derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Integer 'icol';
    input Real 'timeIn';
    input Real 'nextTimeEvent';
    input Real 'pre_nextTimeEvent';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTimeTable_getValue('tableID', 'icol', 'timeIn', 'nextTimeEvent', 'pre_nextTimeEvent') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer';

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  type 'Modelica.Blocks.Types.TimeEvents' = enumeration('Always', 'AtDiscontinuities', 'NoTimeEvents');

  class 'Modelica.Blocks.Types.ExternalCombiTimeTable'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table where first column is time"
      input String 'tableName';
      input String 'fileName';
      input Real 'table'[:, :];
      input Real 'startTime';
      input Integer 'columns'[:];
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation';
      input Real 'shiftTime' = 0.0;
      input 'Modelica.Blocks.Types.TimeEvents' 'timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" 'externalCombiTimeTable' = ModelicaStandardTables_CombiTimeTable_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'startTime', 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'shiftTime', 'timeEvents', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table where first column is time"
      input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" ModelicaStandardTables_CombiTimeTable_close('externalCombiTimeTable') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTimeTable';

  model 'Motor' "Second order thermal model of a motor"
    parameter Real 'TAmb'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    parameter Integer 'lossTable.nout'(min = 1) = 2 "Number of outputs";
    Real 'lossTable.y[1]' "Connector of Real output signals";
    Real 'lossTable.y[2]' "Connector of Real output signals";
    parameter Boolean 'lossTable.tableOnFile' = false "= true, if table is defined on file or in function usertab";
    parameter Real 'lossTable.table[1,1]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'lossTable.table[1,2]' = 100.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'lossTable.table[1,3]' = 500.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'lossTable.table[2,1]' = 360.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'lossTable.table[2,2]' = 1000.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'lossTable.table[2,3]' = 500.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'lossTable.table[3,1]' = 600.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'lossTable.table[3,2]' = 100.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'lossTable.table[3,3]' = 500.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter String 'lossTable.tableName' = "NoName" "Table name on file or in function usertab (see docu)";
    parameter String 'lossTable.fileName' = "NoName" "File where matrix is stored";
    parameter String 'lossTable.delimiter' = "," "Column delimiter character for CSV file";
    parameter Integer 'lossTable.nHeaderLines' = 0 "Number of header lines to ignore for CSV file";
    parameter Boolean 'lossTable.verboseRead' = true "= true, if info message that file is loading is to be printed";
    parameter Integer 'lossTable.columns[1]' = 2 "Columns of table to be interpolated";
    parameter Integer 'lossTable.columns[2]' = 3 "Columns of table to be interpolated";
    parameter 'Modelica.Blocks.Types.Smoothness' 'lossTable.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments' "Smoothness of table interpolation";
    parameter 'Modelica.Blocks.Types.Extrapolation' 'lossTable.extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'Periodic' "Extrapolation of data outside the definition range";
    parameter Real 'lossTable.timeScale'(min = 2.220446049250313e-16, unit = "s", quantity = "Time") = 1.0 "Time scale of first table column" annotation(Evaluate = true);
    parameter Real 'lossTable.offset[1]' = 0.0 "Offsets of output signals";
    parameter Real 'lossTable.startTime'(unit = "s", quantity = "Time") = 0.0 "Output = offset for time < startTime";
    parameter Real 'lossTable.shiftTime'(unit = "s", quantity = "Time") = 0.0 "Shift time of first table column";
    parameter 'Modelica.Blocks.Types.TimeEvents' 'lossTable.timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always' "Time event handling of table interpolation";
    parameter Boolean 'lossTable.verboseExtrapolation' = false "= true, if warning messages are to be printed if time is outside the table definition range";
    parameter Real 'lossTable.t_min'(unit = "s", quantity = "Time") = 'lossTable.t_minScaled' "Minimum abscissa value defined in table";
    parameter Real 'lossTable.t_max'(unit = "s", quantity = "Time") = 'lossTable.t_maxScaled' "Maximum abscissa value defined in table";
    parameter Real 'lossTable.t_minScaled' = 'Modelica.Blocks.Tables.Internal.getTimeTableTmin'('lossTable.tableID') "Minimum (scaled) abscissa value defined in table";
    parameter Real 'lossTable.t_maxScaled' = 'Modelica.Blocks.Tables.Internal.getTimeTableTmax'('lossTable.tableID') "Maximum (scaled) abscissa value defined in table";
    parameter Real 'lossTable.p_offset[1]' = 0.0 "Offsets of output signals";
    parameter Real 'lossTable.p_offset[2]' = 0.0 "Offsets of output signals";
    parameter 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'lossTable.tableID' = 'Modelica.Blocks.Types.ExternalCombiTimeTable'("NoName", "NoName", {{0.0, 100.0, 500.0}, {360.0, 1000.0, 500.0}, {600.0, 100.0, 500.0}}, 0.0, {2, 3}, 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments', 'Modelica.Blocks.Types.Extrapolation'.'Periodic', 0.0, 'Modelica.Blocks.Types.TimeEvents'.'Always', false, ",", 0) "External table object";
    discrete Real 'lossTable.nextTimeEvent'(fixed = true, start = 0.0, unit = "s", quantity = "Time") "Next time event instant";
    discrete Real 'lossTable.nextTimeEventScaled'(fixed = true, start = 0.0) "Next scaled time event instant";
    Real 'lossTable.timeScaled' "Scaled time";
    parameter Boolean 'lossTable.isCsvExt' = false;
    parameter Real 'windingLosses.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 368.15 "Reference temperature";
    parameter Real 'windingLosses.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.00303 "Temperature coefficient of heat flow rate";
    Real 'windingLosses.Q_flow'(unit = "W");
    Real 'windingLosses.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'windingLosses.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'winding.C'(unit = "J/K", quantity = "HeatCapacity") = 2500.0 "Heat capacity of element (= cp*m)";
    Real 'winding.T'(nominal = 300.0, fixed = true, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of element";
    Real 'winding.der_T'(start = 0.0, unit = "K/s", quantity = "TemperatureSlope") "Time derivative of temperature (= der(T))";
    Real 'winding.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'winding.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'Twinding.T'(unit = "degC") "Absolute temperature in degree Celsius as output signal";
    Real 'Twinding.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'Twinding.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'winding2core.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate from port_a -> port_b";
    Real 'winding2core.dT'(unit = "K", quantity = "ThermodynamicTemperature") "port_a.T - port_b.T";
    Real 'winding2core.port_a.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'winding2core.port_a.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'winding2core.port_b.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'winding2core.port_b.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'winding2core.G'(unit = "W/K", quantity = "ThermalConductance") = 10.0 "Constant thermal conductance of material";
    parameter Real 'coreLosses.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'coreLosses.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of heat flow rate";
    Real 'coreLosses.Q_flow'(unit = "W");
    Real 'coreLosses.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'coreLosses.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'core.C'(unit = "J/K", quantity = "HeatCapacity") = 25000.0 "Heat capacity of element (= cp*m)";
    Real 'core.T'(nominal = 300.0, fixed = true, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of element";
    Real 'core.der_T'(start = 0.0, unit = "K/s", quantity = "TemperatureSlope") "Time derivative of temperature (= der(T))";
    Real 'core.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'core.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'Tcore.T'(unit = "degC") "Absolute temperature in degree Celsius as output signal";
    Real 'Tcore.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'Tcore.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'convectionConstant.k'(start = 1.0) = 25.0 "Constant output value";
    Real 'convectionConstant.y' "Connector of Real output signal";
    Real 'convection.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate from solid -> fluid";
    Real 'convection.dT'(unit = "K", quantity = "ThermodynamicTemperature") "= solid.T - fluid.T";
    Real 'convection.Gc'(unit = "W/K") "Signal representing the convective thermal conductance in [W/K]";
    Real 'convection.solid.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'convection.solid.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'convection.fluid.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'convection.fluid.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    parameter Real 'environment.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed temperature at port";
    Real 'environment.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'environment.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
  equation
    'winding.port.T' = 'Twinding.port.T';
    'winding.port.T' = 'winding2core.port_a.T';
    'winding.port.T' = 'windingLosses.port.T';
    'winding2core.port_b.T' = 'convection.solid.T';
    'winding2core.port_b.T' = 'core.port.T';
    'winding2core.port_b.T' = 'Tcore.port.T';
    'winding2core.port_b.T' = 'coreLosses.port.T';
    'convection.fluid.T' = 'environment.port.T';
    'convectionConstant.y' = 'convection.Gc';
    'lossTable.y[1]' = 'windingLosses.Q_flow';
    'lossTable.y[2]' = 'coreLosses.Q_flow';
    'winding2core.port_a.Q_flow' + 'Twinding.port.Q_flow' + 'winding.port.Q_flow' + 'windingLosses.port.Q_flow' = 0.0;
    'convection.solid.Q_flow' + 'Tcore.port.Q_flow' + 'core.port.Q_flow' + 'coreLosses.port.Q_flow' + 'winding2core.port_b.Q_flow' = 0.0;
    'environment.port.Q_flow' + 'convection.fluid.Q_flow' = 0.0;
    'lossTable.timeScaled' = time;

    when {time >= pre('lossTable.nextTimeEvent'), initial()} then
      'lossTable.nextTimeEventScaled' = 'Modelica.Blocks.Tables.Internal.getNextTimeEvent'('lossTable.tableID', 'lossTable.timeScaled');
      'lossTable.nextTimeEvent' = if 'lossTable.nextTimeEventScaled' < 1e60 then 'lossTable.nextTimeEventScaled' else 1e60;
    end when;

    'lossTable.y[1]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer'('lossTable.tableID', 1, 'lossTable.timeScaled', 'lossTable.nextTimeEventScaled', pre('lossTable.nextTimeEventScaled'));
    'lossTable.y[2]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer'('lossTable.tableID', 2, 'lossTable.timeScaled', 'lossTable.nextTimeEventScaled', pre('lossTable.nextTimeEventScaled'));
    'windingLosses.port.Q_flow' = -'windingLosses.Q_flow' * (1.0 + 0.00303 * ('windingLosses.port.T' - 368.15));
    'winding.T' = 'winding.port.T';
    'winding.der_T' = der('winding.T');
    2500.0 * der('winding.T') = 'winding.port.Q_flow';
    'Twinding.T' = 'Twinding.port.T' - 273.15;
    'Twinding.port.Q_flow' = 0.0;
    'winding2core.Q_flow' = 10.0 * 'winding2core.dT';
    'winding2core.dT' = 'winding2core.port_a.T' - 'winding2core.port_b.T';
    'winding2core.port_a.Q_flow' = 'winding2core.Q_flow';
    'winding2core.port_b.Q_flow' = -'winding2core.Q_flow';
    'coreLosses.port.Q_flow' = -'coreLosses.Q_flow';
    'core.T' = 'core.port.T';
    'core.der_T' = der('core.T');
    25000.0 * der('core.T') = 'core.port.Q_flow';
    'Tcore.T' = 'Tcore.port.T' - 273.15;
    'Tcore.port.Q_flow' = 0.0;
    'convectionConstant.y' = 25.0;
    'convection.dT' = 'convection.solid.T' - 'convection.fluid.T';
    'convection.solid.Q_flow' = 'convection.Q_flow';
    'convection.fluid.Q_flow' = -'convection.Q_flow';
    'convection.Q_flow' = 'convection.Gc' * 'convection.dT';
    'environment.port.T' = 293.15;
    annotation(experiment(StopTime = 7200, Interval = 0.01));
  end 'Motor';
end 'Motor';
