    'v2.i.im' = 0.0;
    0.0 = 'v2.pin_p.i.re' + 'v2.pin_n.i.re' "Current balance";
    0.0 = 'v2.pin_p.i.im' + 'v2.pin_n.i.im' "Current balance";
    'v2.pin_p.reference.gamma' = 'v2.pin_n.reference.gamma';
    'v2.omega' = der('v2.pin_p.reference.gamma');
    'polarToComplex.y.re' = 'polarToComplex.len' * cos('polarToComplex.phi');
    'polarToComplex.y.im' = 'polarToComplex.len' * sin('polarToComplex.phi');
    'const.y' = 250.0;
    'ramp.y' = if time < 0.0 then 0.0 else if time < 1.0 then time * 6.283185307179586 else 6.283185307179586;
    'constFrequency.y' = 50.0;
    'i2.i.re' = 'i2.pin_p.i.re';
    'i2.i.im' = 'i2.pin_p.i.im';
    'i2.v.re' = 'i2.pin_p.v.re' - 'i2.pin_n.v.re';
    'i2.v.im' = 'i2.pin_p.v.im' - 'i2.pin_n.v.im';
    'i2.v.re' = 0.0;
    'i2.v.im' = 0.0;
    0.0 = 'i2.pin_p.i.re' + 'i2.pin_n.i.re' "Current balance";
    0.0 = 'i2.pin_p.i.im' + 'i2.pin_n.i.im' "Current balance";
    'i2.pin_p.reference.gamma' = 'i2.pin_n.reference.gamma';
    'i2.omega' = der('i2.pin_p.reference.gamma');
    'i1.i.re' = 'i1.pin_p.i.re';
    'i1.i.im' = 'i1.pin_p.i.im';
    'i1.v.re' = 'i1.pin_p.v.re' - 'i1.pin_n.v.re';
    'i1.v.im' = 'i1.pin_p.v.im' - 'i1.pin_n.v.im';
    'i1.v.re' = 0.0;
    'i1.v.im' = 0.0;
    0.0 = 'i1.pin_p.i.re' + 'i1.pin_n.i.re' "Current balance";
    0.0 = 'i1.pin_p.i.im' + 'i1.pin_n.i.im' "Current balance";
    'i1.pin_p.reference.gamma' = 'i1.pin_n.reference.gamma';
    'i1.omega' = der('i1.pin_p.reference.gamma');
    annotation(experiment(StopTime = 1));
  end 'Transformer';
end 'Transformer';
