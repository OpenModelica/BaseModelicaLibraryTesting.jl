    Real 'idealTransformer.arg_i1'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current i1";
    Real 'idealTransformer.P1'(unit = "W", quantity = "Power") "Active power, side 1";
    Real 'idealTransformer.Q1'(unit = "var", quantity = "Power") "Reactive power, side 1";
    Real 'idealTransformer.S1'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power, side 1";
    Real 'idealTransformer.pf1' "Power factor, side 1";
