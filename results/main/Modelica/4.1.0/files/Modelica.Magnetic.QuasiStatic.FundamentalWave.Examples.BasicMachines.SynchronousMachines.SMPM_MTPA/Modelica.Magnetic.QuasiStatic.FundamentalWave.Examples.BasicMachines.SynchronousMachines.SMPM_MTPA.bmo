    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[2].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[2].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'starMQS.plugToPins_p.plugToPin_p[3].plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    Real 'starMQS.plugToPins_p.plugToPin_p[3].pin_p.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
