//! base 0.1.0
package 'SMPM_MTPA'
  function 'Modelica.Electrical.QuasiStatic.Polyphase.Functions.quasiRMS' "Overall quasi-RMS value of complex input (current or voltage)"
    input 'Complex'[:] 'u';
    output Real 'y';
    Integer 'm' = size('u', 1);
  algorithm
    'y' := sum(sqrt('u['k']'.'re' ^ 2.0 + 'u['k']'.'im' ^ 2.0) for 'k' in 1:'m') / 'm';
    annotation(Inline = true);
  end 'Modelica.Electrical.QuasiStatic.Polyphase.Functions.quasiRMS';

  function 'Modelica.Math.wrapAngle' "Wrap angle to interval ]-pi,pi] or [0,2*pi["
    input Real 'u'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    input Boolean 'positiveRange' = false;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
  algorithm
    'y' := mod('u', 6.283185307179586);

    if 'y' > 3.141592653589793 and not 'positiveRange' then
      'y' := 'y' - 6.283185307179586;
    end if;
  end 'Modelica.Math.wrapAngle';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  record 'Modelica.Units.SI.ComplexVoltage'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexVoltage';

  record 'Modelica.Units.SI.ComplexCurrent'
    Real 're';
    Real 'im';
  end 'Modelica.Units.SI.ComplexCurrent';

  record 'Modelica.ComplexBlocks.Interfaces.ComplexInput'
    Real 're';
    Real 'im';
  end 'Modelica.ComplexBlocks.Interfaces.ComplexInput';

  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  model 'SMPM_MTPA' "Test example: PermanentMagnetSynchronousMachine, investigating maximum torque per Amps"
    parameter Integer 'm' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'VNominal'(unit = "V", quantity = "ElectricPotential") = 100.0 "Nominal RMS voltage per phase";
    parameter Real 'fNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Actual frequency";
    parameter Real 'tRamp'(unit = "s", quantity = "Time") = 1.0 "Frequency ramp";
    parameter Real 'TLoad'(unit = "N.m", quantity = "Torque") = 181.4 "Nominal load torque";
    parameter Real 'tStep'(unit = "s", quantity = "Time") = 1.2 "Time of load torque step";
    parameter Real 'JLoad'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Load's moment of inertia";
    parameter Real 'wNominal'(unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Nominal angular velocity";
    parameter Boolean 'positiveRange' = false "Use positive range of angles, if true";
    output Real 'theta'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Rotor displacement angle, quasi-static";
    output Real 'phi_i'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of current";
    output Real 'phi_v'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of voltage";
    output Real 'phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between voltage and current";
    output Real 'epsilon'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Current angle";
    parameter Integer 'smpmData.m' = 3 "Number of phases" annotation(Evaluate = true);
    parameter Real 'smpmData.Jr'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor's moment of inertia";
    parameter Real 'smpmData.Js'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator's moment of inertia";
    parameter Integer 'smpmData.p'(min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'smpmData.fsNominal'(unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'smpmData.Rs'(unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'smpmData.TsRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 373.15 "Reference temperature of stator resistance";
    parameter Real 'smpmData.alpha20s'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'smpmData.effectiveStatorTurns' = 64.0 "Effective number of stator turns";
    parameter Real 'smpmData.Lszero'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator zero sequence inductance";
    parameter Real 'smpmData.Lssigma'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'smpmData.ratioCommonStatorLeakage'(max = 1.0, min = 0.0) = 1.0 "Ratio of common stray inductance / total stray inductance of stator winding";
    parameter Real 'smpmData.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smpmData.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smpmData.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smpmData.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smpmData.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smpmData.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smpmData.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'smpmData.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'smpmData.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'smpmData.statorCoreParameters.VRef'(min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'smpmData.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'smpmData.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'smpmData.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'smpmData.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'smpmData.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'smpmData.strayLoadParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'smpmData.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpmData.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'smpmData.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    parameter Real 'smpmData.Lmd'(unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator main field inductance per phase in d-axis";
    parameter Real 'smpmData.Lmq'(unit = "H", quantity = "Inductance") = 9.549296585513719e-4 "Stator main field inductance per phase in q-axis";
    parameter Boolean 'smpmData.useDamperCage' = false "Enable / disable damper cage" annotation(Evaluate = true);
    parameter Real 'smpmData.Lrsigmad'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance in d-axis";
    parameter Real 'smpmData.Lrsigmaq'(unit = "H", quantity = "Inductance") = 1.5915494309189535e-4 "Damper stray inductance in q-axis";
    parameter Real 'smpmData.Rrd'(unit = "Ohm", quantity = "Resistance") = 0.04 "Damper resistance in d-axis at TRef";
    parameter Real 'smpmData.Rrq'(unit = "Ohm", quantity = "Resistance") = 0.04 "Damper resistance in q-axis at TRef";
    parameter Real 'smpmData.TrRef'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature of damper resistances in d- and q-axis";
    parameter Real 'smpmData.alpha20r'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of damper resistances in d- and q-axis";
    parameter Real 'smpmData.VsOpenCircuit'(unit = "V", quantity = "ElectricPotential") = 112.3 "Open circuit RMS voltage per phase @ fsNominal";
    parameter Real 'smpmData.permanentMagnetLossParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference permanent magnet losses at IRef and wRef";
    parameter Real 'smpmData.permanentMagnetLossParameters.c'(max = 1.0, min = 0.0) = 0.0 "Part of permanent magnet losses at current = 0, i.e. independent of current";
    parameter Real 'smpmData.permanentMagnetLossParameters.IRef'(min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference stator RMS current that PRef refers to";
    parameter Real 'smpmData.permanentMagnetLossParameters.power_I'(min = 2.2250738585072014e-308) = 2.0 "Exponent of permanent magnet loss torque w.r.t. stator current";
    parameter Real 'smpmData.permanentMagnetLossParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpmData.permanentMagnetLossParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of permanent magnet loss torque w.r.t. angular velocity";
    parameter Real 'smpmData.permanentMagnetLossParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference permanent magnet loss torque at reference angular velocity and reference current";
    constant Real 'smpmQS.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    parameter Integer 'smpmQS.m'(min = 3) = 3 "Number of stator phases" annotation(Evaluate = true);
    parameter Real 'smpmQS.Jr'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Rotor inertia";
    parameter Boolean 'smpmQS.useSupport' = false "Enable / disable (=fixed stator) support" annotation(Evaluate = true);
    parameter Real 'smpmQS.Js'(start = 0.29, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Stator inertia";
    parameter Boolean 'smpmQS.useThermalPort' = false "Enable / disable (=fixed temperatures) thermal port" annotation(Evaluate = true);
    parameter Integer 'smpmQS.p'(start = 2, min = 1) = 2 "Number of pole pairs (Integer)";
    parameter Real 'smpmQS.fsNominal'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Nominal frequency";
    parameter Real 'smpmQS.TsOperational'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 373.15 "Operational temperature of stator resistance";
    parameter Real 'smpmQS.Rs'(start = 0.03, unit = "Ohm", quantity = "Resistance") = 0.03 "Stator resistance per phase at TRef";
    parameter Real 'smpmQS.TsRef'(nominal = 300.0, start = 293.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 373.15 "Reference temperature of stator resistance";
    parameter Real 'smpmQS.alpha20s'(start = 0.0, unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of stator resistance at 20 degC";
    parameter Real 'smpmQS.effectiveStatorTurns' = 64.0 "Effective number of stator turns";
    parameter Real 'smpmQS.Lssigma'(start = 3.183098861837907e-4, unit = "H", quantity = "Inductance") = 3.183098861837907e-4 "Stator stray inductance per phase";
    parameter Real 'smpmQS.L0.d'(start = 1.0, unit = "H", quantity = "Inductance") = 5.1808249704393016e-8 "Component of d (direct) axis, aligned to real part";
    parameter Real 'smpmQS.L0.q'(start = 1.0, unit = "H", quantity = "Inductance") = 1.5542474911317903e-7 "Component of q (quadrature) axis, aligned to imaginary part";
    parameter Real 'smpmQS.frictionParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference friction losses at wRef";
    parameter Real 'smpmQS.frictionParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that the PRef refer to";
    parameter Real 'smpmQS.frictionParameters.power_w'(min = 2.2250738585072014e-308) = 2.0 "Exponent of friction torque w.r.t. angular velocity";
    parameter Real 'smpmQS.frictionParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference friction torque at reference angular velocity";
    parameter Real 'smpmQS.frictionParameters.linear' = 0.001 "Linear angular velocity range with respect to reference angular velocity";
    parameter Real 'smpmQS.frictionParameters.wLinear'(unit = "rad/s", quantity = "AngularVelocity") = 0.15707963267948966 "Linear angular velocity range";
    parameter Real 'smpmQS.frictionParameters.tauLinear'(unit = "N.m", quantity = "Torque") = 0.0 "Torque corresponding with linear angular velocity range";
    parameter Integer 'smpmQS.statorCoreParameters.m' = 3 "Number of phases (1 for DC, 3 for induction machines)";
    parameter Real 'smpmQS.statorCoreParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference core losses at reference inner voltage VRef";
    parameter Real 'smpmQS.statorCoreParameters.VRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "V", quantity = "ElectricPotential") = 100.0 "Reference inner RMS voltage that reference core losses PRef refer to";
    parameter Real 'smpmQS.statorCoreParameters.wRef'(min = 2.2250738585072014e-308, unit = "rad/s", quantity = "AngularVelocity") = 314.1592653589793 "Reference angular velocity that reference core losses PRef refer to";
    parameter Real 'smpmQS.statorCoreParameters.ratioHysteresis'(start = 0.775, max = 1.0, min = 0.0) = 0.0 "Ratio of hysteresis losses with respect to the total core losses at VRef and fRef";
    parameter Real 'smpmQS.statorCoreParameters.GcRef'(unit = "S", quantity = "Conductance") = 0.0 "Reference conductance at reference frequency and voltage";
    parameter Real 'smpmQS.statorCoreParameters.wMin'(unit = "rad/s", quantity = "AngularVelocity") = 3.141592653589793e-4 "Angular velocity limit";
    parameter Real 'smpmQS.strayLoadParameters.PRef'(min = 0.0, unit = "W", quantity = "Power") = 0.0 "Reference stray load losses at IRef and wRef";
    parameter Real 'smpmQS.strayLoadParameters.IRef'(start = 100.0, min = 2.2250738585072014e-308, unit = "A", quantity = "ElectricCurrent") = 100.0 "Reference RMS current that PRef refers to";
    parameter Real 'smpmQS.strayLoadParameters.wRef'(min = 2.2250738585072014e-308, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") = 157.07963267948966 "Reference angular velocity that PRef refers to";
    parameter Real 'smpmQS.strayLoadParameters.power_w'(min = 2.2250738585072014e-308) = 1.0 "Exponent of stray load loss torque w.r.t. angular velocity";
    parameter Real 'smpmQS.strayLoadParameters.tauRef'(unit = "N.m", quantity = "Torque") = 0.0 "Reference stray load torque at reference angular velocity and reference current";
    Real 'smpmQS.gammas'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of stator reference frame";
    Real 'smpmQS.gammar'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of stator reference frame";
    Real 'smpmQS.gamma'(start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Electrical angle between stator and rotor";
    Real 'smpmQS.phiMechanical'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Mechanical angle of rotor against stator";
    Real 'smpmQS.wMechanical'(start = 0.0, displayUnit = "rev/min", unit = "rad/s", quantity = "AngularVelocity") "Mechanical angular velocity of rotor against stator";
    Real 'smpmQS.tauElectrical'(unit = "N.m", quantity = "Torque") "Electromagnetic torque";
    Real 'smpmQS.tauShaft'(unit = "N.m", quantity = "Torque") "Shaft torque";
    Real 'smpmQS.powerBalance.powerStator'(unit = "W", quantity = "Power") "Electrical power (stator)";
    Real 'smpmQS.powerBalance.powerMechanical'(unit = "W", quantity = "Power") "Mechanical power";
    Real 'smpmQS.powerBalance.powerInertiaStator'(unit = "W", quantity = "Power") "Stator inertia power";
    Real 'smpmQS.powerBalance.powerInertiaRotor'(unit = "W", quantity = "Power") "Rotor inertia power";
    Real 'smpmQS.powerBalance.lossPowerTotal'(unit = "W", quantity = "Power") "Total loss power";
    Real 'smpmQS.powerBalance.lossPowerStatorWinding'(unit = "W", quantity = "Power") "Stator copper losses";
    Real 'smpmQS.powerBalance.lossPowerStatorCore'(unit = "W", quantity = "Power") "Stator core losses";
    Real 'smpmQS.powerBalance.lossPowerRotorCore'(unit = "W", quantity = "Power") "Rotor core losses";
    Real 'smpmQS.powerBalance.lossPowerStrayLoad'(unit = "W", quantity = "Power") "Stray load losses";
    Real 'smpmQS.powerBalance.lossPowerFriction'(unit = "W", quantity = "Power") "Friction losses";
    Real 'smpmQS.powerBalance.lossPowerRotorWinding'(unit = "W", quantity = "Power") "Rotor copper losses";
    Real 'smpmQS.powerBalance.lossPowerPermanentMagnet'(unit = "W", quantity = "Power") "Permanent magnet losses";
    Real 'smpmQS.vs[1].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'smpmQS.vs[1].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'smpmQS.vs[2].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'smpmQS.vs[2].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'smpmQS.vs[3].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'smpmQS.vs[3].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'smpmQS.abs_vs[1]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'smpmQS.abs_vs[2]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'smpmQS.abs_vs[3]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex stator voltage";
    Real 'smpmQS.arg_vs[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'smpmQS.arg_vs[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'smpmQS.arg_vs[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator voltage";
    Real 'smpmQS.is[1].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'smpmQS.is[1].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'smpmQS.is[2].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'smpmQS.is[2].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'smpmQS.is[3].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'smpmQS.is[3].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'smpmQS.abs_is[1]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'smpmQS.abs_is[2]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'smpmQS.abs_is[3]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex stator current";
    Real 'smpmQS.arg_is[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'smpmQS.arg_is[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'smpmQS.arg_is[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex stator current";
    Real 'smpmQS.Ps[1]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'smpmQS.Ps[2]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'smpmQS.Ps[3]'(unit = "W", quantity = "Power") "Active stator power";
    Real 'smpmQS.Ps_total'(unit = "W", quantity = "Power") "Total active stator power";
    Real 'smpmQS.Qs[1]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'smpmQS.Qs[2]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'smpmQS.Qs[3]'(unit = "var", quantity = "Power") "Reactive stator power";
    Real 'smpmQS.Qs_total'(unit = "var", quantity = "Power") "Total reactive stator power";
    Real 'smpmQS.Ss[1]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'smpmQS.Ss[2]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'smpmQS.Ss[3]'(unit = "V.A", quantity = "Power") "Magnitude of complex stator apparent power";
    Real 'smpmQS.Ss_total'(unit = "V.A", quantity = "Power") "Magnitude of total complex stator apparent power";
    Real 'smpmQS.pfs[1]' "Stator power factor";
    Real 'smpmQS.pfs[2]' "Stator power factor";
    Real 'smpmQS.pfs[3]' "Stator power factor";
    Real 'smpmQS.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpmQS.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smpmQS.inertiaRotor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpmQS.inertiaRotor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'smpmQS.inertiaRotor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'smpmQS.inertiaRotor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'smpmQS.inertiaRotor.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.29 "Moment of inertia";
    parameter StateSelect 'smpmQS.inertiaRotor.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'smpmQS.inertiaRotor.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'smpmQS.inertiaRotor.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'smpmQS.inertiaRotor.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'smpmQS.inertiaStator.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
