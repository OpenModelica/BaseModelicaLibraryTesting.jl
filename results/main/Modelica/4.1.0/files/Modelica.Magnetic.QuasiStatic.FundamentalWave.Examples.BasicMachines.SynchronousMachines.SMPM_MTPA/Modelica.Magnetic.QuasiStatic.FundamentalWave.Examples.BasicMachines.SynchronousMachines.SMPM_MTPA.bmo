    Real 'starMQS.plugToPins_p.plugToPin_p[3].pin_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Real 'rotSource.magnitude' = 100.0 "Magnitude of complex phasor";
    parameter Real 'rotSource.w'(unit = "rad/s", quantity = "AngularVelocity") = 6.283185307179586 "Constant angular velocity of complex phasor";
    parameter Real 'rotSource.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial angle of complex phasor at time = 0";
    Real 'rotSource.y.re' "Real part of complex number";
    Real 'rotSource.y.im' "Imaginary part of complex number";
    Real 'rotSource.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle";
    Real 'toReal.re';
    Real 'toReal.im';
    Real 'toReal.u.re' "Real part of complex number";
    Real 'toReal.u.im' "Imaginary part of complex number";
    parameter Boolean 'toReal.useConjugateInput' = false "If true, input is processed conjugate complex";
  equation
    'theta' = 'rotorAngleQS.rotorDisplacementAngle';
    'phi_i' = 'Modelica.Math.wrapAngle'('smpmQS.arg_is[1]', false);
    'phi_v' = 'Modelica.Math.wrapAngle'('smpmQS.arg_vs[1]', false);
    'phi' = 'Modelica.Math.wrapAngle'('phi_v' - 'phi_i', false);
    'epsilon' = 'Modelica.Math.wrapAngle'('phi' - 'theta', false);
    'smpmQS.gammas' = 'smpmQS.airGap.gammas';
    'smpmQS.gammar' = 'smpmQS.airGap.gammar';
    'smpmQS.gamma' = 'smpmQS.airGap.gamma';
    'smpmQS.phiMechanical' = 'smpmQS.flange.phi' - 'smpmQS.internalSupport.phi';
    'smpmQS.wMechanical' = der('smpmQS.phiMechanical');
    'smpmQS.tauElectrical' = 'smpmQS.inertiaRotor.flange_a.tau';
    'smpmQS.tauShaft' = -'smpmQS.flange.tau';
    'smpmQS.powerBalance.powerStator' = sum('smpmQS.vs[(1:size('smpmQS.vs', 1))['$i1834']].re' * 'smpmQS.is[(1:size('smpmQS.vs', 1))['$i1834']].re' - 'smpmQS.vs[(1:size('smpmQS.vs', 1))['$i1834']].im' * (-'smpmQS.is[(1:size('smpmQS.vs', 1))['$i1834']].im') for '$i1834' in 1:size('smpmQS.vs', 1));
    'smpmQS.powerBalance.powerMechanical' = 'smpmQS.wMechanical' * 'smpmQS.tauShaft';
    'smpmQS.powerBalance.powerInertiaStator' = 0.29 * 'smpmQS.inertiaStator.a' * 'smpmQS.inertiaStator.w';
    'smpmQS.powerBalance.powerInertiaRotor' = 0.29 * 'smpmQS.inertiaRotor.a' * 'smpmQS.inertiaRotor.w';
    'smpmQS.powerBalance.lossPowerTotal' = 'smpmQS.powerBalance.lossPowerStatorWinding' + 'smpmQS.powerBalance.lossPowerStatorCore' + 'smpmQS.powerBalance.lossPowerRotorCore' + 'smpmQS.powerBalance.lossPowerStrayLoad' + 'smpmQS.powerBalance.lossPowerFriction' + 'smpmQS.powerBalance.lossPowerRotorWinding' + 'smpmQS.powerBalance.lossPowerPermanentMagnet';
    'smpmQS.powerBalance.lossPowerStatorWinding' = 'smpmQS.stator.resistor.resistor[1].LossPower' + 'smpmQS.stator.resistor.resistor[2].LossPower' + 'smpmQS.stator.resistor.resistor[3].LossPower';
    'smpmQS.powerBalance.lossPowerStatorCore' = 'smpmQS.stator.core.lossPower';
    'smpmQS.powerBalance.lossPowerRotorCore' = 0.0;
    'smpmQS.powerBalance.lossPowerStrayLoad' = 'smpmQS.strayLoad.lossPower';
    'smpmQS.powerBalance.lossPowerFriction' = 'smpmQS.friction.lossPower';
    'smpmQS.powerBalance.lossPowerRotorWinding' = 'smpmQS.damperCageLossPower';
    'smpmQS.powerBalance.lossPowerPermanentMagnet' = 'smpmQS.permanentMagnet.lossPower';
    'smpmQS.is[1].re' = 'smpmQS.plug_sp.pin[1].i.re';
    'smpmQS.is[1].im' = 'smpmQS.plug_sp.pin[1].i.im';
    'smpmQS.is[2].re' = 'smpmQS.plug_sp.pin[2].i.re';
    'smpmQS.is[2].im' = 'smpmQS.plug_sp.pin[2].i.im';
    'smpmQS.is[3].re' = 'smpmQS.plug_sp.pin[3].i.re';
    'smpmQS.is[3].im' = 'smpmQS.plug_sp.pin[3].i.im';
    'smpmQS.Ps_total' = 'smpmQS.Ps[1]' + 'smpmQS.Ps[2]' + 'smpmQS.Ps[3]';
    'smpmQS.Qs_total' = 'smpmQS.Qs[1]' + 'smpmQS.Qs[2]' + 'smpmQS.Qs[3]';
    'smpmQS.Ss_total' = sqrt('smpmQS.Ps_total' ^ 2.0 + 'smpmQS.Qs_total' ^ 2.0);
    'smpmQS.stator.i[1].re' = 'smpmQS.stator.plug_p.pin[1].i.re';
    'smpmQS.stator.i[1].im' = 'smpmQS.stator.plug_p.pin[1].i.im';
    'smpmQS.stator.i[2].re' = 'smpmQS.stator.plug_p.pin[2].i.re';
    'smpmQS.stator.i[2].im' = 'smpmQS.stator.plug_p.pin[2].i.im';
    'smpmQS.stator.i[3].re' = 'smpmQS.stator.plug_p.pin[3].i.re';
    'smpmQS.stator.i[3].im' = 'smpmQS.stator.plug_p.pin[3].i.im';
    'smpmQS.stator.P_total' = 'smpmQS.stator.P[1]' + 'smpmQS.stator.P[2]' + 'smpmQS.stator.P[3]';
    'smpmQS.stator.Q_total' = 'smpmQS.stator.Q[1]' + 'smpmQS.stator.Q[2]' + 'smpmQS.stator.Q[3]';
    'smpmQS.stator.S_total' = sqrt('smpmQS.stator.P_total' ^ 2.0 + 'smpmQS.stator.Q_total' ^ 2.0);
    'smpmQS.stator.abs_V_m' = sqrt('smpmQS.stator.V_m.re' ^ 2.0 + 'smpmQS.stator.V_m.im' ^ 2.0);
    'smpmQS.stator.arg_V_m' = 'Modelica.Math.atan3'('smpmQS.stator.V_m.im', 'smpmQS.stator.V_m.re', 0.0);
    'smpmQS.stator.Phi.re' = 'smpmQS.stator.port_p.Phi.re';
    'smpmQS.stator.Phi.im' = 'smpmQS.stator.port_p.Phi.im';
    'smpmQS.stator.abs_Phi' = sqrt('smpmQS.stator.Phi.re' ^ 2.0 + 'smpmQS.stator.Phi.im' ^ 2.0);
    'smpmQS.stator.arg_Phi' = 'Modelica.Math.atan3'('smpmQS.stator.Phi.im', 'smpmQS.stator.Phi.re', 0.0);
    'smpmQS.stator.electroMagneticConverter.P_total' = 'smpmQS.stator.electroMagneticConverter.P[1]' + 'smpmQS.stator.electroMagneticConverter.P[2]' + 'smpmQS.stator.electroMagneticConverter.P[3]';
    'smpmQS.stator.electroMagneticConverter.Q_total' = 'smpmQS.stator.electroMagneticConverter.Q[1]' + 'smpmQS.stator.electroMagneticConverter.Q[2]' + 'smpmQS.stator.electroMagneticConverter.Q[3]';
    'smpmQS.stator.electroMagneticConverter.S_total' = sqrt('smpmQS.stator.electroMagneticConverter.P_total' ^ 2.0 + 'smpmQS.stator.electroMagneticConverter.Q_total' ^ 2.0);
    'smpmQS.stator.electroMagneticConverter.abs_V_m' = sqrt('smpmQS.stator.electroMagneticConverter.V_m.re' ^ 2.0 + 'smpmQS.stator.electroMagneticConverter.V_m.im' ^ 2.0);
    'smpmQS.stator.electroMagneticConverter.arg_V_m' = 'Modelica.Math.atan3'('smpmQS.stator.electroMagneticConverter.V_m.im', 'smpmQS.stator.electroMagneticConverter.V_m.re', 0.0);
    'smpmQS.stator.electroMagneticConverter.abs_Phi' = sqrt('smpmQS.stator.electroMagneticConverter.Phi.re' ^ 2.0 + 'smpmQS.stator.electroMagneticConverter.Phi.im' ^ 2.0);
    'smpmQS.stator.electroMagneticConverter.arg_Phi' = 'Modelica.Math.atan3'('smpmQS.stator.electroMagneticConverter.Phi.im', 'smpmQS.stator.electroMagneticConverter.Phi.re', 0.0);
    'smpmQS.stator.electroMagneticConverter.omega' = der('smpmQS.stator.electroMagneticConverter.port_p.reference.gamma');
    'smpmQS.stator.resistor.P_total' = 'smpmQS.stator.resistor.P[1]' + 'smpmQS.stator.resistor.P[2]' + 'smpmQS.stator.resistor.P[3]';
    'smpmQS.stator.resistor.Q_total' = 'smpmQS.stator.resistor.Q[1]' + 'smpmQS.stator.resistor.Q[2]' + 'smpmQS.stator.resistor.Q[3]';
    'smpmQS.stator.resistor.S_total' = sqrt('smpmQS.stator.resistor.P_total' ^ 2.0 + 'smpmQS.stator.resistor.Q_total' ^ 2.0);
    'smpmQS.stator.resistor.resistor[1].abs_v' = sqrt('smpmQS.stator.resistor.resistor[1].v.re' ^ 2.0 + 'smpmQS.stator.resistor.resistor[1].v.im' ^ 2.0);
    'smpmQS.stator.resistor.resistor[1].arg_v' = 'Modelica.Math.atan3'('smpmQS.stator.resistor.resistor[1].v.im', 'smpmQS.stator.resistor.resistor[1].v.re', 0.0);
    'smpmQS.stator.resistor.resistor[1].abs_i' = sqrt('smpmQS.stator.resistor.resistor[1].i.re' ^ 2.0 + 'smpmQS.stator.resistor.resistor[1].i.im' ^ 2.0);
    'smpmQS.stator.resistor.resistor[1].arg_i' = 'Modelica.Math.atan3'('smpmQS.stator.resistor.resistor[1].i.im', 'smpmQS.stator.resistor.resistor[1].i.re', 0.0);
    'smpmQS.stator.resistor.resistor[1].P' = 'smpmQS.stator.resistor.resistor[1].v.re' * 'smpmQS.stator.resistor.resistor[1].i.re' - 'smpmQS.stator.resistor.resistor[1].v.im' * (-'smpmQS.stator.resistor.resistor[1].i.im');
    'smpmQS.stator.resistor.resistor[1].Q' = 'smpmQS.stator.resistor.resistor[1].v.re' * (-'smpmQS.stator.resistor.resistor[1].i.im') + 'smpmQS.stator.resistor.resistor[1].v.im' * 'smpmQS.stator.resistor.resistor[1].i.re';
    'smpmQS.stator.resistor.resistor[1].S' = sqrt(('smpmQS.stator.resistor.resistor[1].v.re' * 'smpmQS.stator.resistor.resistor[1].i.re' - 'smpmQS.stator.resistor.resistor[1].v.im' * (-'smpmQS.stator.resistor.resistor[1].i.im')) ^ 2.0 + ('smpmQS.stator.resistor.resistor[1].v.re' * (-'smpmQS.stator.resistor.resistor[1].i.im') + 'smpmQS.stator.resistor.resistor[1].v.im' * 'smpmQS.stator.resistor.resistor[1].i.re') ^ 2.0);
    'smpmQS.stator.resistor.resistor[1].pf' = cos('Modelica.Math.atan3'('smpmQS.stator.resistor.resistor[1].Q', 'smpmQS.stator.resistor.resistor[1].P', 0.0));
    'smpmQS.stator.resistor.resistor[1].heatPort.T' = 'smpmQS.stator.resistor.resistor[1].T_heatPort';
    'smpmQS.stator.resistor.resistor[1].heatPort.Q_flow' = -'smpmQS.stator.resistor.resistor[1].LossPower';
    'smpmQS.stator.resistor.resistor[2].abs_v' = sqrt('smpmQS.stator.resistor.resistor[2].v.re' ^ 2.0 + 'smpmQS.stator.resistor.resistor[2].v.im' ^ 2.0);
    'smpmQS.stator.resistor.resistor[2].arg_v' = 'Modelica.Math.atan3'('smpmQS.stator.resistor.resistor[2].v.im', 'smpmQS.stator.resistor.resistor[2].v.re', 0.0);
    'smpmQS.stator.resistor.resistor[2].abs_i' = sqrt('smpmQS.stator.resistor.resistor[2].i.re' ^ 2.0 + 'smpmQS.stator.resistor.resistor[2].i.im' ^ 2.0);
    'smpmQS.stator.resistor.resistor[2].arg_i' = 'Modelica.Math.atan3'('smpmQS.stator.resistor.resistor[2].i.im', 'smpmQS.stator.resistor.resistor[2].i.re', 0.0);
    'smpmQS.stator.resistor.resistor[2].P' = 'smpmQS.stator.resistor.resistor[2].v.re' * 'smpmQS.stator.resistor.resistor[2].i.re' - 'smpmQS.stator.resistor.resistor[2].v.im' * (-'smpmQS.stator.resistor.resistor[2].i.im');
    'smpmQS.stator.resistor.resistor[2].Q' = 'smpmQS.stator.resistor.resistor[2].v.re' * (-'smpmQS.stator.resistor.resistor[2].i.im') + 'smpmQS.stator.resistor.resistor[2].v.im' * 'smpmQS.stator.resistor.resistor[2].i.re';
    'smpmQS.stator.resistor.resistor[2].S' = sqrt(('smpmQS.stator.resistor.resistor[2].v.re' * 'smpmQS.stator.resistor.resistor[2].i.re' - 'smpmQS.stator.resistor.resistor[2].v.im' * (-'smpmQS.stator.resistor.resistor[2].i.im')) ^ 2.0 + ('smpmQS.stator.resistor.resistor[2].v.re' * (-'smpmQS.stator.resistor.resistor[2].i.im') + 'smpmQS.stator.resistor.resistor[2].v.im' * 'smpmQS.stator.resistor.resistor[2].i.re') ^ 2.0);
    'smpmQS.stator.resistor.resistor[2].pf' = cos('Modelica.Math.atan3'('smpmQS.stator.resistor.resistor[2].Q', 'smpmQS.stator.resistor.resistor[2].P', 0.0));
    'smpmQS.stator.resistor.resistor[2].heatPort.T' = 'smpmQS.stator.resistor.resistor[2].T_heatPort';
    'smpmQS.stator.resistor.resistor[2].heatPort.Q_flow' = -'smpmQS.stator.resistor.resistor[2].LossPower';
    'smpmQS.stator.resistor.resistor[3].abs_v' = sqrt('smpmQS.stator.resistor.resistor[3].v.re' ^ 2.0 + 'smpmQS.stator.resistor.resistor[3].v.im' ^ 2.0);
    'smpmQS.stator.resistor.resistor[3].arg_v' = 'Modelica.Math.atan3'('smpmQS.stator.resistor.resistor[3].v.im', 'smpmQS.stator.resistor.resistor[3].v.re', 0.0);
    'smpmQS.stator.resistor.resistor[3].abs_i' = sqrt('smpmQS.stator.resistor.resistor[3].i.re' ^ 2.0 + 'smpmQS.stator.resistor.resistor[3].i.im' ^ 2.0);
    'smpmQS.stator.resistor.resistor[3].arg_i' = 'Modelica.Math.atan3'('smpmQS.stator.resistor.resistor[3].i.im', 'smpmQS.stator.resistor.resistor[3].i.re', 0.0);
