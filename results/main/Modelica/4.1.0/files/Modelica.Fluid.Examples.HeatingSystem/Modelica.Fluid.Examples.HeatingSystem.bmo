    Real 'heater.port_a.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'heater.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") "Mass flow rate from the connection point into the component";
    Real 'heater.port_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'heater.port_b.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    parameter Boolean 'heater.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'heater.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'heater.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
