    parameter Integer 'pipe.nFMDistributed' = 1 "Number of distributed flow models";
    parameter Integer 'pipe.nFMLumped' = 1 "Number of lumped flow models";
    parameter Integer 'pipe.iLumped' = 2 "Index of control volume with representative state if useLumpedPressure" annotation(Evaluate = true);
    parameter Boolean 'pipe.useInnerPortProperties' = false "= true to take port properties for flow models from internal control volumes" annotation(Evaluate = true);
    Real 'pipe.state_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.state_a.T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.state_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.state_b.T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.statesFM[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.statesFM[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.statesFM[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.statesFM[2].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    parameter Boolean 'pipe.flowModel.from_dp' = true "= true, use m_flow = f(dp), otherwise dp = f(m_flow)" annotation(Evaluate = true);
    parameter Integer 'pipe.flowModel.n' = 2 "Number of discrete flow volumes";
    Real 'pipe.flowModel.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.flowModel.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.flowModel.states[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.flowModel.states[2].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.flowModel.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    Real 'pipe.flowModel.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow";
    parameter Real 'pipe.flowModel.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'pipe.flowModel.crossAreas[1]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe.flowModel.crossAreas[2]'(unit = "m2", quantity = "Area") "Cross flow areas at segment boundaries";
    Real 'pipe.flowModel.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe.flowModel.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameters for pipe flow)";
    Real 'pipe.flowModel.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe.flowModel.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average height of surface asperities";
    Real 'pipe.flowModel.dheights[1]'(unit = "m", quantity = "Length") "Height(states[2:n]) - Height(states[1:n-1])";
    parameter Real 'pipe.flowModel.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'pipe.flowModel.allowFlowReversal' = true "= true, if flow reversal is enabled, otherwise restrict flow to design direction (states[1] -> states[n+1])" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'pipe.flowModel.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyState' "Formulation of momentum balance" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") = 0.0 "Start value of mass flow rates";
    parameter Real 'pipe.flowModel.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.3e5 "Start value for p[1] at design inflow";
    parameter Real 'pipe.flowModel.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.3e5 "Start value for p[n+1] at design outflow";
    parameter Integer 'pipe.flowModel.m' = 1 "Number of flow segments";
    Real 'pipe.flowModel.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe.flowModel.m_flows[1]'(stateSelect = StateSelect.default, start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") "Mass flow rates between states";
    Real 'pipe.flowModel.Is[1]'(unit = "kg.m/s", quantity = "Momentum") "Momenta of flow segments";
    Real 'pipe.flowModel.Ib_flows[1]'(unit = "N", quantity = "Force") "Flow of momentum across boundaries";
    Real 'pipe.flowModel.Fs_p[1]'(unit = "N", quantity = "Force") "Pressure forces";
    Real 'pipe.flowModel.Fs_fg[1]'(unit = "N", quantity = "Force") "Friction and gravity forces";
    parameter Boolean 'pipe.flowModel.useUpstreamScheme' = true "= false to average upstream and downstream properties across flow segments" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.use_Ib_flows' = false "= true to consider differences in flow of momentum through boundaries" annotation(Evaluate = true);
    Real 'pipe.flowModel.rhos[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe.flowModel.rhos[2]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density");
    Real 'pipe.flowModel.rhos_act[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
    Real 'pipe.flowModel.mus[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe.flowModel.mus[2]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity");
    Real 'pipe.flowModel.mus_act[1]'(nominal = 0.001, start = 0.001, max = 1e8, min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") "Actual viscosity per segment";
    Real 'pipe.flowModel.dps_fg[1]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    parameter Real 'pipe.flowModel.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0 "Start of turbulent regime, depending on type of flow device";
    parameter Boolean 'pipe.flowModel.show_Res' = false "= true, if Reynolds numbers are included for plotting" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.use_rho_nominal' = false "= true, if rho_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.rho_nominal'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 998.3298937621773 "Nominal density (e.g., rho_liquidWater = 995, rho_air = 1.2)";
    parameter Boolean 'pipe.flowModel.use_mu_nominal' = false "= true, if mu_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'pipe.flowModel.mu_nominal'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") = 8.9e-4 "Nominal dynamic viscosity (e.g., mu_liquidWater = 1e-3, mu_air = 1.8e-5)";
    Real 'pipe.flowModel.pathLengths_internal[1]'(unit = "m", quantity = "Length") "pathLengths used internally; to be defined by extending class";
    Real 'pipe.flowModel.Res_turbulent_internal[1]'(unit = "1", quantity = "ReynoldsNumber") "Re_turbulent used internally; to be defined by extending class";
    parameter Real 'pipe.flowModel.dp_nominal'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Nominal pressure loss (only for nominal models)";
    parameter Real 'pipe.flowModel.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 100.0 * 'pipe.flowModel.m_flow_small' "Nominal mass flow rate";
    parameter Real 'pipe.flowModel.m_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 1e-4 "Within regularization if |m_flows| < m_flow_small (may be wider for large discontinuities in static head)";
    parameter Real 'pipe.flowModel.dp_small'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Within regularization if |dp| < dp_small (may be wider for large discontinuities in static head)";
    parameter Boolean 'pipe.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'pipe.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'pipe.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'pipe.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure loss for nominal conditions";
    Real 'pipe.m_flows[1]'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") "Mass flow rates of fluid across segment boundaries";
    Real 'pipe.m_flows[2]'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") "Mass flow rates of fluid across segment boundaries";
    Real 'pipe.m_flows[3]'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") "Mass flow rates of fluid across segment boundaries";
    Real 'pipe.H_flows[1]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates of fluid across segment boundaries";
    Real 'pipe.H_flows[2]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates of fluid across segment boundaries";
    Real 'pipe.H_flows[3]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates of fluid across segment boundaries";
    Real 'pipe.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'pipe.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'pipe.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe.dheightsFM[1]'(unit = "m", quantity = "Length") "Differences in heights between flow segments";
    Real 'pipe.crossAreasFM[1]'(unit = "m2", quantity = "Area") "Cross flow areas of flow segments";
    Real 'pipe.crossAreasFM[2]'(unit = "m2", quantity = "Area") "Cross flow areas of flow segments";
    Real 'pipe.vsFM[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'pipe.vsFM[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'pipe.dimensionsFM[1]'(unit = "m", quantity = "Length") "Hydraulic diameters of flow segments";
    Real 'pipe.dimensionsFM[2]'(unit = "m", quantity = "Length") "Hydraulic diameters of flow segments";
    Real 'pipe.roughnessesFM[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
    Real 'pipe.roughnessesFM[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
    parameter Boolean 'pipe.use_HeatTransfer' = false "= true to use the HeatTransfer model";
    parameter Integer 'pipe.heatTransfer.n' = 2 "Number of heat transfer segments" annotation(Evaluate = true);
    Real 'pipe.heatTransfer.states[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.heatTransfer.states[1].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.heatTransfer.states[2].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'pipe.heatTransfer.states[2].T'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'pipe.heatTransfer.surfaceAreas[1]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'pipe.heatTransfer.surfaceAreas[2]'(unit = "m2", quantity = "Area") "Heat transfer areas";
    Real 'pipe.heatTransfer.Q_flows[1]'(unit = "W", quantity = "Power") "Heat flow rates";
    Real 'pipe.heatTransfer.Q_flows[2]'(unit = "W", quantity = "Power") "Heat flow rates";
    parameter Boolean 'pipe.heatTransfer.use_k' = false "= true to use k value for thermal isolation";
    parameter Real 'pipe.heatTransfer.k'(unit = "W/(m2.K)", quantity = "CoefficientOfHeatTransfer") = 0.0 "Heat transfer coefficient to ambient" annotation(Evaluate = true);
    parameter Real 'pipe.heatTransfer.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Ambient temperature";
    Real 'pipe.heatTransfer.heatPorts[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'pipe.heatTransfer.heatPorts[1].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'pipe.heatTransfer.heatPorts[2].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'pipe.heatTransfer.heatPorts[2].Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'pipe.heatTransfer.Ts[1]'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    Real 'pipe.heatTransfer.Ts[2]'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperatures defined by fluid states";
    Real 'pipe.heatTransfer.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow in segments";
    Real 'pipe.heatTransfer.vs[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities of fluid flow in segments";
    parameter Real 'pipe.heatTransfer.nParallel' = 1.0 "Number of identical parallel flow devices";
    Real 'pipe.heatTransfer.lengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe.heatTransfer.lengths[2]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'pipe.heatTransfer.dimensions[1]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameter for pipe flow)";
    Real 'pipe.heatTransfer.dimensions[2]'(unit = "m", quantity = "Length") "Characteristic dimensions for fluid flow (diameter for pipe flow)";
    Real 'pipe.heatTransfer.roughnesses[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
    Real 'pipe.heatTransfer.roughnesses[2]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
    parameter Real 'pipe.dxs[1]' = 0.5 "Normalized lengths";
    parameter Real 'pipe.dxs[2]' = 0.5 "Normalized lengths";
  initial equation
    'tank.level' = 1.0;
    der('tank.medium.T') = 0.0;
    0.01 = 'valve.Av' * 31.596358868739564 * 99.99999975 "Determination of Av by the operating point";
    'heater.flowModel.dp_nominal' = 1000.0 * 'heater.flowModel.dp_small';
    'heater.flowModel.dp_small' = 1.0;
    der('heater.mediums[1].T') = 0.0;
    der('heater.mediums[1].p') = 0.0;
    'radiator.flowModel.dp_nominal' = 1000.0 * 'radiator.flowModel.dp_small';
    'radiator.flowModel.dp_small' = 1.0;
    der('radiator.mediums[1].T') = 0.0;
    der('radiator.mediums[1].p') = 0.0;
    'pipe.flowModel.dp_nominal' = 1000.0 * 'pipe.flowModel.dp_small';
    'pipe.flowModel.dp_small' = 1.0;
    der('pipe.mediums[1].T') = 0.0;
    der('pipe.mediums[2].T') = 0.0;
    der('pipe.mediums[1].p') = 0.0;
    der('pipe.mediums[2].p') = 0.0;
  equation
    'tank.fluidVolume' = 'tank.V';
    'tank.medium.T_degC' = 'tank.medium.T' - 273.15;
    'tank.medium.p_bar' = 'tank.medium.p' / 1e5;
    'tank.heatTransfer.states[1].p' = 'tank.medium.state.p';
    'tank.heatTransfer.states[1].T' = 'tank.medium.state.T';
    'tank.fluidLevel' = 'tank.level';
    'pump.fluidVolume' = 0.0;
    'pump.medium.T_degC' = 'pump.medium.T' - 273.15;
    'pump.medium.p_bar' = 'pump.medium.p' / 1e5;
    'pump.heatTransfer.states[1].p' = 'pump.medium.state.p';
    'pump.heatTransfer.states[1].T' = 'pump.medium.state.T';
    'pump.rho' = 'pump.medium.d';
    'pump.dp_pump' = 'pump.port_b.p' - 'pump.port_a.p';
    'pump.head' = 'pump.dp_pump' / ('pump.rho' * 9.80665);
    'pump.m_flow' = 'pump.port_a.m_flow';
    'pump.m_flow_single' = 'pump.m_flow';
    'pump.W_total' = 'pump.W_single';
    'pump.monitoring.state.p' = 'pump.medium.state.p';
    'pump.monitoring.state.T' = 'pump.medium.state.T';
    'valve.V_flow' = 'valve.m_flow' / smooth(1, if 'valve.m_flow' > 1e-4 then (1.0 + ('valve.state_a.p' - 101325.0) * 4.5154260364919865e-10 - ('valve.state_a.T' - 298.15) * 2.571314017648316e-4) * 997.0480319717385 else if 'valve.m_flow' < (-1e-4) then (1.0 + ('valve.state_b.p' - 101325.0) * 4.5154260364919865e-10 - ('valve.state_b.T' - 298.15) * 2.571314017648316e-4) * 997.0480319717385 else if 1e-4 > 0.0 then 'valve.m_flow' / 1e-4 * (('valve.m_flow' / 1e-4) ^ 2.0 - 3.0) * ((1.0 + ('valve.state_b.p' - 101325.0) * 4.5154260364919865e-10 - ('valve.state_b.T' - 298.15) * 2.571314017648316e-4) * 997.0480319717385 - (1.0 + ('valve.state_a.p' - 101325.0) * 4.5154260364919865e-10 - ('valve.state_a.T' - 298.15) * 2.571314017648316e-4) * 997.0480319717385) / 4.0 + ((1.0 + ('valve.state_a.p' - 101325.0) * 4.5154260364919865e-10 - ('valve.state_a.T' - 298.15) * 2.571314017648316e-4) * 997.0480319717385 + (1.0 + ('valve.state_b.p' - 101325.0) * 4.5154260364919865e-10 - ('valve.state_b.T' - 298.15) * 2.571314017648316e-4) * 997.0480319717385) / 2.0 else ((1.0 + ('valve.state_a.p' - 101325.0) * 4.5154260364919865e-10 - ('valve.state_a.T' - 298.15) * 2.571314017648316e-4) * 997.0480319717385 + (1.0 + ('valve.state_b.p' - 101325.0) * 4.5154260364919865e-10 - ('valve.state_b.T' - 298.15) * 2.571314017648316e-4) * 997.0480319717385) / 2.0);
    'valve.port_a_T' = smooth(1, if 'valve.port_a.m_flow' > 1e-4 then 'valve.state_a.T' else if 'valve.port_a.m_flow' < (-1e-4) then ('valve.port_a.h_outflow' - 104929.29464256502 - ('valve.port_a.p' - 101325.0) * 9.260700016004721e-4) / 4181.885502948851 + 298.15 else if 1e-4 > 0.0 then 'valve.port_a.m_flow' / 1e-4 * (('valve.port_a.m_flow' / 1e-4) ^ 2.0 - 3.0) * (('valve.port_a.h_outflow' - 104929.29464256502 - ('valve.port_a.p' - 101325.0) * 9.260700016004721e-4) / 4181.885502948851 + 298.15 - 'valve.state_a.T') / 4.0 + ('valve.state_a.T' + ('valve.port_a.h_outflow' - 104929.29464256502 - ('valve.port_a.p' - 101325.0) * 9.260700016004721e-4) / 4181.885502948851 + 298.15) / 2.0 else ('valve.state_a.T' + ('valve.port_a.h_outflow' - 104929.29464256502 - ('valve.port_a.p' - 101325.0) * 9.260700016004721e-4) / 4181.885502948851 + 298.15) / 2.0);
    'valve.port_b_T' = smooth(1, if 'valve.port_b.m_flow' > 1e-4 then 'valve.state_b.T' else if 'valve.port_b.m_flow' < (-1e-4) then ('valve.port_b.h_outflow' - 104929.29464256502 - ('valve.port_b.p' - 101325.0) * 9.260700016004721e-4) / 4181.885502948851 + 298.15 else if 1e-4 > 0.0 then 'valve.port_b.m_flow' / 1e-4 * (('valve.port_b.m_flow' / 1e-4) ^ 2.0 - 3.0) * (('valve.port_b.h_outflow' - 104929.29464256502 - ('valve.port_b.p' - 101325.0) * 9.260700016004721e-4) / 4181.885502948851 + 298.15 - 'valve.state_b.T') / 4.0 + ('valve.state_b.T' + ('valve.port_b.h_outflow' - 104929.29464256502 - ('valve.port_b.p' - 101325.0) * 9.260700016004721e-4) / 4181.885502948851 + 298.15) / 2.0 else ('valve.state_b.T' + ('valve.port_b.h_outflow' - 104929.29464256502 - ('valve.port_b.p' - 101325.0) * 9.260700016004721e-4) / 4181.885502948851 + 298.15) / 2.0);
    'valve.dp_turbulent' = 1.0;
    'heater.mediums[1].T_degC' = 'heater.mediums[1].T' - 273.15;
    'heater.mediums[1].p_bar' = 'heater.mediums[1].p' / 1e5;
    'heater.flowModel.states[1].p' = 'heater.statesFM[1].p';
    'heater.flowModel.states[1].T' = 'heater.statesFM[1].T';
    'heater.flowModel.states[2].p' = 'heater.statesFM[2].p';
    'heater.flowModel.states[2].T' = 'heater.statesFM[2].T';
