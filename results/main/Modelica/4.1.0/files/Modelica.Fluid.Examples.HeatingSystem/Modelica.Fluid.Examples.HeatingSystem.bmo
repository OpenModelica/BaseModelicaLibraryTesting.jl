    Real 'heater.flowModel.rhos_act[1]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
    Real 'heater.flowModel.rhos_act[2]'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Actual density per segment";
