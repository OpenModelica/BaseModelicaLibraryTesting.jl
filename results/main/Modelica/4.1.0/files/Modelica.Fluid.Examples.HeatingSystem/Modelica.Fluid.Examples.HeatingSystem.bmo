    Real 'pipe.mediums[1].h'(start = 334959.5523620477, unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'pipe.mediums[1].d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
