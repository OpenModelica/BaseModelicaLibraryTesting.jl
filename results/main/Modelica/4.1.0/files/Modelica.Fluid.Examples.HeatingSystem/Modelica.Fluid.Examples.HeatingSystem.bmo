    Real 'radiator.flowModel.dps_fg[1]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    Real 'radiator.flowModel.dps_fg[2]'(start = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure drop between states";
    parameter Real 'radiator.flowModel.Re_turbulent'(unit = "1", quantity = "ReynoldsNumber") = 4000.0 "Start of turbulent regime, depending on type of flow device";
    parameter Boolean 'radiator.flowModel.show_Res' = false "= true, if Reynolds numbers are included for plotting" annotation(Evaluate = true);
    parameter Boolean 'radiator.flowModel.use_rho_nominal' = false "= true, if rho_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'radiator.flowModel.rho_nominal'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 998.3298937621773 "Nominal density (e.g., rho_liquidWater = 995, rho_air = 1.2)";
    parameter Boolean 'radiator.flowModel.use_mu_nominal' = false "= true, if mu_nominal is used, otherwise computed from medium" annotation(Evaluate = true);
    parameter Real 'radiator.flowModel.mu_nominal'(min = 0.0, unit = "Pa.s", quantity = "DynamicViscosity") = 8.9e-4 "Nominal dynamic viscosity (e.g., mu_liquidWater = 1e-3, mu_air = 1.8e-5)";
    Real 'radiator.flowModel.pathLengths_internal[1]'(unit = "m", quantity = "Length") "pathLengths used internally; to be defined by extending class";
    Real 'radiator.flowModel.pathLengths_internal[2]'(unit = "m", quantity = "Length") "pathLengths used internally; to be defined by extending class";
    Real 'radiator.flowModel.Res_turbulent_internal[1]'(unit = "1", quantity = "ReynoldsNumber") "Re_turbulent used internally; to be defined by extending class";
    Real 'radiator.flowModel.Res_turbulent_internal[2]'(unit = "1", quantity = "ReynoldsNumber") "Re_turbulent used internally; to be defined by extending class";
    parameter Real 'radiator.flowModel.dp_nominal'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Nominal pressure loss (only for nominal models)";
    parameter Real 'radiator.flowModel.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 100.0 * 'radiator.flowModel.m_flow_small' "Nominal mass flow rate";
    parameter Real 'radiator.flowModel.m_flow_small'(unit = "kg/s", quantity = "MassFlowRate") = 1e-4 "Within regularization if |m_flows| < m_flow_small (may be wider for large discontinuities in static head)";
    parameter Real 'radiator.flowModel.dp_small'(nominal = 1e5, fixed = false, start = 1.0, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Within regularization if |dp| < dp_small (may be wider for large discontinuities in static head)";
    parameter Boolean 'radiator.flowModel.constantPressureLossCoefficient' = false "= true, if the pressure loss does not depend on fluid states" annotation(Evaluate = true);
    parameter Boolean 'radiator.flowModel.continuousFlowReversal' = false "= true, if the pressure loss is continuous around zero flow" annotation(Evaluate = true);
    Real 'radiator.flowModel.diameters[1]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'radiator.flowModel.diameters[2]'(unit = "m", quantity = "Length") "Mean diameters between segments";
    Real 'radiator.flowModel.dp_fric_nominal'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Pressure loss for nominal conditions";
    Real 'radiator.m_flows[1]'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") "Mass flow rates of fluid across segment boundaries";
    Real 'radiator.m_flows[2]'(start = 0.0, max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") "Mass flow rates of fluid across segment boundaries";
    Real 'radiator.H_flows[1]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates of fluid across segment boundaries";
    Real 'radiator.H_flows[2]'(nominal = 1000.0, max = 1e8, min = -1e8, unit = "W", quantity = "EnthalpyFlowRate") "Enthalpy flow rates of fluid across segment boundaries";
    Real 'radiator.vs[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'radiator.pathLengths[1]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'radiator.pathLengths[2]'(unit = "m", quantity = "Length") "Lengths along flow path";
    Real 'radiator.dheightsFM[1]'(unit = "m", quantity = "Length") "Differences in heights between flow segments";
    Real 'radiator.dheightsFM[2]'(unit = "m", quantity = "Length") "Differences in heights between flow segments";
    Real 'radiator.crossAreasFM[1]'(unit = "m2", quantity = "Area") "Cross flow areas of flow segments";
    Real 'radiator.crossAreasFM[2]'(unit = "m2", quantity = "Area") "Cross flow areas of flow segments";
    Real 'radiator.crossAreasFM[3]'(unit = "m2", quantity = "Area") "Cross flow areas of flow segments";
    Real 'radiator.vsFM[1]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
    Real 'radiator.vsFM[2]'(unit = "m/s", quantity = "Velocity") "Mean velocities in flow segments";
