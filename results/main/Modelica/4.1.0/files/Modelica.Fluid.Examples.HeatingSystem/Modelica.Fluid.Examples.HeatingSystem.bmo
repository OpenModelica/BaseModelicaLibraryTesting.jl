    Real 'radiator.dimensionsFM[2]'(unit = "m", quantity = "Length") "Hydraulic diameters of flow segments";
    Real 'radiator.dimensionsFM[3]'(unit = "m", quantity = "Length") "Hydraulic diameters of flow segments";
    Real 'radiator.roughnessesFM[1]'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") "Average heights of surface asperities";
