    parameter 'Modelica.Fluid.Types.Dynamics' 'heater.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Formulation of mass balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'heater.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Formulation of substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'heater.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Formulation of trace substance balances" annotation(Evaluate = true);
    parameter Real 'heater.p_a_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.3e5 "Start value of pressure at port a";
    parameter Real 'heater.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.3e5 "Start value of pressure at port b";
    parameter Real 'heater.ps_start[1]'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.3e5 "Start value of pressure";
    parameter Boolean 'heater.use_T_start' = true "Use T_start if true, otherwise h_start" annotation(Evaluate = true);
    parameter Real 'heater.T_start'(nominal = 300.0, start = 288.15, max = 1e4, min = 1.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 353.15 "Start value of temperature" annotation(Evaluate = true);
    parameter Real 'heater.h_start'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") = 334959.5523620477 "Start value of specific enthalpy" annotation(Evaluate = true);
    parameter Real 'heater.X_start[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 1.0 "Start value of mass fractions m_i/m";
