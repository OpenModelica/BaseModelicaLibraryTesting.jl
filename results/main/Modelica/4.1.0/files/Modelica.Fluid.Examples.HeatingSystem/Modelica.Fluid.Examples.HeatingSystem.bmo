    Real 'sensor_T_forward.port.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'sensor_T_forward.port.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'sensor_T_forward.T'(min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature in port medium";
    Real 'sensor_T_return.port.m_flow'(max = 1e5, min = 0.0, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") "Mass flow rate from the connection point into the component";
    Real 'sensor_T_return.port.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'sensor_T_return.port.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'sensor_T_return.T'(min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature in port medium";
    output Real 'tankLevel'(unit = "m");
    parameter Real 'handle.height' = 0.9 "Height of step";
