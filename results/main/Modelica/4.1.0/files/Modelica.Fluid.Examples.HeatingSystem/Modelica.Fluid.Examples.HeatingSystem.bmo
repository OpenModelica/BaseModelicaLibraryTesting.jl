    parameter Boolean 'heater.flowModel.from_dp' = true "= true, use m_flow = f(dp), otherwise dp = f(m_flow)" annotation(Evaluate = true);
    parameter Integer 'heater.flowModel.n' = 3 "Number of discrete flow volumes";
