    parameter Real 'heater.perimeter'(min = 0.0, unit = "m", quantity = "Length") = 0.031415926535897934 "Inner perimeter";
    parameter Real 'heater.roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average height of surface asperities (default: smooth steel pipe)";
    parameter Real 'heater.V'(unit = "m3", quantity = "Volume") = 1.5707963267948968e-4 "Volume size";
    parameter Real 'heater.height_ab'(unit = "m", quantity = "Length") = 0.0 "Height(port_b) - Height(port_a)";
