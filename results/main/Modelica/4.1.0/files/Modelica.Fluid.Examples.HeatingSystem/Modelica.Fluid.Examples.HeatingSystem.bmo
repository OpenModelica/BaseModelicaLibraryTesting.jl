    parameter Boolean 'pipe.port_a_exposesState' = true "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'pipe.port_b_exposesState' = true "= true if port_b.p exposes the state of a fluid volume";
    parameter Boolean 'pipe.showDesignFlowDirection' = true "= false to hide the arrow in the model icon";
    parameter Real 'pipe.nParallel'(min = 1.0) = 1.0 "Number of identical parallel pipes";
