    parameter Real 'heater.flowModel.p_b_start'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.3e5 "Start value for p[n+1] at design outflow";
