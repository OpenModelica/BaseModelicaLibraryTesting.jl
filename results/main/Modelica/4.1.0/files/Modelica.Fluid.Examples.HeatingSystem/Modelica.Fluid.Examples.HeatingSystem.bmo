    parameter Real 'heater.m_flow_start'(max = 1e5, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Liquid linear water") = 0.0 "Start value for mass flow rate" annotation(Evaluate = true);
    parameter Integer 'heater.nNodes'(min = 1) = 1 "Number of discrete flow volumes" annotation(Evaluate = true);
