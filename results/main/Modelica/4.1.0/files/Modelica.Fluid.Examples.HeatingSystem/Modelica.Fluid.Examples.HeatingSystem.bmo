    parameter Boolean 'pipe.isCircular' = true "= true, if cross sectional area is circular" annotation(Evaluate = true);
    parameter Real 'pipe.diameter'(min = 0.0, unit = "m", quantity = "Length") = 0.01 "Diameter of circular pipe";
    parameter Real 'pipe.crossArea'(unit = "m2", quantity = "Area") = 7.853981633974484e-5 "Inner cross section area";
    parameter Real 'pipe.perimeter'(min = 0.0, unit = "m", quantity = "Length") = 0.031415926535897934 "Inner perimeter";
    parameter Real 'pipe.roughness'(min = 0.0, displayUnit = "mm", unit = "m", quantity = "Length") = 2.5e-5 "Average height of surface asperities (default: smooth steel pipe)";
