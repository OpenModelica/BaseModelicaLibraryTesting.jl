//! base 0.1.0
package 'DifferentialAmplifier'
  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'DifferentialAmplifier' "Differential amplifier"
    parameter Real 'data.VSource'(unit = "V", quantity = "ElectricPotential") = 400.0 "Source RMS voltage line-to-line";
    parameter Real 'data.fSource'(unit = "Hz", quantity = "Frequency") = 50.0 "Source frequency";
    parameter Real 'data.RLoad'(unit = "Ohm", quantity = "Resistance") = 10.0 "Load resistance of source";
    parameter Real 'data.RGround'(unit = "Ohm", quantity = "Resistance") = 1e5 "Resistance of ground connection";
    parameter Real 'data.V0' = 1e4 "No-load differential amplification";
    parameter Real 'data.VSupply'(unit = "V", quantity = "ElectricPotential") = 15.0 "Supply voltage";
    parameter Real 'data.k' = 100.0 "Attenuation factor";
    parameter Real 'data.R1'(unit = "Ohm", quantity = "Resistance") = 1e5 "Resistor 1";
    parameter Real 'data.R2'(unit = "Ohm", quantity = "Resistance") = 1e5 "Resistor 2";
    parameter Real 'data.R3'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistor 3";
    parameter Real 'data.R4'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistor 4";
    parameter Real 'data.RInstrument'(unit = "Ohm", quantity = "Resistance") = 1e5 "Input resistance of instrument";
    parameter Real 'sourceVoltage1.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 326.5986323710904 "Amplitude of sine wave";
    parameter Real 'sourceVoltage1.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.0471975511966 "Phase of sine wave";
    parameter Real 'sourceVoltage1.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    Real 'sourceVoltage1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sourceVoltage1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sourceVoltage1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sourceVoltage1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sourceVoltage1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sourceVoltage1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sourceVoltage1.signalSource.amplitude' = 326.5986323710904 "Amplitude of sine wave";
    parameter Real 'sourceVoltage1.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'sourceVoltage1.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.0471975511966 "Phase of sine wave";
    parameter Boolean 'sourceVoltage1.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sourceVoltage1.signalSource.y' "Connector of Real output signal";
    parameter Real 'sourceVoltage1.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sourceVoltage1.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sourceVoltage1.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'sourceVoltage1.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
