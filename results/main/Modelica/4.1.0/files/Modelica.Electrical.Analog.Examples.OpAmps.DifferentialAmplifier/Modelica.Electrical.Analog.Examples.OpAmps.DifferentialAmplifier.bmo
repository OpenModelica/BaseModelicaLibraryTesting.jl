    parameter Real 'rootMeanSquare.mean.f'(start = 50.0, unit = "Hz", quantity = "Frequency") = 50.0 "Base frequency";
    parameter Real 'rootMeanSquare.mean.x0' = 0.0 "Start value of integrator state";
    parameter Real 'rootMeanSquare.mean.y0' = 0.0 "Start value of output";
    parameter Boolean 'rootMeanSquare.mean.yGreaterOrEqualZero' = true "= true, if output y is guaranteed to be >= 0 for the exact solution" annotation(Evaluate = true);
    parameter Real 'rootMeanSquare.mean.t0'(fixed = false, unit = "s", quantity = "Time") "Start time of simulation";
    Real 'rootMeanSquare.mean.x' "Integrator state";
    discrete Real 'rootMeanSquare.mean.y_last' "Last sampled mean value";
    Real 'rootMeanSquare.sqrt1.u' "Connector of Real input signal";
    Real 'rootMeanSquare.sqrt1.y' "Connector of Real output signal";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'groundSource.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'groundSource.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'groundOpAmp.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'groundOpAmp.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
  initial equation
    'rootMeanSquare.mean.t0' = time;
    'rootMeanSquare.mean.x' = 0.0;
    'rootMeanSquare.mean.y_last' = 0.0;
  equation
    'opAmp.v_in' = 'opAmp.in_p.v' - 'opAmp.in_n.v';
    'opAmp.v_out' = 'opAmp.out.v';
    'opAmp.p_in' = 'opAmp.in_p.v' * 'opAmp.in_p.i' + 'opAmp.in_n.v' * 'opAmp.in_n.i';
    'opAmp.p_out' = 'opAmp.out.v' * 'opAmp.out.i';
    'opAmp.p_s' = -('opAmp.p_in' + 'opAmp.p_out');
    'opAmp.i_s' = 'opAmp.p_s' / ('opAmp.vps' - 'opAmp.vns');
    'opAmp.s_p.v' = 'opAmp.vps';
    'opAmp.s_p.i' = 'opAmp.i_s';
    'opAmp.s_n.v' = 'opAmp.vns';
    'opAmp.s_n.i' = -'opAmp.i_s';
    'rootMeanSquare.product.y' = 'rootMeanSquare.mean.u';
    'rootMeanSquare.mean.y' = 'rootMeanSquare.sqrt1.u';
    'rootMeanSquare.sqrt1.y' = 'rootMeanSquare.y';
    'rootMeanSquare.u' = 'rootMeanSquare.product.u[2]';
    'rootMeanSquare.u' = 'rootMeanSquare.product.u[1]';
    'voltageSensor.v' = 'rootMeanSquare.u';
    'groundOpAmp.v' = 'negativeSupply.n.v';
    'groundOpAmp.v' = 'positiveSupply.n.v';
    'groundOpAmp.v' = 'voltageSensor.n.v';
    'groundOpAmp.v' = 'resistanceInstrument.n.v';
    'groundOpAmp.v' = 'resistorGround.n.v';
    'groundOpAmp.v' = 'resistor4.n.v';
    'negativeSupply.p.v' = 'opAmp.s_n.v';
    'opAmp.s_p.v' = 'positiveSupply.p.v';
    'groundSource.v' = 'ground.p.v';
    'groundSource.v' = 'resistorGround.p.v';
    'groundSource.v' = 'sourceVoltage2.n.v';
    'groundSource.v' = 'sourceVoltage1.n.v';
    'voltageSensorSource.v' = 'gain.u';
    'sourceVoltage2.p.v' = 'resistanceLoad.n.v';
    'sourceVoltage2.p.v' = 'voltageSensorSource.n.v';
    'sourceVoltage2.p.v' = 'resistor2.p.v';
    'sourceVoltage1.p.v' = 'resistanceLoad.p.v';
    'sourceVoltage1.p.v' = 'voltageSensorSource.p.v';
    'sourceVoltage1.p.v' = 'resistor1.p.v';
    'resistor3.n.v' = 'opAmp.out.v';
    'resistor3.n.v' = 'voltageSensor.p.v';
    'resistor3.n.v' = 'resistanceInstrument.p.v';
    'resistor1.n.v' = 'opAmp.in_n.v';
    'resistor1.n.v' = 'resistor3.p.v';
    'resistor2.n.v' = 'opAmp.in_p.v';
    'resistor2.n.v' = 'resistor4.p.v';
    'ground.p.i' + 'resistorGround.p.i' + 'sourceVoltage2.n.i' + 'sourceVoltage1.n.i' - 'groundSource.i' = 0.0;
    'resistor1.p.i' + 'voltageSensorSource.p.i' + 'resistanceLoad.p.i' + 'sourceVoltage1.p.i' = 0.0;
    'resistor2.p.i' + 'voltageSensorSource.n.i' + 'resistanceLoad.n.i' + 'sourceVoltage2.p.i' = 0.0;
    'positiveSupply.p.i' + 'opAmp.s_p.i' = 0.0;
    'resistor3.p.i' + 'resistor1.n.i' + 'opAmp.in_n.i' = 0.0;
    'resistor4.p.i' + 'resistor2.n.i' + 'opAmp.in_p.i' = 0.0;
    'voltageSensor.n.i' + 'resistanceInstrument.n.i' + 'negativeSupply.n.i' + 'positiveSupply.n.i' + 'resistor4.n.i' + 'resistorGround.n.i' - 'groundOpAmp.i' = 0.0;
    'negativeSupply.p.i' + 'opAmp.s_n.i' = 0.0;
    'voltageSensor.p.i' + 'resistanceInstrument.p.i' + 'resistor3.n.i' + 'opAmp.out.i' = 0.0;
    'groundSource.i' = 0.0;
    'groundOpAmp.i' = 0.0;
    'sourceVoltage1.signalSource.y' = if time < 0.0 then 0.0 else 326.5986323710904 * sin(314.1592653589793 * time + 1.0471975511966);
    'sourceVoltage1.v' = 'sourceVoltage1.signalSource.y';
    0.0 = 'sourceVoltage1.p.i' + 'sourceVoltage1.n.i';
    'sourceVoltage1.i' = 'sourceVoltage1.p.i';
    'sourceVoltage1.v' = 'sourceVoltage1.p.v' - 'sourceVoltage1.n.v';
    'sourceVoltage2.signalSource.y' = if time < 0.0 then 0.0 else 326.5986323710904 * sin(314.1592653589793 * time - 1.0471975511966);
    'sourceVoltage2.v' = 'sourceVoltage2.signalSource.y';
    0.0 = 'sourceVoltage2.p.i' + 'sourceVoltage2.n.i';
    'sourceVoltage2.i' = 'sourceVoltage2.p.i';
    'sourceVoltage2.v' = 'sourceVoltage2.p.v' - 'sourceVoltage2.n.v';
    'resistanceLoad.R_actual' = 10.0;
    'resistanceLoad.v' = 'resistanceLoad.R_actual' * 'resistanceLoad.i';
    'resistanceLoad.LossPower' = 'resistanceLoad.v' * 'resistanceLoad.i';
    'resistanceLoad.T_heatPort' = 300.15;
    0.0 = 'resistanceLoad.p.i' + 'resistanceLoad.n.i';
    'resistanceLoad.i' = 'resistanceLoad.p.i';
    'resistanceLoad.v' = 'resistanceLoad.p.v' - 'resistanceLoad.n.v';
    'voltageSensorSource.p.i' = 0.0;
    'voltageSensorSource.n.i' = 0.0;
    'voltageSensorSource.v' = 'voltageSensorSource.p.v' - 'voltageSensorSource.n.v';
    'gain.y' = (-0.01) * 'gain.u';
    'resistorGround.R_actual' = 1e5;
    'resistorGround.v' = 'resistorGround.R_actual' * 'resistorGround.i';
    'resistorGround.LossPower' = 'resistorGround.v' * 'resistorGround.i';
    'resistorGround.T_heatPort' = 300.15;
    0.0 = 'resistorGround.p.i' + 'resistorGround.n.i';
    'resistorGround.i' = 'resistorGround.p.i';
    'resistorGround.v' = 'resistorGround.p.v' - 'resistorGround.n.v';
    'opAmp.in_p.i' = 0.0;
    'opAmp.in_n.i' = 0.0;
    'opAmp.simplifiedExpr' = 0.0;
    'opAmp.v_out' = smooth(0, noEvent(if 1e4 * 'opAmp.v_in' > 'opAmp.vps' then 'opAmp.vps' else if 1e4 * 'opAmp.v_in' < 'opAmp.vns' then 'opAmp.vns' else 1e4 * 'opAmp.v_in'));
    'resistor1.R_actual' = 1e5;
    'resistor1.v' = 'resistor1.R_actual' * 'resistor1.i';
    'resistor1.LossPower' = 'resistor1.v' * 'resistor1.i';
    'resistor1.T_heatPort' = 300.15;
    0.0 = 'resistor1.p.i' + 'resistor1.n.i';
    'resistor1.i' = 'resistor1.p.i';
    'resistor1.v' = 'resistor1.p.v' - 'resistor1.n.v';
    'resistor2.R_actual' = 1e5;
    'resistor2.v' = 'resistor2.R_actual' * 'resistor2.i';
    'resistor2.LossPower' = 'resistor2.v' * 'resistor2.i';
    'resistor2.T_heatPort' = 300.15;
    0.0 = 'resistor2.p.i' + 'resistor2.n.i';
    'resistor2.i' = 'resistor2.p.i';
    'resistor2.v' = 'resistor2.p.v' - 'resistor2.n.v';
    'resistor3.R_actual' = 1000.0;
    'resistor3.v' = 'resistor3.R_actual' * 'resistor3.i';
    'resistor3.LossPower' = 'resistor3.v' * 'resistor3.i';
    'resistor3.T_heatPort' = 300.15;
    0.0 = 'resistor3.p.i' + 'resistor3.n.i';
    'resistor3.i' = 'resistor3.p.i';
    'resistor3.v' = 'resistor3.p.v' - 'resistor3.n.v';
    'resistor4.R_actual' = 1000.0;
    'resistor4.v' = 'resistor4.R_actual' * 'resistor4.i';
    'resistor4.LossPower' = 'resistor4.v' * 'resistor4.i';
    'resistor4.T_heatPort' = 300.15;
    0.0 = 'resistor4.p.i' + 'resistor4.n.i';
    'resistor4.i' = 'resistor4.p.i';
    'resistor4.v' = 'resistor4.p.v' - 'resistor4.n.v';
    'positiveSupply.v' = 15.0;
    0.0 = 'positiveSupply.p.i' + 'positiveSupply.n.i';
    'positiveSupply.i' = 'positiveSupply.p.i';
    'positiveSupply.v' = 'positiveSupply.p.v' - 'positiveSupply.n.v';
    'negativeSupply.v' = -15.0;
    0.0 = 'negativeSupply.p.i' + 'negativeSupply.n.i';
    'negativeSupply.i' = 'negativeSupply.p.i';
    'negativeSupply.v' = 'negativeSupply.p.v' - 'negativeSupply.n.v';
    'resistanceInstrument.R_actual' = 1e5;
    'resistanceInstrument.v' = 'resistanceInstrument.R_actual' * 'resistanceInstrument.i';
    'resistanceInstrument.LossPower' = 'resistanceInstrument.v' * 'resistanceInstrument.i';
    'resistanceInstrument.T_heatPort' = 300.15;
    0.0 = 'resistanceInstrument.p.i' + 'resistanceInstrument.n.i';
    'resistanceInstrument.i' = 'resistanceInstrument.p.i';
    'resistanceInstrument.v' = 'resistanceInstrument.p.v' - 'resistanceInstrument.n.v';
    'voltageSensor.p.i' = 0.0;
    'voltageSensor.n.i' = 0.0;
    'voltageSensor.v' = 'voltageSensor.p.v' - 'voltageSensor.n.v';
    'rootMeanSquare.product.y' = 'rootMeanSquare.product.u[1]' * 'rootMeanSquare.product.u[2]';
    der('rootMeanSquare.mean.x') = 'rootMeanSquare.mean.u';

    when sample('rootMeanSquare.mean.t0' + 0.02, 0.02) then
      'rootMeanSquare.mean.y_last' = max(0.0, 50.0 * pre('rootMeanSquare.mean.x'));
      reinit('rootMeanSquare.mean.x', 0.0);
    end when;

    'rootMeanSquare.mean.y' = 'rootMeanSquare.mean.y_last';
    'rootMeanSquare.sqrt1.y' = sqrt('rootMeanSquare.sqrt1.u');
    'ground.p.v' = 0.0;
    annotation(experiment(StopTime = 0.2, Interval = 0.0001, Tolerance = 1e-06));
  end 'DifferentialAmplifier';
end 'DifferentialAmplifier';
