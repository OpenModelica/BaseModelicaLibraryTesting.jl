    Real 'pmActuator.armature.stopper_xMin.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'pmActuator.armature.stopper_xMin.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring constant";
    parameter Real 'pmActuator.armature.stopper_xMin.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping constant";
    parameter Real 'pmActuator.armature.stopper_xMin.s_rel0'(unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
