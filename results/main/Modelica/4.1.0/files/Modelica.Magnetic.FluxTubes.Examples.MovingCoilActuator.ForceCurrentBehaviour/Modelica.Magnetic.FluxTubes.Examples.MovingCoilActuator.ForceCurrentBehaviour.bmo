    Real 'pmActuator.armature.limit_xMax.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.limit_xMax.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter StateSelect 'pmActuator.armature.stopper_xMax.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'pmActuator.armature.stopper_xMax.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'pmActuator.armature.stopper_xMax.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'pmActuator.armature.stopper_xMax.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'pmActuator.armature.stopper_xMax.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'pmActuator.armature.stopper_xMax.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.stopper_xMax.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'pmActuator.armature.stopper_xMax.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.stopper_xMax.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'pmActuator.armature.stopper_xMax.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring constant";
    parameter Real 'pmActuator.armature.stopper_xMax.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping constant";
    parameter Real 'pmActuator.armature.stopper_xMax.s_rel0'(unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
    parameter Real 'pmActuator.armature.stopper_xMax.f_ref'(min = 0.0, unit = "N", quantity = "Force") = 1e11 "Reference spring force at s_ref";
    parameter Real 'pmActuator.armature.stopper_xMax.s_ref'(min = 2.220446049250313e-16, unit = "m", quantity = "Length") = 1.0 "Reference relative compression at which f_c = f_ref";
    parameter Real 'pmActuator.armature.stopper_xMax.n'(min = 1.0) = 2.0 "Exponent of spring force ( f_c = -f_ref*|(s_rel-s_rel0)/s_ref|^n )";
    parameter Boolean 'pmActuator.armature.stopper_xMax.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'pmActuator.armature.stopper_xMax.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Boolean 'pmActuator.armature.stopper_xMax.contact' "= true, if contact, otherwise no contact";
    Real 'pmActuator.armature.stopper_xMax.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'pmActuator.armature.stopper_xMax.f_d2'(unit = "N", quantity = "Force") "Linear damping force";
    Real 'pmActuator.armature.stopper_xMax.f_d'(unit = "N", quantity = "Force") "Linear damping force which is limited by spring force (|f_d| <= |f_c|)";
    Real 'pmActuator.armature.stopper_xMax.ratio' "Scaling ratio of relative compression to s_ref";
    parameter StateSelect 'pmActuator.armature.stopper_xMin.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'pmActuator.armature.stopper_xMin.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'pmActuator.armature.stopper_xMin.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'pmActuator.armature.stopper_xMin.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
