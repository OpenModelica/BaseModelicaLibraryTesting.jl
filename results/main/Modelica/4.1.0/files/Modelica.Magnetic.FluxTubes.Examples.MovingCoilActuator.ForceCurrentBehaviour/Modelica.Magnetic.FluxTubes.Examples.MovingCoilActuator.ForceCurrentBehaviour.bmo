    Real 'pmActuator.armature.mass.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    Real 'pmActuator.armature.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
