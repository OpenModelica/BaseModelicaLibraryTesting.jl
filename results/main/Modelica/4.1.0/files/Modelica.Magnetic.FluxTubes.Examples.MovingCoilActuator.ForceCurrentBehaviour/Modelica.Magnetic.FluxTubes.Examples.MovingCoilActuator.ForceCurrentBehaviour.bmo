    parameter Real 'pmActuator.armature.stopper_xMin.n'(min = 1.0) = 2.0 "Exponent of spring force ( f_c = -f_ref*|(s_rel-s_rel0)/s_ref|^n )";
    parameter Boolean 'pmActuator.armature.stopper_xMin.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
