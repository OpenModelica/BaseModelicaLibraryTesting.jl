    Real 'pmActuator.armature.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'pmActuator.armature.limit_xMin.s0'(unit = "m", quantity = "Length") = -0.004 "Fixed offset position of housing";
    Real 'pmActuator.armature.limit_xMin.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'pmActuator.armature.limit_xMin.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
