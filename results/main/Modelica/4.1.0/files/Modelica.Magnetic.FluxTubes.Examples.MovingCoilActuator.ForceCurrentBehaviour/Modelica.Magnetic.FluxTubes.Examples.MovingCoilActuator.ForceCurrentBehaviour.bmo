//! base 0.1.0
package 'ForceCurrentBehaviour'
  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  class 'Modelica.Blocks.Types.ExternalCombiTable1D'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table defined by matrix"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" 'externalCombiTable1D' = ModelicaStandardTables_CombiTable1D_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table defined by matrix"
      input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" ModelicaStandardTables_CombiTable1D_close('externalCombiTable1D') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTable1D';

  model 'ForceCurrentBehaviour' "Comparison of the force-current characteristics of both converter models with armature blocked at mid-position"
    Real 'pmGround.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'pmGround.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'pmActuator.N' = 140.0 "Number of turns";
    parameter Real 'pmActuator.R'(unit = "Ohm", quantity = "Resistance") = 2.86 "Coil resistance";
    parameter Real 'pmActuator.r_core'(min = 0.0, unit = "m", quantity = "Length") = 0.0125 "Radius of ferromagnetic stator core";
    parameter Real 'pmActuator.l_PM'(unit = "m", quantity = "Length") = 0.0035 "Radial thickness of permanent magnet ring";
    parameter Real 'pmActuator.t'(unit = "m", quantity = "Length") = 0.02 "Axial length of permanent magnet ring and air gap respectively";
    parameter Real 'pmActuator.l_air'(unit = "m", quantity = "Length") = 0.003 "Total radial length of armature air gap";
    parameter Real 'pmActuator.l_FeOut'(unit = "m", quantity = "Length") = 0.004 "Radial thickness of outer back iron (for estimation of leakage permeance)";
    parameter Real 'pmActuator.material.H_cBRef'(unit = "A/m", quantity = "MagneticFieldStrength") = 4e5 "Coercivity at reference temperature";
    parameter Real 'pmActuator.material.B_rRef'(unit = "T", quantity = "MagneticFluxDensity") = 0.58 "Remanence at reference temperature";
    parameter Real 'pmActuator.material.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'pmActuator.material.alpha_Br'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = -0.001 "Temperature coefficient of remanence at reference temperature";
    parameter Real 'pmActuator.material.T_op'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operating temperature";
    parameter Real 'pmActuator.material.B_r'(unit = "T", quantity = "MagneticFluxDensity") = 0.58 "Remanence at operating temperature";
    parameter Real 'pmActuator.material.H_cB'(unit = "A/m", quantity = "MagneticFieldStrength") = 4e5 "Coercivity at operating temperature";
    parameter Real 'pmActuator.material.mu_r'(unit = "1", quantity = "RelativePermeability") = 1.1538733367881007 "Relative permeability";
    parameter Real 'pmActuator.m_a'(min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Mass of armature";
    parameter Real 'pmActuator.c'(unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring stiffness between impact partners";
    parameter Real 'pmActuator.d'(unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping coefficient between impact partners";
    parameter Real 'pmActuator.x_min'(unit = "m", quantity = "Length") = -0.004 "Position of stopper at minimum armature position";
    parameter Real 'pmActuator.x_max'(unit = "m", quantity = "Length") = 0.004 "Position of stopper at maximum armature position";
    Real 'pmActuator.x'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m", quantity = "Length") "Armature position, alias for flange position";
    Real 'pmActuator.L'(unit = "H", quantity = "Inductance") "Coil inductance";
    Real 'pmActuator.mmf_PM.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'pmActuator.mmf_PM.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'pmActuator.mmf_PM.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'pmActuator.mmf_PM.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    parameter Real 'pmActuator.mmf_PM.V_m'(unit = "A", quantity = "MagneticPotential") = 1400.0 "Magnetic potential difference";
    Real 'pmActuator.mmf_PM.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'pmActuator.armature.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component from left flange to right flange (= flange_b.s - flange_a.s)";
    parameter Real 'pmActuator.armature.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Armature mass";
    parameter Real 'pmActuator.armature.c'(start = 1e11, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring stiffness between impact partners";
    parameter Real 'pmActuator.armature.d'(start = 2e7, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping coefficient between impact partners";
    parameter Real 'pmActuator.armature.n'(min = 1.0) = 2.0 "Exponent of spring forces (f_c = c*|s_rel|^n)" annotation(Evaluate = true);
    parameter Real 'pmActuator.armature.x_max'(start = 0.01, unit = "m", quantity = "Length") = 0.004 "Position of stopper at maximum armature position";
    parameter Real 'pmActuator.armature.x_min'(start = 0.0, unit = "m", quantity = "Length") = -0.004 "Position of stopper at minimum armature position";
    Real 'pmActuator.armature.s'(start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (= flange_a.s + L/2)";
    Real 'pmActuator.armature.v'(start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of components (= der(s))";
    Real 'pmActuator.armature.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of components (= der(v))";
    parameter Real 'pmActuator.armature.mass.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Mass of the sliding mass";
    parameter StateSelect 'pmActuator.armature.mass.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'pmActuator.armature.mass.s'(stateSelect = StateSelect.default, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'pmActuator.armature.mass.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
