    parameter Real 'M1.c2.m_tVbi'(start = 1.0, unit = "V", quantity = "ElectricPotential") = -2.0;
    parameter Real 'M1.c2.m_VBScrit'(start = 0.7, unit = "V", quantity = "ElectricPotential") = 0.7302825626525529;
