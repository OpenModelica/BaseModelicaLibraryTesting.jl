    'M1.icBD' = 'M1.cc.cBD' * (der('M1.B.v') - der('M1.Dinternal'));
    'M1.icBS' = 'M1.cc.cBS' * (der('M1.B.v') - der('M1.Sinternal'));
    'M1.icGB' = 'M1.cc.cGB' * (der('M1.G.v') - der('M1.B.v'));
    'M1.icGD' = 'M1.cc.cGD' * (der('M1.G.v') - der('M1.Dinternal'));
    'M1.icGS' = 'M1.cc.cGS' * (der('M1.G.v') - der('M1.Sinternal'));
    'M1.ibsgmin' = 1e-12 * ('M1.B.v' - 'M1.Sinternal');
    'M1.ibdgmin' = 1e-12 * ('M1.B.v' - 'M1.Dinternal');
    'M1.G.i' = 'M1.icGB' + 'M1.icGD' + 'M1.icGS';
    'M1.B.i' = 'M1.cc.iBD' + 'M1.cc.iBS' + 'M1.ibdgmin' + 'M1.ibsgmin' - 'M1.icGB' + 'M1.icBD' + 'M1.icBS';
    'M1.D.i' = 'M1.ird';
    'M1.S.i' = 'M1.irs';
    0.0 = 'M1.cc.idrain' - 'M1.ird' - 'M1.cc.iBD' - 'M1.ibdgmin' - 'M1.icGD' - 'M1.icBD';
    0.0 = -('M1.irs' + 'M1.cc.idrain' + 'M1.cc.iBS' + 'M1.ibsgmin' + 'M1.icGS' + 'M1.icBS');
    'VIDS.v' = 0.0;
    0.0 = 'VIDS.p.i' + 'VIDS.n.i';
    'VIDS.i' = 'VIDS.p.i';
    'VIDS.v' = 'VIDS.p.v' - 'VIDS.n.v';
    'g.p.v' = 0.0;
    annotation(experiment(StopTime = 1e-007, Interval = 1e-009));
  end 'Spice3BenchmarkMosfetCharacterization';
end 'Spice3BenchmarkMosfetCharacterization';
