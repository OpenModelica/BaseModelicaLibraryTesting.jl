    Real 'M1.cc.cBD'(start = 0.0, min = -1e60, unit = "F", quantity = "Capacitance");
    Real 'M1.cc.m_capgd'(min = -1e60, unit = "F", quantity = "Capacitance");
    constant Boolean 'M1.m_bInit' = false;
    Real 'M1.Dinternal'(unit = "V", quantity = "ElectricPotential");
    Real 'M1.Sinternal'(unit = "V", quantity = "ElectricPotential");
    Real 'M1.ird'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.irs'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.ibdgmin'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.ibsgmin'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.icBD'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.icBS'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.icGB'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.icGS'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.icGD'(unit = "A", quantity = "ElectricCurrent");
    Real 'M1.vDS'(unit = "V", quantity = "ElectricPotential") "Drain - source voltage";
    Real 'M1.vGS'(unit = "V", quantity = "ElectricPotential") "Gate - source voltage";
    parameter Real 'VIDS.V'(unit = "V", quantity = "ElectricPotential") = 0.0 "Value of constant voltage";
    Real 'VIDS.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'VIDS.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'VIDS.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'VIDS.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'VIDS.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'VIDS.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'MOD1.VTO'(unit = "V", quantity = "ElectricPotential") = -2.0 "Zero-bias threshold voltage, default 0";
    parameter Real 'MOD1.KP'(unit = "A/V2", quantity = "Transconductance") = -1e40 "Transconductance parameter, default 2e-5";
    parameter Real 'MOD1.GAMMA' = -1e40 "Bulk threshold parameter, default 0";
    parameter Real 'MOD1.PHI'(unit = "V", quantity = "ElectricPotential") = -1e40 "Surface potential, default 0.6";
    parameter Real 'MOD1.LAMBDA'(unit = "1/V", quantity = "InversePotential") = 0.0 "Channel-length modulation, default 0";
    parameter Real 'MOD1.RD'(unit = "Ohm", quantity = "Resistance") = -1e40 "Drain ohmic resistance, default 0";
    parameter Real 'MOD1.RS'(unit = "Ohm", quantity = "Resistance") = -1e40 "Source ohmic resistance, default 0";
    parameter Real 'MOD1.CBD'(min = -1e60, unit = "F", quantity = "Capacitance") = 0.0 "Zero-bias B-D junction capacitance, default 0";
    parameter Real 'MOD1.CBS'(min = -1e60, unit = "F", quantity = "Capacitance") = 0.0 "Zero-bias B-S junction capacitance, default 0";
    parameter Real 'MOD1.IS'(unit = "A", quantity = "ElectricCurrent") = 1e-14 "Bulk junction saturation current";
    parameter Real 'MOD1.PB'(unit = "V", quantity = "ElectricPotential") = 0.8 "Bulk junction potential";
    parameter Real 'MOD1.CGSO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-source overlap capacitance per meter channel width";
    parameter Real 'MOD1.CGDO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-drain overlap capacitance per meter channel width";
    parameter Real 'MOD1.CGBO'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Gate-bulk overlap capacitance per meter channel width";
    parameter Real 'MOD1.RSH'(unit = "Ohm", quantity = "Resistance") = 0.0 "Drain and source diffusion sheet resistance";
    parameter Real 'MOD1.CJ'(unit = "F/m2", quantity = "CapacitancePerArea") = 0.0 "Zero-bias bulk junction bottom cap. per sq-meter of junction area";
    parameter Real 'MOD1.MJ' = 0.5 "Bulk junction bottom grading coefficient";
    parameter Real 'MOD1.CJSW'(min = 0.0, unit = "F/m", quantity = "Permittivity") = 0.0 "Zero-bias junction sidewall cap. per meter of junction perimeter";
    parameter Real 'MOD1.MJSW' = 0.5 "Bulk junction sidewall grading coefficient";
    parameter Real 'MOD1.JS'(unit = "A/m2", quantity = "CurrentDensity") = 0.0 "Bulk junction saturation current per sq-meter of junction area";
    parameter Real 'MOD1.TOX'(unit = "m", quantity = "Length") = -1e40 "Oxide thickness, default 1e-7";
    parameter Real 'MOD1.NSUB' = 1e15 "Substrate doping, default 0";
    parameter Real 'MOD1.NSS'(unit = "1/cm2", quantity = "PerArea") = 0.0 "Surface state density";
    parameter Real 'MOD1.TPG' = 1.0 "Type of gate material: +1 opp. to substrate, -1 same as substrate, 0 Al gate";
    parameter Real 'MOD1.LD'(unit = "m", quantity = "Length") = 0.0 "Lateral diffusion";
    parameter Real 'MOD1.UO'(unit = "cm2/(V.s)", quantity = "AreaPerVoltageSecond") = 550.0 "Surface mobility";
    parameter Real 'MOD1.KF' = 0.0 "Flicker noise coefficient";
    parameter Real 'MOD1.AF' = 1.0 "Flicker noise exponent";
    parameter Real 'MOD1.FC' = 0.5 "Coefficient for forward-bias depletion capacitance formula";
    parameter Real 'MOD1.TNOM'(unit = "degC", quantity = "ThermodynamicTemperature") = 27.0 "Parameter measurement temperature, default 27";
    constant Integer 'MOD1.LEVEL' = 1 "Model level: Shichman-Hodges";
    Real 'g.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'g.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'n3.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'n3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'n0.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'n0.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
  equation
    'M1.B.v' = 'n0.v';
    'M1.B.v' = 'M1.S.v';
    'M1.B.v' = 'VGS.n.v';
    'M1.B.v' = 'VDS.n.v';
    'M1.B.v' = 'g.p.v';
    'VIDS.p.v' = 'n3.v';
    'VIDS.p.v' = 'VDS.p.v';
    'M1.G.v' = 'n2.v';
    'M1.G.v' = 'VGS.p.v';
    'VIDS.n.v' = 'n1.v';
    'VIDS.n.v' = 'M1.D.v';
    'VIDS.p.i' + 'VDS.p.i' - 'n3.i' = 0.0;
    'M1.G.i' + 'VGS.p.i' - 'n2.i' = 0.0;
    'VIDS.n.i' + 'M1.D.i' - 'n1.i' = 0.0;
    'g.p.i' + 'M1.B.i' + 'M1.S.i' + 'VGS.n.i' + 'VDS.n.i' - 'n0.i' = 0.0;
    'n3.i' = 0.0;
    'n0.i' = 0.0;
    'n2.i' = 0.0;
    'n1.i' = 0.0;

    when pre('VDS.counter2') <> 0 and sample(0.0, 1.0) then
      'VDS.T0' = time;
      'VDS.counter2' = pre('VDS.counter');
      'VDS.counter' = pre('VDS.counter') - (if pre('VDS.counter') > 0 then 1 else 0);
    end when;

    'VDS.v' = if (time < 0.0 or 'VDS.counter2' == 0) or time >= 'VDS.T0' + 1.0000000199999999 then 0.0 else if time < 'VDS.T0' + 1e-8 then (time - 'VDS.T0') * 10.0 / 1e-8 else if time < 'VDS.T0' + 1.00000001 then 10.0 else ('VDS.T0' + 1.0000000199999999 - time) * 10.0 / 9.99999993922529e-9;
    0.0 = 'VDS.p.i' + 'VDS.n.i';
    'VDS.i' = 'VDS.p.i';
    'VDS.v' = 'VDS.p.v' - 'VDS.n.v';

    when pre('VGS.counter2') <> 0 and sample(4e-8, 2e-8) then
      'VGS.T0' = time;
      'VGS.counter2' = pre('VGS.counter');
      'VGS.counter' = pre('VGS.counter') - (if pre('VGS.counter') > 0 then 1 else 0);
    end when;

    'VGS.v' = if (time < 4e-8 or 'VGS.counter2' == 0) or time >= 'VGS.T0' + 1.2000000000000002e-8 then 0.0 else if time < 'VGS.T0' + 1e-9 then (time - 'VGS.T0') * 5.0 / 1e-9 else if time < 'VGS.T0' + 1.1000000000000001e-8 then 5.0 else ('VGS.T0' + 1.2000000000000002e-8 - time) * 5.0 / 1.0000000000000007e-9;
    0.0 = 'VGS.p.i' + 'VGS.n.i';
    'VGS.i' = 'VGS.p.i';
    'VGS.v' = 'VGS.p.v' - 'VGS.n.v';
