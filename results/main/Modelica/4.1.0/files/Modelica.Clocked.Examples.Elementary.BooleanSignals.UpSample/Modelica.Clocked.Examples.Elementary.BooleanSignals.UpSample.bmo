//! base 0.1.0
package 'UpSample'
  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmin' "Return minimum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMin';
  external "C" 'timeMin' = ModelicaStandardTables_CombiTimeTable_minimumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmin';

  function 'Modelica.Blocks.Tables.Internal.getNextTimeEvent' "Return next time event value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Real 'timeIn';
    output Real 'nextTimeEvent';
  external "C" 'nextTimeEvent' = ModelicaStandardTables_CombiTimeTable_nextTimeEvent('tableID', 'timeIn') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getNextTimeEvent';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableTmax' "Return maximum abscissa value of 1-dim. table where first column is time"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    output Real 'timeMax';
  external "C" 'timeMax' = ModelicaStandardTables_CombiTimeTable_maximumTime('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableTmax';

  function 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer' "Interpolate 1-dim. table where first column is time (but do not provide a derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'tableID';
    input Integer 'icol';
    input Real 'timeIn';
    input Real 'nextTimeEvent';
    input Real 'pre_nextTimeEvent';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTimeTable_getValue('tableID', 'icol', 'timeIn', 'nextTimeEvent', 'pre_nextTimeEvent') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer';

  type 'Modelica.Clocked.Types.Resolution' = enumeration('y', 'd', 'h', 'm', 's', 'ms', 'us', 'ns');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.TimeEvents' = enumeration('Always', 'AtDiscontinuities', 'NoTimeEvents');

  class 'Modelica.Blocks.Types.ExternalCombiTimeTable'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table where first column is time"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Real 'startTime';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation';
      input Real 'shiftTime' = 0.0;
      input 'Modelica.Blocks.Types.TimeEvents' 'timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" 'externalCombiTimeTable' = ModelicaStandardTables_CombiTimeTable_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'startTime', 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'shiftTime', 'timeEvents', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table where first column is time"
      input 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'externalCombiTimeTable';
    external "C" ModelicaStandardTables_CombiTimeTable_close('externalCombiTimeTable') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTimeTable';

  model 'UpSample' "Example of an UpSample block for Boolean signals"
    parameter Integer 'periodicClock.factor'(min = 0) = 20 "Sample factor with respect to resolution" annotation(Evaluate = true);
    parameter 'Modelica.Clocked.Types.Resolution' 'periodicClock.resolution' = 'Modelica.Clocked.Types.Resolution'.'ms' "Clock resolution" annotation(Evaluate = true);
    parameter Boolean 'periodicClock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'periodicClock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'periodicClock.y';
    constant Integer 'periodicClock.conversionTable[1]' = 31536000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[2]' = 86400 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[3]' = 3600 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[4]' = 60 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[5]' = 1 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[6]' = 1000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[7]' = 1000000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[8]' = 1000000000 "Table to convert from Resolution to Integer clock resolution";
    parameter Integer 'periodicClock.resolutionFactor' = 1000 annotation(Evaluate = true);
    Clock 'periodicClock.c';
    Clock 'sample1.clock' "Output signal y is associated with this clock input";
    Boolean 'sample1.u' "Connector of continuous-time, Boolean input signal";
    Boolean 'sample1.y' "Connector of clocked, Boolean output signal";
    parameter Boolean 'upSample1.inferFactor' = true "= true, if upsampling factor is inferred" annotation(Evaluate = true);
    parameter Integer 'upSample1.factor'(min = 1) = 1 "Upsampling factor >= 1 (if inferFactor=false)" annotation(Evaluate = true);
    Boolean 'upSample1.u' "Connector of clocked, Boolean input signal";
    Boolean 'upSample1.y' "Connector of clocked, Boolean output signal (clock of y is faster as clock of u)";
    Boolean 'upSample1.dummy';
    Boolean 'upSample1.b'(start = false);
    Boolean 'upSample1.b_super'(start = false);
    Boolean 'upSample1.u_super';
    parameter Boolean 'upSample2.inferFactor' = false "= true, if upsampling factor is inferred" annotation(Evaluate = true);
    parameter Integer 'upSample2.factor'(min = 1) = 3 "Upsampling factor >= 1 (if inferFactor=false)" annotation(Evaluate = true);
    Boolean 'upSample2.u' "Connector of clocked, Boolean input signal";
    Boolean 'upSample2.y' "Connector of clocked, Boolean output signal (clock of y is faster as clock of u)";
    Boolean 'upSample2.dummy';
    Boolean 'upSample2.b'(start = false);
    Boolean 'upSample2.b_super'(start = false);
    Boolean 'upSample2.u_super';
    parameter Real 'table1.table[1]'(unit = "s", quantity = "Time") = 0.05 "Vector of time points. At every time point, the output y gets its opposite value (e.g., table={0,1})";
    parameter Real 'table1.table[2]'(unit = "s", quantity = "Time") = 0.15 "Vector of time points. At every time point, the output y gets its opposite value (e.g., table={0,1})";
    parameter Boolean 'table1.startValue' = false "Start value of y. At time = table[1], y changes to 'not startValue'";
    parameter 'Modelica.Blocks.Types.Extrapolation' 'table1.extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'HoldLastPoint' "Extrapolation of data outside the definition range";
    parameter Real 'table1.startTime'(unit = "s", quantity = "Time") = -1e60 "Output = false for time < startTime";
    parameter Real 'table1.shiftTime'(unit = "s", quantity = "Time") = 0.0 "Shift time of table";
    Boolean 'table1.y' "Connector of Boolean output signal";
    parameter Integer 'table1.combiTimeTable.nout'(min = 1) = 1 "Number of outputs";
    Real 'table1.combiTimeTable.y[1]' "Connector of Real output signals";
    parameter Boolean 'table1.combiTimeTable.tableOnFile' = false "= true, if table is defined on file or in function usertab";
    parameter Real 'table1.combiTimeTable.table[1,1]' = 0.05 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'table1.combiTimeTable.table[1,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'table1.combiTimeTable.table[2,1]' = 0.05 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'table1.combiTimeTable.table[2,2]' = 1.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'table1.combiTimeTable.table[3,1]' = 0.15 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter Real 'table1.combiTimeTable.table[3,2]' = 0.0 "Table matrix (time = first column; e.g., table=[0, 0; 1, 1; 2, 4])";
    parameter String 'table1.combiTimeTable.tableName' = "NoName" "Table name on file or in function usertab (see docu)";
    parameter String 'table1.combiTimeTable.fileName' = "NoName" "File where matrix is stored";
    parameter String 'table1.combiTimeTable.delimiter' = "," "Column delimiter character for CSV file";
    parameter Integer 'table1.combiTimeTable.nHeaderLines' = 0 "Number of header lines to ignore for CSV file";
    parameter Boolean 'table1.combiTimeTable.verboseRead' = true "= true, if info message that file is loading is to be printed";
    parameter Integer 'table1.combiTimeTable.columns[1]' = 2 "Columns of table to be interpolated";
    parameter 'Modelica.Blocks.Types.Smoothness' 'table1.combiTimeTable.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments' "Smoothness of table interpolation";
    parameter 'Modelica.Blocks.Types.Extrapolation' 'table1.combiTimeTable.extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'HoldLastPoint' "Extrapolation of data outside the definition range";
    parameter Real 'table1.combiTimeTable.timeScale'(min = 2.220446049250313e-16, unit = "s", quantity = "Time") = 1.0 "Time scale of first table column" annotation(Evaluate = true);
    parameter Real 'table1.combiTimeTable.offset[1]' = 0.0 "Offsets of output signals";
    parameter Real 'table1.combiTimeTable.startTime'(unit = "s", quantity = "Time") = -1e60 "Output = offset for time < startTime";
    parameter Real 'table1.combiTimeTable.shiftTime'(unit = "s", quantity = "Time") = 0.0 "Shift time of first table column";
    parameter 'Modelica.Blocks.Types.TimeEvents' 'table1.combiTimeTable.timeEvents' = 'Modelica.Blocks.Types.TimeEvents'.'Always' "Time event handling of table interpolation";
    parameter Boolean 'table1.combiTimeTable.verboseExtrapolation' = false "= true, if warning messages are to be printed if time is outside the table definition range";
    parameter Real 'table1.combiTimeTable.t_min'(unit = "s", quantity = "Time") = 'table1.combiTimeTable.t_minScaled' "Minimum abscissa value defined in table";
    parameter Real 'table1.combiTimeTable.t_max'(unit = "s", quantity = "Time") = 'table1.combiTimeTable.t_maxScaled' "Maximum abscissa value defined in table";
    parameter Real 'table1.combiTimeTable.t_minScaled' = 'Modelica.Blocks.Tables.Internal.getTimeTableTmin'('table1.combiTimeTable.tableID') "Minimum (scaled) abscissa value defined in table";
    parameter Real 'table1.combiTimeTable.t_maxScaled' = 'Modelica.Blocks.Tables.Internal.getTimeTableTmax'('table1.combiTimeTable.tableID') "Maximum (scaled) abscissa value defined in table";
    parameter Real 'table1.combiTimeTable.p_offset[1]' = 0.0 "Offsets of output signals";
    parameter 'Modelica.Blocks.Types.ExternalCombiTimeTable' 'table1.combiTimeTable.tableID' = 'Modelica.Blocks.Types.ExternalCombiTimeTable'("NoName", "NoName", {{0.05, 0.0}, {0.05, 1.0}, {0.15, 0.0}}, -1e60, {2}, 'Modelica.Blocks.Types.Smoothness'.'ConstantSegments', 'Modelica.Blocks.Types.Extrapolation'.'HoldLastPoint', 0.0, 'Modelica.Blocks.Types.TimeEvents'.'Always', false, ",", 0) "External table object";
    discrete Real 'table1.combiTimeTable.nextTimeEvent'(fixed = true, start = 0.0, unit = "s", quantity = "Time") "Next time event instant";
    discrete Real 'table1.combiTimeTable.nextTimeEventScaled'(fixed = true, start = 0.0) "Next scaled time event instant";
    Real 'table1.combiTimeTable.timeScaled' "Scaled time";
    parameter Boolean 'table1.combiTimeTable.isCsvExt' = false;
    Real 'table1.realToBoolean.u' "Connector of Real input signal";
    Boolean 'table1.realToBoolean.y' "Connector of Boolean output signal";
    parameter Real 'table1.realToBoolean.threshold' = 0.5 "Output signal y is true, if input u >= threshold";
    parameter Integer 'table1.n' = 2 "Number of table points";
    Boolean 'and1.u1' "Connector of first Boolean input signal";
    Boolean 'and1.u2' "Connector of second Boolean input signal";
    Boolean 'and1.y' "Connector of Boolean output signal";
  equation
    'table1.combiTimeTable.y[1]' = 'table1.realToBoolean.u';
    'table1.realToBoolean.y' = 'table1.y';
    'periodicClock.y' = 'sample1.clock';
    'table1.y' = 'sample1.u';
    'upSample2.u' = 'sample1.y';
    'upSample2.u' = 'upSample1.u';
    'upSample1.y' = 'and1.u1';
    'upSample2.y' = 'and1.u2';
    'periodicClock.c' = Clock('periodicClock.factor', 1000);
    'periodicClock.y' = 'periodicClock.c';
    'sample1.y' = sample('sample1.u', 'sample1.clock');

    when Clock() then
      'upSample1.dummy' = 'upSample1.u';
      'upSample1.b' = not previous('upSample1.b');
    end when;

    when Clock() then
      'upSample1.b_super' = superSample('upSample1.b', 0);
      'upSample1.u_super' = superSample('upSample1.u', 0);
      'upSample1.y' = if 'upSample1.b_super' <> previous('upSample1.b_super') then 'upSample1.u_super' else false;
    end when;

    when Clock() then
      'upSample2.dummy' = 'upSample2.u';
      'upSample2.b' = not previous('upSample2.b');
    end when;

    when Clock() then
      'upSample2.b_super' = superSample('upSample2.b', 0);
      'upSample2.u_super' = superSample('upSample2.u', 3);
      'upSample2.y' = if 'upSample2.b_super' <> previous('upSample2.b_super') then 'upSample2.u_super' else false;
    end when;

    'table1.combiTimeTable.timeScaled' = time;

    when {time >= pre('table1.combiTimeTable.nextTimeEvent'), initial()} then
      'table1.combiTimeTable.nextTimeEventScaled' = 'Modelica.Blocks.Tables.Internal.getNextTimeEvent'('table1.combiTimeTable.tableID', 'table1.combiTimeTable.timeScaled');
      'table1.combiTimeTable.nextTimeEvent' = if 'table1.combiTimeTable.nextTimeEventScaled' < 1e60 then 'table1.combiTimeTable.nextTimeEventScaled' else 1e60;
    end when;

    'table1.combiTimeTable.y[1]' = 'Modelica.Blocks.Tables.Internal.getTimeTableValueNoDer'('table1.combiTimeTable.tableID', 1, 'table1.combiTimeTable.timeScaled', 'table1.combiTimeTable.nextTimeEventScaled', pre('table1.combiTimeTable.nextTimeEventScaled'));
    'table1.realToBoolean.y' = 'table1.realToBoolean.u' >= 0.5;
    'and1.y' = 'and1.u1' and 'and1.u2';
    annotation(experiment(StopTime = 0.09));
  end 'UpSample';
end 'UpSample';
