    Real 'world.x_label.n_y[1]'(unit = "1") "Vector in direction of y-axis of 'lines' frame, resolved in object frame";
    Real 'world.x_label.n_y[2]'(unit = "1") "Vector in direction of y-axis of 'lines' frame, resolved in object frame";
    Real 'world.x_label.n_y[3]'(unit = "1") "Vector in direction of y-axis of 'lines' frame, resolved in object frame";
    Real 'world.x_label.lines[1,1,1]'(unit = "m", quantity = "Length") "List of start and end points of cylinders resolved in an x-y frame defined by n_x, n_y, e.g., {[0,0;1,1], [0,1;1,0], [2,0; 3,1]}";
