    Real 'world.x_label.r[1]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_label.r[2]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_label.r[3]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_label.r_lines[1]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to the origin of 'lines' frame, resolved in object frame";
    Real 'world.x_label.r_lines[2]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to the origin of 'lines' frame, resolved in object frame";
    Real 'world.x_label.r_lines[3]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to the origin of 'lines' frame, resolved in object frame";
    Real 'world.x_label.n_x[1]'(unit = "1") "Vector in direction of x-axis of 'lines' frame, resolved in object frame";
    Real 'world.x_label.n_x[2]'(unit = "1") "Vector in direction of x-axis of 'lines' frame, resolved in object frame";
