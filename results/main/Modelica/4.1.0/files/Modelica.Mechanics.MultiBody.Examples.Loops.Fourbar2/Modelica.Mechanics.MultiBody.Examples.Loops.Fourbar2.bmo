    Real 'world.x_arrowLine.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.x_arrowLine.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.x_arrowLine.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.x_arrowLine.r[1]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_arrowLine.r[2]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_arrowLine.r[3]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_arrowLine.r_shape[1]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'world.x_arrowLine.r_shape[2]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'world.x_arrowLine.r_shape[3]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'world.x_arrowLine.lengthDirection[1]' "Vector in length direction, resolved in object frame";
    Real 'world.x_arrowLine.lengthDirection[2]' "Vector in length direction, resolved in object frame";
    Real 'world.x_arrowLine.lengthDirection[3]' "Vector in length direction, resolved in object frame";
    Real 'world.x_arrowLine.widthDirection[1]' "Vector in width direction, resolved in object frame";
    Real 'world.x_arrowLine.widthDirection[2]' "Vector in width direction, resolved in object frame";
    Real 'world.x_arrowLine.widthDirection[3]' "Vector in width direction, resolved in object frame";
    Real 'world.x_arrowLine.length'(unit = "m", quantity = "Length") "Length of visual object";
    Real 'world.x_arrowLine.width'(unit = "m", quantity = "Length") "Width of visual object";
    Real 'world.x_arrowLine.height'(unit = "m", quantity = "Length") "Height of visual object";
    Real 'world.x_arrowLine.extra' "Additional size data for some of the shape types";
    Real 'world.x_arrowLine.color[1]' "Color of shape";
    Real 'world.x_arrowLine.color[2]' "Color of shape";
    Real 'world.x_arrowLine.color[3]' "Color of shape";
    Real 'world.x_arrowLine.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter String 'world.x_arrowHead.shapeType' = "cone" "Type of shape (box, sphere, cylinder, pipecylinder, cone, pipe, beam, gearwheel, spring, <external shape>)";
    Real 'world.x_arrowHead.R.T[1,1]' "Transformation matrix from world frame to local frame";
