    'pipe4.mXis[3,1]' = 'pipe4.ms[3]' * 'pipe4.mediums[3].Xi[1]';
    'pipe4.Us[3]' = 'pipe4.ms[3]' * 'pipe4.mediums[3].u';
    'pipe4.ms[4]' = 'pipe4.fluidVolumes[4]' * 'pipe4.mediums[4].d';
    'pipe4.mXis[4,1]' = 'pipe4.ms[4]' * 'pipe4.mediums[4].Xi[1]';
    'pipe4.Us[4]' = 'pipe4.ms[4]' * 'pipe4.mediums[4].u';
    'pipe4.ms[5]' = 'pipe4.fluidVolumes[5]' * 'pipe4.mediums[5].d';
    'pipe4.mXis[5,1]' = 'pipe4.ms[5]' * 'pipe4.mediums[5].Xi[1]';
    'pipe4.Us[5]' = 'pipe4.ms[5]' * 'pipe4.mediums[5].u';
    der('pipe4.Us[1]') = 'pipe4.Hb_flows[1]' + 'pipe4.Wb_flows[1]' + 'pipe4.Qb_flows[1]';
    der('pipe4.Us[2]') = 'pipe4.Hb_flows[2]' + 'pipe4.Wb_flows[2]' + 'pipe4.Qb_flows[2]';
    der('pipe4.Us[3]') = 'pipe4.Hb_flows[3]' + 'pipe4.Wb_flows[3]' + 'pipe4.Qb_flows[3]';
    der('pipe4.Us[4]') = 'pipe4.Hb_flows[4]' + 'pipe4.Wb_flows[4]' + 'pipe4.Qb_flows[4]';
    der('pipe4.Us[5]') = 'pipe4.Hb_flows[5]' + 'pipe4.Wb_flows[5]' + 'pipe4.Qb_flows[5]';
    der('pipe4.ms[1]') = 'pipe4.mb_flows[1]';
    der('pipe4.ms[2]') = 'pipe4.mb_flows[2]';
    der('pipe4.ms[3]') = 'pipe4.mb_flows[3]';
    der('pipe4.ms[4]') = 'pipe4.mb_flows[4]';
    der('pipe4.ms[5]') = 'pipe4.mb_flows[5]';
    der('pipe4.mXis[1,1]') = 'pipe4.mbXi_flows[1,1]';
    der('pipe4.mXis[2,1]') = 'pipe4.mbXi_flows[2,1]';
    der('pipe4.mXis[3,1]') = 'pipe4.mbXi_flows[3,1]';
    der('pipe4.mXis[4,1]') = 'pipe4.mbXi_flows[4,1]';
    der('pipe4.mXis[5,1]') = 'pipe4.mbXi_flows[5,1]';
    assert('boundary4.medium.T' >= 190.0 and 'boundary4.medium.T' <= 647.0, "\nTemperature T is not in the allowed range\n190.0 K <= (T =" + String('boundary4.medium.T') + " K) <= 647.0 K\nrequired from medium model \"" + "Moist air" + "\".", AssertionLevel.error);
    'boundary4.medium.MM' = 1.0 / ('boundary4.medium.Xi[1]' / 0.01801528 + (1.0 - 'boundary4.medium.Xi[1]') / 0.0289651159);
    'boundary4.medium.p_steam_sat' = min('Modelica.Fluid.Examples.BranchingDynamicPipes.boundary4.Medium.saturationPressure'('boundary4.medium.T'), 0.999 * 'boundary4.medium.p');
    'boundary4.medium.X_sat' = min('boundary4.medium.p_steam_sat' * 0.6219647130774989 / max(2.220446049250313e-14, 'boundary4.medium.p' - 'boundary4.medium.p_steam_sat') * (1.0 - 'boundary4.medium.Xi[1]'), 1.0) "Water content at saturation with respect to actual water content";
    'boundary4.medium.X_liquid' = max('boundary4.medium.Xi[1]' - 'boundary4.medium.X_sat', 0.0);
    'boundary4.medium.X_steam' = 'boundary4.medium.Xi[1]' - 'boundary4.medium.X_liquid';
    'boundary4.medium.X_air' = 1.0 - 'boundary4.medium.Xi[1]';
    'boundary4.medium.h' = 'Modelica.Fluid.Examples.BranchingDynamicPipes.boundary4.Medium.specificEnthalpy_pTX'('boundary4.medium.p', 'boundary4.medium.T', {'boundary4.medium.Xi[1]'});
    'boundary4.medium.R_s' = 287.0525368759184 * ('boundary4.medium.X_air' / (1.0 - 'boundary4.medium.X_liquid')) + 461.5254384056201 * 'boundary4.medium.X_steam' / (1.0 - 'boundary4.medium.X_liquid');
    'boundary4.medium.u' = 'boundary4.medium.h' - 'boundary4.medium.R_s' * 'boundary4.medium.T';
    'boundary4.medium.d' = 'boundary4.medium.p' / ('boundary4.medium.R_s' * 'boundary4.medium.T');
    'boundary4.medium.state.p' = 'boundary4.medium.p';
    'boundary4.medium.state.T' = 'boundary4.medium.T';
    'boundary4.medium.state.X[1]' = 'boundary4.medium.X[1]';
    'boundary4.medium.state.X[2]' = 'boundary4.medium.X[2]';
    'boundary4.medium.x_sat' = 0.6219647130774989 * 'boundary4.medium.p_steam_sat' / max(2.220446049250313e-14, 'boundary4.medium.p' - 'boundary4.medium.p_steam_sat');
    'boundary4.medium.x_water' = 'boundary4.medium.Xi[1]' / max('boundary4.medium.X_air', 2.220446049250313e-14);
    'boundary4.medium.phi' = 'boundary4.medium.p' / 'boundary4.medium.p_steam_sat' * 'boundary4.medium.Xi[1]' / ('boundary4.medium.Xi[1]' + 0.6219647130774989 * 'boundary4.medium.X_air');
    'boundary4.medium.Xi[1]' = 'boundary4.medium.X[1]';
    'boundary4.medium.X[2]' = 1.0 - 'boundary4.medium.Xi[1]';
    assert('boundary4.medium.X[1]' >= (-1e-5) and 'boundary4.medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('boundary4.medium.X[1]') + "of substance " + "water" + "\nof medium " + "Moist air" + " is not in the range 0..1", AssertionLevel.error);
    assert('boundary4.medium.X[2]' >= (-1e-5) and 'boundary4.medium.X[2]' <= 1.00001, "Mass fraction X[" + String(2) + "] = " + String('boundary4.medium.X[2]') + "of substance " + "air" + "\nof medium " + "Moist air" + " is not in the range 0..1", AssertionLevel.error);
    assert('boundary4.medium.p' >= 0.0, "Pressure (= " + String('boundary4.medium.p') + " Pa) of medium \"" + "Moist air" + "\" is negative\n(Temperature = " + String('boundary4.medium.T') + " K)", AssertionLevel.error);
    'Modelica.Fluid.Utilities.checkBoundary'("Moist air", {"water", "air"}, false, true, {'boundary4.X_in_internal[1]', 'boundary4.X_in_internal[2]'}, "Boundary_pT");
    'boundary4.T_in_internal' = 293.15;
    'boundary4.X_in_internal[1]' = 0.01;
    'boundary4.X_in_internal[2]' = 0.99;
    'boundary4.medium.p' = 'boundary4.p_in_internal';
    'boundary4.medium.T' = 'boundary4.T_in_internal';
    'boundary4.medium.Xi[1]' = 'boundary4.X_in_internal[1]';
    'boundary4.ports[1].p' = 'boundary4.medium.p';
    'boundary4.ports[1].h_outflow' = 'boundary4.medium.h';
    'boundary4.ports[1].Xi_outflow[1]' = 'boundary4.medium.Xi[1]';
    'ramp1.y' = 1e5 + (if time < 2.0 then 0.0 else if time < 2.0 then (time - 2.0) * 1e5 / 0.0 else 1e5);
    'heat2[1].port.Q_flow' = -40.0 * (1.0 + (-0.01) * ('heat2[1].port.T' - 293.15));
    'heat2[2].port.Q_flow' = -40.0 * (1.0 + (-0.01) * ('heat2[2].port.T' - 293.15));
    'heat2[3].port.Q_flow' = -40.0 * (1.0 + (-0.01) * ('heat2[3].port.T' - 293.15));
    'heat2[4].port.Q_flow' = -40.0 * (1.0 + (-0.01) * ('heat2[4].port.T' - 293.15));
    'heat2[5].port.Q_flow' = -40.0 * (1.0 + (-0.01) * ('heat2[5].port.T' - 293.15));
    annotation(experiment(StopTime = 10));
  end 'BranchingDynamicPipes';
end 'BranchingDynamicPipes';
