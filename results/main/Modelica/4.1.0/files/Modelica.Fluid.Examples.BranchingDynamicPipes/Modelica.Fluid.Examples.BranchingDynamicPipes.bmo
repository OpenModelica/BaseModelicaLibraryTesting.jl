  initial equation
    'pipe1.flowModel.dp_nominal' = 1000.0 * 'pipe1.flowModel.dp_small';
    'pipe1.flowModel.dp_small' = 1.0;
    der('pipe1.flowModel.m_flows[1]') = 0.0;
