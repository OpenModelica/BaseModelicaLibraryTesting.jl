  model 'BranchingDynamicPipes' "Multi-way connections of pipes with dynamic momentum balance, pressure wave and flow reversal"
    parameter Real 'system.p_ambient'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default ambient pressure";
    parameter Real 'system.T_ambient'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default ambient temperature";
    parameter Real 'system.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Boolean 'system.allowFlowReversal' = true "= false to restrict to design flow direction (port_a -> port_b)" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.energyDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Default formulation of energy balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.massDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Default formulation of mass balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.substanceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Default formulation of substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.traceDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Default formulation of trace substance balances" annotation(Evaluate = true);
    parameter 'Modelica.Fluid.Types.Dynamics' 'system.momentumDynamics' = 'Modelica.Fluid.Types.Dynamics'.'SteadyStateInitial' "Default formulation of momentum balances, if options available" annotation(Evaluate = true);
    parameter Real 'system.m_flow_start'(unit = "kg/s", quantity = "MassFlowRate") = 0.0 "Default start value for mass flow rates";
    parameter Real 'system.p_start'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 101325.0 "Default start value for pressures";
    parameter Real 'system.T_start'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Default start value for temperatures";
    parameter Boolean 'system.use_eps_Re' = false "= true to determine turbulent region automatically using Reynolds number" annotation(Evaluate = true);
    parameter Real 'system.m_flow_nominal'(unit = "kg/s", quantity = "MassFlowRate") = 1.0 "Default nominal mass flow rate";
    parameter Real 'system.eps_m_flow'(min = 0.0) = 1e-4 "Regularization of zero flow for |m_flow| < eps_m_flow*m_flow_nominal";
    parameter Real 'system.dp_small'(nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.0 "Default small pressure drop for regularization of laminar and zero flow";
    parameter Real 'system.m_flow_small'(min = 0.0, unit = "kg/s", quantity = "MassFlowRate") = 0.01 "Default small mass flow rate for regularization of laminar and zero flow";
    parameter Integer 'boundary1.nPorts' = 1 "Number of ports";
    Real 'boundary1.medium.p'(stateSelect = StateSelect.default, nominal = 1e5, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'boundary1.medium.Xi[1]'(stateSelect = StateSelect.default, start = 0.01, max = 1.0, min = 0.0, unit = "1", quantity = "MassFraction") "Structurally independent mass fractions";
    Real 'boundary1.medium.h'(unit = "J/kg", quantity = "SpecificEnergy") "Specific enthalpy of medium";
    Real 'boundary1.medium.d'(nominal = 1.0, start = 1.0, max = 1e5, min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") "Density of medium";
    Real 'boundary1.medium.T'(stateSelect = StateSelect.default, nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'boundary1.medium.X[1]'(nominal = 0.1, start = 0.01, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'boundary1.medium.X[2]'(nominal = 0.1, start = 0.99, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'boundary1.medium.u'(nominal = 1e6, max = 1e8, min = -1e8, unit = "J/kg", quantity = "SpecificEnergy") "Specific internal energy of medium";
    Real 'boundary1.medium.R_s'(nominal = 1000.0, start = 1000.0, max = 1e7, min = 0.0, unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") "Gas constant (of mixture if applicable)";
    Real 'boundary1.medium.MM'(nominal = 0.032, max = 0.25, min = 0.001, unit = "kg/mol", quantity = "MolarMass") "Molar mass (of mixture or single fluid)";
    Real 'boundary1.medium.state.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Absolute pressure of medium";
    Real 'boundary1.medium.state.T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of medium";
    Real 'boundary1.medium.state.X[1]'(nominal = 0.1, start = 0.01, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    Real 'boundary1.medium.state.X[2]'(nominal = 0.1, start = 0.99, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fractions (= (component mass)/total mass  m_i/m)";
    parameter Boolean 'boundary1.medium.preferredMediumStates' = false "= true, if StateSelect.prefer shall be used for the independent property variables of the medium" annotation(Evaluate = true);
    parameter Boolean 'boundary1.medium.standardOrderComponents' = true "If true, and reducedX = true, the last element of X will be computed from the other ones";
    Real 'boundary1.medium.T_degC'(unit = "degC", quantity = "ThermodynamicTemperature") "Temperature of medium in [degC]";
    Real 'boundary1.medium.p_bar'(unit = "bar", quantity = "Pressure") "Absolute pressure of medium in [bar]";
    Real 'boundary1.medium.x_water'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass of total water/mass of dry air";
    Real 'boundary1.medium.phi' "Relative humidity";
    Real 'boundary1.medium.X_liquid'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fraction of liquid or solid water";
    Real 'boundary1.medium.X_steam'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fraction of steam water";
    Real 'boundary1.medium.X_air'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Mass fraction of air";
    Real 'boundary1.medium.X_sat'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Steam water mass fraction of saturation boundary in kg_water/kg_moistair";
    Real 'boundary1.medium.x_sat'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Steam water mass content of saturation boundary in kg_water/kg_dryair";
    Real 'boundary1.medium.p_steam_sat'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Partial saturation pressure of steam";
    Real 'boundary1.ports[1].m_flow'(max = 1e60, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rate from the connection point into the component";
    Real 'boundary1.ports[1].p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'boundary1.ports[1].h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'boundary1.ports[1].Xi_outflow[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
    parameter 'Modelica.Fluid.Types.PortFlowDirection' 'boundary1.flowDirection' = 'Modelica.Fluid.Types.PortFlowDirection'.'Bidirectional' "Allowed flow direction" annotation(Evaluate = true);
    parameter Boolean 'boundary1.use_p_in' = false "Get the pressure from the input connector" annotation(Evaluate = true);
    parameter Boolean 'boundary1.use_T_in' = false "Get the temperature from the input connector" annotation(Evaluate = true);
    parameter Boolean 'boundary1.use_X_in' = false "Get the composition from the input connector" annotation(Evaluate = true);
    parameter Boolean 'boundary1.use_C_in' = false "Get the trace substances from the input connector" annotation(Evaluate = true);
    parameter Real 'boundary1.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") = 1.5e5 "Fixed value of pressure";
    parameter Real 'boundary1.T'(nominal = 300.0, start = 288.15, max = 647.0, min = 190.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed value of temperature";
    parameter Real 'boundary1.X[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 0.01 "Fixed value of composition";
    parameter Real 'boundary1.X[2]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") = 0.99 "Fixed value of composition";
    Real 'boundary1.p_in_internal'(unit = "Pa") "Needed to connect to conditional connector";
    Real 'boundary1.T_in_internal'(unit = "K") "Needed to connect to conditional connector";
    Real 'boundary1.X_in_internal[1]'(unit = "1") "Needed to connect to conditional connector";
    Real 'boundary1.X_in_internal[2]'(unit = "1") "Needed to connect to conditional connector";
    parameter Boolean 'pipe1.allowFlowReversal' = true "= true to allow flow reversal, false restricts to design direction (port_a -> port_b)" annotation(Evaluate = true);
    Real 'pipe1.port_a.m_flow'(max = 1e5, min = -1e60, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rate from the connection point into the component";
    Real 'pipe1.port_a.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe1.port_a.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'pipe1.port_a.Xi_outflow[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
    Real 'pipe1.port_b.m_flow'(max = 1e60, min = -1e5, unit = "kg/s", quantity = "MassFlowRate.Moist air") "Mass flow rate from the connection point into the component";
    Real 'pipe1.port_b.p'(nominal = 1e5, start = 1e5, max = 1e8, min = 0.0, displayUnit = "bar", unit = "Pa", quantity = "Pressure") "Thermodynamic pressure in the connection point";
    Real 'pipe1.port_b.h_outflow'(nominal = 1e6, max = 1e10, min = -1e10, unit = "J/kg", quantity = "SpecificEnergy") "Specific thermodynamic enthalpy close to the connection point if m_flow < 0";
    Real 'pipe1.port_b.Xi_outflow[1]'(nominal = 0.1, max = 1.0, min = 0.0, unit = "kg/kg", quantity = "MassFraction") "Independent mixture mass fractions m_i/m close to the connection point if m_flow < 0";
    parameter Boolean 'pipe1.port_a_exposesState' = false "= true if port_a exposes the state of a fluid volume";
    parameter Boolean 'pipe1.port_b_exposesState' = false "= true if port_b.p exposes the state of a fluid volume";
