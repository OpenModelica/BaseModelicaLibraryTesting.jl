 ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).cv / ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).dpT + 1.0) / (('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).dpT * ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).T) else -('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).rho * ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).rho * (('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).vp * ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).cp - ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).vt / ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).rho + ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).T * ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).vt * ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).vt) / ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.bubble2.p', 'medium.bubble2.h', 'medium.bubble2.phase', 0)).cp;
    'medium.dTp' = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.dtsatofp'('medium.p');
    'medium.dTp2' = (1.0 / 'medium.dew.d' - 1.0 / 'medium.bubble.d') / max('medium.s_d' - 'medium.s_b', 1e-6);
    'medium.MM' = 0.018015268;
    'medium.phase' = if ('medium.h' < ('Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.boilingcurve_p'('medium.sat.psat')).h or 'medium.h' > ('Modelica.Media.Water.IF97_Utilities.BaseIF97.Regions.dewcurve_p'('medium.sat.psat')).h) or 'medium.p' > 2.2064e7 then 1 else 2;
    'medium.d' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.p', 'medium.h', 'medium.phase', 0)).rho;
    'medium.T' = ('Modelica.Media.Water.IF97_Utilities.waterBaseProp_ph'('medium.p', 'medium.h', 'medium.phase', 0)).T;
    'medium.sat.Tsat' = 'Modelica.Media.Water.IF97_Utilities.BaseIF97.Basic.tsat'('medium.p');
    'medium.sat.psat' = 'medium.p';
    'medium.u' = 'medium.h' - 'medium.p' / 'medium.d';
    'medium.R_s' = 461.5231157345669;
    'medium.h' = 'medium.state.h';
    'medium.p' = 'medium.state.p';
    'medium.T' = 'medium.state.T';
    'medium.d' = 'medium.state.d';
    'medium.phase' = 'medium.state.phase';
    'medium.X[1]' = 1.0;
    assert('medium.X[1]' >= (-1e-5) and 'medium.X[1]' <= 1.00001, "Mass fraction X[" + String(1) + "] = " + String('medium.X[1]') + "of substance " + "water" + "\nof medium " + "WaterIF97" + " is not in the range 0..1", AssertionLevel.error);
    assert('medium.p' >= 0.0, "Pressure (= " + String('medium.p') + " Pa) of medium \"" + "WaterIF97" + "\" is negative\n(Temperature = " + String('medium.T') + " K)", AssertionLevel.error);
    der('medium.p') = 1e6;
    der('medium.h') = 8e4;
    annotation(experiment(StopTime = 22, Interval = 0.01));
  end 'TestTwoPhaseStates';
end 'TestTwoPhaseStates';
