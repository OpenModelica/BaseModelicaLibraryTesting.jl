    parameter Boolean 'sine.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine.y' "Connector of Real output signal";
    parameter Real 'sine.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    constant Integer 'pwm.m' = 3 "Number of phases";
    parameter 'Modelica.Electrical.PowerConverters.Types.PWMType' 'pwm.pwmType' = 'Modelica.Electrical.PowerConverters.Types.PWMType'.'SVPWM' "PWM Type" annotation(Evaluate = true);
    parameter Real 'pwm.f'(unit = "Hz", quantity = "Frequency") = 100.0 "Switching frequency";
    parameter Real 'pwm.startTime'(unit = "s", quantity = "Time") = 0.0 "Start time of PWM";
    parameter Real 'pwm.uMax' = 2.449489742783178 "Maximum amplitude of signal";
