//! base 0.1.0
package 'ThreePhaseTwoLevel_PWM'
  function 'Modelica.Blocks.Continuous.Internal.Filter.coefficients.lowPass' "Return low pass filter coefficients at given cut-off frequency"
    input Real[:] 'cr_in';
    input Real[:] 'c0_in';
    input Real[size('c0_in', 1)] 'c1_in';
    input Real 'f_cut'(unit = "Hz", quantity = "Frequency");
    output Real[size('cr_in', 1)] 'cr';
    output Real[size('c0_in', 1)] 'c0';
    output Real[size('c0_in', 1)] 'c1';
    Real 'w_cut'(unit = "rad/s", quantity = "AngularVelocity") = 6.283185307179586 * 'f_cut';
    Real 'w_cut2' = 'w_cut' * 'w_cut';
  algorithm
    assert('f_cut' > 0.0, "Cut-off frequency f_cut must be positive", AssertionLevel.error);
    'cr' := 'w_cut' * 'cr_in';
    'c1' := 'w_cut' * 'c1_in';
    'c0' := 'w_cut2' * 'c0_in';
  end 'Modelica.Blocks.Continuous.Internal.Filter.coefficients.lowPass';

  function 'Modelica.Blocks.Continuous.Internal.Filter.roots.lowPass' "Return low pass filter roots as needed for block for given cut-off frequency"
    input Real[:] 'cr_in';
    input Real[:] 'c0_in';
    input Real[size('c0_in', 1)] 'c1_in';
    input Real 'f_cut'(unit = "Hz", quantity = "Frequency");
    output Real[size('cr_in', 1)] 'r';
    output Real[size('c0_in', 1)] 'a';
    output Real[size('c0_in', 1)] 'b';
    output Real[size('c0_in', 1)] 'ku';
    Real[size('c0_in', 1)] 'c0';
    Real[size('c0_in', 1)] 'c1';
    Real[size('cr_in', 1)] 'cr';
  algorithm
    ('cr', 'c0', 'c1') := 'Modelica.Blocks.Continuous.Internal.Filter.coefficients.lowPass'('cr_in', 'c0_in', 'c1_in', 'f_cut');

    for 'i' in 1:size('cr_in', 1) loop
      'r'['i'] := -'cr'['i'];
    end for;

    for 'i' in 1:size('c0_in', 1) loop
      'a'['i'] := -'c1'['i'] / 2.0;
      'b'['i'] := sqrt('c0'['i'] - 'a'['i'] * 'a'['i']);
      'ku'['i'] := 'c0'['i'] / 'b'['i'];
    end for;
  end 'Modelica.Blocks.Continuous.Internal.Filter.roots.lowPass';

  type 'Modelica.Electrical.PowerConverters.Types.PWMType' = enumeration('SVPWM', 'Intersective');

  type 'Modelica.Electrical.PowerConverters.Types.ReferenceType' = enumeration('Sawtooth1', 'Sawtooth3', 'Triangle1', 'Triangle3');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  type 'Modelica.Blocks.Types.AnalogFilter' = enumeration('CriticalDamping', 'Bessel', 'Butterworth', 'ChebyshevI');

  type 'Modelica.Blocks.Types.FilterType' = enumeration('LowPass', 'HighPass', 'BandPass', 'BandStop');

  model 'ThreePhaseTwoLevel_PWM' "Test of pulse width modulation methods"
    parameter Real 'RMS' = 1.0 "Reference RMS Y";
    parameter Real 'cosine.amplitude' = 1.4142135623730951 "Amplitude of cosine wave";
    parameter Real 'cosine.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of cosine wave";
    parameter Real 'cosine.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of cosine wave";
    parameter Boolean 'cosine.continuous' = false "Make output continuous by starting at offset + amplitude*cos(phase)" annotation(Evaluate = true);
    Real 'cosine.y' "Connector of Real output signal";
    parameter Real 'cosine.offset' = 0.0 "Offset of output signal y";
    parameter Real 'cosine.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sine.amplitude' = 1.4142135623730951 "Amplitude of sine wave";
    parameter Real 'sine.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of sine wave";
