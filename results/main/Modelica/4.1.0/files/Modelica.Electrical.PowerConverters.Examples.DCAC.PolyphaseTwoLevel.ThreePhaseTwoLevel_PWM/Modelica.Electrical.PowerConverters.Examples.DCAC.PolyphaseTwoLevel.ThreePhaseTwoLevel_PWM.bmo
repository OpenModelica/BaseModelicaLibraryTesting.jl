    parameter Real 'multiPhase2Level.transistor_p.T[3]'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperatures if useHeatPort = false";
    Boolean 'multiPhase2Level.transistor_p.fire[1]';
    Boolean 'multiPhase2Level.transistor_p.fire[2]';
    Boolean 'multiPhase2Level.transistor_p.fire[3]';
    Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'multiPhase2Level.transistor_p.idealGTOThyristor[1].useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'multiPhase2Level.transistor_p.idealGTOThyristor[1].T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'multiPhase2Level.transistor_p.idealGTOThyristor[1].off'(start = true) "Switching state";
