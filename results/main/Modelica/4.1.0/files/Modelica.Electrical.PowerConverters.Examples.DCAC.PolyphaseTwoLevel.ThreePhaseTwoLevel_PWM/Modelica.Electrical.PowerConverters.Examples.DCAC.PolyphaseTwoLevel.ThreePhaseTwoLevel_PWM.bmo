    discrete Real 'pwm.svPWM.T0'(fixed = true, start = 0.0, unit = "s", quantity = "Time") "Start time of switching interval";
    parameter Boolean 'multiPhase2Level.useConstantEnable' = true "Disable boolean input and use constantEnable, if true";
