    'potentialSensor.potentialSensor[2].phi' = 'potentialSensor.potentialSensor[2].p.v';
    'potentialSensor.potentialSensor[3].p.i' = 0.0;
    'potentialSensor.potentialSensor[3].phi' = 'potentialSensor.potentialSensor[3].p.v';
    'harmonic.sin1.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * cos(12.566370614359172 * time);
    'harmonic.sin2.y' = if time < 0.0 then 0.0 else 1.4142135623730951 * sin(12.566370614359172 * time);
    'harmonic.product1.y' = 'harmonic.product1.u[1]' * 'harmonic.product1.u[2]';
    'harmonic.product2.y' = 'harmonic.product2.u[1]' * 'harmonic.product2.u[2]';
    der('harmonic.mean1.x') = 'harmonic.mean1.u';

    when sample('harmonic.mean1.t0' + 0.5, 0.5) then
      'harmonic.mean1.y_last' = 2.0 * pre('harmonic.mean1.x');
      reinit('harmonic.mean1.x', 0.0);
    end when;

    'harmonic.mean1.y' = 'harmonic.mean1.y_last';
    der('harmonic.mean2.x') = 'harmonic.mean2.u';

    when sample('harmonic.mean2.t0' + 0.5, 0.5) then
      'harmonic.mean2.y_last' = 2.0 * pre('harmonic.mean2.x');
      reinit('harmonic.mean2.x', 0.0);
    end when;

    'harmonic.mean2.y' = 'harmonic.mean2.y_last';
    'harmonic.rectangularToPolar.y_abs' = sqrt('harmonic.rectangularToPolar.u_re' * 'harmonic.rectangularToPolar.u_re' + 'harmonic.rectangularToPolar.u_im' * 'harmonic.rectangularToPolar.u_im');
    'harmonic.rectangularToPolar.y_arg' = atan2('harmonic.rectangularToPolar.u_im', 'harmonic.rectangularToPolar.u_re');
    'harmonic.gain.y' = 'harmonic.gain.u';
    3.0 * 'toSpacePhasor.zero' = 'toSpacePhasor.u[1]' + 'toSpacePhasor.u[2]' + 'toSpacePhasor.u[3]';
    'toSpacePhasor.y[1]' = 0.6666666666666666 * 'toSpacePhasor.u[1]' + (-0.33333333333333315) * 'toSpacePhasor.u[2]' + (-0.3333333333333336) * 'toSpacePhasor.u[3]';
    'toSpacePhasor.y[2]' = 0.5773502691896257 * 'toSpacePhasor.u[2]' + (-0.5773502691896255) * 'toSpacePhasor.u[3]';
    'rotator.RotationMatrix[1,1]' = cos(-'rotator.angle');
    'rotator.RotationMatrix[1,2]' = -sin(-'rotator.angle');
    'rotator.RotationMatrix[2,1]' = sin(-'rotator.angle');
    'rotator.RotationMatrix[2,2]' = cos(-'rotator.angle');
    'rotator.y[1]' = 'rotator.RotationMatrix[1,1]' * 'rotator.u[1]' + 'rotator.RotationMatrix[1,2]' * 'rotator.u[2]';
    'rotator.y[2]' = 'rotator.RotationMatrix[2,1]' * 'rotator.u[1]' + 'rotator.RotationMatrix[2,2]' * 'rotator.u[2]';
    'const.y' = 2.0;
    'integrator.local_reset' = false;
    'integrator.local_set' = 0.0;
    der('integrator.y') = 6.283185307179586 * 'integrator.u';
    'filter[1].uu[1]' = 'filter[1].u';
    der('filter[1].x[1]') = 'filter[1].r[1]' * ('filter[1].x[1]' - 'filter[1].uu[1]');
    der('filter[1].x[2]') = 'filter[1].r[2]' * ('filter[1].x[2]' - 'filter[1].uu[2]');
    'filter[1].uu[2]' = 'filter[1].x[1]';
    'filter[1].uu[3]' = 'filter[1].x[2]';
    'filter[1].y' = 'filter[1].uu[3]';
    'filter[2].uu[1]' = 'filter[2].u';
    der('filter[2].x[1]') = 'filter[2].r[1]' * ('filter[2].x[1]' - 'filter[2].uu[1]');
    der('filter[2].x[2]') = 'filter[2].r[2]' * ('filter[2].x[2]' - 'filter[2].uu[2]');
    'filter[2].uu[2]' = 'filter[2].x[1]';
    'filter[2].uu[3]' = 'filter[2].x[2]';
    'filter[2].y' = 'filter[2].uu[3]';
    'toPolar.y[1]' = sqrt('toPolar.u[1]' ^ 2.0 + 'toPolar.u[2]' ^ 2.0);
    'toPolar.y[2]' = if noEvent('toPolar.y[1]' <= 2.2250738585072014e-308) then 0.0 else atan2('toPolar.u[2]', 'toPolar.u[1]');
  algorithm
    when 'pwm.svPWM.sampleTrigger' then
      'pwm.svPWM.uRef' := min(sqrt('pwm.svPWM.u[1]' ^ 2.0 + 'pwm.svPWM.u[2]' ^ 2.0) / 1.6329931618554518, 0.8660254037844387);
      'pwm.svPWM.phiRef' := if 'pwm.svPWM.uRef' < 2.2250738585072014e-308 then 0.0 else atan2('pwm.svPWM.u[2]', 'pwm.svPWM.u[1]');
      'pwm.svPWM.phiPos' := max(0.0, 'pwm.svPWM.phiRef' + (if 'pwm.svPWM.phiRef' < (-1.3951473992034527e-15) then 6.283185307179586 else 0.0));
      'pwm.svPWM.ka' := min(integer('pwm.svPWM.phiPos' / 1.0471975511965976), 5);
      'pwm.svPWM.kb' := mod('pwm.svPWM.ka' + 1, 6);
      'pwm.svPWM.phiSec' := 'pwm.svPWM.phiPos' - 'pwm.svPWM.ka' * 3.141592653589793 / 3.0;
      'pwm.svPWM.tb' := min('pwm.svPWM.uRef' * sin('pwm.svPWM.phiSec') / 0.8660254037844386, 1.0);
      'pwm.svPWM.ta' := min('pwm.svPWM.uRef' * cos('pwm.svPWM.phiSec') - 'pwm.svPWM.tb' * 0.5000000000000001, 1.0);
      'pwm.svPWM.t0' := max(1.0 - 'pwm.svPWM.ta' - 'pwm.svPWM.tb', 0.0);
      'pwm.svPWM.T0' := time;
    end when;
    annotation(experiment(StopTime = 2, Interval = 0.001, Tolerance = 1e-05));
  end 'ThreePhaseTwoLevel_PWM';
end 'ThreePhaseTwoLevel_PWM';
