    constant Integer 'clutch.Free' = 2 "Element is not active";
    constant Integer 'clutch.Forward' = 1 "w_relfric > 0 (forward sliding)";
    constant Integer 'clutch.Stuck' = 0 "w_relfric = 0 (forward sliding, locked or backward sliding)";
    constant Integer 'clutch.Backward' = -1 "w_relfric < 0 (backward sliding)";
