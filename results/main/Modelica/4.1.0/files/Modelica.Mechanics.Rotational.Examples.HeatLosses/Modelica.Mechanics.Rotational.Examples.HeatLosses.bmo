    constant Integer 'lossyGear.Free' = 2 "Element is not active";
    constant Integer 'lossyGear.Forward' = 1 "w_a > 0 (forward rolling)";
    constant Integer 'lossyGear.Stuck' = 0 "w_a = 0 (forward rolling, locked or backward rolling)";
    constant Integer 'lossyGear.Backward' = -1 "w_a < 0 (backward rolling)";
    Integer 'lossyGear.mode'(fixed = true, start = 2, max = 3, min = -1) "Mode of friction element (unknown, not active, forward/backward rolling, stuck)";
    Real 'lossyGear.tau_eta_p'(unit = "N.m", quantity = "Torque") "tau_eta assuming positive omega";
    Real 'lossyGear.tau_eta_m'(unit = "N.m", quantity = "Torque") "tau_eta assuming negative omega";
    constant Real 'lossyGear.unitAngularAcceleration'(unit = "rad/s2", quantity = "AngularAcceleration") = 1.0;
    constant Real 'lossyGear.unitTorque'(unit = "N.m", quantity = "Torque") = 1.0;
    parameter Real 'lossyGear.eta_mf1_0'(unit = "1") = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('lossyGear.tableID', 1, 0.0);
    parameter Real 'lossyGear.eta_mf2_0'(unit = "1") = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('lossyGear.tableID', 2, 0.0);
    parameter Real 'lossyGear.tau_bf1_0'(unit = "N.m", quantity = "Torque") = abs('Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('lossyGear.tableID', 3, 0.0));
    parameter Real 'lossyGear.tau_bf2_0'(unit = "N.m", quantity = "Torque") = abs('Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('lossyGear.tableID', 4, 0.0));
    parameter Real 'lossyGear.tau_bf_a_0'(unit = "N.m", quantity = "Torque") = if abs('lossyGear.eta_mf1_0' - 1.0) <= 2.220446049250313e-16 and abs('lossyGear.eta_mf2_0' - 1.0) <= 2.220446049250313e-16 then 'lossyGear.tau_bf1_0' / 2.0 else ('lossyGear.tau_bf1_0' - 'lossyGear.tau_bf2_0') / ('lossyGear.eta_mf1_0' - 1.0 / 'lossyGear.eta_mf2_0');
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'lossyGear.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 0.8, 0.8, 1.0, 1.0}, {1.0, 0.7, 0.7, 2.0, 2.0}}, {2, 3, 4, 5}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object for sliding friction coefficient";
    Real 'clutch.phi_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'clutch.w_rel'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity (= der(phi_rel))";
    Real 'clutch.a_rel'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration (= der(w_rel))";
    Real 'clutch.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'clutch.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'clutch.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'clutch.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'clutch.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'clutch.phi_nominal'(min = 0.0, displayUnit = "rad", unit = "rad", quantity = "Angle") = 1e-4 "Nominal value of phi_rel (used for scaling)";
    parameter StateSelect 'clutch.stateSelect' = StateSelect.prefer "Priority to use phi_rel and w_rel as states";
    parameter Real 'clutch.mu_pos[1,1]' = 0.0 "Positive sliding friction coefficient [-] as function of w_rel [rad/s] (w_rel>=0)";
    parameter Real 'clutch.mu_pos[1,2]' = 0.5 "Positive sliding friction coefficient [-] as function of w_rel [rad/s] (w_rel>=0)";
    parameter 'Modelica.Blocks.Types.Smoothness' 'clutch.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' "Smoothness of table interpolation in mu_pos";
    parameter Real 'clutch.peak'(min = 1.0) = 1.0 "Peak for maximum value of mu at w==0 (mu0_max = peak*mu_pos[1,2])";
    parameter Real 'clutch.cgeo'(min = 0.0) = 1.0 "Geometry constant containing friction distribution assumption";
    parameter Real 'clutch.fn_max'(start = 1.0, min = 0.0, unit = "N", quantity = "Force") = 10.0 "Maximum normal force";
    parameter Real 'clutch.w_small'(unit = "rad/s", quantity = "AngularVelocity") = 1e10 "Relative angular velocity near to zero if jumps due to a reinit(..) of the velocity can occur (set to low value only if such impulses can occur)";
    Real 'clutch.w_relfric'(unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity between frictional surfaces";
