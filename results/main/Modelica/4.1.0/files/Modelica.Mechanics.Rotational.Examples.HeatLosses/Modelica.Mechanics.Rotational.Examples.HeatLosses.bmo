    Real 'lossyGear.heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'lossyGear.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'lossyGear.phi_a'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between left shaft flange and support";
    Real 'lossyGear.phi_b'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between right shaft flange and support";
    Real 'lossyGear.sa'(unit = "1") "Path parameter for acceleration and torque loss";
    Real 'lossyGear.w_a'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange_a with respect to support";
    Real 'lossyGear.a_a'(unit = "rad/s2", quantity = "AngularAcceleration") "Angular acceleration of flange_a with respect to support";
    Real 'lossyGear.interpolation_result[1,1]' "Result of interpolation in lossTable (= [eta_mf1, eta_mf2, tau_bf1, tau_bf2])";
    Real 'lossyGear.interpolation_result[1,2]' "Result of interpolation in lossTable (= [eta_mf1, eta_mf2, tau_bf1, tau_bf2])";
    Real 'lossyGear.interpolation_result[1,3]' "Result of interpolation in lossTable (= [eta_mf1, eta_mf2, tau_bf1, tau_bf2])";
    Real 'lossyGear.interpolation_result[1,4]' "Result of interpolation in lossTable (= [eta_mf1, eta_mf2, tau_bf1, tau_bf2])";
    Real 'lossyGear.eta_mf1'(unit = "1") "Mesh efficiency in case that flange_a is driving";
    Real 'lossyGear.eta_mf2'(unit = "1") "Mesh efficiency in case that flange_b is driving";
    Real 'lossyGear.tau_bf_a'(unit = "N.m", quantity = "Torque") "Bearing friction torque on flange_a side";
    Real 'lossyGear.tau_eta'(unit = "N.m", quantity = "Torque") "Torque that determines the driving side (= if forwardSliding then flange_a.tau-tau_bf_a else if backwardSliding then flange_a.tau+tau_bf_a else flange_a.tau)";
    Real 'lossyGear.tau_bf1'(unit = "N.m", quantity = "Torque") "Absolute resultant bearing friction torque with respect to flange_a in case that flange_a is driving (= |tau_bf_a*eta_mf1 + tau_bf_b/i|)";
    Real 'lossyGear.tau_bf2'(unit = "N.m", quantity = "Torque") "Absolute resultant bearing friction torque with respect to flange_a in case that flange_b is driving (= |tau_bf_a/eta_mf2 + tau_bf_b/i|)";
    Real 'lossyGear.quadrant1'(unit = "N.m", quantity = "Torque") "Torque loss if w_a > 0 and flange_a.tau >= 0";
    Real 'lossyGear.quadrant2'(unit = "N.m", quantity = "Torque") "Torque loss if w_a > 0 and flange_a.tau < 0";
    Real 'lossyGear.quadrant3'(unit = "N.m", quantity = "Torque") "Torque loss if w_a < 0 and flange_a.tau >= 0";
    Real 'lossyGear.quadrant4'(unit = "N.m", quantity = "Torque") "Torque loss if w_a < 0 and flange_a.tau < 0";
    Real 'lossyGear.quadrant1_p'(unit = "N.m", quantity = "Torque") "Torque loss at w_a = 0+ to determine driving side (flange_a.tau >= 0)";
    Real 'lossyGear.quadrant2_p'(unit = "N.m", quantity = "Torque") "Torque loss at w_a = 0+ to determine driving side (flange_a.tau < 0)";
    Real 'lossyGear.quadrant3_m'(unit = "N.m", quantity = "Torque") "Torque loss at w_a = 0- to determine driving side (flange_a.tau >=0)";
    Real 'lossyGear.quadrant4_m'(unit = "N.m", quantity = "Torque") "Torque loss at w_a = 0- to determine driving side (flange_a.tau < 0)";
    Real 'lossyGear.tauLoss'(unit = "N.m", quantity = "Torque") "Torque loss due to friction in the gear teeth and in the bearings";
    Real 'lossyGear.tauLossMax'(unit = "N.m", quantity = "Torque") "Torque loss for positive speed";
    Real 'lossyGear.tauLossMin'(unit = "N.m", quantity = "Torque") "Torque loss for negative speed";
    Real 'lossyGear.tauLossMax_p'(unit = "N.m", quantity = "Torque") "Torque loss for positive speed";
    Real 'lossyGear.tauLossMin_m'(unit = "N.m", quantity = "Torque") "Torque loss for negative speed";
    Boolean 'lossyGear.tau_aPos'(start = true) "Only for backwards compatibility (was previously: true, if torque of flange_a is not negative)";
    Boolean 'lossyGear.tau_etaPos'(start = true) "= true, if torque tau_eta is not negative";
    Boolean 'lossyGear.startForward'(start = false) "= true, if starting to roll forward";
    Boolean 'lossyGear.startBackward'(start = false) "= true, if starting to roll backward";
    Boolean 'lossyGear.locked'(start = false) "= true, if gear is locked";
    Boolean 'lossyGear.ideal' "= true, if losses are neglected (that is lossTable = [0, 1, 1, 0, 0])";
