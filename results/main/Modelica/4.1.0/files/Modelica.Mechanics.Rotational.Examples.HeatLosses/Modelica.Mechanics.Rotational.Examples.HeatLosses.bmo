    Real 'clutch.tau0_max'(unit = "N.m", quantity = "Torque") "Maximum friction torque for w_relfric=0 and locked";
    Boolean 'clutch.free' "= true, if frictional element is not active";
    Real 'clutch.sa'(unit = "1") "Path parameter of friction characteristic tau = f(a_relfric)";
    Boolean 'clutch.startForward'(fixed = true, start = false) "= true, if w_relfric=0 and start of forward sliding";
    Boolean 'clutch.startBackward'(fixed = true, start = false) "= true, if w_relfric=0 and start of backward sliding";
    Boolean 'clutch.locked'(start = false) "= true, if w_rel=0 and not sliding";
