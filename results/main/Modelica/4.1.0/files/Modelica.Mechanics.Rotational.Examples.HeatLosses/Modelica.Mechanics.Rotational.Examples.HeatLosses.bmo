    Real 'clutch.heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'clutch.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'clutch.mu' "Friction coefficient";
    Real 'clutch.fn'(unit = "N", quantity = "Force") "Normal force (fn=fn_max*f_normalized)";
