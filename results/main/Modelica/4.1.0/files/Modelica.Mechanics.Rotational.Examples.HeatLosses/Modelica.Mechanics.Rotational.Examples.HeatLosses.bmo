    parameter Real 'brake.peak'(min = 1.0) = 1.0 "Peak for maximum value of mu at w==0 (mu0_max = peak*mu_pos[1,2])";
    parameter Real 'brake.cgeo'(min = 0.0) = 1.0 "Geometry constant containing friction distribution assumption";
    parameter Real 'brake.fn_max'(start = 1.0, min = 0.0, unit = "N", quantity = "Force") = 2.0 "Maximum normal force";
    parameter Real 'brake.w_small'(unit = "rad/s", quantity = "AngularVelocity") = 1e10 "Relative angular velocity near to zero if jumps due to a reinit(..) of the velocity can occur (set to low value only if such impulses can occur)";
    Real 'brake.w_relfric'(unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity between frictional surfaces";
    Real 'brake.a_relfric'(unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration between frictional surfaces";
    Real 'brake.tau0'(unit = "N.m", quantity = "Torque") "Friction torque for w_relfric=0 and forward sliding";
    Real 'brake.tau0_max'(unit = "N.m", quantity = "Torque") "Maximum friction torque for w_relfric=0 and locked";
    Boolean 'brake.free' "= true, if frictional element is not active";
    Real 'brake.sa'(unit = "1") "Path parameter of friction characteristic tau = f(a_relfric)";
    Boolean 'brake.startForward'(fixed = true, start = false) "= true, if w_relfric=0 and start of forward sliding";
    Boolean 'brake.startBackward'(fixed = true, start = false) "= true, if w_relfric=0 and start of backward sliding";
    Boolean 'brake.locked'(start = false) "= true, if w_rel=0 and not sliding";
    constant Integer 'brake.Unknown' = 3 "Value of mode is not known";
    constant Integer 'brake.Free' = 2 "Element is not active";
    constant Integer 'brake.Forward' = 1 "w_relfric > 0 (forward sliding)";
    constant Integer 'brake.Stuck' = 0 "w_relfric = 0 (forward sliding, locked or backward sliding)";
    constant Integer 'brake.Backward' = -1 "w_relfric < 0 (backward sliding)";
    Integer 'brake.mode'(fixed = true, start = 3, max = 3, min = -1) "Mode of friction (-1: backward sliding, 0: stuck, 1: forward sliding, 2: inactive, 3: unknown)";
    constant Real 'brake.unitAngularAcceleration'(unit = "rad/s2", quantity = "AngularAcceleration") = 1.0;
    constant Real 'brake.unitTorque'(unit = "N.m", quantity = "Torque") = 1.0;
    parameter Boolean 'brake.useHeatPort' = true "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'brake.heatPort.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'brake.heatPort.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'brake.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'brake.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between shaft flanges (flange_a, flange_b) and support";
    Real 'brake.tau'(unit = "N.m", quantity = "Torque") "Brake friction torque";
    Real 'brake.w'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of flange_a and flange_b";
    Real 'brake.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of flange_a and flange_b";
    Real 'brake.mu' "Friction coefficient";
    Real 'brake.fn'(unit = "N", quantity = "Force") "Normal force (=fn_max*f_normalized)";
    Real 'brake.f_normalized' "Normalized force signal 0..1 (normal force = fn_max*f_normalized; brake is active if > 0)";
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'brake.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 0.5}}, {2}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object for sliding friction coefficient";
    parameter Real 'brake.mu0' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('brake.tableID', 1, 0.0) "Friction coefficient for w=0 and forward sliding";
    Real 'brake.table_signs[1]' "Signs for sliding friction coefficient table interpolation: [sign for w, sign for mu]";
    Real 'brake.table_signs[2]' "Signs for sliding friction coefficient table interpolation: [sign for w, sign for mu]";
  equation
    'damper.heatPort.Q_flow' = -'damper.lossPower';
    'springDamper.heatPort.Q_flow' = -'springDamper.lossPower';
    'elastoBacklash.heatPort.Q_flow' = -'elastoBacklash.lossPower';
    'elastoBacklash.phi_diff' = 'elastoBacklash.phi_rel';
    'bearingFriction.heatPort.Q_flow' = -'bearingFriction.lossPower';
    'lossyGear.heatPort.Q_flow' = -'lossyGear.lossPower';
    'clutch.heatPort.Q_flow' = -'clutch.lossPower';
    'oneWayClutch.heatPort.Q_flow' = -'oneWayClutch.lossPower';
    'brake.heatPort.Q_flow' = -'brake.lossPower';
    'sine.y' = 'torque.tau';
    'torque.flange.phi' = 'inertia1.flange_a.phi';
    'inertia1.flange_b.phi' = 'springDamper.flange_a.phi';
    'inertia1.flange_b.phi' = 'damper.flange_b.phi';
    'damper.flange_a.phi' = 'fixed.flange.phi';
    'brake.heatPort.T' = 'convection.solid.T';
    'brake.heatPort.T' = 'oneWayClutch.heatPort.T';
    'brake.heatPort.T' = 'clutch.heatPort.T';
    'brake.heatPort.T' = 'lossyGear.heatPort.T';
    'brake.heatPort.T' = 'bearingFriction.heatPort.T';
    'brake.heatPort.T' = 'elastoBacklash.heatPort.T';
    'brake.heatPort.T' = 'springDamper.heatPort.T';
    'brake.heatPort.T' = 'damper.heatPort.T';
    'TAmbient.port.T' = 'convection.fluid.T';
    'const.y' = 'convection.Gc';
    'springDamper.flange_b.phi' = 'inertia2.flange_a.phi';
    'elastoBacklash.flange_a.phi' = 'inertia2.flange_b.phi';
    'elastoBacklash.flange_b.phi' = 'inertia3.flange_a.phi';
    'inertia3.flange_b.phi' = 'bearingFriction.flange_a.phi';
    'spring3.flange_b.phi' = 'inertia4.flange_a.phi';
    'bearingFriction.flange_b.phi' = 'spring3.flange_a.phi';
    'inertia4.flange_b.phi' = 'lossyGear.flange_a.phi';
    'lossyGear.flange_b.phi' = 'clutch.flange_a.phi';
    'clutch.flange_b.phi' = 'inertia5.flange_a.phi';
    'inertia5.flange_b.phi' = 'oneWayClutch.flange_a.phi';
    'oneWayClutch.flange_b.phi' = 'inertia6.flange_a.phi';
    'sine2.y' = 'brake.f_normalized';
    'sine2.y' = 'oneWayClutch.f_normalized';
    'sine2.y' = 'clutch.f_normalized';
    'inertia6.flange_b.phi' = 'brake.flange_a.phi';
    'inertia1.flange_a.tau' + 'torque.flange.tau' = 0.0;
    'fixed.flange.tau' + 'damper.flange_a.tau' = 0.0;
    'springDamper.flange_a.tau' + 'damper.flange_b.tau' + 'inertia1.flange_b.tau' = 0.0;
    'brake.heatPort.Q_flow' + 'oneWayClutch.heatPort.Q_flow' + 'clutch.heatPort.Q_flow' + 'lossyGear.heatPort.Q_flow' + 'bearingFriction.heatPort.Q_flow' + 'elastoBacklash.heatPort.Q_flow' + 'springDamper.heatPort.Q_flow' + 'convection.solid.Q_flow' + 'damper.heatPort.Q_flow' = 0.0;
    'TAmbient.port.Q_flow' + 'convection.fluid.Q_flow' = 0.0;
    'inertia2.flange_a.tau' + 'springDamper.flange_b.tau' = 0.0;
    'elastoBacklash.flange_a.tau' + 'inertia2.flange_b.tau' = 0.0;
    'inertia3.flange_a.tau' + 'elastoBacklash.flange_b.tau' = 0.0;
    'bearingFriction.flange_a.tau' + 'inertia3.flange_b.tau' = 0.0;
    'spring3.flange_a.tau' + 'bearingFriction.flange_b.tau' = 0.0;
    'inertia4.flange_a.tau' + 'spring3.flange_b.tau' = 0.0;
    'lossyGear.flange_a.tau' + 'inertia4.flange_b.tau' = 0.0;
    'clutch.flange_a.tau' + 'lossyGear.flange_b.tau' = 0.0;
    'inertia5.flange_a.tau' + 'clutch.flange_b.tau' = 0.0;
    'oneWayClutch.flange_a.tau' + 'inertia5.flange_b.tau' = 0.0;
    'brake.flange_a.tau' + 'inertia6.flange_b.tau' = 0.0;
    'oneWayClutch.flange_b.tau' + 'inertia6.flange_a.tau' = 0.0;
    'brake.flange_b.tau' = 0.0;
    'sine.y' = if time < 0.0 then 0.0 else 20.0 * sin(31.41592653589793 * time);
    'torque.flange.tau' = -'torque.tau';
    'torque.phi_support' = 0.0;
    'inertia1.phi' = 'inertia1.flange_a.phi';
    'inertia1.phi' = 'inertia1.flange_b.phi';
    'inertia1.w' = der('inertia1.phi');
    'inertia1.a' = der('inertia1.w');
    2.0 * 'inertia1.a' = 'inertia1.flange_a.tau' + 'inertia1.flange_b.tau';
    'damper.tau' = 10.0 * 'damper.w_rel';
    'damper.lossPower' = 'damper.tau' * 'damper.w_rel';
    'damper.phi_rel' = 'damper.flange_b.phi' - 'damper.flange_a.phi';
    'damper.w_rel' = der('damper.phi_rel');
    'damper.a_rel' = der('damper.w_rel');
    'damper.flange_b.tau' = 'damper.tau';
    'damper.flange_a.tau' = -'damper.tau';
    'fixed.flange.phi' = 0.0;
    'convection.dT' = 'convection.solid.T' - 'convection.fluid.T';
    'convection.solid.Q_flow' = 'convection.Q_flow';
    'convection.fluid.Q_flow' = -'convection.Q_flow';
    'convection.Q_flow' = 'convection.Gc' * 'convection.dT';
    'TAmbient.port.T' = 298.15;
    'const.y' = 20.0;
    'springDamper.tau_c' = 1e4 * 'springDamper.phi_rel';
    'springDamper.tau_d' = 20.0 * 'springDamper.w_rel';
    'springDamper.tau' = 'springDamper.tau_c' + 'springDamper.tau_d';
    'springDamper.lossPower' = 'springDamper.tau_d' * 'springDamper.w_rel';
    'springDamper.phi_rel' = 'springDamper.flange_b.phi' - 'springDamper.flange_a.phi';
    'springDamper.w_rel' = der('springDamper.phi_rel');
    'springDamper.a_rel' = der('springDamper.w_rel');
    'springDamper.flange_b.tau' = 'springDamper.tau';
    'springDamper.flange_a.tau' = -'springDamper.tau';
    'inertia2.phi' = 'inertia2.flange_a.phi';
    'inertia2.phi' = 'inertia2.flange_b.phi';
    'inertia2.w' = der('inertia2.phi');
    'inertia2.a' = der('inertia2.w');
    2.0 * 'inertia2.a' = 'inertia2.flange_a.tau' + 'inertia2.flange_b.tau';

    if initial() then
      'elastoBacklash.tau_c' = if 'elastoBacklash.phi_diff' > 7.5e-4 then 1e5 * ('elastoBacklash.phi_diff' - 5e-4) else if 'elastoBacklash.phi_diff' < (-7.5e-4) then 1e5 * ('elastoBacklash.phi_diff' + 5e-4) else 33333.333333333336 * 'elastoBacklash.phi_diff';
      'elastoBacklash.tau_d' = 100.0 * 'elastoBacklash.w_rel';
      'elastoBacklash.tau' = 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d';
      'elastoBacklash.lossPower' = 'elastoBacklash.tau_d' * 'elastoBacklash.w_rel';
    elseif true then
      'elastoBacklash.tau_c' = if 'elastoBacklash.phi_diff' > 5e-4 then 1e5 * ('elastoBacklash.phi_diff' - 5e-4) else if 'elastoBacklash.phi_diff' < (-5e-4) then 1e5 * ('elastoBacklash.phi_diff' + 5e-4) else 0.0;
      'elastoBacklash.tau_d' = 100.0 * 'elastoBacklash.w_rel';
      'elastoBacklash.tau' = if 'elastoBacklash.phi_diff' > 5e-4 then smooth(0, noEvent(if 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d' <= 0.0 then 0.0 else 'elastoBacklash.tau_c' + min('elastoBacklash.tau_c', 'elastoBacklash.tau_d'))) else if 'elastoBacklash.phi_diff' < (-5e-4) then smooth(0, noEvent(if 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d' >= 0.0 then 0.0 else 'elastoBacklash.tau_c' + max('elastoBacklash.tau_c', 'elastoBacklash.tau_d'))) else 0.0;
      'elastoBacklash.lossPower' = if 'elastoBacklash.phi_diff' > 5e-4 then smooth(0, noEvent(if 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d' <= 0.0 then 0.0 else min('elastoBacklash.tau_c', 'elastoBacklash.tau_d') * 'elastoBacklash.w_rel')) else if 'elastoBacklash.phi_diff' < (-5e-4) then smooth(0, noEvent(if 'elastoBacklash.tau_c' + 'elastoBacklash.tau_d' >= 0.0 then 0.0 else max('elastoBacklash.tau_c', 'elastoBacklash.tau_d') * 'elastoBacklash.w_rel')) else 0.0;
    end if;

    'elastoBacklash.phi_rel' = 'elastoBacklash.flange_b.phi' - 'elastoBacklash.flange_a.phi';
    'elastoBacklash.w_rel' = der('elastoBacklash.phi_rel');
    'elastoBacklash.a_rel' = der('elastoBacklash.w_rel');
    'elastoBacklash.flange_b.tau' = 'elastoBacklash.tau';
    'elastoBacklash.flange_a.tau' = -'elastoBacklash.tau';
    'inertia3.phi' = 'inertia3.flange_a.phi';
    'inertia3.phi' = 'inertia3.flange_b.phi';
    'inertia3.w' = der('inertia3.phi');
    'inertia3.a' = der('inertia3.w');
    2.0 * 'inertia3.a' = 'inertia3.flange_a.tau' + 'inertia3.flange_b.tau';
    'bearingFriction.tau0' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('bearingFriction.tableID', 1, 0.0);
    'bearingFriction.tau0_max' = 'bearingFriction.tau0';
    'bearingFriction.free' = false;
    'bearingFriction.phi' = 'bearingFriction.flange_a.phi' - 'bearingFriction.phi_support';
    'bearingFriction.flange_b.phi' = 'bearingFriction.flange_a.phi';
    'bearingFriction.w' = der('bearingFriction.phi');
    'bearingFriction.a' = der('bearingFriction.w');
    'bearingFriction.w_relfric' = 'bearingFriction.w';
    'bearingFriction.a_relfric' = 'bearingFriction.a';
    'bearingFriction.flange_a.tau' + 'bearingFriction.flange_b.tau' - 'bearingFriction.tau' = 0.0;
    'bearingFriction.table_signs[1]' = if 'bearingFriction.startForward' then 1.0 else if 'bearingFriction.startBackward' then -1.0 else if pre('bearingFriction.mode') == 1 then 1.0 else -1.0;
    'bearingFriction.table_signs[2]' = if 'bearingFriction.startForward' then 1.0 else if 'bearingFriction.startBackward' then -1.0 else if pre('bearingFriction.mode') == 1 then 1.0 else -1.0;
    'bearingFriction.tau' = if 'bearingFriction.locked' then 'bearingFriction.sa' else 'bearingFriction.table_signs[2]' * 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('bearingFriction.tableID', 1, 'bearingFriction.table_signs[1]' * 'bearingFriction.w');
    'bearingFriction.lossPower' = 'bearingFriction.tau' * 'bearingFriction.w_relfric';
    'bearingFriction.startForward' = (pre('bearingFriction.mode') == 0 and ('bearingFriction.sa' > 'bearingFriction.tau0_max' or pre('bearingFriction.startForward') and 'bearingFriction.sa' > 'bearingFriction.tau0') or pre('bearingFriction.mode') == (-1) and 'bearingFriction.w_relfric' > 1e10) or initial() and 'bearingFriction.w_relfric' > 0.0;
    'bearingFriction.startBackward' = (pre('bearingFriction.mode') == 0 and ('bearingFriction.sa' < (-'bearingFriction.tau0_max') or pre('bearingFriction.startBackward') and 'bearingFriction.sa' < (-'bearingFriction.tau0')) or pre('bearingFriction.mode') == 1 and 'bearingFriction.w_relfric' < (-1e10)) or initial() and 'bearingFriction.w_relfric' < 0.0;
    'bearingFriction.locked' = not 'bearingFriction.free' and not (((pre('bearingFriction.mode') == 1 or 'bearingFriction.startForward') or pre('bearingFriction.mode') == (-1)) or 'bearingFriction.startBackward');
    'bearingFriction.a_relfric' = if 'bearingFriction.locked' then 0.0 else if 'bearingFriction.free' then 'bearingFriction.sa' else if 'bearingFriction.startForward' then 'bearingFriction.sa' - 'bearingFriction.tau0_max' else if 'bearingFriction.startBackward' then 'bearingFriction.sa' + 'bearingFriction.tau0_max' else if pre('bearingFriction.mode') == 1 then 'bearingFriction.sa' - 'bearingFriction.tau0_max' else if pre('bearingFriction.mode') == (-1) then 'bearingFriction.sa' + 'bearingFriction.tau0_max' else 'bearingFriction.sa' - sign('bearingFriction.w_relfric') * 'bearingFriction.tau0_max';
    'bearingFriction.mode' = if 'bearingFriction.free' then 2 else if ((pre('bearingFriction.mode') == 1 or pre('bearingFriction.mode') == 2) or 'bearingFriction.startForward') and 'bearingFriction.w_relfric' > 0.0 then 1 else if ((pre('bearingFriction.mode') == (-1) or pre('bearingFriction.mode') == 2) or 'bearingFriction.startBackward') and 'bearingFriction.w_relfric' < 0.0 then -1 else 0;
    'bearingFriction.phi_support' = 0.0;
    'spring3.tau' = 1e4 * 'spring3.phi_rel';
    'spring3.phi_rel' = 'spring3.flange_b.phi' - 'spring3.flange_a.phi';
    'spring3.flange_b.tau' = 'spring3.tau';
    'spring3.flange_a.tau' = -'spring3.tau';
    'inertia4.phi' = 'inertia4.flange_a.phi';
    'inertia4.phi' = 'inertia4.flange_b.phi';
    'inertia4.w' = der('inertia4.phi');
    'inertia4.a' = der('inertia4.w');
    2.0 * 'inertia4.a' = 'inertia4.flange_a.tau' + 'inertia4.flange_b.tau';
    'lossyGear.ideal' = false;

    if 'lossyGear.ideal' then
      'lossyGear.interpolation_result[1,1]' = 1.0;
      'lossyGear.interpolation_result[1,2]' = 1.0;
      'lossyGear.interpolation_result[1,3]' = 0.0;
      'lossyGear.interpolation_result[1,4]' = 0.0;
      'lossyGear.eta_mf1' = 1.0;
      'lossyGear.eta_mf2' = 1.0;
      'lossyGear.tau_bf1' = 0.0;
      'lossyGear.tau_bf2' = 0.0;
    elseif true then
      'lossyGear.interpolation_result[1,1]' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('lossyGear.tableID', 1, noEvent(abs('lossyGear.w_a')));
      'lossyGear.interpolation_result[1,2]' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('lossyGear.tableID', 2, noEvent(abs('lossyGear.w_a')));
      'lossyGear.interpolation_result[1,3]' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('lossyGear.tableID', 3, noEvent(abs('lossyGear.w_a')));
      'lossyGear.interpolation_result[1,4]' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('lossyGear.tableID', 4, noEvent(abs('lossyGear.w_a')));
      'lossyGear.eta_mf1' = 'lossyGear.interpolation_result[1,1]';
      'lossyGear.eta_mf2' = 'lossyGear.interpolation_result[1,2]';
      'lossyGear.tau_bf1' = noEvent(abs('lossyGear.interpolation_result[1,3]'));
      'lossyGear.tau_bf2' = noEvent(abs('lossyGear.interpolation_result[1,4]'));
    end if;

    if abs('lossyGear.eta_mf1' - 1.0) <= 2.220446049250313e-16 and abs('lossyGear.eta_mf2' - 1.0) <= 2.220446049250313e-16 then
      'lossyGear.tau_bf_a' = 'lossyGear.tau_bf1' / 2.0;
    elseif true then
      'lossyGear.tau_bf_a' = ('lossyGear.tau_bf1' - 'lossyGear.tau_bf2') / ('lossyGear.eta_mf1' - 1.0 / 'lossyGear.eta_mf2');
    end if;

    'lossyGear.phi_a' = 'lossyGear.flange_a.phi' - 'lossyGear.phi_support';
    'lossyGear.phi_b' = 'lossyGear.flange_b.phi' - 'lossyGear.phi_support';
    'lossyGear.phi_a' = 2.0 * 'lossyGear.phi_b';
    0.0 = 'lossyGear.flange_b.tau' + 2.0 * ('lossyGear.flange_a.tau' - 'lossyGear.tauLoss');
    'lossyGear.w_a' = der('lossyGear.phi_a');
    'lossyGear.a_a' = der('lossyGear.w_a');
    'lossyGear.tau_eta_p' = 'lossyGear.flange_a.tau' - 'lossyGear.tau_bf_a_0';
    'lossyGear.tau_eta_m' = 'lossyGear.flange_a.tau' + 'lossyGear.tau_bf_a_0';
    'lossyGear.quadrant1_p' = (1.0 - 'lossyGear.eta_mf1_0') * 'lossyGear.flange_a.tau' + 'lossyGear.tau_bf1_0';
    'lossyGear.quadrant2_p' = (1.0 - 1.0 / 'lossyGear.eta_mf2_0') * 'lossyGear.flange_a.tau' + 'lossyGear.tau_bf2_0';
    'lossyGear.tauLossMax_p' = if noEvent('lossyGear.tau_eta_p' > 0.0) then 'lossyGear.quadrant1_p' else 'lossyGear.quadrant2_p';
    'lossyGear.quadrant4_m' = (1.0 - 1.0 / 'lossyGear.eta_mf2_0') * 'lossyGear.flange_a.tau' - 'lossyGear.tau_bf2_0';
    'lossyGear.quadrant3_m' = (1.0 - 'lossyGear.eta_mf1_0') * 'lossyGear.flange_a.tau' - 'lossyGear.tau_bf1_0';
    'lossyGear.tauLossMin_m' = if noEvent('lossyGear.tau_eta_m' > 0.0) then 'lossyGear.quadrant4_m' else 'lossyGear.quadrant3_m';
    'lossyGear.quadrant1' = (1.0 - 'lossyGear.eta_mf1') * 'lossyGear.flange_a.tau' + 'lossyGear.tau_bf1';
    'lossyGear.quadrant2' = (1.0 - 1.0 / 'lossyGear.eta_mf2') * 'lossyGear.flange_a.tau' + 'lossyGear.tau_bf2';
    'lossyGear.quadrant4' = (1.0 - 1.0 / 'lossyGear.eta_mf2') * 'lossyGear.flange_a.tau' - 'lossyGear.tau_bf2';
    'lossyGear.quadrant3' = (1.0 - 'lossyGear.eta_mf1') * 'lossyGear.flange_a.tau' - 'lossyGear.tau_bf1';
