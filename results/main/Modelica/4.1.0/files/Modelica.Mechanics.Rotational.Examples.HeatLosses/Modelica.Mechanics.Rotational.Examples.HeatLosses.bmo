    parameter Boolean 'sine2.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine2.y' "Connector of Real output signal";
    parameter Real 'sine2.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine2.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    Real 'inertia6.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia6.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
