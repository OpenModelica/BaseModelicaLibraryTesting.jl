    Real 'oneWayClutch.mu' "Friction coefficient";
    Real 'oneWayClutch.fn'(unit = "N", quantity = "Force") "Normal force (fn=fn_max*inPort.signal)";
    Boolean 'oneWayClutch.startForward'(fixed = true, start = false) "= true, if w_rel=0 and start of forward sliding or w_rel > w_small";
    Boolean 'oneWayClutch.locked'(start = false) "= true, if w_rel=0 and not sliding";
    Boolean 'oneWayClutch.stuck'(fixed = true, start = false) "w_rel=0 (locked or start forward sliding)";
    Real 'oneWayClutch.tau0'(unit = "N.m", quantity = "Torque") "Friction torque for w=0 and sliding";
    Real 'oneWayClutch.tau0_max'(unit = "N.m", quantity = "Torque") "Maximum friction torque for w=0 and locked";
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'oneWayClutch.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 0.5}}, {2}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object for sliding friction coefficient";
    parameter Real 'oneWayClutch.mu0' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('oneWayClutch.tableID', 1, 0.0) "Friction coefficient for w=0 and sliding";
    Boolean 'oneWayClutch.free' "= true, if frictional element is not active";
