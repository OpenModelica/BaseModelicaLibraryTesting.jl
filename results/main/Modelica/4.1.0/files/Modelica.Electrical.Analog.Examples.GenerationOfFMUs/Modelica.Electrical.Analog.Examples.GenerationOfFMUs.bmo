    Real 'inverseCapacitor1.capacitor.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inverseCapacitor1.capacitor.C'(start = 1.0, min = 0.0, unit = "F", quantity = "Capacitance") = 0.002 "Capacitance";
