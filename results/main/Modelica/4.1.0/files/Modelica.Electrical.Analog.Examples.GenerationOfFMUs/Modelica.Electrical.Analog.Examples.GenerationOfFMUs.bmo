    parameter String 'inverseCapacitor1.voltageToCurrent.Name_pder' = "dv" "Name of 1st derivative of potential variable";
    parameter String 'inverseCapacitor1.voltageToCurrent.Name_pder2' = "d2v" "Name of 2nd derivative of potential variable";
