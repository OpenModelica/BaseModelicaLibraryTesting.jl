//! base 0.1.0
package 'GenerationOfFMUs'
  model 'GenerationOfFMUs' "Example to demonstrate variants to generate FMUs (Functional Mock-up Units)"
    parameter Real 'sine12.amplitude' = 1.0 "Amplitude of sine wave";
    parameter Real 'sine12.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 2.0 "Frequency of sine wave";
    parameter Real 'sine12.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine12.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine12.y' "Connector of Real output signal";
    parameter Real 'sine12.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine12.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'directCapacitor1.C'(min = 0.0, unit = "F", quantity = "Capacitance") = 0.001 "Capacitance";
    Real 'directCapacitor1.capacitor.v'(fixed = true, start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'directCapacitor1.capacitor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'directCapacitor1.capacitor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'directCapacitor1.capacitor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'directCapacitor1.capacitor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'directCapacitor1.capacitor.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'directCapacitor1.capacitor.C'(start = 1.0, min = 0.0, unit = "F", quantity = "Capacitance") = 0.001 "Capacitance";
    Real 'directCapacitor1.currentSource.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'directCapacitor1.currentSource.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'directCapacitor1.currentSource.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'directCapacitor1.currentSource.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'directCapacitor1.currentSource.i'(unit = "A") "Current flowing from pin p to pin n as input signal";
    Real 'directCapacitor1.currentSource.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop between the two pins (= p.v - n.v)";
    Real 'directCapacitor1.iDrive'(unit = "A");
    parameter Boolean 'directCapacitor1.currentToVoltage.use_pder' = true "Use output for 1st derivative of potential" annotation(Evaluate = true);
    parameter Boolean 'directCapacitor1.currentToVoltage.use_pder2' = false "Use output for 2nd derivative of potential (only if 1st derivative is used, too)" annotation(Evaluate = true);
    parameter Boolean 'directCapacitor1.currentToVoltage.use_fder' = false "Use input for 1st derivative of flow" annotation(Evaluate = true);
    parameter Boolean 'directCapacitor1.currentToVoltage.use_fder2' = false "Use input for 2nd derivative of flow (only if 1st derivative is used, too)" annotation(Evaluate = true);
    Real 'directCapacitor1.currentToVoltage.p'(unit = "V") "Output for potential";
    Real 'directCapacitor1.currentToVoltage.pder'(unit = "V/s") "Optional output for der(potential)";
    Real 'directCapacitor1.currentToVoltage.f'(unit = "A") "Input for flow";
    parameter String 'directCapacitor1.currentToVoltage.Name_p' = "v" "Name of potential variable";
    parameter String 'directCapacitor1.currentToVoltage.Name_pder' = "dv" "Name of 1st derivative of potential variable";
    parameter String 'directCapacitor1.currentToVoltage.Name_pder2' = "d2v" "Name of 2nd derivative of potential variable";
    parameter String 'directCapacitor1.currentToVoltage.Name_f' = "i" "Name of flow variable";
    parameter String 'directCapacitor1.currentToVoltage.Name_fder' = "di" "Name of 1st derivative of flow variable";
    parameter String 'directCapacitor1.currentToVoltage.Name_fder2' = "d2i" "Name of 2nd derivative of flow variable";
