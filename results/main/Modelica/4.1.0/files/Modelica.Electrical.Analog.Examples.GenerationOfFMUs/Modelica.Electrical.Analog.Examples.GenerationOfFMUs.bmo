    Real 'inverseCapacitor1.voltageToCurrent.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop between the two pins (= p.v - n.v)";
    Real 'inverseCapacitor1.voltageToCurrent.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'inverseCapacitor1.voltageToCurrent.pin_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverseCapacitor1.voltageToCurrent.pin_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverseCapacitor1.voltageToCurrent.pin_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inverseCapacitor1.voltageToCurrent.pin_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inverseCapacitor1.v'(unit = "V") "Voltage to drive the Capacitor";
    Real 'inverseCapacitor1.dv'(unit = "V/s") "Voltage to drive the Capacitor";
    Real 'inverseCapacitor1.i'(unit = "A") "Current needed to drive the oneport according to v, dv";
