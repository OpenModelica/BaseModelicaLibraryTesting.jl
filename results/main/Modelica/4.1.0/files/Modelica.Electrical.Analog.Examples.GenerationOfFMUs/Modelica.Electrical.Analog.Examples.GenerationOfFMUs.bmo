    Real 'inverseCapacitor1.ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'resistor2.R'(unit = "Ohm", quantity = "Resistance") = 10.0 "Resistance";
    parameter Boolean 'resistor2.voltageToCurrent1.use_pder' = false "Use input for 1st derivative of potential" annotation(Evaluate = true);
    parameter Boolean 'resistor2.voltageToCurrent1.use_pder2' = false "Use input for 2nd derivative of potential (only if 1st derivative is used, too)" annotation(Evaluate = true);
