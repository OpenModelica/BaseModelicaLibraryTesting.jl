    Real 'directCapacitor1.v'(unit = "V") "Capacitor changes voltage due to current";
    Real 'directCapacitor1.dv'(unit = "V/s") "Capacitor changes voltage due to current";
    Real 'directCapacitor1.i'(unit = "A") "Current to the capacitor";
    Real 'directCapacitor1.ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'directCapacitor1.ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
