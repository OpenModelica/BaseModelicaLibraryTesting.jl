    end when;

    'v.v' = if (time < 5e-4 or 'v.counter2' == 0) or time >= 'v.T0' + 1000.01 then 0.0 else if time < 'v.T0' + 0.01 then (time - 'v.T0') * 8.0 / 0.01 else if time < 'v.T0' + 1000.01 then 8.0 else ('v.T0' + 1000.01 - time) * 8.0 / 0.0;
    0.0 = 'v.p.i' + 'v.n.i';
    'v.i' = 'v.p.i';
    'v.v' = 'v.p.v' - 'v.n.v';
    annotation(experiment(StopTime = 0.025));
  end 'Oscillator';
end 'Oscillator';
