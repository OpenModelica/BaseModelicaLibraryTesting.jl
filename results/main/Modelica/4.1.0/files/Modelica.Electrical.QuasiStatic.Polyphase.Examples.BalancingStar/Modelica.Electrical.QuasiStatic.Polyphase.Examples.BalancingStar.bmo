    Real 'star.plugToPins_p.pin_p[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'star.plugToPins_p.pin_p[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
