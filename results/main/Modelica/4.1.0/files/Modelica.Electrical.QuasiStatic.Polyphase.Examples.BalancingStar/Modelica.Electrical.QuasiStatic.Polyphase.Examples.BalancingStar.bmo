    Real 'voltageSource.plug_n.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSource.plug_n.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'voltageSource.pi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 3.141592653589793;
    Real 'voltageSource.gamma'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Real 'voltageSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of the source";
    parameter Real 'voltageSource.V[1]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 100.0 "RMS voltage of the source";
    parameter Real 'voltageSource.V[2]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 100.0 "RMS voltage of the source";
    parameter Real 'voltageSource.V[3]'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 100.0 "RMS voltage of the source";
    parameter Real 'voltageSource.phi[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -0.0 "Phase shift of the source";
    parameter Real 'voltageSource.phi[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -2.0943951023931953 "Phase shift of the source";
    parameter Real 'voltageSource.phi[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = -4.1887902047863905 "Phase shift of the source";
    parameter Integer 'star.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    parameter Integer 'star.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'star.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
