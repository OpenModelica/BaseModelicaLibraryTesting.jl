  equation
    'i[1].re' = 'resistor.i.re';
    'i[1].im' = 'resistor.i.im';
    'i[2].re' = 'inductor.i.re';
    'i[2].im' = 'inductor.i.im';
    'i[3].re' = 'capacitor.i.re';
    'i[3].im' = 'capacitor.i.im';
    'voltageSource.P_total' = 'voltageSource.P[1]' + 'voltageSource.P[2]' + 'voltageSource.P[3]';
    'voltageSource.Q_total' = 'voltageSource.Q[1]' + 'voltageSource.Q[2]' + 'voltageSource.Q[3]';
    'voltageSource.S_total' = sqrt('voltageSource.P_total' ^ 2.0 + 'voltageSource.Q_total' ^ 2.0);
    'voltageSource.gamma' = 'voltageSource.plug_p.reference.gamma';
    'powerSensor.omega' = der('powerSensor.currentP.reference.gamma');
    'powerSensor.powerSensor[1].abs_apparentPower' = sqrt('powerSensor.powerSensor[1].apparentPower.re' ^ 2.0 + 'powerSensor.powerSensor[1].apparentPower.im' ^ 2.0);
    'powerSensor.powerSensor[1].arg_apparentPower' = 'Modelica.Math.atan3'('powerSensor.powerSensor[1].apparentPower.im', 'powerSensor.powerSensor[1].apparentPower.re', 0.0);
    'powerSensor.powerSensor[2].abs_apparentPower' = sqrt('powerSensor.powerSensor[2].apparentPower.re' ^ 2.0 + 'powerSensor.powerSensor[2].apparentPower.im' ^ 2.0);
    'powerSensor.powerSensor[2].arg_apparentPower' = 'Modelica.Math.atan3'('powerSensor.powerSensor[2].apparentPower.im', 'powerSensor.powerSensor[2].apparentPower.re', 0.0);
    'powerSensor.powerSensor[3].abs_apparentPower' = sqrt('powerSensor.powerSensor[3].apparentPower.re' ^ 2.0 + 'powerSensor.powerSensor[3].apparentPower.im' ^ 2.0);
    'powerSensor.powerSensor[3].arg_apparentPower' = 'Modelica.Math.atan3'('powerSensor.powerSensor[3].apparentPower.im', 'powerSensor.powerSensor[3].apparentPower.re', 0.0);
    'powerSensor.sum.uInternal[1].re' = 'powerSensor.sum.u[1].re';
    'powerSensor.sum.uInternal[1].im' = 'powerSensor.sum.u[1].im';
    'powerSensor.sum.uInternal[2].re' = 'powerSensor.sum.u[2].re';
    'powerSensor.sum.uInternal[2].im' = 'powerSensor.sum.u[2].im';
    'powerSensor.sum.uInternal[3].re' = 'powerSensor.sum.u[3].re';
    'powerSensor.sum.uInternal[3].im' = 'powerSensor.sum.u[3].im';
    'powerSensor.abs_apparentPower' = sqrt('powerSensor.apparentPower.re' ^ 2.0 + 'powerSensor.apparentPower.im' ^ 2.0);
    'powerSensor.arg_apparentPower' = 'Modelica.Math.atan3'('powerSensor.apparentPower.im', 'powerSensor.apparentPower.re', 0.0);
    'currentSensor.currentSensor[1].abs_i' = sqrt('currentSensor.currentSensor[1].i.re' ^ 2.0 + 'currentSensor.currentSensor[1].i.im' ^ 2.0);
    'currentSensor.currentSensor[1].arg_i' = 'Modelica.Math.atan3'('currentSensor.currentSensor[1].i.im', 'currentSensor.currentSensor[1].i.re', 0.0);
    'currentSensor.currentSensor[2].abs_i' = sqrt('currentSensor.currentSensor[2].i.re' ^ 2.0 + 'currentSensor.currentSensor[2].i.im' ^ 2.0);
    'currentSensor.currentSensor[2].arg_i' = 'Modelica.Math.atan3'('currentSensor.currentSensor[2].i.im', 'currentSensor.currentSensor[2].i.re', 0.0);
    'currentSensor.currentSensor[3].abs_i' = sqrt('currentSensor.currentSensor[3].i.re' ^ 2.0 + 'currentSensor.currentSensor[3].i.im' ^ 2.0);
    'currentSensor.currentSensor[3].arg_i' = 'Modelica.Math.atan3'('currentSensor.currentSensor[3].i.im', 'currentSensor.currentSensor[3].i.re', 0.0);
    'resistor.abs_v' = sqrt('resistor.v.re' ^ 2.0 + 'resistor.v.im' ^ 2.0);
    'resistor.arg_v' = 'Modelica.Math.atan3'('resistor.v.im', 'resistor.v.re', 0.0);
    'resistor.abs_i' = sqrt('resistor.i.re' ^ 2.0 + 'resistor.i.im' ^ 2.0);
    'resistor.arg_i' = 'Modelica.Math.atan3'('resistor.i.im', 'resistor.i.re', 0.0);
    'resistor.P' = 'resistor.v.re' * 'resistor.i.re' - 'resistor.v.im' * (-'resistor.i.im');
    'resistor.Q' = 'resistor.v.re' * (-'resistor.i.im') + 'resistor.v.im' * 'resistor.i.re';
    'resistor.S' = sqrt(('resistor.v.re' * 'resistor.i.re' - 'resistor.v.im' * (-'resistor.i.im')) ^ 2.0 + ('resistor.v.re' * (-'resistor.i.im') + 'resistor.v.im' * 'resistor.i.re') ^ 2.0);
    'resistor.pf' = cos('Modelica.Math.atan3'('resistor.Q', 'resistor.P', 0.0));
    'capacitor.abs_v' = sqrt('capacitor.v.re' ^ 2.0 + 'capacitor.v.im' ^ 2.0);
    'capacitor.arg_v' = 'Modelica.Math.atan3'('capacitor.v.im', 'capacitor.v.re', 0.0);
    'capacitor.abs_i' = sqrt('capacitor.i.re' ^ 2.0 + 'capacitor.i.im' ^ 2.0);
    'capacitor.arg_i' = 'Modelica.Math.atan3'('capacitor.i.im', 'capacitor.i.re', 0.0);
    'capacitor.P' = 'capacitor.v.re' * 'capacitor.i.re' - 'capacitor.v.im' * (-'capacitor.i.im');
    'capacitor.Q' = 'capacitor.v.re' * (-'capacitor.i.im') + 'capacitor.v.im' * 'capacitor.i.re';
    'capacitor.S' = sqrt(('capacitor.v.re' * 'capacitor.i.re' - 'capacitor.v.im' * (-'capacitor.i.im')) ^ 2.0 + ('capacitor.v.re' * (-'capacitor.i.im') + 'capacitor.v.im' * 'capacitor.i.re') ^ 2.0);
    'capacitor.pf' = cos('Modelica.Math.atan3'('capacitor.Q', 'capacitor.P', 0.0));
    'inductor.abs_v' = sqrt('inductor.v.re' ^ 2.0 + 'inductor.v.im' ^ 2.0);
