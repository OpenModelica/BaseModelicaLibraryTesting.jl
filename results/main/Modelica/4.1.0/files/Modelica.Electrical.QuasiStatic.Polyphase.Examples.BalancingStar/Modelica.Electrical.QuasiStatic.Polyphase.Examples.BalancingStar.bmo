    Real 'voltageSource.plug_n.pin[2].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSource.plug_n.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
