    Real 'voltageSource.plug_p.pin[3].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSource.plug_p.pin[3].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSource.plug_p.pin[3].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSource.plug_p.pin[3].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSource.plug_p.reference.gamma'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    parameter Integer 'voltageSource.plug_n.m' = 3 "Number of phases" annotation(Evaluate = true);
