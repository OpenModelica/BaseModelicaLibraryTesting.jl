//! base 0.1.0
package 'BalancingStar'
  function 'Complex.\'*\'.scalarProduct' "Scalar product of two complex vectors c1 and c2"
    input 'Complex'[:] 'c1';
    input 'Complex'[size('c1', 1)] 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex'(0.0, 0.0);

    for 'i' in 1:size('c1', 1) loop
      'c3' := 'Complex.\'constructor\'.fromReal'('c3'.'re' + 'c1[\'i\']'.'re' * 'c2[\'i\']'.'re' + 'c1[\'i\']'.'im' * 'c2[\'i\']'.'im', 'c3'.'im' + 'c1[\'i\']'.'re' * 'c2[\'i\']'.'im' - 'c1[\'i\']'.'im' * 'c2[\'i\']'.'re');
    end for;
    annotation(Inline = true, smoothOrder = 100);
  end 'Complex.\'*\'.scalarProduct';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  model 'BalancingStar' "Balancing an unsymmetrical star-connected load"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'V'(unit = "V", quantity = "ElectricPotential") = 100.0 "Source Voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Source frequency";
    parameter Real 'R'(unit = "Ohm", quantity = "Resistance") = 10.0 "Load resistance";
    parameter Real 'L'(unit = "H", quantity = "Inductance") = 0.0551328895421792 "Load inductance";
    parameter Real 'C'(min = 0.0, unit = "F", quantity = "Capacitance") = 1.837762984739307e-4 "Load capacitance";
    Real 'i[1].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'i[1].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'i[2].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'i[2].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'i[3].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'i[3].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    parameter Integer 'voltageSource.m'(min = 1) = 3 "Number of phases" annotation(Evaluate = true);
    Real 'voltageSource.v[1].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSource.v[1].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSource.v[2].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSource.v[2].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSource.v[3].re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSource.v[3].im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSource.abs_v[1]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'voltageSource.abs_v[2]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'voltageSource.abs_v[3]'(unit = "V", quantity = "ElectricPotential") "Magnitude of complex voltage";
    Real 'voltageSource.arg_v[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'voltageSource.arg_v[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'voltageSource.arg_v[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex voltage";
    Real 'voltageSource.i[1].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSource.i[1].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSource.i[2].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSource.i[2].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSource.i[3].re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSource.i[3].im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSource.abs_i[1]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'voltageSource.abs_i[2]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'voltageSource.abs_i[3]'(unit = "A", quantity = "ElectricCurrent") "Magnitude of complex current";
    Real 'voltageSource.arg_i[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'voltageSource.arg_i[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'voltageSource.arg_i[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Argument of complex current";
    Real 'voltageSource.P[1]'(unit = "W", quantity = "Power") "Active power";
    Real 'voltageSource.P[2]'(unit = "W", quantity = "Power") "Active power";
    Real 'voltageSource.P[3]'(unit = "W", quantity = "Power") "Active power";
    Real 'voltageSource.P_total'(unit = "W", quantity = "Power") "Total active power";
    Real 'voltageSource.Q[1]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSource.Q[2]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSource.Q[3]'(unit = "var", quantity = "Power") "Reactive power";
    Real 'voltageSource.Q_total'(unit = "var", quantity = "Power") "Total reactive power";
    Real 'voltageSource.S[1]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSource.S[2]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSource.S[3]'(unit = "V.A", quantity = "Power") "Magnitude of complex apparent power";
    Real 'voltageSource.S_total'(unit = "V.A", quantity = "Power") "Magnitude of total complex apparent power";
    Real 'voltageSource.pf[1]' "Power factor";
    Real 'voltageSource.pf[2]' "Power factor";
    Real 'voltageSource.pf[3]' "Power factor";
    Real 'voltageSource.omega'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of reference frame";
    parameter Integer 'voltageSource.plug_p.m' = 3 "Number of phases" annotation(Evaluate = true);
    Real 'voltageSource.plug_p.pin[1].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
    Real 'voltageSource.plug_p.pin[1].v.im'(unit = "V", quantity = "ElectricPotential") "Imaginary part of complex number";
    Real 'voltageSource.plug_p.pin[1].i.re'(unit = "A", quantity = "ElectricCurrent") "Real part of complex number";
    Real 'voltageSource.plug_p.pin[1].i.im'(unit = "A", quantity = "ElectricCurrent") "Imaginary part of complex number";
    Real 'voltageSource.plug_p.pin[2].v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
