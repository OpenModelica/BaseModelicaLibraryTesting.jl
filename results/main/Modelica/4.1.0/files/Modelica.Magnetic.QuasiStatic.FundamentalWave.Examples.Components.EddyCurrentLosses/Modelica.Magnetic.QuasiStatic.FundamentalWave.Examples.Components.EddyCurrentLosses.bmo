  equation
    'lossPower_e' = 'loss_e.conductor[1].LossPower' + 'loss_e.conductor[2].LossPower' + 'loss_e.conductor[3].LossPower';
    'lossPower_m' = 'loss_m.lossPower';
    'sineVoltage_e.P_total' = 'sineVoltage_e.P[1]' + 'sineVoltage_e.P[2]' + 'sineVoltage_e.P[3]';
    'sineVoltage_e.Q_total' = 'sineVoltage_e.Q[1]' + 'sineVoltage_e.Q[2]' + 'sineVoltage_e.Q[3]';
    'sineVoltage_e.S_total' = sqrt('sineVoltage_e.P_total' ^ 2.0 + 'sineVoltage_e.Q_total' ^ 2.0);
    'sineVoltage_e.gamma' = 'sineVoltage_e.plug_p.reference.gamma';
    'sineVoltage_m.P_total' = 'sineVoltage_m.P[1]' + 'sineVoltage_m.P[2]' + 'sineVoltage_m.P[3]';
    'sineVoltage_m.Q_total' = 'sineVoltage_m.Q[1]' + 'sineVoltage_m.Q[2]' + 'sineVoltage_m.Q[3]';
    'sineVoltage_m.S_total' = sqrt('sineVoltage_m.P_total' ^ 2.0 + 'sineVoltage_m.Q_total' ^ 2.0);
    'sineVoltage_m.gamma' = 'sineVoltage_m.plug_p.reference.gamma';
    'resistor_e.P_total' = 'resistor_e.P[1]' + 'resistor_e.P[2]' + 'resistor_e.P[3]';
    'resistor_e.Q_total' = 'resistor_e.Q[1]' + 'resistor_e.Q[2]' + 'resistor_e.Q[3]';
    'resistor_e.S_total' = sqrt('resistor_e.P_total' ^ 2.0 + 'resistor_e.Q_total' ^ 2.0);
    'resistor_e.resistor[1].abs_v' = sqrt('resistor_e.resistor[1].v.re' ^ 2.0 + 'resistor_e.resistor[1].v.im' ^ 2.0);
    'resistor_e.resistor[1].arg_v' = 'Modelica.Math.atan3'('resistor_e.resistor[1].v.im', 'resistor_e.resistor[1].v.re', 0.0);
    'resistor_e.resistor[1].abs_i' = sqrt('resistor_e.resistor[1].i.re' ^ 2.0 + 'resistor_e.resistor[1].i.im' ^ 2.0);
    'resistor_e.resistor[1].arg_i' = 'Modelica.Math.atan3'('resistor_e.resistor[1].i.im', 'resistor_e.resistor[1].i.re', 0.0);
    'resistor_e.resistor[1].P' = 'resistor_e.resistor[1].v.re' * 'resistor_e.resistor[1].i.re' - 'resistor_e.resistor[1].v.im' * (-'resistor_e.resistor[1].i.im');
    'resistor_e.resistor[1].Q' = 'resistor_e.resistor[1].v.re' * (-'resistor_e.resistor[1].i.im') + 'resistor_e.resistor[1].v.im' * 'resistor_e.resistor[1].i.re';
    'resistor_e.resistor[1].S' = sqrt(('resistor_e.resistor[1].v.re' * 'resistor_e.resistor[1].i.re' - 'resistor_e.resistor[1].v.im' * (-'resistor_e.resistor[1].i.im')) ^ 2.0 + ('resistor_e.resistor[1].v.re' * (-'resistor_e.resistor[1].i.im') + 'resistor_e.resistor[1].v.im' * 'resistor_e.resistor[1].i.re') ^ 2.0);
    'resistor_e.resistor[1].pf' = cos('Modelica.Math.atan3'('resistor_e.resistor[1].Q', 'resistor_e.resistor[1].P', 0.0));
    'resistor_e.resistor[2].abs_v' = sqrt('resistor_e.resistor[2].v.re' ^ 2.0 + 'resistor_e.resistor[2].v.im' ^ 2.0);
    'resistor_e.resistor[2].arg_v' = 'Modelica.Math.atan3'('resistor_e.resistor[2].v.im', 'resistor_e.resistor[2].v.re', 0.0);
    'resistor_e.resistor[2].abs_i' = sqrt('resistor_e.resistor[2].i.re' ^ 2.0 + 'resistor_e.resistor[2].i.im' ^ 2.0);
    'resistor_e.resistor[2].arg_i' = 'Modelica.Math.atan3'('resistor_e.resistor[2].i.im', 'resistor_e.resistor[2].i.re', 0.0);
    'resistor_e.resistor[2].P' = 'resistor_e.resistor[2].v.re' * 'resistor_e.resistor[2].i.re' - 'resistor_e.resistor[2].v.im' * (-'resistor_e.resistor[2].i.im');
    'resistor_e.resistor[2].Q' = 'resistor_e.resistor[2].v.re' * (-'resistor_e.resistor[2].i.im') + 'resistor_e.resistor[2].v.im' * 'resistor_e.resistor[2].i.re';
    'resistor_e.resistor[2].S' = sqrt(('resistor_e.resistor[2].v.re' * 'resistor_e.resistor[2].i.re' - 'resistor_e.resistor[2].v.im' * (-'resistor_e.resistor[2].i.im')) ^ 2.0 + ('resistor_e.resistor[2].v.re' * (-'resistor_e.resistor[2].i.im') + 'resistor_e.resistor[2].v.im' * 'resistor_e.resistor[2].i.re') ^ 2.0);
    'resistor_e.resistor[2].pf' = cos('Modelica.Math.atan3'('resistor_e.resistor[2].Q', 'resistor_e.resistor[2].P', 0.0));
    'resistor_e.resistor[3].abs_v' = sqrt('resistor_e.resistor[3].v.re' ^ 2.0 + 'resistor_e.resistor[3].v.im' ^ 2.0);
    'resistor_e.resistor[3].arg_v' = 'Modelica.Math.atan3'('resistor_e.resistor[3].v.im', 'resistor_e.resistor[3].v.re', 0.0);
    'resistor_e.resistor[3].abs_i' = sqrt('resistor_e.resistor[3].i.re' ^ 2.0 + 'resistor_e.resistor[3].i.im' ^ 2.0);
    'resistor_e.resistor[3].arg_i' = 'Modelica.Math.atan3'('resistor_e.resistor[3].i.im', 'resistor_e.resistor[3].i.re', 0.0);
    'resistor_e.resistor[3].P' = 'resistor_e.resistor[3].v.re' * 'resistor_e.resistor[3].i.re' - 'resistor_e.resistor[3].v.im' * (-'resistor_e.resistor[3].i.im');
    'resistor_e.resistor[3].Q' = 'resistor_e.resistor[3].v.re' * (-'resistor_e.resistor[3].i.im') + 'resistor_e.resistor[3].v.im' * 'resistor_e.resistor[3].i.re';
    'resistor_e.resistor[3].S' = sqrt(('resistor_e.resistor[3].v.re' * 'resistor_e.resistor[3].i.re' - 'resistor_e.resistor[3].v.im' * (-'resistor_e.resistor[3].i.im')) ^ 2.0 + ('resistor_e.resistor[3].v.re' * (-'resistor_e.resistor[3].i.im') + 'resistor_e.resistor[3].v.im' * 'resistor_e.resistor[3].i.re') ^ 2.0);
    'resistor_e.resistor[3].pf' = cos('Modelica.Math.atan3'('resistor_e.resistor[3].Q', 'resistor_e.resistor[3].P', 0.0));
    'resistor_m.P_total' = 'resistor_m.P[1]' + 'resistor_m.P[2]' + 'resistor_m.P[3]';
    'resistor_m.Q_total' = 'resistor_m.Q[1]' + 'resistor_m.Q[2]' + 'resistor_m.Q[3]';
    'resistor_m.S_total' = sqrt('resistor_m.P_total' ^ 2.0 + 'resistor_m.Q_total' ^ 2.0);
    'resistor_m.resistor[1].abs_v' = sqrt('resistor_m.resistor[1].v.re' ^ 2.0 + 'resistor_m.resistor[1].v.im' ^ 2.0);
    'resistor_m.resistor[1].arg_v' = 'Modelica.Math.atan3'('resistor_m.resistor[1].v.im', 'resistor_m.resistor[1].v.re', 0.0);
    'resistor_m.resistor[1].abs_i' = sqrt('resistor_m.resistor[1].i.re' ^ 2.0 + 'resistor_m.resistor[1].i.im' ^ 2.0);
    'resistor_m.resistor[1].arg_i' = 'Modelica.Math.atan3'('resistor_m.resistor[1].i.im', 'resistor_m.resistor[1].i.re', 0.0);
