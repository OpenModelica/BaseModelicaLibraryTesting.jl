//! base 0.1.0
package 'EddyCurrentLosses'
  function 'Complex.\'*\'.scalarProduct' "Scalar product of two complex vectors c1 and c2"
    input 'Complex'[:] 'c1';
    input 'Complex'[size('c1', 1)] 'c2';
    output 'Complex' 'c3';
  algorithm
    'c3' := 'Complex'(0.0, 0.0);

    for 'i' in 1:size('c1', 1) loop
      'c3' := 'Complex.\'constructor\'.fromReal'('c3'.'re' + 'c1['i']'.'re' * 'c2['i']'.'re' + 'c1['i']'.'im' * 'c2['i']'.'im', 'c3'.'im' + 'c1['i']'.'re' * 'c2['i']'.'im' - 'c1['i']'.'im' * 'c2['i']'.'re');
    end for;
    annotation(Inline = true, smoothOrder = 100);
  end 'Complex.\'*\'.scalarProduct';

  function 'Modelica.Math.atan3' "Four quadrant inverse tangent (select solution that is closest to given angle y0)"
    input Real 'u1';
    input Real 'u2';
    input Real 'y0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0;
    output Real 'y'(displayUnit = "deg", unit = "rad", quantity = "Angle");
    constant Real 'pi2' = 6.283185307179586;
    Real 'w';
  algorithm
    'w' := 'Modelica.Math.atan2'('u1', 'u2');

    if 'y0' == 0.0 then
      'y' := 'w';
    else
      'y' := 'w' + 'pi2' * integer((3.141592653589793 + 'y0' - 'w') / 'pi2');
    end if;
  end 'Modelica.Math.atan3';

  record 'Complex'
    Real 're';
    Real 'im';
  end 'Complex';

  model 'EddyCurrentLosses' "Comparison of equivalent circuits of eddy current loss models"
    constant Integer 'm' = 3 "Number of phases";
    parameter Real 'R'(unit = "Ohm", quantity = "Resistance") = 0.1 "Resistance";
    parameter Real 'Gc'(unit = "S", quantity = "Conductance") = 1e-4 "Loss conductance";
    parameter Real 'R_m'(unit = "H-1", quantity = "Reluctance") = 1.0 "Reluctance of the magnetic circuit";
    parameter Real 'N' = 1.0 "Number of turns";
    output Real 'lossPower_e'(unit = "W", quantity = "Power");
    output Real 'lossPower_m'(unit = "W", quantity = "Power");
    Real 'ground_e.pin.v.re'(unit = "V", quantity = "ElectricPotential") "Real part of complex number";
