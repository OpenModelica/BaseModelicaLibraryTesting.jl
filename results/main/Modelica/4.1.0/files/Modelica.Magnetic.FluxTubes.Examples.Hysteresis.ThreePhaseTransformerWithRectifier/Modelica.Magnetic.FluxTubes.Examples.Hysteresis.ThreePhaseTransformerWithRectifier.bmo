//! base 0.1.0
package 'ThreePhaseTransformerWithRectifier'
  function 'Modelica.Blocks.Continuous.Internal.Filter.roots.lowPass' "Return low pass filter roots as needed for block for given cut-off frequency"
    input Real[:] 'cr_in';
    input Real[:] 'c0_in';
    input Real[size('c0_in', 1)] 'c1_in';
    input Real 'f_cut'(unit = "Hz", quantity = "Frequency");
    output Real[size('cr_in', 1)] 'r';
    output Real[size('c0_in', 1)] 'a';
    output Real[size('c0_in', 1)] 'b';
    output Real[size('c0_in', 1)] 'ku';
    Real[size('c0_in', 1)] 'c0';
    Real[size('c0_in', 1)] 'c1';
    Real[size('cr_in', 1)] 'cr';
  algorithm
    ('cr', 'c0', 'c1') := 'Modelica.Blocks.Continuous.Internal.Filter.coefficients.lowPass'('cr_in', 'c0_in', 'c1_in', 'f_cut');

    for 'i' in 1:size('cr_in', 1) loop
      'r'['i'] := -'cr'['i'];
    end for;

    for 'i' in 1:size('c0_in', 1) loop
      'a'['i'] := -'c1'['i'] / 2.0;
      'b'['i'] := sqrt('c0'['i'] - 'a'['i'] * 'a'['i']);
      'ku'['i'] := 'c0'['i'] / 'b'['i'];
    end for;
  end 'Modelica.Blocks.Continuous.Internal.Filter.roots.lowPass';

  type 'Modelica.Blocks.Types.AnalogFilter' = enumeration('CriticalDamping', 'Bessel', 'Butterworth', 'ChebyshevI');

  type 'Modelica.Blocks.Types.FilterType' = enumeration('LowPass', 'HighPass', 'BandPass', 'BandStop');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'ThreePhaseTransformerWithRectifier' "Three-phase transformer (including hysteresis effect) with rectifier"
    Real 'ground1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ground2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'vSource1.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 50.0 "Amplitude of sine wave";
    parameter Real 'vSource1.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Real 'vSource1.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    Real 'vSource1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'vSource1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSource1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSource1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vSource1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vSource1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'vSource1.signalSource.amplitude' = 50.0 "Amplitude of sine wave";
    parameter Real 'vSource1.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 50.0 "Frequency of sine wave";
    parameter Real 'vSource1.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'vSource1.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'vSource1.signalSource.y' "Connector of Real output signal";
    parameter Real 'vSource1.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'vSource1.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'vSource1.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'vSource1.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    Real 'transformer.Temp.port.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Port temperature";
    Real 'transformer.Temp.port.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
    Real 'transformer.Temp.T'(unit = "K");
    parameter Integer 'transformer.N1' = 200 "Primary turns";
    parameter Real 'transformer.L1'(displayUnit = "mm", unit = "m", quantity = "Length") = 0.192 "Mean primary turn length";
    parameter Real 'transformer.d1'(displayUnit = "mm", unit = "m", quantity = "Length") = 5e-4 "Wire diameter of primary turns";
    parameter Real 'transformer.rho1'(unit = "Ohm.m", quantity = "Resistivity") = 1.678e-8 "Resistivity of primary winding (at 20degC)";
    parameter Real 'transformer.alpha1'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of primary turns";
    parameter Integer 'transformer.N2' = 10 "Secondary turns";
    parameter Real 'transformer.L2'(displayUnit = "mm", unit = "m", quantity = "Length") = 0.192 "Mean secondary turn length";
    parameter Real 'transformer.d2'(displayUnit = "mm", unit = "m", quantity = "Length") = 5e-4 "Wire diameter of secondary turns";
    parameter Real 'transformer.rho2'(unit = "Ohm.m", quantity = "Resistivity") = 1.678e-8 "Resistivity of secondary winding (at 20degC)";
    parameter Real 'transformer.alpha2'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of secondary turns";
    parameter Real 'transformer.l1'(displayUnit = "mm", unit = "m", quantity = "Length") = 0.2 "Mean length l1 of core";
    parameter Real 'transformer.l2'(displayUnit = "mm", unit = "m", quantity = "Length") = 0.15 "Mean length l2 of core";
    parameter Real 'transformer.a'(displayUnit = "mm", unit = "m", quantity = "Length") = 0.04 "Height of core";
    parameter Real 'transformer.b'(displayUnit = "mm", unit = "m", quantity = "Length") = 0.04 "Width of core";
    parameter Real 'transformer.mat.Hsat'(unit = "A/m", quantity = "MagneticFieldStrength") = 650.0 "Hysteresis region between -Hsat .. Hsat";
    parameter Real 'transformer.mat.M'(unit = "1") = 0.967 "Related to saturation value of magnetization";
    parameter Real 'transformer.mat.r'(unit = "1") = 0.50256 "Proportion of the straight region in the vicinity of Hc";
    parameter Real 'transformer.mat.q'(unit = "m/A") = 0.039964 "Slope of the straight region in the vicinity of Hc";
    parameter Real 'transformer.mat.p1'(unit = "m/A") = 0.18807 "Sharpness of major loop";
    parameter Real 'transformer.mat.p2'(unit = "m/A") = 7.81e-4 "Sharpness of major loop";
    parameter Real 'transformer.mat.Hc'(unit = "A/m", quantity = "MagneticFieldStrength") = 42.2283 "Major loop coercivity";
    parameter Real 'transformer.mat.K'(unit = "1") = 50.0 "Slope in saturation region mu_0*K";
    parameter Real 'transformer.mat.sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6 "Electrical conductivity of material";
    Real 'transformer.v1[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drop of primary winding 1-3";
    Real 'transformer.v1[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drop of primary winding 1-3";
    Real 'transformer.v1[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drop of primary winding 1-3";
    Real 'transformer.v2[1]'(unit = "V", quantity = "ElectricPotential") "Voltage drop of secondary winding 1-3";
    Real 'transformer.v2[2]'(unit = "V", quantity = "ElectricPotential") "Voltage drop of secondary winding 1-3";
    Real 'transformer.v2[3]'(unit = "V", quantity = "ElectricPotential") "Voltage drop of secondary winding 1-3";
    Real 'transformer.R1[1]'(unit = "Ohm", quantity = "Resistance") "Resistance of primary winding 1-3";
    Real 'transformer.R1[2]'(unit = "Ohm", quantity = "Resistance") "Resistance of primary winding 1-3";
    Real 'transformer.R1[3]'(unit = "Ohm", quantity = "Resistance") "Resistance of primary winding 1-3";
    Real 'transformer.R2[1]'(unit = "Ohm", quantity = "Resistance") "Resistance of secondary winding 1-3";
    Real 'transformer.R2[2]'(unit = "Ohm", quantity = "Resistance") "Resistance of secondary winding 1-3";
    Real 'transformer.R2[3]'(unit = "Ohm", quantity = "Resistance") "Resistance of secondary winding 1-3";
    Real 'transformer.i1[1]'(unit = "A", quantity = "ElectricCurrent") "Current in primary winding 1-3";
    Real 'transformer.i1[2]'(unit = "A", quantity = "ElectricCurrent") "Current in primary winding 1-3";
    Real 'transformer.i1[3]'(unit = "A", quantity = "ElectricCurrent") "Current in primary winding 1-3";
    Real 'transformer.i2[1]'(unit = "A", quantity = "ElectricCurrent") "Current in secondary winding 1-3";
    Real 'transformer.i2[2]'(unit = "A", quantity = "ElectricCurrent") "Current in secondary winding 1-3";
    Real 'transformer.i2[3]'(unit = "A", quantity = "ElectricCurrent") "Current in secondary winding 1-3";
    Real 'transformer.B[1]'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic Flux Density in core portions 1-3";
    Real 'transformer.B[2]'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic Flux Density in core portions 1-3";
    Real 'transformer.B[3]'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic Flux Density in core portions 1-3";
    Real 'transformer.Phi[1]'(unit = "Wb", quantity = "MagneticFlux") "Magnetic Flux through core portions 1-3";
    Real 'transformer.Phi[2]'(unit = "Wb", quantity = "MagneticFlux") "Magnetic Flux through core portions 1-3";
    Real 'transformer.Phi[3]'(unit = "Wb", quantity = "MagneticFlux") "Magnetic Flux through core portions 1-3";
    Real 'transformer.Hstat[1]'(unit = "A/m", quantity = "MagneticFieldStrength") "Ferromagnetic portion of magnetic field strength";
    Real 'transformer.Hstat[2]'(unit = "A/m", quantity = "MagneticFieldStrength") "Ferromagnetic portion of magnetic field strength";
    Real 'transformer.Hstat[3]'(unit = "A/m", quantity = "MagneticFieldStrength") "Ferromagnetic portion of magnetic field strength";
    Real 'transformer.Heddy[1]'(unit = "A/m", quantity = "MagneticFieldStrength") "Eddy current portion of magnetic field strength";
    Real 'transformer.Heddy[2]'(unit = "A/m", quantity = "MagneticFieldStrength") "Eddy current portion of magnetic field strength";
    Real 'transformer.Heddy[3]'(unit = "A/m", quantity = "MagneticFieldStrength") "Eddy current portion of magnetic field strength";
    Real 'transformer.H[1]'(unit = "A/m", quantity = "MagneticFieldStrength") "Total magnetic field strength of core";
    Real 'transformer.H[2]'(unit = "A/m", quantity = "MagneticFieldStrength") "Total magnetic field strength of core";
    Real 'transformer.H[3]'(unit = "A/m", quantity = "MagneticFieldStrength") "Total magnetic field strength of core";
    parameter Real 'transformer.MagRelStart[1]' = -0.4 "Initial magnetization of Core (-1..1)";
    parameter Real 'transformer.MagRelStart[2]' = 0.8 "Initial magnetization of Core (-1..1)";
    parameter Real 'transformer.MagRelStart[3]' = -0.4 "Initial magnetization of Core (-1..1)";
    parameter Boolean 'transformer.MagRelFixed[1]' = true "Fixed";
    parameter Boolean 'transformer.MagRelFixed[2]' = true "Fixed";
    parameter Boolean 'transformer.MagRelFixed[3]' = false "Fixed";
    parameter Real 'transformer.HStart[1]'(unit = "A/m", quantity = "MagneticFieldStrength") = 0.0 "Initial magnetic field strength of Core";
    parameter Real 'transformer.HStart[2]'(unit = "A/m", quantity = "MagneticFieldStrength") = 0.0 "Initial magnetic field strength of Core";
    parameter Real 'transformer.HStart[3]'(unit = "A/m", quantity = "MagneticFieldStrength") = 0.0 "Initial magnetic field strength of Core";
    parameter Boolean 'transformer.HFixed[1]' = true "Fixed";
    parameter Boolean 'transformer.HFixed[2]' = true "Fixed";
    parameter Boolean 'transformer.HFixed[3]' = true "Fixed";
    parameter Real 'transformer.I1Start[1]'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Initial current of primary Windings";
    parameter Real 'transformer.I1Start[2]'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Initial current of primary Windings";
    parameter Real 'transformer.I1Start[3]'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Initial current of primary Windings";
    parameter Boolean 'transformer.I1Fixed[1]' = true "Fixed";
    parameter Boolean 'transformer.I1Fixed[2]' = true "Fixed";
    parameter Boolean 'transformer.I1Fixed[3]' = true "Fixed";
    parameter Real 'transformer.I2Start[1]'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Initial current of secondary Windings";
    parameter Real 'transformer.I2Start[2]'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Initial current of secondary Windings";
    parameter Real 'transformer.I2Start[3]'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Initial current of secondary Windings";
    parameter Boolean 'transformer.I2Fixed[1]' = true "Fixed";
    parameter Boolean 'transformer.I2Fixed[2]' = false "Fixed";
    parameter Boolean 'transformer.I2Fixed[3]' = false "Fixed";
    Real 'transformer.LossPowerWinding'(unit = "W", quantity = "Power") "Winding losses";
    Real 'transformer.LossPowerStat'(unit = "W", quantity = "Power") "Ferromagnetic hysteresis losses";
    Real 'transformer.LossPowerEddy'(unit = "W", quantity = "Power") "Eddy current losses";
    parameter Boolean 'transformer.useHeatPort' = false "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'transformer.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'transformer.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via HeatPort";
    Real 'transformer.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of HeatPort";
    parameter Boolean 'transformer.EddyCurrents' = true "Enable eddy currents";
    parameter Real 'transformer.sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6 "Conductivity of core material";
    parameter Real 'transformer.t'(displayUnit = "mm", unit = "m", quantity = "Length") = 5e-4 "Thickness of lamination";
    parameter Real 'transformer.L_l1'(unit = "m", quantity = "Length") = 0.01 "Length of leakage of primary Winding";
    parameter Real 'transformer.A_l1'(unit = "m2", quantity = "Area") = 1e-5 "Cross section of leakage of primary Winding";
    parameter Real 'transformer.mu_rel1' = 1.0 "Constant relative permeability of primary leakage (>0 required)";
    parameter Real 'transformer.L_l2'(unit = "m", quantity = "Length") = 0.01 "Cross section of leakage of secondary Winding";
    parameter Real 'transformer.A_l2'(unit = "m2", quantity = "Area") = 1e-5 "Length of leakage of secondary Winding";
    parameter Real 'transformer.mu_rel2' = 1.0 "Constant relative permeability of secondary leakage (>0 required)";
    parameter Real 'transformer.core1.mat.Hsat'(unit = "A/m", quantity = "MagneticFieldStrength") = 650.0 "Hysteresis region between -Hsat .. Hsat";
    parameter Real 'transformer.core1.mat.M'(unit = "1") = 0.967 "Related to saturation value of magnetization";
    parameter Real 'transformer.core1.mat.r'(unit = "1") = 0.50256 "Proportion of the straight region in the vicinity of Hc";
    parameter Real 'transformer.core1.mat.q'(unit = "m/A") = 0.039964 "Slope of the straight region in the vicinity of Hc";
    parameter Real 'transformer.core1.mat.p1'(unit = "m/A") = 0.18807 "Sharpness of major loop";
    parameter Real 'transformer.core1.mat.p2'(unit = "m/A") = 7.81e-4 "Sharpness of major loop";
    parameter Real 'transformer.core1.mat.Hc'(unit = "A/m", quantity = "MagneticFieldStrength") = 42.2283 "Major loop coercivity";
    parameter Real 'transformer.core1.mat.K'(unit = "1") = 50.0 "Slope in saturation region mu_0*K";
    parameter Real 'transformer.core1.mat.sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6 "Electrical conductivity of material";
    Real 'transformer.core1.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'transformer.core1.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'transformer.core1.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'transformer.core1.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'transformer.core1.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'transformer.core1.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'transformer.core1.l'(unit = "m", quantity = "Length") = 0.5 "Length in direction of flux";
    parameter Real 'transformer.core1.A'(unit = "m2", quantity = "Area") = 0.0016 "Area of cross section";
    parameter Real 'transformer.core1.V'(unit = "m3", quantity = "Volume") = 8e-4 "Volume of FluxTube";
    parameter Boolean 'transformer.core1.useHeatPort' = false "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'transformer.core1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'transformer.core1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via HeatPort";
    Real 'transformer.core1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of HeatPort";
    parameter Boolean 'transformer.core1.includeEddyCurrents' = true "= true, if eddy current losses are enabled" annotation(Evaluate = true);
    parameter Real 'transformer.core1.sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6 "Conductivity of core material";
    parameter Real 'transformer.core1.d'(unit = "m", quantity = "Length") = 5e-4 "Thickness of lamination";
    Real 'transformer.core1.H'(fixed = true, start = 0.0, unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'transformer.core1.Hstat'(unit = "A/m", quantity = "MagneticFieldStrength") "Static (ferromagnetic) portion of the magnetic field strength";
    Real 'transformer.core1.Heddy'(unit = "A/m", quantity = "MagneticFieldStrength") "Dynamic (eddy currents) portion of the magnetic field strength";
    Real 'transformer.core1.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'transformer.core1.MagRel'(fixed = true, start = -0.4, max = 1.0, min = -1.0, unit = "1", quantity = "Relative magnetization") "Relative magnetization at initialization (-1..1)";
    Real 'transformer.core1.LossPowerStat'(unit = "W", quantity = "Power") "Ferromagnetic (static) hysteresis losses";
    Real 'transformer.core1.LossPowerEddy'(unit = "W", quantity = "Power") "Eddy current losses (dynamic hysteresis losses)";
    Real 'transformer.core1.derHstat'(start = 0.0, unit = "A/(m.s)");
    parameter Real 'transformer.core1.eddyCurrentFactor'(unit = "S.m") = 0.04583333333333333;
    Boolean 'transformer.core1.asc'(start = true) "True when der(Hstat)>0";
    Real 'transformer.core1.hystR'(unit = "T", quantity = "MagneticFluxDensity") "Rising branch of limiting hysteresis loop";
    Real 'transformer.core1.hystF'(unit = "T", quantity = "MagneticFluxDensity") "Falling branch of limiting hysteresis loop";
    Real 'transformer.core1.diffHyst'(unit = "T", quantity = "MagneticFluxDensity") "Distance between rising and falling limiting hysteresis branch at the current operating point";
    Real 'transformer.core1.dHyst'(unit = "T/s", quantity = "MagneticFluxDensitySlope") "Slope of the Rising (when der(H)>0) or Falling (when der(H)<0) limiting hysteresis branch at the current operating point";
    Real 'transformer.core1.k';
    parameter Real 'transformer.core1.mu0'(unit = "N/A2") = 6.2831853106e-5;
    parameter Real 'transformer.core1.Js'(unit = "T", quantity = "MagneticFluxDensity") = 1.4331021782802786 "Saturation polarization";
    parameter Real 'transformer.core1.eps'(unit = "T", quantity = "MagneticFluxDensity") = 9.67e-4;
    parameter Real 'transformer.core1.P1' = 1.6930237203043585;
    parameter Real 'transformer.core1.P4' = 0.011178593500680808;
    Real 'transformer.core1.H2'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'transformer.core1.H3'(unit = "A/m", quantity = "MagneticFieldStrength");
    Real 'transformer.core1.P2';
    Real 'transformer.core1.P3';
    Real 'transformer.core1.H_lim';
    constant Real 'transformer.core1.unitT'(unit = "T", quantity = "MagneticFluxDensity") = 1.0;
    parameter Real 'transformer.core2.mat.Hsat'(unit = "A/m", quantity = "MagneticFieldStrength") = 650.0 "Hysteresis region between -Hsat .. Hsat";
    parameter Real 'transformer.core2.mat.M'(unit = "1") = 0.967 "Related to saturation value of magnetization";
    parameter Real 'transformer.core2.mat.r'(unit = "1") = 0.50256 "Proportion of the straight region in the vicinity of Hc";
    parameter Real 'transformer.core2.mat.q'(unit = "m/A") = 0.039964 "Slope of the straight region in the vicinity of Hc";
    parameter Real 'transformer.core2.mat.p1'(unit = "m/A") = 0.18807 "Sharpness of major loop";
    parameter Real 'transformer.core2.mat.p2'(unit = "m/A") = 7.81e-4 "Sharpness of major loop";
    parameter Real 'transformer.core2.mat.Hc'(unit = "A/m", quantity = "MagneticFieldStrength") = 42.2283 "Major loop coercivity";
    parameter Real 'transformer.core2.mat.K'(unit = "1") = 50.0 "Slope in saturation region mu_0*K";
    parameter Real 'transformer.core2.mat.sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6 "Electrical conductivity of material";
    Real 'transformer.core2.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'transformer.core2.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'transformer.core2.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'transformer.core2.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'transformer.core2.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'transformer.core2.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'transformer.core2.l'(unit = "m", quantity = "Length") = 0.15 "Length in direction of flux";
    parameter Real 'transformer.core2.A'(unit = "m2", quantity = "Area") = 0.0016 "Area of cross section";
    parameter Real 'transformer.core2.V'(unit = "m3", quantity = "Volume") = 2.4e-4 "Volume of FluxTube";
    parameter Boolean 'transformer.core2.useHeatPort' = false "= true, if HeatPort is enabled" annotation(Evaluate = true);
    parameter Real 'transformer.core2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'transformer.core2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via HeatPort";
    Real 'transformer.core2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of HeatPort";
    parameter Boolean 'transformer.core2.includeEddyCurrents' = true "= true, if eddy current losses are enabled" annotation(Evaluate = true);
    parameter Real 'transformer.core2.sigma'(unit = "S/m", quantity = "Conductivity") = 2.2e6 "Conductivity of core material";
    parameter Real 'transformer.core2.d'(unit = "m", quantity = "Length") = 5e-4 "Thickness of lamination";
    Real 'transformer.core2.H'(fixed = true, start = 0.0, unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'transformer.core2.Hstat'(unit = "A/m", quantity = "MagneticFieldStrength") "Static (ferromagnetic) portion of the magnetic field strength";
    Real 'transformer.core2.Heddy'(unit = "A/m", quantity = "MagneticFieldStrength") "Dynamic (eddy currents) portion of the magnetic field strength";
    Real 'transformer.core2.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'transformer.core2.MagRel'(fixed = true, start = 0.8, max = 1.0, min = -1.0, unit = "1", quantity = "Relative magnetization") "Relative magnetization at initialization (-1..1)";
    Real 'transformer.core2.LossPowerStat'(unit = "W", quantity = "Power") "Ferromagnetic (static) hysteresis losses";
