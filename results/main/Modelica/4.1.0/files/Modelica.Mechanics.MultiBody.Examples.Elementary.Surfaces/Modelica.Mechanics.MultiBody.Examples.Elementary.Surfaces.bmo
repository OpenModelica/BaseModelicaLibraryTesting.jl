    0.0 = 'fixedTranslation3.frame_a.t[1]' + 'fixedTranslation3.frame_b.t[1]' + (-2.2) * 'fixedTranslation3.frame_b.f[3]';
    0.0 = 'fixedTranslation3.frame_a.t[2]' + 'fixedTranslation3.frame_b.t[2]';
    0.0 = 'fixedTranslation3.frame_a.t[3]' + 'fixedTranslation3.frame_b.t[3]' - (-2.2) * 'fixedTranslation3.frame_b.f[1]';
    annotation(experiment(StopTime = 5));
  end 'Surfaces';
end 'Surfaces';
