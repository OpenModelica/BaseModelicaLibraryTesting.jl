//! base 0.1.0
package 'ImpureGenerator'
  function 'Modelica.Math.Random.Utilities.impureRandom' "Impure random number generator (with hidden state vector)"
    input Integer 'id';
    output Real 'y';
  external "C" 'y' = ModelicaRandom_impureRandom_xorshift1024star('id') annotation(Library = "ModelicaExternalC", LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Math.Random.Utilities.impureRandom';

  function 'Modelica.Math.Random.Utilities.initializeImpureRandom' "Initializes the internal state of the impure random number generator"
    input Integer 'seed';
    output Integer 'id';
    constant Integer 'localSeed' = 715827883;
    Integer[33] 'rngState';
  algorithm
    'rngState' := 'Modelica.Math.Random.Utilities.initialStateWithXorshift64star'('localSeed', 'seed', 33);
    'id' := 'localSeed';
    'Modelica.Math.Random.Utilities.initializeImpureRandom.setInternalState'('rngState', 'id');
  end 'Modelica.Math.Random.Utilities.initializeImpureRandom';

  model 'ImpureGenerator' "Demonstrates the usage of the impure random number generator"
    output Real 'impureRandom_y';
    parameter Boolean 'globalSeed.enableNoise' = true "= true, if noise blocks generate noise as output; = false, if they generate a constant output";
    parameter Boolean 'globalSeed.useAutomaticSeed' = false "= true, choose a seed by system time and process id; = false, use fixedSeed";
    parameter Integer 'globalSeed.fixedSeed' = 67867967 "Fixed global seed for random number generators (if useAutomaticSeed = false)";
    parameter Integer 'globalSeed.seed'(fixed = false) "Actually used global seed";
    parameter Integer 'globalSeed.id_impure'(fixed = false) "ID for impure random number generators Modelica.Math.Random.Utilities.impureXXX";
    Real 'impureRandom.y' "Connector of Real output signal";
    parameter Real 'impureRandom.samplePeriod'(unit = "s", quantity = "Time") = 0.01 "Sample period for random number generation";
  initial equation
    'globalSeed.seed' = 67867967;
    'globalSeed.id_impure' = 'Modelica.Math.Random.Utilities.initializeImpureRandom'('globalSeed.seed');
  equation
    'impureRandom_y' = 'impureRandom.y';

    when {initial(), sample(0.01, 0.01)} then
      'impureRandom.y' = 'Modelica.Math.Random.Utilities.impureRandom'('globalSeed.id_impure');
    end when;
    annotation(experiment(StopTime = 2));
  end 'ImpureGenerator';
end 'ImpureGenerator';
