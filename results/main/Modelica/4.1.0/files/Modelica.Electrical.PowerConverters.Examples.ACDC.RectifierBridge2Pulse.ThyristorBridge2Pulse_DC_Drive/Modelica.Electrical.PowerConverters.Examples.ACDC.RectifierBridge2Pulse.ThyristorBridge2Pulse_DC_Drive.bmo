//! base 0.1.0
package 'ThyristorBridge2Pulse_DC_Drive'
  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'ThyristorBridge2Pulse_DC_Drive' "Two pulse Graetz thyristor bridge feeding a DC drive"
    parameter Real 'Vrms'(unit = "V", quantity = "ElectricPotential") = 111.07207345395915 "RMS supply voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 50.0 "Frequency";
    parameter Real 'SMains'(unit = "V.A", quantity = "Power") = 2.5e5 "Mains short circuit apparent power";
    parameter Real 'lamdaMains' = 0.1 "Mains short circuit power factor";
    parameter Real 'ZMains'(unit = "Ohm", quantity = "Resistance") = 0.04934802200544679 "Mains short circuit impedance";
    parameter Real 'RMains'(unit = "Ohm", quantity = "Resistance") = 0.004934802200544679 "Mains resistance" annotation(Evaluate = true);
    parameter Real 'LMains'(unit = "H", quantity = "Inductance") = 1.5629226114141466e-4 "Mains inductance" annotation(Evaluate = true);
    parameter Real 'Ld'(unit = "H", quantity = "Inductance") = 0.015 "Smoothing inductance" annotation(Evaluate = true);
    parameter Real 'tauNominal'(unit = "N.m", quantity = "Torque") = 63.66197723675815 "Nominal torque";
    output Real 'w'(displayUnit = "rpm", unit = "rad/s", quantity = "AngularVelocity") = 'dcpm.wMechanical' "Angular velocity of drive";
    output Real 'tau'(unit = "N.m", quantity = "Torque") = 'dcpm.tauShaft' "Shaft torque of drive";
