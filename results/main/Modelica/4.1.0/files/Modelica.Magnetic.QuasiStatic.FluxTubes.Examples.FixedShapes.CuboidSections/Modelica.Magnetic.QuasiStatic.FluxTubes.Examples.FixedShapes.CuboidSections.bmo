    'cuboidTop.H.im' = 'cuboidTop.B.im' * (1.25663706212e-6 * 'cuboidTop.mu_r') / (1.25663706212e-6 * 'cuboidTop.mu_r' * (1.25663706212e-6 * 'cuboidTop.mu_r'));
