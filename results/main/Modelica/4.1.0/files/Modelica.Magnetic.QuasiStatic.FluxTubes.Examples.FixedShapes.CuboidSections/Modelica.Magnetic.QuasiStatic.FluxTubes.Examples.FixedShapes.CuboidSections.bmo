    'cuboidLeft.H.im' = 'cuboidLeft.B.im' * (1.25663706212e-6 * 'cuboidLeft.mu_r') / (1.25663706212e-6 * 'cuboidLeft.mu_r' * (1.25663706212e-6 * 'cuboidLeft.mu_r'));
