//! base 0.1.0
package 'CompareLosslessLines'
  model 'CompareLosslessLines' "Compare lossless lines with different load"
    parameter Real 'l'(min = 2.2250738585072014e-308, unit = "H/m") = 2.5e-7 "Inductance per meter";
    parameter Real 'c'(min = 2.2250738585072014e-308, unit = "F/m") = 1e-10 "Capacitance per meter";
    parameter Real 'len'(unit = "m", quantity = "Length") = 1.0 "Length of line";
    parameter Real 'c0'(unit = "m/s", quantity = "Velocity") = 2e8 "Speed of EM wave";
    parameter Real 'td'(unit = "s", quantity = "Time") = 5e-9 "Transmission delay";
    parameter Real 'z0'(unit = "Ohm", quantity = "Resistance") = 50.0 "Characteristic impedance";
    Real 'source1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source1.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'source1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'ri1.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 50.0 "Resistance at temperature T_ref";
    parameter Real 'ri1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'ri1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ri1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'ri1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ri1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ri1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ri1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ri1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'ri1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'ri1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'ri1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'ri1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'ri1.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ground1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'line1.v2'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'line1.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'line1.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'line1.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'line1.Z0'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 50.0 "Characteristic impedance";
    parameter Real 'line1.TD'(unit = "s", quantity = "Time") = 5e-9 "Transmission delay: specify > 0 if F and NL are not given";
    parameter Real 'line1.F'(unit = "Hz", quantity = "Frequency") = 0.0 "Frequency: specify > 0 if TD is not given";
    parameter Real 'line1.NL' = 0.25 "Normalized length: specify if TD is not given";
    Real 'line1.es'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of forward travelling wave";
    Real 'line1.er'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of reflected wave";
    parameter Real 'line1.TDi'(unit = "s", quantity = "Time") = 5e-9 "Internally used transmission delay";
    Real 'load1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'load1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'source2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source2.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'source2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'ri2.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 50.0 "Resistance at temperature T_ref";
    parameter Real 'ri2.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'ri2.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ri2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'ri2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ri2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ri2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ri2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ri2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'ri2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'ri2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'ri2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'ri2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'ri2.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ground2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line2.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'line2.v2'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'line2.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'line2.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'line2.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line2.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line2.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line2.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line2.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line2.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line2.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line2.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'line2.Z0'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 50.0 "Characteristic impedance";
    parameter Real 'line2.TD'(unit = "s", quantity = "Time") = 5e-9 "Transmission delay: specify > 0 if F and NL are not given";
    parameter Real 'line2.F'(unit = "Hz", quantity = "Frequency") = 0.0 "Frequency: specify > 0 if TD is not given";
    parameter Real 'line2.NL' = 0.25 "Normalized length: specify if TD is not given";
    Real 'line2.es'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of forward travelling wave";
    Real 'line2.er'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of reflected wave";
    parameter Real 'line2.TDi'(unit = "s", quantity = "Time") = 5e-9 "Internally used transmission delay";
    parameter Real 'load2.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 50.0 "Resistance at temperature T_ref";
    parameter Real 'load2.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'load2.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'load2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'load2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'load2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'load2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'load2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'load2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'load2.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'source3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source3.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'source3.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'source3.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'source3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'ground3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line3.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'line3.v2'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'line3.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'line3.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'line3.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line3.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line3.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line3.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line3.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line3.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line3.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line3.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'line3.Z0'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 50.0 "Characteristic impedance";
    parameter Real 'line3.TD'(unit = "s", quantity = "Time") = 5e-9 "Transmission delay: specify > 0 if F and NL are not given";
    parameter Real 'line3.F'(unit = "Hz", quantity = "Frequency") = 0.0 "Frequency: specify > 0 if TD is not given";
    parameter Real 'line3.NL' = 0.25 "Normalized length: specify if TD is not given";
    Real 'line3.es'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of forward travelling wave";
    Real 'line3.er'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage source of reflected wave";
    parameter Real 'line3.TDi'(unit = "s", quantity = "Time") = 5e-9 "Internally used transmission delay";
    parameter Real 'ri3.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 50.0 "Resistance at temperature T_ref";
    parameter Real 'ri3.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'ri3.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'ri3.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'ri3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ri3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ri3.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ri3.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ri3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'ri3.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'ri3.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'ri3.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'ri3.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'ri3.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'load3.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'load3.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load3.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load3.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'load3.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'load3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'pulse.amplitude' = 10.0 "Amplitude of pulse";
    parameter Real 'pulse.width'(max = 100.0, min = 2.2250738585072014e-308) = 50.0 "Width of pulse in % of period";
    parameter Real 'pulse.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 5e-9 "Time for one period";
    parameter Integer 'pulse.nperiod' = 1 "Number of periods (< 0 means infinite number of periods)";
    Real 'pulse.y' "Connector of Real output signal";
    parameter Real 'pulse.offset' = 0.0 "Offset of output signal y";
    parameter Real 'pulse.startTime'(unit = "s", quantity = "Time") = 2.5e-9 "Output y = offset for time < startTime";
    Real 'pulse.T_width'(unit = "s", quantity = "Time") = 2.5e-9;
    Real 'pulse.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'pulse.count' "Period count";
  equation
    'line1.p2.v' = 'load1.p.v';
    'load1.n.v' = 'ground1.p.v';
    'load1.n.v' = 'line1.n2.v';
    'load1.n.v' = 'source1.n.v';
    'load1.n.v' = 'line1.n1.v';
    'line2.p2.v' = 'load2.p.v';
    'load2.n.v' = 'ground2.p.v';
    'load2.n.v' = 'line2.n2.v';
    'load2.n.v' = 'source2.n.v';
    'load2.n.v' = 'line2.n1.v';
    'line3.p2.v' = 'load3.p.v';
    'load3.n.v' = 'ground3.p.v';
    'load3.n.v' = 'line3.n2.v';
    'load3.n.v' = 'source3.n.v';
    'load3.n.v' = 'line3.n1.v';
    'pulse.y' = 'source3.v';
    'pulse.y' = 'source1.v';
    'pulse.y' = 'source2.v';
    'source1.p.v' = 'ri1.p.v';
    'ri1.n.v' = 'line1.p1.v';
    'source2.p.v' = 'ri2.p.v';
    'ri2.n.v' = 'line2.p1.v';
    'source3.p.v' = 'ri3.p.v';
    'ri3.n.v' = 'line3.p1.v';
    'ri1.p.i' + 'source1.p.i' = 0.0;
    'line1.p1.i' + 'ri1.n.i' = 0.0;
    'load1.p.i' + 'line1.p2.i' = 0.0;
    'load1.n.i' + 'line1.n2.i' + 'line1.n1.i' + 'ground1.p.i' + 'source1.n.i' = 0.0;
    'ri2.p.i' + 'source2.p.i' = 0.0;
    'line2.p1.i' + 'ri2.n.i' = 0.0;
    'load2.p.i' + 'line2.p2.i' = 0.0;
    'load2.n.i' + 'line2.n2.i' + 'line2.n1.i' + 'ground2.p.i' + 'source2.n.i' = 0.0;
    'ri3.p.i' + 'source3.p.i' = 0.0;
    'load3.p.i' + 'line3.p2.i' = 0.0;
    'load3.n.i' + 'line3.n2.i' + 'line3.n1.i' + 'ground3.p.i' + 'source3.n.i' = 0.0;
    'ri3.n.i' + 'line3.p1.i' = 0.0;
    'source1.v' = 'source1.p.v' - 'source1.n.v';
    0.0 = 'source1.p.i' + 'source1.n.i';
    'source1.i' = 'source1.p.i';
    'ri1.R_actual' = 50.0;
    'ri1.v' = 'ri1.R_actual' * 'ri1.i';
    'ri1.LossPower' = 'ri1.v' * 'ri1.i';
    'ri1.T_heatPort' = 300.15;
    0.0 = 'ri1.p.i' + 'ri1.n.i';
    'ri1.i' = 'ri1.p.i';
    'ri1.v' = 'ri1.p.v' - 'ri1.n.v';
    'ground1.p.v' = 0.0;
    'line1.i1' = ('line1.v1' - 'line1.es') / 50.0;
    'line1.i2' = ('line1.v2' - 'line1.er') / 50.0;
    'line1.es' = 2.0 * delay('line1.v2', 5e-9, 5e-9) - delay('line1.er', 5e-9, 5e-9);
    'line1.er' = 2.0 * delay('line1.v1', 5e-9, 5e-9) - delay('line1.es', 5e-9, 5e-9);
    0.0 = 'line1.p1.i' + 'line1.n1.i';
    0.0 = 'line1.p2.i' + 'line1.n2.i';
    'line1.v1' = 'line1.p1.v' - 'line1.n1.v';
    'line1.v2' = 'line1.p2.v' - 'line1.n2.v';
    'line1.i1' = 'line1.p1.i';
    'line1.i2' = 'line1.p2.i';
    'load1.i' = 0.0;
    0.0 = 'load1.p.i' + 'load1.n.i';
    'load1.i' = 'load1.p.i';
    'load1.v' = 'load1.p.v' - 'load1.n.v';
    'source2.v' = 'source2.p.v' - 'source2.n.v';
    0.0 = 'source2.p.i' + 'source2.n.i';
    'source2.i' = 'source2.p.i';
    'ri2.R_actual' = 50.0;
    'ri2.v' = 'ri2.R_actual' * 'ri2.i';
    'ri2.LossPower' = 'ri2.v' * 'ri2.i';
    'ri2.T_heatPort' = 300.15;
    0.0 = 'ri2.p.i' + 'ri2.n.i';
    'ri2.i' = 'ri2.p.i';
    'ri2.v' = 'ri2.p.v' - 'ri2.n.v';
    'ground2.p.v' = 0.0;
    'line2.i1' = ('line2.v1' - 'line2.es') / 50.0;
    'line2.i2' = ('line2.v2' - 'line2.er') / 50.0;
    'line2.es' = 2.0 * delay('line2.v2', 5e-9, 5e-9) - delay('line2.er', 5e-9, 5e-9);
    'line2.er' = 2.0 * delay('line2.v1', 5e-9, 5e-9) - delay('line2.es', 5e-9, 5e-9);
    0.0 = 'line2.p1.i' + 'line2.n1.i';
    0.0 = 'line2.p2.i' + 'line2.n2.i';
    'line2.v1' = 'line2.p1.v' - 'line2.n1.v';
    'line2.v2' = 'line2.p2.v' - 'line2.n2.v';
    'line2.i1' = 'line2.p1.i';
    'line2.i2' = 'line2.p2.i';
    'load2.R_actual' = 50.0;
    'load2.v' = 'load2.R_actual' * 'load2.i';
    'load2.LossPower' = 'load2.v' * 'load2.i';
    'load2.T_heatPort' = 300.15;
    0.0 = 'load2.p.i' + 'load2.n.i';
    'load2.i' = 'load2.p.i';
    'load2.v' = 'load2.p.v' - 'load2.n.v';
    'source3.v' = 'source3.p.v' - 'source3.n.v';
    0.0 = 'source3.p.i' + 'source3.n.i';
    'source3.i' = 'source3.p.i';
    'ground3.p.v' = 0.0;
    'line3.i1' = ('line3.v1' - 'line3.es') / 50.0;
    'line3.i2' = ('line3.v2' - 'line3.er') / 50.0;
    'line3.es' = 2.0 * delay('line3.v2', 5e-9, 5e-9) - delay('line3.er', 5e-9, 5e-9);
    'line3.er' = 2.0 * delay('line3.v1', 5e-9, 5e-9) - delay('line3.es', 5e-9, 5e-9);
    0.0 = 'line3.p1.i' + 'line3.n1.i';
    0.0 = 'line3.p2.i' + 'line3.n2.i';
    'line3.v1' = 'line3.p1.v' - 'line3.n1.v';
    'line3.v2' = 'line3.p2.v' - 'line3.n2.v';
    'line3.i1' = 'line3.p1.i';
    'line3.i2' = 'line3.p2.i';
    'ri3.R_actual' = 50.0;
    'ri3.v' = 'ri3.R_actual' * 'ri3.i';
    'ri3.LossPower' = 'ri3.v' * 'ri3.i';
    'ri3.T_heatPort' = 300.15;
    0.0 = 'ri3.p.i' + 'ri3.n.i';
    'ri3.i' = 'ri3.p.i';
    'ri3.v' = 'ri3.p.v' - 'ri3.n.v';
    'load3.v' = 0.0;
    0.0 = 'load3.p.i' + 'load3.n.i';
    'load3.i' = 'load3.p.i';
    'load3.v' = 'load3.p.v' - 'load3.n.v';

    when time >= (pre('pulse.count') + 1) * 5e-9 + 2.5e-9 then
      'pulse.count' = pre('pulse.count') + 1;
      'pulse.T_start' = time;
    end when;

    'pulse.y' = if time < 2.5e-9 or 'pulse.count' >= 1 then 0.0 else if time < 'pulse.T_start' + 'pulse.T_width' then 10.0 else 0.0;
  initial algorithm
    'pulse.count' := integer((time - 2.5e-9) / 5e-9);
    'pulse.T_start' := 2.5e-9 + 'pulse.count' * 5e-9;
    annotation(experiment(StopTime = 2e-08, Interval = 1e-10, Tolerance = 1e-06));
  end 'CompareLosslessLines';
end 'CompareLosslessLines';
