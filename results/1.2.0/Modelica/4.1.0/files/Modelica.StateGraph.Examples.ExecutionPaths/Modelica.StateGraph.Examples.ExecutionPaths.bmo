//! base 0.1.0
package 'ExecutionPaths'
  model 'ExecutionPaths' "Example to demonstrate parallel and alternative execution paths"
    Boolean 'step0.active' "= true, if step is active, otherwise the step is not active";
    parameter Integer 'step0.nIn'(min = 0) = 1 "Number of input connections";
    parameter Integer 'step0.nOut'(min = 0) = 1 "Number of output connections";
    Boolean 'step0.localActive' "= true, if step is active, otherwise the step is not active";
    Boolean 'step0.inPort[1].occupied' "= true, if step is active";
    Boolean 'step0.inPort[1].set' "= true, if transition fires and step is activated";
    Boolean 'step0.outPort[1].available' "= true, if step is active";
    Boolean 'step0.outPort[1].reset' "= true, if transition fires and step is deactivated";
    Boolean 'step0.outerStatePort.subgraphStatePort.suspend' "= true, if suspend transition of CompositeStep fires";
    Boolean 'step0.outerStatePort.subgraphStatePort.resume' "= true, if resume transition of CompositeStep fires";
    Real 'step0.outerStatePort.subgraphStatePort.activeStepsDummy' "Dummy variable in order that connector fulfills restriction of connector";
    Real 'step0.outerStatePort.subgraphStatePort.activeSteps' "Number of active steps in the CompositeStep";
    Boolean 'step0.outerStatePort.localActive' = 'step0.localActive';
    Boolean 'step0.newActive' "Value of active in the next iteration";
    Boolean 'step0.oldActive' "Value of active when CompositeStep was aborted";
