    Real 'transition1.t'(unit = "s", quantity = "Time") "Actual waiting time (transition will fire when t > waitTime)";
    Boolean 'transition1.enableFire' "= true, if all firing conditions are true";
    Boolean 'transition1.fire' "= true, if transition fires";
    Boolean 'transition1.inPort.available' "= true, if step connected to the transition input is active";
    Boolean 'transition1.inPort.reset' "= true, if transition fires and the step connected to the transition input is deactivated";
    Boolean 'transition1.outPort.occupied' "= true, if step connected to the transition output is active";
    Boolean 'transition1.outPort.set' "= true, if transition fires and step connected to the transition output becomes active";
    discrete Real 'transition1.t_start'(unit = "s", quantity = "Time") "Time instant at which the transition would fire, if waitTime would be zero";
    Real 'transition1.t_dummy';
