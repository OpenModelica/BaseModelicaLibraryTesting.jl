    parameter Real 'cosine_angle_input.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1.0 "Frequency of cosine wave";
    parameter Real 'cosine_angle_input.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of cosine wave";
    parameter Boolean 'cosine_angle_input.continuous' = false "Make output continuous by starting at offset + amplitude*cos(phase)" annotation(Evaluate = true);
    Real 'cosine_angle_input.y' "Connector of Real output signal";
    parameter Real 'cosine_angle_input.offset' = 0.0 "Offset of output signal y";
    parameter Real 'cosine_angle_input.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
