    'rotational_clock_2.update_direction.y' = sample('rotational_clock_2.update_direction.u', 'rotational_clock_2.update_direction.clock');
    'conjunctiveClock.combinator.y' = min({'conjunctiveClock.combinator.u[1]', 'conjunctiveClock.combinator.u[2]'});
    'conjunctiveClock.clock.y' = Clock('conjunctiveClock.clock.u', 0.0);
    'conjunctiveClock.input_ticked[1].input_sample.y' = sample('conjunctiveClock.input_ticked[1].input_sample.u', 'conjunctiveClock.input_ticked[1].input_sample.clock');
    'conjunctiveClock.input_ticked[1].input_tick.y' = not 'conjunctiveClock.input_ticked[1].input_tick.u';
    'conjunctiveClock.input_ticked[1].input_hold.y' = hold('conjunctiveClock.input_ticked[1].input_hold.u');
    'conjunctiveClock.input_ticked[1].input_ticked.y' = change('conjunctiveClock.input_ticked[1].input_ticked.u');
    'conjunctiveClock.input_ticked[2].input_sample.y' = sample('conjunctiveClock.input_ticked[2].input_sample.u', 'conjunctiveClock.input_ticked[2].input_sample.clock');
    'conjunctiveClock.input_ticked[2].input_tick.y' = not 'conjunctiveClock.input_ticked[2].input_tick.u';
    'conjunctiveClock.input_ticked[2].input_hold.y' = hold('conjunctiveClock.input_ticked[2].input_hold.u');
    'conjunctiveClock.input_ticked[2].input_ticked.y' = change('conjunctiveClock.input_ticked[2].input_ticked.u');
    'conjunctiveClock.forbidden_state[1].y' = 'conjunctiveClock.forbidden_state[1].u1' and 'conjunctiveClock.forbidden_state[1].u2';
    'conjunctiveClock.forbidden_state[2].y' = 'conjunctiveClock.forbidden_state[2].u1' and 'conjunctiveClock.forbidden_state[2].u2';
    'conjunctiveClock.S_false[1].y' = false;
    'conjunctiveClock.S_false[2].y' = false;
    'conjunctiveClock.suppress_S[1].y' = if 'conjunctiveClock.suppress_S[1].u2' then 'conjunctiveClock.suppress_S[1].u1' else 'conjunctiveClock.suppress_S[1].u3';
    'conjunctiveClock.suppress_S[2].y' = if 'conjunctiveClock.suppress_S[2].u2' then 'conjunctiveClock.suppress_S[2].u1' else 'conjunctiveClock.suppress_S[2].u3';
    'conjunctiveClock.input_memory[1].nor.y' = not ('conjunctiveClock.input_memory[1].nor.u1' or 'conjunctiveClock.input_memory[1].nor.u2');
    'conjunctiveClock.input_memory[1].nor1.y' = not ('conjunctiveClock.input_memory[1].nor1.u1' or 'conjunctiveClock.input_memory[1].nor1.u2');
    'conjunctiveClock.input_memory[1].pre.y' = pre('conjunctiveClock.input_memory[1].pre.u');
    'conjunctiveClock.input_memory[2].nor.y' = not ('conjunctiveClock.input_memory[2].nor.u1' or 'conjunctiveClock.input_memory[2].nor.u2');
    'conjunctiveClock.input_memory[2].nor1.y' = not ('conjunctiveClock.input_memory[2].nor1.u1' or 'conjunctiveClock.input_memory[2].nor1.u2');
    'conjunctiveClock.input_memory[2].pre.y' = pre('conjunctiveClock.input_memory[2].pre.u');
    'conjunctiveClock.reset_ticked.input_sample.y' = sample('conjunctiveClock.reset_ticked.input_sample.u', 'conjunctiveClock.reset_ticked.input_sample.clock');
    'conjunctiveClock.reset_ticked.input_tick.y' = not 'conjunctiveClock.reset_ticked.input_tick.u';
    'conjunctiveClock.reset_ticked.input_hold.y' = hold('conjunctiveClock.reset_ticked.input_hold.u');
    'conjunctiveClock.reset_ticked.input_ticked.y' = change('conjunctiveClock.reset_ticked.input_ticked.u');
    'conjunctiveClock.splitter.y[1]' = 'conjunctiveClock.splitter.u';
    'conjunctiveClock.splitter.y[2]' = 'conjunctiveClock.splitter.u';
    'disjunctiveClock.combinator.y' = max({'disjunctiveClock.combinator.u[1]', 'disjunctiveClock.combinator.u[2]'});
    'disjunctiveClock.clock.y' = Clock('disjunctiveClock.clock.u', 0.0);
    'disjunctiveClock.input_ticked[1].input_sample.y' = sample('disjunctiveClock.input_ticked[1].input_sample.u', 'disjunctiveClock.input_ticked[1].input_sample.clock');
    'disjunctiveClock.input_ticked[1].input_tick.y' = not 'disjunctiveClock.input_ticked[1].input_tick.u';
    'disjunctiveClock.input_ticked[1].input_hold.y' = hold('disjunctiveClock.input_ticked[1].input_hold.u');
    'disjunctiveClock.input_ticked[1].input_ticked.y' = change('disjunctiveClock.input_ticked[1].input_ticked.u');
    'disjunctiveClock.input_ticked[2].input_sample.y' = sample('disjunctiveClock.input_ticked[2].input_sample.u', 'disjunctiveClock.input_ticked[2].input_sample.clock');
    'disjunctiveClock.input_ticked[2].input_tick.y' = not 'disjunctiveClock.input_ticked[2].input_tick.u';
    'disjunctiveClock.input_ticked[2].input_hold.y' = hold('disjunctiveClock.input_ticked[2].input_hold.u');
    'disjunctiveClock.input_ticked[2].input_ticked.y' = change('disjunctiveClock.input_ticked[2].input_ticked.u');
    'disjunctiveClock.forbidden_state[1].y' = 'disjunctiveClock.forbidden_state[1].u1' and 'disjunctiveClock.forbidden_state[1].u2';
    'disjunctiveClock.forbidden_state[2].y' = 'disjunctiveClock.forbidden_state[2].u1' and 'disjunctiveClock.forbidden_state[2].u2';
    'disjunctiveClock.S_false[1].y' = false;
    'disjunctiveClock.S_false[2].y' = false;
    'disjunctiveClock.suppress_S[1].y' = if 'disjunctiveClock.suppress_S[1].u2' then 'disjunctiveClock.suppress_S[1].u1' else 'disjunctiveClock.suppress_S[1].u3';
    'disjunctiveClock.suppress_S[2].y' = if 'disjunctiveClock.suppress_S[2].u2' then 'disjunctiveClock.suppress_S[2].u1' else 'disjunctiveClock.suppress_S[2].u3';
    'disjunctiveClock.input_memory[1].nor.y' = not ('disjunctiveClock.input_memory[1].nor.u1' or 'disjunctiveClock.input_memory[1].nor.u2');
    'disjunctiveClock.input_memory[1].nor1.y' = not ('disjunctiveClock.input_memory[1].nor1.u1' or 'disjunctiveClock.input_memory[1].nor1.u2');
    'disjunctiveClock.input_memory[1].pre.y' = pre('disjunctiveClock.input_memory[1].pre.u');
    'disjunctiveClock.input_memory[2].nor.y' = not ('disjunctiveClock.input_memory[2].nor.u1' or 'disjunctiveClock.input_memory[2].nor.u2');
    'disjunctiveClock.input_memory[2].nor1.y' = not ('disjunctiveClock.input_memory[2].nor1.u1' or 'disjunctiveClock.input_memory[2].nor1.u2');
    'disjunctiveClock.input_memory[2].pre.y' = pre('disjunctiveClock.input_memory[2].pre.u');
    'disjunctiveClock.reset_ticked.input_sample.y' = sample('disjunctiveClock.reset_ticked.input_sample.u', 'disjunctiveClock.reset_ticked.input_sample.clock');
    'disjunctiveClock.reset_ticked.input_tick.y' = not 'disjunctiveClock.reset_ticked.input_tick.u';
    'disjunctiveClock.reset_ticked.input_hold.y' = hold('disjunctiveClock.reset_ticked.input_hold.u');
    'disjunctiveClock.reset_ticked.input_ticked.y' = change('disjunctiveClock.reset_ticked.input_ticked.u');
    'disjunctiveClock.splitter.y[1]' = 'disjunctiveClock.splitter.u';
    'disjunctiveClock.splitter.y[2]' = 'disjunctiveClock.splitter.u';
    'sample_conjunctive.y' = sample('sample_conjunctive.u', 'sample_conjunctive.clock');
    'sample_disjunctive.y' = sample('sample_disjunctive.u', 'sample_disjunctive.clock');
  initial algorithm
    'trigger_interval_input.count' := integer(time);
    'trigger_interval_input.T_start' := 'trigger_interval_input.count';
  algorithm
    assert('rotational_clock_1.trigger_interval' > 0.0 or 'rotational_clock_1.trigger_interval' < 0.0, "The rotational-interval of rotational clocks must be non-zero.", AssertionLevel.error);
  algorithm
    assert('rotational_clock_2.trigger_interval' > 0.0 or 'rotational_clock_2.trigger_interval' < 0.0, "The rotational-interval of rotational clocks must be non-zero.", AssertionLevel.error);
    annotation(experiment(StopTime = 2));
  end 'LogicalSample';
end 'LogicalSample';
