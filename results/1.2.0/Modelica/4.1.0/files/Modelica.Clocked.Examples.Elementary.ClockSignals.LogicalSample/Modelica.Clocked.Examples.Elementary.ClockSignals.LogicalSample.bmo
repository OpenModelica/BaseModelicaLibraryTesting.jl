//! base 0.1.0
package 'LogicalSample'
  model 'LogicalSample' "Simple example of conjunctive and disjunctive logical clocks, combining clock signals to derive new event driven clocks."
    parameter Real 'sine_angle_input.amplitude' = 10.0 "Amplitude of sine wave";
    parameter Real 'sine_angle_input.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1.0 "Frequency of sine wave";
    parameter Real 'sine_angle_input.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sine_angle_input.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sine_angle_input.y' "Connector of Real output signal";
    parameter Real 'sine_angle_input.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sine_angle_input.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
