//! base 0.1.0
package 'ElasticBearing'
  model 'ElasticBearing' "Example to show possible usage of support flange"
    Real 'shaft.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'shaft.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'shaft.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'shaft.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'shaft.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 1.0 "Moment of inertia";
    parameter StateSelect 'shaft.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'shaft.phi'(stateSelect = StateSelect.default, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'shaft.w'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'shaft.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'load.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'load.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'load.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'load.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'load.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 50.0 "Moment of inertia";
    parameter StateSelect 'load.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'load.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'load.w'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'load.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'spring.phi_rel'(fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'spring.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'spring.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'spring.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'spring.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'spring.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'spring.c'(start = 1e5, min = 0.0, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 1000.0 "Spring constant";
    parameter Real 'spring.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    parameter Real 'fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'springDamper.c'(start = 1e5, min = 0.0, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 1e5 "Spring constant";
    parameter Real 'springDamper.d'(start = 0.0, min = 0.0, unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 5.0 "Damping constant";
    parameter Real 'springDamper.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    Real 'springDamper.phi_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'springDamper.w_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity (= der(phi_rel))";
    Real 'springDamper.a_rel'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration (= der(w_rel))";
    Real 'springDamper.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'springDamper.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'springDamper.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'springDamper.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'springDamper.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'springDamper.phi_nominal'(min = 0.0, displayUnit = "rad", unit = "rad", quantity = "Angle") = 1e-4 "Nominal value of phi_rel (used for scaling)";
    parameter StateSelect 'springDamper.stateSelect' = StateSelect.prefer "Priority to use phi_rel and w_rel as states";
    parameter Boolean 'springDamper.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'springDamper.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'springDamper.tau_c'(unit = "N.m", quantity = "Torque") "Spring torque";
    Real 'springDamper.tau_d'(unit = "N.m", quantity = "Torque") "Damping torque";
    parameter Boolean 'torque.useSupport' = true "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'torque.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'torque.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'torque.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'torque.phi_support' "Absolute rotation angle of flange";
    Real 'torque.support.tau'(unit = "N.m", quantity = "Torque") = -'torque.flange.tau' "Cut torque in the flange";
    Real 'torque.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'torque.tau'(unit = "N.m") "Accelerating torque acting at flange (= -flange.tau)";
    parameter Real 'ramp.height' = 100.0 "Height of ramp";
    parameter Real 'ramp.duration'(start = 2.0, min = 0.0, unit = "s", quantity = "Time") = 5.0 "Duration of ramp (= 0.0 gives a Step)";
    Real 'ramp.y' "Connector of Real output signal";
    parameter Real 'ramp.offset' = 0.0 "Offset of output signal y";
    parameter Real 'ramp.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Boolean 'idealGear.useSupport' = true "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'idealGear.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'idealGear.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'idealGear.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'idealGear.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'idealGear.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'idealGear.phi_support' "Absolute rotation angle of flange";
    Real 'idealGear.support.tau'(unit = "N.m", quantity = "Torque") = -('idealGear.flange_a.tau' + 'idealGear.flange_b.tau') "Cut torque in the flange";
    Real 'idealGear.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    parameter Real 'idealGear.ratio'(start = 1.0) = 3.0 "Transmission ratio (flange_a.phi/flange_b.phi)";
    Real 'idealGear.phi_a'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between left shaft flange and support";
    Real 'idealGear.phi_b'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle between right shaft flange and support";
    Real 'housing.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'housing.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'housing.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'housing.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'housing.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 5.0 "Moment of inertia";
    parameter StateSelect 'housing.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'housing.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'housing.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'housing.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    Real 'multiSensor.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'multiSensor.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'multiSensor.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'multiSensor.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'multiSensor.power'(unit = "W") "Power in flange flange_a as output signal";
    Real 'multiSensor.w'(unit = "rad/s") "Absolute angular velocity of flange_a as output signal";
    Real 'multiSensor.tau'(unit = "N.m") "Torque in flange flange_a and flange_b (tau = flange_a.tau = -flange_b.tau) as output signal";
  equation
    'torque.flange.phi' = 'shaft.flange_a.phi';
    'spring.flange_b.phi' = 'load.flange_a.phi';
    'fixed.flange.phi' = 'torque.support.phi';
    'fixed.flange.phi' = 'springDamper.flange_a.phi';
    'shaft.flange_b.phi' = 'idealGear.flange_a.phi';
    'idealGear.flange_b.phi' = 'spring.flange_a.phi';
    'idealGear.support.phi' = 'housing.flange_b.phi';
    'ramp.y' = 'torque.tau';
    'housing.flange_a.phi' = 'multiSensor.flange_b.phi';
    'multiSensor.flange_a.phi' = 'springDamper.flange_b.phi';
    'idealGear.flange_a.tau' + 'shaft.flange_b.tau' = 0.0;
    'load.flange_b.tau' = 0.0;
    'spring.flange_b.tau' + 'load.flange_a.tau' = 0.0;
    'torque.support.tau' + 'springDamper.flange_a.tau' + 'fixed.flange.tau' = 0.0;
    'torque.flange.tau' + 'shaft.flange_a.tau' = 0.0;
    'idealGear.flange_b.tau' + 'spring.flange_a.tau' = 0.0;
    'housing.flange_b.tau' + 'idealGear.support.tau' = 0.0;
    'multiSensor.flange_b.tau' + 'housing.flange_a.tau' = 0.0;
    'multiSensor.flange_a.tau' + 'springDamper.flange_b.tau' = 0.0;
    'shaft.phi' = 'shaft.flange_a.phi';
    'shaft.phi' = 'shaft.flange_b.phi';
    'shaft.w' = der('shaft.phi');
    'shaft.a' = der('shaft.w');
    'shaft.a' = 'shaft.flange_a.tau' + 'shaft.flange_b.tau';
    'load.phi' = 'load.flange_a.phi';
    'load.phi' = 'load.flange_b.phi';
    'load.w' = der('load.phi');
    'load.a' = der('load.w');
    50.0 * 'load.a' = 'load.flange_a.tau' + 'load.flange_b.tau';
    'spring.tau' = 1000.0 * 'spring.phi_rel';
    'spring.phi_rel' = 'spring.flange_b.phi' - 'spring.flange_a.phi';
    'spring.flange_b.tau' = 'spring.tau';
    'spring.flange_a.tau' = -'spring.tau';
    'fixed.flange.phi' = 0.0;
    'springDamper.tau_c' = 1e5 * 'springDamper.phi_rel';
    'springDamper.tau_d' = 5.0 * 'springDamper.w_rel';
    'springDamper.tau' = 'springDamper.tau_c' + 'springDamper.tau_d';
    'springDamper.lossPower' = 'springDamper.tau_d' * 'springDamper.w_rel';
    'springDamper.phi_rel' = 'springDamper.flange_b.phi' - 'springDamper.flange_a.phi';
    'springDamper.w_rel' = der('springDamper.phi_rel');
    'springDamper.a_rel' = der('springDamper.w_rel');
    'springDamper.flange_b.tau' = 'springDamper.tau';
    'springDamper.flange_a.tau' = -'springDamper.tau';
    'torque.flange.tau' = -'torque.tau';
    'ramp.y' = if time < 0.0 then 0.0 else if time < 5.0 then time * 100.0 / 5.0 else 100.0;
    'idealGear.phi_a' = 'idealGear.flange_a.phi' - 'idealGear.phi_support';
    'idealGear.phi_b' = 'idealGear.flange_b.phi' - 'idealGear.phi_support';
    'idealGear.phi_a' = 3.0 * 'idealGear.phi_b';
    0.0 = 3.0 * 'idealGear.flange_a.tau' + 'idealGear.flange_b.tau';
    'housing.phi' = 'housing.flange_a.phi';
    'housing.phi' = 'housing.flange_b.phi';
    'housing.w' = der('housing.phi');
    'housing.a' = der('housing.w');
    5.0 * 'housing.a' = 'housing.flange_a.tau' + 'housing.flange_b.tau';
    'multiSensor.flange_a.phi' = 'multiSensor.flange_b.phi';
    'multiSensor.w' = der('multiSensor.flange_a.phi');
    'multiSensor.tau' = 'multiSensor.flange_a.tau';
    'multiSensor.power' = 'multiSensor.tau' * 'multiSensor.w';
    0.0 = 'multiSensor.flange_a.tau' + 'multiSensor.flange_b.tau';
    annotation(experiment(StopTime = 10, Interval = 0.01));
  end 'ElasticBearing';
end 'ElasticBearing';
