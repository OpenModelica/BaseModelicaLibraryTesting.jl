    'reluctance_s[2].port_p.Phi.re' + 'reluctance_s[2].port_n.Phi.re' = 0.0;
    'reluctance_s[2].port_p.Phi.im' + 'reluctance_s[2].port_n.Phi.im' = 0.0;
    1.5707963267948966 * 'reluctance_s[3].V_m.re' = 25.0 * 'reluctance_s[3].Phi.re';
    1.5707963267948966 * 'reluctance_s[3].V_m.im' = 25.0 * 'reluctance_s[3].Phi.im';
    'reluctance_s[3].port_p.Phi.re' + 'reluctance_s[3].port_n.Phi.re' = 0.0;
