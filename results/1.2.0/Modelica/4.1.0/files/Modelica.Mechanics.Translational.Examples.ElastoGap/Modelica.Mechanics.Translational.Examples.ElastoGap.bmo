//! base 0.1.0
package 'ElastoGap'
  model 'ElastoGap' "Demonstrate usage of ElastoGap"
    parameter Real 'fixed.s0'(unit = "m", quantity = "Length") = 0.0 "Fixed offset position of housing";
    Real 'fixed.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'fixed.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'rod1.s'(unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'rod1.L'(start = 0.0, unit = "m", quantity = "Length") = 2.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'rod1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'rod1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'rod1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'rod1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'rod2.s'(unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'rod2.L'(start = 0.0, unit = "m", quantity = "Length") = 2.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'rod2.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'rod2.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'rod2.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'rod2.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter StateSelect 'springDamper1.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'springDamper1.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'springDamper1.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, fixed = false, start = 1.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'springDamper1.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'springDamper1.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'springDamper1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'springDamper1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'springDamper1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'springDamper1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'springDamper1.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 10.0 "Spring constant";
    parameter Real 'springDamper1.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 1.5 "Damping constant";
    parameter Real 'springDamper1.s_rel0'(unit = "m", quantity = "Length") = 1.0 "Unstretched spring length";
    parameter Boolean 'springDamper1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'springDamper1.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'springDamper1.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'springDamper1.f_d'(unit = "N", quantity = "Force") "Damping force";
    parameter StateSelect 'springDamper2.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'springDamper2.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'springDamper2.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, fixed = false, start = 1.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'springDamper2.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'springDamper2.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'springDamper2.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'springDamper2.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'springDamper2.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'springDamper2.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'springDamper2.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 10.0 "Spring constant";
    parameter Real 'springDamper2.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 1.5 "Damping constant";
    parameter Real 'springDamper2.s_rel0'(unit = "m", quantity = "Length") = 1.0 "Unstretched spring length";
    parameter Boolean 'springDamper2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'springDamper2.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'springDamper2.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'springDamper2.f_d'(unit = "N", quantity = "Force") "Damping force";
    parameter Real 'mass1.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass of the sliding mass";
    parameter StateSelect 'mass1.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'mass1.s'(stateSelect = StateSelect.default, fixed = true, start = 2.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'mass1.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'mass1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass1.v'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass1.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter StateSelect 'elastoGap1.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'elastoGap1.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'elastoGap1.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, fixed = false, start = 1.5, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'elastoGap1.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'elastoGap1.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'elastoGap1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'elastoGap1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'elastoGap1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'elastoGap1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'elastoGap1.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 10.0 "Spring constant";
    parameter Real 'elastoGap1.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 1.5 "Damping constant";
    parameter Real 'elastoGap1.s_rel0'(unit = "m", quantity = "Length") = 1.5 "Unstretched spring length";
    parameter Real 'elastoGap1.f_ref'(min = 0.0, unit = "N", quantity = "Force") = 10.0 "Reference spring force at s_ref";
    parameter Real 'elastoGap1.s_ref'(min = 2.220446049250313e-16, unit = "m", quantity = "Length") = 1.0 "Reference relative compression at which f_c = f_ref";
    parameter Real 'elastoGap1.n'(min = 1.0) = 1.0 "Exponent of spring force ( f_c = -f_ref*|(s_rel-s_rel0)/s_ref|^n )";
    parameter Boolean 'elastoGap1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'elastoGap1.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Boolean 'elastoGap1.contact' "= true, if contact, otherwise no contact";
    Real 'elastoGap1.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'elastoGap1.f_d2'(unit = "N", quantity = "Force") "Linear damping force";
    Real 'elastoGap1.f_d'(unit = "N", quantity = "Force") "Linear damping force which is limited by spring force (|f_d| <= |f_c|)";
    Real 'elastoGap1.ratio' "Scaling ratio of relative compression to s_ref";
    parameter StateSelect 'elastoGap2.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'elastoGap2.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'elastoGap2.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, fixed = false, start = 1.5, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'elastoGap2.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'elastoGap2.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'elastoGap2.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'elastoGap2.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'elastoGap2.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'elastoGap2.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'elastoGap2.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 10.0 "Spring constant";
    parameter Real 'elastoGap2.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 1.5 "Damping constant";
    parameter Real 'elastoGap2.s_rel0'(unit = "m", quantity = "Length") = 1.5 "Unstretched spring length";
    parameter Real 'elastoGap2.f_ref'(min = 0.0, unit = "N", quantity = "Force") = 10.0 "Reference spring force at s_ref";
    parameter Real 'elastoGap2.s_ref'(min = 2.220446049250313e-16, unit = "m", quantity = "Length") = 1.0 "Reference relative compression at which f_c = f_ref";
    parameter Real 'elastoGap2.n'(min = 1.0) = 1.0 "Exponent of spring force ( f_c = -f_ref*|(s_rel-s_rel0)/s_ref|^n )";
    parameter Boolean 'elastoGap2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'elastoGap2.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Boolean 'elastoGap2.contact' "= true, if contact, otherwise no contact";
    Real 'elastoGap2.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'elastoGap2.f_d2'(unit = "N", quantity = "Force") "Linear damping force";
    Real 'elastoGap2.f_d'(unit = "N", quantity = "Force") "Linear damping force which is limited by spring force (|f_d| <= |f_c|)";
    Real 'elastoGap2.ratio' "Scaling ratio of relative compression to s_ref";
    parameter Real 'mass2.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass of the sliding mass";
    parameter StateSelect 'mass2.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'mass2.s'(stateSelect = StateSelect.default, fixed = true, start = 2.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'mass2.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'mass2.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass2.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass2.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass2.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass2.v'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass2.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter Real 'd'(unit = "N.s/m", quantity = "TranslationalDampingConstant") = 1.5 "Damping constant";
  equation
    'fixed.flange.s' = 'rod2.flange_a.s';
    'fixed.flange.s' = 'rod1.flange_b.s';
    'rod1.flange_a.s' = 'elastoGap1.flange_a.s';
    'rod1.flange_a.s' = 'springDamper1.flange_a.s';
    'rod2.flange_b.s' = 'elastoGap2.flange_b.s';
    'rod2.flange_b.s' = 'springDamper2.flange_b.s';
    'springDamper1.flange_b.s' = 'mass1.flange_a.s';
    'mass1.flange_b.s' = 'springDamper2.flange_a.s';
    'elastoGap1.flange_b.s' = 'mass2.flange_a.s';
    'mass2.flange_b.s' = 'elastoGap2.flange_a.s';
    'rod2.flange_a.f' + 'rod1.flange_b.f' + 'fixed.flange.f' = 0.0;
    'elastoGap1.flange_a.f' + 'springDamper1.flange_a.f' + 'rod1.flange_a.f' = 0.0;
    'mass1.flange_a.f' + 'springDamper1.flange_b.f' = 0.0;
    'elastoGap2.flange_b.f' + 'springDamper2.flange_b.f' + 'rod2.flange_b.f' = 0.0;
    'mass1.flange_b.f' + 'springDamper2.flange_a.f' = 0.0;
    'mass2.flange_a.f' + 'elastoGap1.flange_b.f' = 0.0;
    'mass2.flange_b.f' + 'elastoGap2.flange_a.f' = 0.0;
    'fixed.flange.s' = 0.0;
    0.0 = 'rod1.flange_a.f' + 'rod1.flange_b.f';
    'rod1.flange_a.s' = 'rod1.s' - 1.0;
    'rod1.flange_b.s' = 'rod1.s' + 1.0;
    0.0 = 'rod2.flange_a.f' + 'rod2.flange_b.f';
    'rod2.flange_a.s' = 'rod2.s' - 1.0;
    'rod2.flange_b.s' = 'rod2.s' + 1.0;
    'springDamper1.f_c' = 10.0 * ('springDamper1.s_rel' - 1.0);
    'springDamper1.f_d' = 1.5 * 'springDamper1.v_rel';
    'springDamper1.f' = 'springDamper1.f_c' + 'springDamper1.f_d';
    'springDamper1.lossPower' = 'springDamper1.f_d' * 'springDamper1.v_rel';
    'springDamper1.s_rel' = 'springDamper1.flange_b.s' - 'springDamper1.flange_a.s';
    'springDamper1.v_rel' = der('springDamper1.s_rel');
    'springDamper1.flange_b.f' = 'springDamper1.f';
    'springDamper1.flange_a.f' = -'springDamper1.f';
    'springDamper2.f_c' = 10.0 * ('springDamper2.s_rel' - 1.0);
    'springDamper2.f_d' = 1.5 * 'springDamper2.v_rel';
    'springDamper2.f' = 'springDamper2.f_c' + 'springDamper2.f_d';
    'springDamper2.lossPower' = 'springDamper2.f_d' * 'springDamper2.v_rel';
    'springDamper2.s_rel' = 'springDamper2.flange_b.s' - 'springDamper2.flange_a.s';
    'springDamper2.v_rel' = der('springDamper2.s_rel');
    'springDamper2.flange_b.f' = 'springDamper2.f';
    'springDamper2.flange_a.f' = -'springDamper2.f';
    'mass1.v' = der('mass1.s');
    'mass1.a' = der('mass1.v');
    'mass1.a' = 'mass1.flange_a.f' + 'mass1.flange_b.f';
    'mass1.flange_a.s' = 'mass1.s';
    'mass1.flange_b.s' = 'mass1.s';
    'elastoGap1.contact' = 'elastoGap1.s_rel' < 1.5;
    'elastoGap1.ratio' = 'elastoGap1.s_rel' - 1.5;
    'elastoGap1.f_c' = smooth(1, noEvent(if 'elastoGap1.contact' then -10.0 * abs('elastoGap1.ratio') else 0.0));
    'elastoGap1.f_d2' = if 'elastoGap1.contact' then 1.5 * 'elastoGap1.v_rel' else 0.0;
    'elastoGap1.f_d' = smooth(0, noEvent(if 'elastoGap1.contact' then min(max('elastoGap1.f_d2', 'elastoGap1.f_c'), -'elastoGap1.f_c') else 0.0));
    'elastoGap1.f' = 'elastoGap1.f_c' + 'elastoGap1.f_d';
    'elastoGap1.lossPower' = 'elastoGap1.f_d' * 'elastoGap1.v_rel';
    'elastoGap1.s_rel' = 'elastoGap1.flange_b.s' - 'elastoGap1.flange_a.s';
    'elastoGap1.v_rel' = der('elastoGap1.s_rel');
    'elastoGap1.flange_b.f' = 'elastoGap1.f';
    'elastoGap1.flange_a.f' = -'elastoGap1.f';
    'elastoGap2.contact' = 'elastoGap2.s_rel' < 1.5;
    'elastoGap2.ratio' = 'elastoGap2.s_rel' - 1.5;
    'elastoGap2.f_c' = smooth(1, noEvent(if 'elastoGap2.contact' then -10.0 * abs('elastoGap2.ratio') else 0.0));
    'elastoGap2.f_d2' = if 'elastoGap2.contact' then 1.5 * 'elastoGap2.v_rel' else 0.0;
    'elastoGap2.f_d' = smooth(0, noEvent(if 'elastoGap2.contact' then min(max('elastoGap2.f_d2', 'elastoGap2.f_c'), -'elastoGap2.f_c') else 0.0));
    'elastoGap2.f' = 'elastoGap2.f_c' + 'elastoGap2.f_d';
    'elastoGap2.lossPower' = 'elastoGap2.f_d' * 'elastoGap2.v_rel';
    'elastoGap2.s_rel' = 'elastoGap2.flange_b.s' - 'elastoGap2.flange_a.s';
    'elastoGap2.v_rel' = der('elastoGap2.s_rel');
    'elastoGap2.flange_b.f' = 'elastoGap2.f';
    'elastoGap2.flange_a.f' = -'elastoGap2.f';
    'mass2.v' = der('mass2.s');
    'mass2.a' = der('mass2.v');
    'mass2.a' = 'mass2.flange_a.f' + 'mass2.flange_b.f';
    'mass2.flange_a.s' = 'mass2.s';
    'mass2.flange_b.s' = 'mass2.s';
    annotation(experiment(StopTime = 5, Interval = 0.01));
  end 'ElastoGap';
end 'ElastoGap';
