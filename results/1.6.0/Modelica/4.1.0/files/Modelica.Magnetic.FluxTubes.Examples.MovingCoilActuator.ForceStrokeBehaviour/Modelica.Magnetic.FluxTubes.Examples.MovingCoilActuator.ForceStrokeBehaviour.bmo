//! base 0.1.0
package 'ForceStrokeBehaviour'
  function 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer' "Derivative of interpolated 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    input Real 'der_u';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTable1D_getDerValue('tableID', 'icol', 'u', 'der_u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer';

  function 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmax' "Return maximum abscissa value of 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    output Real 'uMax';
  external "C" 'uMax' = ModelicaStandardTables_CombiTable1D_maximumAbscissa('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmax';

  function 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmin' "Return minimum abscissa value of 1-dim. table defined by matrix"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    output Real 'uMin';
  external "C" 'uMin' = ModelicaStandardTables_CombiTable1D_minimumAbscissa('tableID') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getTable1DAbscissaUmin';

  function 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2' "Interpolate 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTable1D_getValue('tableID', 'icol', 'u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1) = 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer');
  end 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2';

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  class 'Modelica.Blocks.Types.ExternalCombiTable1D'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table defined by matrix"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" 'externalCombiTable1D' = ModelicaStandardTables_CombiTable1D_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table defined by matrix"
      input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" ModelicaStandardTables_CombiTable1D_close('externalCombiTable1D') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTable1D';

  model 'ForceStrokeBehaviour' "Force-stroke characteristic of the permeance model at constant current"
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'actuator.N' = 140.0 "Number of turns";
    parameter Real 'actuator.R'(unit = "Ohm", quantity = "Resistance") = 2.86 "Coil resistance";
    parameter Real 'actuator.r_core'(min = 0.0, unit = "m", quantity = "Length") = 0.0125 "Radius of ferromagnetic stator core";
    parameter Real 'actuator.l_PM'(unit = "m", quantity = "Length") = 0.0035 "Radial thickness of permanent magnet ring";
    parameter Real 'actuator.t'(unit = "m", quantity = "Length") = 0.02 "Axial length of permanent magnet ring and air gap respectively";
    parameter Real 'actuator.l_air'(unit = "m", quantity = "Length") = 0.003 "Total radial length of armature air gap";
    parameter Real 'actuator.l_FeOut'(unit = "m", quantity = "Length") = 0.004 "Radial thickness of outer back iron (for estimation of leakage permeance)";
    parameter Real 'actuator.material.H_cBRef'(unit = "A/m", quantity = "MagneticFieldStrength") = 4e5 "Coercivity at reference temperature";
    parameter Real 'actuator.material.B_rRef'(unit = "T", quantity = "MagneticFluxDensity") = 0.58 "Remanence at reference temperature";
    parameter Real 'actuator.material.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Reference temperature";
    parameter Real 'actuator.material.alpha_Br'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = -0.001 "Temperature coefficient of remanence at reference temperature";
    parameter Real 'actuator.material.T_op'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Operating temperature";
    parameter Real 'actuator.material.B_r'(unit = "T", quantity = "MagneticFluxDensity") = 0.58 "Remanence at operating temperature";
    parameter Real 'actuator.material.H_cB'(unit = "A/m", quantity = "MagneticFieldStrength") = 4e5 "Coercivity at operating temperature";
    parameter Real 'actuator.material.mu_r'(unit = "1", quantity = "RelativePermeability") = 1.1538733367881007 "Relative permeability";
    parameter Real 'actuator.m_a'(min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Mass of armature";
    parameter Real 'actuator.c'(unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring stiffness between impact partners";
    parameter Real 'actuator.d'(unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping coefficient between impact partners";
    parameter Real 'actuator.x_min'(unit = "m", quantity = "Length") = -0.004 "Position of stopper at minimum armature position";
    parameter Real 'actuator.x_max'(unit = "m", quantity = "Length") = 0.004 "Position of stopper at maximum armature position";
    Real 'actuator.x'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m", quantity = "Length") "Armature position, alias for flange position";
    Real 'actuator.L'(unit = "H", quantity = "Inductance") "Coil inductance";
    Real 'actuator.mmf_PM.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'actuator.mmf_PM.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'actuator.mmf_PM.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'actuator.mmf_PM.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    parameter Real 'actuator.mmf_PM.V_m'(unit = "A", quantity = "MagneticPotential") = 1400.0 "Magnetic potential difference";
    Real 'actuator.mmf_PM.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Real 'actuator.armature.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component from left flange to right flange (= flange_b.s - flange_a.s)";
    parameter Real 'actuator.armature.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Armature mass";
    parameter Real 'actuator.armature.c'(start = 1e11, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring stiffness between impact partners";
    parameter Real 'actuator.armature.d'(start = 2e7, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping coefficient between impact partners";
    parameter Real 'actuator.armature.n'(min = 1.0) = 2.0 "Exponent of spring forces (f_c = c*|s_rel|^n)" annotation(Evaluate = true);
    parameter Real 'actuator.armature.x_max'(start = 0.01, unit = "m", quantity = "Length") = 0.004 "Position of stopper at maximum armature position";
    parameter Real 'actuator.armature.x_min'(start = 0.0, unit = "m", quantity = "Length") = -0.004 "Position of stopper at minimum armature position";
    Real 'actuator.armature.s'(start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (= flange_a.s + L/2)";
    Real 'actuator.armature.v'(start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of components (= der(s))";
    Real 'actuator.armature.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of components (= der(v))";
    parameter Real 'actuator.armature.mass.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 0.012 "Mass of the sliding mass";
    parameter StateSelect 'actuator.armature.mass.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'actuator.armature.mass.s'(stateSelect = StateSelect.default, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'actuator.armature.mass.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'actuator.armature.mass.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.mass.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'actuator.armature.mass.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.mass.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'actuator.armature.mass.v'(stateSelect = StateSelect.default, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'actuator.armature.mass.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    Real 'actuator.armature.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'actuator.armature.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'actuator.armature.limit_xMin.s0'(unit = "m", quantity = "Length") = -0.004 "Fixed offset position of housing";
    Real 'actuator.armature.limit_xMin.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.limit_xMin.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'actuator.armature.limit_xMax.s0'(unit = "m", quantity = "Length") = 0.004 "Fixed offset position of housing";
    Real 'actuator.armature.limit_xMax.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.limit_xMax.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter StateSelect 'actuator.armature.stopper_xMax.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'actuator.armature.stopper_xMax.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'actuator.armature.stopper_xMax.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'actuator.armature.stopper_xMax.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'actuator.armature.stopper_xMax.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'actuator.armature.stopper_xMax.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.stopper_xMax.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'actuator.armature.stopper_xMax.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.stopper_xMax.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'actuator.armature.stopper_xMax.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring constant";
    parameter Real 'actuator.armature.stopper_xMax.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping constant";
    parameter Real 'actuator.armature.stopper_xMax.s_rel0'(unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
    parameter Real 'actuator.armature.stopper_xMax.f_ref'(min = 0.0, unit = "N", quantity = "Force") = 1e11 "Reference spring force at s_ref";
    parameter Real 'actuator.armature.stopper_xMax.s_ref'(min = 2.220446049250313e-16, unit = "m", quantity = "Length") = 1.0 "Reference relative compression at which f_c = f_ref";
    parameter Real 'actuator.armature.stopper_xMax.n'(min = 1.0) = 2.0 "Exponent of spring force ( f_c = -f_ref*|(s_rel-s_rel0)/s_ref|^n )";
    parameter Boolean 'actuator.armature.stopper_xMax.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'actuator.armature.stopper_xMax.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Boolean 'actuator.armature.stopper_xMax.contact' "= true, if contact, otherwise no contact";
    Real 'actuator.armature.stopper_xMax.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'actuator.armature.stopper_xMax.f_d2'(unit = "N", quantity = "Force") "Linear damping force";
    Real 'actuator.armature.stopper_xMax.f_d'(unit = "N", quantity = "Force") "Linear damping force which is limited by spring force (|f_d| <= |f_c|)";
    Real 'actuator.armature.stopper_xMax.ratio' "Scaling ratio of relative compression to s_ref";
    parameter StateSelect 'actuator.armature.stopper_xMin.stateSelect' = StateSelect.prefer "Priority to use s_rel and v_rel as states";
    parameter Real 'actuator.armature.stopper_xMin.s_nominal'(min = 0.0, unit = "m", quantity = "Length") = 1e-4 "Nominal value of s_rel (used for scaling)";
    Real 'actuator.armature.stopper_xMin.s_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, unit = "m", quantity = "Length") "Relative distance (= flange_b.s - flange_a.s)";
    Real 'actuator.armature.stopper_xMin.v_rel'(stateSelect = StateSelect.prefer, start = 0.0, unit = "m/s", quantity = "Velocity") "Relative velocity (= der(s_rel))";
    Real 'actuator.armature.stopper_xMin.f'(unit = "N", quantity = "Force") "Forces between flanges (= flange_b.f)";
    Real 'actuator.armature.stopper_xMin.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.stopper_xMin.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'actuator.armature.stopper_xMin.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.armature.stopper_xMin.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    parameter Real 'actuator.armature.stopper_xMin.c'(start = 1.0, min = 0.0, unit = "N/m", quantity = "TranslationalSpringConstant") = 1e11 "Spring constant";
    parameter Real 'actuator.armature.stopper_xMin.d'(start = 1.0, min = 0.0, unit = "N.s/m", quantity = "TranslationalDampingConstant") = 400.0 "Damping constant";
    parameter Real 'actuator.armature.stopper_xMin.s_rel0'(unit = "m", quantity = "Length") = 0.0 "Unstretched spring length";
    parameter Real 'actuator.armature.stopper_xMin.f_ref'(min = 0.0, unit = "N", quantity = "Force") = 1e11 "Reference spring force at s_ref";
    parameter Real 'actuator.armature.stopper_xMin.s_ref'(min = 2.220446049250313e-16, unit = "m", quantity = "Length") = 1.0 "Reference relative compression at which f_c = f_ref";
    parameter Real 'actuator.armature.stopper_xMin.n'(min = 1.0) = 2.0 "Exponent of spring force ( f_c = -f_ref*|(s_rel-s_rel0)/s_ref|^n )";
    parameter Boolean 'actuator.armature.stopper_xMin.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'actuator.armature.stopper_xMin.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Boolean 'actuator.armature.stopper_xMin.contact' "= true, if contact, otherwise no contact";
    Real 'actuator.armature.stopper_xMin.f_c'(unit = "N", quantity = "Force") "Spring force";
    Real 'actuator.armature.stopper_xMin.f_d2'(unit = "N", quantity = "Force") "Linear damping force";
    Real 'actuator.armature.stopper_xMin.f_d'(unit = "N", quantity = "Force") "Linear damping force which is limited by spring force (|f_d| <= |f_c|)";
    Real 'actuator.armature.stopper_xMin.ratio' "Scaling ratio of relative compression to s_ref";
    parameter Real 'actuator.r.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 2.86 "Resistance at temperature T_ref";
    parameter Real 'actuator.r.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'actuator.r.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'actuator.r.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'actuator.r.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'actuator.r.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'actuator.r.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'actuator.r.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'actuator.r.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'actuator.r.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'actuator.r.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'actuator.r.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'actuator.r.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'actuator.r.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'actuator.ground.port.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'actuator.ground.port.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'actuator.coil.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'actuator.coil.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'actuator.coil.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'actuator.coil.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'actuator.coil.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'actuator.coil.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'actuator.coil.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'actuator.coil.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'actuator.coil.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'actuator.coil.i'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'actuator.coil.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'actuator.coil.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux coupled into magnetic circuit";
    parameter Real 'actuator.coil.N' = 140.0 "Number of turns";
    Real 'actuator.coil.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'actuator.coil.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    Real 'actuator.coil.eps' = 2.220446049250313e-14;
    Real 'actuator.g_ma.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'actuator.g_ma.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'actuator.g_ma.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'actuator.g_ma.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'actuator.g_ma.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'actuator.g_ma.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'actuator.g_ma.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    parameter Real 'actuator.g_ma.mu_r'(start = 1.0, unit = "1", quantity = "RelativePermeability") = 1.05 "Relative magnetic permeability";
    Real 'actuator.g_ma.F_m'(unit = "N", quantity = "Force") "Reluctance force";
    Real 'actuator.g_ma.s'(unit = "m", quantity = "Length") = 'actuator.g_ma.flange.s' - 'actuator.g_ma.s_support' "Distance between flange and support";
    Real 'actuator.g_ma.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'actuator.g_ma.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'actuator.g_ma.dGmBydx'(unit = "V.s/(A.m)", quantity = "Permeability") "Derivative of permeance with respect to armature position";
    parameter Integer 'actuator.g_ma.dlBydx' = 1 "Derivative of flux tube's varying dimension with respect to armature position; set to +1 or -1";
    Real 'actuator.g_ma.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'actuator.g_ma.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'actuator.g_ma.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    Real 'actuator.g_ma.l'(unit = "m", quantity = "Length") = 0.01 + 'actuator.x' "Axial length (orthogonal to direction of flux)";
