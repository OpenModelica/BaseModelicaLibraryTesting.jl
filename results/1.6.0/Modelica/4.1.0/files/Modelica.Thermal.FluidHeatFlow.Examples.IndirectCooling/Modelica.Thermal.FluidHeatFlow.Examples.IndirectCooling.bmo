    Real 'outerConvection.fluid.Q_flow'(unit = "W", quantity = "Power") "Heat flow rate (positive if flowing from outside into the component)";
  equation
    'ambient1.flowPort.h' = 'outerPump.flowPort_a.h';
    assert(abs('ambient1.flowPort.medium.rho' - 'outerPump.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient1.flowPort.medium.cp' - 'outerPump.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient1.flowPort.medium.cv' - 'outerPump.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient1.flowPort.medium.lambda' - 'outerPump.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('ambient1.flowPort.medium.nu' - 'outerPump.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'ambient1.flowPort.p' = 'outerPump.flowPort_a.p';
    'heatCapacitor.port.T' = 'thermalConductor.port_a.T';
    'heatCapacitor.port.T' = 'prescribedHeatFlow.port.T';
    'pipe1.heatPort.T' = 'thermalConductor.port_b.T';
    'pipe1.flowPort_b.h' = 'innerPump.flowPort_a.h';
    assert(abs('pipe1.flowPort_b.medium.rho' - 'innerPump.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.cp' - 'innerPump.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.cv' - 'innerPump.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.lambda' - 'innerPump.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('pipe1.flowPort_b.medium.nu' - 'innerPump.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'pipe1.flowPort_b.p' = 'innerPump.flowPort_a.p';
    'innerPipe.flowPort_b.h' = 'absolutePressure.flowPort.h';
    'innerPipe.flowPort_b.h' = 'pipe1.flowPort_a.h';
    assert(abs('innerPipe.flowPort_b.medium.rho' - 'absolutePressure.flowPort.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.rho' - 'pipe1.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.cp' - 'absolutePressure.flowPort.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.cp' - 'pipe1.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.cv' - 'absolutePressure.flowPort.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.cv' - 'pipe1.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.lambda' - 'absolutePressure.flowPort.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.lambda' - 'pipe1.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.nu' - 'absolutePressure.flowPort.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPipe.flowPort_b.medium.nu' - 'pipe1.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'innerPipe.flowPort_b.p' = 'absolutePressure.flowPort.p';
    'innerPipe.flowPort_b.p' = 'pipe1.flowPort_a.p';
    'heatFlow.y' = 'prescribedHeatFlow.Q_flow';
    'innerPump.flowPort_b.h' = 'innerPipe.flowPort_a.h';
    assert(abs('innerPump.flowPort_b.medium.rho' - 'innerPipe.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPump.flowPort_b.medium.cp' - 'innerPipe.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPump.flowPort_b.medium.cv' - 'innerPipe.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPump.flowPort_b.medium.lambda' - 'innerPipe.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('innerPump.flowPort_b.medium.nu' - 'innerPipe.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'innerPump.flowPort_b.p' = 'innerPipe.flowPort_a.p';
    'outerPump.flowPort_b.h' = 'outerPipe.flowPort_a.h';
    assert(abs('outerPump.flowPort_b.medium.rho' - 'outerPipe.flowPort_a.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('outerPump.flowPort_b.medium.cp' - 'outerPipe.flowPort_a.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('outerPump.flowPort_b.medium.cv' - 'outerPipe.flowPort_a.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('outerPump.flowPort_b.medium.lambda' - 'outerPipe.flowPort_a.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('outerPump.flowPort_b.medium.nu' - 'outerPipe.flowPort_a.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'outerPump.flowPort_b.p' = 'outerPipe.flowPort_a.p';
    'outerPipe.flowPort_b.h' = 'ambient2.flowPort.h';
    assert(abs('outerPipe.flowPort_b.medium.rho' - 'ambient2.flowPort.medium.rho') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('outerPipe.flowPort_b.medium.cp' - 'ambient2.flowPort.medium.cp') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('outerPipe.flowPort_b.medium.cv' - 'ambient2.flowPort.medium.cv') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('outerPipe.flowPort_b.medium.lambda' - 'ambient2.flowPort.medium.lambda') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    assert(abs('outerPipe.flowPort_b.medium.nu' - 'ambient2.flowPort.medium.nu') <= 0.0, "Connected constants/parameters must be equal", AssertionLevel.error);
    'outerPipe.flowPort_b.p' = 'ambient2.flowPort.p';
    'outerPipe.heatPort.T' = 'outerConvection.fluid.T';
    'outerConvection.solid.T' = 'innerConvection.solid.T';
    'innerConvection.fluid.T' = 'innerPipe.heatPort.T';
    'innerGc.y' = 'innerConvection.Gc';
    'outerGc.y' = 'outerConvection.Gc';
    'outerVolumeFlow.y' = 'outerPump.volumeFlow';
    'innerVolumeFlow.y' = 'innerPump.volumeFlow';
    'outerPump.flowPort_a.m_flow' + 'ambient1.flowPort.m_flow' = 0.0;
    'outerPump.flowPort_a.H_flow' + 'ambient1.flowPort.H_flow' = 0.0;
    'outerPipe.flowPort_a.m_flow' + 'outerPump.flowPort_b.m_flow' = 0.0;
    'outerPipe.flowPort_a.H_flow' + 'outerPump.flowPort_b.H_flow' = 0.0;
    'prescribedHeatFlow.port.Q_flow' + 'heatCapacitor.port.Q_flow' + 'thermalConductor.port_a.Q_flow' = 0.0;
    'innerPipe.flowPort_b.m_flow' + 'absolutePressure.flowPort.m_flow' + 'pipe1.flowPort_a.m_flow' = 0.0;
    'innerPipe.flowPort_b.H_flow' + 'absolutePressure.flowPort.H_flow' + 'pipe1.flowPort_a.H_flow' = 0.0;
    'innerPump.flowPort_a.m_flow' + 'pipe1.flowPort_b.m_flow' = 0.0;
    'innerPump.flowPort_a.H_flow' + 'pipe1.flowPort_b.H_flow' = 0.0;
    'pipe1.heatPort.Q_flow' + 'thermalConductor.port_b.Q_flow' = 0.0;
    'innerPipe.flowPort_a.m_flow' + 'innerPump.flowPort_b.m_flow' = 0.0;
    'innerPipe.flowPort_a.H_flow' + 'innerPump.flowPort_b.H_flow' = 0.0;
    'outerPipe.flowPort_b.m_flow' + 'ambient2.flowPort.m_flow' = 0.0;
    'outerPipe.flowPort_b.H_flow' + 'ambient2.flowPort.H_flow' = 0.0;
    'outerConvection.fluid.Q_flow' + 'outerPipe.heatPort.Q_flow' = 0.0;
    'innerConvection.fluid.Q_flow' + 'innerPipe.heatPort.Q_flow' = 0.0;
    'outerConvection.solid.Q_flow' + 'innerConvection.solid.Q_flow' = 0.0;
    'ambient1.pAmbient' = 0.0;
    'ambient1.TAmbient' = 293.15;
    'ambient1.flowPort.p' = 'ambient1.pAmbient';
    'ambient1.T' = 'ambient1.TAmbient';
    'ambient1.T_port' = 'ambient1.flowPort.h' / 'ambient1.medium.cp';
    'ambient1.T' = 'ambient1.h' / 'ambient1.medium.cp';
    'ambient1.flowPort.H_flow' = semiLinear('ambient1.flowPort.m_flow', 'ambient1.flowPort.h', 'ambient1.h');
    'outerPump.Q_flow' = 0.0;
    'outerPump.V_flow' = 'outerPump.internalVolumeFlow';
    'outerPump.dp' = 'outerPump.flowPort_a.p' - 'outerPump.flowPort_b.p';
    'outerPump.V_flow' = 'outerPump.flowPort_a.m_flow' / 'outerPump.medium.rho';
    'outerPump.T_a' = 'outerPump.flowPort_a.h' / 'outerPump.medium.cp';
    'outerPump.T_b' = 'outerPump.flowPort_b.h' / 'outerPump.medium.cp';
    'outerPump.dT' = if noEvent('outerPump.V_flow' >= 0.0) then 'outerPump.T' - 'outerPump.T_a' else 'outerPump.T_b' - 'outerPump.T';
    'outerPump.h' = 'outerPump.medium.cp' * 'outerPump.T';
    'outerPump.T_q' = 'outerPump.T';
    'outerPump.flowPort_a.m_flow' + 'outerPump.flowPort_b.m_flow' = 0.0;
    'outerPump.flowPort_a.H_flow' + 'outerPump.flowPort_b.H_flow' + 'outerPump.Q_flow' = 0.0;
    'outerPump.flowPort_a.H_flow' = semiLinear('outerPump.flowPort_a.m_flow', 'outerPump.flowPort_a.h', 'outerPump.h');
    'outerPump.flowPort_b.H_flow' = semiLinear('outerPump.flowPort_b.m_flow', 'outerPump.flowPort_b.h', 'outerPump.h');
    'ambient2.pAmbient' = 0.0;
    'ambient2.TAmbient' = 293.15;
    'ambient2.flowPort.p' = 'ambient2.pAmbient';
    'ambient2.T' = 'ambient2.TAmbient';
    'ambient2.T_port' = 'ambient2.flowPort.h' / 'ambient2.medium.cp';
    'ambient2.T' = 'ambient2.h' / 'ambient2.medium.cp';
    'ambient2.flowPort.H_flow' = semiLinear('ambient2.flowPort.m_flow', 'ambient2.flowPort.h', 'ambient2.h');
    'thermalConductor.Q_flow' = 'thermalConductor.dT';
    'thermalConductor.dT' = 'thermalConductor.port_a.T' - 'thermalConductor.port_b.T';
    'thermalConductor.port_a.Q_flow' = 'thermalConductor.Q_flow';
    'thermalConductor.port_b.Q_flow' = -'thermalConductor.Q_flow';
    'heatCapacitor.T' = 'heatCapacitor.port.T';
    'heatCapacitor.der_T' = der('heatCapacitor.T');
    0.05 * der('heatCapacitor.T') = 'heatCapacitor.port.Q_flow';
    'prescribedHeatFlow.port.Q_flow' = -'prescribedHeatFlow.Q_flow';
    'pipe1.volumeFlow' = 'pipe1.V_flow';
    'pipe1.dp' = 'pipe1.pressureDrop';
    'pipe1.Q_flow' = 'pipe1.Q_flowHeatPort' + 'pipe1.Q_friction';

    if 'pipe1.volumeFlow' > 1.0 then
      'pipe1.pressureDrop' = 1000.0 * 'pipe1.volumeFlow' + 'pipe1.k' * ('pipe1.volumeFlow' - 1.0) ^ 2.0;
    elseif 'pipe1.volumeFlow' < (-1.0) then
      'pipe1.pressureDrop' = 1000.0 * 'pipe1.volumeFlow' - 'pipe1.k' * ('pipe1.volumeFlow' + 1.0) ^ 2.0;
    elseif true then
      'pipe1.pressureDrop' = 1000.0 * 'pipe1.volumeFlow';
    end if;

    'pipe1.Q_friction' = 0.0;
    'pipe1.dp' = 'pipe1.flowPort_a.p' - 'pipe1.flowPort_b.p';
    'pipe1.V_flow' = 'pipe1.flowPort_a.m_flow' / 'pipe1.medium.rho';
    'pipe1.T_a' = 'pipe1.flowPort_a.h' / 'pipe1.medium.cp';
    'pipe1.T_b' = 'pipe1.flowPort_b.h' / 'pipe1.medium.cp';
    'pipe1.dT' = if noEvent('pipe1.V_flow' >= 0.0) then 'pipe1.T' - 'pipe1.T_a' else 'pipe1.T_b' - 'pipe1.T';
    'pipe1.h' = 'pipe1.medium.cp' * 'pipe1.T';
    'pipe1.T_q' = 'pipe1.T';
    'pipe1.flowPort_a.m_flow' + 'pipe1.flowPort_b.m_flow' = 0.0;
    'pipe1.flowPort_a.H_flow' + 'pipe1.flowPort_b.H_flow' + 'pipe1.Q_flow' = 0.1 * 'pipe1.medium.cv' * der('pipe1.T');
    'pipe1.flowPort_a.H_flow' = semiLinear('pipe1.flowPort_a.m_flow', 'pipe1.flowPort_a.h', 'pipe1.h');
    'pipe1.flowPort_b.H_flow' = semiLinear('pipe1.flowPort_b.m_flow', 'pipe1.flowPort_b.h', 'pipe1.h');
    'absolutePressure.flowPort.p' = 1e4;
    'absolutePressure.flowPort.H_flow' = 0.0;
    'absolutePressure.T_port' = 'absolutePressure.flowPort.h' / 'absolutePressure.medium.cp';
    'absolutePressure.T' = 'absolutePressure.h' / 'absolutePressure.medium.cp';
    'absolutePressure.h' = 'absolutePressure.flowPort.h';
    'innerPump.Q_flow' = 0.0;
    'innerPump.V_flow' = 'innerPump.internalVolumeFlow';
    'innerPump.dp' = 'innerPump.flowPort_a.p' - 'innerPump.flowPort_b.p';
    'innerPump.V_flow' = 'innerPump.flowPort_a.m_flow' / 'innerPump.medium.rho';
    'innerPump.T_a' = 'innerPump.flowPort_a.h' / 'innerPump.medium.cp';
    'innerPump.T_b' = 'innerPump.flowPort_b.h' / 'innerPump.medium.cp';
    'innerPump.dT' = if noEvent('innerPump.V_flow' >= 0.0) then 'innerPump.T' - 'innerPump.T_a' else 'innerPump.T_b' - 'innerPump.T';
    'innerPump.h' = 'innerPump.medium.cp' * 'innerPump.T';
    'innerPump.T_q' = 'innerPump.T';
    'innerPump.flowPort_a.m_flow' + 'innerPump.flowPort_b.m_flow' = 0.0;
    'innerPump.flowPort_a.H_flow' + 'innerPump.flowPort_b.H_flow' + 'innerPump.Q_flow' = 0.0;
    'innerPump.flowPort_a.H_flow' = semiLinear('innerPump.flowPort_a.m_flow', 'innerPump.flowPort_a.h', 'innerPump.h');
    'innerPump.flowPort_b.H_flow' = semiLinear('innerPump.flowPort_b.m_flow', 'innerPump.flowPort_b.h', 'innerPump.h');
    'heatFlow.y' = 10.0;
    'outerVolumeFlow.y' = 1.0;
    'innerVolumeFlow.y' = 1.0;
    'outerGc.y' = 2.0;
    'innerGc.y' = 2.0;
    'outerPipe.volumeFlow' = 'outerPipe.V_flow';
    'outerPipe.dp' = 'outerPipe.pressureDrop';
    'outerPipe.Q_flow' = 'outerPipe.Q_flowHeatPort' + 'outerPipe.Q_friction';

    if 'outerPipe.volumeFlow' > 0.1 then
      'outerPipe.pressureDrop' = 'outerPipe.volumeFlow' + 'outerPipe.k' * ('outerPipe.volumeFlow' - 0.1) ^ 2.0;
    elseif 'outerPipe.volumeFlow' < (-0.1) then
      'outerPipe.pressureDrop' = 'outerPipe.volumeFlow' - 'outerPipe.k' * ('outerPipe.volumeFlow' + 0.1) ^ 2.0;
    elseif true then
      'outerPipe.pressureDrop' = 'outerPipe.volumeFlow';
    end if;

    'outerPipe.Q_friction' = 0.0;
    'outerPipe.dp' = 'outerPipe.flowPort_a.p' - 'outerPipe.flowPort_b.p';
    'outerPipe.V_flow' = 'outerPipe.flowPort_a.m_flow' / 'outerPipe.medium.rho';
    'outerPipe.T_a' = 'outerPipe.flowPort_a.h' / 'outerPipe.medium.cp';
    'outerPipe.T_b' = 'outerPipe.flowPort_b.h' / 'outerPipe.medium.cp';
    'outerPipe.dT' = if noEvent('outerPipe.V_flow' >= 0.0) then 'outerPipe.T' - 'outerPipe.T_a' else 'outerPipe.T_b' - 'outerPipe.T';
    'outerPipe.h' = 'outerPipe.medium.cp' * 'outerPipe.T';
    'outerPipe.T_q' = 'outerPipe.T';
    'outerPipe.flowPort_a.m_flow' + 'outerPipe.flowPort_b.m_flow' = 0.0;
    'outerPipe.flowPort_a.H_flow' + 'outerPipe.flowPort_b.H_flow' + 'outerPipe.Q_flow' = 0.1 * 'outerPipe.medium.cv' * der('outerPipe.T');
    'outerPipe.flowPort_a.H_flow' = semiLinear('outerPipe.flowPort_a.m_flow', 'outerPipe.flowPort_a.h', 'outerPipe.h');
    'outerPipe.flowPort_b.H_flow' = semiLinear('outerPipe.flowPort_b.m_flow', 'outerPipe.flowPort_b.h', 'outerPipe.h');
    'innerPipe.volumeFlow' = 'innerPipe.V_flow';
    'innerPipe.dp' = 'innerPipe.pressureDrop';
    'innerPipe.Q_flow' = 'innerPipe.Q_flowHeatPort' + 'innerPipe.Q_friction';

    if 'innerPipe.volumeFlow' > 0.1 then
      'innerPipe.pressureDrop' = 'innerPipe.volumeFlow' + 'innerPipe.k' * ('innerPipe.volumeFlow' - 0.1) ^ 2.0;
    elseif 'innerPipe.volumeFlow' < (-0.1) then
      'innerPipe.pressureDrop' = 'innerPipe.volumeFlow' - 'innerPipe.k' * ('innerPipe.volumeFlow' + 0.1) ^ 2.0;
    elseif true then
      'innerPipe.pressureDrop' = 'innerPipe.volumeFlow';
    end if;

    'innerPipe.Q_friction' = 0.0;
    'innerPipe.dp' = 'innerPipe.flowPort_a.p' - 'innerPipe.flowPort_b.p';
    'innerPipe.V_flow' = 'innerPipe.flowPort_a.m_flow' / 'innerPipe.medium.rho';
    'innerPipe.T_a' = 'innerPipe.flowPort_a.h' / 'innerPipe.medium.cp';
    'innerPipe.T_b' = 'innerPipe.flowPort_b.h' / 'innerPipe.medium.cp';
    'innerPipe.dT' = if noEvent('innerPipe.V_flow' >= 0.0) then 'innerPipe.T' - 'innerPipe.T_a' else 'innerPipe.T_b' - 'innerPipe.T';
    'innerPipe.h' = 'innerPipe.medium.cp' * 'innerPipe.T';
    'innerPipe.T_q' = 'innerPipe.T';
    'innerPipe.flowPort_a.m_flow' + 'innerPipe.flowPort_b.m_flow' = 0.0;
    'innerPipe.flowPort_a.H_flow' + 'innerPipe.flowPort_b.H_flow' + 'innerPipe.Q_flow' = 0.1 * 'innerPipe.medium.cv' * der('innerPipe.T');
    'innerPipe.flowPort_a.H_flow' = semiLinear('innerPipe.flowPort_a.m_flow', 'innerPipe.flowPort_a.h', 'innerPipe.h');
    'innerPipe.flowPort_b.H_flow' = semiLinear('innerPipe.flowPort_b.m_flow', 'innerPipe.flowPort_b.h', 'innerPipe.h');
    'innerConvection.dT' = 'innerConvection.solid.T' - 'innerConvection.fluid.T';
    'innerConvection.solid.Q_flow' = 'innerConvection.Q_flow';
    'innerConvection.fluid.Q_flow' = -'innerConvection.Q_flow';
    'innerConvection.Q_flow' = 'innerConvection.Gc' * 'innerConvection.dT';
    'outerConvection.dT' = 'outerConvection.solid.T' - 'outerConvection.fluid.T';
    'outerConvection.solid.Q_flow' = 'outerConvection.Q_flow';
    'outerConvection.fluid.Q_flow' = -'outerConvection.Q_flow';
    'outerConvection.Q_flow' = 'outerConvection.Gc' * 'outerConvection.dT';
  initial algorithm
    assert(true, "SimpleFriction: V_flowNominal has to be > V_flowLaminar!", AssertionLevel.error);
    assert(true, "SimpleFriction: dpNominal has to be > dpLaminar/V_flowLaminar*V_flowNominal!", AssertionLevel.error);
    'pipe1.k' := 0.0;
  initial algorithm
    assert(true, "SimpleFriction: V_flowNominal has to be > V_flowLaminar!", AssertionLevel.error);
    assert(true, "SimpleFriction: dpNominal has to be > dpLaminar/V_flowLaminar*V_flowNominal!", AssertionLevel.error);
    'outerPipe.k' := 0.0;
  initial algorithm
    assert(true, "SimpleFriction: V_flowNominal has to be > V_flowLaminar!", AssertionLevel.error);
    assert(true, "SimpleFriction: dpNominal has to be > dpLaminar/V_flowLaminar*V_flowNominal!", AssertionLevel.error);
    'innerPipe.k' := 0.0;
    annotation(experiment(StopTime = 1.5, Interval = 0.001));
  end 'IndirectCooling';
end 'IndirectCooling';
