//! base 0.1.0
package 'ToroidalCoreQuadraticCrossSection'
  model 'ToroidalCoreQuadraticCrossSection' "Educational example: iron core with airgap"
    parameter Real 'r_o'(unit = "m", quantity = "Length") = 0.055 "Outer radius of iron core";
    parameter Real 'r_i'(unit = "m", quantity = "Length") = 0.045 "Inner radius of iron core";
    parameter Real 'l'(unit = "m", quantity = "Length") = 0.01 "Length of rectangular cross section";
    parameter Real 'mu_r'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Relative permeability of core";
    parameter Real 'delta'(unit = "m", quantity = "Length") = 0.001 "Length of airgap";
    parameter Real 'alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 6.263185307179587 "Section angle of toroidal core";
    parameter Integer 'N' = 500 "Number of exciting coil turns";
    parameter Real 'I'(unit = "A", quantity = "ElectricCurrent") = 1.5 "Maximum exciting current";
    Real 'excitingCoil.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'excitingCoil.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'excitingCoil.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'excitingCoil.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'excitingCoil.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'excitingCoil.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'excitingCoil.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'excitingCoil.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'excitingCoil.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'excitingCoil.i'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'excitingCoil.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'excitingCoil.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux coupled into magnetic circuit";
    parameter Real 'excitingCoil.N' = 500.0 "Number of turns";
    Real 'excitingCoil.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'excitingCoil.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    Real 'excitingCoil.eps';
    Real 'core.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'core.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'core.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'core.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'core.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'core.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'core.nonLinearPermeability' = false "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'core.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1000.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'core.material.label' = "SoftMagnetic" "Name of material";
    parameter Real 'core.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1.0 "Initial relative permeability at B=0";
    parameter Real 'core.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Flux density at maximum relative permeability";
    parameter Real 'core.material.c_a' = 1.0 "Coefficient of approximation function";
    parameter Real 'core.material.c_b' = 1.0 "Coefficient of approximation function";
    parameter Real 'core.material.n' = 1.0 "Exponent of approximation function";
    Real 'core.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'core.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'core.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'core.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'core.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'core.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'core.B_N' "Absolute value of normalized B";
    parameter Real 'core.l'(unit = "m", quantity = "Length") = 0.01 "Width (orthogonal to flux direction)";
    parameter Real 'core.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.045 "Inner radius of hollow cylinder";
    parameter Real 'core.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.055 "Outer radius of hollow cylinder";
    parameter Real 'core.alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 6.263185307179587 "Angle of cylinder section";
    Real 'airGap.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'airGap.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'airGap.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'airGap.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'airGap.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference of ports";
    Real 'airGap.Phi'(start = 0.0, unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port_p to port_n";
    parameter Boolean 'airGap.nonLinearPermeability' = false "= true, if non-linear rel. permeability is used, otherwise constant rel. permeability" annotation(Evaluate = true);
    parameter Real 'airGap.mu_rConst'(unit = "1", quantity = "RelativePermeability") = 1.0 "Constant relative permeability; used if nonLinearPermeability = false";
    parameter String 'airGap.material.label' = "SoftMagnetic" "Name of material";
    parameter Real 'airGap.material.mu_i'(unit = "1", quantity = "RelativePermeability") = 1.0 "Initial relative permeability at B=0";
    parameter Real 'airGap.material.B_myMax'(unit = "T", quantity = "MagneticFluxDensity") = 1.0 "Flux density at maximum relative permeability";
    parameter Real 'airGap.material.c_a' = 1.0 "Coefficient of approximation function";
    parameter Real 'airGap.material.c_b' = 1.0 "Coefficient of approximation function";
    parameter Real 'airGap.material.n' = 1.0 "Exponent of approximation function";
    Real 'airGap.R_m'(unit = "H-1", quantity = "Reluctance") "Magnetic reluctance";
    Real 'airGap.G_m'(unit = "H", quantity = "Permeance") "Magnetic permeance";
    Real 'airGap.B'(unit = "T", quantity = "MagneticFluxDensity") "Magnetic flux density";
    Real 'airGap.A'(unit = "m2", quantity = "Area") "Cross-sectional area penetrated by magnetic flux";
    Real 'airGap.H'(unit = "A/m", quantity = "MagneticFieldStrength") "Magnetic field strength";
    Real 'airGap.mu_r'(unit = "1", quantity = "RelativePermeability") "Relative magnetic permeability";
    Real 'airGap.B_N' "Absolute value of normalized B";
    parameter Real 'airGap.l'(unit = "m", quantity = "Length") = 0.01 "Width (orthogonal to flux direction)";
    parameter Real 'airGap.r_i'(min = 0.0, unit = "m", quantity = "Length") = 0.045 "Inner radius of hollow cylinder";
    parameter Real 'airGap.r_o'(min = 0.0, unit = "m", quantity = "Length") = 0.055 "Outer radius of hollow cylinder";
    parameter Real 'airGap.alpha'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.019999999999999574 "Angle of cylinder section";
    Real 'measuringCoil.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'measuringCoil.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'measuringCoil.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'measuringCoil.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'measuringCoil.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'measuringCoil.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'measuringCoil.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'measuringCoil.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'measuringCoil.v'(unit = "V", quantity = "ElectricPotential") "Voltage";
    Real 'measuringCoil.i'(stateSelect = StateSelect.prefer, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current";
    Real 'measuringCoil.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential difference";
    Real 'measuringCoil.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux coupled into magnetic circuit";
    parameter Real 'measuringCoil.N' = 1.0 "Number of turns";
    Real 'measuringCoil.Psi'(unit = "Wb", quantity = "MagneticFlux") "Flux linkage";
    Real 'measuringCoil.L_stat'(unit = "H", quantity = "Inductance") "Static inductance abs(Psi/i)";
    Real 'measuringCoil.eps';
    Real 'magneticGround.port.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'magneticGround.port.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'electricGround1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricGround1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'rampCurrent.I'(start = 1.0, unit = "A", quantity = "ElectricCurrent") = 1.5 "Height of ramp";
    parameter Real 'rampCurrent.duration'(start = 2.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.015 "Duration of ramp";
    Real 'rampCurrent.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'rampCurrent.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rampCurrent.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rampCurrent.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'rampCurrent.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'rampCurrent.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'rampCurrent.signalSource.height' = 1.5 "Height of ramp";
    parameter Real 'rampCurrent.signalSource.duration'(start = 2.0, min = 0.0, unit = "s", quantity = "Time") = 0.015 "Duration of ramp (= 0.0 gives a Step)";
    Real 'rampCurrent.signalSource.y' "Connector of Real output signal";
    parameter Real 'rampCurrent.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'rampCurrent.signalSource.startTime'(unit = "s", quantity = "Time") = 0.01 "Output y = offset for time < startTime";
    parameter Real 'rampCurrent.offset'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Current offset";
    parameter Real 'rampCurrent.startTime'(unit = "s", quantity = "Time") = 0.01 "Time offset";
    Real 'magFluxSensor.port_p.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'magFluxSensor.port_p.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'magFluxSensor.port_n.V_m'(unit = "A", quantity = "MagneticPotential") "Magnetic potential at the port";
    Real 'magFluxSensor.port_n.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux flowing into the port";
    Real 'magFluxSensor.Phi'(unit = "Wb", quantity = "MagneticFlux") "Magnetic flux from port p to port n as output signal";
    Real 'electricGround2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'electricGround2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'voltageSensor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'voltageSensor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'voltageSensor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'voltageSensor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'voltageSensor.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as output signal";
  equation
    'excitingCoil.eps' = 2.220446049250313e-14;
    'measuringCoil.eps' = 2.220446049250313e-14;
    'core.port_n.V_m' = 'measuringCoil.port_p.V_m';
    'measuringCoil.port_n.V_m' = 'airGap.port_p.V_m';
    'rampCurrent.p.v' = 'electricGround1.p.v';
    'rampCurrent.p.v' = 'excitingCoil.n.v';
    'rampCurrent.n.v' = 'excitingCoil.p.v';
    'electricGround2.p.v' = 'voltageSensor.n.v';
    'electricGround2.p.v' = 'measuringCoil.n.v';
    'measuringCoil.p.v' = 'voltageSensor.p.v';
    'excitingCoil.port_n.V_m' = 'magFluxSensor.port_n.V_m';
    'magneticGround.port.V_m' = 'airGap.port_n.V_m';
    'magneticGround.port.V_m' = 'magFluxSensor.port_p.V_m';
    'excitingCoil.port_p.V_m' = 'core.port_p.V_m';
    'core.port_p.Phi' + 'excitingCoil.port_p.Phi' = 0.0;
    'magFluxSensor.port_n.Phi' + 'excitingCoil.port_n.Phi' = 0.0;
    'rampCurrent.p.i' + 'electricGround1.p.i' + 'excitingCoil.n.i' = 0.0;
    'measuringCoil.port_p.Phi' + 'core.port_n.Phi' = 0.0;
    'measuringCoil.port_n.Phi' + 'airGap.port_p.Phi' = 0.0;
    'voltageSensor.p.i' + 'measuringCoil.p.i' = 0.0;
    'voltageSensor.n.i' + 'electricGround2.p.i' + 'measuringCoil.n.i' = 0.0;
    'rampCurrent.n.i' + 'excitingCoil.p.i' = 0.0;
    'magFluxSensor.port_p.Phi' + 'magneticGround.port.Phi' + 'airGap.port_n.Phi' = 0.0;
    'excitingCoil.v' = 'excitingCoil.p.v' - 'excitingCoil.n.v';
    0.0 = 'excitingCoil.p.i' + 'excitingCoil.n.i';
    'excitingCoil.i' = 'excitingCoil.p.i';
    'excitingCoil.V_m' = 'excitingCoil.port_p.V_m' - 'excitingCoil.port_n.V_m';
    0.0 = 'excitingCoil.port_p.Phi' + 'excitingCoil.port_n.Phi';
    'excitingCoil.Phi' = 'excitingCoil.port_p.Phi';
    'excitingCoil.V_m' = 'excitingCoil.i' * 500.0 "Ampere's law";
    500.0 * der('excitingCoil.Phi') = -'excitingCoil.v' "Faraday's law";
    'excitingCoil.Psi' = 500.0 * 'excitingCoil.Phi';
    'excitingCoil.L_stat' = noEvent(if abs('excitingCoil.i') > 'excitingCoil.eps' then abs('excitingCoil.Psi' / 'excitingCoil.i') else abs('excitingCoil.Psi' / 'excitingCoil.eps'));
    'core.A' = 1.0000000000000002e-4;
    'core.G_m' = 1.25663706212e-6 * 'core.mu_r' * 'core.A' / 0.31315926535897937;
    'core.B_N' = abs('core.B' / 'core.material.B_myMax');
    'core.mu_r' = 1000.0;
    'core.R_m' = 1.0 / 'core.G_m';
    'core.V_m' = 'core.Phi' * 'core.R_m';
    'core.B' = 'core.Phi' / 'core.A';
    'core.H' = 'core.B' / (1.25663706212e-6 * 'core.mu_r');
    0.0 = 'core.port_p.Phi' + 'core.port_n.Phi';
    'core.V_m' = 'core.port_p.V_m' - 'core.port_n.V_m';
    'core.Phi' = 'core.port_p.Phi';
    'airGap.A' = 1.0000000000000002e-4;
    'airGap.G_m' = 1.25663706212e-6 * 'airGap.mu_r' * 'airGap.A' / 9.999999999999788e-4;
    'airGap.B_N' = abs('airGap.B' / 'airGap.material.B_myMax');
    'airGap.mu_r' = 1.0;
    'airGap.R_m' = 1.0 / 'airGap.G_m';
    'airGap.V_m' = 'airGap.Phi' * 'airGap.R_m';
    'airGap.B' = 'airGap.Phi' / 'airGap.A';
    'airGap.H' = 'airGap.B' / (1.25663706212e-6 * 'airGap.mu_r');
    0.0 = 'airGap.port_p.Phi' + 'airGap.port_n.Phi';
    'airGap.V_m' = 'airGap.port_p.V_m' - 'airGap.port_n.V_m';
    'airGap.Phi' = 'airGap.port_p.Phi';
    'measuringCoil.v' = 'measuringCoil.p.v' - 'measuringCoil.n.v';
    0.0 = 'measuringCoil.p.i' + 'measuringCoil.n.i';
    'measuringCoil.i' = 'measuringCoil.p.i';
    'measuringCoil.V_m' = 'measuringCoil.port_p.V_m' - 'measuringCoil.port_n.V_m';
    0.0 = 'measuringCoil.port_p.Phi' + 'measuringCoil.port_n.Phi';
    'measuringCoil.Phi' = 'measuringCoil.port_p.Phi';
    'measuringCoil.V_m' = 'measuringCoil.i' "Ampere's law";
    der('measuringCoil.Phi') = -'measuringCoil.v' "Faraday's law";
    'measuringCoil.Psi' = 'measuringCoil.Phi';
    'measuringCoil.L_stat' = noEvent(if abs('measuringCoil.i') > 'measuringCoil.eps' then abs('measuringCoil.Psi' / 'measuringCoil.i') else abs('measuringCoil.Psi' / 'measuringCoil.eps'));
    'magneticGround.port.V_m' = 0.0;
    'electricGround1.p.v' = 0.0;
    'rampCurrent.signalSource.y' = if time < 0.01 then 0.0 else if time < 0.025 then (time - 0.01) * 1.5 / 0.015 else 1.5;
    'rampCurrent.i' = 'rampCurrent.signalSource.y';
    0.0 = 'rampCurrent.p.i' + 'rampCurrent.n.i';
    'rampCurrent.i' = 'rampCurrent.p.i';
    'rampCurrent.v' = 'rampCurrent.p.v' - 'rampCurrent.n.v';
    'magFluxSensor.port_p.V_m' = 'magFluxSensor.port_n.V_m';
    'magFluxSensor.Phi' = 'magFluxSensor.port_p.Phi';
    0.0 = 'magFluxSensor.port_p.Phi' + 'magFluxSensor.port_n.Phi';
    'electricGround2.p.v' = 0.0;
    'voltageSensor.p.i' = 0.0;
    'voltageSensor.n.i' = 0.0;
    'voltageSensor.v' = 'voltageSensor.p.v' - 'voltageSensor.n.v';
    annotation(experiment(StopTime = 0.05, Interval = 0.0001));
  end 'ToroidalCoreQuadraticCrossSection';
end 'ToroidalCoreQuadraticCrossSection';
