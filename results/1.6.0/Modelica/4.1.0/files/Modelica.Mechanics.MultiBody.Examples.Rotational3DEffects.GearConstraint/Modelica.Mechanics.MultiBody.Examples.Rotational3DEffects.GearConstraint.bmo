//! base 0.1.0
package 'GearConstraint'
  function 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy' "Return orientation object from n_x and n_y vectors"
    input Real 'n_x'[3];
    input Real 'n_y'[3];
    output Real 'T'[3, 3];
    Real 'e_x'[3](each unit = "1") = if 'Modelica.Math.Vectors.length'('n_x') < 1e-10 then {1.0, 0.0, 0.0} else 'Modelica.Math.Vectors.normalize'('n_x', 2.220446049250313e-14);
    Real 'e_y'[3](each unit = "1") = if 'Modelica.Math.Vectors.length'('n_y') < 1e-10 then {0.0, 1.0, 0.0} else 'Modelica.Math.Vectors.normalize'('n_y', 2.220446049250313e-14);
    Real 'n_z_aux'[3](each unit = "1") = {'e_x'[2] * 'e_y'[3] - 'e_x'[3] * 'e_y'[2], 'e_x'[3] * 'e_y'[1] - 'e_x'[1] * 'e_y'[3], 'e_x'[1] * 'e_y'[2] - 'e_x'[2] * 'e_y'[1]};
    Real 'n_y_aux'[3](each unit = "1") = if 'n_z_aux'[1] * 'n_z_aux'[1] + 'n_z_aux'[2] * 'n_z_aux'[2] + 'n_z_aux'[3] * 'n_z_aux'[3] > 1e-6 then 'e_y' else if abs('e_x'[1]) > 1e-6 then {0.0, 1.0, 0.0} else {1.0, 0.0, 0.0};
    Real 'e_z_aux'[3](each unit = "1") = {'e_x'[2] * 'n_y_aux'[3] - 'e_x'[3] * 'n_y_aux'[2], 'e_x'[3] * 'n_y_aux'[1] - 'e_x'[1] * 'n_y_aux'[3], 'e_x'[1] * 'n_y_aux'[2] - 'e_x'[2] * 'n_y_aux'[1]};
    Real 'e_z'[3](each unit = "1") = 'Modelica.Math.Vectors.normalize'('e_z_aux', 2.220446049250313e-14);
  algorithm
    'T' := {'e_x', {'e_z'[2] * 'e_x'[3] - 'e_z'[3] * 'e_x'[2], 'e_z'[3] * 'e_x'[1] - 'e_z'[1] * 'e_x'[3], 'e_z'[1] * 'e_x'[2] - 'e_z'[2] * 'e_x'[1]}, 'e_z'};
  end 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy';

  type 'Modelica.Mechanics.MultiBody.Types.GravityTypes' = enumeration('NoGravity', 'UniformGravity', 'PointGravity');

  type 'Modelica.Mechanics.MultiBody.Types.ResolveInFrameAB' = enumeration('world', 'frame_a', 'frame_b', 'frame_resolve');

  type 'Modelica.Mechanics.MultiBody.Types.VectorQuantity' = enumeration('Force', 'Torque', 'Velocity', 'Acceleration', 'AngularVelocity', 'AngularAcceleration', 'RelativePosition');

  model 'GearConstraint' "Demonstrate usage of GearConstraint model"
    Real 'gearConstraint.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.frame_a.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.frame_a.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.frame_a.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'gearConstraint.frame_a.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'gearConstraint.frame_a.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'gearConstraint.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.frame_b.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.frame_b.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.frame_b.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.frame_b.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.frame_b.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.frame_b.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.frame_b.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
