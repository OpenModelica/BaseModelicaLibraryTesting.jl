    parameter Real 'gearConstraint.r_a[3]'(unit = "m", quantity = "Length") = 0.0 "Vector from frame bearing to frame_a resolved in bearing";
    parameter Real 'gearConstraint.r_b[1]'(unit = "m", quantity = "Length") = 0.0 "Vector from frame bearing to frame_b resolved in bearing";
    parameter Real 'gearConstraint.r_b[2]'(unit = "m", quantity = "Length") = 0.0 "Vector from frame bearing to frame_b resolved in bearing";
    parameter Real 'gearConstraint.r_b[3]'(unit = "m", quantity = "Length") = 0.0 "Vector from frame bearing to frame_b resolved in bearing";
    parameter StateSelect 'gearConstraint.stateSelect' = StateSelect.default "Priority to use joint coordinates (phi_a, phi_b, w_a, w_b) as states";
    parameter Boolean 'gearConstraint.checkTotalPower' = true "= true, if total power flowing into this component shall be determined (must be zero)";
    Real 'gearConstraint.phi_b'(stateSelect = StateSelect.default, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle of revolute joint at frame_b";
    Real 'gearConstraint.w_b'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "First derivative of angle phi_b (relative angular velocity b)";
    Real 'gearConstraint.a_b'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Second derivative of angle phi_b (relative angular acceleration b)";
    Real 'gearConstraint.totalPower'(unit = "W", quantity = "Power") "Total power flowing into this element, if checkTotalPower=true (otherwise dummy)";
    Real 'gearConstraint.actuatedRevolute_a.axis.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'gearConstraint.actuatedRevolute_a.axis.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'gearConstraint.actuatedRevolute_a.support.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'gearConstraint.actuatedRevolute_a.support.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'gearConstraint.actuatedRevolute_a.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
