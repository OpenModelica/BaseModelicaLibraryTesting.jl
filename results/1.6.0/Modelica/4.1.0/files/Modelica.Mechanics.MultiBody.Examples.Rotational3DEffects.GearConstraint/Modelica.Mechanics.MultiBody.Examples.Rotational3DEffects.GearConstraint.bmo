    Real 'gearConstraint.actuatedRevolute_a.frame_a.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_a.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_a.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
