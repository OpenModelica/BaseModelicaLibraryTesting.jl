    Real 'gearConstraint.actuatedRevolute_a.frame_b.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_b.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_b.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'gearConstraint.actuatedRevolute_a.frame_b.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
