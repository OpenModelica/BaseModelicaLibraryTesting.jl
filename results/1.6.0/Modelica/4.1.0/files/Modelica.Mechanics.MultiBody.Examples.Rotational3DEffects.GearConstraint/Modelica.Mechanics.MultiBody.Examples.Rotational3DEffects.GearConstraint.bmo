    Real 'gearConstraint.bearing.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.bearing.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.bearing.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'gearConstraint.bearing.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.bearing.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.bearing.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.bearing.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.bearing.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'gearConstraint.bearing.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
