    parameter Boolean 'gearConstraint.actuatedRevolute_a.useAxisFlange' = true "= true, if axis flange is enabled" annotation(Evaluate = true);
    parameter Boolean 'gearConstraint.actuatedRevolute_a.animation' = false "= true, if animation shall be enabled (show axis as cylinder)";
    parameter Real 'gearConstraint.actuatedRevolute_a.n[1]'(unit = "1") = 1.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'gearConstraint.actuatedRevolute_a.n[2]'(unit = "1") = 0.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'gearConstraint.actuatedRevolute_a.n[3]'(unit = "1") = 0.0 "Axis of rotation resolved in frame_a (= same as in frame_b)" annotation(Evaluate = true);
    parameter Real 'gearConstraint.actuatedRevolute_a.cylinderLength'(min = 0.0, unit = "m", quantity = "Length") = 0.1 "Length of cylinder representing the joint axis";
    parameter Real 'gearConstraint.actuatedRevolute_a.cylinderDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.05 "Diameter of cylinder representing the joint axis";
    Integer 'gearConstraint.actuatedRevolute_a.cylinderColor[1]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Integer 'gearConstraint.actuatedRevolute_a.cylinderColor[2]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Integer 'gearConstraint.actuatedRevolute_a.cylinderColor[3]'(max = 255, min = 0) "Color of cylinder representing the joint axis";
    Real 'gearConstraint.actuatedRevolute_a.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter StateSelect 'gearConstraint.actuatedRevolute_a.stateSelect' = StateSelect.prefer "Priority to use joint angle phi and w=der(phi) as states";
    Real 'gearConstraint.actuatedRevolute_a.phi'(stateSelect = StateSelect.prefer, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle from frame_a to frame_b";
    Real 'gearConstraint.actuatedRevolute_a.w'(stateSelect = StateSelect.prefer, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "First derivative of angle phi (relative angular velocity)";
    Real 'gearConstraint.actuatedRevolute_a.a'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Second derivative of angle phi (relative angular acceleration)";
    Real 'gearConstraint.actuatedRevolute_a.tau'(unit = "N.m", quantity = "Torque") "Driving torque in direction of axis of rotation";
    Real 'gearConstraint.actuatedRevolute_a.angle'(displayUnit = "deg", unit = "rad", quantity = "Angle") "= phi";
    parameter Real 'gearConstraint.actuatedRevolute_a.e[1]'(unit = "1") = 1.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    parameter Real 'gearConstraint.actuatedRevolute_a.e[2]'(unit = "1") = 0.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    parameter Real 'gearConstraint.actuatedRevolute_a.e[3]'(unit = "1") = 0.0 "Unit vector in direction of rotation axis, resolved in frame_a (= same as in frame_b)";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'gearConstraint.actuatedRevolute_a.R_rel.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    parameter Real 'gearConstraint.actuatedRevolute_a.fixed.phi0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Fixed offset angle of housing";
    Real 'gearConstraint.actuatedRevolute_a.fixed.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'gearConstraint.actuatedRevolute_a.fixed.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'gearConstraint.actuatedRevolute_a.internalAxis.tau'(unit = "N.m", quantity = "Torque") "External support torque (must be computed via torque balance in model where InternalSupport is used; = flange.tau)";
    Real 'gearConstraint.actuatedRevolute_a.internalAxis.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "External support angle (= flange.phi)";
