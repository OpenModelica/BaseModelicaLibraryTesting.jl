//! base 0.1.0
package 'SpringDamperSystem'
  function 'Modelica.Mechanics.MultiBody.Frames.resolve1' "Transform vector from frame 2 to frame 1"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v2';
    output Real[3] 'v1';
  algorithm
    'v1' := {'R'.'T'[1,1] * 'v2'[1] + 'R'.'T'[2,1] * 'v2'[2] + 'R'.'T'[3,1] * 'v2'[3], 'R'.'T'[1,2] * 'v2'[1] + 'R'.'T'[2,2] * 'v2'[2] + 'R'.'T'[3,2] * 'v2'[3], 'R'.'T'[1,3] * 'v2'[1] + 'R'.'T'[2,3] * 'v2'[2] + 'R'.'T'[3,3] * 'v2'[3]};
    annotation(derivative(order = 1, noDerivative = 'R') = 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der', InlineAfterIndexReduction = true);
  end 'Modelica.Mechanics.MultiBody.Frames.resolve1';

  function 'Modelica.Mechanics.MultiBody.Frames.resolve2' "Transform vector from frame 1 to frame 2"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v1';
    output Real[3] 'v2';
  algorithm
    'v2' := {'R'.'T'[1,1] * 'v1'[1] + 'R'.'T'[1,2] * 'v1'[2] + 'R'.'T'[1,3] * 'v1'[3], 'R'.'T'[2,1] * 'v1'[1] + 'R'.'T'[2,2] * 'v1'[2] + 'R'.'T'[2,3] * 'v1'[3], 'R'.'T'[3,1] * 'v1'[1] + 'R'.'T'[3,2] * 'v1'[2] + 'R'.'T'[3,3] * 'v1'[3]};
    annotation(derivative(order = 1, noDerivative = 'R') = 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der', InlineAfterIndexReduction = true);
  end 'Modelica.Mechanics.MultiBody.Frames.resolve2';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent' "Maximum of the input arguments, without event and function can be differentiated"
    input Real 'u1';
    input Real 'u2';
    output Real 'y';
  algorithm
    'y' := if 'u1' > 'u2' then 'u1' else 'u2';
    annotation(derivative(order = 1) = 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent_d', LateInline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent_d' "First derivative of function maxWithoutEvent(..)"
    input Real 'u1';
    input Real 'u2';
    input Real 'u1_d';
    input Real 'u2_d';
    output Real 'y_d';
  algorithm
    'y_d' := if 'u1' > 'u2' then 'u1_d' else 'u2_d';
    annotation(derivative(order = 2) = 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent_dd', LateInline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent_d';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent_dd' "First derivative of function maxWithoutEvent_d(..)"
    input Real 'u1';
    input Real 'u2';
    input Real 'u1_d';
    input Real 'u2_d';
    input Real 'u1_dd';
    input Real 'u2_dd';
    output Real 'y_dd';
  algorithm
    'y_dd' := if 'u1' > 'u2' then 'u1_dd' else 'u2_dd';
    annotation(LateInline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.maxWithoutEvent_dd';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der' "Derivative of function Frames.resolve1(..)"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v2';
    input Real[3] 'v2_der';
    output Real[3] 'v1_der';
  algorithm
    'v1_der' := 'Modelica.Mechanics.MultiBody.Frames.resolve1'('R', {'v2_der'[1] + 'R'.'w'[2] * 'v2'[3] - 'R'.'w'[3] * 'v2'[2], 'v2_der'[2] + 'R'.'w'[3] * 'v2'[1] - 'R'.'w'[1] * 'v2'[3], 'v2_der'[3] + 'R'.'w'[1] * 'v2'[2] - 'R'.'w'[2] * 'v2'[1]});
    annotation(Inline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve1_der';

  function 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der' "Derivative of function Frames.resolve2(..)"
    input 'Modelica.Mechanics.MultiBody.Frames.Orientation' 'R';
    input Real[3] 'v1';
    input Real[3] 'v1_der';
    output Real[3] 'v2_der';
  algorithm
    'v2_der' := 'Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1_der') - {'R'.'w'[2] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[3] - 'R'.'w'[3] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[2], 'R'.'w'[3] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[1] - 'R'.'w'[1] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[3], 'R'.'w'[1] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[2] - 'R'.'w'[2] * ('Modelica.Mechanics.MultiBody.Frames.resolve2'('R', 'v1'))[1]};
    annotation(Inline = true);
  end 'Modelica.Mechanics.MultiBody.Frames.Internal.resolve2_der';

  function 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy' "Return orientation object from n_x and n_y vectors"
    input Real[3] 'n_x';
    input Real[3] 'n_y';
    output Real[3, 3] 'T';
    Real[3] 'e_x'(each unit = "1") = if sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3]) < 1e-10 then {1.0, 0.0, 0.0} else smooth(0, if sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3]) >= 2.220446049250313e-14 then {'n_x'[1] / sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3]), 'n_x'[2] / sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3]), 'n_x'[3] / sqrt('n_x'[1] * 'n_x'[1] + 'n_x'[2] * 'n_x'[2] + 'n_x'[3] * 'n_x'[3])} else {'n_x'[1] / 2.220446049250313e-14, 'n_x'[2] / 2.220446049250313e-14, 'n_x'[3] / 2.220446049250313e-14});
    Real[3] 'e_y'(each unit = "1") = if sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3]) < 1e-10 then {0.0, 1.0, 0.0} else smooth(0, if sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3]) >= 2.220446049250313e-14 then {'n_y'[1] / sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3]), 'n_y'[2] / sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3]), 'n_y'[3] / sqrt('n_y'[1] * 'n_y'[1] + 'n_y'[2] * 'n_y'[2] + 'n_y'[3] * 'n_y'[3])} else {'n_y'[1] / 2.220446049250313e-14, 'n_y'[2] / 2.220446049250313e-14, 'n_y'[3] / 2.220446049250313e-14});
    Real[3] 'n_z_aux'(each unit = "1") = {'e_x'[2] * 'e_y'[3] - 'e_x'[3] * 'e_y'[2], 'e_x'[3] * 'e_y'[1] - 'e_x'[1] * 'e_y'[3], 'e_x'[1] * 'e_y'[2] - 'e_x'[2] * 'e_y'[1]};
    Real[3] 'n_y_aux'(each unit = "1") = if 'n_z_aux'[1] * 'n_z_aux'[1] + 'n_z_aux'[2] * 'n_z_aux'[2] + 'n_z_aux'[3] * 'n_z_aux'[3] > 1e-6 then 'e_y' else if abs('e_x'[1]) > 1e-6 then {0.0, 1.0, 0.0} else {1.0, 0.0, 0.0};
    Real[3] 'e_z_aux'(each unit = "1") = {'e_x'[2] * 'n_y_aux'[3] - 'e_x'[3] * 'n_y_aux'[2], 'e_x'[3] * 'n_y_aux'[1] - 'e_x'[1] * 'n_y_aux'[3], 'e_x'[1] * 'n_y_aux'[2] - 'e_x'[2] * 'n_y_aux'[1]};
    Real[3] 'e_z'(each unit = "1") = smooth(0, if sqrt('e_z_aux'[1] * 'e_z_aux'[1] + 'e_z_aux'[2] * 'e_z_aux'[2] + 'e_z_aux'[3] * 'e_z_aux'[3]) >= 2.220446049250313e-14 then {'e_z_aux'[1] / sqrt('e_z_aux'[1] * 'e_z_aux'[1] + 'e_z_aux'[2] * 'e_z_aux'[2] + 'e_z_aux'[3] * 'e_z_aux'[3]), 'e_z_aux'[2] / sqrt('e_z_aux'[1] * 'e_z_aux'[1] + 'e_z_aux'[2] * 'e_z_aux'[2] + 'e_z_aux'[3] * 'e_z_aux'[3]), 'e_z_aux'[3] / sqrt('e_z_aux'[1] * 'e_z_aux'[1] + 'e_z_aux'[2] * 'e_z_aux'[2] + 'e_z_aux'[3] * 'e_z_aux'[3])} else {'e_z_aux'[1] / 2.220446049250313e-14, 'e_z_aux'[2] / 2.220446049250313e-14, 'e_z_aux'[3] / 2.220446049250313e-14});
  algorithm
    'T' := {'e_x', {'e_z'[2] * 'e_x'[3] - 'e_z'[3] * 'e_x'[2], 'e_z'[3] * 'e_x'[1] - 'e_z'[1] * 'e_x'[3], 'e_z'[1] * 'e_x'[2] - 'e_z'[2] * 'e_x'[1]}, 'e_z'};
  end 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy';

  function 'Modelica.Units.Conversions.to_unit1' "Change the unit of a Real number to unit=\"1\""
    input Real 'r';
    output Real 'result'(unit = "1");
  algorithm
    'result' := 'r';
    annotation(Inline = true);
  end 'Modelica.Units.Conversions.to_unit1';

  type 'Modelica.Mechanics.MultiBody.Types.GravityTypes' = enumeration('NoGravity', 'UniformGravity', 'PointGravity');

  record 'Modelica.Mechanics.MultiBody.Frames.Orientation'
    Real[3, 3] 'T';
    Real[3] 'w'(unit = fill("rad/s", 3), quantity = fill("AngularVelocity", 3));
  end 'Modelica.Mechanics.MultiBody.Frames.Orientation';

  model 'SpringDamperSystem' "Simple spring/damper/mass system"
    parameter Boolean 'animation' = true "= true, if animation shall be enabled";
    Real 'world.frame_b.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'world.frame_b.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'world.frame_b.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.frame_b.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.frame_b.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.frame_b.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'world.frame_b.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'world.frame_b.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'world.frame_b.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'world.frame_b.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'world.frame_b.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    parameter Boolean 'world.enableAnimation' = true "= true, if animation of all components is enabled";
    parameter Boolean 'world.animateWorld' = true "= true, if world coordinate system shall be visualized";
    parameter Boolean 'world.animateGravity' = true "= true, if gravity field shall be visualized (acceleration vector or field center)";
    parameter Boolean 'world.animateGround' = false "= true, if ground plane shall be visualized";
    parameter String 'world.label1' = "x" "Label of horizontal axis in icon";
    parameter String 'world.label2' = "y" "Label of vertical axis in icon";
    parameter 'Modelica.Mechanics.MultiBody.Types.GravityTypes' 'world.gravityType' = 'Modelica.Mechanics.MultiBody.Types.GravityTypes'.'UniformGravity' "Type of gravity field" annotation(Evaluate = true);
    parameter Real 'world.g'(unit = "m/s2", quantity = "Acceleration") = 9.80665 "Constant gravity acceleration";
    parameter Real 'world.n[1]'(unit = "1") = 0.0 "Direction of gravity resolved in world frame (gravity = g*n/length(n))" annotation(Evaluate = true);
    parameter Real 'world.n[2]'(unit = "1") = -1.0 "Direction of gravity resolved in world frame (gravity = g*n/length(n))" annotation(Evaluate = true);
    parameter Real 'world.n[3]'(unit = "1") = 0.0 "Direction of gravity resolved in world frame (gravity = g*n/length(n))" annotation(Evaluate = true);
    parameter Real 'world.mu'(min = 0.0, unit = "m3/s2") = 3.986004418e14 "Gravity field constant (default = field constant of earth)";
    parameter Boolean 'world.driveTrainMechanics3D' = true "= true, if 3-dim. mechanical effects of Parts.Mounting1D/Rotor1D/BevelGear1D shall be taken into account";
    parameter Real 'world.axisLength'(min = 0.0, unit = "m", quantity = "Length") = 0.5 "Length of world axes arrows";
    parameter Real 'world.axisDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.0125 "Diameter of world axes arrows";
    parameter Boolean 'world.axisShowLabels' = true "= true, if labels shall be shown";
    Integer 'world.axisColor_x[1]'(max = 255, min = 0) "Color of x-arrow";
    Integer 'world.axisColor_x[2]'(max = 255, min = 0) "Color of x-arrow";
    Integer 'world.axisColor_x[3]'(max = 255, min = 0) "Color of x-arrow";
    Integer 'world.axisColor_y[1]'(max = 255, min = 0);
    Integer 'world.axisColor_y[2]'(max = 255, min = 0);
    Integer 'world.axisColor_y[3]'(max = 255, min = 0);
    Integer 'world.axisColor_z[1]'(max = 255, min = 0) "Color of z-arrow";
    Integer 'world.axisColor_z[2]'(max = 255, min = 0) "Color of z-arrow";
    Integer 'world.axisColor_z[3]'(max = 255, min = 0) "Color of z-arrow";
    parameter Real 'world.gravityArrowTail[1]'(unit = "m", quantity = "Length") = 0.0 "Position vector from origin of world frame to arrow tail, resolved in world frame";
    parameter Real 'world.gravityArrowTail[2]'(unit = "m", quantity = "Length") = 0.0 "Position vector from origin of world frame to arrow tail, resolved in world frame";
    parameter Real 'world.gravityArrowTail[3]'(unit = "m", quantity = "Length") = 0.0 "Position vector from origin of world frame to arrow tail, resolved in world frame";
    parameter Real 'world.gravityArrowLength'(unit = "m", quantity = "Length") = 0.25 "Length of gravity arrow";
    parameter Real 'world.gravityArrowDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.0125 "Diameter of gravity arrow";
    Integer 'world.gravityArrowColor[1]'(max = 255, min = 0) "Color of gravity arrow";
    Integer 'world.gravityArrowColor[2]'(max = 255, min = 0) "Color of gravity arrow";
    Integer 'world.gravityArrowColor[3]'(max = 255, min = 0) "Color of gravity arrow";
    parameter Real 'world.gravitySphereDiameter'(min = 0.0, unit = "m", quantity = "Length") = 1.2742e7 "Diameter of sphere representing gravity center (default = mean diameter of earth)";
    Integer 'world.gravitySphereColor[1]'(max = 255, min = 0) "Color of gravity sphere";
    Integer 'world.gravitySphereColor[2]'(max = 255, min = 0) "Color of gravity sphere";
    Integer 'world.gravitySphereColor[3]'(max = 255, min = 0) "Color of gravity sphere";
    parameter Real 'world.groundAxis_u[1]'(unit = "1") = 1.0 "Vector along 1st axis (called u) of ground plane, resolved in world frame (should be perpendicular to gravity direction)";
    parameter Real 'world.groundAxis_u[2]'(unit = "1") = 0.0 "Vector along 1st axis (called u) of ground plane, resolved in world frame (should be perpendicular to gravity direction)";
    parameter Real 'world.groundAxis_u[3]'(unit = "1") = 0.0 "Vector along 1st axis (called u) of ground plane, resolved in world frame (should be perpendicular to gravity direction)";
    parameter Real 'world.groundLength_u'(unit = "m", quantity = "Length") = 2.0 "Length of ground plane along groundAxis_u";
    parameter Real 'world.groundLength_v'(unit = "m", quantity = "Length") = 2.0 "Length of ground plane perpendicular to groundAxis_u";
    Integer 'world.groundColor[1]'(max = 255, min = 0) "Color of ground plane";
    Integer 'world.groundColor[2]'(max = 255, min = 0) "Color of ground plane";
    Integer 'world.groundColor[3]'(max = 255, min = 0) "Color of ground plane";
    parameter Real 'world.nominalLength'(unit = "m", quantity = "Length") = 1.0 "Nominal length of multi-body system";
    parameter Real 'world.defaultAxisLength'(unit = "m", quantity = "Length") = 0.2 "Default for length of a frame axis (but not world frame)";
    parameter Real 'world.defaultJointLength'(unit = "m", quantity = "Length") = 0.1 "Default for the fixed length of a shape representing a joint";
    parameter Real 'world.defaultJointWidth'(unit = "m", quantity = "Length") = 0.05 "Default for the fixed width of a shape representing a joint";
    parameter Real 'world.defaultForceLength'(unit = "m", quantity = "Length") = 0.1 "Default for the fixed length of a shape representing a force (e.g., damper)";
    parameter Real 'world.defaultForceWidth'(unit = "m", quantity = "Length") = 0.05 "Default for the fixed width of a shape representing a force (e.g., spring, bushing)";
    parameter Real 'world.defaultBodyDiameter'(unit = "m", quantity = "Length") = 0.1111111111111111 "Default for diameter of sphere representing the center of mass of a body";
    parameter Real 'world.defaultWidthFraction' = 20.0 "Default for shape width as a fraction of shape length (e.g., for Parts.FixedTranslation)";
    parameter Real 'world.defaultArrowDiameter'(unit = "m", quantity = "Length") = 0.025 "Default for arrow diameter (e.g., of forces, torques, sensors)";
    parameter Real 'world.defaultFrameDiameterFraction' = 40.0 "Default for arrow diameter of a coordinate system as a fraction of axis length";
    parameter Real 'world.defaultSpecularCoefficient'(min = 0.0) = 0.7 "Default reflection of ambient light (= 0: light is completely absorbed)";
    parameter Real 'world.defaultN_to_m'(min = 0.0, unit = "N/m") = 1000.0 "Default scaling of force arrows (length = force/defaultN_to_m)";
    parameter Real 'world.defaultNm_to_m'(min = 0.0, unit = "N.m/m") = 1000.0 "Default scaling of torque arrows (length = torque/defaultNm_to_m)";
    parameter Real 'world.headLength'(unit = "m", quantity = "Length") = 0.0625;
    parameter Real 'world.headWidth'(unit = "m", quantity = "Length") = 0.037500000000000006;
    parameter Real 'world.lineLength'(unit = "m", quantity = "Length") = 0.4375;
    parameter Real 'world.lineWidth'(unit = "m", quantity = "Length") = 0.0125;
    parameter Real 'world.scaledLabel'(unit = "m", quantity = "Length") = 0.037500000000000006;
    parameter Real 'world.labelStart'(unit = "m", quantity = "Length") = 0.525;
    parameter String 'world.x_arrowLine.shapeType' = "cylinder" "Type of shape (box, sphere, cylinder, pipecylinder, cone, pipe, beam, gearwheel, spring, <external shape>)";
    Real 'world.x_arrowLine.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'world.x_arrowLine.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.x_arrowLine.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.x_arrowLine.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'world.x_arrowLine.r[1]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_arrowLine.r[2]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_arrowLine.r[3]'(unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of object frame, resolved in world frame";
    Real 'world.x_arrowLine.r_shape[1]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'world.x_arrowLine.r_shape[2]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'world.x_arrowLine.r_shape[3]'(unit = "m", quantity = "Length") "Position vector from origin of object frame to shape origin, resolved in object frame";
    Real 'world.x_arrowLine.lengthDirection[1]' "Vector in length direction, resolved in object frame";
    Real 'world.x_arrowLine.lengthDirection[2]' "Vector in length direction, resolved in object frame";
    Real 'world.x_arrowLine.lengthDirection[3]' "Vector in length direction, resolved in object frame";
    Real 'world.x_arrowLine.widthDirection[1]' "Vector in width direction, resolved in object frame";
    Real 'world.x_arrowLine.widthDirection[2]' "Vector in width direction, resolved in object frame";
    Real 'world.x_arrowLine.widthDirection[3]' "Vector in width direction, resolved in object frame";
