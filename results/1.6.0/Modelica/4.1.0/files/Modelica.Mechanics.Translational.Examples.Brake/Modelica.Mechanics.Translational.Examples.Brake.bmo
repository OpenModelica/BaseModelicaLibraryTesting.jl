//! base 0.1.0
package 'Brake'
  function 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer' "Derivative of interpolated 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    input Real 'der_u';
    output Real 'der_y';
  external "C" 'der_y' = ModelicaStandardTables_CombiTable1D_getDerValue('tableID', 'icol', 'u', 'der_u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
  end 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer';

  function 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2' "Interpolate 1-dim. table defined by matrix (but do not provide a second derivative function)"
    input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'tableID';
    input Integer 'icol';
    input Real 'u';
    output Real 'y';
  external "C" 'y' = ModelicaStandardTables_CombiTable1D_getValue('tableID', 'icol', 'u') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    annotation(derivative(order = 1) = 'Modelica.Blocks.Tables.Internal.getDerTable1DValueNoDer');
  end 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2';

  type 'Modelica.Blocks.Types.Smoothness' = enumeration('LinearSegments', 'ContinuousDerivative', 'ConstantSegments', 'MonotoneContinuousDerivative1', 'MonotoneContinuousDerivative2', 'ModifiedContinuousDerivative');

  class 'Modelica.Blocks.Types.ExternalCombiTable1D'
  extends ExternalObject;

    function constructor "Initialize 1-dim. table defined by matrix"
      input String 'tableName';
      input String 'fileName';
      input Real[:, :] 'table';
      input Integer[:] 'columns';
      input 'Modelica.Blocks.Types.Smoothness' 'smoothness';
      input 'Modelica.Blocks.Types.Extrapolation' 'extrapolation' = 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints';
      input Boolean 'verboseRead' = true;
      input String 'delimiter' = ",";
      input Integer 'nHeaderLines' = 0;
      output 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" 'externalCombiTable1D' = ModelicaStandardTables_CombiTable1D_init3('fileName', 'tableName', 'table', size('table', 1), size('table', 2), 'columns', size('columns', 1), 'smoothness', 'extrapolation', 'verboseRead', 'delimiter', 'nHeaderLines') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end constructor;

    function destructor "Terminate 1-dim. table defined by matrix"
      input 'Modelica.Blocks.Types.ExternalCombiTable1D' 'externalCombiTable1D';
    external "C" ModelicaStandardTables_CombiTable1D_close('externalCombiTable1D') annotation(Library = {"ModelicaStandardTables", "ModelicaIO", "ModelicaMatIO", "zlib"}, LibraryDirectory = "modelica://Modelica/Resources/Library");
    end destructor;

end 'Modelica.Blocks.Types.ExternalCombiTable1D';

  type 'Modelica.Blocks.Types.Extrapolation' = enumeration('HoldLastPoint', 'LastTwoPoints', 'Periodic', 'NoExtrapolation');

  model 'Brake' "Demonstrate braking of a translational moving mass"
    parameter Boolean 'brake.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'brake.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'brake.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'brake.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'brake.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'brake.s_a'(unit = "m", quantity = "Length") "Distance between left flange and support";
    Real 'brake.s_b'(unit = "m", quantity = "Length") "Distance between right flange and support";
    Real 'brake.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    parameter Boolean 'brake.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'brake.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    parameter Real 'brake.mu_pos[1,1]' = 0.0 "Positive sliding friction coefficient [-] as function of v [m/s] (v>=0)";
    parameter Real 'brake.mu_pos[1,2]' = 0.5 "Positive sliding friction coefficient [-] as function of v [m/s] (v>=0)";
    parameter 'Modelica.Blocks.Types.Smoothness' 'brake.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' "Smoothness of interpolation in mu_pos table";
    parameter Real 'brake.peak'(min = 1.0) = 1.0 "Peak for maximum value of mu at v==0 (mu0_max = peak*mu_pos[1,2])";
    parameter Real 'brake.cgeo'(min = 0.0) = 1.0 "Geometry constant containing friction distribution assumption";
    parameter Real 'brake.fn_max'(start = 1.0, min = 0.0, unit = "N", quantity = "Force") = 1.0 "Maximum normal force";
    parameter Real 'brake.v_small'(unit = "m/s", quantity = "Velocity") = 0.001 "Relative velocity near to zero (see model info text)";
    Real 'brake.v_relfric'(unit = "m/s", quantity = "Velocity") "Relative velocity between frictional surfaces";
    Real 'brake.a_relfric'(unit = "m/s2", quantity = "Acceleration") "Relative acceleration between frictional surfaces";
    Real 'brake.f0'(unit = "N", quantity = "Force") "Friction force for v_relfric=0 and forward sliding";
    Real 'brake.f0_max'(unit = "N", quantity = "Force") "Maximum friction force for v_relfric=0 and locked";
    Boolean 'brake.free' "= true, if frictional element is not active";
    Real 'brake.sa'(unit = "1") "Path parameter of friction characteristic f = f(a_relfric)";
    Boolean 'brake.startForward'(fixed = true, start = false) "= true, if v_relfric=0 and start of forward sliding";
    Boolean 'brake.startBackward'(fixed = true, start = false) "= true, if v_relfric=0 and start of backward sliding";
    Boolean 'brake.locked'(start = false) "= true, if v_relfric=0 and not sliding";
    constant Integer 'brake.Unknown' = 3 "Value of mode is not known";
    constant Integer 'brake.Free' = 2 "Element is not active";
    constant Integer 'brake.Forward' = 1 "v_relfric > 0 (forward sliding)";
    constant Integer 'brake.Stuck' = 0 "v_relfric = 0 (forward sliding, locked or backward sliding)";
    constant Integer 'brake.Backward' = -1 "v_relfric < 0 (backward sliding)";
    Integer 'brake.mode'(fixed = true, start = 3, max = 3, min = -1) "Mode of friction (-1: backward sliding, 0: stuck, 1: forward sliding, 2: inactive, 3: unknown)";
    constant Real 'brake.unitAcceleration'(unit = "m/s2", quantity = "Acceleration") = 1.0;
    constant Real 'brake.unitForce'(unit = "N", quantity = "Force") = 1.0;
    Real 'brake.s'(unit = "m", quantity = "Length") "Absolute position of flange_a and of flange_b";
    Real 'brake.f'(unit = "N", quantity = "Force") "Brake friction force";
    Real 'brake.v'(unit = "m/s", quantity = "Velocity") "Absolute velocity of flange_a and flange_b";
    Real 'brake.a'(unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of flange_a and flange_b";
    Real 'brake.mu' "Friction coefficient";
    Real 'brake.fn'(unit = "N", quantity = "Force") "Normal force (=fn_max*f_normalized)";
    Real 'brake.f_normalized' "Normalized force signal 0..1 (normal force = fn_max*f_normalized; brake is active if > 0)";
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'brake.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 0.5}}, {2}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object for sliding friction coefficient";
    parameter Real 'brake.mu0' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('brake.tableID', 1, 0.0) "Friction coefficient for v=0 and forward sliding";
    Real 'brake.table_signs[1]' "Signs for sliding friction coefficient table interpolation: [sign for v, sign for mu]";
    Real 'brake.table_signs[2]' "Signs for sliding friction coefficient table interpolation: [sign for v, sign for mu]";
    parameter Real 'mass1.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass of the sliding mass";
    parameter StateSelect 'mass1.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'mass1.s'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'mass1.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'mass1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass1.v'(stateSelect = StateSelect.default, fixed = true, start = 1.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass1.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter Real 'step.height' = 2.0 "Height of step";
    Real 'step.y' "Connector of Real output signal";
    parameter Real 'step.offset' = 0.0 "Offset of output signal y";
    parameter Real 'step.startTime'(unit = "s", quantity = "Time") = 0.1 "Output y = offset for time < startTime";
    parameter Boolean 'brake1.useSupport' = true "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'brake1.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'brake1.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'brake1.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'brake1.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'brake1.support.s'(unit = "m", quantity = "Length") = 'brake1.s_support' "Absolute position of flange";
    Real 'brake1.support.f'(unit = "N", quantity = "Force") = -('brake1.flange_a.f' + 'brake1.flange_b.f') "Cut force directed into flange";
    Real 'brake1.s_a'(unit = "m", quantity = "Length") "Distance between left flange and support";
    Real 'brake1.s_b'(unit = "m", quantity = "Length") "Distance between right flange and support";
    Real 'brake1.s_support'(unit = "m", quantity = "Length") "Absolute position of support flange";
    parameter Boolean 'brake1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'brake1.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    parameter Real 'brake1.mu_pos[1,1]' = 0.0 "Positive sliding friction coefficient [-] as function of v [m/s] (v>=0)";
    parameter Real 'brake1.mu_pos[1,2]' = 0.5 "Positive sliding friction coefficient [-] as function of v [m/s] (v>=0)";
    parameter 'Modelica.Blocks.Types.Smoothness' 'brake1.smoothness' = 'Modelica.Blocks.Types.Smoothness'.'LinearSegments' "Smoothness of interpolation in mu_pos table";
    parameter Real 'brake1.peak'(min = 1.0) = 1.0 "Peak for maximum value of mu at v==0 (mu0_max = peak*mu_pos[1,2])";
    parameter Real 'brake1.cgeo'(min = 0.0) = 1.0 "Geometry constant containing friction distribution assumption";
    parameter Real 'brake1.fn_max'(start = 1.0, min = 0.0, unit = "N", quantity = "Force") = 1.0 "Maximum normal force";
    parameter Real 'brake1.v_small'(unit = "m/s", quantity = "Velocity") = 0.001 "Relative velocity near to zero (see model info text)";
    Real 'brake1.v_relfric'(unit = "m/s", quantity = "Velocity") "Relative velocity between frictional surfaces";
    Real 'brake1.a_relfric'(unit = "m/s2", quantity = "Acceleration") "Relative acceleration between frictional surfaces";
    Real 'brake1.f0'(unit = "N", quantity = "Force") "Friction force for v_relfric=0 and forward sliding";
    Real 'brake1.f0_max'(unit = "N", quantity = "Force") "Maximum friction force for v_relfric=0 and locked";
    Boolean 'brake1.free' "= true, if frictional element is not active";
    Real 'brake1.sa'(unit = "1") "Path parameter of friction characteristic f = f(a_relfric)";
    Boolean 'brake1.startForward'(fixed = true, start = false) "= true, if v_relfric=0 and start of forward sliding";
    Boolean 'brake1.startBackward'(fixed = true, start = false) "= true, if v_relfric=0 and start of backward sliding";
    Boolean 'brake1.locked'(start = false) "= true, if v_relfric=0 and not sliding";
    constant Integer 'brake1.Unknown' = 3 "Value of mode is not known";
    constant Integer 'brake1.Free' = 2 "Element is not active";
    constant Integer 'brake1.Forward' = 1 "v_relfric > 0 (forward sliding)";
    constant Integer 'brake1.Stuck' = 0 "v_relfric = 0 (forward sliding, locked or backward sliding)";
    constant Integer 'brake1.Backward' = -1 "v_relfric < 0 (backward sliding)";
    Integer 'brake1.mode'(fixed = true, start = 3, max = 3, min = -1) "Mode of friction (-1: backward sliding, 0: stuck, 1: forward sliding, 2: inactive, 3: unknown)";
    constant Real 'brake1.unitAcceleration'(unit = "m/s2", quantity = "Acceleration") = 1.0;
    constant Real 'brake1.unitForce'(unit = "N", quantity = "Force") = 1.0;
    Real 'brake1.s'(unit = "m", quantity = "Length") "Absolute position of flange_a and of flange_b";
    Real 'brake1.f'(unit = "N", quantity = "Force") "Brake friction force";
    Real 'brake1.v'(unit = "m/s", quantity = "Velocity") "Absolute velocity of flange_a and flange_b";
    Real 'brake1.a'(unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of flange_a and flange_b";
    Real 'brake1.mu' "Friction coefficient";
    Real 'brake1.fn'(unit = "N", quantity = "Force") "Normal force (=fn_max*f_normalized)";
    Real 'brake1.f_normalized' "Normalized force signal 0..1 (normal force = fn_max*f_normalized; brake is active if > 0)";
    parameter 'Modelica.Blocks.Types.ExternalCombiTable1D' 'brake1.tableID' = 'Modelica.Blocks.Types.ExternalCombiTable1D'("NoName", "NoName", {{0.0, 0.5}}, {2}, 'Modelica.Blocks.Types.Smoothness'.'LinearSegments', 'Modelica.Blocks.Types.Extrapolation'.'LastTwoPoints', false, ",", 0) "External table object for sliding friction coefficient";
    parameter Real 'brake1.mu0' = 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('brake1.tableID', 1, 0.0) "Friction coefficient for v=0 and forward sliding";
    Real 'brake1.table_signs[1]' "Signs for sliding friction coefficient table interpolation: [sign for v, sign for mu]";
    Real 'brake1.table_signs[2]' "Signs for sliding friction coefficient table interpolation: [sign for v, sign for mu]";
    parameter Real 'mass2.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 1.0 "Mass of the sliding mass";
    parameter StateSelect 'mass2.stateSelect' = StateSelect.default "Priority to use s and v as states";
    Real 'mass2.s'(stateSelect = StateSelect.default, fixed = true, start = 0.0, unit = "m", quantity = "Length") "Absolute position of center of component (s = flange_a.s + L/2 = flange_b.s - L/2)";
    parameter Real 'mass2.L'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Length of component, from left flange to right flange (= flange_b.s - flange_a.s)";
    Real 'mass2.flange_a.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass2.flange_a.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass2.flange_b.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'mass2.flange_b.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
    Real 'mass2.v'(stateSelect = StateSelect.default, fixed = true, start = 1.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of component";
    Real 'mass2.a'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of component";
    parameter Real 'fixed.s0'(unit = "m", quantity = "Length") = 0.0 "Fixed offset position of housing";
    Real 'fixed.flange.s'(unit = "m", quantity = "Length") "Absolute position of flange";
    Real 'fixed.flange.f'(unit = "N", quantity = "Force") "Cut force directed into flange";
  equation
    'mass1.flange_b.s' = 'brake.flange_a.s';
    'step.y' = 'brake1.f_normalized';
    'step.y' = 'brake.f_normalized';
    'mass2.flange_b.s' = 'brake1.flange_a.s';
    'fixed.flange.s' = 'brake1.support.s';
    'brake.flange_b.f' = 0.0;
    'mass1.flange_a.f' = 0.0;
    'mass1.flange_b.f' + 'brake.flange_a.f' = 0.0;
    'brake1.flange_b.f' = 0.0;
    'mass2.flange_a.f' = 0.0;
    'mass2.flange_b.f' + 'brake1.flange_a.f' = 0.0;
    'fixed.flange.f' + 'brake1.support.f' = 0.0;
    'brake.s' = 'brake.s_a';
    'brake.s' = 'brake.s_b';
    'brake.v' = der('brake.s');
    'brake.a' = der('brake.v');
    'brake.v_relfric' = 'brake.v';
    'brake.a_relfric' = 'brake.a';
    'brake.flange_a.f' + 'brake.flange_b.f' - 'brake.f' = 0.0;
    'brake.fn' = 'brake.f_normalized';
    'brake.f0' = 'brake.mu0' * 'brake.fn';
    'brake.f0_max' = 'brake.f0';
    'brake.free' = 'brake.fn' <= 0.0;
    'brake.table_signs[1]' = if 'brake.startForward' then 1.0 else if 'brake.startBackward' then -1.0 else if pre('brake.mode') == 1 then 1.0 else -1.0;
    'brake.table_signs[2]' = if 'brake.startForward' then 1.0 else if 'brake.startBackward' then -1.0 else if pre('brake.mode') == 1 then 1.0 else -1.0;
    'brake.mu' = 'brake.table_signs[2]' * 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('brake.tableID', 1, 'brake.table_signs[1]' * 'brake.v');
    'brake.f' = if 'brake.locked' then 'brake.sa' else if 'brake.free' then 0.0 else 'brake.mu' * 'brake.fn';
    'brake.lossPower' = 'brake.f' * 'brake.v_relfric';
    'brake.startForward' = (pre('brake.mode') == 0 and ('brake.sa' > 'brake.f0_max' or pre('brake.startForward') and 'brake.sa' > 'brake.f0') or pre('brake.mode') == (-1) and 'brake.v_relfric' > 0.001) or initial() and 'brake.v_relfric' > 0.0;
    'brake.startBackward' = (pre('brake.mode') == 0 and ('brake.sa' < (-'brake.f0_max') or pre('brake.startBackward') and 'brake.sa' < (-'brake.f0')) or pre('brake.mode') == 1 and 'brake.v_relfric' < (-0.001)) or initial() and 'brake.v_relfric' < 0.0;
    'brake.locked' = not 'brake.free' and not (((pre('brake.mode') == 1 or 'brake.startForward') or pre('brake.mode') == (-1)) or 'brake.startBackward');
    'brake.a_relfric' = if 'brake.locked' then 0.0 else if 'brake.free' then 'brake.sa' else if 'brake.startForward' then 'brake.sa' - 'brake.f0_max' else if 'brake.startBackward' then 'brake.sa' + 'brake.f0_max' else if pre('brake.mode') == 1 then 'brake.sa' - 'brake.f0_max' else if pre('brake.mode') == (-1) then 'brake.sa' + 'brake.f0_max' else 'brake.sa' - sign('brake.v_relfric') * 'brake.f0_max';
    'brake.mode' = if 'brake.free' then 2 else if ((pre('brake.mode') == 1 or pre('brake.mode') == 2) or 'brake.startForward') and 'brake.v_relfric' > 0.0 then 1 else if ((pre('brake.mode') == (-1) or pre('brake.mode') == 2) or 'brake.startBackward') and 'brake.v_relfric' < 0.0 then -1 else 0;
    'brake.s_a' = 'brake.flange_a.s' - 'brake.s_support';
    'brake.s_b' = 'brake.flange_b.s' - 'brake.s_support';
    'brake.s_support' = 0.0;
    'mass1.v' = der('mass1.s');
    'mass1.a' = der('mass1.v');
    'mass1.a' = 'mass1.flange_a.f' + 'mass1.flange_b.f';
    'mass1.flange_a.s' = 'mass1.s';
    'mass1.flange_b.s' = 'mass1.s';
    'step.y' = if time < 0.1 then 0.0 else 2.0;
    'brake1.s' = 'brake1.s_a';
    'brake1.s' = 'brake1.s_b';
    'brake1.v' = der('brake1.s');
    'brake1.a' = der('brake1.v');
    'brake1.v_relfric' = 'brake1.v';
    'brake1.a_relfric' = 'brake1.a';
    'brake1.flange_a.f' + 'brake1.flange_b.f' - 'brake1.f' = 0.0;
    'brake1.fn' = 'brake1.f_normalized';
    'brake1.f0' = 'brake1.mu0' * 'brake1.fn';
    'brake1.f0_max' = 'brake1.f0';
    'brake1.free' = 'brake1.fn' <= 0.0;
    'brake1.table_signs[1]' = if 'brake1.startForward' then 1.0 else if 'brake1.startBackward' then -1.0 else if pre('brake1.mode') == 1 then 1.0 else -1.0;
    'brake1.table_signs[2]' = if 'brake1.startForward' then 1.0 else if 'brake1.startBackward' then -1.0 else if pre('brake1.mode') == 1 then 1.0 else -1.0;
    'brake1.mu' = 'brake1.table_signs[2]' * 'Modelica.Blocks.Tables.Internal.getTable1DValueNoDer2'('brake1.tableID', 1, 'brake1.table_signs[1]' * 'brake1.v');
    'brake1.f' = if 'brake1.locked' then 'brake1.sa' else if 'brake1.free' then 0.0 else 'brake1.mu' * 'brake1.fn';
    'brake1.lossPower' = 'brake1.f' * 'brake1.v_relfric';
    'brake1.startForward' = (pre('brake1.mode') == 0 and ('brake1.sa' > 'brake1.f0_max' or pre('brake1.startForward') and 'brake1.sa' > 'brake1.f0') or pre('brake1.mode') == (-1) and 'brake1.v_relfric' > 0.001) or initial() and 'brake1.v_relfric' > 0.0;
    'brake1.startBackward' = (pre('brake1.mode') == 0 and ('brake1.sa' < (-'brake1.f0_max') or pre('brake1.startBackward') and 'brake1.sa' < (-'brake1.f0')) or pre('brake1.mode') == 1 and 'brake1.v_relfric' < (-0.001)) or initial() and 'brake1.v_relfric' < 0.0;
    'brake1.locked' = not 'brake1.free' and not (((pre('brake1.mode') == 1 or 'brake1.startForward') or pre('brake1.mode') == (-1)) or 'brake1.startBackward');
    'brake1.a_relfric' = if 'brake1.locked' then 0.0 else if 'brake1.free' then 'brake1.sa' else if 'brake1.startForward' then 'brake1.sa' - 'brake1.f0_max' else if 'brake1.startBackward' then 'brake1.sa' + 'brake1.f0_max' else if pre('brake1.mode') == 1 then 'brake1.sa' - 'brake1.f0_max' else if pre('brake1.mode') == (-1) then 'brake1.sa' + 'brake1.f0_max' else 'brake1.sa' - sign('brake1.v_relfric') * 'brake1.f0_max';
    'brake1.mode' = if 'brake1.free' then 2 else if ((pre('brake1.mode') == 1 or pre('brake1.mode') == 2) or 'brake1.startForward') and 'brake1.v_relfric' > 0.0 then 1 else if ((pre('brake1.mode') == (-1) or pre('brake1.mode') == 2) or 'brake1.startBackward') and 'brake1.v_relfric' < 0.0 then -1 else 0;
    'brake1.s_a' = 'brake1.flange_a.s' - 'brake1.s_support';
    'brake1.s_b' = 'brake1.flange_b.s' - 'brake1.s_support';
    'mass2.v' = der('mass2.s');
    'mass2.a' = der('mass2.v');
    'mass2.a' = 'mass2.flange_a.f' + 'mass2.flange_b.f';
    'mass2.flange_a.s' = 'mass2.s';
    'mass2.flange_b.s' = 'mass2.s';
    'fixed.flange.s' = 0.0;
    annotation(experiment(StopTime = 2.0, Interval = 0.001));
  end 'Brake';
end 'Brake';
