    parameter Real 'idealPump.flowPort_b.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
    parameter Real 'idealPump.flowPort_b.medium.cv'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant volume";
    parameter Real 'idealPump.flowPort_b.medium.lambda'(unit = "W/(m.K)", quantity = "ThermalConductivity") = 1.0 "Thermal conductivity";
    parameter Real 'idealPump.flowPort_b.medium.nu'(min = 0.0, unit = "m2/s", quantity = "KinematicViscosity") = 1.0 "Kinematic viscosity";
    Real 'idealPump.flowPort_b.p'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'idealPump.flowPort_b.m_flow'(unit = "kg/s", quantity = "MassFlowRate");
    Real 'idealPump.flowPort_b.h'(unit = "J/kg", quantity = "SpecificEnergy");
    Real 'idealPump.flowPort_b.H_flow'(unit = "W", quantity = "EnthalpyFlowRate");
    parameter Real 'idealPump.wNominal'(start = 1.0, displayUnit = "rad/s", unit = "rad/s", quantity = "AngularVelocity") = 1.0 "Nominal speed";
    parameter Real 'idealPump.dp0'(start = 2.0, displayUnit = "Pa", unit = "Pa", quantity = "Pressure") = 2.0 "Max. pressure increase @ V_flow=0";
    parameter Real 'idealPump.V_flow0'(start = 2.0, unit = "m3/s", quantity = "VolumeFlowRate") = 2.0 "Max. volume flow rate @ dp=0";
    Real 'idealPump.w'(unit = "rad/s", quantity = "AngularVelocity") = der('idealPump.flange_a.phi') "Speed";
    Real 'idealPump.dp1'(displayUnit = "bar", unit = "Pa", quantity = "Pressure");
    Real 'idealPump.V_flow1'(unit = "m3/s", quantity = "VolumeFlowRate");
    Real 'idealPump.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'idealPump.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'valve.medium.rho'(min = 0.0, displayUnit = "g/cm3", unit = "kg/m3", quantity = "Density") = 1.0 "Density";
    parameter Real 'valve.medium.cp'(unit = "J/(kg.K)", quantity = "SpecificHeatCapacity") = 1.0 "Specific heat capacity at constant pressure";
