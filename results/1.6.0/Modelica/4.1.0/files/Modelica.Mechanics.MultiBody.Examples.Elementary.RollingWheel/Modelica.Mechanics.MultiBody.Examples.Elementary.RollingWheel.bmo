//! base 0.1.0
package 'RollingWheel'
  function 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy' "Return orientation object from n_x and n_y vectors"
    input Real 'n_x'[3];
    input Real 'n_y'[3];
    output Real 'T'[3, 3];
    Real 'e_x'[3](each unit = "1") = if 'Modelica.Math.Vectors.length'('n_x') < 1e-10 then {1.0, 0.0, 0.0} else 'Modelica.Math.Vectors.normalize'('n_x', 2.220446049250313e-14);
    Real 'e_y'[3](each unit = "1") = if 'Modelica.Math.Vectors.length'('n_y') < 1e-10 then {0.0, 1.0, 0.0} else 'Modelica.Math.Vectors.normalize'('n_y', 2.220446049250313e-14);
    Real 'n_z_aux'[3](each unit = "1") = {'e_x'[2] * 'e_y'[3] - 'e_x'[3] * 'e_y'[2], 'e_x'[3] * 'e_y'[1] - 'e_x'[1] * 'e_y'[3], 'e_x'[1] * 'e_y'[2] - 'e_x'[2] * 'e_y'[1]};
    Real 'n_y_aux'[3](each unit = "1") = if 'n_z_aux'[1] * 'n_z_aux'[1] + 'n_z_aux'[2] * 'n_z_aux'[2] + 'n_z_aux'[3] * 'n_z_aux'[3] > 1e-6 then 'e_y' else if abs('e_x'[1]) > 1e-6 then {0.0, 1.0, 0.0} else {1.0, 0.0, 0.0};
    Real 'e_z_aux'[3](each unit = "1") = {'e_x'[2] * 'n_y_aux'[3] - 'e_x'[3] * 'n_y_aux'[2], 'e_x'[3] * 'n_y_aux'[1] - 'e_x'[1] * 'n_y_aux'[3], 'e_x'[1] * 'n_y_aux'[2] - 'e_x'[2] * 'n_y_aux'[1]};
    Real 'e_z'[3](each unit = "1") = 'Modelica.Math.Vectors.normalize'('e_z_aux', 2.220446049250313e-14);
  algorithm
    'T' := {'e_x', {'e_z'[2] * 'e_x'[3] - 'e_z'[3] * 'e_x'[2], 'e_z'[3] * 'e_x'[1] - 'e_z'[1] * 'e_x'[3], 'e_z'[1] * 'e_x'[2] - 'e_z'[2] * 'e_x'[1]}, 'e_z'};
  end 'Modelica.Mechanics.MultiBody.Frames.TransformationMatrices.from_nxy';

  type 'Modelica.Mechanics.MultiBody.Types.GravityTypes' = enumeration('NoGravity', 'UniformGravity', 'PointGravity');

  model 'RollingWheel' "Single wheel rolling on ground starting from an initial speed"
    parameter Boolean 'wheel1.animation' = true "= true, if animation of wheel shall be enabled";
    parameter Real 'wheel1.radius'(min = 0.0, unit = "m", quantity = "Length") = 0.3 "Radius of wheel";
    parameter Real 'wheel1.m'(min = 0.0, unit = "kg", quantity = "Mass") = 2.0 "Mass of wheel";
    parameter Real 'wheel1.I_axis'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.06 "Inertia along the wheel axis";
    parameter Real 'wheel1.I_long'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Inertia perpendicular to the wheel axis";
    parameter StateSelect 'wheel1.stateSelect' = StateSelect.always "Priority to use generalized coordinates as states" annotation(Evaluate = true);
    Real 'wheel1.x'(stateSelect = StateSelect.always, fixed = true, start = 0.2, unit = "m", quantity = "Length") "x-coordinate of wheel axis";
    Real 'wheel1.y'(stateSelect = StateSelect.always, fixed = true, start = 0.2, unit = "m", quantity = "Length") "y-coordinate of wheel axis";
    Real 'wheel1.angles[1]'(stateSelect = StateSelect.always, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angles to rotate world-frame in to frame_a around z-, y-, x-axis";
    Real 'wheel1.angles[2]'(stateSelect = StateSelect.always, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angles to rotate world-frame in to frame_a around z-, y-, x-axis";
    Real 'wheel1.angles[3]'(stateSelect = StateSelect.always, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Angles to rotate world-frame in to frame_a around z-, y-, x-axis";
    Real 'wheel1.der_angles[1]'(stateSelect = StateSelect.always, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Derivative of angles";
    Real 'wheel1.der_angles[2]'(stateSelect = StateSelect.always, fixed = true, start = 5.0, unit = "rad/s", quantity = "AngularVelocity") "Derivative of angles";
    Real 'wheel1.der_angles[3]'(stateSelect = StateSelect.always, fixed = true, start = 1.0, unit = "rad/s", quantity = "AngularVelocity") "Derivative of angles";
    parameter Real 'wheel1.width'(min = 0.0, unit = "m", quantity = "Length") = 0.035 "Width of wheel";
    parameter Real 'wheel1.hollowFraction' = 0.6 "For ring-like visualization: wheel radius / inner hole radius; i.e. 1.0: completely hollow, 0.0: full disc";
    parameter Integer 'wheel1.color[1]'(max = 255, min = 0) = 30 "Color of wheel";
    parameter Integer 'wheel1.color[2]'(max = 255, min = 0) = 30 "Color of wheel";
    parameter Integer 'wheel1.color[3]'(max = 255, min = 0) = 30 "Color of wheel";
    Real 'wheel1.body.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'wheel1.body.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'wheel1.body.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'wheel1.body.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.body.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'wheel1.body.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'wheel1.body.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'wheel1.body.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'wheel1.body.frame_a.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'wheel1.body.frame_a.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'wheel1.body.frame_a.t[1]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'wheel1.body.frame_a.t[2]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    Real 'wheel1.body.frame_a.t[3]'(unit = "N.m", quantity = "Torque") "Cut-torque resolved in connector frame";
    parameter Boolean 'wheel1.body.animation' = false "= true, if animation shall be enabled (show cylinder and sphere)";
    parameter Real 'wheel1.body.r_CM[1]'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to center of mass, resolved in frame_a";
    parameter Real 'wheel1.body.r_CM[2]'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to center of mass, resolved in frame_a";
    parameter Real 'wheel1.body.r_CM[3]'(start = 0.0, unit = "m", quantity = "Length") = 0.0 "Vector from frame_a to center of mass, resolved in frame_a";
    parameter Real 'wheel1.body.m'(start = 1.0, min = 0.0, unit = "kg", quantity = "Mass") = 2.0 "Mass of rigid body";
    parameter Real 'wheel1.body.I_11'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Element (1,1) of inertia tensor";
    parameter Real 'wheel1.body.I_22'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.06 "Element (2,2) of inertia tensor";
    parameter Real 'wheel1.body.I_33'(min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Element (3,3) of inertia tensor";
    parameter Real 'wheel1.body.I_21'(min = -1e60, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Element (2,1) of inertia tensor";
    parameter Real 'wheel1.body.I_31'(min = -1e60, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Element (3,1) of inertia tensor";
    parameter Real 'wheel1.body.I_32'(min = -1e60, unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Element (3,2) of inertia tensor";
    Real 'wheel1.body.r_0[1]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of frame_a";
    Real 'wheel1.body.r_0[2]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of frame_a";
    Real 'wheel1.body.r_0[3]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m", quantity = "Length") "Position vector from origin of world frame to origin of frame_a";
    Real 'wheel1.body.v_0[1]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
    Real 'wheel1.body.v_0[2]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
    Real 'wheel1.body.v_0[3]'(stateSelect = StateSelect.avoid, start = 0.0, unit = "m/s", quantity = "Velocity") "Absolute velocity of frame_a, resolved in world frame (= der(r_0))";
    Real 'wheel1.body.a_0[1]'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of frame_a resolved in world frame (= der(v_0))";
    Real 'wheel1.body.a_0[2]'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of frame_a resolved in world frame (= der(v_0))";
    Real 'wheel1.body.a_0[3]'(start = 0.0, unit = "m/s2", quantity = "Acceleration") "Absolute acceleration of frame_a resolved in world frame (= der(v_0))";
    parameter Boolean 'wheel1.body.angles_fixed' = false "= true, if angles_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'wheel1.body.angles_start[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate world frame around 'sequence_start' axes into frame_a";
    parameter Real 'wheel1.body.angles_start[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate world frame around 'sequence_start' axes into frame_a";
    parameter Real 'wheel1.body.angles_start[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Initial values of angles to rotate world frame around 'sequence_start' axes into frame_a";
    parameter Integer 'wheel1.body.sequence_start[1]'(max = 3, min = 1) = 1 "Sequence of rotations to rotate world frame into frame_a at initial time" annotation(Evaluate = true);
    parameter Integer 'wheel1.body.sequence_start[2]'(max = 3, min = 1) = 2 "Sequence of rotations to rotate world frame into frame_a at initial time" annotation(Evaluate = true);
    parameter Integer 'wheel1.body.sequence_start[3]'(max = 3, min = 1) = 3 "Sequence of rotations to rotate world frame into frame_a at initial time" annotation(Evaluate = true);
    parameter Boolean 'wheel1.body.w_0_fixed' = false "= true, if w_0_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'wheel1.body.w_0_start[1]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial or guess values of angular velocity of frame_a resolved in world frame";
    parameter Real 'wheel1.body.w_0_start[2]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial or guess values of angular velocity of frame_a resolved in world frame";
    parameter Real 'wheel1.body.w_0_start[3]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Initial or guess values of angular velocity of frame_a resolved in world frame";
    parameter Boolean 'wheel1.body.z_0_fixed' = false "= true, if z_0_start are used as initial values, else as guess values" annotation(Evaluate = true);
    parameter Real 'wheel1.body.z_0_start[1]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_0 = der(w_0)";
    parameter Real 'wheel1.body.z_0_start[2]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_0 = der(w_0)";
    parameter Real 'wheel1.body.z_0_start[3]'(unit = "rad/s2", quantity = "AngularAcceleration") = 0.0 "Initial values of angular acceleration z_0 = der(w_0)";
    parameter Real 'wheel1.body.sphereDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.1111111111111111 "Diameter of sphere";
    Integer 'wheel1.body.sphereColor[1]'(max = 255, min = 0) "Color of sphere";
    Integer 'wheel1.body.sphereColor[2]'(max = 255, min = 0) "Color of sphere";
    Integer 'wheel1.body.sphereColor[3]'(max = 255, min = 0) "Color of sphere";
    parameter Real 'wheel1.body.cylinderDiameter'(min = 0.0, unit = "m", quantity = "Length") = 0.037037037037037035 "Diameter of cylinder";
    Integer 'wheel1.body.cylinderColor[1]'(max = 255, min = 0) "Color of cylinder";
    Integer 'wheel1.body.cylinderColor[2]'(max = 255, min = 0) "Color of cylinder";
    Integer 'wheel1.body.cylinderColor[3]'(max = 255, min = 0) "Color of cylinder";
    Real 'wheel1.body.specularCoefficient'(min = 0.0) "Reflection of ambient light (= 0: light is completely absorbed)";
    parameter Boolean 'wheel1.body.enforceStates' = false "= true, if absolute variables of body object shall be used as states (StateSelect.always)" annotation(Evaluate = true);
    parameter Boolean 'wheel1.body.useQuaternions' = true "= true, if quaternions shall be used as potential states otherwise use 3 angles as potential states" annotation(Evaluate = true);
    parameter Integer 'wheel1.body.sequence_angleStates[1]'(max = 3, min = 1) = 1 "Sequence of rotations to rotate world frame into frame_a around the 3 angles used as potential states" annotation(Evaluate = true);
    parameter Integer 'wheel1.body.sequence_angleStates[2]'(max = 3, min = 1) = 2 "Sequence of rotations to rotate world frame into frame_a around the 3 angles used as potential states" annotation(Evaluate = true);
    parameter Integer 'wheel1.body.sequence_angleStates[3]'(max = 3, min = 1) = 3 "Sequence of rotations to rotate world frame into frame_a around the 3 angles used as potential states" annotation(Evaluate = true);
    parameter Real 'wheel1.body.I[1,1]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Inertia tensor";
    parameter Real 'wheel1.body.I[1,2]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Inertia tensor";
    parameter Real 'wheel1.body.I[1,3]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Inertia tensor";
    parameter Real 'wheel1.body.I[2,1]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Inertia tensor";
    parameter Real 'wheel1.body.I[2,2]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.06 "Inertia tensor";
    parameter Real 'wheel1.body.I[2,3]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Inertia tensor";
    parameter Real 'wheel1.body.I[3,1]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Inertia tensor";
    parameter Real 'wheel1.body.I[3,2]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.0 "Inertia tensor";
    parameter Real 'wheel1.body.I[3,3]'(unit = "kg.m2", quantity = "MomentOfInertia") = 0.12 "Inertia tensor";
    parameter Real 'wheel1.body.R_start.T[1,1]' = 1.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.T[1,2]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.T[1,3]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.T[2,1]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.T[2,2]' = 1.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.T[2,3]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.T[3,1]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.T[3,2]' = 0.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.T[3,3]' = 1.0 "Transformation matrix from world frame to local frame";
    parameter Real 'wheel1.body.R_start.w[1]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Absolute angular velocity of local frame, resolved in local frame";
    parameter Real 'wheel1.body.R_start.w[2]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Absolute angular velocity of local frame, resolved in local frame";
    parameter Real 'wheel1.body.R_start.w[3]'(unit = "rad/s", quantity = "AngularVelocity") = 0.0 "Absolute angular velocity of local frame, resolved in local frame";
    Real 'wheel1.body.w_a[1]'(stateSelect = StateSelect.avoid, fixed = false, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of frame_a resolved in frame_a";
    Real 'wheel1.body.w_a[2]'(stateSelect = StateSelect.avoid, fixed = false, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of frame_a resolved in frame_a";
    Real 'wheel1.body.w_a[3]'(stateSelect = StateSelect.avoid, fixed = false, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of frame_a resolved in frame_a";
    Real 'wheel1.body.z_a[1]'(fixed = false, start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of frame_a resolved in frame_a";
    Real 'wheel1.body.z_a[2]'(fixed = false, start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of frame_a resolved in frame_a";
    Real 'wheel1.body.z_a[3]'(fixed = false, start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of frame_a resolved in frame_a";
    Real 'wheel1.body.g_0[1]'(unit = "m/s2", quantity = "Acceleration") "Gravity acceleration resolved in world frame";
    Real 'wheel1.body.g_0[2]'(unit = "m/s2", quantity = "Acceleration") "Gravity acceleration resolved in world frame";
    Real 'wheel1.body.g_0[3]'(unit = "m/s2", quantity = "Acceleration") "Gravity acceleration resolved in world frame";
    parameter Real 'wheel1.body.Q_start[1]' = 0.0 "Quaternion orientation object from world frame to frame_a at initial time";
    parameter Real 'wheel1.body.Q_start[2]' = 0.0 "Quaternion orientation object from world frame to frame_a at initial time";
    parameter Real 'wheel1.body.Q_start[3]' = 0.0 "Quaternion orientation object from world frame to frame_a at initial time";
    parameter Real 'wheel1.body.Q_start[4]' = 1.0 "Quaternion orientation object from world frame to frame_a at initial time";
    Real 'wheel1.body.Q[1]'(stateSelect = StateSelect.avoid, start = 0.0) "Quaternion orientation object from world frame to frame_a (dummy value, if quaternions are not used as states)";
    Real 'wheel1.body.Q[2]'(stateSelect = StateSelect.avoid, start = 0.0) "Quaternion orientation object from world frame to frame_a (dummy value, if quaternions are not used as states)";
    Real 'wheel1.body.Q[3]'(stateSelect = StateSelect.avoid, start = 0.0) "Quaternion orientation object from world frame to frame_a (dummy value, if quaternions are not used as states)";
    Real 'wheel1.body.Q[4]'(stateSelect = StateSelect.avoid, start = 1.0) "Quaternion orientation object from world frame to frame_a (dummy value, if quaternions are not used as states)";
    parameter Real 'wheel1.body.phi_start[1]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Potential angle states at initial time";
    parameter Real 'wheel1.body.phi_start[2]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Potential angle states at initial time";
    parameter Real 'wheel1.body.phi_start[3]'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Potential angle states at initial time";
    Real 'wheel1.body.phi[1]'(stateSelect = StateSelect.avoid, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Dummy or 3 angles to rotate world frame into frame_a of body";
    Real 'wheel1.body.phi[2]'(stateSelect = StateSelect.avoid, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Dummy or 3 angles to rotate world frame into frame_a of body";
    Real 'wheel1.body.phi[3]'(stateSelect = StateSelect.avoid, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Dummy or 3 angles to rotate world frame into frame_a of body";
    Real 'wheel1.body.phi_d[1]'(stateSelect = StateSelect.avoid, unit = "rad/s", quantity = "AngularVelocity") "= der(phi)";
    Real 'wheel1.body.phi_d[2]'(stateSelect = StateSelect.avoid, unit = "rad/s", quantity = "AngularVelocity") "= der(phi)";
    Real 'wheel1.body.phi_d[3]'(stateSelect = StateSelect.avoid, unit = "rad/s", quantity = "AngularVelocity") "= der(phi)";
    Real 'wheel1.body.phi_dd[1]'(unit = "rad/s2", quantity = "AngularAcceleration") "= der(phi_d)";
    Real 'wheel1.body.phi_dd[2]'(unit = "rad/s2", quantity = "AngularAcceleration") "= der(phi_d)";
    Real 'wheel1.body.phi_dd[3]'(unit = "rad/s2", quantity = "AngularAcceleration") "= der(phi_d)";
    Real 'wheel1.frame_a.r_0[1]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'wheel1.frame_a.r_0[2]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'wheel1.frame_a.r_0[3]'(unit = "m", quantity = "Length") "Position vector from world frame to the connector frame origin, resolved in world frame";
    Real 'wheel1.frame_a.R.T[1,1]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.T[1,2]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.T[1,3]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.T[2,1]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.T[2,2]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.T[2,3]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.T[3,1]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.T[3,2]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.T[3,3]' "Transformation matrix from world frame to local frame";
    Real 'wheel1.frame_a.R.w[1]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'wheel1.frame_a.R.w[2]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'wheel1.frame_a.R.w[3]'(unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of local frame, resolved in local frame";
    Real 'wheel1.frame_a.f[1]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'wheel1.frame_a.f[2]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
    Real 'wheel1.frame_a.f[3]'(unit = "N", quantity = "Force") "Cut-force resolved in connector frame";
