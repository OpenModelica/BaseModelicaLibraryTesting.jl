    'hbridge.inverter_n.iAC' = 'hbridge.inverter_n.ac.i';
    'hbridge.inverter_n.powerAC' = 'hbridge.inverter_n.vAC' * 'hbridge.inverter_n.iAC';
    'hbridge.enableLogic.internalEnable[1]' = 'hbridge.enableLogic.booleanReplicator.y[1]';
    'hbridge.enableLogic.enableConstantSource.y' = 'hbridge.enableLogic.booleanReplicator.u';
    'hbridge.inverter_p.enableLogic.internalEnable[1]' = 'hbridge.inverter_p.enableLogic.booleanReplicator.y[1]';
    'hbridge.inverter_p.enableLogic.enableConstantSource.y' = 'hbridge.inverter_p.enableLogic.booleanReplicator.u';
    'hbridge.inverter_p.transistor_p.p.v' = 'hbridge.inverter_p.diode_p.n.v';
    'hbridge.inverter_p.transistor_p.p.v' = 'hbridge.inverter_p.dc_p.v';
    'hbridge.inverter_p.diode_p.n.i' + 'hbridge.inverter_p.transistor_p.p.i' - 'hbridge.inverter_p.dc_p.i' = 0.0;
    'hbridge.inverter_p.transistor_n.n.v' = 'hbridge.inverter_p.diode_n.p.v';
    'hbridge.inverter_p.transistor_n.n.v' = 'hbridge.inverter_p.dc_n.v';
    'hbridge.inverter_p.diode_n.p.i' + 'hbridge.inverter_p.transistor_n.n.i' - 'hbridge.inverter_p.dc_n.i' = 0.0;
    'hbridge.inverter_p.ac.v' = 'hbridge.inverter_p.transistor_p.n.v';
    'hbridge.inverter_p.ac.v' = 'hbridge.inverter_p.transistor_n.p.v';
    'hbridge.inverter_p.ac.v' = 'hbridge.inverter_p.diode_n.n.v';
    'hbridge.inverter_p.ac.v' = 'hbridge.inverter_p.diode_p.p.v';
    'hbridge.inverter_p.andCondition_p.y' = 'hbridge.inverter_p.transistor_p.fire';
    'hbridge.inverter_p.andCondition_n.y' = 'hbridge.inverter_p.transistor_n.fire';
    'hbridge.inverter_p.fire_n' = 'hbridge.inverter_p.andCondition_n.u1';
    'hbridge.inverter_p.enableLogic.internalEnable[1]' = 'hbridge.inverter_p.andCondition_p.u2';
    'hbridge.inverter_p.enableLogic.internalEnable[1]' = 'hbridge.inverter_p.andCondition_n.u2';
    'hbridge.inverter_p.andCondition_p.u1' = 'hbridge.inverter_p.fire_p';
    'hbridge.inverter_n.enableLogic.internalEnable[1]' = 'hbridge.inverter_n.enableLogic.booleanReplicator.y[1]';
    'hbridge.inverter_n.enableLogic.enableConstantSource.y' = 'hbridge.inverter_n.enableLogic.booleanReplicator.u';
    'hbridge.inverter_n.transistor_p.p.v' = 'hbridge.inverter_n.diode_p.n.v';
    'hbridge.inverter_n.transistor_p.p.v' = 'hbridge.inverter_n.dc_p.v';
    'hbridge.inverter_n.diode_p.n.i' + 'hbridge.inverter_n.transistor_p.p.i' - 'hbridge.inverter_n.dc_p.i' = 0.0;
    'hbridge.inverter_n.transistor_n.n.v' = 'hbridge.inverter_n.diode_n.p.v';
    'hbridge.inverter_n.transistor_n.n.v' = 'hbridge.inverter_n.dc_n.v';
    'hbridge.inverter_n.diode_n.p.i' + 'hbridge.inverter_n.transistor_n.n.i' - 'hbridge.inverter_n.dc_n.i' = 0.0;
    'hbridge.inverter_n.ac.v' = 'hbridge.inverter_n.transistor_p.n.v';
    'hbridge.inverter_n.ac.v' = 'hbridge.inverter_n.transistor_n.p.v';
    'hbridge.inverter_n.ac.v' = 'hbridge.inverter_n.diode_n.n.v';
