    'hbridge.inverter_p.andCondition_n.y' = 'hbridge.inverter_p.andCondition_n.u1' and 'hbridge.inverter_p.andCondition_n.u2';
    'hbridge.inverter_p.transistor_p.off' = 'hbridge.inverter_p.transistor_p.s' < 0.0 or not 'hbridge.inverter_p.transistor_p.fire';
    'hbridge.inverter_p.transistor_p.v' = 'hbridge.inverter_p.transistor_p.s' * (if 'hbridge.inverter_p.transistor_p.off' then 1.0 else 1e-5);
    'hbridge.inverter_p.transistor_p.i' = 'hbridge.inverter_p.transistor_p.s' * (if 'hbridge.inverter_p.transistor_p.off' then 1e-5 else 1.0);
    'hbridge.inverter_p.transistor_p.LossPower' = 'hbridge.inverter_p.transistor_p.v' * 'hbridge.inverter_p.transistor_p.i';
    'hbridge.inverter_p.transistor_p.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_p.transistor_p.p.i' + 'hbridge.inverter_p.transistor_p.n.i';
    'hbridge.inverter_p.transistor_p.i' = 'hbridge.inverter_p.transistor_p.p.i';
    'hbridge.inverter_p.transistor_p.v' = 'hbridge.inverter_p.transistor_p.p.v' - 'hbridge.inverter_p.transistor_p.n.v';
    'hbridge.inverter_p.diode_p.off' = 'hbridge.inverter_p.diode_p.s' < 0.0;
    'hbridge.inverter_p.diode_p.v' = 'hbridge.inverter_p.diode_p.s' * (if 'hbridge.inverter_p.diode_p.off' then 1.0 else 1e-5);
    'hbridge.inverter_p.diode_p.i' = 'hbridge.inverter_p.diode_p.s' * (if 'hbridge.inverter_p.diode_p.off' then 1e-5 else 1.0);
    'hbridge.inverter_p.diode_p.LossPower' = 'hbridge.inverter_p.diode_p.v' * 'hbridge.inverter_p.diode_p.i';
    'hbridge.inverter_p.diode_p.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_p.diode_p.p.i' + 'hbridge.inverter_p.diode_p.n.i';
    'hbridge.inverter_p.diode_p.i' = 'hbridge.inverter_p.diode_p.p.i';
    'hbridge.inverter_p.diode_p.v' = 'hbridge.inverter_p.diode_p.p.v' - 'hbridge.inverter_p.diode_p.n.v';
    'hbridge.inverter_p.transistor_n.off' = 'hbridge.inverter_p.transistor_n.s' < 0.0 or not 'hbridge.inverter_p.transistor_n.fire';
    'hbridge.inverter_p.transistor_n.v' = 'hbridge.inverter_p.transistor_n.s' * (if 'hbridge.inverter_p.transistor_n.off' then 1.0 else 1e-5);
    'hbridge.inverter_p.transistor_n.i' = 'hbridge.inverter_p.transistor_n.s' * (if 'hbridge.inverter_p.transistor_n.off' then 1e-5 else 1.0);
    'hbridge.inverter_p.transistor_n.LossPower' = 'hbridge.inverter_p.transistor_n.v' * 'hbridge.inverter_p.transistor_n.i';
    'hbridge.inverter_p.transistor_n.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_p.transistor_n.p.i' + 'hbridge.inverter_p.transistor_n.n.i';
    'hbridge.inverter_p.transistor_n.i' = 'hbridge.inverter_p.transistor_n.p.i';
    'hbridge.inverter_p.transistor_n.v' = 'hbridge.inverter_p.transistor_n.p.v' - 'hbridge.inverter_p.transistor_n.n.v';
    'hbridge.inverter_p.diode_n.off' = 'hbridge.inverter_p.diode_n.s' < 0.0;
    'hbridge.inverter_p.diode_n.v' = 'hbridge.inverter_p.diode_n.s' * (if 'hbridge.inverter_p.diode_n.off' then 1.0 else 1e-5);
    'hbridge.inverter_p.diode_n.i' = 'hbridge.inverter_p.diode_n.s' * (if 'hbridge.inverter_p.diode_n.off' then 1e-5 else 1.0);
    'hbridge.inverter_p.diode_n.LossPower' = 'hbridge.inverter_p.diode_n.v' * 'hbridge.inverter_p.diode_n.i';
    'hbridge.inverter_p.diode_n.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_p.diode_n.p.i' + 'hbridge.inverter_p.diode_n.n.i';
    'hbridge.inverter_p.diode_n.i' = 'hbridge.inverter_p.diode_n.p.i';
    'hbridge.inverter_p.diode_n.v' = 'hbridge.inverter_p.diode_n.p.v' - 'hbridge.inverter_p.diode_n.n.v';
    'hbridge.inverter_p.LossPower' = 'hbridge.inverter_p.transistor_p.LossPower' + 'hbridge.inverter_p.diode_n.LossPower' + 'hbridge.inverter_p.transistor_n.LossPower' + 'hbridge.inverter_p.diode_n.LossPower';
    'hbridge.inverter_p.T_heatPort' = 293.15;
    'hbridge.inverter_n.enableLogic.enableConstantSource.y' = true;
    'hbridge.inverter_n.enableLogic.booleanReplicator.y[1]' = 'hbridge.inverter_n.enableLogic.booleanReplicator.u';
    'hbridge.inverter_n.andCondition_p.y' = 'hbridge.inverter_n.andCondition_p.u1' and 'hbridge.inverter_n.andCondition_p.u2';
    'hbridge.inverter_n.andCondition_n.y' = 'hbridge.inverter_n.andCondition_n.u1' and 'hbridge.inverter_n.andCondition_n.u2';
    'hbridge.inverter_n.transistor_p.off' = 'hbridge.inverter_n.transistor_p.s' < 0.0 or not 'hbridge.inverter_n.transistor_p.fire';
    'hbridge.inverter_n.transistor_p.v' = 'hbridge.inverter_n.transistor_p.s' * (if 'hbridge.inverter_n.transistor_p.off' then 1.0 else 1e-5);
    'hbridge.inverter_n.transistor_p.i' = 'hbridge.inverter_n.transistor_p.s' * (if 'hbridge.inverter_n.transistor_p.off' then 1e-5 else 1.0);
    'hbridge.inverter_n.transistor_p.LossPower' = 'hbridge.inverter_n.transistor_p.v' * 'hbridge.inverter_n.transistor_p.i';
    'hbridge.inverter_n.transistor_p.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_n.transistor_p.p.i' + 'hbridge.inverter_n.transistor_p.n.i';
    'hbridge.inverter_n.transistor_p.i' = 'hbridge.inverter_n.transistor_p.p.i';
    'hbridge.inverter_n.transistor_p.v' = 'hbridge.inverter_n.transistor_p.p.v' - 'hbridge.inverter_n.transistor_p.n.v';
    'hbridge.inverter_n.diode_p.off' = 'hbridge.inverter_n.diode_p.s' < 0.0;
    'hbridge.inverter_n.diode_p.v' = 'hbridge.inverter_n.diode_p.s' * (if 'hbridge.inverter_n.diode_p.off' then 1.0 else 1e-5);
    'hbridge.inverter_n.diode_p.i' = 'hbridge.inverter_n.diode_p.s' * (if 'hbridge.inverter_n.diode_p.off' then 1e-5 else 1.0);
    'hbridge.inverter_n.diode_p.LossPower' = 'hbridge.inverter_n.diode_p.v' * 'hbridge.inverter_n.diode_p.i';
    'hbridge.inverter_n.diode_p.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_n.diode_p.p.i' + 'hbridge.inverter_n.diode_p.n.i';
    'hbridge.inverter_n.diode_p.i' = 'hbridge.inverter_n.diode_p.p.i';
    'hbridge.inverter_n.diode_p.v' = 'hbridge.inverter_n.diode_p.p.v' - 'hbridge.inverter_n.diode_p.n.v';
    'hbridge.inverter_n.transistor_n.off' = 'hbridge.inverter_n.transistor_n.s' < 0.0 or not 'hbridge.inverter_n.transistor_n.fire';
    'hbridge.inverter_n.transistor_n.v' = 'hbridge.inverter_n.transistor_n.s' * (if 'hbridge.inverter_n.transistor_n.off' then 1.0 else 1e-5);
    'hbridge.inverter_n.transistor_n.i' = 'hbridge.inverter_n.transistor_n.s' * (if 'hbridge.inverter_n.transistor_n.off' then 1e-5 else 1.0);
    'hbridge.inverter_n.transistor_n.LossPower' = 'hbridge.inverter_n.transistor_n.v' * 'hbridge.inverter_n.transistor_n.i';
    'hbridge.inverter_n.transistor_n.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_n.transistor_n.p.i' + 'hbridge.inverter_n.transistor_n.n.i';
    'hbridge.inverter_n.transistor_n.i' = 'hbridge.inverter_n.transistor_n.p.i';
    'hbridge.inverter_n.transistor_n.v' = 'hbridge.inverter_n.transistor_n.p.v' - 'hbridge.inverter_n.transistor_n.n.v';
    'hbridge.inverter_n.diode_n.off' = 'hbridge.inverter_n.diode_n.s' < 0.0;
    'hbridge.inverter_n.diode_n.v' = 'hbridge.inverter_n.diode_n.s' * (if 'hbridge.inverter_n.diode_n.off' then 1.0 else 1e-5);
    'hbridge.inverter_n.diode_n.i' = 'hbridge.inverter_n.diode_n.s' * (if 'hbridge.inverter_n.diode_n.off' then 1e-5 else 1.0);
    'hbridge.inverter_n.diode_n.LossPower' = 'hbridge.inverter_n.diode_n.v' * 'hbridge.inverter_n.diode_n.i';
    'hbridge.inverter_n.diode_n.T_heatPort' = 293.15;
    0.0 = 'hbridge.inverter_n.diode_n.p.i' + 'hbridge.inverter_n.diode_n.n.i';
    'hbridge.inverter_n.diode_n.i' = 'hbridge.inverter_n.diode_n.p.i';
    'hbridge.inverter_n.diode_n.v' = 'hbridge.inverter_n.diode_n.p.v' - 'hbridge.inverter_n.diode_n.n.v';
    'hbridge.inverter_n.LossPower' = 'hbridge.inverter_n.transistor_p.LossPower' + 'hbridge.inverter_n.diode_n.LossPower' + 'hbridge.inverter_n.transistor_n.LossPower' + 'hbridge.inverter_n.diode_n.LossPower';
    'hbridge.inverter_n.T_heatPort' = 293.15;
    'hbridge.not_p.y' = not 'hbridge.not_p.u';
    'hbridge.not_n.y' = not 'hbridge.not_n.u';
    'hbridge.LossPower' = 'hbridge.inverter_p.LossPower' + 'hbridge.inverter_n.LossPower';
    'hbridge.T_heatPort' = 293.15;
    'constantVoltage.v' = 100.0;
    0.0 = 'constantVoltage.p.i' + 'constantVoltage.n.i';
    'constantVoltage.i' = 'constantVoltage.p.i';
    'constantVoltage.v' = 'constantVoltage.p.v' - 'constantVoltage.n.v';
    'signalPWM.const.y' = 0.6;
    'signalPWM.limiter.simplifiedExpr' = 'signalPWM.limiter.u';
    'signalPWM.limiter.y' = homotopy(smooth(0, if 'signalPWM.limiter.u' > 1.0 then 1.0 else if 'signalPWM.limiter.u' < 0.0 then 0.0 else 'signalPWM.limiter.u'), 'signalPWM.limiter.simplifiedExpr');

    when {'signalPWM.zeroOrderHold.sampleTrigger', initial()} then
      'signalPWM.zeroOrderHold.ySample' = if time >= 0.0 then 'signalPWM.zeroOrderHold.u' else pre('signalPWM.zeroOrderHold.ySample');
    end when;

    'signalPWM.zeroOrderHold.y' = pre('signalPWM.zeroOrderHold.ySample');
    'signalPWM.zeroOrderHold.sampleTrigger' = sample(0.0, 0.001);

    when 'signalPWM.zeroOrderHold.sampleTrigger' then
      'signalPWM.zeroOrderHold.firstTrigger' = time <= 5e-4;
    end when;

    when time >= (pre('signalPWM.sawtooth.count') + 1) * 0.001 then
      'signalPWM.sawtooth.count' = pre('signalPWM.sawtooth.count') + 1;
      'signalPWM.sawtooth.T_start' = time;
    end when;

    'signalPWM.sawtooth.y' = if time < 0.0 then 0.0 else (time - 'signalPWM.sawtooth.T_start') / 0.001;
    'signalPWM.greaterEqual_p.y' = 'signalPWM.greaterEqual_p.u1' > 'signalPWM.greaterEqual_p.u2';
    'signalPWM.inverse.y' = not 'signalPWM.inverse.u';
    'ground.p.v' = 0.0;
    'currentSensor.p.v' = 'currentSensor.n.v';
    'currentSensor.p.i' = 'currentSensor.i';
    'currentSensor.n.i' = -'currentSensor.i';
    'voltageSensor.p.i' = 0.0;
    'voltageSensor.n.i' = 0.0;
    'voltageSensor.v' = 'voltageSensor.p.v' - 'voltageSensor.n.v';
    der('meanCurrent.x') = 'meanCurrent.u';

    when sample('meanCurrent.t0' + 0.001, 0.001) then
      'meanCurrent.y_last' = 1000.0 * pre('meanCurrent.x');
      reinit('meanCurrent.x', 0.0);
    end when;

    'meanCurrent.y' = 'meanCurrent.y_last';
    der('meanVoltage.x') = 'meanVoltage.u';

    when sample('meanVoltage.t0' + 0.001, 0.001) then
      'meanVoltage.y_last' = 1000.0 * pre('meanVoltage.x');
      reinit('meanVoltage.x', 0.0);
    end when;

    'meanVoltage.y' = 'meanVoltage.y_last';
    'resistor.R_actual' = 100.0;
    'resistor.v' = 'resistor.R_actual' * 'resistor.i';
    'resistor.LossPower' = 'resistor.v' * 'resistor.i';
    'resistor.T_heatPort' = 300.15;
    0.0 = 'resistor.p.i' + 'resistor.n.i';
    'resistor.i' = 'resistor.p.i';
    'resistor.v' = 'resistor.p.v' - 'resistor.n.v';
    der('inductor.i') = 'inductor.v';
    0.0 = 'inductor.p.i' + 'inductor.n.i';
    'inductor.i' = 'inductor.p.i';
    'inductor.v' = 'inductor.p.v' - 'inductor.n.v';
  initial algorithm
    'signalPWM.sawtooth.count' := integer(time / 0.001);
    'signalPWM.sawtooth.T_start' := 'signalPWM.sawtooth.count' * 0.001;
    annotation(experiment(StopTime = 0.1, Interval = 0.0002, Tolerance = 1e-06));
  end 'HBridge_RL';
end 'HBridge_RL';
