    'resistor.p.i' + 'voltageSensor.p.i' + 'hbridge.dc_p2.i' = 0.0;
    'inductor.p.i' + 'resistor.n.i' = 0.0;
    'inductor.n.i' + 'voltageSensor.n.i' + 'currentSensor.p.i' = 0.0;
    'hbridge.enableLogic.enableConstantSource.y' = true;
    'hbridge.enableLogic.booleanReplicator.y[1]' = 'hbridge.enableLogic.booleanReplicator.u';
