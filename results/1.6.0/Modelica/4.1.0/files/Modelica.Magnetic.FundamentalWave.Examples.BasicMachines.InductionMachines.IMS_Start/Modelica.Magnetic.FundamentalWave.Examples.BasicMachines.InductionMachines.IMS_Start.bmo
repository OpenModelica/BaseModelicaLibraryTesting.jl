    Real 'aimsM.rotor.stray.arg_Phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 'Modelica.Math.atan3'('aimsM.rotor.stray.Phi.im', 'aimsM.rotor.stray.Phi.re', 0.0) "Argument of complex magnetic flux";
