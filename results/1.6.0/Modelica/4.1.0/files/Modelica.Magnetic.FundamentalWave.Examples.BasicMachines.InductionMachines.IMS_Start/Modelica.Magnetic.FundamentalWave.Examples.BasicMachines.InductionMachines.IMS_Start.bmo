    Boolean 'idealCloser.control[1]' "true => p--n connected, false => switch open";
    Boolean 'idealCloser.control[2]' "true => p--n connected, false => switch open";
    Boolean 'idealCloser.control[3]' "true => p--n connected, false => switch open";
    Real 'idealCloser.idealClosingSwitch[1].v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'idealCloser.idealClosingSwitch[1].p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'idealCloser.idealClosingSwitch[1].p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'idealCloser.idealClosingSwitch[1].n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
