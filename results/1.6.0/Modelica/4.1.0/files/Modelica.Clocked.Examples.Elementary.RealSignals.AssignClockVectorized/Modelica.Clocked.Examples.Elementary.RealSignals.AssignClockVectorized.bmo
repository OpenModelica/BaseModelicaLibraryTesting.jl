//! base 0.1.0
package 'AssignClockVectorized'
  type 'Modelica.Clocked.Types.Resolution' = enumeration('y', 'd', 'h', 'm', 's', 'ms', 'us', 'ns');

  model 'AssignClockVectorized' "Example of a AssignClockVectorized block for Real signals"
    parameter Integer 'periodicClock.factor'(min = 0) = 20 "Sample factor with respect to resolution" annotation(Evaluate = true);
    parameter 'Modelica.Clocked.Types.Resolution' 'periodicClock.resolution' = 'Modelica.Clocked.Types.Resolution'.'ms' "Clock resolution" annotation(Evaluate = true);
    parameter Boolean 'periodicClock.useSolver' = false "= true, if solverMethod shall be explicitly defined" annotation(Evaluate = true);
    parameter String 'periodicClock.solverMethod' = "ExplicitEuler" "Integration method used for discretized continuous-time partitions";
    Clock 'periodicClock.y';
    constant Integer 'periodicClock.conversionTable[1]' = 31536000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[2]' = 86400 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[3]' = 3600 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[4]' = 60 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[5]' = 1 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[6]' = 1000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[7]' = 1000000 "Table to convert from Resolution to Integer clock resolution";
    constant Integer 'periodicClock.conversionTable[8]' = 1000000000 "Table to convert from Resolution to Integer clock resolution";
    parameter Integer 'periodicClock.resolutionFactor' = 1000 annotation(Evaluate = true);
    Clock 'periodicClock.c';
    Real 'unitDelay1.u'(start = 0.0) "Connector of clocked, Real input signal";
    Real 'unitDelay1.y' "Connector of clocked, Real output signal";
    parameter Real 'unitDelay1.y_start' = 0.0 "Value of output signal at first clock tick";
    Real 'add.u1' "Connector of Real input signal 1";
    Real 'add.u2' "Connector of Real input signal 2";
    Real 'add.y' "Connector of Real output signal";
    parameter Real 'add.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'add.k2' = 1.0 "Gain of input signal 2";
    parameter Real 'const.k'(start = 1.0) = 1.0 "Constant output value";
    Real 'const.y' "Connector of Real output signal";
    parameter Integer 'assignClock1.n'(min = 1) = 2 "Size of input signal vector u (= size of output signal vector y)";
    Real 'assignClock1.u[1]' "Connector of clocked, Real input signal";
    Real 'assignClock1.u[2]' "Connector of clocked, Real input signal";
    Real 'assignClock1.y[1]' "Connector of clocked, Real output signal";
    Real 'assignClock1.y[2]' "Connector of clocked, Real output signal";
    Clock 'assignClock1.clock';
    Real 'add1.u1' "Connector of Real input signal 1";
    Real 'add1.u2' "Connector of Real input signal 2";
    Real 'add1.y' "Connector of Real output signal";
    parameter Real 'add1.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'add1.k2' = 1.0 "Gain of input signal 2";
    parameter Real 'const1.k'(start = 1.0) = 2.0 "Constant output value";
    Real 'const1.y' "Connector of Real output signal";
    Real 'unitDelay2.u'(start = 0.0) "Connector of clocked, Real input signal";
    Real 'unitDelay2.y' "Connector of clocked, Real output signal";
    parameter Real 'unitDelay2.y_start' = 0.0 "Value of output signal at first clock tick";
  equation
    'add.u2' = 'const.y';
    'unitDelay1.y' = 'add.u1';
    'periodicClock.y' = 'assignClock1.clock';
    'const1.y' = 'add1.u1';
    'unitDelay2.y' = 'add1.u2';
    'add.y' = 'assignClock1.u[1]';
    'add1.y' = 'assignClock1.u[2]';
    'assignClock1.y[2]' = 'unitDelay2.u';
    'assignClock1.y[1]' = 'unitDelay1.u';
    'periodicClock.c' = Clock('periodicClock.factor', 1000);
    'periodicClock.y' = 'periodicClock.c';
    'unitDelay1.y' = previous('unitDelay1.u');
    'add.y' = 'add.u1' + 'add.u2';
    'const.y' = 1.0;

    when 'assignClock1.clock' then
      'assignClock1.y[1]' = 'assignClock1.u[1]';
      'assignClock1.y[2]' = 'assignClock1.u[2]';
    end when;

    'add1.y' = 'add1.u1' + 'add1.u2';
    'const1.y' = 2.0;
    'unitDelay2.y' = previous('unitDelay2.u');
    annotation(experiment(StopTime = 0.09));
  end 'AssignClockVectorized';
end 'AssignClockVectorized';
