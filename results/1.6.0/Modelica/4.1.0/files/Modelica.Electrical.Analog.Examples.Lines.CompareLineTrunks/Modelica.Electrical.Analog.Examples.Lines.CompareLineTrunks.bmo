//! base 0.1.0
package 'CompareLineTrunks'
  model 'CompareLineTrunks' "Compares oLine and tLine splitting lines into trunks"
    parameter Real 'Rload'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Load resistance";
    parameter Real 'r1'(min = 2.2250738585072014e-308, unit = "Ohm/m") = 1e-6 "Resistance per meter";
    parameter Real 'g1'(min = 2.2250738585072014e-308, unit = "S/m") = 1e-12 "Conductance per meter";
    parameter Real 'l1'(min = 2.2250738585072014e-308, unit = "H/m") = 1e-6 "Inductance per meter";
    parameter Real 'c1'(min = 2.2250738585072014e-308, unit = "F/m") = 1e-11 "Capacitance per meter";
    parameter Real 'len'(unit = "m", quantity = "Length") = 1e5 "Length of line";
    parameter Integer 'segsPerTrunk' = 7 "Segments per trunk";
    parameter Real 'c'(unit = "m/s", quantity = "Velocity") = 3.1622776601683795e8 "Speed of EM wave";
    parameter Real 'td'(unit = "s", quantity = "Time") = 7.905694150420947e-5 "Transmission delay";
    parameter Real 'z0'(unit = "Ohm", quantity = "Resistance") = 316.22776601683796 "Characteristic impedance for very high frequency";
    parameter Real 'ramp.height' = 1.0 "Height of ramp";
    parameter Real 'ramp.duration'(start = 2.0, min = 0.0, unit = "s", quantity = "Time") = 5e-5 "Duration of ramp (= 0.0 gives a Step)";
    Real 'ramp.y' "Connector of Real output signal";
    parameter Real 'ramp.offset' = 0.0 "Offset of output signal y";
    parameter Real 'ramp.startTime'(unit = "s", quantity = "Time") = 4e-4 "Output y = offset for time < startTime";
    Real 'srcLump.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'srcLump.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'srcLump.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'srcLump.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'srcLump.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as input signal";
    Real 'srcLump.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    Real 'ground1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
