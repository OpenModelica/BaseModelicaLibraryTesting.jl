    Real 'oLine1.p3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'oLine1.v13'(unit = "V", quantity = "ElectricPotential");
    Real 'oLine1.v23'(unit = "V", quantity = "ElectricPotential");
    Real 'oLine1.i1'(unit = "A", quantity = "ElectricCurrent");
    Real 'oLine1.i2'(unit = "A", quantity = "ElectricCurrent");
    parameter Real 'oLine1.r'(start = 1.0, min = 2.2250738585072014e-308, unit = "Ohm/m") = 1e-6 "Resistance per meter";
    parameter Real 'oLine1.l'(start = 1.0, min = 2.2250738585072014e-308, unit = "H/m") = 1e-6 "Inductance per meter";
    parameter Real 'oLine1.g'(start = 1.0, min = 2.2250738585072014e-308, unit = "S/m") = 1e-12 "Conductance per meter";
    parameter Real 'oLine1.c'(start = 1.0, min = 2.2250738585072014e-308, unit = "F/m") = 1e-11 "Capacitance per meter";
    parameter Real 'oLine1.length'(start = 1.0, min = 2.2250738585072014e-308, unit = "m", quantity = "Length") = 25000.0 "Length of line";
    parameter Integer 'oLine1.N'(start = 1, min = 1) = 7 "Number of lumped segments";
    parameter Real 'oLine1.alpha_R'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(heatPort.T - T_ref))";
    parameter Real 'oLine1.alpha_G'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of conductance (G_actual = G/(1 + alpha*(heatPort.T - T_ref))";
