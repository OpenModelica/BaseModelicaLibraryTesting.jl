    Real 'V1.signalSource.y' "Connector of Real output signal";
    parameter Real 'V1.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'V1.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'V1.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'V1.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'V2.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 15.0 "Height of ramp";
