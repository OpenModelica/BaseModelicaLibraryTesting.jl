//! base 0.1.0
package 'DifferenceAmplifier'
  function 'Modelica.Electrical.Analog.Semiconductors.exlin' "Exponential function linearly continued for x > Maxexp"
    input Real 'x';
    input Real 'Maxexp';
    output Real 'z';
  algorithm
    'z' := if 'x' > 'Maxexp' then exp('Maxexp') * (1.0 + 'x' - 'Maxexp') else exp('x');
  end 'Modelica.Electrical.Analog.Semiconductors.exlin';

  function 'Modelica.Electrical.Analog.Semiconductors.exlin2' "Exponential function linearly continued for x < MinExp and x > Maxexp"
    input Real 'x';
    input Real 'Minexp';
    input Real 'Maxexp';
    output Real 'z';
  algorithm
    'z' := if 'x' < 'Minexp' then exp('Minexp') * (1.0 + 'x' - 'Minexp') else 'Modelica.Electrical.Analog.Semiconductors.exlin'('x', 'Maxexp');
  end 'Modelica.Electrical.Analog.Semiconductors.exlin2';

  function 'Modelica.Electrical.Analog.Semiconductors.pow' "Just a helper function for x^y in order that a symbolic engine can apply some transformations more easily"
    input Real 'x';
    input Real 'y';
    output Real 'z';
  algorithm
    'z' := 'x' ^ 'y';
  end 'Modelica.Electrical.Analog.Semiconductors.pow';

  function 'Modelica.Electrical.Analog.Semiconductors.powlin' "Power function (1 - x)^(-y) linearly continued for x > 0 (provided y = const.)"
    input Real 'x';
    input Real 'y';
    output Real 'z';
  algorithm
    'z' := if 'x' > 0.0 then 1.0 + 'y' * 'x' else 'Modelica.Electrical.Analog.Semiconductors.pow'(1.0 - 'x', -'y');
  end 'Modelica.Electrical.Analog.Semiconductors.powlin';

  model 'DifferenceAmplifier' "Simple NPN transistor amplifier circuit"
    parameter Real 'V1.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 0.2 "Amplitude of sine wave";
    parameter Real 'V1.f'(start = 2.0, unit = "Hz", quantity = "Frequency") = 2e8 "Frequency of sine wave";
    parameter Real 'V1.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Real 'V1.damping'(start = 1.0, unit = "s-1", quantity = "DampingCoefficient") = 1e7 "Damping coefficient of sine wave";
    Real 'V1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'V1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'V1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'V1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'V1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'V1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'V1.signalSource.amplitude' = 0.2 "Amplitude of sine wave";
    parameter Real 'V1.signalSource.f'(start = 2.0, unit = "Hz", quantity = "Frequency") = 2e8 "Frequency of sine wave";
