//! base 0.1.0
package 'ThyristorBehaviourTest'
  model 'ThyristorBehaviourTest' "Thyristor demonstration example"
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'sineVoltage.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 30.0 "Amplitude of sine wave";
    parameter Real 'sineVoltage.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Real 'sineVoltage.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1e4 "Frequency of sine wave";
    Real 'sineVoltage.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'sineVoltage.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'sineVoltage.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'sineVoltage.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'sineVoltage.signalSource.amplitude' = 30.0 "Amplitude of sine wave";
    parameter Real 'sineVoltage.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1e4 "Frequency of sine wave";
    parameter Real 'sineVoltage.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'sineVoltage.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'sineVoltage.signalSource.y' "Connector of Real output signal";
    parameter Real 'sineVoltage.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'sineVoltage.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'sineVoltage.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'sineVoltage.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'resistor.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 10.0 "Resistance at temperature T_ref";
    parameter Real 'resistor.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'pulseCurrent.I'(start = 1.0, unit = "A", quantity = "ElectricCurrent") = 0.005 "Amplitude of pulse";
    parameter Real 'pulseCurrent.width'(start = 50.0, max = 100.0, min = 2.2250738585072014e-308) = 10.0 "Width of pulse in % of period";
    parameter Real 'pulseCurrent.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 1e-4 "Time for one period";
    Real 'pulseCurrent.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'pulseCurrent.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'pulseCurrent.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'pulseCurrent.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'pulseCurrent.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'pulseCurrent.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'pulseCurrent.signalSource.amplitude' = 0.005 "Amplitude of pulse";
    parameter Real 'pulseCurrent.signalSource.width'(max = 100.0, min = 2.2250738585072014e-308) = 10.0 "Width of pulse in % of period";
    parameter Real 'pulseCurrent.signalSource.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 1e-4 "Time for one period";
    parameter Integer 'pulseCurrent.signalSource.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'pulseCurrent.signalSource.y' "Connector of Real output signal";
    parameter Real 'pulseCurrent.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'pulseCurrent.signalSource.startTime'(unit = "s", quantity = "Time") = 2e-5 "Output y = offset for time < startTime";
    Real 'pulseCurrent.signalSource.T_width'(unit = "s", quantity = "Time") = 1e-5;
    Real 'pulseCurrent.signalSource.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'pulseCurrent.signalSource.count' "Period count";
    parameter Real 'pulseCurrent.offset'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Current offset";
    parameter Real 'pulseCurrent.startTime'(unit = "s", quantity = "Time") = 2e-5 "Time offset";
    parameter Real 'thyristor_v4_1.VDRM'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 100.0 "Forward breakthrough voltage";
    parameter Real 'thyristor_v4_1.VRRM'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 100.0 "Reverse breakthrough voltage";
    parameter Real 'thyristor_v4_1.IDRM'(unit = "A", quantity = "ElectricCurrent") = 0.1 "Saturation current";
    parameter Real 'thyristor_v4_1.VTM'(unit = "V", quantity = "ElectricPotential") = 1.7 "Conducting voltage";
    parameter Real 'thyristor_v4_1.IH'(unit = "A", quantity = "ElectricCurrent") = 0.006 "Holding current";
    parameter Real 'thyristor_v4_1.ITM'(unit = "A", quantity = "ElectricCurrent") = 25.0 "Conducting current";
    parameter Real 'thyristor_v4_1.VGT'(unit = "V", quantity = "ElectricPotential") = 0.7 "Gate trigger voltage";
    parameter Real 'thyristor_v4_1.IGT'(unit = "A", quantity = "ElectricCurrent") = 0.005 "Gate trigger current";
    parameter Real 'thyristor_v4_1.TON'(unit = "s", quantity = "Time") = 1e-6 "Switch on time";
    parameter Real 'thyristor_v4_1.TOFF'(unit = "s", quantity = "Time") = 1.5e-5 "Switch off time";
    parameter Real 'thyristor_v4_1.Vt'(unit = "V", quantity = "ElectricPotential") = 0.04 "Voltage equivalent of temperature (kT/qn)";
    parameter Real 'thyristor_v4_1.Nbv' = 0.74 "Reverse Breakthrough emission coefficient";
    parameter Boolean 'thyristor_v4_1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'thyristor_v4_1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'thyristor_v4_1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'thyristor_v4_1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'thyristor_v4_1.iGK'(unit = "A", quantity = "ElectricCurrent") "Gate current";
    Real 'thyristor_v4_1.vGK'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage between gate and cathode";
    Real 'thyristor_v4_1.vAK'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage between anode and cathode";
    Real 'thyristor_v4_1.vControl'(fixed = true, start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'thyristor_v4_1.vContot'(unit = "V", quantity = "ElectricPotential");
    Real 'thyristor_v4_1.vConmain'(unit = "V", quantity = "ElectricPotential");
    parameter Real 'thyristor_v4_1.vRef'(unit = "V", quantity = "ElectricPotential") = 0.65;
    Real 'thyristor_v4_1.Anode.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'thyristor_v4_1.Anode.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'thyristor_v4_1.Cathode.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'thyristor_v4_1.Cathode.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'thyristor_v4_1.Gate.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'thyristor_v4_1.Gate.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'thyristor_v4_1.Von'(unit = "V", quantity = "ElectricPotential") = 5.0;
    parameter Real 'thyristor_v4_1.Voff'(unit = "V", quantity = "ElectricPotential") = 1.5;
    parameter Real 'thyristor_v4_1.Ron'(unit = "Ohm", quantity = "Resistance") = 0.04 "Forward conducting mode resistance";
    parameter Real 'thyristor_v4_1.Roff'(unit = "Ohm", quantity = "Resistance") = 980392.1568627452 "Blocking mode resistance";
    Real 'inductor.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'inductor.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'inductor.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'inductor.i'(fixed = true, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'inductor.L'(start = 1.0, unit = "H", quantity = "Inductance") = 2e-6 "Inductance";
  equation
    'inductor.n.v' = 'ground.p.v';
    'inductor.n.v' = 'sineVoltage.n.v';
    'sineVoltage.p.v' = 'thyristor_v4_1.Anode.v';
    'resistor.p.v' = 'pulseCurrent.p.v';
    'resistor.p.v' = 'thyristor_v4_1.Cathode.v';
    'pulseCurrent.n.v' = 'thyristor_v4_1.Gate.v';
    'resistor.n.v' = 'inductor.p.v';
    'thyristor_v4_1.Anode.i' + 'sineVoltage.p.i' = 0.0;
    'inductor.n.i' + 'sineVoltage.n.i' + 'ground.p.i' = 0.0;
    'inductor.p.i' + 'resistor.n.i' = 0.0;
    'thyristor_v4_1.Gate.i' + 'pulseCurrent.n.i' = 0.0;
    'thyristor_v4_1.Cathode.i' + 'pulseCurrent.p.i' + 'resistor.p.i' = 0.0;
    'ground.p.v' = 0.0;
    'sineVoltage.signalSource.y' = if time < 0.0 then 0.0 else 30.0 * sin(62831.853071795864 * time);
    'sineVoltage.v' = 'sineVoltage.signalSource.y';
    0.0 = 'sineVoltage.p.i' + 'sineVoltage.n.i';
    'sineVoltage.i' = 'sineVoltage.p.i';
    'sineVoltage.v' = 'sineVoltage.p.v' - 'sineVoltage.n.v';
    'resistor.R_actual' = 10.0;
    'resistor.v' = 'resistor.R_actual' * 'resistor.i';
    'resistor.LossPower' = 'resistor.v' * 'resistor.i';
    'resistor.T_heatPort' = 300.15;
    0.0 = 'resistor.p.i' + 'resistor.n.i';
    'resistor.i' = 'resistor.p.i';
    'resistor.v' = 'resistor.p.v' - 'resistor.n.v';

    when time >= (pre('pulseCurrent.signalSource.count') + 1) * 1e-4 + 2e-5 then
      'pulseCurrent.signalSource.count' = pre('pulseCurrent.signalSource.count') + 1;
      'pulseCurrent.signalSource.T_start' = time;
    end when;

    'pulseCurrent.signalSource.y' = if time < 2e-5 then 0.0 else if time < 'pulseCurrent.signalSource.T_start' + 'pulseCurrent.signalSource.T_width' then 0.005 else 0.0;
    'pulseCurrent.i' = 'pulseCurrent.signalSource.y';
    0.0 = 'pulseCurrent.p.i' + 'pulseCurrent.n.i';
    'pulseCurrent.i' = 'pulseCurrent.p.i';
    'pulseCurrent.v' = 'pulseCurrent.p.v' - 'pulseCurrent.n.v';
    'thyristor_v4_1.Anode.i' + 'thyristor_v4_1.Gate.i' + 'thyristor_v4_1.Cathode.i' = 0.0;
    'thyristor_v4_1.vGK' = 'thyristor_v4_1.Gate.v' - 'thyristor_v4_1.Cathode.v';
    'thyristor_v4_1.vAK' = 'thyristor_v4_1.Anode.v' - 'thyristor_v4_1.Cathode.v';
    'thyristor_v4_1.iGK' = 'thyristor_v4_1.Gate.i';
    'thyristor_v4_1.vGK' = smooth(0, if 'thyristor_v4_1.vGK' < 0.65 then 140.0 * 'thyristor_v4_1.iGK' else 0.6035714285714286 + 'thyristor_v4_1.iGK' * 0.04999999999999993 / 0.005);
    'thyristor_v4_1.vContot' = 'thyristor_v4_1.vConmain' + smooth(0, if 'thyristor_v4_1.iGK' < 0.00475 then 0.0 else if 'thyristor_v4_1.iGK' < 0.00575 then 1e4 * ('thyristor_v4_1.iGK' - 0.00475) * 'thyristor_v4_1.vAK' else 10.0 * 'thyristor_v4_1.vAK');
    der('thyristor_v4_1.vControl') = ('thyristor_v4_1.vContot' - 'thyristor_v4_1.vControl') / (if 'thyristor_v4_1.vContot' - 'thyristor_v4_1.vControl' > 0.0 then 1.87e-6 else 9.57e-6);
    'thyristor_v4_1.Anode.i' = smooth(1, if 'thyristor_v4_1.vAK' < (-100.0) then -1.0199999999999999e-4 * exp(-('thyristor_v4_1.vAK' + 100.0) / 0.0296) else if 'thyristor_v4_1.vControl' < 1.5 then 'thyristor_v4_1.vAK' / 980392.1568627452 else if 'thyristor_v4_1.vControl' < 5.0 then 'thyristor_v4_1.vAK' / (198.02950859533487 * 4.0799999999999995e-8 ^ ((3.0 * ((2.0 * 'thyristor_v4_1.vControl' - 5.0 - 1.5) / 7.0) - 4.0 * ((2.0 * 'thyristor_v4_1.vControl' - 5.0 - 1.5) / 7.0) ^ 3.0) / 2.0)) else 'thyristor_v4_1.vAK' / 0.04);
    'thyristor_v4_1.vConmain' = if 'thyristor_v4_1.Anode.i' > 0.006 or 'thyristor_v4_1.vAK' > 100.0 then 5.0 else 0.0;
    'thyristor_v4_1.LossPower' = 'thyristor_v4_1.Anode.i' * 'thyristor_v4_1.Anode.v' + 'thyristor_v4_1.Cathode.i' * 'thyristor_v4_1.Cathode.v' + 'thyristor_v4_1.Gate.i' * 'thyristor_v4_1.Gate.v';
    'thyristor_v4_1.T_heatPort' = 293.15;
    2e-6 * der('inductor.i') = 'inductor.v';
    0.0 = 'inductor.p.i' + 'inductor.n.i';
    'inductor.i' = 'inductor.p.i';
    'inductor.v' = 'inductor.p.v' - 'inductor.n.v';
  initial algorithm
    'pulseCurrent.signalSource.count' := integer((time - 2e-5) / 1e-4);
    'pulseCurrent.signalSource.T_start' := 2e-5 + 'pulseCurrent.signalSource.count' * 1e-4;
    annotation(experiment(StopTime = 0.0002));
  end 'ThyristorBehaviourTest';
end 'ThyristorBehaviourTest';
